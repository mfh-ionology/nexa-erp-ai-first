# ERP Database (per-tenant PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/nexa_erp
# Direct connection for DDL/migrations (set separately if using PgBouncer for DATABASE_URL)
DIRECT_URL=postgresql://user:password@localhost:5432/nexa_erp

# Platform Database (central PostgreSQL)
PLATFORM_DATABASE_URL=postgresql://nexa_platform:nexa_platform_dev_pass@localhost:5433/nexa_platform_dev

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-jwt-secret-here

# Prisma (allow destructive migration operations in dev)
PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=yes

# S3 / MinIO (Object Storage)
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-west-2
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=nexa-attachments
S3_FORCE_PATH_STYLE=true

# AI
CLAUDE_API_KEY=your-claude-api-key-here

# Platform API ↔ ERP API shared service token (required for AI module to initialize)
PLATFORM_SERVICE_TOKEN=your-platform-service-token-here
PLATFORM_API_URL=http://localhost:5101/api/v1

# AI encryption key for BYOK API key storage (32+ chars recommended)
AI_ENCRYPTION_KEY=your-ai-encryption-key-here-32ch

# SMTP (Email Notifications)
# For dev: use Mailtrap (smtp.mailtrap.io) or Ethereal (ethereal.email)
# For prod: use SendGrid (smtp.sendgrid.net), SES, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Nexa ERP
SMTP_FROM_EMAIL=noreply@nexa-erp.com
