# ERP Database (per-tenant PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/nexa_erp
# Direct connection for DDL/migrations (set separately if using PgBouncer for DATABASE_URL)
DIRECT_URL=postgresql://user:password@localhost:5432/nexa_erp

# Platform Database (central PostgreSQL)
PLATFORM_DATABASE_URL=postgresql://nexa_platform:nexa_platform_dev_pass@localhost:5433/nexa_platform_dev

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-jwt-secret-here

# Prisma (allow destructive migration operations in dev)
PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=yes

# S3 / MinIO (Object Storage)
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-west-2
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=nexa-attachments
S3_FORCE_PATH_STYLE=true

# AI
CLAUDE_API_KEY=your-claude-api-key-here
