        ExportTagXml("Ref",tstr,5);
        ExportPlainXml("</CdtrRefInf>",4);
        ExportPlainXml("</Strd>",3);
      end else begin
        if (OPrw.PayUrgency!=kPaymentUrgencyNormal or 
           (OPrw.PayUrgency==kPaymentUrgencyNormal and blank(VIr.InvoiceNr) and blank(OPrw.BankRefStr)) or 
           ValidateIBAN(bankacc) or 
           OPrw.PayChannel==kPaymentChannelSWEOtherDomestic) then begin
          tstr = OPrw.BankRefStr;
          if (blank(tstr)) then begin
            tstr = VIr.InvoiceNr;
            if (blank(tstr)) then begin
              tstr = Left(OPrw.Comment,50);
            end;
          end;
          ExportTagXml("Ustrd",tstr,3);
        end else begin
          if (nonblank(OPrw.BankRefStr)) then begin
            ExportPlainXml("<Strd>",3);
            ExportPlainXml("<RfrdDocAmt>",4);
            ExportAttributeTagXml("RmtdAmt",ValToString(OPrw.RecVal,M4Val,"",".",0),"Ccy",OPrw.RecCurncy,5);
            ExportPlainXml("</RfrdDocAmt>",4);
            ExportPlainXml("<CdtrRefInf>",4);
            ExportPlainXml("<Tp>",5);
            ExportPlainXml("<CdOrPrtry>",6);
            ExportTagXml("Cd","SCOR",7);
            ExportPlainXml("</CdOrPrtry>",6);
            ExportPlainXml("</Tp>",5);
            ExportTagXml("Ref",OPrw.BankRefStr,5);
            ExportPlainXml("</CdtrRefInf>",4);
            ExportPlainXml("</Strd>",3);
          end else begin
            if (OPrw.PayChannel==kPaymentChannelSWEBankgiro or OPrw.PayChannel==kPaymentChannelSWEPlusgiro) then begin
              tstr = VIr.InvoiceNr;
            end else begin
              tstr = OPrw.VISerNr;
            end;
            if (nonblank(tstr)) then begin
              ExportPlainXml("<Strd>",3);
              ExportPlainXml("<RfrdDocInf>",4);
              ExportPlainXml("<Tp>",5);
              ExportPlainXml("<CdOrPrtry>",6);
              ExportTagXml("Cd","CINV",7);
              ExportPlainXml("</CdOrPrtry>",6);
              ExportPlainXml("</Tp>",5);
              ExportTagXml("Nb",tstr,5);
              ExportPlainXml("</RfrdDocInf>",4);
              ExportPlainXml("<RfrdDocAmt>",4);
              ExportAttributeTagXml("DuePyblAmt",ValToString(OPrw.RecVal,M4Val,"",".",0),"Ccy",OPrw.RecCurncy,5);
              ExportPlainXml("</RfrdDocAmt>",4);
              ExportPlainXml("</Strd>",3);
              end;
          end;
        end;
      end;


//       if ((ForeignPaymf) or (left(CYb.Bank2,2)!=country)) and (Bankr.Sorting == "Foreign") then begin
//         tstr1 = "Invoice:" & left(refstr,122);
//         ExportTagXml("Ustrd",left(tstr1,140),3);    
