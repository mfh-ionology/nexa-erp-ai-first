//           ExportPlainXml("</Tp>",5);  
//           ExportTagXml("Nb",VIr.SerNr,5);               
//           ExportTagXml("RltdDt",DateToString(VIr.TransDate,"YYYY-MM-DD"),5);
//           ExportPlainXml("</RfrdDocInf>",4);
