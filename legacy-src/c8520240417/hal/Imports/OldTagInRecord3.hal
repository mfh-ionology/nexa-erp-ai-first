    UTFrw.Alt3 = oldUTFrw.Alt3;
    UTFrw.Alt4 = oldUTFrw.Alt4;
    UTFrw.Alt5 = oldUTFrw.Alt5;
    UTFrw.Alt6 = oldUTFrw.Alt6;
    UTFrw.Rating1 = oldUTFrw.Rating1;
    UTFrw.Rating2 = oldUTFrw.Rating2;
    MatRowPut(UTFr,rwcnt,UTFrw);

    rwcnt = rwcnt + 1;
  end; 

  ReadRecordTextField(oldUTFr,"Math2");
  SetTextField(UTFr,GetTextField(oldUTFr));
  return;
end;

global
updating procedure ReadImportTagUnivTestFeedbackVc()
begin
  record UnivTestFeedback2Vc UTFr;
  record UnivTestFeedbackVc oldUTFr;
  record ModuleBlock Modb;

  BlockLoad(Modb);

  while (NextImportLine(false)) begin
    ReadImportTagUnivTestFeedbackVcRecord(UTFr,oldUTFr);
    if (Modb.CourseBookingConversion<>0) then begin
      if (RecordImportStore(UTFr,false)) then begin end;
    end else begin
      if (RecordImportStore(oldUTFr,false)) then begin end;
    end;
    
  end;
LReadImportTagUnivTestFeedbackVc:;
  return;
end;
