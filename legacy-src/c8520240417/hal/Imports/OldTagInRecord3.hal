  oldCourser.Terminated = StringToInt(ImportField);
  oldCourser.Class = ImportField;
  oldCourser.Type = ImportField;
  oldCourser.MaxPersons = StringToLongInt(ImportField);
  oldCourser.Length = ImportField;
  oldCourser.ItemCode = ImportField;
  oldCourser.Responsible = ImportField;
  oldCourser.ActType = ImportField;
  oldCourser.SMSReminderText = ImportField;
  oldCourser.ShortName = ImportField;
  oldCourser.StartDate = StringToDate(ImportField);
  oldCourser.EndDate = StringToDate(ImportField);
  oldCourser.Visibility = StringToInt(ImportField);
  oldCourser.Classification = ImportField;
  oldCourser.Format = StringToInt(ImportField);
  oldCourser.Groups = StringToInt(ImportField);
  oldCourser.Teachers = ImportField;
  oldCourser.Departments = ImportField;
  oldCourser.RegKey = ImportField;
  oldCourser.EnableSelfEnrol = StringToInt(ImportField);

  RecordNew(Courser);
  Courser.prevCode = oldCourser.Code;
  Courser.Name = oldCourser.Name;
  Courser.Contact = oldCourser.Contact;
  Courser.ContactSClass = oldCourser.ContactSClass;
  Courser.PricePrHour = oldCourser.PricePrHour;
  Courser.Description = oldCourser.Description;
  Courser.Terminated = oldCourser.Terminated;
  Courser.Class = oldCourser.Class;
  Courser.Type = oldCourser.Type;
  Courser.MaxPersons = oldCourser.MaxPersons;
  Courser.Length = oldCourser.Length;
  Courser.ItemCode = oldCourser.ItemCode;
  Courser.Responsible = oldCourser.Responsible;
  Courser.ActType = oldCourser.ActType;
  Courser.SMSReminderText = oldCourser.SMSReminderText;
  Courser.ShortName = oldCourser.ShortName;
  Courser.StartDate = oldCourser.StartDate;
  Courser.EndDate = oldCourser.EndDate;
  Courser.Visibility = oldCourser.Visibility;
  Courser.Classification = oldCourser.Classification;
  Courser.Format = oldCourser.Format;
  Courser.Groups = oldCourser.Groups;
  Courser.Teachers = oldCourser.Teachers;
  Courser.Departments = oldCourser.Departments;
  Courser.RegKey = oldCourser.RegKey;
  Courser.EnableSelfEnrol = oldCourser.EnableSelfEnrol;
  Courser.SerNr = NextSerNr("Course2Vc",CurrentDate,-1,false,"");

  rwcnt = 0;
  while (NextImportLine(false)) begin
    ClearRow(oldCourser,oldCourserw,1);
    oldCourserw.LangCode = ImportField;
    oldCourserw.LangName = ImportField;
    oldCourserw.LangDescription = ImportField;
    oldCourserw.LangLength = ImportField;
    MatRowPut(oldCourser,rwcnt,oldCourserw);

    ClearRow(Courser,Courserw,1);
    Courserw.LangCode = oldCourserw.LangCode;
    Courserw.LangName = oldCourserw.LangName;
    Courserw.LangDescription = oldCourserw.LangDescription;
    Courserw.LangLength = oldCourserw.LangLength;
    MatRowPut(Courser,rwcnt,Courserw);

    rwcnt = rwcnt + 1;
  end; 

  ReadRecordTextField(oldCourser,"Math2");
  SetTextField(Courser,GetTextField(oldCourser));
end;

global
updating procedure ReadImportTagCourseVc()
begin
  record Course2Vc Courser;
  record CourseVc oldCourser;
  record ModuleBlock Modb;

  BlockLoad(Modb);

  while (NextImportLine(false)) begin
    ReadImportTagCourseVcRecord(Courser,oldCourser);
    if (Modb.CourseBookingConversion<>0) then begin
      if (RecordImportStore(Courser,false)) then begin end;
    end else begin
      if (RecordImportStore(oldCourser,false)) then begin end;
    end;
  end;
LReadImportTagCourseVc:;
  return;
end;

