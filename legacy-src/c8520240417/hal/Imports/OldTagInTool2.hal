procedure ReadImportTagRestAccVc2Record(record RestAccVc RAr)
begin
  record TaxMatrixVc TMr;
  string 255 tstr;
  row RestAccVc RArw;
  integer rwcnt;
  
  RecordNew(RAr);
  RAr.SerNr = StringToLongint(ImportField);
  RAr.TransDate = StringToDate(ImportField);
  RAr.TransTime = StringToTime(ImportField);
  RAr.CustCode = ImportField;
  RAr.Cashier = ImportField;
  RAr.Comment = ImportField;
  RAr.Closed = StringToInt(ImportField);
  RAr.Sum4 = StringToVal(ImportField,M4Val);
  RAr.Sum1 = StringToVal(ImportField,M4Val);
  RAr.Paid = StringToVal(ImportField,M4Val);
  RAr.Resource = ImportField;
  RAr.CreditCard = ImportField;
  RAr.AuthorizationCode = ImportField;
  RAr.PayDeal = ImportField;
  RAr.CUCode = ImportField;
  RAr.CUName = ImportField;
  RAr.MachineName = ImportField;
  RAr.PaySerNr = StringToLongint(ImportField);
  RAr.Invalid = StringToInt(ImportField);
  RAr.SalesGroup = ImportField;
  RAr.GuestCode = ImportField;
  RAr.GuestName = ImportField;
  RAr.NLFlag = StringToInt(ImportField);
  RAr.StockMovFlag = StringToInt(ImportField);
  RAr.Discount = ImportField;
  RAr.Waiter2 = ImportField;
  RAr.CashValue = StringToVal(ImportField,M4Val);
  RAr.RetValue = StringToVal(ImportField,M4Val);
  RAr.Paid2 = StringToVal(ImportField,M4Val);
  RAr.Paid3 = StringToVal(ImportField,M4Val);
  RAr.PayDeal2 = ImportField;
  RAr.PayDeal3 = ImportField;
  RAr.PayDeal4 = ImportField;
  RAr.RemValue = StringToVal(ImportField,M4Val);
  RAr.TendValue = StringToVal(ImportField,M4Val);
  RAr.TipValue = StringToVal(ImportField,M4Val);
  RAr.DrawerCode = ImportField;
  RAr.Persons = StringToLongint(ImportField);
  RAr.AuthorizationCode2 = ImportField;
  RAr.ServCharge = StringToVal(ImportField,M4Val);
  RAr.Objects = ImportField;
  RAr.StockFileName = ImportField;
  RAr.StockTransNr = StringToLongint(ImportField);
  RAr.PriceList = ImportField;
  RAr.TerminalID = ImportField;
  RAr.LoyaltyCardNr = ImportField;
  RAr.LCMLevel = ImportField;
  RAr.Points = StringToVal(ImportField,M4Val);
  RAr.MergedToSerNr = StringToLongint(ImportField);
  RAr.StartTime = StringToTime(ImportField);
  RAr.BranchID = ImportField;
  RAr.ReportingDate = StringToDate(ImportField);
  RAr.Location = ImportField;
  RAr.Class = ImportField;
  ImportPackedMatrix(TMr);
  PackFieldMatrix(RAr,"TaxMatrix",TMr);
  RAr.KitchenOrdNr = StringToLongint(ImportField);
  RAr.Sum3 = StringToVal(ImportField,M4Val);
  RAr.TransferToSL = StringToInt(ImportField);
  RAr.ARAcc = ImportField;
  RAr.RebCode = ImportField;
  RAr.Sum0 = StringToVal(ImportField,M4Val);
  RAr.FiscalFlag = StringToInt(ImportField);
  RAr.Prntdf = StringToInt(ImportField);
  RAr.OfficialSerNr = ImportField;
  RAr.RefStr = ImportField;
  RAr.OfficialSerNr2 = ImportField;
  RAr.PrintDate = StringToDate(ImportField);
  RAr.Hash = ImportField;
  RAr.HashKeyVersion = StringToInt(ImportField);
  RAr.LangCode = ImportField;
  RAr.Addr0 = ImportField;
  RAr.Addr1 = ImportField;
  RAr.Addr2 = ImportField;
  RAr.Addr3 = ImportField;
  RAr.InvAddr3 = ImportField;
  RAr.InvAddr4 = ImportField;
  RAr.RegNr1 = ImportField;
  RAr.RegNr2 = ImportField;
  RAr.VATNr = ImportField;
  RAr.InclVAT = StringToInt(ImportField);
  RAr.CustTaxTemplateCode = ImportField;
  RAr.CustCat = ImportField;
  RAr.TaxAdminServSeal = ImportField;
  RAr.IVNr = StringToLongint(ImportField);
  RAr.SplitQty = StringToLongint(ImportField);
  RAr.OfficialSerNrSerie = ImportField;
  RAr.OfficialSerNr2Serie = ImportField;
  RAr.CustVATCode = ImportField;
  RAr.FiscalDeviceSeqNr = StringToLongint(ImportField);
  RAr.IPBookVAT = StringToInt(ImportField);
  
  rwcnt = 0;
  
  while (NextImportLine(false)) begin
    ClearRow(RAr,RArw,1);
    RArw.ArtCode = ImportField;
    RArw.Quant = StringToVal(ImportField,M4UVal);
    RArw.Price = StringToVal(ImportField,M423Val);
    RArw.Spec = ImportField;
    RArw.SplitQty = StringToVal(ImportField,M4UVal);
    RArw.VATCode = ImportField;
    RArw.AlreadyPrinted = StringToInt(ImportField);
    RArw.stp = StringToInt(ImportField);
    RArw.Sum = StringToVal(ImportField,M4Val);
    RArw.GCNr = StringToLongint(ImportField);
    RArw.PayMode = ImportField;
    RArw.CreditCard = ImportField;
    RArw.AuthorizationCode = ImportField;
    RArw.CurncyCode = ImportField;
    RArw.FrRate = StringToVal(ImportField,M4Rate);
    RArw.ToRateB1 = StringToVal(ImportField,M4Rate);
    RArw.ToRateB2 = StringToVal(ImportField,M4Rate);
    RArw.BaseRate1 = StringToVal(ImportField,M4Rate);
    RArw.BaseRate2 = StringToVal(ImportField,M4Rate);
    RArw.VoidedRowNr = StringToLongint(ImportField);
    RArw.Sign = ImportField;
    RArw.ovst = StringToInt(ImportField);
    RArw.TranferStatus = StringToInt(ImportField);
    RArw.TranferRestAccNr = StringToLongint(ImportField);
    RArw.KitchenStatus = StringToInt(ImportField);
    RArw.ChequeNr = StringToLongint(ImportField);
    RArw.CheckNr = ImportField;
    RArw.Points = StringToVal(ImportField,M4Val);
    RArw.SalesAssistant = ImportField;
    RArw.VoidedSign = ImportField;
    RArw.PrintGroupCode = ImportField;
    RArw.Modifier = StringToInt(ImportField);
    RArw.TaxTemplateCode = ImportField;
    ImportPackedMatrix(TMr);
    PackRowFieldMatrix(RArw,"TaxMatrix",TMr);
    RArw.vRebate = StringToVal(ImportField,M41Val);
    RArw.BasePrice = StringToVal(ImportField,M4Val);
    RArw.rowGP = StringToVal(ImportField,M4Val);
    RArw.PriceFactor = StringToVal(ImportField,M45Val);
    RArw.AlreadyPrintedToKitchen = StringToInt(ImportField);
    RArw.StandProblemCode = ImportField;
    RArw.MealCourse = ImportField;
    RArw.SeatCode = ImportField;
    RArw.KitchenDepartment = ImportField;
    RArw.OrgRestAccNr = StringToLongint(ImportField);
    MatRowPut(RAr,rwcnt,RArw);
    rwcnt = rwcnt + 1;
  end;
  
  return;
end;

