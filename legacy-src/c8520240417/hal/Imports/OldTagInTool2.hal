procedure ReadImportTagBarMenuVcRecord(record BarMenuVc BMr)
begin
  string 255 tstr;
  row BarMenuVc BMrw;
  integer rwcnt;
  
  RecordNew(BMr);
  BMr.Code = ImportField;
  BMr.Comment = ImportField;
  BMr.MenuName = ImportField;
  BMr.Amount = StringToVal(ImportField,M4Val);
  BMr.Sorting = ImportField;
  BMr.SalesItem = ImportField;
  BMr.DiscountItem = ImportField;
  
  rwcnt = 0;
  
  while (NextImportLine(false)) begin
    ClearRow(BMr,BMrw,1);
    BMrw.ArtCode = ImportField;
    BMrw.Name = ImportField;
    BMrw.RowGroup = ImportField;
    BMrw.ExtraCost = StringToVal(ImportField,M4Val);
    BMrw.clr = StringToInt(ImportField);
    MatRowPut(BMr,rwcnt,BMrw);
    rwcnt = rwcnt + 1;
  end;
  
  return;
end;

global
updating procedure ReadImportTagBarMenuVc(string thetag)
begin
  record BarMenuVc BMr;
  
  while (NextImportLine(false)) begin
    ReadImportTagBarMenuVcRecord(BMr);
    RecordImportStore(BMr,false);
  end;
  
  return;
end;

