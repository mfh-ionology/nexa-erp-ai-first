updating procedure ImpDanskeSWE(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  string 255 ntrykey,nkey,nkey2,ntrykey2,tstr;
  string 255 sortcode,bankacc,inputLine,name,reference;
  xml xdata;
  Integer n,j;
  record CYBlock CYb;
  record PMBlock PMb;
  row PMBlock PMbrw;
  record SRBlock SRb;

  BlockLoad(PMb);
  BlockLoad(CYb);
  BlockLoad(SRb);
	
  xdata = ParseXmlFile(GetImportFileName);
  bankacc = XmlGet(xdata,"Document/BkToCstmrDbtCdtNtfctn/Ntfctn/Acct/Id/Othr/Id");
  GetBankAccPMRow(PMb,"",bankacc,PMbrw);
  nkey = "Document/BkToCstmrDbtCdtNtfctn/Ntfctn/Ntry";
  n = 0;
  while (XmlNodeExists(xdata,nkey & "[" & n & "]")) begin
    ntrykey = nkey & "[" & n & "]";
    RecordNew(BTRr);
    j = 0;    
    while (XmlNodeExists(xdata,ntrykey & "/NtryDtls/TxDtls" & "[" & j & "]")) begin
      ntrykey2 = ntrykey & "/NtryDtls/TxDtls" &  "[" & j & "]";  
      BTRr.TransDate = DateFromString(XmlGet(xdata,ntrykey2 & "/RltdDts/AccptncDtTm"),"YYYY-MM-DD");
      reference = XmlGet(xdata,ntrykey2 & "/RmtInf/Strd/CdtrRefInf/Ref");
      BTRr.Reference = reference;
      BTRr.TRNumber = reference;
      if (nonblank(reference)) then begin
        BTRr.Comment = reference;
      end else begin
        BTRr.Comment = XmlGet(xdata,ntrykey2 & "/RmtInf/Ustrd");
      end;
      name = XmlGet(xdata,ntrykey2 & "/RltdPties/Dbtr/Nm");
     // if (nonblank(XmlGet(xdata,ntrykey2 & "/RltdPties/Dbtr/PstlAdr/PstCd"))) then begin tstr = name & " " & XmlGet(xdata,ntrykey2 & "/RltdPties/Dbtr/Nm"); end;
     // if (nonblank(XmlGet(xdata,ntrykey2 & "/RltdPties/Dbtr/PstlAdr/TwnNm"))) then begin tstr = name & " " & XmlGet(xdata,ntrykey2 & "/RltdPties/Dbtr/PstlAdr/TwnNm"); end;      
      if (XMLGetChildname(xdata,ntrykey2 & "/AmtDtls",0))=="PrtryAmt" and  ((XmlGet(xdata,ntrykey2 & "/AmtDtls/PrtryAmt/Tp"))=="DBIT") then begin
        BTRr.TypeRef = "D";
        BTRr.Sum = ValFromString(XmlGet(xdata,ntrykey2 & "/AmtDtls/PrtryAmt/Amt"),".","");
        BTRr.CurncyCode = XmlGetAttribute(xdata,ntrykey2 & "/AmtDtls/PrtryAmt/Amt","Ccy"); 
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayBankAcc = bankacc;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = RepSpec.f20;
        end;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
        end;
        BTRr.PayName = CYb.CompName;
        BTRr.PayVATNr = CYb.VATNr;
        BTRr.PayRegNr1 = CYb.OrgNr;
        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpName = name;
        BTRr.RcpReference = XmlGet(xdata,ntrykey2 & "/RmtInf/Strd/CdtrRefInf/Ref");
        BTRr.RcpRegNr1 = XmlGet(xdata,ntrykey2 & "/RltdPties/Dbtr/Id/OrgId/Othr/Id");
      end else begin
        BTRr.TypeRef = "C";
        BTRr.Sum = ValFromString(XmlGet(xdata,ntrykey2 & "/AmtDtls/TxAmt/Amt"),".","");
        BTRr.CurncyCode = XmlGetAttribute(xdata,ntrykey2 & "/AmtDtls/TxAmt/Amt","Ccy"); 
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = name;
        BTRr.PayReference = XmlGet(xdata,ntrykey2 & "/RmtInf/Strd/CdtrRefInf/Ref");
        BTRr.PayRegNr1 = XmlGet(xdata,ntrykey2 & "/RltdPties/Dbtr/Id/OrgId/Othr/Id");
        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpBankAcc = bankacc;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = RepSpec.f20;
        end;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
        end;
        BTRr.RcpName = CYb.CompName;
        BTRr.RcpReference = XmlGet(xdata,ntrykey2 & "/RmtInf/Strd/CdtrRefInf/Ref");
        BTRr.RcpVATNr = CYb.VATNr;
        BTRr.RcpRegNr1 = CYb.OrgNr;
        CreateReceipt(SRb,PMbrw.Code,BTRr,false);
      end;
        BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
        if (BTRr.SerNr>0) then begin
          RecordStore(BTRr,false);
        end;
      j = j + 1;
    end;
    n = n + 1;
  end;
  while (TestEOF==false) begin
    inputLine = ImportField;
    if (NextImportLine(true)) then begin
    end;
  end;
  return;
end;

updating procedure XMLBankTRIn(record RcVc RepSpec)
begin
  switch (RepSpec.flags[20]) begin
    case kReceiptBankSwedBankLithuania: ImpSwedBankLTU(RepSpec);
    case kReceiptBankSEBLithuania:      ImpSEBLTU(RepSpec);
    case kReceiptBankLuminorLithuania:  ImpLuminorLTU(RepSpec);
    case kReceiptBankPayseraLithuania:  ImpPayseraLTU(RepSpec);
    case kReceiptBankRaiffeisenCroatia: ImpRaiffeisenBankHRV(RepSpec);
    case kReceiptBankZGBCroatia:        ImpZGBHRV(RepSpec);
    case kReceiptBankErsteCroatia:      ImpErsteHRV(RepSpec);
    case kReceiptBankAddikoCroatia:     ImpAddikoHRV(RepSpec);
    case kReceiptBankSEBLatvia:         ImpSEBLVA(RepSpec);
    case kReceiptBankSwedBankLatvia:    ImpSwedBankLVA(RepSpec);
    case kReceiptBankSEBEstonia:        ImpSEBEST(RepSpec);
    case kReceiptBankSwedBankEstonia:   ImpSwedBankEST(RepSpec);
    case kReceiptBankSEBFinland:        ImpSEBFIN(RepSpec);
    case kReceiptBankSEBSweden:         ImpSEBSWEDEN(RepSpec,kReceiptBankSEBSweden);
    case kReceiptBankSEBSweden054:      ImpSEBSWEDEN(RepSpec,kReceiptBankSEBSweden054);
    case kReceiptBankSEBNorway:         ImpSEBNorway(RepSpec);
    case kReceiptBankDanskeSweden54:    ImpDanskeSWE(RepSpec);
    case kReceiptBankNKBMSlovenia:      ImpRaiffeisenBankHRV(RepSpec); //same format as Croatia Raiffeisen
    otherwise
      while (TestEOF==false) begin
        if (NextImportLine(true)) then begin
        end;
      end;
  end;
  return;
end;

updating procedure OFXBankTRIn(record RcVc RepSpec)
begin
  record CYBlock CYb;
  record PMBlock PMb;
  row PMBlock PMbrw;
  xml xdata;
  string 255 tstr,xkeytr,xkey;
  string 255 crncy,sortcode,bankacc,typeref;
  record BankTRVc BTRr;
  LongInt l;
  Boolean debitf;
  val sum;
  
  BlockLoad(CYb);
  BlockLoad(PMb);
  xdata = ParseXMLFile(GetImportFileName);
  xkey = "OFX/BANKMSGSRSV1/STMTTRNRS/STMTRS/";
  crncy = XmlGet(xdata,xkey & "CURDEF");

  sortcode = XmlGet(xdata,xkey & "BANKACCTFROM/BANKID");
  bankacc = XmlGet(xdata,xkey & "BANKACCTFROM/ACCTID");
  GetBankAccPMRow(PMb,sortcode,bankacc,PMbrw);

  xkey = "OFX/BANKMSGSRSV1/STMTTRNRS/STMTRS/BANKTRANLIST";
  
  l = 0;
  while (XmlNodeExists(xdata,xkey & "/STMTTRN[" & l & "]")) begin
    xkeytr = xkey & "/STMTTRN[" & l & "]/";

    typeref = XmlGet(xdata,xkeytr & "TRNTYPE");
    sum = ValFromString(XmlGet(xdata,xkeytr & "TRNAMT"),".","");
    debitf = IsDebitType(typeref,sum);
    if (debitf) begin
      tstr = "D"; 
      sum = sum*-1;
    end else begin
      tstr = "C";
    end;

    RecordNew(BTRr);
    BTRr.CurncyCode = crncy;
    BTRr.TypeRef = tstr;
    BTRr.TransDate = DateFromString(XmlGet(xdata,xkeytr & "DTPOSTED"),"YYYYMMDD");
    BTRr.Sum = sum;
    BTRr.OffReference = XmlGet(xdata,xkeytr & "CHECKNUM");
    BTRr.Reference = XmlGet(xdata,xkeytr & "NAME");
    BTRr.Comment = XmlGet(xdata,xkeytr & "MEMO");

    if (debitf) then begin
      BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = RepSpec.f20;
      end;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.PayName = CYb.CompName;
      BTRr.PayReference = BTRr.Reference;
      BTRr.PayVATNr = CYb.VATNr;
      BTRr.PayRegNr1 = CYb.OrgNr;
    end else begin
      BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = RepSpec.f20;
      end;
      BTRr.RcpTransDate = BTRr.TransDate;
      BTRr.RcpName = CYb.CompName;
      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpRegNr1 = CYb.OrgNr;
    end;
    
    BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
    if (BTRr.SerNr>0) then begin
      RecordStore(BTRr,false);
    end;
    l = l + 1;
  end;

  while (TestEOF==false) begin
    tstr = ImportField;
    if (NextImportLine(true)) then begin
    end;
  end;
  return;
end;

function string 255 ImportAmountColumn(record RcVc RepSpec,string inline,var record BankTRVc BTRr,integer column)
begin
  string 255 data;
  longint pos;
  Integer i;

  pos = 0;
  while (i<column) begin
    GetNextSubstring(inline,pos,RepSpec.AccStr,data);
    i = i + 1;
  end;
  data = StripCharacter(data,"""");
  BTRr.Sum = ValFromString(data,RepSpec.FirstAcc,"");
  if (BTRr.Sum>=0) then begin
    BTRr.TypeRef = "C";
  end else begin
    data = StripCharacter(BTRr.Sum,"-");
    BTRr.Sum = ValFromString(data,RepSpec.FirstAcc,"");
    BTRr.TypeRef = "D";
  end;
  return;
end;

function string 255 ImportColumn(record CYBlock CYb,string inline,Integer col,Integer amtcol,string specbankacc,string fsep,string coldata,string dateformat,string decsep,string thosep,var record BankTRVc BTRr)
begin
  string 255 data,bankacc,name;
  Integer i;
  LongInt pos;

  if (col==amtcol) then begin goto LImportColumn; end;

  pos = 0;
  while (i<col) begin
    GetNextSubstring(inline,pos,fsep,data);
    i = i + 1;
  end;
  data = StripCharacter(data,"""");
  if (nonblank(data)) then begin
    switch (SetFromString(621,coldata)) begin
      case kBankTRFileColumnDate:
        BTRr.TransDate = DateFromString(data,dateformat);
      case kBankTRFileColumnTime:
  //      BTRr.TransTime = TimeFromString(data,"HHMMSS");
      case kBankTRFileColumnReference:
        BTRr.Reference = data;
      case kBankTRFileColumnType:
        BTRr.TypeRef = data;
      case kBankTRFileColumnCreditAmount:
        BTRr.Sum = StringToVal(data,M4Val);
        BTRr.TypeRef = "C";
      case kBankTRFileColumnDebitAmount:
        BTRr.Sum = StringToVal(data,M4Val);
        BTRr.TypeRef = "D";
      case kBankTRFileColumnStatus:
      case kBankTRFileColumnCurrency:
        BTRr.CurncyCode = data;
      case kBankTRFileColumnReceipID:
        BTRr.OrdNumber = data;
      case kBankTRFileColumnBalance:
      case kBankTRFileColumnComment:
        BTRr.Comment = data;
      case kBankTRFileColumnBankAcc:
        bankacc = data;
      case kBankTRFileColumnTransNumber:
         BTRr.TRNumber = data;
      case kBankTRFileColumnVatNr:
        switch (Left(BTRr.TypeRef,1)) begin
          case "D":  BTRr.PayVATNr = data;
          case "C":  BTRr.RcpVATNr = data;
        end;
      case kBankTRFileColumnName:
        switch (Left(BTRr.TypeRef,1)) begin
          case "D":  BTRr.RcpName = data;
          case "C":  BTRr.PayName = data;
        end;
    end;
    switch (Left(BTRr.TypeRef,1)) begin
      case "D":
        BTRr.PayBankAcc = bankacc;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = specbankacc;
        end;
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayReference = BTRr.Reference;
        if (HasLocalization("ARG")==false) then begin
          BTRr.PayVATNr = CYb.VATNr;
          BTRr.PayName = CYb.CompName;
        end;
        BTRr.PayRegNr1 = CYb.OrgNr;
      case "C":
        BTRr.RcpBankAcc = bankacc;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = specbankacc;
        end;
        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpReference = BTRr.Reference;
        if (HasLocalization("ARG")==false) then begin
          BTRr.RcpVATNr = CYb.VATNr;
          BTRr.RcpName = CYb.CompName;
        end;
        BTRr.RcpRegNr1 = CYb.OrgNr;
    end;
  end;
LImportColumn:;
  return;
end;

updating procedure ImpSEBSWE(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  row PMBlock PMbrw;
  string 255 tstr,inputLine,data;
  LongInt pos;
  string 255 bic,bankacc,crncy,entrydate,valuedate;
  string 255 amount,text,reference,structured,additional;
  
  
  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  
  NextImportLine(true);
  
  while (TestEOF==false) begin 
    inputLine = ImportField;
    RecordNew(BTRr);
    
    pos = 0;
    GetNextSubstring(inputLine,pos,"|",bic);
    GetNextSubstring(inputLine,pos,"|",bankacc);
    GetNextSubstring(inputLine,pos,"|",crncy);
    GetNextSubstring(inputLine,pos,"|",entrydate);
    GetNextSubstring(inputLine,pos,"|",valuedate);
    GetNextSubstring(inputLine,pos,"|",amount);
    GetNextSubstring(inputLine,pos,"|",text);
    GetNextSubstring(inputLine,pos,"|",reference);
    GetNextSubstring(inputLine,pos,"|",structured);
    GetNextSubstring(inputLine,pos,"|",additional);
    
    BTRr.CurncyCode = crncy;
    BTRr.TransDate = StringToDate(entrydate);
    BTRr.Sum = StringToVal(StripCharacter(amount,"-"),M4Val);
    BTRr.Reference = reference;
    BTRr.Comment = additional;
    GetBankAccPMRow(PMb,bic,bankacc,PMbrw);
        
    if (left(amount,1)=="-") then begin
      BTRr.PayBankAcc = bankacc;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.PayName = CYb.CompName;
//      BTRr.RcpBankAcc = ;
//      BTRr.RcpName = ;
      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;
      BTRr.PayVATNr = CYb.VATNr;
      BTRr.PayRegNr1 = CYb.OrgNr;
      BTRr.TypeRef = "D";
    end else begin
      BTRr.RcpBankAcc = bankacc;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
//      BTRr.PayBankAcc = ;
//      BTRr.PayName = ;
      BTRr.PayReference = BTRr.Reference;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.RcpTransDate = BTRr.TransDate;
      BTRr.RcpName = CYb.CompName;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;
    
    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
    if (NextImportLine(true)) then begin
    end;
  end;
  
  return;
end;

updating procedure ImpBankUSA(record RcVc RepSpec,Integer bank)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record BaseCurBlock BCb;
  row PMBlock PMbrw;
  string 255 tstr,inputLine,SumType;
  string 255 entrydate,reference,additional;
  string 255 amount,text,type;
  LongInt pos;
  Date tmpdate;
  Boolean successf;
  
  BlockLoad(CYb)
  BlockLoad(BCb);
  
  if (bank!=kReceiptBankWellsFargoUSA) then begin
    NextImportLine(true);
  end;
  if (bank==kReceiptBankOfAmericaUSA) then begin
    NextImportLine(true);
  end;
  
  while (TestEOF==false) begin 
    inputLine = ImportField;
    pos = 0;
    RecordNew(BTRr);
    
    switch (bank) begin
      case kReceiptBankOfAmericaUSA:
        GetNextSubstring(inputLine,pos,",",entrydate);
        GetNextSubstring(inputLine,pos,",",reference);
        GetNextSubstring(inputLine,pos,",",text);
        GetNextSubstring(inputLine,pos,",",additional);
        GetNextSubstring(inputLine,pos,",",amount);
      case kReceiptBankAllyUSA:
        GetNextSubstring(inputLine,pos,",",entrydate);
        GetNextSubstring(inputLine,pos,",",tstr);
        GetNextSubstring(inputLine,pos,",",amount);
        GetNextSubstring(inputLine,pos,",",tstr);
        GetNextSubstring(inputLine,pos,",",text);
      case kReceiptBankWellsFargoUSA:
        GetNextSubstring(inputLine,pos,",",entrydate);
        GetNextSubstring(inputLine,pos,",",amount);
        GetNextSubstring(inputLine,pos,",",text);
      case kReceiptBankChaseUSA:
        GetNextSubstring(inputLine,pos,",",entrydate);
        GetNextSubstring(inputLine,pos,",",tstr);
        GetNextSubstring(inputLine,pos,",",text);
        GetNextSubstring(inputLine,pos,",",additional);
        GetNextSubstring(inputLine,pos,",",tstr);
        GetNextSubstring(inputLine,pos,",",amount);
      case kReceiptBankAmexUSA:
        GetNextSubstring(inputLine,pos,",",entrydate);
        GetNextSubstring(inputLine,pos,",",reference);
        GetNextSubstring(inputLine,pos,",",text);
        GetNextSubstring(inputLine,pos,",",tstr);
        GetNextSubstring(inputLine,pos,",",tstr);
        GetNextSubstring(inputLine,pos,",",amount);
        GetNextSubstring(inputLine,pos,",",tstr);
        GetNextSubstring(inputLine,pos,",",type);
      otherwise
        goto LImpBankUSA;
    end;
    BTRr.Type = 0;
    switch (bank) begin
      case kReceiptBankOfAmericaUSA:  tmpdate = DateFromString(entrydate,"MM/DD/YYYY");
      case kReceiptBankAllyUSA:       tmpdate = DateFromString(entrydate,"YYYY-MM-DD");
      case kReceiptBankWellsFargoUSA: tmpdate = DateFromString(entrydate,"MM/DD/YYYY");
      case kReceiptBankChaseUSA:      tmpdate = DateFromString(entrydate,"MM/DD/YYYY");
      case kReceiptBankAmexUSA:       tmpdate = DateFromString(entrydate,"MM/DD/YY");
    end;
    BTRr.TransDate = tmpdate;
    if (bank==kReceiptBankAmexUSA) then begin
      reference = StripCharacter(reference,"'");
    end;
    BTRr.Reference = reference;
    BTRr.CurncyCode = BCb.BaseCur1;
    BTRr.Sum = StringToVal(StripCharacter(amount,"-"),M4Val);
    if (left(amount,1)=="-" or left(type,1)=="D") then begin 
      SumType = "D";
    end else begin 
      SumType = "C";
    end;
    BTRr.TypeRef = SumType;
    switch (SumType) begin
      case "D": 
        BTRr.PayBankAcc = RepSpec.f1;
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = CYb.CompName;
        BTRr.RcpReference = BTRr.Reference;
        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.PayVATNr = CYb.VATNr;
        BTRr.PayRegNr1 = CYb.OrgNr;
      case "C": 
        BTRr.RcpBankAcc = RepSpec.f20;
        BTRr.PayReference = BTRr.Reference;
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpName = CYb.CompName;
        BTRr.RcpVATNr = CYb.VATNr;
        BTRr.RcpRegNr1 = CYb.OrgNr;
        BTRr.RcpBankAcc = RepSpec.f1;
    end;  
    BTRr.Comment = text;
    if (blankdate(BTRr.TransDate)) then begin 
      BTRr.TransDate = CurrentDate;    
    end;
    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
        successf = true;
      end;
    end;
    if (NextImportLine(true)) then begin
    end;
  end;
LImpBankUSA:;
  if (successf) then begin
    CheckMarkBox(15092,"");
  end;
  return;
end;

updating procedure ImpBankNedbankSouthAfrica(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  row PMBlock PMbrw;
  string 255 tstr,inputLine,inputLine2;
  LongInt pos;
  string 255 bankacc,transdate,fee;
  string 255 amount,desc,text,reference,balance;
  
  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);
  
  NextImportLine(true);
  inputLine = ImportField;
  tstr = inputLine;
  pos = 0;
  GetNextSubstring(tstr,pos,",",bankacc);
  GetNextSubstring(tstr,pos,",",bankacc);

  while (TestEOF==false) begin 
    inputLine = ImportField;
    tstr = StripCharacter(inputLine,"""");
    RecordNew(BTRr);
    pos = 0;
    GetNextSubstring(tstr,pos,",",transdate);
    GetNextSubstring(tstr,pos,",",desc);
    GetNextSubstring(tstr,pos,",",amount);
    GetNextSubstring(tstr,pos,",",balance);
    BTRr.CurncyCode = BCb.BaseCur1;
    BTRr.TransDate = DateFromString(transdate,"DD/MM/YYYY");
    BTRr.Comment = desc;
    BTRr.Sum = StringToVal(StripCharacter(amount,"-"),M4Val);
    BTRr.Reference = reference;
    
    GetBankAccPMRow(PMb,"",bankacc,PMbrw);
        
    if (left(amount,1)=="-") then begin
      BTRr.PayBankAcc = bankacc;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.PayName = CYb.CompName;
      BTRr.PayVATNr = CYb.VATNr;
      BTRr.PayRegNr1 = CYb.OrgNr;
      BTRr.TypeRef = "D";
      BTRr.RcpBankAcc = CYb.Bank1;
      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;
    end else begin
      BTRr.RcpBankAcc = bankacc;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.PayBankAcc = CYb.Bank1;
      BTRr.PayReference = BTRr.Reference;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.RcpTransDate = BTRr.TransDate;

      BTRr.RcpName = CYb.CompName;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      BTRr.PayName = desc;
      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;
    
    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
    if (NextImportLine(true)) then begin
    end;
  end;
  
  return;
end;

function integer ConvertMonthName(string month)
begin
  integer res;
  switch (month) begin
    case "Jan": res = 1;
    case "Feb": res = 2;
    case "Mar": res = 3;
    case "Apr": res = 4;
    case "May": res = 5;
    case "Jun": res = 6;
    case "Jul": res = 7;
    case "Aug": res = 8;
    case "Sep": res = 9;
    case "Oct": res = 10;
    case "Nov": res = 11;
    case "Dec": res = 12;
  end;
  ConvertMonthName = res;
  return;
end;

updating procedure ImpBankWindhoekNamibia(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  row PMBlock PMbrw;
  string 255 tstr,inputLine;
  LongInt pos;
  string 255 bankacc,transdate;
  string 255 amount,desc,reference,balance,transtype,skip,offreference;
  
  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);
  
  inputLine = ImportField;
  tstr = StripCharacter(inputLine,"""");
  pos = 0;
  GetNextSubstring(tstr,pos,",",skip);
  GetNextSubstring(tstr,pos,",",bankacc);
  GetNextSubstring(tstr,pos,",",skip);
  GetNextSubstring(tstr,pos,",",skip);
  GetNextSubstring(tstr,pos,",",skip);  
  GetNextSubstring(tstr,pos,",",skip);
  GetNextSubstring(tstr,pos,",",skip);
  GetNextSubstring(tstr,pos,",",skip);
  while (TestEOF==false) begin 
    inputLine = ImportField;
    tstr = StripCharacter(inputLine,"""");
    pos = 0;
    GetNextSubstring(tstr,pos,",",skip);
    GetNextSubstring(tstr,pos,",",offreference);
    GetNextSubstring(tstr,pos,",",skip);
    GetNextSubstring(tstr,pos,",",transdate);//4
    GetNextSubstring(tstr,pos,",",transtype);//5
    GetNextSubstring(tstr,pos,",",skip);
    GetNextSubstring(tstr,pos,",",desc);//7
    GetNextSubstring(tstr,pos,",",skip);
    GetNextSubstring(tstr,pos,",",amount);//9
    GetNextSubstring(tstr,pos,",",balance);//10
    GetNextSubstring(tstr,pos,",",reference);//11

    if (transtype=="CR" or transtype=="DR") then begin
      RecordNew(BTRr);
      BTRr.CurncyCode = BCb.BaseCur1;
      BTRr.TransDate = DateFromString(transdate,"YYYYMMDD");
      BTRr.Comment = desc;
      BTRr.OffReference = offreference;
      BTRr.Balance = StringToVal(balance,M4Val);
      BTRr.Sum = StringToVal(StripCharacter(amount,"-"),M4Val);
      BTRr.Reference = reference;
      GetBankAccPMRow(PMb,"",bankacc,PMbrw);
      if (transtype=="DR") then begin
        BTRr.PayBankAcc = bankacc;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = RepSpec.f20;
        end;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
        end;
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = CYb.CompName;
        BTRr.PayVATNr = CYb.VATNr;
        BTRr.PayRegNr1 = CYb.OrgNr;
        BTRr.TypeRef = "D";
        BTRr.RcpBankAcc = CYb.Bank1;
        BTRr.RcpReference = BTRr.Reference;
        BTRr.RcpTransDate = BTRr.TransDate;
      end else begin
        BTRr.OffReference = offreference;
        BTRr.RcpBankAcc = bankacc;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = RepSpec.f20;
        end;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
        end;
        BTRr.PayBankAcc = CYb.Bank1;
        BTRr.PayReference = BTRr.Reference;
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.RcpTransDate = BTRr.TransDate;
  
        BTRr.RcpName = CYb.CompName;
        BTRr.RcpVATNr = CYb.VATNr;
        BTRr.RcpRegNr1 = CYb.OrgNr;
        BTRr.PayName = desc;
        BTRr.TypeRef = "C";
        CreateReceipt(SRb,PMbrw.Code,BTRr,false);
      end;
      if (BTRr.Sum!=0) then begin
        BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
        if (BTRr.SerNr>0) then begin
          RecordStore(BTRr,false);
        end;
      end;
    end;  
    if (NextImportLine(true)) then begin
    end;
  end;
  return;
end;

updating procedure ImpBankNedbankNamibia(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  row PMBlock PMbrw;
  LongInt pos;
  Integer i;
  string 255 bankacc,exptransdate,debitamount,creditamount,currency;
  string 255 tstr,inputLine,amount,desc,reference,balance,skip;
  string 255 day, month,year,mmonth;
  date transdate;

  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);
  
  for (i=0;i<13;i=i+1) begin
    if (i==6) then begin
      inputLine = ImportField;
      pos = 0;
      GetNextSubstring(inputLine,pos,",",tstr);
      GetNextSubstring(inputLine,pos,",",bankacc);
      bankacc = StripNonDigits(bankacc);
    end;
    if (i==7) then begin
      inputLine = ImportField;
      pos = 0;
      GetNextSubstring(inputLine,pos,",",tstr);
      GetNextSubstring(inputLine,pos,",",currency);
    end;
    NextImportLine(true);
  end;
  while (TestEOF==false) begin 
    inputLine = ImportField;
    pos = 0;
    GetNextSubstring(inputLine,pos,",",exptransdate);
    GetNextSubstring(inputLine,pos,",",skip);
    GetNextSubstring(inputLine,pos,",",reference);
    GetNextSubstring(inputLine,pos,",",desc);
    GetNextSubstring(inputLine,pos,",",skip); 
    GetNextSubstring(inputLine,pos,"",amount);   
    creditamount = blankval;
    debitamount = blankval;
    if (left(amount,1)==",") then begin
      pos = 2;
      GetNextSubstring(amount,pos,"\"",creditamount);
      GetNextSubstring(amount,pos,"\"",skip);
      GetNextSubstring(amount,pos,"\"",balance);
    end else begin
      pos = 0;
      GetNextSubstring(amount,pos,"\"",debitamount);
      GetNextSubstring(amount,pos,"\"",balance);
      GetNextSubstring(amount,pos,"\"",skip);
      GetNextSubstring(amount,pos,"\"",skip);
    end;  
    RecordNew(BTRr);
    BTRr.Balance = StringToValue(balance,M4Rate,",",".");
    StripSpace(BTRr.CurncyCode,currency);
    pos = 0;
    GetNextSubstring(exptransdate,pos,"-",day);   
    GetNextSubstring(exptransdate,pos,"-",mmonth);
    StripSpace(month,mmonth);
    GetNextSubstring(exptransdate,pos,"-",year);
    transdate.day = StringToInt(day);
    transdate.month = ConvertMonthName(month);
    transdate.year = 2000 + StringToInt(year);
    BTRr.TransDate = transdate;
    BTRr.Comment = desc;
    BTRr.Reference = reference;
    GetBankAccPMRow(PMb,"",bankacc,PMbrw);
    if (nonblank(debitamount))then begin
      BTRr.Sum = StringToValue(debitamount,M4Rate,",",".");
      BTRr.PayBankAcc = bankacc;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.PayName = CYb.CompName;
      BTRr.PayVATNr = CYb.VATNr;
      BTRr.PayRegNr1 = CYb.OrgNr;
      BTRr.TypeRef = "D";

      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;
    end else begin
      BTRr.Sum = StringToValue(creditamount,M4Rate,",",".");
      BTRr.RcpBankAcc = bankacc;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.PayReference = BTRr.Reference;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.RcpTransDate = BTRr.TransDate;

      BTRr.RcpName = CYb.CompName;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      BTRr.PayName = desc;
      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;
    
    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
    if (NextImportLine(true)) then begin
    end;
  end;
  return;
end;

updating procedure ImpBankMillenniumPOR(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  row PMBlock PMbrw;
  LongInt pos;
  Integer i;
  string 255 bankacc,transdate,currency,amount,desc,reference,skip,balance;

  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);
  
  for (i=0;i<7;i=i+1) begin
    NextImportLine(true);
  end;
  while (TestEOF==false) begin 
    skip = ImportField;
    skip = ImportField;
    bankacc = ImportField;
    currency = ImportField;
    skip = ImportField;
    transdate = ImportField;
    desc = ImportField;
    amount = ImportField;
    balance = ImportField;
    reference = ImportField;
    RecordNew(BTRr);
    BTRr.Sum = StringToValue(StripCharacter(amount,"-"),M4Rate,"",",");
    BTRr.CurncyCode = currency;
    BTRr.TransDate = DateFromString(transdate,"DD-MM-YYYY");
    BTRr.Comment = desc;
    BTRr.Reference = reference;
    BTRr.Balance = StringToVal(balance,M4Val);

    GetBankAccPMRow(PMb,"",bankacc,PMbrw);
    if (left(amount,1)=="-") then begin
      BTRr.PayBankAcc = bankacc;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.PayName = CYb.CompName;
      BTRr.PayVATNr = CYb.VATNr;
      BTRr.PayRegNr1 = CYb.OrgNr;
      BTRr.TypeRef = "D";
      if (FindStringInString(desc,"TRF. P/O ")) then begin
        BTRr.RcpName = ReplaceStringWithString(desc,"TRF. P/O ","");
        if (left(BTRr.RcpName,1)==" ") then begin   
          BTRr.RcpName = Right(BTRr.RcpName,len(BTRr.RcpName)-1); 
        end;
      end;  
      //BTRr.RcpBankAcc = CYb.Bank1;
      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;
    end else begin
      BTRr.RcpBankAcc = bankacc;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      //BTRr.PayBankAcc = CYb.Bank1;
      BTRr.PayReference = BTRr.Reference;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.RcpTransDate = BTRr.TransDate;

      BTRr.RcpName = CYb.CompName;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      if (FindStringInString(desc,"TRF. P/O ")) then begin
        BTRr.PayName = ReplaceStringWithString(desc,"TRF. P/O ","");
        if (left(BTRr.PayName,1)==" ") then begin
          BTRr.PayName = Right(BTRr.PayName,len(BTRr.PayName)-1);
        end;
      end;  
      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;
    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
    if (NextImportLine(true)) then begin
    end;
  end;
  return;
end;

updating procedure ImpBankStandardSouthAfrica(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  row PMBlock PMbrw;
  string 255 tstr,inputLine;
  string 255 valuedate,desc,amount;
  string 255 ref,custref,bankacc;
  LongInt pos;
  Integer i;
  
  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);
  
  for (i=0;i<15;i=i+1) begin
    if (i==4) then begin
      inputLine = ImportField;
      pos = 0;
      GetNextSubstring(inputLine,pos,",",tstr);
      GetNextSubstring(inputLine,pos,",",bankacc);
      bankacc = StripNonDigits(bankacc);
    end;
    NextImportLine(true);
  end;
  
  while (TestEOF==false) begin 
    inputLine = ImportField;
    RecordNew(BTRr);
    
    pos = 0;
    GetNextSubstring(inputLine,pos,",",tstr);         // Date
    GetNextSubstring(inputLine,pos,",",valuedate);    // Value Date
    GetNextSubstring(inputLine,pos,",",tstr);         // Statement number
    GetNextSubstring(inputLine,pos,",",desc);         // Description
    GetNextSubstring(inputLine,pos,",",amount);       // Amount
    GetNextSubstring(inputLine,pos,",",tstr);         // Balance
    GetNextSubstring(inputLine,pos,",",tstr);         // Type
    GetNextSubstring(inputLine,pos,",",ref);          // Originator Reference
    GetNextSubstring(inputLine,pos,",",custref);      // Customer Reference

    BTRr.CurncyCode = BCb.BaseCur1;
    BTRr.TransDate = DateFromString(valuedate,"YYYY/MM/DD");
    BTRr.Comment = desc;
    tstr = StripCharacter(amount,"-");
    tstr = StripCharacter(tstr,"+");
    BTRr.Sum = StringToVal(tstr,M4Val);
    BTRr.Reference = ref;
    
    GetBankAccPMRow(PMb,"",bankacc,PMbrw);
    
    if (left(amount,1)=="-") then begin
      BTRr.PayBankAcc = bankacc;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.PayName = CYb.CompName;
      BTRr.PayVATNr = CYb.VATNr;
      BTRr.PayRegNr1 = CYb.OrgNr;
      BTRr.TypeRef = "D";
      BTRr.RcpBankAcc = CYb.Bank1;
      BTRr.RcpReference = custref;
      BTRr.RcpTransDate = BTRr.TransDate;
    end else begin
      BTRr.RcpBankAcc = bankacc;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.PayBankAcc = CYb.Bank1;
      BTRr.PayReference = custref;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.RcpTransDate = BTRr.TransDate;

      BTRr.RcpName = CYb.CompName;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      BTRr.PayName = desc;
      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;
    
    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
    if (NextImportLine(true)) then begin
    end;
  end;
  
  return;
end;

