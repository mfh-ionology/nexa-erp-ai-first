    BTRr.TRNumber = XmlGet(xdata,ntrykey & "DocNo");
    BTRr.Comment = XmlGet(xdata,ntrykey & "PmtInfo");
    
    switch (Left(BTRr.TypeRef,1)) begin
      case "D":
        BTRr.PayBankAcc = bankacc;
