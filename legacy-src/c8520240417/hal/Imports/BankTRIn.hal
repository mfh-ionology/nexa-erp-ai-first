global
updating procedure CSVBankTRIn(record RcVc RepSpec)
begin
  string 255 inline;
  record BankTRVc BTRr;
  Integer col,amtcol;
  record CYBlock CYb;
  record BankTRSetVc BankTRSetr;

  if (nonblank(RepSpec.f11)) then begin
    GetBankTransactionSettings(RepSpec.f11,RepSpec);
  end;

  switch (RepSpec.flags[20]) begin
  //  case kReceiptBankSEBSweden:         ImpSEBSWE(RepSpec);
    case kReceiptBankChaseUSA:            ImpBankUSA(RepSpec,kReceiptBankChaseUSA);
    case kReceiptBankOfAmericaUSA:        ImpBankUSA(RepSpec,kReceiptBankOfAmericaUSA);
    case kReceiptBankAllyUSA:             ImpBankUSA(RepSpec,kReceiptBankAllyUSA);
    case kReceiptBankWellsFargoUSA:       ImpBankUSA(RepSpec,kReceiptBankWellsFargoUSA);
    case kReceiptBankAmexUSA:             ImpBankUSA(RepSpec,kReceiptBankAmexUSA);
    case kReceiptBankFNBSouthAfrica:      ImpBankFNBSouthAfrica(RepSpec);
    case kReceiptBankSantanderArgentina:  ImpBankArgentina(RepSpec);
    case kReceiptBankBarclaysUK:          ImpBankBarclaysUK(RepSpec);
    case kReceiptBankWestpacAUS:          ImpBankWestpacAUS(RepSpec);
    case kReceiptBankCBANetBankAUS:       ImpBankCBANetBankAUS(RepSpec);
    case kReceiptBankASBNZ:               ImpBankASBNZ(RepSpec);
    case kReceiptBankASBCCNZ:             ImpBankASBCCNZ(RepSpec);
    case kReceiptBankBNZNZ:               ImpBankBNZNZ(RepSpec);
    case kReceiptBankCBACommBizAUS:       ImpBankCBACommBizAUS(RepSpec);
    case kReceiptBankNedbankNamibia:      ImpBankNedbankNamibia(RepSpec);
    case kReceiptBankWindhoekNamibia:     ImpBankWindhoekNamibia(RepSpec);
    case kReceiptBankNedbankSouthAfrica:  ImpBankNedbankSouthAfrica(RepSpec);
    case kReceiptBankStandardSouthAfrica: ImpBankStandardSouthAfrica(RepSpec);
    case kReceiptBankAbsaBankSouthAfrica: ImpBankAbsaBankSouthAfrica(RepSpec);
    case kReceiptBankEmiratesNBDBankUAE:  ImpBankEmiratesNBDBankUAE(RepSpec);
    otherwise
      BlockLoad(CYb);
      if (RepSpec.flags[0]!=0) then begin
        NextImportLine(true);
      end;
      while (TestEOF==false) begin
        inline = ImportField;
        RecordNew(BTRr);
        col = 1;
        amtcol = 0;
        if (SetFromString(621,RepSpec.f1)==kBankTRFileColumnAmount) then begin amtcol = 1; end;
        if (SetFromString(621,RepSpec.f2)==kBankTRFileColumnAmount) then begin amtcol = 2; end;
        if (SetFromString(621,RepSpec.f3)==kBankTRFileColumnAmount) then begin amtcol = 3; end;
        if (SetFromString(621,RepSpec.f4)==kBankTRFileColumnAmount) then begin amtcol = 4; end;
        if (SetFromString(621,RepSpec.f5)==kBankTRFileColumnAmount) then begin amtcol = 5; end;
        if (SetFromString(621,RepSpec.f6)==kBankTRFileColumnAmount) then begin amtcol = 6; end;
        if (SetFromString(621,RepSpec.f7)==kBankTRFileColumnAmount) then begin amtcol = 7; end;
        if (SetFromString(621,RepSpec.f8)==kBankTRFileColumnAmount) then begin amtcol = 8; end;
        if (SetFromString(621,RepSpec.f9)==kBankTRFileColumnAmount) then begin amtcol = 9; end;
        if (SetFromString(621,RepSpec.f10)==kBankTRFileColumnAmount) then begin amtcol = 10; end;

        if (amtcol==0) and ((SetFromString(621,RepSpec.f1)==kBankTRFileColumnCreditAmount) or (SetFromString(621,RepSpec.f2)==kBankTRFileColumnCreditAmount) or
                            (SetFromString(621,RepSpec.f3)==kBankTRFileColumnCreditAmount) or (SetFromString(621,RepSpec.f4)==kBankTRFileColumnCreditAmount) or 
                            (SetFromString(621,RepSpec.f5)==kBankTRFileColumnCreditAmount) or (SetFromString(621,RepSpec.f6)==kBankTRFileColumnCreditAmount) or 
                            (SetFromString(621,RepSpec.f7)==kBankTRFileColumnCreditAmount) or (SetFromString(621,RepSpec.f8)==kBankTRFileColumnCreditAmount) or 
                            (SetFromString(621,RepSpec.f9)==kBankTRFileColumnCreditAmount) or (SetFromString(621,RepSpec.f10)==kBankTRFileColumnCreditAmount)) then begin
                            goto LSkipAmoutCol;        
        end;

        if (amtcol!=0) then begin
          ImportAmountColumn(RepSpec,inline,BTRr,amtcol); 
LSkipAmoutCol:;
          ImportColumn(CYb,inline,col,amtcol,RepSpec.f20,RepSpec.AccStr,RepSpec.f1,RepSpec.Stext,RepSpec.FirstAcc,RepSpec.LastAcc,BTRr); col = col + 1;      
          ImportColumn(CYb,inline,col,amtcol,RepSpec.f20,RepSpec.AccStr,RepSpec.f2,RepSpec.Stext,RepSpec.FirstAcc,RepSpec.LastAcc,BTRr); col = col + 1;
          ImportColumn(CYb,inline,col,amtcol,RepSpec.f20,RepSpec.AccStr,RepSpec.f3,RepSpec.Stext,RepSpec.FirstAcc,RepSpec.LastAcc,BTRr); col = col + 1;
          ImportColumn(CYb,inline,col,amtcol,RepSpec.f20,RepSpec.AccStr,RepSpec.f4,RepSpec.Stext,RepSpec.FirstAcc,RepSpec.LastAcc,BTRr); col = col + 1;
          ImportColumn(CYb,inline,col,amtcol,RepSpec.f20,RepSpec.AccStr,RepSpec.f5,RepSpec.Stext,RepSpec.FirstAcc,RepSpec.LastAcc,BTRr); col = col + 1;
          ImportColumn(CYb,inline,col,amtcol,RepSpec.f20,RepSpec.AccStr,RepSpec.f6,RepSpec.Stext,RepSpec.FirstAcc,RepSpec.LastAcc,BTRr); col = col + 1;
          ImportColumn(CYb,inline,col,amtcol,RepSpec.f20,RepSpec.AccStr,RepSpec.f7,RepSpec.Stext,RepSpec.FirstAcc,RepSpec.LastAcc,BTRr); col = col + 1;
          ImportColumn(CYb,inline,col,amtcol,RepSpec.f20,RepSpec.AccStr,RepSpec.f8,RepSpec.Stext,RepSpec.FirstAcc,RepSpec.LastAcc,BTRr); col = col + 1;
          ImportColumn(CYb,inline,col,amtcol,RepSpec.f20,RepSpec.AccStr,RepSpec.f9,RepSpec.Stext,RepSpec.FirstAcc,RepSpec.LastAcc,BTRr); col = col + 1;
          ImportColumn(CYb,inline,col,amtcol,RepSpec.f20,RepSpec.AccStr,RepSpec.f10,RepSpec.Stext,RepSpec.FirstAcc,RepSpec.LastAcc,BTRr); col = col + 1;
        end;
        if (BTRr.Sum!=0) then begin
          BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
          if (BTRr.SerNr>0) then begin
            RecordStore(BTRr,false);
          end;
        end;
        if (NextImportLine(true)) then begin end;
      end;
    end;

  return;
end;

global
updating procedure BankTRIn(record RcVc RepSpec)
begin
  LongInt transnrbefore,transnrafter;

  transnrbefore = CountRecords("BankTRVc");
  switch (RepSpec.ArtMode) begin
    case 0: OFXBankTRIn(RepSpec);
    case 1: CSVBankTRIn(RepSpec);
    case 2: XMLBankTRIn(RepSpec);
    case 3: TXTBankTRIn(RepSpec);
    case 4: MT940BankTRIn(RepSpec);
  end;
  
  transnrafter = CountRecords("BankTRVc");
  CheckMarkBox(1658,". " & transnrafter-transnrbefore & " " & USetStr(43236) & " " & USetStr(43235));
  return;
end;
