external procedure IPSumup(var record IPVc);
external procedure IPVc_PasteBankVal(var record IPVc,Integer);
external procedure IPVc_PasteRecVal(var record IPVc,Integer);
external function Boolean IPVc_PasteCustCode(var record IPVc,Integer,var LongInt);
external function Boolean PasteInvIn2IPr(var record IPVc,Integer,Date,var val,Boolean,var Boolean);
external function string 255 StripCharacter(string,string);
external function Boolean IsDigit(string);
external function val ValFromString(string,string,string);
external function Date DateFromString(string,string);
external function boolean IsNumeric(string);
external procedure StripSpace(var string,string);
external function Boolean FindStringInString(string,string);
external function string 20 StripDigits(string);
external function val StringToValue(string,Integer,string,string);

procedure GetBankTransactionSettings(string code,var record RcVc RepSpec)
begin
  record BankTRSetVc BankTRSetr;

  BankTRSetr.Code = code;
  if (ReadFirstMain(BankTRSetr,1,true)) then begin
    RepSpec.Stext =  BankTRSetr.DateFormat;
    RepSpec.AccStr = BankTRSetr.FieldSeparator;  
    RepSpec.FirstAcc = BankTRSetr.DecimSeparator;
    RepSpec.LastAcc = BankTRSetr.ThousSeparator;
    RepSpec.f1 = BankTRSetr.Column1;
    RepSpec.f2 = BankTRSetr.Column2;
    RepSpec.f3 = BankTRSetr.Column3;
    RepSpec.f4 = BankTRSetr.Column4;
    RepSpec.f5 = BankTRSetr.Column5;
    RepSpec.f6 = BankTRSetr.Column6;
    RepSpec.f7 = BankTRSetr.Column7;
    RepSpec.f8 = BankTRSetr.Column8;
    RepSpec.f9 = BankTRSetr.Column9;
    RepSpec.f10 = BankTRSetr.Column10;
    RepSpec.flags[0] = BankTRSetr.SkipFirstLineFlag;
  end;

 return;
end;

function Boolean IsDebitType(string type,val sum)
begin
  Boolean res;

  switch (Left(type,1)) begin
    case "D": res = true;
    case "C": res = false;
    otherwise
      if (sum<0) then begin
        res = true;
      end;
  end;

  IsDebitType = res;
  return;
end;

function Boolean BankAccountNumberMatches(string pmbanknr,string bankacc)
begin
  Boolean res;
  Integer i;
  string 255 tstr;
  
  while (i<len(bankacc)) begin
    if (IsDigit(Mid(bankacc,i,1))) then begin
      tstr = right(bankacc,len(bankacc)-i);
      i = len(bankacc);
    end;
    i = i + 1;
  end;
  if (Right(pmbanknr,len(tstr))==tstr) then begin
    res = true;
  end;
  BankAccountNumberMatches = res;
  return;
end;

global
function Boolean GetBankAccPMRow(record PMBlock PMb,string sortcode,string bankacc,var row PMBlock PMbrw)
begin
  Boolean res;
  Integer i,rwcnt;
  
  ClearRow(PMb,PMbrw,1);
  res = true;
  BlockLoad(PMb);
  rwcnt = MatRowCnt(PMb);
  for (i=0 ;i<rwcnt;i=i+1) begin
    MatRowGet(PMb,i,PMbrw);
    if (PMbrw.SortCode==sortcode or blank(sortcode)) and (BankAccountNumberMatches(PMbrw.BankNr,bankacc)) then begin
      goto LGetBankAccPMRow;
    end;
  end;
  res = false;
  ClearRow(PMb,PMbrw,1);
LGetBankAccPMRow:;
  GetBankAccPMRow = res;
  return;
end;

function string 255 GetBankAccountNr(record PMBlock PMb,string accnr,var row PMBlock PMbrw)
begin
  string 255 res;
  Integer i,rwcnt;
  
  ClearRow(PMb,PMbrw,1);

  BlockLoad(PMb);
  rwcnt = MatRowCnt(PMb);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(PMb,i,PMbrw);
    if (PMbrw.AccNr==accnr) then begin
      res = PMbrw.BankNr;
      goto LGetBankAccountNr;
    end;
  end;
LGetBankAccountNr:;
 GetBankAccountNr = res;
  return;
end;

global
function Boolean GetYodleeIDPMRow(record PMBlock PMb,string sortcode,string accountid,var row PMBlock PMbrw)
begin
  Boolean res;
  Integer i,rwcnt;
  
  ClearRow(PMb,PMbrw,1);
  res = true;
  BlockLoad(PMb);
  rwcnt = MatRowCnt(PMb);
  for (i=0 ;i<rwcnt;i=i+1) begin
    MatRowGet(PMb,i,PMbrw);
    if (PMbrw.YodleeaccountId==accountid) then begin
      goto LGetYodleeIDPMRow;
    end;
  end;
  res = false;
LGetYodleeIDPMRow:;
  GetYodleeIDPMRow = res;
  return;
end;

global
updating procedure CreateReceipt(record SRBlock SRb,string paymode,record BankTRVc BTRr,boolean emSzmalf)
begin
  record CUVc CUr;
  record IPVc IPr;
  row IPVc IPrw;
  LongInt pos,err;
  string 255 tstr,custcode;
  record IVVc IVr;
  record ARVc ARr;
  Integer rownr;
  val chk,btv;
  Boolean testf,found,installmentf,cufound,empty;
  
  empty = true;
  btv = BTRr.Sum;
  if (emSzmalf) then begin
    tstr = ValToString(btv,M4Val,"",".",0);
    btv = StringToVal(StripCharacter(tstr,"-"),M4Val);
  end;
  RecordNew(IPr);
  IPr.TransDate = BTRr.TransDate;
  IPr.SerNr = NextSerNr("IPVc",IPr.TransDate,SRb.LastPayNr,false,"");
  IPr.RegDate = CurrentDate;
  IPr.OKFlag = 0;
  IPr.PayMode = paymode;
  IPr.Comment = BTRr.Comment;
  pos = 0;
  GetNextSubstring(BTRr.PayReference,pos,",",tstr);
  tstr = Trim(tstr);
  while (nonblank(tstr) and btv>0) begin
    testf = false;
    if (nonblank(tstr)) then begin
      IVr.OfficialSerNr = tstr;
      testf = ReadFirstKey("OfficialSerNr",IVr,1,true);
    end;
    if (testf==false) then begin
      IVr.SerNr = StripNonDigits(tstr);
      testf = ReadFirstKey("SerNr",IVr,1,true);
    end;
    if (testf) then begin
      if (nonblank(BTRr.PayRegNr1)) then begin
        if (IVr.RegNr1!=BTRr.PayRegNr1) then begin
          testf = false;
        end;
        if (!testf) then begin
          CUr.Code = IVr.CustCode;
          ReadFirstMain(CUr,1,true);
          testf = (CUr.RegNr1==BTRr.PayRegNr1);
        end;
      end else begin //ddc:: 210430 Maybe it should also check bank account if it doesn't find customer with reg.no.?
        if (nonblank(BTRr.PayBankAcc)) then begin
          CUr.Code = IVr.CustCode;
          ReadFirstMain(CUr,1,true);
          if (nonblank(CUr.IBANCode)) then begin
            if (CUr.IBANCode!=BTRr.PayBankAcc) then begin
              testf = false;
            end;
          end;
          if (nonblank(CUr.BankAccount)) then begin
            if (CUr.BankAccount!=BTRr.PayBankAcc) then begin
              testf = false;
            end;
          end;
        end else begin
          testf = false;
        end;
      end;
    end;

    if (testf) then begin
      empty = false;
      rownr = MatRowCnt(IPr);
      custcode = IVr.CustCode;
      ClearRow(IPr,IPrw,1);
      IPrw.InvoiceNr = IVr.SerNr;
      MatRowPut(IPr,rownr,IPrw);
      PasteInvIn2IPr(IPr,rownr,IPr.TransDate,chk,false,installmentf);
      MatRowGet(IPr,rownr,IPrw);
      if (btv!=IPrw.InvVal) then begin
        IPrw.RecCurncy = BTRr.CurncyCode;
        if (emSzmalf) then begin
          IPrw.RecVal = 0;
          IPrw.SplitVAT = btv;
          IPrw.InvoiceNr = StripNonDigits(BTRr.Comment);
        end else begin
          IPrw.RecVal = btv;
        end;
        MatRowPut(IPr,rownr,IPrw);
        IPVc_PasteRecVal(IPr,rownr);
      end;
      MatRowGet(IPr,rownr,IPrw);
      IPrw.rkRecNumber = BTRr.Comment;
      MatRowPut(IPr,rownr,IPrw);
      MatRowGet(IPr,rownr,IPrw);
      if (!emSzmalf) then begin
        btv = btv - IPrw.InvVal;
      end;
    end;
    GetNextSubstring(BTRr.PayReference,pos,",",tstr);
    tstr = Trim(tstr);
  end;
  if (!empty) then begin
    goto LCreateReceipt;
  end;
  if (btv>0) then begin
    cufound = true;
    if (blank(custcode)) then begin
      if (nonblank(BTRr.PayRegNr1)) then begin
        CUr.RegNr1 = BTRr.PayRegNr1;
        cufound = ReadFirstKey("RegNr1",CUr,1,true);
        custcode = CUr.Code;
        if (blank(CUr.RegNr1)) then begin cufound = false; custcode = ""; end;
        if (cufound==false) then begin
          CUr.IBANCode = BTRr.PayBankAcc;
          cufound = ReadFirstKey("ActIBAN",CUr,1,true);
          custcode = CUr.Code;
        end;
        if (cufound==false) then begin
          CUr.BankAccount = BTRr.PayBankAcc;
          cufound = ReadFirstKey("BankAccount",CUr,1,true);
          custcode = CUr.Code;
        end;
        if (cufound==false and nonblank(BTRr.PayRegNr1)) then begin
          CUr.VATNr = BTRr.PayRegNr1;
          cufound = ReadFirstKey("VATNr",CUr,1,true);
          custcode = CUr.Code;
        end;
      end else begin
        CUr.Name = BTRr.PayName;
        cufound = ReadFirstKey("Name",CUr,1,true);
        custcode = CUr.Code;
      end;
    end;
    if (cufound) then begin
      found = true;
      ARr.CustCode = custcode;
      while (LoopKey("CustCode",ARr,1,found)) begin
        if (ARr.CustCode!=custcode) then begin found = false; end;
        if (found) then begin
          testf = true;
          IVr.SerNr = ARr.InvoiceNr;
          testf = ReadFirstKey("SerNr",IVr,1,true);
          if (testf) then begin
            rownr = MatRowCnt(IPr);
            custcode = IVr.CustCode;
            ClearRow(IPr,IPrw,1);
            IPrw.InvoiceNr = IVr.SerNr;
            MatRowPut(IPr,rownr,IPrw);
            PasteInvIn2IPr(IPr,rownr,IPr.TransDate,chk,false,installmentf);
            MatRowGet(IPr,rownr,IPrw);
            if (btv!=IPrw.InvVal) then begin
              IPrw.RecCurncy = BTRr.CurncyCode;
              if (emSzmalf) then begin
                IPrw.RecVal = 0;
                IPrw.SplitVAT = btv;
                IPrw.InvoiceNr = StripNonDigits(BTRr.Comment);
              end else begin
                IPrw.RecVal = btv;
              end;
              MatRowPut(IPr,rownr,IPrw);
              IPVc_PasteRecVal(IPr,rownr);
            end;
            MatRowGet(IPr,rownr,IPrw);
            IPrw.rkRecNumber = BTRr.Comment;
            MatRowPut(IPr,rownr,IPrw);
            MatRowGet(IPr,rownr,IPrw);
            if(!emSzmalf) then begin
              btv = btv - IPrw.InvVal;
            end;  
            if (btv<=0) then begin found = false; end;
          end;
        end;
      end;
    end;
  end;
  if (btv>0 and cufound) then begin
    rownr = MatRowCnt(IPr);
    ClearRow(IPr,IPrw,1);
    IPrw.CustCode = custcode;
    MatRowPut(IPr,rownr,IPrw);
    IPVc_PasteCustCode(IPr,rownr,err);
    MatRowGet(IPr,rownr,IPrw);
    IPrw.RecCurncy = BTRr.CurncyCode;
    if (emSzmalf) then begin
      IPrw.RecVal = 0;
      IPrw.SplitVAT = btv;
    end else begin
      IPrw.RecVal = btv;
    end;
    MatRowPut(IPr,rownr,IPrw);
    IPVc_PasteRecVal(IPr,rownr);
    MatRowGet(IPr,rownr,IPrw);
    IPrw.rkRecNumber = BTRr.Comment;
    MatRowPut(IPr,rownr,IPrw);
  end;
  
LCreateReceipt:;
  if (cufound or !empty) then begin
    IPSumup(IPr);
    RecordStore(IPr,false);
  end;
  return;
end;

updating procedure ImpSwedBankLTU(record RcVc RepSpec)
begin
  record BankTRVc oBTRr;
  record BankTRVc BTRr;
  string 255 acctkey,balkey,ntrykey,nkey;
  string 255 sortcode,bankacc,inputLine;
  xml xdata;
  Integer n;
  record CYBlock CYb;
  record PMBlock PMb;
  row PMBlock PMbrw;
  record SRBlock SRb;
  Boolean dayf;
  
  BlockLoad(PMb);
  BlockLoad(CYb);
  BlockLoad(SRb);

  xdata = ParseXmlFile(GetImportFileName);

  acctkey = "Document/Rpt/Acct/";
  sortcode = XmlGet(xdata,"Document/BkToCstmrAcctRpt/Rpt/Acct/Svcr/FinInstnId/BIC");
  bankacc = XmlGet(xdata,"Document/BkToCstmrAcctRpt/Rpt/Acct/Id/IBAN");
  dayf = false;
  if (blank(sortcode) and blank(bankacc)) then begin
    acctkey = "Document/Rpt/Stmt/";
    sortcode = XmlGet(xdata,"Document/BkToCstmrStmt/Stmt/Acct/Svcr/FinInstnId/BIC");
    bankacc = XmlGet(xdata,"Document/BkToCstmrStmt/Stmt/Acct/Id/IBAN");
    dayf = true;

  end;

 // GetBankAccPMRow(PMb,"",bankacc,PMbrw);

  acctkey = "Document/BkToCstmrAcctRpt/Rpt/Acct/";
  balkey = "Document/BkToCstmrAcctRpt/Rpt/Bal/";
  nkey = "Document/BkToCstmrAcctRpt/Rpt/Ntry";

  if (dayf) then begin  
    acctkey = "Document/BkToCstmrStmt/Stmt/Acct/";
    balkey = "Document/BkToCstmrStmt/Stmt/Bal/";
    nkey = "Document/BkToCstmrStmt/Stmt/Ntry";
  end;

  n = 0;
  while (XmlNodeExists(xdata,nkey & "[" & n & "]")) begin
    ntrykey = nkey & "[" & n & "]/";
    RecordNew(BTRr);
    BTRr.CurncyCode = XmlGetAttribute(xdata,ntrykey & "Amt","Ccy");
    BTRr.Sum = ValFromString(XmlGet(xdata,ntrykey & "Amt"),".","");
    BTRr.TypeRef = XmlGet(xdata,ntrykey & "CdtDbtInd");
    BTRr.TransDate = DateFromString(XmlGet(xdata,ntrykey & "BookgDt/Dt"),"YYYY-MM-DD");

    BTRr.TRNumber = XmlGet(xdata,ntrykey & "AcctSvcrRef");
    BTRr.Comment = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Ustrd");

//    BTRr.Comment = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RltdPties/CdtrAcct/Id/IBAN");
//    BTRr.Comment = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RltdPties/CdtrAcct/Id/IBAN");

//    BTRr.Reference = XmlGet(xdata,ntrykey & "MEMO");
    
    switch (Left(BTRr.TypeRef,1)) begin
      case "D":
        BTRr.PayBankAcc = bankacc;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = RepSpec.f20;
        end;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
        end;
        
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = CYb.CompName;
        BTRr.PayVATNr = CYb.VATNr;
        BTRr.PayRegNr1 = CYb.OrgNr;


        BTRr.RcpBankAcc = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RltdPties/CdtrAcct/Id/IBAN");
        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpName = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RltdPties/Cdtr/Nm");
        BTRr.RcpRegNr1 = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RltdPties/Cdtr/Id/OrgId/Othr/Id");
        BTRr.RcpReference = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Ustrd");

      case "C":
        BTRr.RcpBankAcc = bankacc;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = RepSpec.f20;
        end;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
        end;
        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpName = CYb.CompName;
        BTRr.RcpVATNr = CYb.VATNr;
        BTRr.RcpRegNr1 = CYb.OrgNr;

        BTRr.PayBankAcc = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RltdPties/DbtrAcct/Id/IBAN");
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RltdPties/Dbtr/Nm");
        BTRr.PayRegNr1 = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RltdPties/Dbtr/Id/OrgId/Othr/Id");
        BTRr.PayReference = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Ustrd");
        CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;
    oBTRr.TRNumber = BTRr.TRNumber;
    if (ReadFirstKey("TRNumber",oBTRr,1,true)==false) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;

    n = n + 1;
  end;
  
  while (TestEOF==false) begin
    inputLine = ImportField;
    if (NextImportLine(true)) then begin
    end;
  end;
  return;
end;

updating procedure ImpSEBLVA(record RcVc RepSpec)
begin
  record BankTRVc oBTRr;
  record BankTRVc BTRr;
  string 255 acctkey,balkey,ntrykey,nkey;
  string 255 sortcode,bankacc,inputLine;
  xml xdata;
  Integer n;
  record CYBlock CYb;
  record PMBlock PMb;
  row PMBlock PMbrw;
  record SRBlock SRb;
  
  BlockLoad(PMb);
  BlockLoad(CYb);
  BlockLoad(SRb);
	
  xdata = ParseXmlFile(GetImportFileName);

  acctkey = "FIDAVISTA/Statement/AccountSet";
  bankacc = XmlGet(xdata,"FIDAVISTA/Statement/AccountSet/IBAN");

  GetBankAccPMRow(PMb,"",bankacc,PMbrw);

  nkey = "FIDAVISTA/Statement/AccountSet/CcyStmt/TrxSet";

  n = 0;
  while (XmlNodeExists(xdata,nkey & "[" & n & "]")) begin
    ntrykey = nkey & "[" & n & "]/";
    RecordNew(BTRr);

    BTRr.CurncyCode = XmlGet(xdata,"FIDAVISTA/Statement/AccountSet/CcyStmt/Ccy");
    BTRr.Sum = ValFromString(XmlGet(xdata,ntrykey & "CPartySet/Amt"),".","");
    BTRr.TypeRef = XmlGet(xdata,ntrykey & "CorD");
    BTRr.TransDate = DateFromString(XmlGet(xdata,ntrykey & "BookDate"),"YYYY-MM-DD");

    BTRr.TRNumber = XmlGet(xdata,ntrykey & "DocNo");
    BTRr.Comment = XmlGet(xdata,ntrykey & "TypeName");
    
    switch (Left(BTRr.TypeRef,1)) begin
      case "D":
        BTRr.PayBankAcc = bankacc;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = RepSpec.f20;
        end;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
        end;
        
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = CYb.CompName;
        BTRr.PayVATNr = CYb.VATNr;
        BTRr.PayRegNr1 = CYb.OrgNr;


        BTRr.RcpBankAcc = XmlGet(xdata,ntrykey & "CPartySet/AccNo");
        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpName = XmlGet(xdata,ntrykey & "CPartySet/AccHolder/Name");
        BTRr.RcpRegNr1 = XmlGet(xdata,ntrykey & "CPartySet/AccHolder/LegalId");
        BTRr.RcpReference = XmlGet(xdata,ntrykey & "BankRef");

      case "C":
        BTRr.RcpBankAcc = bankacc;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = RepSpec.f20;
        end;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
        end;

        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpName = CYb.CompName;
        BTRr.RcpVATNr = CYb.VATNr;
        BTRr.RcpRegNr1 = CYb.OrgNr;

        BTRr.PayBankAcc = XmlGet(xdata,ntrykey & "CPartySet/AccNo");
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = XmlGet(xdata,ntrykey & "CPartySet/AccHolder/Name");
        BTRr.PayRegNr1 = XmlGet(xdata,ntrykey & "CPartySet/AccHolder/LegalId");
        BTRr.PayReference = XmlGet(xdata,ntrykey & "BankRef");
        CreateReceipt(SRb,PMbrw.Code,BTRr,false);

      
    end;
    
    oBTRr.TRNumber = BTRr.TRNumber;
    if (ReadFirstKey("TRNumber",oBTRr,1,true)==false) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;

    n = n + 1;
  end;
  
  while (TestEOF==false) begin
    inputLine = ImportField;
    if (NextImportLine(true)) then begin
    end;
  end;
  return;
end;

updating procedure ImpSwedBankEST(record RcVc RepSpec)
begin
  record BankTRVc oBTRr;
  record BankTRVc BTRr;
  string 255 acctkey,balkey,ntrykey,nkey;
  string 255 sortcode,bankacc,inputLine;
  xml xdata;
  Integer n;
  record CYBlock CYb;
  record PMBlock PMb;
  row PMBlock PMbrw;
  record SRBlock SRb;
  
  BlockLoad(PMb);
  BlockLoad(CYb);
  BlockLoad(SRb);
	
  xdata = ParseXmlFile(GetImportFileName);

  acctkey = "Document/Rpt/Acct/";
  bankacc = XmlGet(xdata,"Document/BkToCstmrAcctRpt/Rpt/Acct/Id/IBAN");
  sortcode = XmlGet(xdata,"Document/BkToCstmrAcctRpt/Rpt/Acct/Svcr/FinInstnId/BIC");

  GetBankAccPMRow(PMb,"",bankacc,PMbrw);

  acctkey = "Document/BkToCstmrAcctRpt/Rpt/Acct/";
  balkey = "Document/BkToCstmrAcctRpt/Rpt/Bal/";
  nkey = "Document/BkToCstmrAcctRpt/Rpt/Ntry";

  n = 0;
  while (XmlNodeExists(xdata,nkey & "[" & n & "]")) begin
    ntrykey = nkey & "[" & n & "]/";
    RecordNew(BTRr);

    BTRr.CurncyCode = XmlGetAttribute(xdata,ntrykey & "Amt","Ccy");
    BTRr.Sum = ValFromString(XmlGet(xdata,ntrykey & "Amt"),".","");
    BTRr.TypeRef = XmlGet(xdata,ntrykey & "CdtDbtInd");
    BTRr.TransDate = DateFromString(XmlGet(xdata,ntrykey & "BookgDt/Dt"),"YYYY-MM-DD");

    BTRr.TRNumber = XmlGet(xdata,ntrykey & "AcctSvcrRef");
    BTRr.Comment = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Ustrd");
    
