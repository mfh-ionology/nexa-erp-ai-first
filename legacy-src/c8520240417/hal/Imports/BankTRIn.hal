updating procedure ImpSwedBankLVA(record RcVc RepSpec)
begin
  record BankTRVc oBTRr;
  record BankTRVc BTRr;
  string 255 acctkey,balkey,ntrykey,nkey;
  string 255 sortcode,bankacc,inputLine;
  xml xdata;
  Integer n;
