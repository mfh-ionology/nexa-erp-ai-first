      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;
    
    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
    if (NextImportLine(true)) then begin
    end;
  end;
  
  return;
end;

updating procedure ImpBankArgentina(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  row PMBlock PMbrw;
  string 255 tstr,inputLine;
  LongInt pos,pos1;
  string 255 bankacc,transdate,transnr,reference;
  string 255 comment,name,vatnr,amount,curr,balance;
  string 255 branchorigin,branchdesc;
  string 255 comments,other,corrname;

  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);

  while (TestEOF==false) begin
    inputLine = ImportField;
    tstr = StripCharacter(inputLine,"""");
    RecordNew(BTRr);

    pos = 0;
    GetNextSubstring(tstr,pos,",",transdate);
    GetNextSubstring(tstr,pos,",",branchorigin);
    GetNextSubstring(tstr,pos,",",branchdesc);
    GetNextSubstring(tstr,pos,",",reference);
    GetNextSubstring(tstr,pos,",",transnr);
    GetNextSubstring(tstr,pos,",",comments);
    GetNextSubstring(tstr,pos,",",amount);
    GetNextSubstring(tstr,pos,",",balance);

    pos1 = 0;
    GetNextSubstring(comments,pos1,"-",comment);
    GetNextSubstring(comments,pos1,"/",name);
    GetNextSubstring(comments,pos1,"/",other);
    GetNextSubstring(comments,pos1,"/",vatnr);

    BTRr.CurncyCode = curr;
    BTRr.TransDate = DateFromString(transdate,"DD/MM/YYYY");
    BTRr.Sum = StringToVal(StripCharacter(amount,"-"),M4Val);
    BTRr.Reference = reference;
    BTRr.Comment = comment;
    BTRr.TRNumber = transnr;
    GetBankAccPMRow(PMb,"",bankacc,PMbrw);
    bankacc = GetBankAccountNr(PMb,RepSpec.f13,PMbrw);
    corrname = Left(name,len(name)-1);
    name = Right(corrname,len(corrname)-1);

    if (left(amount,1)=="-") then begin
      BTRr.PayBankAcc = bankacc;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.RcpBankAcc = bankacc;
      BTRr.RcpVATNr = vatnr;
      BTRr.RcpReference = reference;
      BTRr.RcpTransDate = BTRr.TransDate;
      BTRr.RcpName = name;

      BTRr.PayRegNr1 = CYb.OrgNr;
      BTRr.PayVATNr = CYb.VATNr;
      BTRr.PayName = CYb.CompName;
      BTRr.PayRegNr1 = CYb.OrgNr;
      BTRr.PayBankAcc = CYb.Bank1;
      BTRr.PayReference = BTRr.Reference;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.TypeRef = "D";
    end else begin
      BTRr.RcpBankAcc = CYb.Bank1;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.PayBankAcc = bankacc;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpName = CYb.CompName;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;
      BTRr.PayTransDate = transdate;
      BTRr.PayReference = reference;
      BTRr.PayName = name;
      BTRr.PayVATNr = vatnr;
      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;
    
    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
    if (NextImportLine(true)) then begin
    end;
  end;
  
  return;
end;

procedure AddStrToStr(var string res,string tstr)
begin

  if (blank(res)) then begin
    res = tstr;
  end else begin
    res = res & " " & tstr;
  end;

  return;
end;

procedure GetDataFromNarrative(string narrative,var string reference,var string pname)
begin
  
Longint pos;
string 255 tstr;
Boolean foundf,loopf;

  pos = 0;
  loopf = true;
  pname = "";
  reference = "";
  while (loopf) begin
    GetNextSubstring(narrative,pos," ",tstr);  
    if (IsNumeric(tstr)==true) then begin 
      foundf = true;
      while (foundf) begin
        GetNextSubstring(narrative,pos," ",tstr);  
        if (IsNumeric(tstr)==true) then begin AddStrToStr(reference,tstr); end;
        if (nonblank(tstr)) then begin
          AddStrToStr(pname,tstr);
        end else begin
          foundf = false; loopf = false;
        end;
      end;
    end;   
  end;
return;
end;

updating procedure ImpBankWestpacAUS(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  record SysFormatBlock SFb;
  row PMBlock PMbrw;
  string 255 tstr,inputLine;
  LongInt pos;
  string 255 dateformat,bankacc,pname,reference;
  string 255 damount,camount,narrative,account,transdate,balance,category,tstr2,nar2,other,bankaccountnr;
  Boolean loopf,foundf,anotherf,blankf,skipf;

  BlockLoad(SFb);
  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);

  skipf = true;
  while (TestEOF==false) begin
    if (skipf) then begin NextImportLine(true); skipf = false; end; 
    RecordNew(BTRr);
    inputLine = ImportField; 
    pos = 0;
    GetNextSubstring(inputLine,pos,",",account);  
    GetNextSubstring(inputLine,pos,chr(34),transdate); 
    GetNextSubstring(inputLine,pos,chr(34),narrative);
    GetNextSubstring(inputLine,pos,",",other);
    GetNextSubstring(inputLine,pos,",",damount);
    GetNextSubstring(inputLine,pos,",",camount);
    GetNextSubstring(inputLine,pos,",",balance);
    GetNextSubstring(inputLine,pos,",",category);
    GetNextSubstring(inputLine,pos,",",tstr2);

    transdate = Left(transdate,len(transdate)-1);
    switch (category) begin
      case "PAYMENT":
      if (FindStringInString(narrative,"PAYMENT BY AUTHORITY TO")) then begin
        pos = 24;
        GetNextSubstring(narrative,pos,",",tstr); 
        pname = tstr;
        while (GetNextSubstring(narrative,pos,",",tstr)) begin
          reference = tstr;
        end;
      end else begin
        GetDataFromNarrative(narrative,reference,pname);
      end; 

      if (blank(reference)) then begin
        pos =0;
        while (GetNextSubstring(narrative,pos," ",tstr)) begin
          reference = tstr; 
        end;
      end;

      case "DEP":  
      if (FindStringInString(narrative,"DEPOSIT-OSKO PAYMENT")) then begin
        pos = 0;
        foundf = false;
        loopf = true;
        pname = "";
        reference =  "";
        while (loopf) begin 
          GetNextSubstring(narrative,pos," ",tstr);  
          if (IsNumeric(tstr)==true) then begin foundf = true; end;
          if (foundf) then begin
            anotherf = true;
            while (anotherf) begin
              GetNextSubstring(narrative,pos," ",tstr);
              if ((IsNumeric(tstr)==true)) then begin anotherf = false; end;
              if (anotherf and nonblank(tstr) and ((IsNumeric(tstr)==false))) then begin
                AddStrToStr(pname,tstr);
              end else begin
                if (nonblank(tstr) and (IsNumeric(tstr)==true)) then begin
                  AddStrToStr(reference,tstr);
                  loopf = false;
                end else begin
                  loopf = false;
                end;  
              end;  
            end;        
          end;
        end;  
      end;
      if (FindStringInString(narrative,"DEPOSIT ")) then begin
        pname = "";
        blankf = false;
        loopf = true;
        pos = 8;
        while (loopf) begin
          GetNextSubstring(narrative,pos," ",tstr)
          if (blankf and blank(tstr)) then begin loopf = false; end;
          if (blank(tstr)) then begin blankf = true; end;
          if (loopf and nonblank(tstr)) then begin
            AddStrToStr(pname,tstr);
          end;
        end;
        reference = StripNonDigits(narrative);
      end;

      case "FEE":
        GetDataFromNarrative(narrative,reference,pname);
        reference = "Bank Fee";
        bankaccountnr = Right(account,6);
    end;

    switch (SFb.dateOrder) begin
      case 0: dateformat = "MM-DD-YYYY";
      case 1: dateformat = "DD-MM-YYYY";
      case 2: dateformat = "YYYY-MM-DD";
    end;

    BTRr.TransDate = DateFromString(transdate,dateformat);
    BTRr.CurncyCode = BCb.BaseCur1;
    BTRr.Reference = reference;
    BTRr.Comment = narrative; 
    BTRr.Balance = StringToVal(balance,M4Val);
    if (nonblank(damount)) then begin
      BTRr.PayBankAcc = Right(account,6);
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.PayName = CYb.CompName;
      BTRr.PayReference = BTRr.Reference;
      BTRr.PayRegNr1 = CYb.OrgNr;
      BTRr.PayVATNr = CYb.VATNr;
      BTRr.Sum = StringToVal(damount,M4Val);
      BTRr.RcpTransDate = BTRr.TransDate;
      BTRr.RcpBankAcc =  bankaccountnr;
      BTRr.RcpReference = reference;
      BTRr.RcpName = pname;
      BTRr.TypeRef = "D";
    end else begin
      BTRr.PayBankAcc = "";
      BTRr.PayTransDate = transdate;
      BTRr.PayReference = reference;
      BTRr.PayName = pname;
      BTRr.Sum = StringToVal(camount,M4Val);
      BTRr.RcpBankAcc = Right(account,6);
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.RcpTransDate = BTRr.TransDate;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpName = CYb.CompName;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      BTRr.RcpReference = reference;
      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;
    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin 
        RecordStore(BTRr,false);
      end;
    end;
    if (NextImportLine(true)) then begin end;
  end;
return;
end;

function string 255 FindPName(string comment)
begin
string 255 pname,tstr;
longint pos;
Boolean loopf;

  pos = 0;
  GetNextSubstring(comment,pos," ",tstr);
  GetNextSubstring(comment,pos," ",tstr);
  GetNextSubstring(comment,pos," ",tstr);
  loopf = true;
  while (loopf) begin 
    GetNextSubstring(comment,pos," ",tstr);
    if (IsNumeric(tstr)==false) then  begin 
      loopf = true; 
    end else begin
      loopf = false;
    end;
    if (loopf) then begin
      if (blank(pname)) then begin
        pname = tstr;
      end else begin
        pname = pname & " " & tstr;
      end;
    end;
  end;

 FindPName = pname;
end;

updating procedure ImpBankCBANetBankAUS(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  record SysFormatBlock SFb;
  row PMBlock PMbrw;
  string 255 tstr,inputLine;
  string 255 transdate,amount,comment,balance,dateformat;
  string 255 tstr2,tstr3,pname,bankacc,ref;
  LongInt pos;

  BlockLoad(SFb);
  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);

  while (TestEOF==false) begin
    RecordNew(BTRr);
    pname = "";
    ref = "";
    inputLine = ImportField; 
    tstr = StripCharacter(inputLine,"""");
    pos = 0;

    GetNextSubstring(tstr,pos,",",transdate);  
    GetNextSubstring(tstr,pos,",",amount);
    GetNextSubstring(tstr,pos,",",comment);
    GetNextSubstring(tstr,pos,",",balance);

    switch (SFb.dateOrder) begin
      case 0: dateformat = "MM-DD-YYYY";
      case 1: dateformat = "DD-MM-YYYY";
      case 2: dateformat = "YYYY-MM-DD";
    end;

    BTRr.TransDate = DateFromString(transdate,dateformat);
    BTRr.CurncyCode = BCb.BaseCur1;
    BTRr.Sum = StringToVal(StripCharacter(amount,"-"),M4Val);
    BTRr.Comment = comment; 
    BTRr.Balance = StringToVal(balance,M4Val);
    if (left(amount,1)=="-") then begin
      pos = 0;
      while (GetNextSubstring(comment,pos," ",ref)) begin
        BTRr.Reference = ref;
      end;
      if (FindStringInString(comment, "Direct Debit")) then begin 
        pname = FindPName(comment);
      end else begin 
        pos = 0;
        GetNextSubstring(comment,pos," ",tstr2);
        GetNextSubstring(comment,pos," ",tstr3);
        pname = tstr2 & " " & tstr3;
      end;
        if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
        BTRr.RcpBankAcc = CYb.Bank1;
        BTRr.RcpReference = BTRr.Reference;
        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpName = pname;
        BTRr.PayRegNr1 = CYb.OrgNr;
        BTRr.PayVATNr = CYb.VATNr;
        BTRr.PayName = CYb.CompName;
        BTRr.PayRegNr1 = CYb.OrgNr;
        BTRr.PayReference = BTRr.Reference;
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.TypeRef = "D";
    end else begin
      if (FindStringInString(comment, "Transfer from xx")) then begin 
        pos = 16;
        GetNextSubstring(comment,pos," ",bankacc);
        BTRr.PayBankAcc = bankacc;
        BTRr.Reference = "Transfer from xx" & bankacc;
      end else begin
        pos = 0;
        while (GetNextSubstring(comment,pos," ",ref)) begin
          BTRr.Reference = ref;
        end;
        BTRr.PayBankAcc = "";
      end;
      if (FindStringInString(comment, "Direct Credit")) then begin
        pname = FindPName(comment);
      end else begin 
        pname = "";
      end;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpName = CYb.CompName;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.PayReference =  BTRr.Reference;
      BTRr.PayName = pname;
      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;
    GetBankAccPMRow(PMb,"",bankacc,PMbrw);
    bankacc = GetBankAccountNr(PMb,RepSpec.f13,PMbrw);

    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
    if (NextImportLine(true)) then begin
    end;
  end;
  
  return;
end;

updating procedure ImpBankCBACommBizAUS(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  record SysFormatBlock SFb;
  row PMBlock PMbrw;
  string 255 tstr,inputLine;
  string 255 transdate,balance,debit,credit,description,currency,dateformat,ref,pname;
  LongInt pos;
  Boolean loopf2,digitf;

  BlockLoad(SFb);
  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);

   while (TestEOF==false) begin
    RecordNew(BTRr);
    inputLine = ImportField; 
    tstr = StripCharacter(inputLine,"""");
    pname = "";
    ref = "";
    pos = 0;
    GetNextSubstring(tstr,pos,",",transdate);  
    GetNextSubstring(tstr,pos,",",description);  
    GetNextSubstring(tstr,pos,",",currency);  
    GetNextSubstring(tstr,pos,",",debit);  
    GetNextSubstring(tstr,pos,",",credit);  
    GetNextSubstring(tstr,pos,",",balance);  

    if (FindStringInString(transdate,"Process date")) then begin goto LImpBankCBACommBizAUS; end;
    pos = 0;
    while (GetNextSubstring(description,pos," ",tstr)) begin
      //gets the last one
      ref = tstr;
    end;

    switch (SFb.dateOrder) begin
      case 0: dateformat = "MM-DD-YYYY";
      case 1: dateformat = "DD-MM-YYYY";
      case 2: dateformat = "YYYY-MM-DD";
    end;

    BTRr.TransDate = DateFromString(transdate,dateformat);
    BTRr.CurncyCode = currency;
    BTRr.Comment = description; 
    BTRr.Balance = StringToVal(balance,M4Val);
    BTRr.Reference = ref;
    if (blank(credit)) then begin
      BTRr.Sum = StringToVal(debit,M4Val);
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = RepSpec.f20;
      end;
      BTRr.RcpBankAcc = CYb.Bank1;
      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.PayName = CYb.CompName;
      BTRr.PayReference = BTRr.Reference;
      BTRr.PayRegNr1 = CYb.OrgNr;
      BTRr.PayVATNr = CYb.VATNr;
      BTRr.PayRegNr1 = CYb.OrgNr;
      BTRr.TypeRef = "D";
    end else begin
      BTRr.Sum = StringToVal(credit,M4Val);
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = RepSpec.f20;
      end;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpName = CYb.CompName;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;
      BTRr.PayTransDate = BTRr.TransDate;
      loopf2 = true; 
      digitf = false; 
      pos = 0;
      while (loopf2) begin
        GetNextSubstring(description,pos," ",tstr);
        if (blank(tstr)) then begin loopf2 = false; end;
        if (tstr==ref) then begin loopf2 = false; end;
        if (IsDigit(tstr)) then begin digitf = true; goto Lskip; end;
        if (loopf2 and nonblank(tstr) and digitf) then begin
          AddStrToStr(pname,tstr);
        end;
      Lskip:;
      end;
      BTRr.PayName = pname;
      BTRr.PayReference =  BTRr.Reference;
      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;

    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
LImpBankCBACommBizAUS:;
    if (NextImportLine(true)) then begin end;
  end;
  
  return;
end;

updating procedure ImpBankEmiratesNBDBankUAE(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  row PMBlock PMbrw;
  string 255 tstr,inputLine;
  string 255 transdate,debitamount,creditamount,accountnr,reference,skip,comment;
  val damount,camount;
  LongInt pos;

  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);

  NextImportLine(true);
  while (TestEOF==false) begin
    RecordNew(BTRr);
    inputLine = ImportField; 
    tstr = StripCharacter(inputLine,"""");

    pos = 0;
    GetNextSubstring(tstr,pos,",",accountnr);  
    GetNextSubstring(tstr,pos,",",transdate);  
    GetNextSubstring(tstr,pos,",",skip);  
    GetNextSubstring(tstr,pos,",",comment);
    GetNextSubstring(tstr,pos,",",reference);
    GetNextSubstring(tstr,pos,",",debitamount);
    GetNextSubstring(tstr,pos,",",creditamount);

    BTRr.TransDate = DateFromString(transdate,"DD-MM-YYYY");
    BTRr.CurncyCode = BCb.BaseCur1;
    BTRr.Comment = comment;
    BTRr.Reference = reference;
    GetBankAccPMRow(PMb,"",accountnr,PMbrw);
    damount = StringToVal(debitamount,M4Val);
    camount = StringToVal(creditamount,M4Val);
    if (damount>0) then begin
      BTRr.Sum = damount;
      BTRr.PayBankAcc = accountnr;
        if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
        BTRr.RcpBankAcc = CYb.Bank1;
        BTRr.RcpReference = BTRr.Reference;
        BTRr.RcpTransDate = BTRr.TransDate;

        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = CYb.CompName;
        BTRr.PayReference = BTRr.Reference;
        BTRr.PayRegNr1 = CYb.OrgNr;
        BTRr.PayVATNr = CYb.VATNr;
        BTRr.PayRegNr1 = CYb.OrgNr;
        BTRr.TypeRef = "D";
    end else begin
      BTRr.Sum = camount;
      BTRr.RcpBankAcc = accountnr;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpName = CYb.CompName;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;

      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.PayReference =  BTRr.Reference;
      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;

    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
    if (NextImportLine(true)) then begin
    end;
  end;
  
  return;
end;

updating procedure ImpBankAbsaBankSouthAfrica(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  record SysFormatBlock SFb;
  row PMBlock PMbrw;
  string 255 tstr,tstr2,inputLine;
  LongInt pos;
  string 255 amount,bankacc,transdate,desc,skip,skip2;
  Boolean blankf,loopf;
  
  BlockLoad(SFb);
  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);

  while (TestEOF==false) begin 
    inputLine = ImportField;
    RecordNew(BTRr);
    pos = 0;
    GetNextSubstring(inputLine,pos,",",transdate);
    GetNextSubstring(inputLine,pos,"",tstr);
    if (left(tstr,1)=="\"") then begin 
      pos = 1;
      GetNextSubstring(tstr,pos,"\"",desc);
      GetNextSubstring(tstr,pos,"\"",skip);
      pos = 0;
      GetNextSubstring(skip,pos,",",skip2);
      GetNextSubstring(skip,pos,",",amount);
    end else begin
      pos = 0;
      GetNextSubstring(tstr,pos,",",desc);   
      GetNextSubstring(tstr,pos,",",amount);
      GetNextSubstring(tstr,pos,",",skip);   
    end;
 
    RecordNew(BTRr);
    BTRr.Sum = StringToVal(StripCharacter(amount,"-"),M4Val);
    BTRr.CurncyCode = BCb.BaseCur1;;
    BTRr.TransDate = DateFromString(transdate,"YYYYMMDD");
    BTRr.Comment = desc;

    GetBankAccPMRow(PMb,"",bankacc,PMbrw);
    if (left(amount,1)=="-") then begin
      BTRr.PayBankAcc = bankacc;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.PayName = CYb.CompName;
      BTRr.PayVATNr = CYb.VATNr;
      BTRr.PayRegNr1 = CYb.OrgNr;
      BTRr.TypeRef = "D";
      BTRr.RcpBankAcc = CYb.Bank1;
      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;
    end else begin
      BTRr.RcpBankAcc = bankacc;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.PayBankAcc = CYb.Bank1;
      BTRr.PayReference = BTRr.Reference;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.RcpTransDate = BTRr.TransDate;

      BTRr.RcpName = CYb.CompName;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      BTRr.PayName = desc;
      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;
    
    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
    if (NextImportLine(true)) then begin
    end;
  end;
  
  return;
end;

updating procedure ImpBankBarclaysUK(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  record SysFormatBlock SFb;
  row PMBlock PMbrw;
  string 255 tstr,tstr2,inputLine;
  LongInt pos;
  string 255 amount,bankacc,transdate,transnr,reference,bankdesc;
  string 255 account,memo,pname,accountp1,accountp2,dateformat;
  Boolean blankf,loopf;
  
  BlockLoad(SFb);
  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);

  while (TestEOF==false) begin
    RecordNew(BTRr);

    inputLine = ImportField; 
    inputLine = ImportField;
    tstr = StripCharacter(inputLine,"""");

    pos = 0;
    GetNextSubstring(tstr,pos,",",transnr);  
    GetNextSubstring(tstr,pos,",",transdate);  
    GetNextSubstring(tstr,pos,",",account);  
    GetNextSubstring(tstr,pos,",",amount);
    GetNextSubstring(tstr,pos,",",tstr2);
    GetNextSubstring(tstr,pos,",",memo);

    pname = "";
    bankdesc = "";

    blankf = false;
    loopf = true;
    pos = 0;
    while (loopf) begin
      GetNextSubstring(memo,pos," ",tstr)
      if (blankf and blank(tstr)) then begin loopf = false; end;
      if (blank(tstr)) then begin blankf = true; end;
      if (loopf and nonblank(tstr)) then begin
        AddStrToStr(pname,tstr);
      end;
    end;

    blankf = false;
    loopf = true;
    while (loopf) begin
      GetNextSubstring(memo,pos," ",tstr)
      if (blankf and blank(tstr)) then begin loopf = false; end;
      if (blank(tstr)) then begin blankf = true; end;
      if (loopf and nonblank(tstr)) then begin
        AddStrToStr(bankdesc,tstr);
      end;
    end;

    pos = 0;
    GetNextSubstring(account,pos,"  ",accountp1);
    GetNextSubstring(account,pos,"  ",accountp2);

  
    switch (SFb.dateOrder) begin
      case 0: dateformat = "MM-DD-YYYY";
      case 1: dateformat = "DD-MM-YYYY";
      case 2: dateformat = "YYYY-MM-DD";
    end;

    BTRr.TransDate = DateFromString(transdate,dateformat);
    BTRr.CurncyCode = BCb.BaseCur1;
    BTRr.Sum = StringToVal(StripCharacter(amount,"-"),M4Val);
    BTRr.Reference = StripNonDigits(memo);
    BTRr.Comment = memo; 
    if (nonblank(transnr)) then begin
      BTRr.TRNumber = transnr;
    end;

    GetBankAccPMRow(PMb,"",bankacc,PMbrw);
    bankacc = GetBankAccountNr(PMb,RepSpec.f13,PMbrw);

    if (left(amount,1)=="-") then begin
      BTRr.PayBankAcc = bankacc;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.RcpBankAcc = CYb.Bank1;
      BTRr.RcpReference =  BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;
      BTRr.RcpName = pname;

      BTRr.PayRegNr1 = CYb.OrgNr;
      BTRr.PayVATNr = CYb.VATNr;
      BTRr.PayName = CYb.CompName;
      BTRr.PayRegNr1 = CYb.OrgNr;
      BTRr.PayBankAcc = accountp2;
      BTRr.PayReference = BTRr.Reference;
      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.TypeRef = "D";
    end else begin
      BTRr.RcpBankAcc = accountp2;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.PayBankAcc = CYb.Bank1;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpName = CYb.CompName;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;
      BTRr.PayTransDate = transdate;
      BTRr.PayReference =  BTRr.Reference;
      BTRr.PayName = pname;
      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;
    
    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
    if (NextImportLine(true)) then begin
    end;
  end;
  
  return;
end;

updating procedure ImpBankASBCCNZ(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  row PMBlock PMbrw;
  string 255 tstr,inputLine;
  string 255 transdate,amount,balance,dateformat;
  string 255 ccnr,accountname,particulars,code,reference,transtype;
  LongInt pos;
  integer i;
  string 255 ccused,processdate,desc;

  BlockLoad(PMb);
  BlockLoad(CYb);
  BlockLoad(SRb);
  BlockLoad(BCb);

  for (i=0;i<3;i=i+1) begin
    NextImportLine(true);
  end;
  while (TestEOF==false) begin
    RecordNew(BTRr);
    inputLine = ImportField; 
    tstr = StripCharacter(inputLine,""""); 
    pos = 0;
    GetNextSubstring(tstr,pos,",",ccnr);  
    GetNextSubstring(tstr,pos,",",ccused);  
    GetNextSubstring(tstr,pos,",",reference);  
    GetNextSubstring(tstr,pos,",",transdate);
    GetNextSubstring(tstr,pos,",",amount);
    GetNextSubstring(tstr,pos,",",processdate);
    GetNextSubstring(tstr,pos,",",desc);
    StripSpace(ccnr,ccnr);

    BTRr.TransDate = DateFromString(transdate,"DD/MM/YY");
    BTRr.CurncyCode = BCb.BaseCur1;
    BTRr.Sum = StringToVal(StripCharacter(amount,"-"),M4Val);
    BTRr.Comment = desc; 
    BTRr.Balance = StringToVal(balance,M4Val);
    BTRr.Reference = reference;
    GetBankAccPMRow(PMb,"",ccnr,PMbrw);

    if (left(amount,1)!="-") then begin
      pos = 0;
      BTRr.PayBankAcc = ccnr;
        if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
        BTRr.RcpReference = BTRr.Reference;
        BTRr.RcpTransDate = BTRr.TransDate;

        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = CYb.CompName;
        BTRr.PayReference = BTRr.Reference;
        BTRr.PayRegNr1 = CYb.OrgNr;
        BTRr.PayVATNr = CYb.VATNr;
        BTRr.PayRegNr1 = CYb.OrgNr;
        BTRr.TypeRef = "D";
    end else begin
      BTRr.RcpBankAcc = ccnr;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpName = CYb.CompName;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;

      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.PayReference =  BTRr.Reference;
      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;

    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
    if (NextImportLine(true)) then begin
    end;
  end;
  return;
end;

updating procedure ImpBankBNZNZ(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  row PMBlock PMbrw;
  string 255 tstr,inputLine;
  string 255 transdate,amount;
  string 255 particulars,code,reference,otherparty,transtype;
  string 255 thisparty,payee,serial,transcode,batchnr,origbank,processdate;
  LongInt pos;

  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);
  NextImportLine(true);

  while (TestEOF==false) begin
    RecordNew(BTRr);
    inputLine = ImportField; 
    tstr = StripCharacter(inputLine,"""");
    pos = 0;
 
    GetNextSubstring(tstr,pos,",",transdate);  
    GetNextSubstring(tstr,pos,",",amount);
    GetNextSubstring(tstr,pos,",",payee);
    GetNextSubstring(tstr,pos,",",particulars);
    GetNextSubstring(tstr,pos,",",code);
    GetNextSubstring(tstr,pos,",",reference);
    GetNextSubstring(tstr,pos,",",transtype);
    GetNextSubstring(tstr,pos,",",thisparty);
    thisparty = StripCharacter(thisparty,"-");
    GetNextSubstring(tstr,pos,",",otherparty);
    otherparty = StripCharacter(otherparty,"-");
    GetNextSubstring(tstr,pos,",",serial);
    GetNextSubstring(tstr,pos,",",transcode);
    GetNextSubstring(tstr,pos,",",batchnr);
    GetNextSubstring(tstr,pos,",",origbank);
    GetNextSubstring(tstr,pos,",",processdate);

    BTRr.TransDate = DateFromString(transdate,"DD/MM/YY");
    BTRr.CurncyCode = BCb.BaseCur1;
    BTRr.Sum = StringToVal(StripCharacter(amount,"-"),M4Val);
    BTRr.Comment = particulars; 
    BTRr.Reference = reference;
    GetBankAccPMRow(PMb,"",thisparty,PMbrw);
    thisparty = Right(thisparty,9);
    if (left(amount,1)=="-") then begin
      pos = 0;
      BTRr.PayBankAcc = thisparty;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
        BTRr.RcpBankAcc = otherparty;
        BTRr.RcpReference = BTRr.Reference;
        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpName = payee;

        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = CYb.CompName;
        BTRr.PayReference = BTRr.Reference;
        BTRr.PayRegNr1 = CYb.OrgNr;
        BTRr.PayVATNr = CYb.VATNr;
        BTRr.PayRegNr1 = CYb.OrgNr;
        BTRr.TypeRef = "D";
    end else begin
      BTRr.RcpBankAcc = Right(thisparty,9);
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpName = CYb.CompName;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;

      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.PayName = payee;
      BTRr.PayReference =  BTRr.Reference;
      BTRr.PayBankAcc = otherparty;

      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;

    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
    if (NextImportLine(true)) then begin
    end;
  end;
  
  return;
end;

updating procedure ImpBankASBNZ(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  row PMBlock PMbrw;
  string 255 tstr,inputLine;
  string 255 transdate,amount,balance,dateformat;
  string 255 accountnr,accountname,particulars,code,reference,otherparty,transtype;
  LongInt pos;

  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);

  while (TestEOF==false) begin
    RecordNew(BTRr);
    inputLine = ImportField; 
    tstr = StripCharacter(inputLine,"""");
    pos = 0;
    GetNextSubstring(tstr,pos,",",accountnr);  
    GetNextSubstring(tstr,pos,",",accountname);  
    GetNextSubstring(tstr,pos,",",transdate);  
    GetNextSubstring(tstr,pos,",",amount);
    GetNextSubstring(tstr,pos,",",particulars);
    GetNextSubstring(tstr,pos,",",code);
    GetNextSubstring(tstr,pos,",",reference);
    GetNextSubstring(tstr,pos,",",otherparty);
    GetNextSubstring(tstr,pos,",",transtype);
    GetNextSubstring(tstr,pos,",",balance);

    if (FindStringInString(accountnr,"Created")) then begin goto LImpBankASBNZ; end;
    if (FindStringInString(accountnr,"Transaction(s)")) then begin goto LImpBankASBNZ; end;
    if (FindStringInString(accountnr,"Account")) then begin goto LImpBankASBNZ; end;

    BTRr.TransDate = DateFromString(transdate,"YYYY-MM-DD");
    BTRr.CurncyCode = BCb.BaseCur1;
    BTRr.Sum = StringToVal(StripCharacter(amount,"-"),M4Val);
    BTRr.Comment = particulars & " " & code & " " & reference & " " & otherparty; 
    BTRr.Balance = StringToVal(balance,M4Val);
    BTRr.Reference = reference;
    GetBankAccPMRow(PMb,"",accountnr,PMbrw);

    if (left(amount,1)=="-") then begin
      pos = 0;
      BTRr.PayBankAcc = accountnr;
        if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.PayBankAcc)) then begin
        BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
        BTRr.RcpBankAcc = CYb.Bank1;
        BTRr.RcpReference = BTRr.Reference;
        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpName = StripDigits(otherparty);

        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = CYb.CompName;
        BTRr.PayReference = BTRr.Reference;
        BTRr.PayRegNr1 = CYb.OrgNr;
        BTRr.PayVATNr = CYb.VATNr;
        BTRr.PayRegNr1 = CYb.OrgNr;
        BTRr.TypeRef = "D";
    end else begin
      BTRr.RcpBankAcc = accountnr;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = RepSpec.f20;
      end;
      if (blank(BTRr.RcpBankAcc)) then begin
        BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
      end;
      BTRr.RcpVATNr = CYb.VATNr;
      BTRr.RcpName = CYb.CompName;
      BTRr.RcpRegNr1 = CYb.OrgNr;
      BTRr.RcpReference = BTRr.Reference;
      BTRr.RcpTransDate = BTRr.TransDate;

      BTRr.PayTransDate = BTRr.TransDate;
      BTRr.PayName = StripDigits(otherparty);
      BTRr.PayReference =  BTRr.Reference;
      BTRr.TypeRef = "C";
      CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;

    if (BTRr.Sum!=0) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
LImpBankASBNZ:;
    if (NextImportLine(true)) then begin
    end;
  end;
  
  return;
end;

procedure StripZeroBeforeAmount(string amount,var string newamount)
begin
  Integer i;
  string 255 tstr;

  while (i<len(amount)) begin      
      if(Mid(amount,i,1)!="0")then begin
      tstr = right(amount,len(amount)-i);
      i = len(amount);
      newamount = tstr;
    end;
    i = i + 1;
  end;
  return;
end;

updating procedure ImpBankMT940PEKAOSAPOL(record RcVc RepSpec)
begin
  record BankTRVc BTRr;
  record CYBlock CYb;
  record PMBlock PMb;
  record SRBlock SRb;
  record BaseCurBlock BCb;
  row PMBlock PMbrw;
  LongInt pos;
  Integer i;
  string 255 additionalref,otherbankacc,fullcomment,newamount,name,comment,oneline,lastcurrletter,type,bankacc,transdate,currency,amount,desc,reference,skip,inputLine,tstr;
  Boolean firstf,addfirstf;

  SetImportCodePage("CP852");

  BlockLoad(PMb);
  BlockLoad(CYb)
  BlockLoad(SRb);
  BlockLoad(BCb);
  NextImportLine(true);

  while (TestEOF==false) begin
    if (Left(inputLine,5)==":28C:") then begin additionalref = Mid(inputLine,5,len(inputLine)-5);end;
    if (Left(inputLine,4)!=":61:") then begin
      NextImportLine(true);
      inputLine = ImportField; 
      if (Left(inputLine,3)==":25") then begin
        pos = 0;
        GetNextSubString(inputLine,pos,"/",skip);
        GetNextSubString(inputLine,pos,"/",bankacc);
      end;
    end else begin
      transdate =  Mid(inputLine,4,6);
      type =  Mid(inputLine,14,1);
      lastcurrletter = Mid(inputLine,15,1);
      pos = 16;
      GetNextSubString(inputLine,pos,"N",amount);
      StripZeroBeforeAmount(amount,newamount)
      if (FindStringInString(inputLine,"NONREF")==false) then begin
        GetNextSubString(inputLine,pos,"N",reference);
      end else begin
        reference = additionalref;
      end;
      NextImportLine(true);
      inputLine = ImportField; 
      if (Left(inputLine,3)==":86") then begin
        firstf = true;
        if (firstf) then begin
          oneline = inputLine;
          firstf = false;
        end;
        NextImportLine(true);
        inputLine = ImportField; 
        if (Left(inputLine,1)=="^") begin
          goto LImpBankMT940PEKAOSAPOL;
        end;  
        while (Left(inputLine,1)=="^") begin
          NextImportLine(true);
          inputLine = ImportField; 
          if (Left(inputLine,1)==":") begin
            goto LImpBankMT940PEKAOSAPOLSkip;
          end; 
LImpBankMT940PEKAOSAPOL:;
          oneline = oneline & " " & inputLine;
          LImpBankMT940PEKAOSAPOLSkip:;
        end;
        pos = 0;
        addfirstf = true;
        name = ""; fullcomment = "";
        while (GetNextSubstring(oneline,pos,chr(94),tstr)) begin
          if (Left(tstr,2)>"19") and (Left(tstr,2)<"26") then begin
            comment = Right(tstr,Len(tstr)-2);
            if (addfirstf) then begin
              fullcomment = comment;
              addfirstf = false;
            end else begin
              fullcomment = fullcomment & comment;
            end;
          end;
          if (Left(tstr,2)>"31") and (Left(tstr,2)<"34") then begin
            name = name &  Right(tstr,Len(tstr)-2);
          end;
          if (Left(tstr,2)=="38") then begin
            otherbankacc = Right(tstr,Len(tstr)-2);
          end;
          if (blank(otherbankacc)) then begin
            if (Left(tstr,2)=="29") then begin
              otherbankacc = Right(tstr,Len(tstr)-2);
            end;
          end;  
        end;
      end;
      RecordNew(BTRr);
      BTRr.OffReference = additionalref;
      BTRr.CurncyCode = BCb.BaseCur1;
      BTRr.TransDate = StringToDateFmt(transdate,m4_ymd);
      BTRr.Comment = fullcomment;
      BTRr.Sum = StringToValue(newamount,M4Rate,"",",");
      BTRr.Reference = reference;
      GetBankAccPMRow(PMb,"",bankacc,PMbrw);
      if (type=="D") then begin
         BTRr.PayBankAcc = bankacc;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = RepSpec.f20;
        end;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
        end;
         BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = CYb.CompName;
        BTRr.PayVATNr = CYb.VATNr;
        BTRr.PayRegNr1 = CYb.OrgNr;
        BTRr.TypeRef = "D";
        BTRr.RcpName = name;
        if (nonblank(otherbankacc)) then begin
          BTRr.RcpBankAcc = otherbankacc;
        end else begin
          BTRr.RcpBankAcc = CYb.Bank1;
        end;
        BTRr.RcpReference = BTRr.Reference;
        BTRr.RcpTransDate = BTRr.TransDate;
       end else begin
         BTRr.RcpBankAcc = bankacc;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = RepSpec.f20;
        end;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
        end;      
        if (nonblank(otherbankacc)) then begin
          BTRr.PayBankAcc = otherbankacc;
        end else begin
          BTRr.PayBankAcc = CYb.Bank1;
        end;
        BTRr.PayName = name;
       // BTRr.PayReference = BTRr.Reference;
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpName = CYb.CompName;
        BTRr.RcpVATNr = CYb.VATNr;
        BTRr.RcpRegNr1 = CYb.OrgNr;
        BTRr.TypeRef = "C";
        CreateReceipt(SRb,PMbrw.Code,BTRr,false);
       end;
      
      if (BTRr.Sum!=0) then begin
        BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
        if (BTRr.SerNr>0) then begin
          RecordStore(BTRr,false);
        end;
      end;
    end;  
  end;
  return;
end;

