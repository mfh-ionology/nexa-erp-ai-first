  xml xdata;
  Integer n;
  record CYBlock CYb;
  record PMBlock PMb;
  row PMBlock PMbrw;
  record SRBlock SRb;
  
  BlockLoad(PMb);
  BlockLoad(CYb);
  BlockLoad(SRb);
	
  xdata = ParseXmlFile(GetImportFileName);

  acctkey = "Document/Stmt/Acct/";
  sortcode = XmlGet(xdata,"Document/BkToCstmrStmt/Stmt/Acct/Svcr/FinInstnId/BIC");
  bankacc = XmlGet(xdata,"Document/BkToCstmrStmt/Stmt/Acct/Id/IBAN");

  GetBankAccPMRow(PMb,"",bankacc,PMbrw);

  acctkey = "Document/BkToCstmrStmt/Stmt/Acct/";
  balkey = "Document/BkToCstmrStmt/Stmt/Bal/";
  nkey = "Document/BkToCstmrStmt/Stmt/Ntry";

  n = 0;
  while (XmlNodeExists(xdata,nkey & "[" & n & "]")) begin
    ntrykey = nkey & "[" & n & "]/";
    RecordNew(BTRr);

    BTRr.CurncyCode = XmlGetAttribute(xdata,ntrykey & "Amt","Ccy");
    BTRr.Sum = ValFromString(XmlGet(xdata,ntrykey & "Amt"),".","");
    BTRr.TypeRef = XmlGet(xdata,ntrykey & "CdtDbtInd");
    BTRr.TransDate = DateFromString(XmlGet(xdata,ntrykey & "BookgDt/Dt"),"YYYY-MM-DD");

    BTRr.TRNumber = XmlGet(xdata,ntrykey & "AcctSvcrRef");
    BTRr.Reference = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/Refs/AcctSvcrRef");
    switch (Left(BTRr.TypeRef,1)) begin
      case "D":
        BTRr.PayBankAcc = bankacc;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = RepSpec.f20;
        end;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
        end;
        
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = CYb.CompName;
        BTRr.PayVATNr = CYb.VATNr;
        BTRr.PayRegNr1 = CYb.OrgNr;

        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpName = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RltdPties/Cdtr/Nm");
        BTRr.RcpRegNr1 = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RltdPties/Cdtr/Id/OrgId/Othr/Id");
        BTRr.RcpBankAcc = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RltdPties/CdtrAcct/Id/IBAN");

        if (nonblank(XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Strd/CdtrRefInf/Ref"))) then begin
          BTRr.RcpReference = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Strd/CdtrRefInf/Ref");
        end else begin
          BTRr.RcpReference = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Ustrd");
        end;
        if (nonblank(XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Ustrd"))) then begin
          BTRr.Comment =XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Ustrd");
        end else begin
          BTRr.Comment = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Strd/CdtrRefInf/Ref");
        end;

      case "C":
        BTRr.RcpBankAcc = bankacc;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = RepSpec.f20;
        end;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
        end;

        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpName = CYb.CompName;
        BTRr.RcpVATNr = CYb.VATNr;
        BTRr.RcpRegNr1 = CYb.OrgNr;

        BTRr.PayBankAcc = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RltdPties/DbtrAcct/Id/IBAN");
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RltdPties/Dbtr/Nm");
        BTRr.PayRegNr1 = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RltdPties/Dbtr/Id/OrgId/Othr/Id");

        if nonblank(XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Strd/CdtrRefInf/Ref")) then begin
          BTRr.PayReference = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Strd/CdtrRefInf/Ref");
        end else begin
          BTRr.PayReference = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Ustrd");
        end;
        if (nonblank(XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Ustrd"))) then begin
          BTRr.Comment =XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Ustrd");
        end else begin
          BTRr.Comment = XmlGet(xdata,ntrykey & "NtryDtls/TxDtls/RmtInf/Strd/CdtrRefInf/Ref");
        end;
        CreateReceipt(SRb,PMbrw.Code,BTRr,false);
    end;
    
    oBTRr.TRNumber = BTRr.TRNumber;
    if (ReadFirstKey("TRNumber",oBTRr,1,true)==false) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;

    n = n + 1;
  end;
  
  while (TestEOF==false) begin
    inputLine = ImportField;
    if (NextImportLine(true)) then begin
    end;
  end;
  return;
end;

updating procedure ImpSEBSWEDEN(record RcVc RepSpec,Integer format)
begin
  record BankTRVc oBTRr;
  record BankTRVc BTRr;
  string 255 acctkey,balkey,ntrykey,nkey,nkey2,ntrykey2;
  string 255 sortcode,bankacc,inputLine;
  xml xdata,xdata2;
  Integer n,j, cnt2;
  record CYBlock CYb;
  record PMBlock PMb;
  row PMBlock PMbrw;
  record SRBlock SRb;
  string 255 x,z,currency,a,b,reference;
  val y,sum;
  area data2area;
  string 255 formatkey1,formatkey2;

  switch (format) begin
    case kReceiptBankSEBSweden:
      formatkey1 = "BkToCstmrStmt";
      formatkey2 = "Stmt";
    case kReceiptBankSEBSweden054:
      formatkey1 = "BkToCstmrDbtCdtNtfctn";
      formatkey2 = "Ntfctn";
  end;

  BlockLoad(PMb);
  BlockLoad(CYb);
  BlockLoad(SRb);
	
  xdata = ParseXmlFile(GetImportFileName);
  acctkey = "Document/" & formatkey2 & "/Acct/";
  sortcode = XmlGet(xdata,"Document/" & formatkey1 & "/" & formatkey2 & "/Acct/Svcr/FinInstnId/BIC");
  bankacc = XmlGet(xdata,"Document/" & formatkey1 & "/" & formatkey2 & "/Acct/Id/Othr/Id");
  if (blank(bankacc)) then begin
    bankacc = XmlGet(xdata,"Document/" & formatkey1 & "/" & formatkey2 & "/Acct/Id/IBAN");
  end;
  GetBankAccPMRow(PMb,"",bankacc,PMbrw);
  acctkey = "Document/" & formatkey1 & "/" & formatkey2 & "/Acct/";
  balkey = "Document/" & formatkey1 & "/" & formatkey2 & "/Bal/";
  nkey = "Document/" & formatkey1 & "/" & formatkey2 & "/Ntry";
  n = 0;
  while (XmlNodeExists(xdata,nkey & "[" & n & "]")) begin
    ntrykey = nkey & "[" & n & "]";
    RecordNew(BTRr);

    if (nonblank( XmlGet(xdata,ntrykey & "/NtryDtls/TxDtls/Refs/AcctSvcrRef"))) then begin
      BTRr.Reference =  XmlGet(xdata,ntrykey & "/NtryDtls/TxDtls/Refs/AcctSvcrRef");
    end else begin
      BTRr.Reference =XmlGet(xdata,ntrykey & "/AcctSvcrRef");
    end;
    BTRr.TypeRef = XmlGet(xdata,ntrykey & "/CdtDbtInd");
    switch (Left(BTRr.TypeRef,1)) begin
      case "D":
        BTRr.PayBankAcc = bankacc;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = RepSpec.f20;
        end;
        if (blank(BTRr.PayBankAcc)) then begin
          BTRr.PayBankAcc = PMbrw.SortCode & PMbrw.BankNr;
        end;
        BTRr.TRNumber = XmlGet(xdata,ntrykey & "/AcctSvcrRef");
        BTRr.TransDate = DateFromString(XmlGet(xdata,ntrykey & "/BookgDt/Dt"),"YYYY-MM-DD");  
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = CYb.CompName;
        BTRr.PayVATNr = CYb.VATNr;
        BTRr.PayRegNr1 = CYb.OrgNr;
        reference = XmlGet(xdata,ntrykey & "/NtryDtls/TxDtls/RmtInf/Strd/RfrdDocInf/Nb");
        if (nonblank(XmlGet(xdata,ntrykey & "/NtryDtls/TxDtls/RmtInf/Strd/AddtlRmtInf"))) then begin
          reference = reference & " " & XmlGet(xdata,ntrykey & "/NtryDtls/TxDtls/RmtInf/Strd/AddtlRmtInf");
        end;
        BTRr.PayReference = reference;
        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpName = XmlGet(xdata,ntrykey & "/NtryDtls/TxDtls/RltdPties/Cdtr/Nm");
        BTRr.RcpRegNr1 = XmlGet(xdata,ntrykey & "/NtryDtls/TxDtls/RltdPties/Cdtr/Id/OrgId/Othr/Id");
        BTRr.RcpBankAcc = XmlGet(xdata,ntrykey & "/NtryDtls/TxDtls/RltdPties/CdtrAcct/Id/Othr/Id");
        BTRr.CurncyCode = XmlGetAttribute(xdata,ntrykey & "/NtryDtls/TxDtls/AmtDtls/TxAmt/Amt","Ccy"); 
        BTRr.Sum = ValFromString(XmlGet(xdata,ntrykey & "/NtryDtls/TxDtls/AmtDtls/TxAmt/Amt"),".","");
        BTRr.RcpReference = XmlGet(xdata,ntrykey & "/NtryDtls/TxDtls/RmtInf/Strd/CdtrRefInf/Ref");
        BTRr.Comment = XmlGet(xdata,ntrykey & "/NtryDtls/TxDtls/RmtInf/Strd/CdtrRefInf/Ref");
        if (blank(BTRr.Comment)) then begin
           BTRr.Comment = XmlGet(xdata,ntrykey & "/NtryDtls/TxDtls/RmtInf/Ustrd");
        end;
      case "C":
        BTRr.RcpBankAcc = bankacc;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = RepSpec.f20;
        end;
        if (blank(BTRr.RcpBankAcc)) then begin
          BTRr.RcpBankAcc = PMbrw.SortCode & PMbrw.BankNr;
        end;
      j = 0;    
      while (XmlNodeExists(xdata,ntrykey & "/NtryDtls/TxDtls" & "[" & j & "]")) begin
        ntrykey2 = ntrykey & "/NtryDtls/TxDtls" &  "[" & j & "]";  
        BTRr.TransDate = DateFromString(XmlGet(xdata,ntrykey & "/BookgDt/Dt"),"YYYY-MM-DD");
        BTRr.RcpTransDate = BTRr.TransDate;
        BTRr.RcpName = CYb.CompName;
        BTRr.RcpVATNr = CYb.VATNr;
        BTRr.RcpRegNr1 = CYb.OrgNr;
  
        BTRr.PayBankAcc = XmlGet(xdata,ntrykey2 & "/RltdPties/DbtrAcct/Id/Othr/Id");
        BTRr.PayTransDate = BTRr.TransDate;
        BTRr.PayName = XmlGet(xdata,ntrykey2 & "/RltdPties/Dbtr/Nm");
        BTRr.PayRegNr1 = XmlGet(xdata,ntrykey2 & "/RltdPties/Dbtr/Id/OrgId/Othr/Id");

        if (nonblank(XmlGet(xdata,ntrykey2 & "/RmtInf/Strd/RfrdDocInf/Nb"))) then begin
          reference = XmlGet(xdata,ntrykey2 & "/RmtInf/Strd/RfrdDocInf/Nb");
          if (nonblank(XmlGet(xdata,ntrykey2 & "/RmtInf/Strd/AddtlRmtInf"))) then begin
            reference = reference & " " & XmlGet(xdata,ntrykey2 & "/RmtInf/Strd/AddtlRmtInf");
          end;
        end else begin
          reference = XmlGet(xdata,ntrykey2 & "/RmtInf/Strd/CdtrRefInf/Ref");
        end;
        BTRr.PayReference = reference;
        BTRr.Comment = reference;
        BTRr.CurncyCode = XmlGetAttribute(xdata,ntrykey2 & "/AmtDtls/TxAmt/Amt","Ccy");

        /*
         <Strd>
          <RfrdDocInf>
            <Tp>
              <CdOrPrtry>
                <Cd>CINV</Cd>
              </CdOrPrtry>
            </Tp>
            <Nb>15257</Nb>
          </RfrdDocInf>
          <RfrdDocAmt>
            <RmtdAmt Ccy="SEK">158657.00</RmtdAmt>
          </RfrdDocAmt>
        </Strd>

        Reference / Tr. number = what we use currently <AcctSvcrRef> + <Nb> from each <Strd> section, so we can make this number unique
        Type = if <Cd>CINV</Cd>  enter CRDT
                    if <Cd>CREN</Cd> enter DEBIT
        Sum = from <Strd> section <RmtdAmt
        Currency = from <Strd> section <RmtdAmt
        Comment = <Nb> from each <Strd> section

        if type = CRDT
        - P.name from <Dbtr><Nm>
        - P.Bank acc. from DbtrAcct><Id><Othr><Id>
        - P.Reference from <Strd> section <Nb>

        if type = DEBIT
        - R.name from <Dbtr><Nm>
        - R.Bank acc. from DbtrAcct><Id><Othr><Id>
        - R.Reference from <Strd> section <Nb>

        In our example:

        transaction 1
        Reference = STOIIQ0I230102135810870220000001_15257
        Tr. number = STOIIQ0I230102135810870220000001_15257
        Type =CRDT       
        Sum = 158657.00
        Currency = SEK
        Comment = 15257
        P.name = BLOMSTERBODA Sverige AB STÄNGSELBODAVÄGEN 1
        P.Bank acc. = 51820892
        P.Reference = 15257
        ….
        transaction 4

        Reference = STOIIQ0I230102135810870220000001_90717
        Tr. number = STOIIQ0I230102135810870220000001_90717
        Type =DEBIT       
        Sum = 158657.00
        Currency = SEK
        Comment = 90717
        R.name = BLOMSTERBODA Sverige AB STÄNGSELBODAVÄGEN 1
        R.Bank acc. = 51820892
        R.Reference = 90717

        */
       
        BTRr.Sum = ValFromString(XmlGet(xdata,ntrykey2 & "/AmtDtls/TxAmt/Amt"),".","");
        BTRr.TRNumber = XmlGet(xdata,ntrykey2 & "/Refs/AcctSvcrRef");
        BTRr.Reference = BTRr.TRNumber;

        CreateReceipt(SRb,PMbrw.Code,BTRr,false);
        j = j + 1;
        oBTRr.TRNumber = BTRr.TRNumber;
        if (ReadFirstKey("TRNumber",oBTRr,1,true)==false) then begin
          BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
          if (BTRr.SerNr>0) then begin
            RecordStore(BTRr,false);
          end;
        end;
      end;
    end;
    oBTRr.TRNumber = BTRr.TRNumber;
    if (ReadFirstKey("TRNumber",oBTRr,1,true)==false) then begin
      BTRr.SerNr = NextSerNr("BankTRVc",BTRr.TransDate,-1,false,"");
      if (BTRr.SerNr>0) then begin
        RecordStore(BTRr,false);
      end;
    end;
    n = n + 1;
  end;
  while (TestEOF==false) begin
    inputLine = ImportField;
    if (NextImportLine(true)) then begin
    end;
  end;
  return;
end;

