external function Boolean WrapAndPrint(Integer,string,Integer);
external function Boolean FindTheUser(var record UserVc);
external procedure HTEmployees(string,string,var string);
external procedure HT2Per2(Integer,Date,Date,var string);

procedure PrintActivities(record RcVc RepSpec,integer recnr)
begin
  record ActVc Actr;
  Boolean foundf,found2f,testf,firstf;
  record EmplPSVc EmplPSr;
  Integer count;

  foundf = true; firstf = true; count = 0;
  Actr.CUCode = RepSpec.f2;
  while (LoopBackKey("CUCodeActType",Actr,1,foundf)) begin
    if (Actr.CUCode!=RepSpec.f2) then begin foundf = false; end;
    if (foundf) then begin
      testf = true;
      if (Actr.Invalid!=0) then begin testf = false; end;
      if (recnr!=0) then begin  
        if (count>=recnr) then begin
          testf = false;
        end;  
      end; 
      if (testf) then begin
        if (firstf) then begin
          StartFormat(15);
          OutString(2,0,USetStr(43220),false);
          EndFormat;
          firstf = false;
        end;
        count = count + 1;
        StartFormat(15);
        OutStringID(3,"DblActRec",Actr.TransDate,false,Actr.SerNr);
        OutString(4,"DblPersAct",Actr.MainPersons,false);
        WrapAndPrint(8,Actr.Comment,58);
        EndFormat;
      end;
    end;
  end;
  Gray_Divider(0,1);
  return;
end;

procedure PrintPerformanceAppr(record RcVc RepSpec,integer recnr)
begin
  record HRMPAVc HRMPAr;
  Boolean foundf,testf,firstf;
  integer count;

  foundf = true; firstf = true; count = 0;
  while (LoopBackKey("Employee",HRMPAr,1,foundf)) begin
    testf = true;
    if (nonblank(RepSpec.f2)) then begin
      if (HRMPAr.Employee!=RepSpec.f2) then begin testf = false; end;
    end;
    if (recnr!=0) then begin  
       if (count>=recnr) then begin
        testf = false;
      end;  
    end; 
    if (testf) then begin
      if (firstf) then begin
        StartFormat(10);
        EndFormat;
        StartFormat(15);
        OutString(2,0,USetStr(43221),false);
        EndFormat;
        firstf = false;
      end;
      count = count + 1;
      StartFormat(15);
      OutLongInt(2,"DblHRMPAVc",HRMPAr.SerNr,false);
      OutDate(3,0,HRMPAr.TransDate,false);
      OutString(8,0,HRMPAr.Comment,false);      
      EndFormat;
    end;
  end;
  Gray_Divider(15,1);
  return;
end;

