function Boolean IsDateOlderThanDays(date dt,Integer curstatus,Integer days)
begin
  Boolean res;
  date tdt;

  if (blankdate(dt)) then begin // Important!
    res = true;
    goto LIsDateOlderThanDays;
  end;
  if (curstatus==kStatusRunning) then begin goto LIsDateOlderThanDays; end;
  if (days==0) then begin goto LIsDateOlderThanDays; end;

  tdt = AddDay(CurrentDate,-days);
  if (dt<tdt) then begin res = true; end;

LIsDateOlderThanDays:;
  IsDateOlderThanDays = res;
  return;
end;

