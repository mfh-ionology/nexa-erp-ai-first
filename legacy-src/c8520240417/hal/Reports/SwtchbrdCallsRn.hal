external procedure HT2Per(Date, Date , var string);
external procedure GetUserDefActTypes(string,string,var string,var Integer,var Integer);
external procedure GetUserName(string,var string);
external remote procedure ActPers1CompanyRn(record RcVc ,string , string ,var LongInt ,var val );
