LogText(0,"TelephonySetupOverviewRn get inside here2");
    OutString(170,"DblUserVc",USr.Code,false);
    CheckAstName(asteriskusername,USr.AstUserName,usererrf);
  end;
  */
  /*
LogText(0,"TelephonySetupOverviewRn get here3");
  if (ReadFirstMain(AsteriskUserr,0,true)) then begin
LogText(0,"TelephonySetupOverviewRn get here3 name=" & AsteriskUserr.Name);
    OutString(210,"DblAsteriskUser2Vc",AsteriskUserr.SerNr,false);
    CheckAstName(asteriskusername,AsteriskUserr.UserName,usererrf);
  end;
*/
  EndFormat;
  return;
end;

global
procedure TelephonySetupOverviewRn(record RcVc RepSpec)
begin
  record PBXConnectionVc PBXCr;
  record SipTrunk2Vc STr;
  array record SipTrunk2Vc STra;
  row SipTrunk2Vc STrw;
  Boolean TrHs,foundf,testf,includeclosedf;
  integer cnt,i,rwcnt,arrid,alen,length;
  string 255 phonenr,pbxcode;
  vector integer namev;
  array record GlobalUserVc GUra;
  array record UserVc USra;
  array record AsteriskUser2Vc AsteriskUserra;
  array string 255 atags;
  
  includeclosedf = RepSpec.flags[1];
  StartReportJob("Telephony Setup Overview");
  if (nonblank(RepSpec.f1) and blank(RepSpec.f2)) then begin
    PBXCr.Code = RepSpec.f1;
    if (ReadFirstMain(PBXCr,1,true)) then begin
      TrHs = true;
      cnt = 0;
      STr.PBXConnection = PBXCr.Code;
      while(LoopKey("PBXConnection",STr,1,TrHs)) begin
        testf = true;
        if (STr.Closedf!=0 and includeclosedf==false) then begin testf = false; end;
        if (STr.PBXConnection!=PBXCr.Code) then begin TrHs = false; testf = false; end;
        if (testf) then begin
          STra[cnt] = STr;
          cnt = cnt + 1;
        end;
      end;
      pbxcode = PBXCr.Code;
      Header(1,"PBX: " & PBXCr.Comment,1);
    end else begin
      Header(1,"no match found for PBX " & RepSpec.f1,1);
    end;
  end;
  
  if (nonblank(RepSpec.f2)) then begin
    phonenr = RepSpec.f2;
    TrHs = true;
    foundf = false;
    cnt = 0;
    while(LoopMain(STr,1,TrHs)) begin
      rwcnt = MatRowCnt(STr);
      for (i=0;i<rwcnt;i=i+1) begin
        MatRowGet(STr,i,STrw);
        if (InString(STrw.Extension,phonenr)) then begin
          foundf = true;
          STra[cnt] = STr;
          cnt = cnt + 1;
          TrHs = false;
        end;
      end;
      if (foundf==false and InString(STr.DefaultCallerId,phonenr)) then begin
        foundf = true;
        STra[cnt] = STr;
        cnt = cnt + 1;
        TrHs = false;
      end;
    end;
    if (foundf) then begin
      pbxcode = STr.PBXConnection;
      Header(1,phonenr & " found in SIP trunk: " & STr.Code,1);
    end else begin
      Header(1,"no match found for number " & RepSpec.f2,1);
    end;
  end;
  EndHeader;
  
  for (i=0;i<cnt;i=i+1) begin
    STr = STra[i];
    OutpuSIPTrunk(STr,includeclosedf);
  end;
  if (nonblank(pbxcode)) then begin
    alen = 1;
    FillGlobalUserArray(pbxcode,GUra,namev,alen);
    FillPersonArray(pbxcode,USra,namev,alen);
    FillAsteriskUserArray(pbxcode,AsteriskUserra,namev,alen);
    GetVectorTags(namev,atags);
    SortStringArray(atags);
    length = atags.length;
    StartFormat(15);
    OutString(130,0,"Global user",false);
    OutString(170,0,"Person",false);
    OutString(210,0,"Asterisk User",false);
    EndFormat;
    for(i=0;i<length;i=i+1) begin
      arrid = namev[atags[i]];
      OutputPBXUsers(atags[i],GUra[arrid],USra[arrid],AsteriskUserra[arrid]);
    end;
  end;
  
  if (blank(RepSpec.f1) and blank(RepSpec.f2)) then begin
    StartFormat(15);
    OutString(120,0,"Specify a PBX connection or a phone number.",false);
    EndFormat;
  end;
  StartFormat(15);
  EndFormat;
  EndJob;
    
  return;
end;
