external function LongInt DateDiff(Date,Date);
external function LongInt MonthDiff(Date,Date);
external procedure FindFiscalYear(Date,var Date,var Date);
external procedure vTimeDiff(Time,Time,var val);
external procedure HTDepartments(string,string,var string);
external procedure HTJobTitles(string,string,var string);
external procedure HTEmployees(string,string,var string);
external function Boolean FindHRMCOChange(LongInt,var record HRMCOChangeVc);
external function roundmode SetRoundModeD(Integer);
external function LongInt DaysInYear(Integer);
external function val CheckLeaveUsed(Date,Date,record HRMCOVc);
external procedure HT2Per(Date,Date,var string);

function Boolean CompanyHasContracts()
begin
  Boolean res;
  record HRMCOVc HRMCOr;
  Boolean found;
  Integer cnt;
  
  found = true;
  while (LoopMain(HRMCOr,1,found)) begin
    cnt = cnt + 1;
    if (cnt>0) then begin
      found = false;
      res = true;
    end;
  end;

  CompanyHasContracts = res;
  
  return;
end;

procedure PrintHeader(record RcVc RepSpec)
begin
  Integer rw;
  string 255 tstr;
  string 255 fremp,toemp;

  rw = 1;
  HT2Per(RepSpec.sStartDate,RepSpec.sEndDate,tstr);
  Header(rw,tstr,1);
  rw = rw + 1;
  tstr = USetStr(19652) & ": " & USetStr(19653+RepSpec.flags[0]);
  Header(rw,tstr,0);
  if (nonblank(RepSpec.f1)) then begin
    fremp = FirstInRange(RepSpec.f1,20);
    toemp = LastInRange(RepSpec.f1,20);   
    HTEmployees(fremp,toemp,tstr);
    Header(rw,tstr,1);
     rw = rw + 1;
  end;
  if (nonblank(RepSpec.f3)) then begin
    HTJobTitles(RepSpec.f3,RepSpec.f3,tstr);
    Header(rw,tstr,0);
     rw = rw + 1;
  end;
  if (nonblank(RepSpec.FirstAcc)) then begin
    HTDepartments(RepSpec.FirstAcc,RepSpec.FirstAcc,tstr);
    Header(rw,tstr,1);
    rw = rw + 1;
  end;
  if (nonblank(RepSpec.LastAcc)) then begin
    tstr = USetStr(19651) & ": " & RepSpec.LastAcc;
    Header(rw,tstr,1);
    rw = rw + 1;
  end;

  return;
end;

function val CalculateDaysTaken(record RcVc RepSpec,string Employee,string acttype)
begin
  val res,timev;
  Boolean found,testf;
  record ActVc Actr;
  string 255 keystr;
  Date td,YearStartDate,StartDate,EndDate;
  Time timet,blanktimet;
  record LeaveRulesBlock LRb;

  BlockLoad(LRb);
  td = RepSpec.sEndDate;
  if (blankdate(td)) then begin
    td = CurrentDate;
  end;
  StartDate = td;
  switch (LRb.LeaveCalculationBase) begin
    case kLeaveCalculationBaseCalendarYear:
      StartDate.month = 1;
      StartDate.day = 1;
      EndDate.month = 12;
      EndDate.day = 31;
    case kLeaveCalculationBaseFiscalYear:
      FindFiscalYear(td,StartDate,EndDate);  
  end;
  if (StartDate<Actr.TransDate) then begin
    StartDate = Actr.TransDate;
  end;

  keystr = "CUCodeTypeDate";
  Actr.CUCode = Employee;
  Actr.ActType = acttype;
  Actr.TransDate = StartDate;
  found = true;
  while (LoopKey(keystr,Actr,3,found)) begin
    if (Actr.CUCode!=Employee) then begin found = false; end;
    if (Actr.ActType!=acttype) then begin found = false; end;
    if (Actr.TransDate>RepSpec.sEndDate) then begin found = false; end;
    if (found) then begin
      testf = true;
      if (Actr.OKFlag==0) then begin testf = false; end;
      if (Actr.Invalid!=0) then begin testf = false; end;
      if (testf) then begin
        timet = blanktimet;
        if (nonblanktime(Actr.CostTime)) then begin
          vTimeDiff(timet,Actr.CostTime,timev);
        end else begin
          vTimeDiff(Actr.EndTime,Actr.StartTime,timev);
        end;  
        res = res + timev/8.00;
      end;
    end;
  end;
LCalculateDaysTaken:;  
  CalculateDaysTaken = res;
  return;
end;

function Boolean LeaveTransferExists(record HRMCOVc HRMCOr,date ed)
begin
  Boolean res,TrHs,foundf;
  record LeaveTransferVc LTr;

  LTr.Employee = HRMCOr.Employee;
  LTr.TransDate = HRMCOr.StartDate;
  TrHs = true;
  while (LoopKey("Employee",LTr,2,TrHs)) begin
    if (DateInRange(LTr.TransDate,HRMCOr.StartDate,ed)==false) then begin TrHs = false; end;
    if (TrHs) then begin
      foundf = true;
      if (LTr.OKFlag==0) then begin foundf = false;    end;
      if (LTr.Employee!=HRMCOr.Employee) then begin foundf = false; end;
        if (foundf) then begin 
          res = true;
          goto LLeaveTransferExists;
        end;
  
    end;
  end;
LLeaveTransferExists:;
LeaveTransferExists = res;
  return;
end;

