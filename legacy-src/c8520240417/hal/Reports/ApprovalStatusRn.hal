global
procedure ApprovalStatusRn(record RcVc RepSpec)
begin
  string 255 tstr;
  Integer rw;

  rw = 1;
  StartReportJob(USetStr(28420));
  HT2Per(RepSpec.sStartDate,RepSpec.sEndDate,tstr);
  Header(rw,tstr,1);
  rw = rw + 1;
  HTPers(RepSpec.f1,tstr);
  Header(rw,tstr,1);
  rw = rw + 1;
  HTApprovalStatus(RepSpec.flags[0],RepSpec.flags[1],RepSpec.flags[2],RepSpec.flags[3],RepSpec.flags[4],tstr);
  Header(rw,tstr,1);
  rw = rw + 1;
  if (RepSpec.flags[6]==1) then begin
    Header(rw,USetStr(23642) & ": " & USetStr(14490),1);
    rw = rw + 1;
  end;  
  if (RepSpec.flags[7]==1) then begin
    Header(rw,USetStr(23642) & ": " & USetStr(16211),1);
    rw = rw + 1;
  end; 
    if (RepSpec.flags[8]==1) then begin
    Header(rw,USetStr(23642) & ": " & USetStr(40853),1);
    rw = rw + 1;
  end; 
  if (RepSpec.flags[9]==1) then begin
    Header(rw,USetStr(23642) & ": " & USetStr(12154),1);
    rw = rw + 1;
  end; 

  EndHeader;
  SetRepCol(2,60);
  SetRepCol(3,150);
  SetRepCol(4,200);
  SetRepCol(5,300);
  SetRepCol(6,320);
  SetRepCol(7,370);
  SetRepCol(8,410);
  Gray_Divider(0,1);
  
  if (RepSpec.flags[6]==1) then begin
    PrintVISection(RepSpec);
    StartFormat(15);
    EndFormat;
  end;
  if (RepSpec.flags[7]==1) then begin
    PrintExpSection(RepSpec);
    StartFormat(15);
    EndFormat;
  end;
  if (RepSpec.flags[8]==1) then begin
    PrintOPSection(RepSpec);
    StartFormat(15);
    EndFormat;
  end;
  if (RepSpec.flags[9]==1) then begin
    PrintOtherSection(RepSpec);
    StartFormat(15);
    EndFormat;
  end;
  EndJob;
  return;
end;
