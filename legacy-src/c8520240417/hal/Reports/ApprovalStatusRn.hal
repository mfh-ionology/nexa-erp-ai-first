  firstf = true;
  found = true;
  while (LoopMain(Acptr,1,found)) begin
    if (found) then begin
      testf = true; 
      if (vprintedf[Acptr.Register]==true) then begin testf = false; end;
      if (testf) then begin
         if (RepSpec.flags[6]==1) and (firstf) then begin
          StartFormat(15); 
          OutString(0,0,USetStr(28437),false);
          OutString(2,0,USetStr(28438),false);
          OutString(3,0,USetStr(28439),false);
          OutString(4,0,USetStr(28454),false);
          OutString(5,0,USetStr(28434),true);
          OutString(6,0,USetStr(28435),false);
          OutString(7,0,USetStr(28418),false);
          OutString(8,0,USetStr(28419),false);
          OutString(1,0,USetStr(28436),true);
          EndFormat;
          Black_Divider(0,1);
          firstf = false;
        end;
        PrintActivitiesforApprovalRule(RepSpec,Acptr,kAcceptanceVI);
        vprintedf[Acptr.Register] = true;
      end;
    end;
  end;

  return;
end;

