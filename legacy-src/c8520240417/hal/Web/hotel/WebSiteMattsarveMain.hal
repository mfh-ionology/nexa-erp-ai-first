procedure WebMattsarveGallery()
begin
  Integer filecnt,i;
  string 255 filename,folder,extension,filepath,imagepath,imagename;

  WebOutBegin;
  <div class="index_cont">
    <div class="index_title"><?var(GetWebTranslation("GALLERYTITLE"))?></div>
    <img class="lion_left" src="/images/lion_left.png">
    <img class="lion_right" src="/images/lion_right.png">
    <div class="history_cont">
    EndWebOut;
    folder = "webcust/images/gallery";
    filecnt = CountFilesInDir(folder);
    while (i<filecnt) begin
      filename = GetFileNameInDir(folder,i);
      extension = right(filename,4);
      if (extension==".jpg") then begin
        filepath = "images/gallery/" & filename;
        imagepath = WebHost & "/" & DisplayThumbnail(filepath,350,0);
        imagename = "gallery_image_" & i;
        WebOutBegin;
        <div id="<?var(imagename)?>)" class="gallery_image" style="background-image: url(http://<?var(imagepath)?>"></div>
        EndWebOut;
      end;
      i = i + 1;
    end;
    WebOutBegin;
    </div>
  </div>
  <div id="gallery_overlay" class="gallery_overlay" onclick="$(this).toggle()"><img id="gallery_full_image" class="gallery_full_image"></div>
  EndWebOut;

  return;
end;

procedure WebMattsarveContact()
begin

  WebOutBegin;
  <div class="index_cont">
  <img class="lion_left" src="/images/lion_left.png">
  <img class="lion_right" src="/images/lion_right.png">
    <div class="history_cont">
      <div class="contact_cont">
        <form>
          <img class="contact_top_image" src="/images/contac_us_image_03.png">
          <div class="contact_title"><?var(GetWebTranslation("CONTACTTITLE"))?></div>
          <div class="contact_text"><?var(GetWebTranslation("CONTACT1"))?></div>
          <div class="contact_full"><?var(GetWebTranslation("SUBJECTCON"))?></div>
          <div class="contact_full"><input class="contact_input" name="subject" type="text"></div>
          <div class="contact_full">
            <div class="contact_half"><?var(GetWebTranslation("NAMECON"))?></div>
            <div class="contact_separator"></div>
            <div class="contact_half"><?var(GetWebTranslation("SURNAMECON"))?></div>
            <div class="contact_half"><input class="contact_input" name="name" type="text"></div>
            <div class="contact_separator"></div>
            <div class="contact_half"><input class="contact_input" name="surname" type="text"></div>
          </div>
          <div class="contact_full">
            <div class="contact_half"><?var(GetWebTranslation("EMAILCON"))?></div>
            <div class="contact_separator"></div>
            <div class="contact_half"><?var(GetWebTranslation("NUMBERCON"))?></div>
            <div class="contact_half"><input class="contact_input" name="email" type="text"></div>
            <div class="contact_separator"></div>
            <div class="contact_half"><input class="contact_input" name="number" type="text"></div>
          </div>
          <div class="contact_full"><?var(GetWebTranslation("MESSAGECON"))?></div>
          <div class="contact_full"><textarea class="contact_textfield" name="message"></textarea></div>
          <div class="contact_full">
            <div class="contact_submit"><?var(GetWebTranslation("SUBMITCON"))?></div>
          </div>
          <img class="contact_bot_image" src="/images/contac_us_image_07.png">
        </form>
      </div>
    </div>
  </div>
  EndWebOut;

  return;
end;

global
procedure HotelMattsarveMain(record WebNGStructVc WSr,string mpath)
begin
  string 255 path,node,lang;

  path = WebGetArg("path");
  node = removenextnode(path);
  lang = removenextnode(path);
  node = removenextnode(path);
  WebOutBegin; <html lang="<?var(lang)?>"> EndWebOut;
  WebMattsarveHead;
  WebOutBegin; <body> EndWebOut;
  WebMattsarveHeader(lang);
  WebOutBegin; <div class="main_cont"> EndWebOut;
  switch (node) begin
    case "stay": WebMattsarveStay;
    case "history": WebMattsarveHistory;
    case "cafe": WebMattsarveCafe;
    case "conferences": WebMattsarveConf;
    case "wedding": WebMattsarveParty;
    case "gallery": WebMattsarveGallery;
    case "contact": WebMattsarveContact;
    otherwise WebMattsarveIndex;
  end;
  WebOutBegin; </div> EndWebOut;
  WebMattsarveFooter(lang);
  WebOutBegin; </body> EndWebOut;
  WebOutBegin; </html> EndWebOut;

  return;
end;
