external function string 255 removenextnode(var string);
external function string 255 GetStartStructLink();
external function string 255 DisplayThumbnail(string,integer,integer);
//translation
external function string 255 ToolWebNGTranslateText(integer);
external function string 10 CurrentWebLang();



//TODO NRR move to tools (maybe move to C, refrence M4_WEBOUTPAGEWITHTEMPLATE)
function string 255 GetWebTranslation(string code)
begin
  record WebNGTranslateVc WTr;
  string 255 res,tstr,tstr2,part;
  longint pos;
  
  WTr.Code = code;
  WTr.LangCode = CurrentWebLang;
  if (ReadFirstMain(WTr,2,true)) then begin
    tstr = GetTextField(WTr);
    if (WTr.HtmlTranslation) then begin
      while(GetNextSubstring(tstr,pos,chr(13),part))
      begin
        if (len(tstr)>pos) then begin
          tstr2 = tstr2 & part & "<br>";
        end else begin
          tstr2 = tstr2 & part;
        end;
      end;
      pos = 0;
      while(GetNextSubstring(tstr2,pos,chr(9),part))
      begin
        if (len(tstr2)>pos) then begin
          res = res & part & "&nbsp;&nbsp;&nbsp;";
          end else begin
            res = res & part;
          end;
      end;
    end else begin
      res = tstr;
    end;
  end else begin
    res = "Missing translation: " & code;
  end;
  
  GetWebTranslation = res;
  return;
end;

procedure WebMattsarveHead()
begin

  WebOutBegin;
  <head>
  <link rel="icon" href="img/favicon.png" sizes="32x32">
  <title><?var(GetWebTranslation("WEBTITLE"))?></title>
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js"></script>
  <script src="/js/main.js"></script>
  <link rel="stylesheet" type="text/css" href="/css/main.css">
  </head>
  EndWebOut;
  
  return;
end;

procedure WebMattsarveHeader(string lang)
begin
  
  WebOutBegin;
  <div class="header_cont">
    <div class="head_title"><?var(GetWebTranslation("HEAD_TITLE"))?></div>
    <div class="head_menu_cont">
      <a href="http://<?var(WebHost)?>/<?var(lang)?>"><div class="head_menu_item"><?var(GetWebTranslation("MENU_HOME"))?></div></a>
      <a href="http://<?var(WebHost)?>/<?var(lang)?>/history"><div class="head_menu_item"><?var(GetWebTranslation("MENU_HISTORY"))?></div></a>
      <a href="http://<?var(WebHost)?>/<?var(lang)?>/stay"><div class="head_menu_item"><?var(GetWebTranslation("MENU_STAY"))?></div></a>
      <a href="http://<?var(WebHost)?>/<?var(lang)?>/cafe"><div class="head_menu_item"><?var(GetWebTranslation("MENU_CAFE"))?></div></a>
      <a href="http://<?var(WebHost)?>/<?var(lang)?>/conferences"><div class="head_menu_item"><?var(GetWebTranslation("MENU_CONF"))?></div></a>
      <a href="http://<?var(WebHost)?>/<?var(lang)?>/wedding"><div class="head_menu_item"><?var(GetWebTranslation("MENU_PARTY"))?></div></a>
      <a href="http://<?var(WebHost)?>/<?var(lang)?>/gallery"><div class="head_menu_item"><?var(GetWebTranslation("MENU_GALLERY"))?></div></a>
      <!--<a href="http://<?var(WebHost)?>/<?var(lang)?>/contact"><div class="head_menu_item"><?var(GetWebTranslation("MENU_CONTACT"))?></div></a>-->
    </div>
  </div>
  EndWebOut;
  
  return;
end;

