//========================================================================================================================
//========================================================================================================================
//========================================================================================================================

global
procedure WebHWULMSTest(LongInt contentnr)
begin
  record UnivTest2Vc Testr;
  row UnivTest2Vc Testrw;
  record UnivTestAnswer2Vc Answerr;
  row UnivTestAnswer2Vc Answerrw;
  string 60 langcode,llink,tstr;
  integer rwcnt,i;
  record UserVc Userr;
  Integer oldcomp,newcomp;
  Boolean res,res2,allowquestions,foundf;
  record CUVc CUr;
  Array Integer arows;
  Integer acnt,ai;
  string 255 newaddress;
  Boolean TestIsActive;
  Date TestSDate,TestEDate;
  Time TestSTime,TestETime;
  record CourseContentVc CourseContentr;

  oldcomp = CurrentCompany;
  newcomp = StringToInt(WebGetArg("company")); //not implemented yset
  if ((newcomp>0) and (oldcomp!=newcomp)) then begin
    res = SetCompany(newcomp,false);
  end;
  if (res==false) then begin
    newcomp = oldcomp;
  end;

  WebSetLanguage(langcode);

  CourseContentr.SerNr = contentnr;
  if (ReadFirstMain(CourseContentr,1,true)) then begin 
    
  end;

  Testr.SerNr = CourseContentr.Test;
  if (ReadFirstMain(Testr,1,true)) then begin
    ToolWebHBSDivStartPage;
    ToolWebHBSDivSetMainTitle;
    ToolWebHBSDivStartBody("","");

//     if (WebLoginStatus <> 3) then begin
//       WebOutStringNL("<table align=""center"" width=""90%"" cellspacing=""1"" cellpadding=""3"" border=""0"" class=""deftbl"">");
//       WebOutStringNL("  <tr><td colspan=""4"" class=""feedback-txt"">You are not logged in.</td></tr>");
//       WebOutStringNL("</table>");
//       goto LWebHWULMSTestCUNew;
//     end;

    TestIsActive = CourseContentVc_VisibilityDateTime(contentnr,TestSDate,TestSTime,TestEDate,TestETime);
    if (TestIsActive==false) then begin
      WebOutStringNL("<table align=""center"" width=""90%"" cellspacing=""1"" cellpadding=""3"" border=""0"" class=""deftbl"">");
      WebOutStringNL("  <tr><td colspan=""4"" class=""feedback-txt"">The test is not open at the moment, please contact HansaWorld University.</td></tr>");
      WebOutStringNL("</table>");
      goto LWebHWULMSTestCUNew;
    end;

    if (nonblank(CurrentUser)) then begin
      Userr.Code = CurrentUser;
      if (FindTheUser(Userr)) then begin
        CUr.Code = Userr.CustCode;
      end;
    end;
    if (blank(CUr.Code)) then begin
      CUr.Code = CurrentCust;
    end;
    res2 = ReadFirstMain(CUr,1,true);

    // if (blank(CUr.Code) or res2==false) then begin
    //   WebOutStringNL("<table align=""center"" width=""90%"" cellspacing=""1"" cellpadding=""3"" border=""0"" class=""deftbl"">");
    //   WebOutStringNL("  <tr><td colspan=""4"" class=""feedback-txt"">Your contact card is not set up correctly. You cannot take this test.</td></tr>");
    //   WebOutStringNL("</table>");
    //   goto LWebHWULMSTestCUNew;
    // end;

    rwcnt = MatRowCnt(Testr);
    Randomize;
    while (acnt<rwcnt) begin
      i = Random(0,rwcnt-1);
      for (ai=0;ai<acnt;ai=ai+1) begin
        if (arows[ai]==i) then begin
          goto LSKIPROWNRCUNEW;
        end;
      end;
      arows[acnt] = i;
      acnt = acnt + 1;
LSKIPROWNRCUNEW:;
    end;
    if (acnt>Testr.NoOfQuestions) then begin acnt = Testr.NoOfQuestions; end;
    allowquestions = true;

    foundf = true;
    Answerr.CustCode = CUr.Code;
    Answerr.UnivTestNr = Testr.SerNr;
    Answerr.EndDate = CurrentDate;
    while (LoopKey("CustCode",Answerr,3,foundf)) begin
      if (Answerr.CustCode != CUr.Code or Answerr.UnivTestNr != Testr.SerNr or Answerr.EndDate != CurrentDate) then begin
        foundf = false;
      end;
      if (foundf and Answerr.OKFlag!=1) then begin
        goto LWebHWULMSTestCustDoIt;
      end;
    end;
    RecordNew(Answerr);
    Answerr.SerNr = NextSerNr("UnivTestAnswer2Vc",CurrentDate,-1,false,"");
    Answerr.EndDate = CurrentDate;
    Answerr.CustCode = CUr.Code;
    Answerr.Person = CurrentUser;
    Answerr.PersonName = CUr.Name;
    Answerr.UnivTestNr = Testr.SerNr;
    Answerr.CourseName = Testr.CourseName;
    Answerr.NoOfQuestions = acnt;
    Answerr.CorrectAnswers = 0;
    Answerr.StartDate = CurrentDate;
    Answerr.StartTime = CurrentTime;
    Answerr.LastRowUpdated = -1;

    i = 0;
    for (ai=0;ai<acnt;ai=ai+1) begin
      MatRowGet(Testr,arows[ai],Testrw);
      ClearRow(Answerr,Answerrw,1);
      Answerrw.OrigRowNo = arows[ai]+1;
      Answerrw.Question = Testrw.Question;
      if (Testrw.Alt1Correct!=0) then begin Answerrw.Alt1 = "+"; end else begin Answerrw.Alt1 = "-"; end; if (blank(Testrw.Alt1)) then begin Answerrw.Alt1 = ""; end;
      Answerrw.Alt1 = Answerrw.Alt1 & Testrw.Alt1;
      if (Testrw.Alt2Correct!=0) then begin Answerrw.Alt2 = "+"; end else begin Answerrw.Alt2 = "-"; end; if (blank(Testrw.Alt2)) then begin Answerrw.Alt2 = ""; end;
      Answerrw.Alt2 = Answerrw.Alt2 & Testrw.Alt2;
      if (Testrw.Alt3Correct!=0) then begin Answerrw.Alt3 = "+"; end else begin Answerrw.Alt3 = "-"; end; if (blank(Testrw.Alt3)) then begin Answerrw.Alt3 = ""; end;
      Answerrw.Alt3 = Answerrw.Alt3 & Testrw.Alt3;
      if (Testrw.Alt4Correct!=0) then begin Answerrw.Alt4 = "+"; end else begin Answerrw.Alt4 = "-"; end; if (blank(Testrw.Alt4)) then begin Answerrw.Alt4 = ""; end;
      Answerrw.Alt4 = Answerrw.Alt4 & Testrw.Alt4;
      if (Testrw.Alt5Correct!=0) then begin Answerrw.Alt5 = "+"; end else begin Answerrw.Alt5 = "-"; end; if (blank(Testrw.Alt5)) then begin Answerrw.Alt5 = ""; end;
      Answerrw.Alt5 = Answerrw.Alt5 & Testrw.Alt5;
      if (Testrw.Alt6Correct!=0) then begin Answerrw.Alt6 = "+"; end else begin Answerrw.Alt6 = "-"; end; if (blank(Testrw.Alt6)) then begin Answerrw.Alt6 = ""; end;
      Answerrw.Alt6 = Answerrw.Alt6 & Testrw.Alt6;
      Answerrw.Answer = "";
      MatRowPut(Answerr,i,Answerrw);
      i = i+1;
    end;

    queued.WebHWUUnivTestsAnswersQueue(Answerr,newcomp);
LWebHWULMSTestCustDoIt:;

    newaddress = ToolWebBuildLink("WebHWULMSTARRefresh","&type=cust" & "&refact=hwunav" & "&startnav=1" & "&rownr=0" & "&plook=" & "hworld" & "&testnr=" & Answerr.UnivTestNr & "&p_cc=" & Answerr.CustCode & "&ed=" & DateToString(Answerr.EndDate,"YYYYMMDD") & "&st=" & ToTimeString(Answerr.StartTime) & "&thecomp=" & newcomp & "&langcode=" & langcode & "&contentnr=" & contentnr);
    WebHWUSendRefreshHTML(newaddress,1,false);
    ToolWebHBSDivEndPage;
  end;
LWebHWULMSTestCUNew:;
  if (res) then begin
    ResetCompany(oldcomp);
  end;
  return;
end;

global
procedure WebHWULMSTARRefresh()
begin
  record UnivTestAnswer2Vc Answerr;
  string 255 refreshaction,correct_answers,nrofqs,newaddress,p_cc,pagelook;
  LongInt univtestnr;
  integer oldcomp,thecomp;
  Integer rw;
  Date enddate;
  Time starttime;
  boolean handled,res,htmlenvelope;
  integer rownr,torownr;
  string 255 navdir,startnav;
  string 255 nextpage,langcode,type;
  LongInt contentnr;
  boolean feedbacksubmitted;

  type = WebGetArg("type");
  refreshaction = WebGetArg("refact");
  pagelook = WebGetArg("plook");
  langcode = WebGetArg("langcode");
  contentnr = StringToLongInt(WebGetArg("contentnr"));
  thecomp = StringToInt(WebGetArg("thecomp"));
  oldcomp = CurrentCompany;
  if (thecomp>0 and thecomp!=oldcomp) then begin
    res = SetCompany(thecomp,false);
  end;
  if (res==false) then begin
    thecomp = oldcomp;
  end;
  
  if (refreshaction=="hwuans2") then begin
    feedbacksubmitted = true;
    refreshaction = "hwuans";
  end;

  switch (refreshaction) begin
    case "hwuans":
      univtestnr = StringToLongInt(WebGetArg("testnr"));
      p_cc = WebGetArg("p_cc");
      enddate = DateFromString(WebGetArg("ed"),"YYYYMMDD");
      starttime = GetTime(WebGetArg("st"));
      correct_answers = WebGetArg("ans");
      nrofqs = WebGetArg("qs");

      Answerr.UnivTestNr = univtestnr;
      Answerr.CustCode = p_cc;
      Answerr.EndDate = enddate;
      Answerr.StartTime = starttime;
      if (ReadFirstKey("UnivTestNr",Answerr,4,true)) then begin
        if (pagelook=="intranet") then begin
          ToolWebStartPage;
          ToolWebSetMainTitle;
          WebTestFeedbackJS;
          ToolWebStartBody("");
        end;
        if (pagelook=="hworld") then begin
          ToolWebHBSDivStartPage;
          ToolWebHBSDivSetMainTitle;
          WebTestFeedbackJS;
          ToolWebHBSDivStartBody("","");
        end;
        ShowAnswerFeedback(Answerr);
        ToolWebTestFeedbackOverallComment(Answerr,feedbacksubmitted);
        switch (pagelook) begin
          case "intranet": ToolWebMenuItem("Finish","WebMainUser.hal","","",rw);
          case "hworld": ToolWebMenuItem("Finish","/","","",rw);
        end;
        if (pagelook=="intranet") then begin
          ToolWebEndPage(true);
        end;
        if (pagelook=="hworld") then begin
          ToolWebHBSDivEndPage;
        end;
      end else begin
        newaddress = ToolWebBuildLink("WebHWULMSTARRefresh","&type=" & type & "&refact=hwuans" & "&ans=" & correct_answers & "&qs=" & nrofqs & "&testnr=" & univtestnr & "&p_cc=" & p_cc & "&ed=" & enddate & "&st=" & WebGetArg("st") & "&thecomp=" & thecomp & "&langcode=" & langcode & "&ws=" & WebGetArg("ws") & "&contentnr=" & contentnr);
        WebHWUSendRefreshHTML(newaddress,1,true);
      end;
    case "hwunav":
      univtestnr = StringToLongInt(WebGetArg("testnr"));
      p_cc = WebGetArg("p_cc");
      enddate = DateFromString(WebGetArg("ed"),"YYYYMMDD");
      starttime = GetTime(WebGetArg("st"));
      navdir = WebGetArg("navdir");
      startnav = WebGetArg("startnav");
      rownr = StringToInt(WebGetArg("rownr"));
      torownr = StringToInt(WebGetArg("torownr"));

      handled = false;
      htmlenvelope = false;

      Answerr.UnivTestNr = univtestnr;
      Answerr.CustCode = p_cc;
      Answerr.EndDate = enddate;
      Answerr.StartTime = starttime;
      res = ReadFirstKey("UnivTestNr",Answerr,4,true);
      if (res or startnav!="1") then begin
        htmlenvelope = true;
        if (pagelook=="intranet") then begin
          ToolWebStartPage;
          ToolWebSetMainTitle;
          WebTestFeedbackJS;
          ToolWebStartBody("");
        end;
        if (pagelook=="hworld") then begin
          ToolWebHBSDivStartPage;
          ToolWebHBSDivSetMainTitle;
          WebTestFeedbackJS;
          ToolWebHBSDivStartBody("","");
        end;
        ToolWebStartTable;

        if (res) then begin
          // if (startnav=="1") then begin //Answerr.LastRowUpdated==rownr or 
            switch (navdir) begin
              case "back":
                if (rownr>0) then begin
                  rownr = rownr-1;
                end;
              case "next":
                rownr = rownr+1;
                if (rownr>=MatRowCnt(Answerr)) then begin
                  rownr = MatRowCnt(Answerr)-1;
                end;
              otherwise
                if (Left(navdir,4)=="page") then begin
                  rownr = torownr-1;
                end;
            end;
            if (navdir=="finish") then begin

            end else begin
              if (type=="cust") then begin
                HWLMSShowQuestion(Answerr,rownr,langcode,StringToInt(thecomp),contentnr,true);
              end else begin
                HWLMSShowQuestion(Answerr,rownr,langcode,StringToInt(thecomp),contentnr,false);
              end;
            end;
            handled = true;
          // end;
        end else begin
          if (startnav!="1") then begin
            if (pagelook=="intranet") then begin
              nextpage = "WebMainUser.hal";
            end;
            if (pagelook=="hworld") then begin
              nextpage = "WebHBSDivMain.hal";
            end;
            ToolWebMenuItem("<b><big>" & "An error occurred. Could not find Answer record." & "</b></big>",nextpage,"","",rw);
            handled = true;
          end;
        end;
        ToolWebEndTable;
        if (pagelook=="intranet") then begin
          ToolWebEndPage(true);
        end;
        if (pagelook=="hworld") then begin
          ToolWebHBSDivEndPage;
        end;
      end;

      if (handled==false) then begin
        newaddress = ToolWebBuildLink("WebHWULMSTARRefresh","&type=" & type & "&refact=hwunav" & "&rownr=" & rownr & "&navdir=" & navdir & "&plook=" & pagelook & "&testnr=" & univtestnr & "&p_cc=" & p_cc & "&ed=" & enddate & "&st=" & WebGetArg("st") & "&thecomp=" & thecomp & "&langcode=" & langcode & "&ws=" & WebGetArg("ws") & "&contentnr=" & contentnr);
        WebHWUSendRefreshHTML(newaddress,1,(htmlenvelope==false));
      end;

  end;
  if (res) then begin
    ResetCompany(oldcomp);
  end;
  return;
end;

global
procedure WebHWULMSTestNavigate()
begin
  integer oldcomp,newcomp;
  boolean res,res2,custstyle;
  record UnivTest2Vc Testr;
  string 255 langcode,newaddress,navdir;
  record UserVc Userr;
  record CUVc CUr;
  record UnivTestAnswer2Vc Answerr;
  integer rownr;
  string 255 page_look,torownr;
  Date EndDate;
  Time StartTime;
  Boolean TestIsActive;
  Date TestSDate,TestEDate;
  Time TestSTime,TestETime;
  LongInt pos,contentnr;

  oldcomp = CurrentCompany;
  newcomp = StringToInt(WebGetArg("company"));
  if (newcomp>0 and newcomp!=oldcomp) then begin
    res = SetCompany(newcomp,false);
  end;

  if (WebGetArg("type")=="cust") then begin
    custstyle = true;
  end;

  page_look = WebGetArg("plook");
  langcode = WebGetArg("langcode");
  contentnr = StringToLongInt(WebGetArg("contentnr"));

  WebSetLanguage(langcode);
  Testr.SerNr = WebGetArg("testnr");
  EndDate = DateFromString(WebGetArg("enddate"),"YYYYMMDD");
  StartTime = GetTime(WebGetArg("starttime"));

  if (ReadFirstMain(Testr,1,true)) then begin
    if (custstyle) then begin
      ToolWebHBSDivStartPage;
      ToolWebHBSDivSetMainTitle;
      ToolWebHBSDivStartBody("","");
    end else begin
      ToolWebStartPage;
      ToolWebSetMainTitle;
      ToolWebStartBody("");
    end;

    // if (WebLoginStatus <> 3) then begin
    //   WebOutStringNL("<table align=""center"" width=""90%"" cellspacing=""1"" cellpadding=""3"" border=""0"" class=""deftbl"">");
    //   WebOutStringNL("  <tr><td colspan=""4"" class=""feedback-txt"">You are not logged in.</td></tr>");
    //   WebOutStringNL("</table>");
    //   goto LWebHWULMSTestNavigate;
    // end;

    TestIsActive = CourseContentVc_VisibilityDateTime(contentnr,TestSDate,TestSTime,TestEDate,TestETime);
    if (TestIsActive==false) then begin
      WebOutStringNL("<table align=""center"" width=""90%"" cellspacing=""1"" cellpadding=""3"" border=""0"" class=""deftbl"">");
      WebOutStringNL("  <tr><td colspan=""4"" class=""feedback-txt"">The test is not open at the moment, please contact HansaWorld University.</td></tr>");
      WebOutStringNL("</table>");
      goto LWebHWULMSTestNavigate;
    end;

    // if (nonblank(CurrentUser)) then begin
    //   Userr.Code = CurrentUser;
    //   if (FindTheUser(Userr)) then begin
    //     CUr.Code = Userr.CustCode;
    //   end;
    // end;
    // if (blank(CUr.Code)) then begin
    //   CUr.Code = CurrentCust;
    // end;
    // res2 = ReadFirstMain(CUr,1,true);

    // if (blank(CUr.Code) or res2==false) then begin
    //   WebOutStringNL("<table align=""center"" width=""90%"" cellspacing=""1"" cellpadding=""3"" border=""0"" class=""deftbl"">");
    //   WebOutStringNL("  <tr><td colspan=""4"" class=""feedback-txt"">Your contact card is not set up correctly. You cannot take this test.</td></tr>");
    //   WebOutStringNL("</table>");
    //   goto LWebHWULMSTestNavigate;
    // end;

    Answerr.UnivTestNr = Testr.SerNr;
    Answerr.CustCode = CUr.Code;
    Answerr.EndDate = EndDate;
    Answerr.StartTime = StartTime;
    if (ReadFirstKey("CustCode",Answerr,4,true)) then begin
      if (Answerr.OKFlag==0) then begin

        rownr = StringToInt(WebGetArg("rownrpost"));
        navdir = WebGetArg("navdircombo");

        if (navdir=="back" or navdir=="next" or Left(navdir,4)=="page") then begin
          if (Left(navdir,4)=="page") then begin
            pos = 0;
            GetNextSubString(navdir,pos,":",torownr);
            GetNextSubString(navdir,pos,":",torownr);
          end;
          queued.LMSUpdateAnswers(WebGetArg("person_name"),Answerr.UnivTestNr,Answerr.CustCode,Answerr.EndDate,Answerr.StartTime,rownr,WebGetArg("questa"),WebGetArg("questb"),WebGetArg("questc"),WebGetArg("questd"),WebGetArg("queste"),WebGetArg("questf"));
          queued.LMSUpdateWebTestFeedback(Answerr.CustCode,Answerr.UnivTestNr,Answerr.EndDate,Answerr.StartTime,rownr,WebGetArg("feedbackQ"),WebGetArg("feedback1"),WebGetArg("feedback2"),WebGetArg("feedback3"),WebGetArg("feedback4"),WebGetArg("feedback5"),WebGetArg("feedback6"),WebGetArg("rating1"),WebGetArg("rating2"));
          newaddress = ToolWebBuildLink("WebHWULMSTARRefresh","&type=" & WebGetArg("type") & "&refact=hwunav" & "&rownr=" & rownr & "&navdir=" & navdir & "&plook=" & page_look & "&testnr=" & Answerr.UnivTestNr & "&p_cc=" & Answerr.CustCode & "&ed=" & DateToString(Answerr.EndDate,"YYYYMMDD") & "&st=" & ToTimeString(Answerr.StartTime) & "&thecomp=" & newcomp & "&langcode=" & langcode & "&ws=" & WebGetArg("warningshown") & "&torownr=" & torownr & "&contentnr=" & contentnr);
        end else begin
          queued.LMSCompleteTest(WebGetArg("person_name"),Answerr.UnivTestNr,Answerr.CustCode,Answerr.EndDate,Answerr.StartTime,rownr,WebGetArg("questa"),WebGetArg("questb"),WebGetArg("questc"),WebGetArg("questd"),WebGetArg("queste"),WebGetArg("questf"));
          queued.LMSUpdateWebTestFeedback(Answerr.CustCode,Answerr.UnivTestNr,Answerr.EndDate,Answerr.StartTime,rownr,WebGetArg("feedbackQ"),WebGetArg("feedback1"),WebGetArg("feedback2"),WebGetArg("feedback3"),WebGetArg("feedback4"),WebGetArg("feedback5"),WebGetArg("feedback6"),WebGetArg("rating1"),WebGetArg("rating2"));
          newaddress = ToolWebBuildLink("WebHWULMSTARRefresh","&type=" & WebGetArg("type") & "&refact=hwuans" & "&plook=" & page_look & "&testnr=" & Answerr.UnivTestNr & "&p_cc=" & Answerr.CustCode & "&ed=" & DateToString(Answerr.EndDate,"YYYYMMDD") & "&st=" & ToTimeString(Answerr.StartTime) & "&thecomp=" & newcomp & "&langcode=" & langcode & "&ws=" & WebGetArg("warningshown") & "&contentnr=" & contentnr);
        end;
        WebHWUSendRefreshHTML(newaddress,1,false);
      end else begin
        WebOutStringNL("<table align=""center"" width=""90%"" cellspacing=""1"" cellpadding=""3"" border=""0"" class=""deftbl"">");
        WebOutStringNL("  <tr><td colspan=""4"" class=""feedback-txt"">This test has already been submitted.</td></tr>");
        WebOutStringNL("</table>");
      end;
    end else begin
      WebOutStringNL("<table align=""center"" width=""90%"" cellspacing=""1"" cellpadding=""3"" border=""0"" class=""deftbl"">");
      WebOutStringNL("  <tr><td colspan=""4"" class=""feedback-txt"">An error occurred. No open test for current user.</td></tr>");
      WebOutStringNL("</table>");
    end;
SkipQuestions:;
    ToolWebEndPage(true);
  end;
LWebHWULMSTestNavigate:;
  if (res) then begin
    ResetCompany(oldcomp);
  end;
  return;
end;
