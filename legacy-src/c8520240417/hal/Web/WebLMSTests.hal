procedure ToolWebTestFeedbackRating(string label,string fieldname,integer curvalue)
begin
  integer i;
  
  WebOutStringNL("<div class=""ratingscontrol"">");
  WebOutStringNL(label);
  WebOutStringNL("<br>");
  for (i=1;i<=5;i=i+1) begin
    if (curvalue==i) then begin
      WebOutString("<input type=""radio"" name=""" & fieldname & """ value=""" & i & """ checked=""checked"">");
    end else begin
      WebOutString("<input type=""radio"" name=""" & fieldname & """ value=""" & i & """>");
    end;
    WebOutString(i);
    if (i!=5) then begin
      WebOutString("&nbsp;");
    end;
  end;
  WebOutStringNL("</div>");
  return;
end;


