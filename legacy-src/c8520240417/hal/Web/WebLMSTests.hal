procedure GetWebTestFeedbackRow(record UnivTestAnswer2Vc Answerr,integer rownr,var record UnivTestFeedback2Vc UTFr,var row UnivTestFeedback2Vc UTFrw,var boolean showfeedbackfields)
begin
  row UnivTestAnswer2Vc Answerrw;
  
  if (FindWebTestFeedback(Answerr.CustCode,Answerr.UnivTestNr,Answerr.EndDate,Answerr.StartTime,UTFr)) then begin
    MatRowGet(Answerr,rownr,Answerrw);
    MatRowGet(UTFr,Answerrw.OrigRowNo-1,UTFrw)
    if ((UTFrw.Question!="-" and nonblank(UTFrw.Question)) or nonblank(UTFrw.Alt1) or nonblank(UTFrw.Alt2) or nonblank(UTFrw.Alt3) or nonblank(UTFrw.Alt4) or nonblank(UTFrw.Alt5) or nonblank(UTFrw.Alt6)) then begin
      showfeedbackfields = true;
    end;
    if (showfeedbackfields==false) then begin
      if (UTFrw.Rating1>0 or UTFrw.Rating2>0) then begin
        showfeedbackfields = true;
      end;
    end;
  end;
  
  return;
end;

global
updating procedure LMSUpdateWebTestFeedback(string custcode,string univtestnr,date d,time t,integer rownr,string feedbackQ,string feedback1,string feedback2,string feedback3,string feedback4,string feedback5,string feedback6,string rating1,string rating2)
begin
  record UnivTestAnswer2Vc Answerr;
  row UnivTestAnswer2Vc Answerrw;
  record UnivTestFeedback2Vc oldUTFr,UTFr;
  row UnivTestFeedback2Vc UTFrw;
  integer i,rwcnt;
  boolean newf;
  
  Answerr.CustCode = custcode;
  Answerr.UnivTestNr = univtestnr;
  Answerr.EndDate = d;
  Answerr.StartTime = t;
  if (ReadFirstKey("CustCode",Answerr,4,true)==false) then begin
    goto LHWUUWTFeedback;
  end;
  MatRowGet(Answerr,rownr,Answerrw);

  UTFr.CustCode = custcode;
  UTFr.UnivTestNr = univtestnr;
  UTFr.CreatedDate = d;
  UTFr.CreatedTime = t;
  if (ReadFirstMain(UTFr,4,true)) then begin
    RecordCopy(oldUTFr,UTFr);
  end else begin
    Recordnew(UTFr);
    UTFr.CustCode = custcode;
    UTFr.UnivTestNr = univtestnr;
    UTFr.CreatedDate = d;
    UTFr.CreatedTime = t;
    UTFr.CourseName = Answerr.CourseName;
    UTFr.PersonName = Answerr.PersonName;
    UTFr.UserCode = Answerr.Person;
    UTFr.Answers = Answerr.SerNr;
    newf = true;

    rwcnt = MatRowCnt(Answerr);
    for (i=0;i<rwcnt;i=i+1) begin
      ClearRow(UTFr,UTFrw,1);
      UTFrw.Question = "-";
      MatRowPut(UTFr,i,UTFrw);
    end;
  end;
  
  MatRowGet(UTFr,Answerrw.OrigRowNo-1,UTFrw);
  UTFrw.Question = feedbackQ;
  UTFrw.Alt1 = feedback1;
  UTFrw.Alt2 = feedback2;
  UTFrw.Alt3 = feedback3;
  UTFrw.Alt4 = feedback4;
  UTFrw.Alt5 = feedback5;
  UTFrw.Alt6 = feedback6;
  UTFrw.Rating1 = StringToInt(rating1);
  UTFrw.Rating2 = StringToInt(rating2);
  if (blank(UTFrw.Question)) then begin UTFrw.Question = "-"; end;
  MatRowPut(UTFr,Answerrw.OrigRowNo-1,UTFrw);
  
  if (newf) then begin
    if (RecordInsert(UTFr,true)) then begin end;
  end else begin
    if (RecordUpdate(oldUTFr,UTFr,true)==0) then begin end;
  end;

LHWUUWTFeedback:;
  return;
end;

function string 255 GetAnswerText(string Answer)
begin
  string 255 res;
  
  switch (Answer) begin
    case "+": res = "yes";
    case "-": res = "no";
  end;
  
  GetAnswerText = res;
  return;
end;

procedure ShowOneAnswer(string Answer)
begin
  string 1 UserAnswer,TestAnswer;
  string 255 tstr;
  
  if (nonblank(Answer)) then begin
    UserAnswer = Mid(Answer,0,1);
    TestAnswer = Mid(Answer,1,1);
    tstr = Right(Answer,Len(Answer)-2);
    if (UserAnswer==TestAnswer) then begin
      tstr = tstr & " [correct: " & GetAnswerText(UserAnswer) & "]";
    end else begin
      tstr = tstr & " [you answered: " & GetAnswerText(UserAnswer) & "; correct answer was: " & GetAnswerText(TestAnswer) & "]";
    end;
    WebOutStringNL("<li>" & tstr & "</li>");
  end;
  
  return;
end;

procedure ShowAnswerFeedback(record UnivTestAnswer2Vc Answerr)
begin
  row UnivTestAnswer2Vc Answerrw;
  Integer i,rwcnt;
  record UnivTest2Vc Testr;
  Boolean TestPassed;
  
  Testr.SerNr = Answerr.UnivTestNr;
  ReadFirstMain(Testr,1,true);
  TestPassed = Answerr.CorrectAnswers>=Testr.CorrAnsToPass;
  WebOutTagOpen("<div id=""answerfeedback"">");
  WebOutStringNL("<h1>Test Results</h1>");
  WebOutStringNL("<p>");
  if (TestPassed) then begin
    WebOutStringNL("Congratulations! You passed the test.<br>");
  end;
  WebOutStringNL("You answered " & Answerr.CorrectAnswers & " out of " & Answerr.NoOfQuestions & " questions correctly.<br>");
  WebOutStringNL("Number of questions needed to pass the test: " & Testr.CorrAnsToPass & ".<br>");
  WebOutStringNL("</p>");
  if (Answerr.CorrectAnswers<Answerr.NoOfQuestions) then begin
    WebOutStringNL("<h2>Incorrectly answered questions</h2>");
    WebOutStringNL("<ul>");
    rwcnt = MatRowCnt(Answerr);
    for (i=0;i<rwcnt;i=i+1) begin
      MatRowGet(Answerr,i,Answerrw);
      if (Answerrw.Answer!="OK") then begin
        WebOutStringNL("<li>");
        WebOutStringNL(Answerrw.Question);
        if (TestPassed) then begin
          WebOutStringNL("<ul>");
          ShowOneAnswer(Answerrw.Alt1);
          ShowOneAnswer(Answerrw.Alt2);
          ShowOneAnswer(Answerrw.Alt3);
          ShowOneAnswer(Answerrw.Alt4);
          ShowOneAnswer(Answerrw.Alt5);
          ShowOneAnswer(Answerrw.Alt6);
          WebOutStringNL("</ul>");
        end;
        WebOutStringNL("</li>");
      end;
    end;
    WebOutStringNL("</ul>");
  end;
  WebOutTagClose("</div>");
  return;
end;

procedure HWUUnivTestRowNew(record UnivTestAnswer2Vc Answerr,Integer rownr)
begin
  row UnivTestAnswer2Vc Answerrw;
  string 255 ans;
  boolean checked;
  integer i;
  string 255 tstr;
  record UnivTestFeedback2Vc UTFr;
  row UnivTestFeedback2Vc UTFrw;
  string 255 curval;
  boolean showfeedbackfields;

  MatRowGet(Answerr,rownr,Answerrw);
  GetWebTestFeedbackRow(Answerr,rownr,UTFr,UTFrw,showfeedbackfields);
  WebOutStringNL("  <tr height=""1"">");
  WebOutStringNL("    <td colspan=""3"">&nbsp;<br><br></td>");
  WebOutStringNL("  </tr>");
  WebOutStringNL("  <tr height=""30"">");
  WebOutStringNL("    <td width=""45"" class=""triip"" align=""center"">" & rownr+1 & "</td>");
  WebOutString("    <td class=""triip"">" & Answerrw.Question);
  WebOutStringNL(" <a id=""showfeedbackfields"" onclick=""show_comments()"">[Comment]</a></td>");
  WebOutStringNL("  </tr>");
  ToolWebTestFeedbackHead(rownr,UTFrw.Question,showfeedbackfields);
  ToolWebTestFeedbackInfo(showfeedbackfields);
  WebOutStringNL("  <tr>");
  WebOutStringNL("    <td valign=""top"" colspan=""2"">");
  WebOutStringNL("      <table border=""0"" width=""100%"" class=""tekst"" cellspacing=""0"" cellpadding=""2"">");

  tstr = "";
  for (i=1;i<=6;i=i+1) begin
    switch (i) begin
      case 1: ans = Answerrw.Alt1; curval = UTFrw.Alt1;
      case 2: ans = Answerrw.Alt2; curval = UTFrw.Alt2;
      case 3: ans = Answerrw.Alt3; curval = UTFrw.Alt3;
      case 4: ans = Answerrw.Alt4; curval = UTFrw.Alt4;
      case 5: ans = Answerrw.Alt5; curval = UTFrw.Alt5;
      case 6: ans = Answerrw.Alt6; curval = UTFrw.Alt6;
      otherwise ans = ""; curval = "";
    end;

    if (nonblank(ans)) then begin
      checked = false;
      if (mid(ans,1,1)=="+" or mid(ans,1,1)=="-") then begin
        if (left(ans,1)=="+") then begin
          checked = true;
        end;
        ans = right(ans,len(ans)-2);
      end else begin
        ans = right(ans,len(ans)-1);
      end;
      WebOutStringNL("        <tr valign=""top"">");
      WebOutString("          <td align=""center"" width=""30""><input id=""quest" & chr(96+i) & """ name=""quest" & chr(96+i) & """ type=""checkbox"" value=""true""");
      if (checked) then begin
        WebOutString("checked=""true""");
        tstr = tstr & "+";
      end else begin
        tstr = tstr & "-";
      end;

      WebOutStringNL("></td>");
      WebOutStringNL("          <td>" & ans & "</td>");
      WebOutStringNL("        </tr>");
      ToolWebTestFeedbackRow(rownr,i,curval,showfeedbackfields);
    end else begin
      tstr = tstr & ".";
    end;
  end;

  WebOutStringNL("      </table>");
  WebOutStringNL("    </td>");
  WebOutStringNL("  </tr>");
  return;
end;

procedure WebHWLMSUnivTestPageHeader(string UserName,record CUVc CUr,record UnivTest2Vc Testr,integer rownr,string langcode,integer newcomp,boolean custstyle,Date EndDate,Time StartTime,LongInt contentnr)
begin
  string 255 llink,tstr;
  Date TestStartDate,TestEndDate,CurDate;
  Time TestStartTime,TestEndTime,CurTime;

  CurDate = CurrentDate;
  CurTime = CurrentTime;

  CourseContentVc_VisibilityDateTime(contentnr,TestStartDate,TestStartTime,TestEndDate,TestEndTime);

  WebOutString("<form method=""post"" action=""");
  llink = ToolWebBuildLink("WebHWULMSTestNavigate","&sessionid=" & WebGetArg("sessionid"));
  WebOutLink(llink);
  WebOutStringNL(""">");
  WebOutStringNL("<input value=""" & WebGetArg("ws") & """ type=""hidden"" name=""warningshown"" id=""warningshown"">");
  if (WebGetArg("ws")!="1" and nonblankdate(TestEndDate)) begin
    WebOutStringNL("<script type=""text/javascript"">");
    WebOutString("var t;");
    WebOutString("var serverTime=new Date(");
    WebOutString(CurDate.year & ",");
    WebOutString(CurDate.month-1 & ","); //month is 0 based
    WebOutString(CurDate.day & ",");
    WebOutString(CurTime.hour & ",");
    WebOutString(CurTime.minute & ",");
    WebOutString(CurTime.second & ",");
    WebOutString("0);");
    WebOutString("var clientTime=new Date();");
    WebOutString("var offset=serverTime-clientTime;");
    WebOutString("var endTime=new Date(");
    WebOutString(TestEndDate.year & ",");
    WebOutString(TestEndDate.month-1 & ","); //month is 0 based
    WebOutString(TestEndDate.day & ",");
    WebOutString(TestEndTime.hour & ",");
    WebOutString(TestEndTime.minute & ",");
    WebOutString(TestEndTime.second & ",");
    WebOutString("0)-offset;");
    WebOutString("function TimeUpWarning() {");
    WebOutString("  var curTime=new Date();");
    WebOutString("  if ((endTime-curTime)<=(3*60*1000)) {");
    WebOutString("    alert('You have less than 3 minutes before this test ends. Please finish up!');");
    WebOutString("    var obj=document.getElementById('warningshown');");
    WebOutString("    if (obj!=null) obj.value=1;");
    WebOutString("  } else {");
    WebOutString("    t=setTimeout('TimeUpWarning()',5000);");
    WebOutString("  }");
    WebOutString("}");
    WebOutStringNL("t = setTimeout('TimeUpWarning()',5000);");
    WebOutStringNL("</script>");
  end;

  WebOutString("<input value=""" & CUr.Code & """ type=""hidden"" name=""p_cc"" size=""31"">");
  WebOutString("<input value=""" & Testr.SerNr & """ type=""hidden"" name=""testnr"" size=""31"">");
  WebOutString("<input value=""" & contentnr & """ type=""hidden"" name=""contentnr"" size=""31"">");
  WebOutString("<input value=""" & newcomp & """ type=""hidden"" name=""company"" size=""31"">");
  WebOutString("<input value=""" & custstyle & """ type=""hidden"" name=""custstyle"">");
  WebOutString("<input value=""" & rownr & """ type=""hidden"" name=""rownrpost"">");
  WebOutString("<input value=""" & DateToString(EndDate,"YYYYMMDD") & """ type=""hidden"" name=""enddate"">");
  WebOutString("<input value=""" & ToTimeString(StartTime) & """ type=""hidden"" name=""starttime"">");
  WebOutString("<input type=""hidden"" name=""plook"" value=""" & WebGetArg("plook") & """");
  WebOutStringNL("<table align=""center"" width=""90%"" cellspacing=""1"" cellpadding=""3"" border=""0"" class=""deftbl"">");
  WebOutStringNL("  <tr><th>" & TranslateString("Test",langcode) & " " & Testr.CourseName & "</th></tr>");
  WebOutStringNL("</table>");
  WebOutString("<table align=""center"" bgcolor=""#FFFFFF"" width=""90%"" cellspacing=""3"" cellpadding=""3"" border=""0"" class="""">");

  tstr = UserName;
  if (blank(tstr)) then begin
    WebOutString("<tr><td class=""feedback-txt"">" & TranslateString("30024",langcode) & "</td><td width=""72%""><input value="""" type=""text"" id=""person_name"" name=""person_name"" size=""31"" class=""feedback""></td></tr>");
  end else begin
    WebOutString("<tr><td width=""28%"" class=""feedback-txt"">" & TranslateString("30024",langcode) & ":</td><td width=""72%"" class=""feedback-txt"">" & tstr & "</td></tr>");
  end;

  WebOutStringNL("  <tr height=""1"">");
  WebOutStringNL("    <td colspan=""3"">&nbsp;<br><br></td>");
  WebOutStringNL("  </tr>");
  WebOutString("</table>");
  WebOutStringNL("<table align=""center"" width=""90%"" cellspacing=""1"" cellpadding=""3"" border=""0"" class=""deftbl"">");
  tstr = "Questions";
  if (nonblankdate(TestEndDate)) then begin
    tstr = tstr & ", post your answers before";
  end;
  WebOutStringNL("  <tr><th>" & TranslateString(tstr,langcode) & " " & TestEndDate & " " & TestEndTime & "</th></tr>");
  WebOutStringNL("</table>");

  WebOutStringNL("<table align=""center"" bgcolor=""#FFFFFF"" width=""90%"" cellspacing=""0"" cellpadding=""3"" border=""0"" class="""">");
  return;
end;

function boolean AllQuestionsAnsweredSkipCurrent(record UnivTestAnswer2Vc Answerr,integer rownr)
begin
  integer i,j,cnt;
  string 255 alt;
  boolean res,checked;
  row UnivTestAnswer2Vc Answerrw;

  res = true;
  cnt = MatRowCnt(Answerr);

  for (i=0;i<cnt;i=i+1) begin
    if (i!=rownr) then begin
      checked = false;
      MatRowGet(Answerr,i,Answerrw);
      for (j=1;j<=6;j=j+1) begin
        switch (j) begin
          case 1: alt = Answerrw.Alt1;
          case 2: alt = Answerrw.Alt2;
          case 3: alt = Answerrw.Alt3;
          case 4: alt = Answerrw.Alt4;
          case 5: alt = Answerrw.Alt5;
          case 6: alt = Answerrw.Alt6;
        end;
        if (mid(alt,1,1)=="+" or mid(alt,1,1)=="-") then begin
          if (left(alt,1)=="+") then begin
            checked = true;
          end;
        end;
      end;
      if (checked==false) then begin
        res = false;
        goto LAllQuestionsAnsweredSkipCurrent;
      end;
    end;
  end;
LAllQuestionsAnsweredSkipCurrent:;
  AllQuestionsAnsweredSkipCurrent = res;
  return;
end;

procedure HWLMSShowQuestion(record UnivTestAnswer2Vc Answerr,integer quest,string langcode,integer thecomp,LongInt contentnr,boolean custstyle)
begin
  record UserVc Userr;
  record UnivTest2Vc Testr;
  record CUVc CUr;
  string 255 confirmmessage,confirm2;
  boolean res;
  record UnivTestFeedback2Vc UTFr;
  row UnivTestFeedback2Vc UTFrw;
  boolean showfeedbackfields;
  Integer nrofquestions;
  Integer currentquest;

  if (nonblank(CurrentUser)) then begin
    Userr.Code = CurrentUser;
    if (FindTheUser(Userr)) then begin
      CUr.Code = Userr.CustCode;
    end;
  end;
  if (blank(CUr.Code)) then begin
    CUr.Code = CurrentCust;
  end;
  if (ReadFirstMain(CUr,1,true)) then begin end;

  Testr.SerNr = Answerr.UnivTestNr;
  if (ReadFirstMain(Testr,1,true)) then begin end;

  nrofquestions = MatRowCnt(Answerr);
  currentquest = quest + 1;

  WebHWLMSUnivTestPageHeader(Answerr.PersonName,CUr,Testr,quest,langcode,thecomp,custstyle,Answerr.EndDate,Answerr.StartTime,contentnr);
  HWUUnivTestRowNew(Answerr,quest);
  
  WebOutStringNL("  <tr height=""30""><td width=""190""><br><br></td></tr>");
  GetWebTestFeedbackRow(Answerr,quest,UTFr,UTFrw,showfeedbackfields);
  ToolWebTestFeedbackQuestionRating(quest,UTFrw.Rating1,UTFrw.Rating2,showfeedbackfields);

  WebOutStringNL("  <tr height=""30"">");
  WebOutStringNL("    <td width=""380"">");
  if (currentquest>1) then begin
    WebOutStringNL("<input type=""submit"" name=""navdircombo"" value=""Back"">&nbsp;");
    if (currentquest>=4) then begin
      WebOutStringNL("<button type=""submit"" name=""navdircombo"" value=""Page:1"">1</button>");
      if (currentquest>=5) then begin
        WebOutStringNL("...");
      end;
    end;
  end;
  if (currentquest==nrofquestions) then begin
    if (currentquest-2>=0) then begin
      WebOutStringNL("<button type=""submit"" name=""navdircombo"" value=""Page:" & currentquest-2 & """>" & currentquest-2 & "</button>");
    end;
    if (currentquest-1>=0) then begin 
      WebOutStringNL("<button type=""submit"" name=""navdircombo"" value=""Page:" & currentquest-1 & """>" & currentquest-1 & "</button>");
    end;
    WebOutStringNL("<button type=""submit"" name=""navdircombo"" value=""Page:" & nrofquestions & """>" & nrofquestions & "</button>");
    WebOutString("<input type=""submit"" name=""navdircombo"" value=""Finish"" onclick=""");
    if (blank(Answerr.PersonName)) then begin
      WebOutString("if (document.getElementById('person_name')!=null && document.getElementById('person_name').value=='') { ");
      WebOutString("  alert('Please fill in your name. You cannot submit this test without specifying your name.'); ");
      WebOutString("  return false; ");
      WebOutString("} else {");
    end;
    WebOutString("    var submit=confirm('Do you want to submit this test? You cannot change any more questions after submitting!');");
    res = AllQuestionsAnsweredSkipCurrent(Answerr,quest);
    WebOutString("    if (submit) {");
    if (res) then begin
      WebOutString("      var ch=new Array('a','b','c','d','e','f');");
      WebOutString("      var checked=false;");
      WebOutString("      for (i=0;i<6;i++) {");
      WebOutString("        var cb=document.getElementById('quest'+ch[i]);");
      WebOutString("        if (cb!=null && cb.checked) checked=true;");
      WebOutString("      }");
      WebOutString("      if (checked==false) {");
    end;
    WebOutString("        submit=confirm('WARNING! You did not answer all the questions. Please cancel and review your questions. If you press Ok, your test will be submitted with unanswered questions!');");
    if (res) then begin
      WebOutString("      }");
    end;
    WebOutString("    }");
    WebOutString("    return submit;");
    if (blank(Answerr.PersonName)) then begin
      WebOutString("}");
    end;
    WebOutStringNL("""></td>");
  end else begin
    if (currentquest-2>0) then begin
      WebOutStringNL("<button type=""submit"" name=""navdircombo"" value=""Page:" & currentquest-2 & """>" & currentquest-2 & "</button>");
    end;
    if (currentquest-1>0) then begin 
      WebOutStringNL("<button type=""submit"" name=""navdircombo"" value=""Page:" & currentquest-1 & """>" & currentquest-1 & "</button>");
    end;
    WebOutStringNL("<button type=""submit"" name=""navdircombo"" value=""Page:" & currentquest & """>" & currentquest & "</button>"); //Current page
    if (currentquest+1<=nrofquestions) then begin
      WebOutStringNL("<button type=""submit"" name=""navdircombo"" value=""Page:" & currentquest+1 & """>" & currentquest+1 & "</button>");
    end;
    if (currentquest+2<=nrofquestions) then begin
      WebOutStringNL("<button type=""submit"" name=""navdircombo"" value=""Page:" & currentquest+2 & """>" & currentquest+2 & "</button>");
    end;
    if ((nrofquestions-currentquest)>=3) then begin
      if ((nrofquestions-currentquest)>=4) then begin
        WebOutStringNL("...");
      end;
      WebOutStringNL("<button type=""submit"" name=""navdircombo"" value=""Page:" & nrofquestions & """>" & nrofquestions & "</button>");
    end;
    WebOutStringNL("<input type=""submit"" name=""navdircombo"" value=""Next""></td>");
  end;
  WebOutStringNL("  </tr>");
  WebOutStringNL("</table>");
  WebOutStringNL("</form>");

  return;
end;

global
updating procedure LMSUpdateAnswers(string personname,LongInt univtestnr,string custcode,date enddate,time starttime,integer rownr,string questa,string questb,string questc,string questd,string queste,string questf)
begin
  row UnivTestAnswer2Vc Answerrw;
  record UnivTestAnswer2Vc oldAnswerr,Answerr;
  string 255 alt1,alt2,alt3,alt4,alt5,alt6;
  string 255 ans,alt;
  integer i;
  string 255 oldstr,newstr;

  oldstr = "";
  newstr = "";

  Answerr.UnivTestNr = univtestnr;
  Answerr.CustCode = custcode;
  Answerr.EndDate = enddate;
  Answerr.StartTime = starttime;
  if (ReadFirstKey("CustCode",Answerr,4,true)) then begin
    RecordCopy(oldAnswerr,Answerr);
    MatRowGet(Answerr,rownr,Answerrw);
    for (i=1;i<=6;i=i+1) begin
      switch (i) begin
        case 1: ans = Answerrw.Alt1; alt = questa;
        case 2: ans = Answerrw.Alt2; alt = questb;
        case 3: ans = Answerrw.Alt3; alt = questc;
        case 4: ans = Answerrw.Alt4; alt = questd;
        case 5: ans = Answerrw.Alt5; alt = queste;
        case 6: ans = Answerrw.Alt6; alt = questf;
        otherwise
          ans = "";
      end;
      if (nonblank(ans)) then begin
        if (mid(ans,1,1)=="+" or mid(ans,1,1)=="-") then begin
          oldstr = oldstr & left(ans,1);
          ans = right(ans,len(ans)-1);
        end else begin
          oldstr = oldstr & ".";
        end;
        if (alt=="true") then begin
          ans = "+" & ans;
        end else begin
          ans = "-" & ans;
        end;
        newstr = newstr & left(ans,1);
        switch (i) begin
          case 1: Answerrw.Alt1 = ans;
          case 2: Answerrw.Alt2 = ans;
          case 3: Answerrw.Alt3 = ans;
          case 4: Answerrw.Alt4 = ans;
          case 5: Answerrw.Alt5 = ans;
          case 6: Answerrw.Alt6 = ans;
        end;
      end;
    end;

    MatRowPut(Answerr,rownr,Answerrw);

    if (nonblank(Personname)) then begin
      Answerr.PersonName = Personname;
    end;
    Answerr.LastRowUpdated = rownr;
    i = RecordUpdate(oldAnswerr,Answerr,true);

  end;

  return;
end;

global
updating procedure LMSCompleteTest(string personname,LongInt univtestnr,string custcode,date enddate,time starttime,integer rownr,string questa,string questb,string questc,string questd,string queste,string questf)
begin
  record UnivTestAnswer2Vc Answer2r;
  row UnivTestAnswer2Vc Answerrw;
  record UnivTestAnswer2Vc oldAnswerr;
  integer correct_answers;
  integer i,cnt,rw;

  Answer2r.UnivTestNr = univtestnr;
  Answer2r.CustCode = CustCode;
  Answer2r.EndDate = EndDate;
  Answer2r.StartTime = StartTime;
  if (ReadFirstKey("CustCode",Answer2r,4,true)) then begin
    LMSUpdateAnswers(Personname,univtestnr,CustCode,EndDate,StartTime,rownr,questa,questb,questc,questd,queste,questf);
  end;

  //called after UpdateAnswers which is not queued this time, so we know this happens after UpdateAnswers completed completely
  Answer2r.UnivTestNr = univtestnr;
  Answer2r.CustCode = CustCode;
  Answer2r.EndDate = EndDate;
  Answer2r.StartTime = StartTime;
  if (ReadFirstKey("CustCode",Answer2r,4,true)) then begin end;

  RecordCopy(oldAnswerr,Answer2r);

  correct_answers = 0;
  cnt = MatRowCnt(Answer2r);
  for (i=0;i<cnt;i=i+1) begin
    MatRowGet(Answer2r,i,Answerrw);
    if ((left(Answerrw.Alt1,1)==mid(Answerrw.Alt1,1,1)) and
       (left(Answerrw.Alt2,1)==mid(Answerrw.Alt2,1,1)) and
       (left(Answerrw.Alt3,1)==mid(Answerrw.Alt3,1,1)) and
       (left(Answerrw.Alt4,1)==mid(Answerrw.Alt4,1,1)) and
       (left(Answerrw.Alt5,1)==mid(Answerrw.Alt5,1,1)) and
       (left(Answerrw.Alt6,1)==mid(Answerrw.Alt6,1,1))) then begin
      correct_answers = correct_answers + 1;
      Answerrw.Answer = "OK";
    end else begin
      Answerrw.Answer = "";
    end;
    MatRowPut(Answer2r,i,Answerrw);
  end;
  Answer2r.CorrectAnswers = correct_answers;
  Answer2r.EndTime = CurrentTime;
  Answer2r.OKFlag = 1;

  i = RecordUpdate(oldAnswerr,Answer2r,true);

  return;
end;

global
updating procedure WebHWUUnivTestsAnswersQueue(record UnivTestAnswer2Vc Answerr,Integer comp)
begin
  Boolean res;
  Integer oldcomp;

  oldcomp = CurrentCompany;
  if (SetCompany(comp,false)) then begin
    res = RecordStore(Answerr,true);
  end;
  ResetCompany(oldcomp);
  return;
end;

