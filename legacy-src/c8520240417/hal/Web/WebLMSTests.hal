function boolean FindWebTestFeedback(string custcode,LongInt univtestnr,date startdate,time starttime,var record UnivTestFeedback2Vc UTFr)
begin
  boolean res;
  
  UTFr.CustCode = custcode;
  UTFr.UnivTestNr = univtestnr;
  UTFr.CreatedDate = startdate;
  UTFr.CreatedTime = starttime;
  res = ReadFirstMain(UTFr,4,true);
  
  FindWebTestFeedback = res;
  return;  
end;

