procedure WebsiteLeRace()
begin

  WebOutBegin; <div class="main_containter" style="background-image: url(/images/lerace/background-top.png)"> EndWebOut;
  WebsiteHeader;
  WebOutBegin;
    <img class="index_image" src="/images/lerace/Whats-on-header-image.png"/>
    <div class="index_cont">
      <div class="index_text_cont">
        <div class="index_title">
          <div class="index_title_inner">WHATS ON?</div>
        </div>
        <div class="index_text">An event for every occasion and activities for every season. Akaroa and Banks Peninsula have an exiting calendar of events all year round.
        </br>
        Want to host your own event? Find out how Akaroa Disctrict Promotions can help organize and promote it here</div>
      </div>
      <div class="event_cont">
        <div class="event_image"></div>
        <div class="event_content">
          <div class="event_info_cont">
            <div class="event_info_text">
              <b>LOCATION:</b> Christchurch to Akaroa
              </br>
              <b>WEB:</b> <a href="lerace.co.nz">lerace.co.nz</a>
            </div>
            <div class="event_map_link"></div>
          </div>
          <div class="event_text">
            <h3>Le Race</h3>
            <b>19 Sep 2020</b>
            </br></br>
            This annual cycle race starts in the middle of Christchurch at 7.30am for the pre-race briefing and then it's all go at 8.00am. The finish line is in the centre of Akaroa, followed by prize giving on the Akaroa recreation ground. Make a weekend of it by booking into 1 of the many wonderful B&B's in Akaroa and enjoy a family weekend away. Be warned! This is not your ordinary 100 km race. Hugely popular across all abilities, amazing views and more hills than you can shake a pump at.
            </br></br>
            Covid-19 -19 – Le Race Postponed (as at March 16, 5:00pm): New Date is September 19th 2020
            > Due to the COVID-19 pandemic, the government decided today that mass-gatherings of more than 500 people cannot be held (excluding schools & workplaces).
            </br>
            > Le Race currently had more than 600 entries plus 100-plus crew, let alone participant supporters etc. So this announcement means that the event cannot go ahead this weekend.
            </br>
            > We intend to postpone, but because there has been no clear direction from government as to how long this restriction might be imposed we cannot give a firm date at this stage.
            </br>
            > The new date for Le Race will be announced as soon as we can  (working out cycling calendar now), but we also have to work through Council permissions and re-booking of key service providers, marshals etc.
            </br>
            > The government indicated there would be more detail surrounding these restrictions by the end of this week. We will continue updating as we know more.
            </br></br>
            Please stay safe and well and follow all Ministry of Health advice as it continues to evolve.</br>
            <b>FACEBOOK page HERE.</b></br>
            <b>Future dates:</b></br>
            * 27 March 2021</br>
            * 26 March 2022</br>
          </div>
        </div>
      </div>
    </div>
  EndWebOut;
  WebOutBegin;</div>EndWebOut;
  
end;

procedure showloginpage()
begin

  WebOutBegin;
  <form method="POST">
    Username: <input type="text" name="username">
    Password: <input type="password" name="password">
    <input type="submit" value="Submit">
  </form>
  EndWebOut;

end;

function boolean DirtyRequieresLogin()
begin
  boolean res;
  string 255 username,password;

  if (GetSessionString("loggedin")!="true") then begin
    username = WebGetArg("username");
    password = WebGetArg("password");
    if (username=="ilove" and password=="akaroa") then begin
      PutSessionString("loggedin","true");
    end else begin
      showloginpage;
      res = 1;
    end;
  end;

  DirtyRequieresLogin = res;
end;

global
procedure BuildCustomWebsite(record WebNGStructVc WSr,string mpath)
begin
  string 255 path,node,lang;
  array string 255 nodes;
  integer i;

  if (DirtyRequieresLogin) then begin
    goto LBuildCustomWebsite;
  end;

LogText(0,"language found: " & lang);
  lang = "en";
  path = WebGetArg("path");
  node = removenextnode(path);
  //NRR why is the first one always blank??
  node = removenextnode(path);
  while (nonblank(node)) begin
    nodes[i] = node;
    i = i + 1;
    LogText(0,"node" & i & "=" & node);
    node = removenextnode(path);
  end;
  WebOutBegin; <html lang="<?var(lang)?>"> EndWebOut;
  WebsiteHead;
  WebOutBegin; <body> EndWebOut;
  WebOutBegin; <div class="main_cont"> EndWebOut;
  switch (nodes[0]) begin
    case "attractions": WebsiteAttractions;
    case "history": WebsiteHistory;
    case "activities": WebsiteActivities;
    case "eatanddrink": WebsiteEatDrink;
    case "planyourtrip": WebsitePlanTrip;
    case "wheretostay": WebsiteStay;
    case "lerace": WebsiteLeRace;
    otherwise WebsiteIndex;
  end;
  WebOutBegin; </div> EndWebOut;
  WebsiteFooter;
  WebOutBegin; </body> EndWebOut;
  WebOutBegin; </html> EndWebOut;
  
LBuildCustomWebsite:;
  return;
end;
