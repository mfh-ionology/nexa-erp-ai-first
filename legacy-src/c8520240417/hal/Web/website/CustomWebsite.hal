          <div class="footer_social_icon" style="background-image: url(/images/social_facebook.png);"></div>
          <div class="footer_social_icon" style="background-image: url(/images/social_youtube.png);"></div>
          <div class="footer_social_icon" style="background-image: url(/images/social_instagram.png);"></div>
        </div>
      </div>
      <div class="footer_right">
        <div class="footer_menu">
          <div class="footer_menu_item">Activities & nature</div>
          <a href="http://<?var(WebHost)?>/attractions"><div class="footer_menu_item">Attraction & culture</div></a>
          <div class="footer_menu_item">Eat & drink</div>
          <div class="footer_menu_item">Where to stay</div>
          <div class="footer_menu_item">Plan Your trip</div>
        </div>
        <div class="footer_menu">
          <div class="footer_menu_item">Events</div>
          <div class="footer_menu_item">Getting Here</div>
          <div class="footer_menu_item">Helpful Information</div>
          <div class="footer_menu_item">Cruse Ship Schedule</div>
        </div>
        <div class="footer_menu">
          <div class="footer_menu_item">Contact Us</div>
          <div class="footer_menu_item">Akaroa New Zealand</div>
          <div class="footer_menu_item">www.magicakaroa.com</div>
        </div>
      </div>
    </div>
    <div class="footer_copyright">©Copyright 2020 Akaroa District Promotions created by HansaWorld</div>
  </div>
  EndWebOut;
  
  return;
end;

