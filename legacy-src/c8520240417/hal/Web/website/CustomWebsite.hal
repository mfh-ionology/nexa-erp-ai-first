procedure WebsitePlanTrip()
begin

  WebOutBegin; <div class="main_containter" style="background-image: url(/images/plantrip/background-top.png)"> EndWebOut;
  WebsiteHeader;
  WebOutBegin;
    <img class="index_image" src="/images/plantrip/plan-your-trip-header-image.png"/>
    <div class="index_cont">
      <div class="index_text_cont">
        <div class="index_title">
          <div class="index_title_inner">Plan Your Trip</div>
        </div>
        <div style="background-image: url(/images/plantrip/plan-your-trip-callout-image-1.png)"></div>
        <div class="index_text">
          <div class="plantrip_gallery" style="background-image: url(/images/plantrip/plan-your-trip-callout-image-1.png)"></div>
          <div class="plantrip_text">
          Only a short 75km drive from Christcurch separate you from your next adventure.
          </br>
          Along the way you'll enjoy the picturesque journey as you navigate your way through the idyllic township of Little River - the gateway to Banks Peninsula. Home to artists, writers and farmers who's produce can be found in the infamous Little River Cafe and Gallery, this small township thrives on character and charm endearing itself to all visitors no matter how long their visit lasts.
          </br>
          upon reaching the Hilltop Take a moment to experience the stunning panoramic view of Akaroa harbour and sorrounding peninsula. From here, the options are yours to arrive at your final destination. Head directly to Akaroa via SH75 or take the scenic 'Tourist Drive' along the crater of the extinct volcano for unparraleled views down into the harbour. Along the way, discover a number of the region's vineyards or visit Barry's Bay Cheese - the delicious cheese producers who source fresh Banks
          </div>
        </div>
      </div>
      <div class="index_images_cont" style="background-image: url(images/plantrip/background-2.png)">
        <div class="index_images">
          <div class="index_images_cont_inner">
            <img class="index_images_inner" src="/images/plantrip/transport.png"/>
            <div class="index_images_banner">
              <div class="index_images_banner_title">TRANSPORT</div>
            </div>
          </div>
        </div>
        <div class="index_images">
          <div class="index_images_cont_inner">
            <img class="index_images_inner" src="/images/plantrip/helpful-information.png"/>
            <div class="index_images_banner">
              <div class="index_images_banner_title">HELPFUL INFORMATION</div>
            </div>
          </div>
        </div>
        <div class="index_images">
          <div class="index_images_cont_inner">
            <img class="index_images_inner" src="/images/plantrip/play-it-safe.png"/>
            <div class="index_images_banner">
              <div class="index_images_banner_title">PLAY IT SAFE</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  EndWebOut;
  WebOutBegin;</div>EndWebOut;
