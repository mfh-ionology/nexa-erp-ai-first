procedure WebsiteHead()
begin

  WebOutBegin;
  <head>
  <link rel="icon" href="images/favicon.png" sizes="32x32">
  <title>Magic Akaroa</title>
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js"></script>
  <script src="/js/main.js"></script>
  <link rel="stylesheet" type="text/css" href="/css/main.css">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="shortcut icon" href="favicon.ico" type="image/x-icon">
  </head>
  EndWebOut;

end;

procedure WebsiteHeader()
begin
  
  WebOutBegin;
  <div class="header_cont">
    <div class="head_title" style="background-image: url(/images/top_logo.png);"></div>
    <a class="toggle-menu genericon" onclick="$('#top_menu').toggle()"></a>
    <div id="top_menu" class="head_menu_cont menu_hide">
      <a href="http://<?var(WebHost)?>"><div class="head_menu_item">HOME</div></a>
      <a href="http://<?var(WebHost)?>/activities"><div class="head_menu_item">ACTIVITIES & NATURE</div></a>
      <a href="http://<?var(WebHost)?>/attractions"><div class="head_menu_item">ATTRACTION & CULTURE</div></a>
      <a href="http://<?var(WebHost)?>/eatanddrink"><div class="head_menu_item">EAT & DRINK</div></a>
      <a href="http://<?var(WebHost)?>/wheretostay"><div class="head_menu_item">WHERE TO STAY</div></a>
      <a href="http://<?var(WebHost)?>/planyourtrip"><div class="head_menu_item">PLAN YOUR TRIP</div></a>
    </div>
  </div>
  EndWebOut;
  
  return;
end;

procedure WebsiteFooter()
begin

  WebOutBegin;
  <div class="footer">
    <div class="footer_cont">
      <div class="footer_left">
        <div class="footer_image"></div>
