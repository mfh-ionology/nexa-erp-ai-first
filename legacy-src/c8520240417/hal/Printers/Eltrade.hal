function Integer EndNonFiscalReceipt()
begin
  INteger res,msglen,noErr;
  string 255 CtrlSeq,msglenhex;

  CtrlSeq = CtrlSeq & HexToInt("0x45");
  CtrlSeq = CtrlSeq & chr(FB15_FS);
