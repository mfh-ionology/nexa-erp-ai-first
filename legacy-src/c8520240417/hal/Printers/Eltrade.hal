  CtrlSeq = CtrlSeq & chr(Eltrade_ETX);

  res = FB15Write(CtrlSeq,Eltrade_DELAY);  

  PrintRecReturn = res;
  return;
end;

function Integer PrintCommentLine(record IVVc IVr,row IVVc IVrw)
begin
  INteger res,msglen,noErr;
  string 255 CtrlSeq,msglenhex;
