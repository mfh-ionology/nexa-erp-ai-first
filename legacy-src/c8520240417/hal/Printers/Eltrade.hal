function Integer EltradeWriteAndGetResponse(string CtrlSeq,LongInt delay,var string response) 
begin
  Integer res;

  response = "";
  res = OutComPort(0,CtrlSeq);

  if (res!=0) then begin
    res = WaitForEltradeReply(delay,response);
    if (res==Eltrade_NAK) then begin
      response = "";
      res = EltradeWriteAndGetResponse(CtrlSeq,delay,response);
    end;
  end else begin
    res = 1;
  end;
LogText(0," EltradeWriteAndGetResponse CtrlSeq=" & CtrlSeq);  
LogText(0," EltradeWriteAndGetResponse response=" & response);  
  EltradeWriteAndGetResponse = res;
  return;
end;
 
