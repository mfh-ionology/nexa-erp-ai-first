function Integer ReadErrorFromStatus(string status)
begin
  Integer res,noErr;
  Integer i,err,bytetest;
  
  noErr = 0;
  res = noErr;

  bytetest = GetByteFromString(status,0);
//  if (TestBit(bytetest,5)!=0) then begin res = 19381; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,4)!=0) then begin res = 19382; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,3)!=0) then begin res = 19383; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,2)!=0) then begin res = 12402; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,1)!=0) then begin res = 22114; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,0)!=0) then begin res = 19385; goto LReadErrorFromStatus; end;

  bytetest = GetByteFromString(status,1);
  if (TestBit(bytetest,6)!=0) then begin res = 30214; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,5)!=0) then begin res = 30213; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,2)!=0) then begin res = 19349; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,1)!=0) then begin res = 19389; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,0)!=0) then begin res = 19340; goto LReadErrorFromStatus; end;

  bytetest = GetByteFromString(status,2);
  if (TestBit(bytetest,6)!=0) then begin res = 30215; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,5)!=0) then begin res = 22128; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,4)!=0) then begin res = 19342; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,3)!=0) then begin res = 22126; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,2)!=0) then begin res = 19342; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,1)!=0) then begin res = 19341; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,0)!=0) then begin res = 19342; goto LReadErrorFromStatus; end;

//  bytetest = GetByteFromString(status,3); siwtches

  bytetest = GetByteFromString(status,4);
  if (TestBit(bytetest,5)!=0) then begin res = 19381; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,4)!=0) then begin res = 36163; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,3)!=0) then begin res = 19345; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,2)!=0) then begin res = 30216; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,0)!=0) then begin res = 19349; goto LReadErrorFromStatus; end;

  bytetest = GetByteFromString(status,5);
  if (TestBit(bytetest,6)!=0) then begin res = 30218; goto LReadErrorFromStatus; end;

  if (TestBit(bytetest,3)!=0) then begin res = 30217; goto LReadErrorFromStatus; end;
  if (TestBit(bytetest,0)!=0) then begin res = 36163; goto LReadErrorFromStatus; end;

LReadErrorFromStatus:;  
  ReadErrorFromStatus = res;
  return;
end;

function Integer WaitForEltradeReply(LongInt waittickscoef,var string response)
begin
  Integer res;
  Integer noErr;
  LongInt waitticks;
  LongInt currenttick, starttick;
  Integer l,responselen;
  Boolean waitf;
  string 255 c,errorcode,status;
  Integer pos,i;
  string 255 tstr,tstr2;

  res = noErr;
  response = "";
  waitticks = waittickscoef*1000;
  starttick = GetCurTick;

  waitf = true;
  while (waitf) begin
    currenttick = GetCurTick;

    c = ReadComPort(0,1);

    response = response & c;

    switch (asc(c)) begin
      case Eltrade_ETX:
        waitf = false;
      case Eltrade_NAK://repeat message
        res = Eltrade_NAK;
        goto LWaitForEltradeReply;
      case Eltrade_SYN:
    end;
    

    if ((currenttick-starttick)>waitticks) then begin
      waitf = false;
    end;
  end;
 

  ExtractObjWithSeparator(chr(Eltrade_Postamble),response,true,pos,tstr);
  response = Right(tstr,len(tstr)-4);
  ExtractObjWithSeparator(chr(Eltrade_Postamble),response,true,pos,status);
  errorcode = ReadErrorFromStatus(status);
  

  if (asc(errorcode)!=0) then begin
    res = StringToInt(errorcode);
    LogText(0,"WaitForEltradeReply errorcode " & errorcode & " res " & res);
//    ResetFiscal;
  end;  
LWaitForEltradeReply:;  
  WaitForEltradeReply = res;
  return;
end;

