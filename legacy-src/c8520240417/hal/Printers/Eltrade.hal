function Integer EltradeOpen(record LSerialPortDeviceVc LSPDr)
begin
  Integer res;
  
  if (OpenComPort(0,LSPDr.Port,LSPDr.BaudRate,LSPDr.Parity,LSPDr.ByteSize,LSPDr.StopBits,LSPDr.FlowControl)) then begin
//    res = FB15GetFiscalData("3");
  end else begin
    res = 1;
  end;
  EltradeOpen = res;
  return;
end;

procedure EltradeClose()
begin
  Integer res;

  res = CloseComPort(0);
  return;
end;

function Integer CheckEltradeClock(var Integer cmdnr)
begin
  Integer res,msglen,noErr,pos;
  string 255 CtrlSeq,msglenhex,response,fpresp; 
  Date td; 
  Integer pY,pM,pD;
  
//<COMMAND>=<0x4F><FS><Ő5Ő><FS>

//00 01 02 03 04 05 06 07 08 09 0A 0B 0C 0D 0E 0F 
//AA 55 00 50 3E 00 72
    
  td = CurrentDate;
  msglen = 4;

  CtrlSeq = chr(HexToInt(msglenhex));
  CtrlSeq = CtrlSeq & chr(cmdnr);
  cmdnr = cmdnr + 1;
  CtrlSeq = CtrlSeq & chr(HexToInt("0x3E"));
  CtrlSeq = CtrlSeq & chr(Eltrade_Postamble);

  CtrlSeq = CtrlSeq & chr(HexToInt(CalculateBCC(CtrlSeq)));
  
  CtrlSeq = chr(Eltrade_SOH) & CtrlSeq & chr(Eltrade_ETX);

  res = EltradeWriteAndGetResponse(CtrlSeq,Eltrade_DELAY,response);
    
  if (res!=noErr) then begin
    if (res>=12400) then begin
      MessageBox(0,USetStr(res));
    end else begin
      MessageBox(0,"error " & USetStr(res));
    end;
    goto LCheckEltradeClock;
  end;

  ExtractObjWithSeparator(" ",response,true,pos,fpresp);
//  td = DateFromString(fpresp,"DD-MM-YY");
//  ExtractObjWithSeparator(" ",response,true,pos,fpresp);
  pD = StringToInt(Mid(fpresp,0,2));
  pM = StringToInt(Mid(fpresp,3,2));
  pM = StringToInt(Mid(fpresp,6,2));
    
  if ((td.year==pY) and (td.month==pM) and (td.day==pD)) then begin
     res = noErr;
  end else begin
     MessageBox(0,USetStr(12402));
     MessageBox(0,USetStr(12403) & pY & pM & pD);
     MessageBox(0,USetStr(12404) & GetYear(td) & GetMonth(td) & GetDay(td));
     res = 12402;
  end;
LCheckEltradeClock:;
  CheckEltradeClock = res;
  return;
end;

function Integer LoadEltradeVATRates(vector val vatrates,var Integer cmdnr)
begin
  Integer res,msglen,noErr;
  string 255 CtrlSeq,msglenhex,response,fpresp,tmpstr; 
  LongInt pos;
  val vr;

  msglen = 13+20;
  CtrlSeq = chr(HexToInt(msglenhex));
  CtrlSeq = CtrlSeq & chr(cmdnr);
  cmdnr = cmdnr + 1;
  CtrlSeq = CtrlSeq & chr(HexToInt("0x32"));
  CtrlSeq = CtrlSeq & DateToString(CurrentDate,"DDMMYY");
  CtrlSeq = CtrlSeq & ",";
  CtrlSeq = CtrlSeq & DateToString(CurrentDate,"DDMMYY");
  CtrlSeq = CtrlSeq & chr(Eltrade_Postamble);

  CtrlSeq = CtrlSeq & chr(HexToInt(CalculateBCC(CtrlSeq)));
  CtrlSeq = chr(Eltrade_SOH) & CtrlSeq & chr(Eltrade_ETX);

  res = EltradeWriteAndGetResponse(CtrlSeq,Eltrade_DELAY,response);
  
  if (res!=noErr) then begin
    res = 12405;
    goto LLoadEltradeVATRates;
  end;

  pos = 0;
  GetNextSubstring(response,pos,",",tmpstr);
  GetNextSubstring(response,pos,",",fpresp);
  vr = ValFromString(fpresp,"","")/100;
  vatrates[0] = vr;
  GetNextSubstring(response,pos,",",fpresp);
  vr = ValFromString(fpresp,"","")/100;
  vatrates[1] = vr;
  GetNextSubstring(response,pos,",",fpresp);
  vr = ValFromString(fpresp,"","")/100;
  vatrates[2] = vr;


LLoadEltradeVATRates:;
  LoadEltradeVATRates = res;
  return;
end;

