function Integer FindStrPosition(string tstr,string decsep)
begin
  Integer res;
  Integer i,slen;
  
  slen = len(tstr);
  for (i=slen;i>=0;i=i-1) begin
    if (Mid(tstr,i,1)==decsep) then begin
       res = i;
       goto LFindStrPosition;
    end;
  end;
LFindStrPosition:;  
  FindStrPosition = res;
  return;  
end;

function Integer HexToInt(string instr)
begin
  Integer res;
  string 16 hexs;
  Integer pos,slen,i,t;

  res = 0;
  slen = len(instr);
  hexs = "0123456789ABCDEF";
  for (i=slen;i>0;i=i-1) begin
    pos = FindStrPosition(hexs,Mid(instr,i-1,1));
    res = res + pos*Power(16,(slen-i));
  end; 
  HexToInt = res; 
  return;  
end;

global
function Integer CheckFM32State(Integer Printer)
begin
  Integer res,noErr;
  string 255 response; 
  Date td; 
  Integer pY,pM,pD;
  
//<COMMAND>=<0x4F><FS><Ő5Ő><FS>

  td = CurrentDate;
  res = FiscalPrinterGetInfo(Printer,9,response);

  if (res!=noErr) then begin
    if (res>=12400) then begin
      ReportDLLError(0,USetStr(res));
    end else begin
      ReportDLLError(0,"FM32 state error " & USetStr(res));
    end;
    goto LCheckFM32State;
  end;

  switch (Left(response,1)) begin
    case "0": res = 0;
    case "1": res = 1;
    case "2": res = 2;
    case "3": res = 12400;
    case "4": res = 4;
  end;
  
LCheckFM32State:;

  CheckFM32State = res;
  return;
end;

