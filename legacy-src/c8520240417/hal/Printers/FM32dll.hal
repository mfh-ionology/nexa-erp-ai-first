function Integer MoneyOutCurr(Integer Printer,record CashVc Cashr)
begin
  INteger res,noErr;

  res = CheckFM32State(Printer);
  switch (res) begin
    case kFiscalPrinterStateIDLE:
      res = FiscalPrinterMoneyOut(Printer,0,AbsoluteVal(Cashr.Total));
    case kFiscalPrinterStateZIDLE:
      res = FiscalPrinterMoneyOut(Printer,0,AbsoluteVal(Cashr.Total));
  end;
  MoneyOutCurr = res;
  return;
end;

function Integer MoneyInCurr(Integer Printer,record CashVc Cashr)
begin
  Integer res,noErr;

  res = CheckFM32State(Printer);
  switch (res) begin
    case kFiscalPrinterStateIDLE:
      res = FiscalPrinterMoneyIn(Printer,0,AbsoluteVal(Cashr.Total));
    case kFiscalPrinterStateZIDLE:
      res = FiscalPrinterMoneyIn(Printer,0,AbsoluteVal(Cashr.Total));
  end;
  MoneyInCurr = res;
  return;
end;

global
procedure PrintFM32CashEventdll(var record CashVc Cashr,record LSerialPortDeviceVc LSPDr)
begin
  Integer noErr,res;
  
  noErr = 0;
  if (RequireOpenSession(Cashr.MachineName)) then begin
    if (IsSessionOpen(Cashr.MachineName,Cashr.Drawer,Cashr.TransDate,Cashr.TransTime)==false) then begin
      res = 2195;
      goto LPrintFM32CashEvent;
    end;
  end;
  res = CheckFM32State(LSPDr.Printer);
  switch (res) begin
    case kFiscalPrinterStateFIS:
      FiscalPrinterReset(LSPDr.Printer);
    case kFiscalPrinterStateZIDLE:
      FiscalPrinterReset(LSPDr.Printer);
  end;
  switch (Cashr.Event) begin
    case 0:
      if (Cashr.Total<0) then begin
        res = MoneyInCurr(LSPDr.Printer,Cashr);
      end else begin
        res = MoneyOutCurr(LSPDr.Printer,Cashr);
      end;
    case 1:
      if (Cashr.Total<0) then begin
        res = MoneyOutCurr(LSPDr.Printer,Cashr);
      end else begin
        res = MoneyInCurr(LSPDr.Printer,Cashr);
      end;
  end;
LPrintFM32CashEvent:;
  if (res!=0) then begin
    if (res<0) then begin res = 22138; end;
    MessageBox(res,"");
  end;
  return;
end;

global
procedure FisUSBSetClerkdll(record LSerialPortDeviceVc LSPDr,string usercode,Boolean loginf)
begin
  Integer noErr,res;
  record UserVc Userr;

  noErr = 0;
  res = CheckFM32Clock(LSPDr.Printer);
  if (res!=noErr) then begin
    goto LFisUSBSetClerkdll;
  end;
  Userr.Code = usercode;
  FindTheUser(Userr);
  res = FiscalPrinterSetClerk(LSPDr.Printer,Userr.Name,0,loginf);
  res = 0;
LFisUSBSetClerkdll:;
  if (res!=0) then begin
    if (res<0) then begin res = 22138; end;
    ReportDLLError(res,"");
  end;
  return;
end;

global
procedure FisUSBRegisterClerkdll(string usercode)
begin
  Integer noErr,res;
  record LocalMachineBlock LMb;
  record LSerialPortDeviceVc LSPDr;
  record UserVc Userr;

  BlockLoad(LMb);  
  if (FindLocalSerialPortDevice(kSerialPortDeviceClassFiscalPrinter,-1,LMb.LocalMachineCode,LSPDr)==false) then begin  
    goto LFisUSBRegisterClerkdll;
  end;
  noErr = 0;
  switch (LSPDr.Printer) begin
    case kSerialPortDeviceModelFiscPrinterFisUSBMDLL:
      res = CheckFM32State(LSPDr.Printer);
      switch (res) begin
        case kFiscalPrinterStateFIS:
          FiscalPrinterReset(LSPDr.Printer);
      end;
      Userr.Code = usercode;
      FindTheUser(Userr);
      FiscalPrinterRegisterClerk(LSPDr.Printer,Userr.Name);
LFisUSBRegisterClerkdll:;
      if (res!=0) then begin
        if (res<0) then begin res = 22138; end;
        MessageBox(res,"");
      end;
  end;
  return;
end;

global
procedure FisUSBUnregisterClerkdll(string usercode)
begin
  Integer noErr,res;
  record LocalMachineBlock LMb;
  record LSerialPortDeviceVc LSPDr;
  record UserVc Userr;

  BlockLoad(LMb);  
  if (FindLocalSerialPortDevice(kSerialPortDeviceClassFiscalPrinter,-1,LMb.LocalMachineCode,LSPDr)==false) then begin  
    goto LFisUSBUnregisterClerkdll;
  end;
  noErr = 0;
  switch (LSPDr.Printer) begin
    case kSerialPortDeviceModelFiscPrinterFisUSBMDLL:
      res = CheckFM32State(LSPDr.Printer);
      switch (res) begin
        case kFiscalPrinterStateFIS:
          FiscalPrinterReset(LSPDr.Printer);
      end;
      Userr.Code = usercode;
      FindTheUser(Userr);
      FiscalPrinterUnregisterClerk(LSPDr.Printer,Userr.Name);
LFisUSBUnregisterClerkdll:;
      if (res!=0) then begin
        if (res<0) then begin res = 22138; end;
        MessageBox(res,"");
      end;
  end;
  return;
end;

global
procedure FM32DLLOpenDrawer(record LSerialPortDeviceVc LSPDr,Boolean opencomf)
begin
  Integer res;
  string 20 CtrlSeq;
  string 255 ldevice;

  ldevice = LSPDr.Port;
  if (blank(ldevice)) then begin
    ldevice = "COM1";
  end;
  if (opencomf) then begin
    res = OpenComPort(0,ldevice,LSPDr.BaudRate,LSPDr.Parity,LSPDr.ByteSize,LSPDr.StopBits,LSPDr.FlowControl);
    if (res==0) then begin
      goto LFM32DLLOpenDrawer;
    end;
  end;
  CtrlSeq = chr(2) & chr(129) & chr(167) & chr(85) & chr(0) & chr(0);  
  res = OutComPort(0,CtrlSeq);
  if (opencomf) then begin
    CloseComPort(0);
  end;
LFM32DLLOpenDrawer:;  
  return;
end;
