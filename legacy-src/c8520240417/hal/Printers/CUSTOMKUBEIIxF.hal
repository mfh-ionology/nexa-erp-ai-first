forward function Integer CUSTOMKUBEIIxFWrite(var Integer,string,LongInt);

//FS, Field Separator = 0x1C

enum begin
  CUSTOMKUBEIIxF_DELAY = 10,
  CUSTOMKUBEIIxF_LONGDELAY = 30
end;

enum begin
  CUSTOMKUBEIIxF_STX = 2,
  CUSTOMKUBEIIxF_ETX = 3,
  CUSTOMKUBEIIxF_ACK = 6,
  CUSTOMKUBEIIxF_NAK = 15
end;

function string 255 CalculateLRC(string CtrlSeq)
begin
  string 255 res;
  Integer i,resi,a;
  
  resi = 0;
//LogText(0,"s.CalculateLRC CtrlSeq=" & CtrlSeq);  
  for (i=0;i<len(CtrlSeq);i=i+1) begin
    a = GetByteFromString(Mid(CtrlSeq,i,1),0);
    resi = resi + a;
  end;
  resi = Mod(resi,100);  
  res = resi;
  res = Right(res,2);
  M4PadString(res,2,"0",true,res);          
  CalculateLRC = res;
  return;
end;

function string 255 SequenceNr(var Integer seqnr)
begin
  string 255 res;
  
  seqnr = seqnr + 1;
  if (seqnr>99) then begin
    seqnr = 1;
  end;
  M4PadString(seqnr,2,"0",true,res);          
  SequenceNr = res;
  return;
end;

