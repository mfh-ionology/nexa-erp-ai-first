global
procedure SetPOSWindowDisplayModeFiscalPrinterEPSON81II(record LSerialPortDeviceVc LSPDr,string dispstr,string disp2str)
begin
  string 255 host,codepage,response,operator;
  LongInt port;
  LongInt pos;
  Integer seqnr,noErr;
  Integer res;
  string 255 tstr,t2;
  string 255 CtrlSeq;
  record MachineCashVc MCr;

  seqnr = 0;
  noErr = 0;

  res = EPSON81IIOpen(LSPDr);
  if (res!=noErr) then begin
    goto LSetPOSWindowDisplayModeFiscalPrinterEPSON81II;
  end;

  operator = "01";

  res = Send_InconsequentialMessages(seqnr,operator);
  if (res!=noErr) then begin
    goto LSetPOSWindowDisplayModeFiscalPrinterEPSON81II;
  end;

  M4PadString(dispstr,20," ",false,tstr);          
  M4PadString(disp2str,20," ",false,t2);          
  tstr = tstr & t2;
  res = DisplayText(seqnr,operator,0,tstr);
  if (res!=noErr) then begin
    MessageBox(21484,"");
    goto LSetPOSWindowDisplayModeFiscalPrinterEPSON81II;
  end;
  if (blank(dispstr) and Left(disp2str,len(USetStr(24172)))==USetStr(24172)) then begin
    MCr.Code = LSPDr.LocalMachineCode;
    ReadFirstMain(MCr,1,true);

    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "4";
    CtrlSeq = CtrlSeq & "015";
    CtrlSeq = CtrlSeq & "13";
    CtrlSeq = CtrlSeq & "997";
    CtrlSeq = CtrlSeq & "NU";
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);  

    res = EPSON81IIWrite(seqnr,"01",CtrlSeq,EPSON81II_DELAY);
  
    M4PadString(MCr.DisplayText,20," ",false,tstr);          
    res = DisplayText(seqnr,operator,3,tstr);
  end;
LSetPOSWindowDisplayModeFiscalPrinterEPSON81II:;  
  EPSON81IIClose;
  return;
end;


//TCPIP --------------- TCPIP

procedure TCPIPResetFiscal(string host,LongInt port,var Integer seqnr,string operator)
begin
  INteger res,noErr;
  string 255 CtrlSeq,cmd,response;

  CtrlSeq = CtrlSeq & SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "088";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

LogText(0,"ResetFiscal CtrlSeq=" & CtrlSeq);

  res = TCPIP_EPSON81IIWrite(host,port,seqnr,CtrlSeq,EPSON81II_DELAY);
  return;
end;

function Integer TCPIP_EPSON81IIWriteAndGetResponse(string host,LongInt port,var Integer seqnr,string operator,string CtrlSeq,LongInt delay,var string response) 
begin
  Integer res,noErr;
  Area req,reply;
  string 255 errorcode;

  response = "";

LogText(0,"tcpwriteandresp CtrlSeq=" & chr(EPSON81II_STX) & CtrlSeq & chr(EPSON81II_ETX));

  SetAreaZeroSize(req);
  AddStringToArea(chr(EPSON81II_STX) & CtrlSeq & chr(EPSON81II_ETX),req);

  SendTCPRequest(host,port,-1,false,"","","","",false,req,reply,EPSON81II_DELAY,0);

//  res = ParsePOSNETReplyFromTCPIP(host,port,codepage,reply);
  res = 0;
  response = AreaToString(reply);
  
LogText(0,"tcpwriteandresp response=" & response);  
  
  if (Mid(response,4,3)=="ERR") then begin
    errorcode = Mid(response,9,2);
    res = StringToInt(errorcode);
Trace("errorcode " & errorcode,"");  
  end;
  if (res!=noErr) then begin
    TCPIPResetFiscal(host,port,seqnr,operator);
  end;

//LogText(0," error.WaitForEPSON81IIReply " & response & " command " & command & " fpresp " & fpresp & " errorcode " & errorcode & " Mid(response,4,3) " & Mid(response,4,3));

  
  TCPIP_EPSON81IIWriteAndGetResponse = res;
  return;
end;

function Integer TCPIP_EPSON81IIWrite(string host,LongInt port,var Integer seqnr,string operator,string CtrlSeq,LongInt delay) 
begin
  Integer res,noErr;
  Area req,reply;
  string 255 response;
  string 255 errorcode;
  
LogText(0,"tcpwrite CtrlSeq=" & chr(EPSON81II_STX) & CtrlSeq & chr(EPSON81II_ETX));

  SetAreaZeroSize(req);
  AddStringToArea(chr(EPSON81II_STX) & CtrlSeq & chr(EPSON81II_ETX),req);

  SendTCPRequest(host,port,-1,false,"","","","",false,req,reply,EPSON81II_DELAY,0);

  res = 0;
  response = AreaToString(reply);
LogText(0,"tcpread response=" & response);  

  if (Mid(response,4,3)=="ERR") then begin
    errorcode = Mid(response,9,2);
    res = StringToInt(errorcode);
Trace("errorcode " & errorcode,"");  
  end;
  if (res!=noErr and Mid(CtrlSeq,4,3)!="088") then begin
    TCPIPResetFiscal(host,port,seqnr,operator);
  end;
  
  TCPIP_EPSON81IIWrite = res;
  return;
end;

function Integer TCPIPSend_InconsequentialMessages(string host,LongInt port,string codepage,var Integer seqnr,string operator)
begin
  Integer res,noErr;
  string 255 CtrlSeq; 
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "074";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);  

  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=noErr) then begin
    goto LTCPIPSend_InconsequentialMessages;
  end;

  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "015";
  CtrlSeq = CtrlSeq & "13";
  CtrlSeq = CtrlSeq & "005";
  CtrlSeq = CtrlSeq & "NU";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);  

  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=noErr) then begin
    goto LTCPIPSend_InconsequentialMessages;
  end;
LTCPIPSend_InconsequentialMessages:;  
  TCPIPSend_InconsequentialMessages = res;
  return;
end;

function Integer TCPIPCheckClock(string host,LongInt port,string codepage,var Integer seqnr)
begin
  INteger res,noErr;
  string 255 CtrlSeq,response,fpresp,tstr; 
  Date td; 
  Integer pY,pM,pD;
  LongInt pos;
  
//<COMMAND>=<0x4F><FS><Ő5Ő><FS>

  td = CurrentDate;

  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "201";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);  

  res = TCPIP_EPSON81IIWriteAndGetResponse(host,port,seqnr,"",CtrlSeq,EPSON81II_DELAY,response);
        
  if (res!=noErr) then begin
    if (res>=12400) then begin
      MessageBox(0,USetStr(res));
    end else begin
      MessageBox(0,"error " & USetStr(res));
    end;
    goto LTCPIPCheckClock;
  end;

  pos = 0;
  GetNextSubstring(response,pos,"E",fpresp);
  GetNextSubstring(response,pos,"E",fpresp);

  fpresp = Right(fpresp,len(fpresp)-4);

  pD = StringToInt(Left(fpresp,2));
  pM = StringToInt(Mid(fpresp,2,2));
  pY = 2000+StringToInt(Mid(fpresp,4,2));
    
  if ((td.year==pY) and (td.month==pM) and (td.day==pD)) then begin
     res = noErr;
  end else begin
     MessageBox(0,USetStr(12402));
     MessageBox(0,USetStr(12403) & pY & pM & pD);
     MessageBox(0,USetStr(12404) & GetYear(td) & GetMonth(td) & GetDay(td));
     res = 12402;
  end;
LTCPIPCheckClock:;
  TCPIPCheckClock = res;
  return;
end;

function Integer TCPGetEPSON81IIREADPROMO(string host,LongInt port,string codepage,var Integer seqnr,string operator)
begin
  Integer res,noErr;
  string 255 CtrlSeq,response; 
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "278";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "3";
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  
  res = TCPIP_EPSON81IIWriteAndGetResponse(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY,response);
LogText(0,"TCPGetEPSON81IIREADPROMO response " & response);  
  TCPGetEPSON81IIREADPROMO = res;
  return;
end;

function Integer TCPIPBeginFiscalReceipt(string host,LongInt port,string codepage,var Integer seqnr,string operator,string regnr1)
begin
  INteger res,noErr;
  string 255 CtrlSeq,response,tstr;
  record MachineCashVc MCr;

  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "085";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=noErr) then begin
    goto LTCPIPBeginFiscalReceipt;
  end;

  if (nonblank(regnr1)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "061";
    CtrlSeq = CtrlSeq & operator;
    M4PadString(regnr1,16," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  end;
//likley is done below but we dont know if should be dont for every invoice or not
  /*
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "4";
    CtrlSeq = CtrlSeq & "015";
    CtrlSeq = CtrlSeq & "09";
    CtrlSeq = CtrlSeq & "000";
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LTCPIPBeginFiscalReceipt;
    end;
  */
LTCPIPBeginFiscalReceipt:;  
  TCPIPBeginFiscalReceipt = res;
  return;
end;

function Integer IVCash_TCPIPPrintCommentLine(string host,LongInt port,string codepage,var Integer seqnr,string operator,record IVCashVc IVCr,row IVCashVc IVCrw)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr,response;
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "078";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "00";
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & "1";
  M4PadString(IVCrw.Spec,32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWriteAndGetResponse(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY,response);
  IVCash_TCPIPPrintCommentLine = res;
  return;
end;

function Integer IVCash_TCPIPDiscountAdditionForItem(string host,LongInt port,string codepage,var Integer seqnr,string operator,record IVCashVc IVCr,row IVCashVc IVCrw)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr,response;
  string 255 unit;
  val v,p;
  
  CalcSum(IVCrw.Quant,IVCrw.Price,IVCrw.PriceFactor,0,v,0);
  v = v - FormulaDiscountCalcSum(IVCrw.Quant,IVCrw.Price,IVCrw.PriceFactor,IVCrw.vRebate);  
  p = CalculateDiscountPercentage(IVCrw.Quant,IVCrw.Price,IVCrw.Sum);

  unit = IVCrw.UnitCode;
  if (blank(unit)) then begin
    unit = "PCS";
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "083";
  CtrlSeq = CtrlSeq & operator;
  tstr = ValToString(p,M41Val,"",".",0);
  M4PadString(USetStr(1870) & " " & tstr & "%",32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;

  tstr = ValToString(v*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);
  CtrlSeq = CtrlSeq & tstr;  
  CtrlSeq = CtrlSeq & "0";  
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "1";  
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

//  res = TCPIP_EPSON81IIWriteAndGetResponse(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY,response);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);

  IVCash_TCPIPDiscountAdditionForItem = res;
  return;
end;

function Integer IVCash_TCPIPPrintItemRow(string host,LongInt port,string codepage,var Integer seqnr,string operator,Integer typ,record IVCashVc IVCr,row IVCashVc IVCrw,vector val vatrates)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr,response;
  string 255 unit;
  Boolean negtivef;
  record INVc INr;
  
  ReadFirstItem(IVCrw.ArtCode,INr,false,true);
  if (IVCrw.Quant<0) then begin
    negtivef = true;
    IVCrw.Quant = -IVCrw.Quant;
  end;
  negtivef = negtivef or IVCr.InvType==kPOSInvoiceTypeCredit;
  unit = IVCrw.UnitCode;
  if (blank(unit)) then begin
    unit = "PCS";
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  if (negtivef) then begin
    CtrlSeq = CtrlSeq & "081";
  end else begin
    CtrlSeq = CtrlSeq & "080";
  end;
  tstr = StringToInt(operator) + 50;
  CtrlSeq = CtrlSeq & tstr;
  M4PadString(IVCrw.Spec,32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  tstr = ValToString(IVCrw.Quant*1000,M40Val,"","",0);
  M4PadString(tstr,7,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  tstr = ValToString(IVCrw.Price*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & FindFiscalDepartment(INr);
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
//  res = TCPIP_EPSON81IIWriteAndGetResponse(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY,response);
  
  if (res==noErr) then begin
    if (nonblank(IVCrw.SerialNr)) then begin
      IVCrw.Spec = UsetStr(1141) & IVCrw.SerialNr;
      res = IVCash_TCPIPPrintCommentLine(host,port,codepage,seqnr,operator,IVCr,IVCrw);
    end;
  end;


  if (res==noErr) then begin
    if (nonblank(IVCrw.vRebate)) then begin
      res = IVCash_TCPIPDiscountAdditionForItem(host,port,codepage,seqnr,operator,IVCr,IVCrw);
    end;
  end;
  IVCash_TCPIPPrintItemRow = res;
  return;
end;

