procedure CalculatePaymentModeSums(record IVVc IVr,vector val vpaymodesums)
begin
  row IVVc IVrw;
  Integer i,rwcnt;
  val t;
  
  if (IVr.InvType==kInvoiceTypeCredit) then begin
    vpaymodesums[kInvoiceRowTypeCashPayment] = IVr.BaseSum4;
  end else begin
    vpaymodesums[kInvoiceRowTypeCreditCardPayment] = 0.00;
    vpaymodesums[kInvoiceRowTypeCashPayment] = 0.00;
    rwcnt = MatRowCnt(IVr);
    for (i=0;i<rwcnt;i=i+1) begin
      MatRowGet(IVr,i,IVrw);
      switch (IVrw.stp) begin
  //      case kInvoiceRowTypeGiftVoucherPayment:
        case kInvoiceRowTypeCreditCardPayment:
          vpaymodesums[kInvoiceRowTypeCreditCardPayment] = vpaymodesums[kInvoiceRowTypeCreditCardPayment] + MulRateToBase1(IVrw.CurncyCode,IVrw.Sum,IVrw.FrRate,IVrw.ToRateB1,IVrw.ToRateB2,IVrw.BaseRate1,IVrw.BaseRate2,DefaultCurRoundOff);
  //      case kInvoiceRowTypeLoyaltyPointsPayment:
        case kInvoiceRowTypeCashPayment:
          vpaymodesums[kInvoiceRowTypeCashPayment] = vpaymodesums[kInvoiceRowTypeCashPayment] + MulRateToBase1(IVrw.CurncyCode,IVrw.Sum,IVrw.FrRate,IVrw.ToRateB1,IVrw.ToRateB2,IVrw.BaseRate1,IVrw.BaseRate2,DefaultCurRoundOff);
  //      case kInvoiceRowTypeChequePayment:
      end;
    end;
    switch (IVr.InvType) begin
      case kInvoiceTypeCreditSpecialSales: goto LkInvoiceTypeCredit;
      case kInvoiceTypeCredit:
  LkInvoiceTypeCredit:;
        t = IVr.BaseSum4 - vpaymodesums[kInvoiceRowTypeCashPayment] - vpaymodesums[kInvoiceRowTypeCreditCardPayment];
        if (t>0) then begin
          vpaymodesums[kInvoiceRowTypeCashPayment] = vpaymodesums[kInvoiceRowTypeCashPayment] + t;  
        end;
      otherwise
        t = IVr.BaseSum4 - vpaymodesums[kInvoiceRowTypeCashPayment] - vpaymodesums[kInvoiceRowTypeCreditCardPayment];
        if (t>0) then begin
          vpaymodesums[kInvoiceRowTypeCashPayment] = vpaymodesums[kInvoiceRowTypeCashPayment] + t;  
        end;
    end;
  end;
  return;
end;

function Integer EndFiscalReceipt(var Integer seqnr,string operator,record IVVc IVr)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  vector val vpaymodesums;

  CalculatePaymentModeSums(IVr,vpaymodesums);

  if (vpaymodesums[kInvoiceRowTypeCreditCardPayment]!=0) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "084";
    CtrlSeq = CtrlSeq & operator;
    M4PadString("Cash",32," ",false,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    tstr = ValToString(AbsoluteVal(vpaymodesums[kInvoiceRowTypeCreditCardPayment]*100),M40Val,"","",1);
    M4PadString(tstr,9,"0",true,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "2";
    CtrlSeq = CtrlSeq & "06";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_LONGDELAY);
    if (res!=noErr) then begin
      res = 19389;
      goto LEndFiscalReceipt;
    end;
  end;
  if (vpaymodesums[kInvoiceRowTypeCashPayment]!=0) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "084";
    CtrlSeq = CtrlSeq & operator;
    M4PadString("Cash",32," ",false,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    tstr = ValToString(AbsoluteVal(vpaymodesums[kInvoiceRowTypeCashPayment]*100),M40Val,"","",1);
    M4PadString(tstr,9,"0",true,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "01";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_LONGDELAY);
    if (res!=noErr) then begin
      res = 19389;
      goto LEndFiscalReceipt;
    end;
  end;
LEndFiscalReceipt:;
  EndFiscalReceipt = res;
  return;
end;

function Integer PrintReturnLine(var Integer seqnr,string operator,string OrgIVNr)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "078";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "00";
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & "1";
  tstr = USetStr(41013) & ": " & OrgIVNr;
  M4PadString(tstr,32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);  
  PrintReturnLine = res;
  return;
end;

function Integer DiscountAdditionForItem(var Integer seqnr,string operator,record IVVc IVr,row IVVc IVrw)
begin
  Integer res;
  string 255 CtrlSeq,tstr;
  string 255 unit;
  val v;
  
  unit = IVrw.UnitCode;
  if (blank(unit)) then begin
    unit = "PZ";
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "083";
  CtrlSeq = CtrlSeq & operator;
  tstr = ValToString(IVrw.vRebate,M41Val,"",".",0);
  M4PadString(USetStr(1870) & " " & tstr & "%",32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;  
  v = (IVrw.Quant*IVrw.Price-IVrw.Sum);
  tstr = ValToString(v*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);
  CtrlSeq = CtrlSeq & tstr;  
  CtrlSeq = CtrlSeq & "0";  
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & "1";  
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);  

  DiscountAdditionForItem = res;
  return;
end;

function Integer PrintItemRow(var Integer seqnr,string operator,record IVVc IVr,row IVVc IVrw,vector val vatrates)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  string 255 unit;
  Boolean negtivef;
  
  if (IVrw.Quant<0) then begin
    negtivef = true;
    IVrw.Quant = -IVrw.Quant;
  end;
  negtivef = negtivef or IVr.InvType==kInvoiceTypeCredit;
  unit = IVrw.UnitCode;
  if (blank(unit)) then begin
    unit = "PZ";
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  if (negtivef) then begin
    CtrlSeq = CtrlSeq & "081";
  end else begin
    CtrlSeq = CtrlSeq & "080";
  end;
  tstr = StringToInt(operator) + 50;
  CtrlSeq = CtrlSeq & tstr;
  M4PadString(IVrw.Spec,32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  tstr = ValToString(IVrw.Quant*1000,M40Val,"","",0);
  M4PadString(tstr,7,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  tstr = ValToString(IVrw.Price*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);  
  if (res==noErr) then begin
    if (IVrw.vRebate!=0) then begin
      res = DiscountAdditionForItem(seqnr,operator,IVr,IVrw);
    end;
  end;
  PrintItemRow = res;
  return;
end;

function Integer PrintRecReturn(var Integer seqnr,string operator,record IVVc IVr,row IVVc IVrw,vector val vatrates)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  string 255 unit;
  
  unit = IVrw.UnitCode;
  if (blank(unit)) then begin
    unit = "PCS";
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "082";
  tstr = StringToInt(operator) + 50;
  CtrlSeq = CtrlSeq & tstr;
  M4PadString(IVrw.Spec,32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  tstr = ValToString(IVrw.Quant*1000,M40Val,"","",0);
  M4PadString(tstr,7,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  tstr = ValToString(IVrw.Price*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);  
  PrintRecReturn = res;
  return;
end;

function Integer PrintCommentLine(var Integer seqnr,string operator,record IVVc IVr,row IVVc IVrw)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "078";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "00";
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & "1";
  M4PadString(IVrw.Spec,32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);  
  PrintCommentLine = res;
  return;
end;

function Integer PrintItemRows(var Integer seqnr,string operator,record IVVc IVr,vector val vatrates)
begin
  INteger res,noErr;
  row IVVc IVrw;
  Integer i,rwcnt;

  rwcnt = MatRowCnt(IVr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(IVr,i,IVrw);    
    switch (IVrw.stp) begin
      case kInvoiceRowTypeStructuredItemComponent:
        goto LkInvoiceRowTypeNormal1;
      case kInvoiceRowTypeNormal:
LkInvoiceRowTypeNormal1:;
        if (nonblank(IVrw.ArtCode)) then begin
          res = PrintItemRow(seqnr,operator,IVr,IVrw,vatrates);
          if (res!=noErr) then begin
            goto LPrintItemRows;
          end;
        end else begin
          res = PrintCommentLine(seqnr,operator,IVr,IVrw);
          if (res!=noErr) then begin
            goto LPrintItemRows;
          end;
        end;
      case kInvoiceRowTypeCredit:
        res = PrintReturnLine(seqnr,operator,IVrw.OrdRow);
        if (res!=noErr) then begin
          goto LPrintItemRows;
        end;
      case kInvoiceRowTypeVoid:
    end;
  end;
LPrintItemRows:;  
  PrintItemRows = res;
  return;
end;

global
updating procedure PrintEPSON81IIReceipt_IVVc(var record IVVc aIVr,record LSerialPortDeviceVc LSPDr)
begin
  record IVVc IVr;
  record IVVc oldIVr;
  Integer noErr,res;
  record LocalMachineBlock LMb;
  record MachineCashVc MCr;
  vector val vatrates;
  Integer seqnr;
  string 255 operator;
  
  noErr = 0;
  res = EPSON81IIOpen(LSPDr);

  if (res==noErr) then begin
    noErr = 0;
    BlockLoad(LMb);
    
//    operator = IVr.POSOperatorID;
    if (blank(operator)) then begin
      operator = "01";
    end;
    
    res = CheckEPSON81IIClock(seqnr);
    if (res!=noErr) then begin
      goto LPrintEPSON81IIReceipt;
    end;
    res = LoadEPSON81IIVATRates(seqnr,vatrates);
    if (res!=noErr) then begin
      goto LPrintEPSON81IIReceipt;
    end;
    if (aIVr.InvType==kInvoiceTypeCredit) then begin
//      res = BeginFiscalCreditNote(seqnr,aIVr.SerNr);
    end else begin
      res = BeginFiscalReceipt(seqnr,operator,aIVr.RegNr1);
    end;
    if (res!=noErr) then begin
      goto LPrintEPSON81IIReceipt;
    end;
    res = PrintItemRows(seqnr,operator,aIVr,vatrates);
    if (res!=noErr) then begin
      goto LPrintEPSON81IIReceipt;
    end;
    res = EndFiscalReceipt(seqnr,operator,aIVr);
    if (res!=noErr) then begin
      goto LPrintEPSON81IIReceipt;
    end;
    IVr.SerNr = aIVr.SerNr;
    if (ReadFirstMain(IVr,1,true)) then begin
      if (IVr.Prntdf==0) then begin
        RecordCopy(oldIVr,IVr);
        IVr.Prntdf = 1;
        RecordUpdate(oldIVr,IVr,false);
        RecordCopy(aIVr,IVr);
      end;
    end;    
LPrintEPSON81IIReceipt:;
    DisplayText(seqnr,"",0,USetStr(27522));
    EPSON81IIClose;
    if (res!=0) then begin
      MessageBox(res,"");
    end;
  end;
  return;
end;

procedure IVCash_CalculatePaymentModeSums(record IVCashVc IVCr,vector val vpaymodesums)
begin
  row IVCashVc IVCrw;
  Integer i,rwcnt;
  val t;
  row PMBlock PMrw;
  
  vpaymodesums[kInvoiceRowTypeCreditCardPayment] = 0.00;
  vpaymodesums[kInvoiceRowTypeCashPayment] = 0.00;
  if (IVCr.InvType==kPOSInvoiceTypeCredit) then begin
    vpaymodesums[kInvoiceRowTypeCashPayment] = IVCr.BaseSum4;
  end else begin
    rwcnt = MatRowCnt(IVCr);
    for (i=0;i<rwcnt;i=i+1) begin
      MatRowGet(IVCr,i,IVCrw);
      switch (IVCrw.stp) begin
        case kInvoiceRowTypeCreditCardPayment:
          vpaymodesums[kInvoiceRowTypeCreditCardPayment] = vpaymodesums[kInvoiceRowTypeCreditCardPayment] + MulRateToBase1(IVCrw.CurncyCode,IVCrw.Sum,IVCrw.FrRate,IVCrw.ToRateB1,IVCrw.ToRateB2,IVCrw.BaseRate1,IVCrw.BaseRate2,DefaultCurRoundOff);
        case kInvoiceRowTypeCashPayment:
          vpaymodesums[kInvoiceRowTypeCashPayment] = vpaymodesums[kInvoiceRowTypeCashPayment] + MulRateToBase1(IVCrw.CurncyCode,IVCrw.Sum,IVCrw.FrRate,IVCrw.ToRateB1,IVCrw.ToRateB2,IVCrw.BaseRate1,IVCrw.BaseRate2,DefaultCurRoundOff);
      end;
    end;

    vpaymodesums[kInvoiceRowTypeCashPayment] = vpaymodesums[kInvoiceRowTypeCashPayment] + IVCr.CashValue;  

    if (IVCr.RecValue!=0) then begin
      GetPMRow(IVCr.PayDeal,PMrw);
      switch (PMrw.CheckType) begin
        case kPayModeTypeCreditCard:
          vpaymodesums[kInvoiceRowTypeCreditCardPayment] = vpaymodesums[kInvoiceRowTypeCreditCardPayment] + IVCr.RecValue;  
        otherwise
          vpaymodesums[kInvoiceRowTypeCashPayment] = vpaymodesums[kInvoiceRowTypeCashPayment] + IVCr.RecValue;  
      end;
    end;
    if (IVCr.RecValue2!=0) then begin
      GetPMRow(IVCr.PayDeal2,PMrw);
      switch (PMrw.CheckType) begin
        case kPayModeTypeCreditCard:
          vpaymodesums[kInvoiceRowTypeCreditCardPayment] = vpaymodesums[kInvoiceRowTypeCreditCardPayment] + IVCr.RecValue2;  
        otherwise
          vpaymodesums[kInvoiceRowTypeCashPayment] = vpaymodesums[kInvoiceRowTypeCashPayment] + IVCr.RecValue2;  
      end;
    end;
  end;
  return;
end;

function Integer IVCash_EndFiscalReceipt(var Integer seqnr,string operator,record IVCashVc IVCr)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  vector val vpaymodesums;


  IVCash_CalculatePaymentModeSums(IVCr,vpaymodesums);
    
  if (vpaymodesums[kInvoiceRowTypeCreditCardPayment]!=0) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "084";
    CtrlSeq = CtrlSeq & operator;
    M4PadString(USetStr(20801),32," ",false,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    tstr = ValToString(AbsoluteVal(vpaymodesums[kInvoiceRowTypeCreditCardPayment]*100),M40Val,"","",1);
    M4PadString(tstr,9,"0",true,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "2";
    CtrlSeq = CtrlSeq & "06";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_LONGDELAY);
    if (res!=noErr) then begin
      res = 19389;
      goto LIVCash_EndFiscalReceipt;
    end;
  end;

  if (vpaymodesums[kInvoiceRowTypeCashPayment]!=0) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "084";
    CtrlSeq = CtrlSeq & operator;
    M4PadString(USetStr(20800),32," ",false,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    tstr = ValToString(AbsoluteVal(vpaymodesums[kInvoiceRowTypeCashPayment]*100),M40Val,"","",1);
    M4PadString(tstr,9,"0",true,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "01";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_LONGDELAY);
    if (res!=noErr) then begin
      res = 19389;
      goto LIVCash_EndFiscalReceipt;
    end;
  end;

LIVCash_EndFiscalReceipt:;
  IVCash_EndFiscalReceipt = res;
  return;
end;

function Integer IVCash_DiscountAdditionForItem(var Integer seqnr,string operator,record IVCashVc IVCr,row IVCashVc IVCrw)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  string 255 unit;
  val v,p;
  
  CalcSum(IVCrw.Quant,IVCrw.Price,IVCrw.PriceFactor,0,v,0);
  v = v - FormulaDiscountCalcSum(IVCrw.Quant,IVCrw.Price,IVCrw.PriceFactor,IVCrw.vRebate);  
  p = CalculateDiscountPercentage(IVCrw.Quant,IVCrw.Price,IVCrw.Sum);

  unit = IVCrw.UnitCode;
  if (blank(unit)) then begin
    unit = "PCS";
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "083";
  CtrlSeq = CtrlSeq & operator;
  tstr = ValToString(p,M41Val,"",".",0);
  M4PadString(USetStr(1870) & " " & tstr & "%",32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;

  tstr = ValToString(v*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);
  CtrlSeq = CtrlSeq & tstr;  
  CtrlSeq = CtrlSeq & "0";  
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & "1";  
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);  

  IVCash_DiscountAdditionForItem = res;
  return;
end;

function Integer IVCash_PrintCommentLine(var Integer seqnr,string operator,record IVCashVc IVCr,row IVCashVc IVCrw)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "078";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "00";
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & "1";
  M4PadString(IVCrw.Spec,32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);  
  IVCash_PrintCommentLine = res;
  return;
end;

function Integer IVCash_PrintItemRow(var Integer seqnr,string operator,Integer typ,record IVCashVc IVCr,row IVCashVc IVCrw,vector val vatrates)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  string 255 unit;
  Boolean negtivef;
  record INVc INr;
  
  ReadFirstItem(IVCrw.ArtCode,INr,false,true);
  if (IVCrw.Quant<0) then begin
    negtivef = true;
    IVCrw.Quant = -IVCrw.Quant;
  end;
  negtivef = negtivef or IVCr.InvType==kPOSInvoiceTypeCredit;
  unit = IVCrw.UnitCode;
  if (blank(unit)) then begin
    unit = "PCS";
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  if (negtivef) then begin
    CtrlSeq = CtrlSeq & "081";
  end else begin
    CtrlSeq = CtrlSeq & "080";
  end;
  tstr = StringToInt(operator) + 50;
  CtrlSeq = CtrlSeq & tstr;
  M4PadString(IVCrw.Spec,32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  tstr = ValToString(IVCrw.Quant*1000,M40Val,"","",0);
  M4PadString(tstr,7,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  tstr = ValToString(IVCrw.Price*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & FindFiscalDepartment(INr);
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);  
  
  if (res==noErr) then begin
    if (nonblank(IVCrw.SerialNr)) then begin
      IVCrw.Spec = UsetStr(1141) & IVCrw.SerialNr;
      res = IVCash_PrintCommentLine(seqnr,operator,IVCr,IVCrw);
    end;
  end;


  if (res==noErr) then begin
    if (nonblank(IVCrw.vRebate)) then begin
      res = IVCash_DiscountAdditionForItem(seqnr,operator,IVCr,IVCrw);
    end;
  end;
  IVCash_PrintItemRow = res;
  return;
end;

function Integer IVCash_PrintRecReturn(var Integer seqnr,string operator,record IVCashVc IVCr,row IVCashVc IVCrw,vector val vatrates)
begin
   INteger res,noErr;
  string 255 CtrlSeq,tstr;
  string 255 unit;
  
  unit = IVCrw.UnitCode;
  if (blank(unit)) then begin
    unit = "PCS";
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "082";
  tstr = StringToInt(operator) + 50;
  CtrlSeq = CtrlSeq & tstr;
  M4PadString(IVCrw.Spec,32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  tstr = ValToString(IVCrw.Quant*1000,M40Val,"","",0);
  M4PadString(tstr,7,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  tstr = ValToString(IVCrw.Price*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);  
  IVCash_PrintRecReturn = res;
  return;
end;

function Integer IVCash_PrintItemRows(var Integer seqnr,string operator,Integer typ,record IVCashVc IVCr,vector val vatrates)
begin
  INteger res,noErr;
  row IVCashVc IVCrw;
  Integer i,rwcnt;

  rwcnt = MatRowCnt(IVCr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(IVCr,i,IVCrw);
    switch (IVCrw.stp) begin
      case kInvoiceRowTypeStructuredItemComponent:
        goto LkInvoiceRowTypeNormal2_B;
      case kInvoiceRowTypeNormal:
LkInvoiceRowTypeNormal2_B:;
        if (nonblank(IVCrw.ArtCode)) then begin
          res = IVCash_PrintItemRow(seqnr,operator,typ,IVCr,IVCrw,vatrates);
          if (res!=noErr) then begin
            goto LPrintItemRows;
          end;
        end else begin
          res = IVCash_PrintCommentLine(seqnr,operator,IVCr,IVCrw);
          if (res!=noErr) then begin
            goto LPrintItemRows;
          end;
        end;
      case kInvoiceRowTypeReturnIVNr:
        res = PrintReturnLine(seqnr,operator,IVCrw.OrgIVNr);
        if (res!=noErr) then begin
          goto LPrintItemRows;
        end;
      case kInvoiceRowTypeVoid:
    end;
  end;
LPrintItemRows:;  
  IVCash_PrintItemRows = res;
  return;
end;

global
updating procedure PrintEPSON81IIReceipt_IVCashVc(var record IVCashVc IVCr,record LSerialPortDeviceVc LSPDr)
begin
  record IVCashVc oldIVCr;
  Integer noErr,res;
  record LocalMachineBlock LMb;
  record MachineCashVc MCr;
  vector val vatrates;
  Integer seqnr;
  string 255 operator;
  
  noErr = 0;
  res = EPSON81IIOpen(LSPDr);

  if (res==noErr) then begin
    noErr = 0;
    BlockLoad(LMb);
    
    operator = IVCr.POSOperatorID;
    if (blank(operator)) then begin
      operator = "01";
    end;
    
    res = Send_InconsequentialMessages(seqnr,operator);
    if (res!=noErr) then begin
      goto LPrintEPSON81IIReceipt_IVCashVc;
    end;
    
    MCr.Code = IVCr.LocalMachineCode;
    ReadFirstMain(MCr,1,true);

    res = CheckEPSON81IIClock(seqnr);
    if (res!=noErr) then begin
      goto LPrintEPSON81IIReceipt_IVCashVc;
    end;

    if (blank(IVCr.VATNr)) then begin
      if (IVCr.InvType==kPOSInvoiceTypeCredit) then begin
//        res = BeginFiscalCreditNote(seqnr,IVCr.SerNr);
//not allowed in Italy
      end else begin
        res = BeginFiscalReceipt(seqnr,operator,IVCr.RegNr1);
      end;
      if (res!=noErr) then begin 
        goto LPrintEPSON81IIReceipt_IVCashVc; 
      end;
      res = IVCash_PrintItemRows(seqnr,operator,0,IVCr,vatrates);
      if (res!=noErr) then begin
        goto LPrintEPSON81IIReceipt_IVCashVc;
      end;
      res = IVCash_EndFiscalReceipt(seqnr,operator,IVCr);
      if (res!=noErr) then begin
        goto LPrintEPSON81IIReceipt_IVCashVc;
      end;
    end else begin

//      res = LoadEPSON81IIVATRates(seqnr,vatrates);
//      if (res!=noErr) then begin
//        goto LPrintEPSON81IIReceipt_IVCashVc;
//      end;

//GetEPSON81IIInvoiceParametres(seqnr);


      if (IVCr.InvType==kPOSInvoiceTypeCredit) then begin
//        res = BeginFiscalCreditNote(seqnr,IVCr.SerNr);
//not allowed in Italy
      end else begin
        res = BeginFiscalInvoice(seqnr,operator,IVCr.OfficialSerNr,MatRowCnt(IVCr),MCr,IVCr.VATNr,IVCr.Addr0,IVCr.Addr1,IVCr.Addr2,IVCr.Addr3,IVCr.InvAddr3);
      end;
      if (res!=noErr) then begin 
        goto LPrintEPSON81IIReceipt_IVCashVc; 
      end;

      res = IVCash_PrintFiscalInvoiceItemRows(seqnr,operator,1,IVCr,vatrates);
      if (res!=noErr) then begin
        goto LPrintEPSON81IIReceipt_IVCashVc;
      end;
      res = IVCash_EndFiscalReceipt(seqnr,operator,IVCr);
      if (res!=noErr) then begin
        goto LPrintEPSON81IIReceipt_IVCashVc;
      end;

    end;
    
    
    if (IVCr.Prntdf!=0) then begin
      RecordCopy(oldIVCr,IVCr);
      IVCr.Prntdf = 1;
      RecordUpdate(oldIVCr,IVCr,false);
    end;    

LPrintEPSON81IIReceipt_IVCashVc:;
    DisplayText(seqnr,"",0,USetStr(27522));
    EPSON81IIClose;
    if (res!=0) then begin
      MessageBox(res,"");
    end;
  end;
  return;
end;

global
procedure PrintEPSON81IIFiscalInvoice_IVCashVc(var record IVCashVc IVCr,record LSerialPortDeviceVc LSPDr)
begin
  string 255 host,codepage,operator;
  LongInt port;
  LongInt pos;
  Integer seqnr,noErr;
  Integer res;
  string 255 tstr,CtrlSeq;
  string 255 serie,sernr;
  row LegalInvNrBlock LINrbrw;

  seqnr = 0;
  noErr = 0;
  if (EPSON81IIOpen(LSPDr)) then begin

    operator = IVCr.POSOperatorID;
    if (blank(operator)) then begin
      operator = "01";
    end;

    res = Send_InconsequentialMessages(seqnr,operator);
    if (res!=noErr) then begin
      goto LPrintEPSON81IIFiscalInvoice_IVCashVc;
    end;

    GetLegalInvNrRow(IVCr.OfficialSerNr,LINrbrw);
    serie = GetLegalInvoiceNrSerie(LINrbrw,IVCr.OfficialSerNr);
    sernr = GetLegalInvoiceNrString(LINrbrw,IVCr.OfficialSerNr);
    if (nonblank(IVCr.Addr0)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "078";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "6";
      CtrlSeq = CtrlSeq & "01";
      CtrlSeq = CtrlSeq & "0";
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.Addr0,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IIFiscalInvoice_IVCashVc;
      end;
    end;
    if (nonblank(IVCr.Addr1)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "078";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "6";
      CtrlSeq = CtrlSeq & "02";
      CtrlSeq = CtrlSeq & "0";
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.Addr1,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IIFiscalInvoice_IVCashVc;
      end;
    end;
    if (nonblank(IVCr.Addr2)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "078";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "6";
      CtrlSeq = CtrlSeq & "03";
      CtrlSeq = CtrlSeq & "0";
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.Addr2,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IIFiscalInvoice_IVCashVc;
      end;
    end;
    if (nonblank(IVCr.Addr3)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "078";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "6";
      CtrlSeq = CtrlSeq & "03";
      CtrlSeq = CtrlSeq & "0";
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.Addr3,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IIFiscalInvoice_IVCashVc;
      end;
    end;
    if (nonblank(IVCr.InvAddr3)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "078";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "6";
      CtrlSeq = CtrlSeq & "03";
      CtrlSeq = CtrlSeq & "0";
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.InvAddr3,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IIFiscalInvoice_IVCashVc;
      end;
    end;

    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "052";
    CtrlSeq = CtrlSeq & operator;
    M4PadString(sernr,4,"0",true,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);

    if (res!=noErr) then begin
      res = 19389;
      goto LPrintEPSON81IIFiscalInvoice_IVCashVc;
    end;
LPrintEPSON81IIFiscalInvoice_IVCashVc:;  
    ResetFiscal(seqnr,operator);
  end;
  EPSON81IIClose;
  return;
end;

function Integer IVCash_PrintCourtesyReceiptItemRow(var Integer seqnr,string operator,record IVCashVc IVCr,row IVCashVc IVCrw)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr,t2;
  string 255 unit;
  Boolean negtivef;
  record INVc INr;
  
  ReadFirstItem(IVCrw.ArtCode,INr,false,true);
  if (IVCrw.Quant<0) then begin
    negtivef = true;
    IVCrw.Quant = -IVCrw.Quant;
  end;
  negtivef = negtivef or IVCr.InvType==kPOSInvoiceTypeCredit;
  unit = IVCrw.UnitCode;
  if (blank(unit)) then begin
    unit = "PCS";
  end;
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "064";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "1";
  M4PadString(IVCrw.Spec,20," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  tstr = ValToString(IVCrw.Quant,M4Val,"",".",0);
  M4PadString(tstr,7," ",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LIVCash_PrintCourtesyReceiptItemRow;
  end;
    
LIVCash_PrintCourtesyReceiptItemRow:;  
  IVCash_PrintCourtesyReceiptItemRow = res;
  return;
end;

function Integer IVCash_PrintCourtesyReceiptCommentLine(var Integer seqnr,string operator,record IVCashVc IVCr,row IVCashVc IVCrw)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "064";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "1";
  M4PadString(IVCrw.Spec,32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  IVCash_PrintCourtesyReceiptCommentLine = res;
  return;
end;

function Integer IVCash_PrintCourtesyReceiptItemRows(var Integer seqnr,string operator,record IVCashVc IVCr)
begin
  INteger res,noErr;
  row IVCashVc IVCrw;
  Integer i,rwcnt;

  rwcnt = MatRowCnt(IVCr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(IVCr,i,IVCrw);
    switch (IVCrw.stp) begin
      case kInvoiceRowTypeStructuredItemComponent:
        goto LkInvoiceRowTypeNormal3;
      case kInvoiceRowTypeNormal:
LkInvoiceRowTypeNormal3:;
        if (nonblank(IVCrw.ArtCode)) then begin
          res = IVCash_PrintCourtesyReceiptItemRow(seqnr,operator,IVCr,IVCrw);
          if (res!=noErr) then begin
            goto LIVCash_PrintCourtesyReceiptItemRows;
          end;
        end else begin
          res = IVCash_PrintCourtesyReceiptCommentLine(seqnr,operator,IVCr,IVCrw);
          if (res!=noErr) then begin
            goto LIVCash_PrintCourtesyReceiptItemRows;
          end;
        end;
      case kInvoiceRowTypeReturnIVNr:
/*
        res = PrintReturnLine(seqnr,IVCrw.OrgIVNr);
        if (res!=noErr) then begin
          goto LIVCash_PrintCourtesyReceiptItemRows;
        end;
*/        
      case kInvoiceRowTypeVoid:
    end;
  end;
LIVCash_PrintCourtesyReceiptItemRows:;  
  IVCash_PrintCourtesyReceiptItemRows = res;
  return;
end;

global
procedure PrintEPSON81IICourtesyReceipt_IVCashVc(var record IVCashVc IVCr,record LSerialPortDeviceVc LSPDr)
begin
  string 255 host,codepage,barcode;
  LongInt port;
  LongInt pos;
  Integer seqnr,noErr;
  Integer res;
  string 255 tstr,CtrlSeq,operator;
  string 255 serie,sernr;
  row LegalInvNrBlock LINrbrw;

  seqnr = 0;
  noErr = 0;

  res = EPSON81IIOpen(LSPDr);
  if (res!=noErr) then begin
    goto LPrintEPSON81IICourtesyReceipt_IVCashVc;
  end;

  GetLegalInvNrRow(IVCr.OfficialSerNr,LINrbrw);
  serie = GetLegalInvoiceNrSerie(LINrbrw,IVCr.OfficialSerNr);
  sernr = GetLegalInvoiceNrString(LINrbrw,IVCr.OfficialSerNr);
  
  operator = IVCr.POSOperatorID;
  if (blank(operator)) then begin
    operator = "01";
  end;

  res = Send_InconsequentialMessages(seqnr,operator);
  if (res!=noErr) then begin
    goto LPrintEPSON81IICourtesyReceipt_IVCashVc;
  end;
  
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "063";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LPrintEPSON81IICourtesyReceipt_IVCashVc;
  end;

  if (nonblank(IVCr.Addr0)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "064";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "1";
    M4PadString(IVCr.Addr0,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LPrintEPSON81IICourtesyReceipt_IVCashVc;
    end;
  end;
  if (nonblank(IVCr.Addr1)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "064";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "1";
    M4PadString(IVCr.Addr1,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LPrintEPSON81IICourtesyReceipt_IVCashVc;
    end;
  end;
  if (nonblank(IVCr.Addr2)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "064";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "1";
    M4PadString(IVCr.Addr2,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LPrintEPSON81IICourtesyReceipt_IVCashVc;
    end;
  end;
  if (nonblank(IVCr.Addr3)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "064";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "1";
    M4PadString(IVCr.Addr3,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LPrintEPSON81IICourtesyReceipt_IVCashVc;
    end;
  end;
  if (nonblank(IVCr.InvAddr3)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "064";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "1";
    M4PadString(IVCr.InvAddr3,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LPrintEPSON81IICourtesyReceipt_IVCashVc;
    end;
  end;
  if (nonblank(IVCr.InvAddr4)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "064";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "1";
    M4PadString(IVCr.InvAddr4,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LPrintEPSON81IICourtesyReceipt_IVCashVc;
    end;
  end;

  res = IVCash_PrintCourtesyReceiptItemRows(seqnr,operator,IVCr);
  if (res!=0) then begin
    goto LPrintEPSON81IICourtesyReceipt_IVCashVc;
  end;

  barcode = IVCr.SerNr & " " & DateToString(IVCr.TransDate,"YYYY/MM/DD");
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "075";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "001";
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & "008";
  CtrlSeq = CtrlSeq & "2";
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & "NU";
  CtrlSeq = CtrlSeq & "91";
  CtrlSeq = CtrlSeq & barcode;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LPrintEPSON81IICourtesyReceipt_IVCashVc;
  end;

  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "065";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LPrintEPSON81IICourtesyReceipt_IVCashVc;
  end;


LPrintEPSON81IICourtesyReceipt_IVCashVc:;  
  EPSON81IIClose;
  return;
end;

function Integer MoneyOutCurr(record CashVc Cashr)
begin
  Integer res,noErr,seqnr;
  string 255 CtrlSeq,tstr;
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "032";
  tstr = ValToString(Cashr.Total*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,"01",CtrlSeq,EPSON81II_DELAY);  
  MoneyOutCurr = res;
  return;
end;

function Integer MoneyInCurr(record CashVc Cashr)
begin
  Integer res,noErr,seqnr;
  string 255 CtrlSeq,tstr;
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "031";
  tstr = ValToString(Cashr.Total*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,"01",CtrlSeq,EPSON81II_DELAY);  
  MoneyInCurr = res;
  return;
end;

global
procedure PrintEPSON81IICashEvent(var record CashVc Cashr,record LSerialPortDeviceVc LSPDr)
begin
  Integer noErr,res;
  Integer seqnr;
  
  noErr = 0;
  res = EPSON81IIOpen(LSPDr);
  if (res==noErr) then begin    
    res = Send_InconsequentialMessages(seqnr,"01");
    
    res = CheckEPSON81IIClock(seqnr);
    if (res!=noErr) then begin
      goto LPrintEPSON81IICashEvent;
    end;
    switch (Cashr.Event) begin
      case 0:
        MoneyOutCurr(Cashr);
      case 1:
        MoneyInCurr(Cashr);
    end;
LPrintEPSON81IICashEvent:;
    EPSON81IIClose;
    if (res!=0) then begin
      MessageBox(res,"");
    end;
  end;
  return;
end;

global
procedure EPSON81IIDailyReport(record LSerialPortDeviceVc LSPDr)
begin
  Integer res,noErr,seqnr;
  string 255 CtrlSeq; 

  res = EPSON81IIOpen(LSPDr);
  if (res!=noErr) then begin
    goto LEPSON81IIDailyReport;
  end;

  res = Send_InconsequentialMessages(seqnr,"01");
  
  CtrlSeq = CtrlSeq & SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "3";
  CtrlSeq = CtrlSeq & "001";
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

  res = EPSON81IIWrite(seqnr,"01",CtrlSeq,EPSON81II_DELAY);

  EPSON81IIClose;

  if (res!=0) then begin
    MessageBox(res,"");
  end;

LEPSON81IIDailyReport:;  
  return;
end;

global
procedure EPSON81IIMonthlyReport(record LSerialPortDeviceVc LSPDr)
begin
  Integer res,noErr,seqnr;
  string 255 CtrlSeq; 
  Date sd,ed;

  res = EPSON81IIOpen(LSPDr);
  if (res!=noErr) then begin
    goto LEPSON81IIMonthlyReport;
  end;
  
  res = Send_InconsequentialMessages(seqnr,"01");
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "3";
  CtrlSeq = CtrlSeq & "013";
  sd = CurrentDate;
  sd.day = 1;
  ed = CurrentDate;
  ed.day = DaysInMonth(ed.year,ed.month);
  CtrlSeq = CtrlSeq & DateToString(sd,"DDMMYY");
  CtrlSeq = CtrlSeq & DateToString(ed,"DDMMYY");
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

  res = EPSON81IIWrite(seqnr,"01",CtrlSeq,EPSON81II_DELAY);


  EPSON81IIClose;
  if (res!=0) then begin
    MessageBox(res,"");
  end;
LEPSON81IIMonthlyReport:;  
  return;
end;

