begin
  Integer res,noErr;
  string 255 CtrlSeq,response; 
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "074";
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  
  res = EPSON81IIWriteAndGetResponse(seqnr,"01",CtrlSeq,EPSON81II_DELAY,response);
  GetEPSON81IIStatus = res;
  return;
end;

