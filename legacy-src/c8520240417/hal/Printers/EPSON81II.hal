function Integer TCPIPPrintReturnLine(string host,LongInt port,string codepage,var Integer seqnr,string operator,string OrgIVNr)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "078";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "00";
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & "1";
  tstr = USetStr(41013) & ": " & OrgIVNr;
  M4PadString(tstr,32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  TCPIPPrintReturnLine = res;
  return;
end;

function Integer IVCash_TCPIPPrintItemRows(string host,LongInt port,string codepage,var Integer seqnr,string operator,Integer typ,record IVCashVc IVCr,vector val vatrates)
begin
  INteger res,noErr;
  row IVCashVc IVCrw;
  Integer i,rwcnt;

  rwcnt = MatRowCnt(IVCr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(IVCr,i,IVCrw);
    switch (IVCrw.stp) begin
      case kInvoiceRowTypeStructuredItemComponent:
        goto LkInvoiceRowTypeNormal2_C;
      case kInvoiceRowTypeNormal:
LkInvoiceRowTypeNormal2_C:;
        if (nonblank(IVCrw.ArtCode)) then begin
          res = IVCash_TCPIPPrintItemRow(host,port,codepage,seqnr,operator,typ,IVCr,IVCrw,vatrates);
          if (res!=noErr) then begin
            goto LIVCash_TCPIPPrintItemRows;
          end;
        end else begin
          res = IVCash_TCPIPPrintCommentLine(host,port,codepage,seqnr,operator,IVCr,IVCrw);
          if (res!=noErr) then begin
            goto LIVCash_TCPIPPrintItemRows;
          end;
        end;
      case kInvoiceRowTypeReturnIVNr:
        res = TCPIPPrintReturnLine(host,port,codepage,seqnr,operator,IVCrw.OrgIVNr);
        if (res!=noErr) then begin
          goto LIVCash_TCPIPPrintItemRows;
        end;
      case kInvoiceRowTypeVoid:
/*        
        just skip 
        res = IVCash_TCPIPPrintRecReturn(seqnr,IVCr,IVCrw,vatrates);
        if (res!=noErr) then begin
          goto LIVCash_TCPIPPrintItemRows;
        end;
*/        
    end;
  end;
LIVCash_TCPIPPrintItemRows:;  
  IVCash_TCPIPPrintItemRows = res;
  return;
end;

function Integer IVCash_TCPIPInvoiceDiscountAdditionForItem(string host,LongInt port,string codepage,var Integer seqnr,string operator,record IVCashVc IVCr,row IVCashVc IVCrw)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  string 255 unit;
  val v,p;
  
  CalcSum(IVCrw.Quant,IVCrw.Price,IVCrw.PriceFactor,0,v,0);
  v = v - FormulaDiscountCalcSum(IVCrw.Quant,IVCrw.Price,IVCrw.PriceFactor,IVCrw.vRebate);  
  p = CalculateDiscountPercentage(IVCrw.Quant,IVCrw.Price,IVCrw.Sum);

  unit = IVCrw.UnitCode;
  if (blank(unit)) then begin
    unit = "PCS";
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "023";
  CtrlSeq = CtrlSeq & operator;
  tstr = ValToString(p*100,M40Val,"","",0);
  M4PadString(tstr,4,"0",true,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);

  IVCash_TCPIPInvoiceDiscountAdditionForItem = res;
  return;
end;

function Integer IVCash_TCPIPPrintFiscalItemRow(string host,LongInt port,string codepage,var Integer seqnr,string operator,Integer typ,record IVCashVc IVCr,row IVCashVc IVCrw,vector val vatrates)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  string 255 unit;
  Boolean negtivef;
  record INVc INr;
  
  ReadFirstItem(IVCrw.ArtCode,INr,false,true);
  if (IVCrw.Quant<0) then begin
    negtivef = true;
    IVCrw.Quant = -IVCrw.Quant;
  end;
  negtivef = negtivef or IVCr.InvType==kPOSInvoiceTypeCredit;
  unit = IVCrw.UnitCode;
  if (blank(unit)) then begin
    unit = "PCS";
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  if (negtivef) then begin
    CtrlSeq = CtrlSeq & "011";
  end else begin
    CtrlSeq = CtrlSeq & "005";
  end;
  CtrlSeq = CtrlSeq & operator;
  M4PadString(IVCrw.ArtCode,40," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  M4PadString(IVCrw.Spec,20," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  tstr = ValToString(IVCrw.Quant*1000,M40Val,"","",0);
  M4PadString(tstr,7,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "1";
  tstr = ValToString(IVCrw.Price*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & FindFiscalDepartment(INr);
  tstr = ValToString(IVCrw.Sum*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);

/*  
  if (res==noErr) then begin
    if (nonblank(IVCrw.SerialNr)) then begin
      IVCrw.Spec = UsetStr(1141) & IVCrw.SerialNr;
      res = IVCash_PrintCommentLine(seqnr,IVCr,IVCrw);
    end;
  end;
*/

  if (res==noErr) then begin
    if (nonblank(IVCrw.vRebate)) then begin
      res = IVCash_TCPIPInvoiceDiscountAdditionForItem(host,port,codepage,seqnr,operator,IVCr,IVCrw);
    end;
  end;
  
  IVCash_TCPIPPrintFiscalItemRow = res;
  return;
end;

