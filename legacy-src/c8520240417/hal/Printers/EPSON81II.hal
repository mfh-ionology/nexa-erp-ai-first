    switch (IVCrw.stp) begin
      case kInvoiceRowTypeStructuredItemComponent:
        goto LkInvoiceRowTypeNormal2_D;
      case kInvoiceRowTypeNormal:
LkInvoiceRowTypeNormal2_D:;
        if (nonblank(IVCrw.ArtCode)) then begin
          res = IVCash_TCPIPPrintFiscalItemRow(host,port,codepage,seqnr,operator,typ,IVCr,IVCrw,vatrates);
          if (res!=noErr) then begin
            goto LIVCash_TCPIPPrintFiscalInvoiceItemRows;
          end;
        end else begin
//          res = IVCash_PrintCommentLine(seqnr,operator,IVCr,IVCrw);
          if (res!=noErr) then begin
            goto LIVCash_TCPIPPrintFiscalInvoiceItemRows;
          end;
        end;
      case kInvoiceRowTypeReturnIVNr:
/*
        res = PrintReturnLine(seqnr,IVCrw.OrgIVNr);
        if (res!=noErr) then begin
          goto LIVCash_TCPIPPrintFiscalInvoiceItemRows;
        end;
*/        
      case kInvoiceRowTypeVoid:
    end;
  end;
LIVCash_TCPIPPrintFiscalInvoiceItemRows:;  
  IVCash_TCPIPPrintFiscalInvoiceItemRows = res;
  return;
end;

function Integer TCPIPGetEPSON81IIInvoiceParametres(string host,LongInt port,string codepage,var Integer seqnr,string operator,var string response)
begin
  Integer res,noErr;
  string 255 CtrlSeq; 

  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "225";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  
  res = TCPIP_EPSON81IIWriteAndGetResponse(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY,response);
  TCPIPGetEPSON81IIInvoiceParametres = res;
  return;
end;

function Integer TCPIPPrintHeader(string host,LongInt port,string codepage,var Integer seqnr,string operator,record MachineCashVc MCr)
begin
  string 255 CtrlSeq,tstr;
  Integer res,noErr,h;

  h = 1;
  if (nonblank(MCr.Head0)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "5";
    M4PadString(h,2,"0",true,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(MCr.Head0,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LTCPIPPrintHeader;
    end;
    h = h + 1;
  end;
  if (nonblank(MCr.Head1)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "5";
    M4PadString(h,2,"0",true,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(MCr.Head1,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LTCPIPPrintHeader;
    end;
    h = h + 1;
  end;
  if (nonblank(MCr.Head2)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "5";
    M4PadString(h,2,"0",true,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(MCr.Head2,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LTCPIPPrintHeader;
    end;
    h = h + 1;
  end;
  if (nonblank(MCr.Head3)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "5";
    M4PadString(h,2,"0",true,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(MCr.Head3,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LTCPIPPrintHeader;
    end;
    h = h + 1;
  end;
  if (nonblank(MCr.Head4)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "5";
    M4PadString(h,2,"0",true,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(MCr.Head4,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LTCPIPPrintHeader;
    end;
    h = h + 1;
  end;
LTCPIPPrintHeader:;  
  TCPIPPrintHeader = res;
  return;
end;

function Integer TCPIPBeginFiscalInvoice(string host,LongInt port,string codepage,var Integer seqnr,string operator,string offnr,Integer rwcnt,record MachineCashVc MCr,string vatnr,string name,string addr1,string addr2,string addr3,string addr4)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr,response;
  row LegalInvNrBlock LINrbrw;
  string 255 serie,sernr;
  Integer h;
  LongInt pos;

//?  ResetFiscal(seqnr);

  if (nonblank(MCr.Head0)) then begin h = h + 1; end;
  if (nonblank(MCr.Head1)) then begin h = h + 1; end;
  if (nonblank(MCr.Head2)) then begin h = h + 1; end;
  if (nonblank(MCr.Head3)) then begin h = h + 1; end;
  if (nonblank(MCr.Head4)) then begin h = h + 1; end;

  TCPIPGetEPSON81IIInvoiceParametres(host,port,codepage,seqnr,operator,response);

  tstr = Mid(response,8,4);
//SetParameters


  GetLegalInvNrRow(offnr,LINrbrw);
  serie = GetLegalInvoiceNrSerie(LINrbrw,offnr);
  sernr = GetLegalInvoiceNrString(LINrbrw,offnr);   
//  sernr = StringToLongInt(tstr) + 1;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "025";
  M4PadString(sernr,4,"0",true,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "99";
  M4PadString(h,2,"0",true,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "1";
  M4PadString(" ",14," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  M4PadString(serie,10," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LTCPIPBeginFiscalInvoice;
  end;

  res = TCPIPPrintHeader(host,port,codepage,seqnr,operator,MCr);
  if (res!=0) then begin
    goto LTCPIPBeginFiscalInvoice;
  end;


  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "078";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "6";
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & "1";
  M4PadString(name,40," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LTCPIPBeginFiscalInvoice;
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "078";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "6";
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & "1";
  M4PadString(vatnr,40," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LTCPIPBeginFiscalInvoice;
  end;
  if (nonblank(addr1)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "6";
    CtrlSeq = CtrlSeq & "02";
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(addr1,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LTCPIPBeginFiscalInvoice;
    end;
  end;
  if (nonblank(addr2)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "6";
    CtrlSeq = CtrlSeq & "03";
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(addr2,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LTCPIPBeginFiscalInvoice;
    end;
  end;
  if (nonblank(addr3)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "6";
    CtrlSeq = CtrlSeq & "03";
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(addr3,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LTCPIPBeginFiscalInvoice;
    end;
  end;
  if (nonblank(addr4)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "6";
    CtrlSeq = CtrlSeq & "03";
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(addr4,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LTCPIPBeginFiscalInvoice;
    end;
  end;


/*
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "053";
  CtrlSeq = CtrlSeq & "01";
  M4PadString(sernr,5,"0",true,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LTCPIPBeginFiscalInvoice;
  end;
*/

  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "089";
  CtrlSeq = CtrlSeq & operator;
//  M4PadString(sernr,5,"0",true,tstr);
  CtrlSeq = CtrlSeq & sernr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LTCPIPBeginFiscalInvoice;
  end;

/*
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "025";
  M4PadString(sernr,4,"0",true,tstr);
  CtrlSeq = CtrlSeq & tstr;
  M4PadString(rwcnt,2,"0",true,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "00";
  CtrlSeq = CtrlSeq & "1";
  M4PadString(" ",14," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "  ";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LTCPIPBeginFiscalInvoice;
  end;
*/

  if (nonblank(MCr.Foot0)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "4";
    CtrlSeq = CtrlSeq & "027";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(MCr.Foot0,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LTCPIPBeginFiscalInvoice;
    end;
  end;
  if (nonblank(MCr.Foot1)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "4";
    CtrlSeq = CtrlSeq & "027";
    CtrlSeq = CtrlSeq & "2";
    M4PadString(MCr.Foot1,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LTCPIPBeginFiscalInvoice;
    end;
  end;

LTCPIPBeginFiscalInvoice:;  
  TCPIPBeginFiscalInvoice = res;
  return;
end;

function Integer IVCash_TCPIPEndFiscalReceipt(string host,LongInt port,string codepage,var Integer seqnr,string operator,record IVCashVc IVCr)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr,response;
  vector val vpaymodesums;


  IVCash_CalculatePaymentModeSums(IVCr,vpaymodesums);
    
  if (vpaymodesums[kInvoiceRowTypeCreditCardPayment]!=0) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "084";
    CtrlSeq = CtrlSeq & operator;
    M4PadString(USetStr(20801),32," ",false,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    tstr = ValToString(AbsoluteVal(vpaymodesums[kInvoiceRowTypeCreditCardPayment]*100),M40Val,"","",1);
    M4PadString(tstr,9,"0",true,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "2";
    CtrlSeq = CtrlSeq & "00";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=noErr) then begin
      res = 19389;
      goto LIVCash_TCPIPEndFiscalReceipt;
    end;
  end;

  if (vpaymodesums[kInvoiceRowTypeCashPayment]!=0) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "084";
    CtrlSeq = CtrlSeq & operator;
    M4PadString(USetStr(20800),32," ",false,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    tstr = ValToString(AbsoluteVal(vpaymodesums[kInvoiceRowTypeCashPayment]*100),M40Val,"","",1);
    M4PadString(tstr,9,"0",true,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "01";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
//    res = TCPIP_EPSON81IIWriteAndGetResponse(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY,response);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=noErr) then begin
      res = 19389;
      goto LIVCash_TCPIPEndFiscalReceipt;
    end;
  end;

LIVCash_TCPIPEndFiscalReceipt:;
  IVCash_TCPIPEndFiscalReceipt = res;
  return;
end;

function Integer IVCash_TCPIPEndFiscalInvoice(string host,LongInt port,string codepage,var Integer seqnr,string operator,record IVCashVc IVCr)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  vector val vpaymodesums;
    
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "087";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);

  if (res!=noErr) then begin
    res = 19389;
    goto LIVCash_TCPIPEndFiscalInvoice;
  end;
LIVCash_TCPIPEndFiscalInvoice:;
  IVCash_TCPIPEndFiscalInvoice = res;
  return;
end;

function Integer TCPIPLoadVATRate(string host,LongInt port,string codepage,var Integer seqnr,string vatrate,var val vr)
begin
  INteger res,noErr;
  string 255 CtrlSeq,response,fpresp; 
  LongInt pos;

  vr = blankval;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "205";
  CtrlSeq = CtrlSeq & vatrate;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  
  res = TCPIP_EPSON81IIWriteAndGetResponse(host,port,seqnr,"",CtrlSeq,EPSON81II_DELAY,response);
  LogText(0,"TCPIPLoadVATRate response=" & response);

  if (res!=noErr) then begin
    res = 12405;
    goto LTCPIPLoadVATRate;
  end;
  if (blank(response)) then begin
    res = 12405;
    goto LTCPIPLoadVATRate;
  end;
  fpresp = Mid(response,10,4);  
  vr = ValFromString(fpresp,".","")/100;

LTCPIPLoadVATRate:;
  TCPIPLoadVATRate = res;
  return;
end;

function Integer TCPIPLoadVATRates(string host,LongInt port,string codepage,var Integer seqnr,vector val vatrates)
begin
  Integer res;
  val vr;
  
/*
  res = TCPIPLoadVATRate(seqnr,"00",vr);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LTCPIPLoadVATRates;
  end;
*/  
  vatrates["00"] = vr;
  res = TCPIPLoadVATRate(host,port,codepage,seqnr,"01",vr);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LTCPIPLoadVATRates;
  end;
  vatrates["01"] = vr;
  res = TCPIPLoadVATRate(host,port,codepage,seqnr,"02",vr);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LTCPIPLoadVATRates;
  end;
  vatrates["02"] = vr;
  res = TCPIPLoadVATRate(host,port,codepage,seqnr,"03",vr);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LTCPIPLoadVATRates;
  end;
  vatrates["03"] = vr;
  res = TCPIPLoadVATRate(host,port,codepage,seqnr,"04",vr);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LTCPIPLoadVATRates;
  end;
  vatrates["04"] = vr;
  res = TCPIPLoadVATRate(host,port,codepage,seqnr,"05",vr);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LTCPIPLoadVATRates;
  end;
  vatrates["05"] = vr;
LTCPIPLoadVATRates:;
  TCPIPLoadVATRates = res;
  return;
end;

function Integer TCPIPDisplayText(string host,LongInt port,var Integer seqnr,string operator,Integer typ,string text)
begin
  Integer res;
  string 255 CtrlSeq,tstr;

  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "062";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & typ;
  M4PadString(text,40," ",false,tstr);            
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "00";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);  

  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  TCPIPDisplayText = res;
  return;
end;

global
updating procedure PrintEPSON81IITCPIPReceipt_IVCashVc(var record IVCashVc IVCr,record LSerialPortDeviceVc LSPDr)
begin
  record IVCashVc oldIVCr;
  string 255 replystr,tstr;
  vector val vatrates;
  string 255 host,codepage,operator;
  LongInt port;
  LongInt pos;
  Integer seqnr,noErr;
  Integer res;
  record MachineCashVc MCr;

  seqnr = 0;
  noErr = 0;
  if (InString(LSPDr.Port,":")) then begin
    pos = 0;
    GetNextSubstring(LSPDr.Port,pos,":",host);
    GetNextSubstring(LSPDr.Port,pos,":",tstr);
    port = StringToLongInt(tstr);    
    codepage = StringSetFromString(89,LSPDr.Codepage);

    operator = IVCr.POSOperatorID;
    if (blank(operator)) then begin
      operator = "01";
    end;

    res = TCPIPSend_InconsequentialMessages(host,port,codepage,seqnr,operator);
    if (res!=noErr) then begin
      goto LPrintEPSON81IITCPIPReceipt_IVCashVc;
    end;

//    TCPIPResetFiscal(host,port,seqnr);

    MCr.Code = IVCr.LocalMachineCode;
    ReadFirstMain(MCr,1,true);

    res = TCPIPCheckClock(host,port,codepage,seqnr);
    if (res!=noErr) then begin
      goto LPrintEPSON81IITCPIPReceipt_IVCashVc;
    end;
    if (blank(IVCr.VATNr)) then begin
      if (IVCr.InvType==kPOSInvoiceTypeCredit) then begin
        res = 1;
//        res = BeginFiscalCreditNote(seqnr,IVCr.SerNr);
//not allowed in Italy
      end else begin
        res = TCPIPBeginFiscalReceipt(host,port,codepage,seqnr,operator,IVCr.RegNr1);
      end;
      if (res!=noErr) then begin  goto LPrintEPSON81IITCPIPReceipt_IVCashVc; end;

      res = IVCash_TCPIPPrintItemRows(host,port,codepage,seqnr,operator,0,IVCr,vatrates);
      if (res!=noErr) then begin goto LPrintEPSON81IITCPIPReceipt_IVCashVc; end;

      res = IVCash_TCPIPEndFiscalReceipt(host,port,codepage,seqnr,operator,IVCr);
      if (res!=noErr) then begin
        goto LPrintEPSON81IITCPIPReceipt_IVCashVc;
      end;
    end else begin
      res = TCPIPLoadVATRates(host,port,codepage,seqnr,vatrates);
      if (res!=noErr) then begin goto LPrintEPSON81IITCPIPReceipt_IVCashVc; end;

      if (IVCr.InvType==kPOSInvoiceTypeCredit) then begin
        res = 1;
//        res = BeginFiscalCreditNote(seqnr,IVCr.SerNr);
//not allowed in Italy
      end else begin
        res = TCPIPBeginFiscalInvoice(host,port,codepage,seqnr,operator,IVCr.OfficialSerNr,MatRowCnt(IVCr),MCr,IVCr.VATNr,IVCr.Addr0,IVCr.Addr1,IVCr.Addr2,IVCr.Addr3,IVCr.InvAddr3);
        if (res!=noErr) then begin 
          goto LPrintEPSON81IITCPIPReceipt_IVCashVc;  
        end;
      end;
/*      
      if (res!=noErr) then begin 
        res = IVCash_TCPIPEndFiscalInvoice(host,port,codepage,seqnr,operator,IVCr);
        goto LPrintEPSON81IITCPIPReceipt_IVCashVc;  
      end;
*/      

      res = IVCash_TCPIPPrintFiscalInvoiceItemRows(host,port,codepage,seqnr,operator,1,IVCr,vatrates);
      if (res!=noErr) then begin 
        res = IVCash_TCPIPEndFiscalInvoice(host,port,codepage,seqnr,operator,IVCr);
        goto LPrintEPSON81IITCPIPReceipt_IVCashVc; 
      end;
      res = IVCash_TCPIPEndFiscalReceipt(host,port,codepage,seqnr,operator,IVCr);
      if (res!=noErr) then begin  goto LPrintEPSON81IITCPIPReceipt_IVCashVc; end;      
    end;
    tstr = MCr.DisplayText;
    if (blank(tstr)) then begin
      tstr = USetStr(27522);
    end;
    TCPIPDisplayText(host,port,seqnr,operator,0,tstr);
    if (IVCr.Prntdf!=0) then begin
      RecordCopy(oldIVCr,IVCr);
      IVCr.Prntdf = 1;
      RecordUpdate(oldIVCr,IVCr,false);
    end;    
    
LPrintEPSON81IITCPIPReceipt_IVCashVc:;
  end;
  return;
end;

global
procedure PrintEPSON81IITCPIPFiscalInvoice_IVCashVc(var record IVCashVc IVCr,record LSerialPortDeviceVc LSPDr)
begin
  string 255 host,codepage,operator;
  LongInt port;
  LongInt pos;
  Integer seqnr,noErr;
  Integer res;
  string 255 tstr,CtrlSeq;
  string 255 serie,sernr;
  row LegalInvNrBlock LINrbrw;

  seqnr = 0;
  noErr = 0;
  if (InString(LSPDr.Port,":")) then begin
    pos = 0;
    GetNextSubstring(LSPDr.Port,pos,":",host);
    GetNextSubstring(LSPDr.Port,pos,":",tstr);
    port = StringToLongInt(tstr);    
    codepage = StringSetFromString(89,LSPDr.Codepage);

    operator = IVCr.POSOperatorID;
    if (blank(operator)) then begin
      operator = "01";
    end;

    res = TCPIPSend_InconsequentialMessages(host,port,codepage,seqnr,operator);
    if (res!=noErr) then begin
      goto LPrintEPSON81IITCPIPFiscalInvoice_IVCashVc;
    end;

    GetLegalInvNrRow(IVCr.OfficialSerNr,LINrbrw);
    serie = GetLegalInvoiceNrSerie(LINrbrw,IVCr.OfficialSerNr);
    sernr = GetLegalInvoiceNrString(LINrbrw,IVCr.OfficialSerNr);
    if (nonblank(IVCr.Addr0)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "078";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "6";
      CtrlSeq = CtrlSeq & "01";
      CtrlSeq = CtrlSeq & "0";
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.Addr0,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IITCPIPFiscalInvoice_IVCashVc;
      end;
    end;
    if (nonblank(IVCr.Addr1)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "078";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "6";
      CtrlSeq = CtrlSeq & "02";
      CtrlSeq = CtrlSeq & "0";
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.Addr1,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IITCPIPFiscalInvoice_IVCashVc;
      end;
    end;
    if (nonblank(IVCr.Addr2)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "078";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "6";
      CtrlSeq = CtrlSeq & "03";
      CtrlSeq = CtrlSeq & "0";
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.Addr2,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IITCPIPFiscalInvoice_IVCashVc;
      end;
    end;
    if (nonblank(IVCr.Addr3)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "078";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "6";
      CtrlSeq = CtrlSeq & "03";
      CtrlSeq = CtrlSeq & "0";
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.Addr3,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IITCPIPFiscalInvoice_IVCashVc;
      end;
    end;
    if (nonblank(IVCr.InvAddr3)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "078";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "6";
      CtrlSeq = CtrlSeq & "03";
      CtrlSeq = CtrlSeq & "0";
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.InvAddr3,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IITCPIPFiscalInvoice_IVCashVc;
      end;
    end;

    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "052";
    CtrlSeq = CtrlSeq & operator;
    M4PadString(sernr,4,"0",true,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);

    if (res!=noErr) then begin
      res = 19389;
      goto LPrintEPSON81IITCPIPFiscalInvoice_IVCashVc;
    end;
LPrintEPSON81IITCPIPFiscalInvoice_IVCashVc:;  
    TCPIPResetFiscal(host,port,seqnr,operator);
  end;
  return;
end;

function Integer IVCash_TCPIPPrintCourtesyReceiptItemRow(string host,LongInt port,string codepage,var Integer seqnr,string operator,record IVCashVc IVCr,row IVCashVc IVCrw)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr,t2;
  string 255 unit;
  Boolean negtivef;
  record INVc INr;
  
  ReadFirstItem(IVCrw.ArtCode,INr,false,true);
  if (IVCrw.Quant<0) then begin
    negtivef = true;
    IVCrw.Quant = -IVCrw.Quant;
  end;
  negtivef = negtivef or IVCr.InvType==kPOSInvoiceTypeCredit;
  unit = IVCrw.UnitCode;
  if (blank(unit)) then begin
    unit = "PCS";
  end;
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "064";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "1";
  M4PadString(IVCrw.Spec,20," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  tstr = ValToString(IVCrw.Quant,M4Val,"",".",0);
  M4PadString(tstr,7," ",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LIVCash_TCPIPPrintCourtesyReceiptItemRow;
  end;
    
LIVCash_TCPIPPrintCourtesyReceiptItemRow:;  
  IVCash_TCPIPPrintCourtesyReceiptItemRow = res;
  return;
end;

function Integer IVCash_TCPIPPrintCourtesyReceiptCommentLine(string host,LongInt port,string codepage,var Integer seqnr,string operator,record IVCashVc IVCr,row IVCashVc IVCrw)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "064";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "1";
  M4PadString(IVCrw.Spec,32," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  IVCash_TCPIPPrintCourtesyReceiptCommentLine = res;
  return;
end;

function Integer IVCash_TCPIPPrintCourtesyReceiptItemRows(string host,LongInt port,string codepage,var Integer seqnr,string operator,record IVCashVc IVCr)
begin
  INteger res,noErr;
  row IVCashVc IVCrw;
  Integer i,rwcnt;

  rwcnt = MatRowCnt(IVCr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(IVCr,i,IVCrw);
    switch (IVCrw.stp) begin
      case kInvoiceRowTypeStructuredItemComponent:
        goto LkInvoiceRowTypeNormal3;
      case kInvoiceRowTypeNormal:
LkInvoiceRowTypeNormal3:;
        if (nonblank(IVCrw.ArtCode)) then begin
          res = IVCash_TCPIPPrintCourtesyReceiptItemRow(host,port,codepage,seqnr,operator,IVCr,IVCrw);
          if (res!=noErr) then begin
            goto LIVCash_TCPIPPrintCourtesyReceiptItemRows;
          end;
        end else begin
          res = IVCash_TCPIPPrintCourtesyReceiptCommentLine(host,port,codepage,seqnr,operator,IVCr,IVCrw);
          if (res!=noErr) then begin
            goto LIVCash_TCPIPPrintCourtesyReceiptItemRows;
          end;
        end;
      case kInvoiceRowTypeReturnIVNr:
/*
        res = PrintReturnLine(seqnr,IVCrw.OrgIVNr);
        if (res!=noErr) then begin
          goto LIVCash_TCPIPPrintCourtesyReceiptItemRows;
        end;
*/        
      case kInvoiceRowTypeVoid:
    end;
  end;
LIVCash_TCPIPPrintCourtesyReceiptItemRows:;  
  IVCash_TCPIPPrintCourtesyReceiptItemRows = res;
  return;
end;

global
procedure PrintEPSON81IITCPIPCourtesyReceipt_IVCashVc(var record IVCashVc IVCr,record LSerialPortDeviceVc LSPDr)
begin
  string 255 host,codepage,barcode;
  LongInt port;
  LongInt pos;
  Integer seqnr,noErr;
  Integer res;
  string 255 tstr,CtrlSeq,operator;
  string 255 serie,sernr;
  row LegalInvNrBlock LINrbrw;

  seqnr = 0;
  noErr = 0;
  if (InString(LSPDr.Port,":")) then begin
    pos = 0;
    GetNextSubstring(LSPDr.Port,pos,":",host);
    GetNextSubstring(LSPDr.Port,pos,":",tstr);
    port = StringToLongInt(tstr);    
    codepage = StringSetFromString(89,LSPDr.Codepage);
    GetLegalInvNrRow(IVCr.OfficialSerNr,LINrbrw);
    serie = GetLegalInvoiceNrSerie(LINrbrw,IVCr.OfficialSerNr);
    sernr = GetLegalInvoiceNrString(LINrbrw,IVCr.OfficialSerNr);
    
    operator = IVCr.POSOperatorID;
    if (blank(operator)) then begin
      operator = "01";
    end;

    res = TCPIPSend_InconsequentialMessages(host,port,codepage,seqnr,operator);
    if (res!=noErr) then begin
      goto LPrintEPSON81IITCPIPCourtesyReceipt_IVCashVc;
    end;
    
    
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "063";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LPrintEPSON81IITCPIPCourtesyReceipt_IVCashVc;
    end;

    if (nonblank(IVCr.Addr0)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "064";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.Addr0,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IITCPIPCourtesyReceipt_IVCashVc;
      end;
    end;
    if (nonblank(IVCr.Addr1)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "064";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.Addr1,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IITCPIPCourtesyReceipt_IVCashVc;
      end;
    end;
    if (nonblank(IVCr.Addr2)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "064";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.Addr2,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IITCPIPCourtesyReceipt_IVCashVc;
      end;
    end;
    if (nonblank(IVCr.Addr3)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "064";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.Addr3,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IITCPIPCourtesyReceipt_IVCashVc;
      end;
    end;
    if (nonblank(IVCr.InvAddr3)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "064";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.InvAddr3,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IITCPIPCourtesyReceipt_IVCashVc;
      end;
    end;
    if (nonblank(IVCr.InvAddr4)) then begin
      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "1";
      CtrlSeq = CtrlSeq & "064";
      CtrlSeq = CtrlSeq & operator;
      CtrlSeq = CtrlSeq & "1";
      M4PadString(IVCr.InvAddr4,40," ",false,tstr);
      CtrlSeq = CtrlSeq & tstr;
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
      res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
      if (res!=0) then begin
        goto LPrintEPSON81IITCPIPCourtesyReceipt_IVCashVc;
      end;
    end;

    res = IVCash_TCPIPPrintCourtesyReceiptItemRows(host,port,codepage,seqnr,operator,IVCr);
    if (res!=0) then begin
      goto LPrintEPSON81IITCPIPCourtesyReceipt_IVCashVc;
    end;

    barcode = IVCr.SerNr & " " & DateToString(IVCr.TransDate,"YYYY/MM/DD");
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "075";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "001";
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "008";
    CtrlSeq = CtrlSeq & "2";
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "NU";
    CtrlSeq = CtrlSeq & "91";
    CtrlSeq = CtrlSeq & barcode;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LPrintEPSON81IITCPIPCourtesyReceipt_IVCashVc;
    end;

    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "065";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LPrintEPSON81IITCPIPCourtesyReceipt_IVCashVc;
    end;


LPrintEPSON81IITCPIPCourtesyReceipt_IVCashVc:;  
  end;
  return;
end;

global
procedure EPSON81IITCPIPSetFiscalPrinterLogo(Integer typ,Integer stat,record LSerialPortDeviceVc LSPDr)
begin
  string 255 host,codepage;
  LongInt port;
  LongInt pos;
  Integer seqnr,noErr;
  Integer res;
  string 255 tstr,CtrlSeq;
  string 255 serie,sernr;
  row LegalInvNrBlock LINrbrw;

  goto LEPSON81IITCPIPSetFiscalPrinterLogo;
//we dont know the command syntax atm
  seqnr = 0;
  noErr = 0;
  if (InString(LSPDr.Port,":")) then begin
    pos = 0;
    GetNextSubstring(LSPDr.Port,pos,":",host);
    GetNextSubstring(LSPDr.Port,pos,":",tstr);
    port = StringToLongInt(tstr);    
    codepage = StringSetFromString(89,LSPDr.Codepage);

    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "4";
    CtrlSeq = CtrlSeq & "015";
    switch (typ) begin
      case 0: CtrlSeq = CtrlSeq & "09";
      case 1: CtrlSeq = CtrlSeq & "19";
    end;
    M4PadString(stat,3,"0",true,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "NU";
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,"",CtrlSeq,EPSON81II_DELAY);
    if (res!=noErr) then begin
      goto LEPSON81IITCPIPSetFiscalPrinterLogo;
    end;

    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "4";
    CtrlSeq = CtrlSeq & "015";
    switch (typ) begin
      case 0: CtrlSeq = CtrlSeq & "10";
      case 1: CtrlSeq = CtrlSeq & "29";
    end;
    M4PadString(stat,3,"0",true,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "NU";
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWrite(host,port,seqnr,"",CtrlSeq,EPSON81II_DELAY);
    if (res!=noErr) then begin
      goto LEPSON81IITCPIPSetFiscalPrinterLogo;
    end;
  end;
LEPSON81IITCPIPSetFiscalPrinterLogo:;      
  return;
end;

global
procedure EPSON81IITCPIPSetFiscalPrinterDepartment(record FiscalDepVc FDr,record LSerialPortDeviceVc LSPDr)
begin
  string 255 host,codepage,response;
  LongInt port;
  LongInt pos;
  Integer seqnr,noErr;
  Integer res;
  string 255 tstr,CtrlSeq,vg;
  vector val vatrates;

  seqnr = 0;
  noErr = 0;
  if (InString(LSPDr.Port,":")) then begin
    pos = 0;
    GetNextSubstring(LSPDr.Port,pos,":",host);
    GetNextSubstring(LSPDr.Port,pos,":",tstr);
    port = StringToLongInt(tstr);    
    codepage = StringSetFromString(89,LSPDr.Codepage);

    res = TCPIPSend_InconsequentialMessages(host,port,codepage,seqnr,"01");
    if (res!=noErr) then begin
      MessageBox(21484,"");
      goto LEPSON81IITCPIPSetFiscalPrinterDepartment;
    end;

    res = TCPIPLoadVATRates(host,port,codepage,seqnr,vatrates);
    if (res!=noErr) then begin
      MessageBox(21484,"");
      goto LEPSON81IITCPIPSetFiscalPrinterDepartment;
    end;
    vg = GetEPSON81IIVATGroup(FDr.VATCode,vatrates);
    if (blank(vg)) then begin
      MessageBox(21484,"");
      goto LEPSON81IITCPIPSetFiscalPrinterDepartment;
    end;
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "4";
    CtrlSeq = CtrlSeq & "002";
    CtrlSeq = CtrlSeq & FDr.Code;
    M4PadString(FDr.Description,20," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    M4PadString("0",9,"0",true,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    M4PadString("0",9,"0",true,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    M4PadString("0",9,"0",true,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & vg;
    M4PadString("0",9,"0",true,tstr);          
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "00";
    CtrlSeq = CtrlSeq & "00";
    CtrlSeq = CtrlSeq & FDr.Unittext;
    CtrlSeq = CtrlSeq & "NU";
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = TCPIP_EPSON81IIWriteAndGetResponse(host,port,seqnr,"",CtrlSeq,EPSON81II_DELAY,response);
    if (res!=noErr) then begin
      MessageBox(21484,"");
      goto LEPSON81IITCPIPSetFiscalPrinterDepartment;
    end;
    MessageBox(40410,"");
  end;
LEPSON81IITCPIPSetFiscalPrinterDepartment:;      
  return;
end;

global
procedure SetPOSWindowDisplayModeFiscalPrinterEPSON81IITCPIP(record LSerialPortDeviceVc LSPDr,string dispstr,string disp2str)
begin
  string 255 host,codepage,response,operator;
  LongInt port;
  LongInt pos;
  Integer seqnr,noErr;
  Integer res;
  string 255 tstr,t2;
  string 255 CtrlSeq;
  record MachineCashVc MCr;

  seqnr = 0;
  noErr = 0;
  if (InString(LSPDr.Port,":")) then begin
    pos = 0;
    GetNextSubstring(LSPDr.Port,pos,":",host);
    GetNextSubstring(LSPDr.Port,pos,":",tstr);
    port = StringToLongInt(tstr);    
    codepage = StringSetFromString(89,LSPDr.Codepage);

    operator = "01";

    res = TCPIPSend_InconsequentialMessages(host,port,codepage,seqnr,operator);
    if (res!=noErr) then begin
      goto LSetPOSWindowDisplayModeFiscalPrinterEPSON81IITCPIP;
    end;


    M4PadString(dispstr,20," ",false,tstr);          
    M4PadString(disp2str,20," ",false,t2);          
    tstr = tstr & t2;
    res = TCPIPDisplayText(host,port,seqnr,operator,0,tstr);
    if (res!=noErr) then begin
      MessageBox(21484,"");
      goto LSetPOSWindowDisplayModeFiscalPrinterEPSON81IITCPIP;
    end;
    if (blank(dispstr) and Left(disp2str,len(USetStr(24172)))==USetStr(24172)) then begin
      MCr.Code = LSPDr.LocalMachineCode;
      ReadFirstMain(MCr,1,true);

      CtrlSeq = SequenceNr(seqnr);
      CtrlSeq = CtrlSeq & "E";
      CtrlSeq = CtrlSeq & "4";
      CtrlSeq = CtrlSeq & "015";
      CtrlSeq = CtrlSeq & "13";
      CtrlSeq = CtrlSeq & "997";
      CtrlSeq = CtrlSeq & "NU";
      CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);  

      res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);

      M4PadString(MCr.DisplayText,20," ",false,tstr);          
      res = TCPIPDisplayText(host,port,seqnr,operator,3,tstr);
    end;
  end;
LSetPOSWindowDisplayModeFiscalPrinterEPSON81IITCPIP:;  
  return;
end;


function Integer TCPIPMoneyOutCurr(string host,LongInt port,var Integer seqnr,string operator,record CashVc Cashr)
begin
  Integer res,noErr;
  string 255 CtrlSeq,tstr;
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "032";
  tstr = ValToString(Cashr.Total*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  TCPIPMoneyOutCurr = res;
  return;
end;

function Integer TCPIPMoneyInCurr(string host,LongInt port,var Integer seqnr,string operator,record CashVc Cashr)
begin
  Integer res,noErr;
  string 255 CtrlSeq,tstr;
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "031";
  tstr = ValToString(Cashr.Total*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  TCPIPMoneyInCurr = res;
  return;
end;

global
procedure PrintCashEventEPSON81IITCPIP(var record CashVc Cashr,record LSerialPortDeviceVc LSPDr)
begin
  string 255 host,codepage,response,operator,tstr;
  LongInt port;
  LongInt pos;
  Integer seqnr,noErr;
  Integer res;
  string 255 CtrlSeq;
  
  noErr = 0;
  seqnr = 0;
  if (InString(LSPDr.Port,":")) then begin
    pos = 0;
    GetNextSubstring(LSPDr.Port,pos,":",host);
    GetNextSubstring(LSPDr.Port,pos,":",tstr);
    port = StringToLongInt(tstr);    
    codepage = StringSetFromString(89,LSPDr.Codepage);

    operator = "01";

    res = TCPIPSend_InconsequentialMessages(host,port,codepage,seqnr,operator);
    if (res!=noErr) then begin
      goto LPrintCashEventEPSON81IITCPIP;
    end;

    
   switch (Cashr.Event) begin
      case 0:
        TCPIPMoneyOutCurr(host,port,seqnr,operator,Cashr);
      case 1:
        TCPIPMoneyInCurr(host,port,seqnr,operator,Cashr);
    end;
LPrintCashEventEPSON81IITCPIP:;
    if (res!=0) then begin
      MessageBox(res,"");
    end;
  end;
  return;
end;

global
procedure EPSON81IITCPIPDailyReport(record LSerialPortDeviceVc LSPDr)
begin
  string 255 host,codepage,response,operator,tstr;
  LongInt port;
  LongInt pos;
  Integer seqnr,noErr;
  Integer res;
  string 255 CtrlSeq;

  noErr = 0;
  seqnr = 0;
  if (InString(LSPDr.Port,":")) then begin
    pos = 0;
    GetNextSubstring(LSPDr.Port,pos,":",host);
    GetNextSubstring(LSPDr.Port,pos,":",tstr);
    port = StringToLongInt(tstr);    
    codepage = StringSetFromString(89,LSPDr.Codepage);

    operator = "01";

    res = TCPIPSend_InconsequentialMessages(host,port,codepage,seqnr,operator);
    if (res!=noErr) then begin
      goto LEPSON81IITCPIPDailyReport;
    end;

  
    CtrlSeq = CtrlSeq & SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "3";
    CtrlSeq = CtrlSeq & "001";
    CtrlSeq = CtrlSeq & "01";
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);

    if (res!=0) then begin
      MessageBox(res,"");
    end;
  end;

LEPSON81IITCPIPDailyReport:;  
  return;
end;

global
procedure EPSON81IITCPIPMonthlyReport(record LSerialPortDeviceVc LSPDr)
begin
  string 255 host,codepage,response,operator,tstr;
  LongInt port;
  LongInt pos;
  Integer seqnr,noErr;
  Integer res;
  string 255 CtrlSeq;
  Date sd,ed;

  noErr = 0;
  seqnr = 0;
  if (InString(LSPDr.Port,":")) then begin
    pos = 0;
    GetNextSubstring(LSPDr.Port,pos,":",host);
    GetNextSubstring(LSPDr.Port,pos,":",tstr);
    port = StringToLongInt(tstr);    
    codepage = StringSetFromString(89,LSPDr.Codepage);

    operator = "01";

    res = TCPIPSend_InconsequentialMessages(host,port,codepage,seqnr,operator);
    if (res!=noErr) then begin
      goto LEPSON81IITCPIPMonthlyReport;
    end;

    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "3";
    CtrlSeq = CtrlSeq & "013";
    sd = CurrentDate;
    sd.day = 1;
    ed = CurrentDate;
    ed.day = DaysInMonth(ed.year,ed.month);
    CtrlSeq = CtrlSeq & DateToString(sd,"DDMMYY");
    CtrlSeq = CtrlSeq & DateToString(ed,"DDMMYY");
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);


    if (res!=0) then begin
      MessageBox(res,"");
    end;
  end;
LEPSON81IITCPIPMonthlyReport:;  
  return;
end;

global
procedure EPSON81IITCPIPPeriodicReport(record RcVc RepSpec,record LSerialPortDeviceVc LSPDr)
begin
  string 255 host,codepage,response,operator,tstr;
  LongInt port;
  LongInt pos;
  Integer seqnr,noErr;
  Integer res;
  string 255 CtrlSeq;

  noErr = 0;
  seqnr = 0;
  if (InString(LSPDr.Port,":")) then begin
    pos = 0;
    GetNextSubstring(LSPDr.Port,pos,":",host);
    GetNextSubstring(LSPDr.Port,pos,":",tstr);
    port = StringToLongInt(tstr);    
    codepage = StringSetFromString(89,LSPDr.Codepage);

    operator = "01";

    res = TCPIPSend_InconsequentialMessages(host,port,codepage,seqnr,operator);
    if (res!=noErr) then begin
      goto LEPSON81IITCPIPPeriodicReport;
    end;

    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "3";
    CtrlSeq = CtrlSeq & "013";
    CtrlSeq = CtrlSeq & DateToString(RepSpec.d1,"DDMMYY");
    CtrlSeq = CtrlSeq & DateToString(RepSpec.d2,"DDMMYY");
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

    res = TCPIP_EPSON81IIWrite(host,port,seqnr,operator,CtrlSeq,EPSON81II_DELAY);

    if (res!=0) then begin
      MessageBox(res,"");
    end;
  end;
 LEPSON81IITCPIPPeriodicReport:;  
  return;
end;
