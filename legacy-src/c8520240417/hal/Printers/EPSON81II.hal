//FS, Field Separator = 0x1C

enum begin
  EPSON81II_DELAY = 10,
  EPSON81II_LONGDELAY = 30
end;

enum begin
  EPSON81II_STX = 2,
  EPSON81II_ETX = 3,
  EPSON81II_ACK = 6,
  EPSON81II_NAK = 15
end;

function string 255 FindFiscalDepartment(record INVc INr)
begin
  string 255 res;
  record ITVc ITr;
  
  res = INr.FiscalDep;
  if (blank(res)) then begin
    ITr.Code = INr.Group;
    ReadFirstMain(ITr,1,true);
    res = ITr.FiscalDep;
  end;
  FindFiscalDepartment = res;
  return;
end;

function string 255 CalculateLRC(string CtrlSeq)
begin
  string 255 res;
  Integer i,resi,a;
  
  resi = 0;
//LogText(0,"s.CalculateLRC CtrlSeq=" & CtrlSeq);  
  for (i=0;i<len(CtrlSeq);i=i+1) begin
    a = GetByteFromString(Mid(CtrlSeq,i,1),0);
    resi = resi + a;
  end;
  resi = Mod(resi,100);  
  res = resi;
  res = Right(res,2);
  M4PadString(res,2,"0",true,res);          
  CalculateLRC = res;
  return;
end;

function string 255 SequenceNr(var Integer seqnr)
begin
  string 255 res;
  
  seqnr = seqnr + 1;
  if (seqnr>99) then begin
    seqnr = 1;
  end;
  M4PadString(seqnr,2,"0",true,res);          
  SequenceNr = res;
  return;
end;

procedure ResetFiscal(var Integer seqnr,string operator)
begin
  INteger res,noErr;
  string 255 CtrlSeq,cmd;

  CtrlSeq = CtrlSeq & SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "088";
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

LogText(0,"ResetFiscal CtrlSeq=" & CtrlSeq);

  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
/*
  res = OutComPort(0,CtrlSeq);
  if (res!=0) then begin
    res = 0;
  end else begin
    res = 1;
  end;
*/  
  return;
end;

function Integer WaitForEPSON81IIReply(var Integer seqnr,string operator,string command,LongInt waittickscoef,var string response)
begin
  Integer res;
  Integer noErr;
  LongInt waitticks;
  LongInt currenttick, starttick;
  Integer l,responselen;
  Boolean waitf;
  string 255 c,fpresp,errorcode;
  Integer i;
  LongInt pos;
  string 255 tstr,tstr2;

  res = noErr;
  response = "";
  waitticks = waittickscoef*1000;
  starttick = GetCurTick;

  starttick = GetCurTick;
  waitf = true;
  while (waitf) begin
    currenttick = GetCurTick;

    c = ReadComPort(0,1);
//LogText(0," r.WaitForEPSON81IIReply c=" & c & " asc(c) " & asc(c));

    response = response & c;

    if (asc(c)==EPSON81II_ETX) then begin
      waitf = false;
    end;    
    if ((currenttick-starttick)>waitticks) then begin
      waitf = false;
    end;
  end;
LWaitForEPSON81IIReply:;


  GetNextSubstring(response,pos,"E",fpresp);
  GetNextSubstring(response,pos,"E",fpresp);

LogText(0," 3.read " & response & " command " & command & " fpresp " & fpresp & " Mid(response,4,3) " & Mid(response,4,3));

  if (command==Mid(response,3,5)) then begin
  end else begin
     
    if (Mid(response,4,3)=="ERR") then begin
      errorcode = Mid(response,9,2);
    end;

//LogText(0," error.WaitForEPSON81IIReply " & response & " command " & command & " fpresp " & fpresp & " errorcode " & errorcode & " Mid(response,4,3) " & Mid(response,4,3));

    res = StringToInt(errorcode);

    if (res!=0) then begin
      LogText(0,"WaitForEPSON81IIReply errorcode " & errorcode & " res " & res);
      if (command!="E1088") then begin//reset
        ResetFiscal(seqnr,operator);
      end;
    end;
    
  end else begin
    res = 10000;
  end;

  WaitForEPSON81IIReply = res;
  return;
end;

function Integer EPSON81IIWrite(var Integer seqnr,string operator,string CtrlSeq,LongInt delay) 
begin
  Integer res;
  string 255 response;
  

LogText(0,"write CtrlSeq=" & chr(EPSON81II_STX) & CtrlSeq & chr(EPSON81II_ETX));
//HalCallStack;

  res = OutComPort(0,chr(EPSON81II_STX) & CtrlSeq & chr(EPSON81II_ETX));
  if (res!=0) then begin
    res = WaitForEPSON81IIReply(seqnr,operator,Mid(CtrlSeq,2,5),delay,response);
  end else begin
    res = 1;
  end;

//LogText(0,"EPSON81IIWrite CtrlSeq=" & CtrlSeq);
//LogText(0,"EPSON81IIWrite response=" & response);
  EPSON81IIWrite = res;
  return;
end;

function Integer EPSON81IIWriteAndGetResponse(var Integer seqnr,string operator,string CtrlSeq,LongInt delay,var string response) 
begin
  Integer res;

  response = "";

LogText(0,"writer CtrlSeq=" & chr(EPSON81II_STX) & CtrlSeq & chr(EPSON81II_ETX));

  res = OutComPort(0,chr(EPSON81II_STX) & CtrlSeq & chr(EPSON81II_ETX));

  if (res!=0) then begin
    res = WaitForEPSON81IIReply(seqnr,operator,Mid(CtrlSeq,2,5),delay,response);
  end else begin
    res = 1;
  end;
//LogText(0," EPSON81IIWriteAndGetResponse CtrlSeq=" & CtrlSeq);  
LogText(0," read response=" & response);  
  EPSON81IIWriteAndGetResponse = res;
  return;
end;
  
function Integer EPSON81IIOpen(record LSerialPortDeviceVc LSPDr)
begin
  Integer res;
  
  if (OpenComPort(0,LSPDr.Port,LSPDr.BaudRate,LSPDr.Parity,LSPDr.ByteSize,LSPDr.StopBits,LSPDr.FlowControl)) then begin
    SetComPortCodepage("UTF-8");
  end else begin
    res = 1;
  end;
  EPSON81IIOpen = res;
  return;
end;

procedure EPSON81IIClose()
begin
  Integer res;

  res = CloseComPort(0);
  return;
end;

function Integer Send_InconsequentialMessages(var Integer seqnr,string operator)
begin
  Integer res,noErr;
  string 255 CtrlSeq; 
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "074";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);  

  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=noErr) then begin
    goto LSend_InconsequentialMessages;
  end;

  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=noErr) then begin
    goto LSend_InconsequentialMessages;
  end;
LSend_InconsequentialMessages:;  
  Send_InconsequentialMessages = res;
  return;
end;

function Integer DisplayText(var Integer seqnr,string operator,Integer typ,string text)
begin
  Integer res;
  string 255 CtrlSeq,tstr;
  
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "062";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & typ;
  M4PadString(text,40," ",false,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "00";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);  

  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  DisplayText = res;
  return;
end;

function Integer CheckEPSON81IIClock(var Integer seqnr)
begin
  INteger res,noErr;
  string 255 CtrlSeq,response,fpresp,tstr; 
  Date td; 
  Integer pY,pM,pD;
  LongInt pos;
  
//<COMMAND>=<0x4F><FS><Ő5Ő><FS>

  td = CurrentDate;

  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "201";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);  

  res = EPSON81IIWriteAndGetResponse(seqnr,"01",CtrlSeq,EPSON81II_DELAY,response);
    
  if (res!=noErr) then begin
    if (res>=12400) then begin
      MessageBox(0,USetStr(res));
    end else begin
      MessageBox(0,"error " & USetStr(res));
    end;
    goto LCheckEPSON81IIClock;
  end;

  pos = 0;
  GetNextSubstring(response,pos,"E",fpresp);
  GetNextSubstring(response,pos,"E",fpresp);

  fpresp = Right(fpresp,len(fpresp)-4);

  pD = StringToInt(Left(fpresp,2));
  pM = StringToInt(Mid(fpresp,2,2));
  pY = 2000+StringToInt(Mid(fpresp,4,2));
    
  if ((td.year==pY) and (td.month==pM) and (td.day==pD)) then begin
     res = noErr;
  end else begin
     MessageBox(0,USetStr(12402));
     MessageBox(0,USetStr(12403) & pY & pM & pD);
     MessageBox(0,USetStr(12404) & GetYear(td) & GetMonth(td) & GetDay(td));
     res = 12402;
  end;
LCheckEPSON81IIClock:;
  CheckEPSON81IIClock = res;
  return;
end;

function Integer LoadEPSON81IIVATRate(var Integer seqnr,string vatrate,var val vr)
begin
  INteger res,noErr;
  string 255 CtrlSeq,response,fpresp; 
  LongInt pos;

  vr = blankval;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "205";
  CtrlSeq = CtrlSeq & vatrate;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  
  res = EPSON81IIWriteAndGetResponse(seqnr,"01",CtrlSeq,EPSON81II_DELAY,response);
  if (res!=noErr) then begin
    res = 12405;
    goto LLoadEPSON81IIVATRate;
  end;
  fpresp = Mid(response,10,4);  
  vr = ValFromString(fpresp,".","")/100;

LLoadEPSON81IIVATRate:;
  LoadEPSON81IIVATRate = res;
  return;
end;

function Integer LoadEPSON81IIVATRates(var Integer seqnr,vector val vatrates)
begin
  Integer res;
  val vr;
  
  vatrates["00"] = vr;
  res = LoadEPSON81IIVATRate(seqnr,"01",vr);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LLoadEPSON81IIVATRates;
  end;
  vatrates["01"] = vr;
  res = LoadEPSON81IIVATRate(seqnr,"02",vr);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LLoadEPSON81IIVATRates;
  end;
  vatrates["02"] = vr;
  res = LoadEPSON81IIVATRate(seqnr,"03",vr);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LLoadEPSON81IIVATRates;
  end;
  vatrates["03"] = vr;
  res = LoadEPSON81IIVATRate(seqnr,"04",vr);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LLoadEPSON81IIVATRates;
  end;
  vatrates["04"] = vr;
  res = LoadEPSON81IIVATRate(seqnr,"05",vr);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LLoadEPSON81IIVATRates;
  end;
  vatrates["05"] = vr;
LLoadEPSON81IIVATRates:;
  LoadEPSON81IIVATRates = res;
  return;
end;

function Integer SetEPSON81IIVATRate(var Integer seqnr,string vatcode,val vatrate)
begin
  INteger res,noErr;
  string 255 CtrlSeq,response,tstr; 
  LongInt pos;

  tstr = ValToString(vatrate,M4Qty,"","",1);
  M4PadString(tstr,4,"0",true,tstr);          
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "005";
  CtrlSeq = CtrlSeq & vatcode;
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  
  res = EPSON81IIWriteAndGetResponse(seqnr,"01",CtrlSeq,EPSON81II_DELAY,response);
  if (res!=noErr) then begin
    res = 12405;
    goto LSetEPSON81IIVATRate;
  end;
  
LSetEPSON81IIVATRate:;

  SetEPSON81IIVATRate = res;
  return;
end;

function Integer SetEPSON81IIVATRates(var Integer seqnr)
begin
  Integer res;
  

  res = SetEPSON81IIVATRate(seqnr,"01",0);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LSetEPSON81IIVATRates;
  end;

  res = SetEPSON81IIVATRate(seqnr,"02",4);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LSetEPSON81IIVATRates;
  end;
  res = SetEPSON81IIVATRate(seqnr,"03",10);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LSetEPSON81IIVATRates;
  end;
  res = SetEPSON81IIVATRate(seqnr,"04",22);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LSetEPSON81IIVATRates;
  end;
  res = SetEPSON81IIVATRate(seqnr,"05",5);
  if (res!=0) then begin
    MessageBox(0,USetStr(res));
    goto LSetEPSON81IIVATRates;
  end;

LSetEPSON81IIVATRates:;
  SetEPSON81IIVATRates = res;
  return;
end;

function string 255 GetEPSON81IIVATGroup(string vatcode,vector val vatrates)
begin
  string 255 res;
  val vatprc,tax1;

  GetVATdouble(vatcode,vatprc,tax1,0);
  if (vatprc==vatrates["00"]) then begin 
    res = "00"; 
    goto LGetEPSON81IIVATGroup;
  end;
  if (vatprc==vatrates["01"]) then begin 
    res = "01"; 
    goto LGetEPSON81IIVATGroup;
  end;
  if (vatprc==vatrates["02"]) then begin 
    res = "02"; 
    goto LGetEPSON81IIVATGroup;
  end;
  if (vatprc==vatrates["03"]) then begin 
    res = "03"; 
    goto LGetEPSON81IIVATGroup;
  end;
  if (vatprc==vatrates["04"]) then begin 
    res = "04"; 
    goto LGetEPSON81IIVATGroup;
  end;
  if (vatprc==vatrates["05"]) then begin 
    res = "05"; 
    goto LGetEPSON81IIVATGroup;
  end;
LGetEPSON81IIVATGroup:;
  GetEPSON81IIVATGroup = res;
  return;
end;

global
procedure EPSON81IISetFiscalPrinterDepartment(record FiscalDepVc FDr,record LSerialPortDeviceVc LSPDr)
begin
  string 255 host,codepage,response;
  LongInt port;
  LongInt pos;
  Integer seqnr,noErr;
  Integer res;
  string 255 tstr,CtrlSeq,vg;
  vector val vatrates;

  seqnr = 0;
  noErr = 0;

  res = EPSON81IIOpen(LSPDr);
  if (res!=noErr) then begin
    MessageBox(21484,"");
    goto LEPSON81IISetFiscalPrinterDepartment;
  end;

  res = Send_InconsequentialMessages(seqnr,"01");
  if (res!=noErr) then begin
    MessageBox(21484,"");
    goto LEPSON81IISetFiscalPrinterDepartment;
  end;

  res = LoadEPSON81IIVATRates(seqnr,vatrates);
  if (res!=noErr) then begin
    MessageBox(21484,"");
    goto LEPSON81IISetFiscalPrinterDepartment;
  end;
  vg = GetEPSON81IIVATGroup(FDr.VATCode,vatrates);
  if (blank(vg)) then begin
    MessageBox(21484,"");
    goto LEPSON81IISetFiscalPrinterDepartment;
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "002";
  CtrlSeq = CtrlSeq & FDr.Code;
  M4PadString(FDr.Description,20," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  M4PadString("0",9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  M4PadString("0",9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  M4PadString("0",9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & vg;
  M4PadString("0",9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "00";
  CtrlSeq = CtrlSeq & "00";
  CtrlSeq = CtrlSeq & FDr.Unittext;
  CtrlSeq = CtrlSeq & "NU";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWriteAndGetResponse(seqnr,"01",CtrlSeq,EPSON81II_DELAY,response);
  if (res!=noErr) then begin
    MessageBox(21484,"");
    goto LEPSON81IISetFiscalPrinterDepartment;
  end;
  MessageBox(40410,"");
LEPSON81IISetFiscalPrinterDepartment:;      
  return;
end;

function Integer SetEPSON81IITrainingMode(var Integer seqnr)
begin
  Integer res,noErr;
  string 255 CtrlSeq,tstr; 
  LongInt pos;

  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "014";
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  
  res = EPSON81IIWrite(seqnr,"01",CtrlSeq,EPSON81II_DELAY);
  SetEPSON81IITrainingMode = res;
  return;
end;

function Integer SetEPSON81IIFiscalMode(var Integer seqnr)
begin
  Integer res,noErr;
  string 255 CtrlSeq,tstr; 
  LongInt pos;

  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "3";
  CtrlSeq = CtrlSeq & "018";
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & "1973";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  
  res = EPSON81IIWrite(seqnr,"01",CtrlSeq,EPSON81II_DELAY);
  SetEPSON81IIFiscalMode = res;
  return;
end;

function Integer BeginFiscalReceipt(var Integer seqnr,string operator,string regnr1)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;

  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "085";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=noErr) then begin
    goto LBeginFiscalReceipt;
  end;
  if (nonblank(regnr1)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "061";
    CtrlSeq = CtrlSeq & operator;
    M4PadString(regnr1,16," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);

    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  end;
LBeginFiscalReceipt:;  
  BeginFiscalReceipt = res;
  return;
end;

function Integer PrintHeader(var Integer seqnr,string operator,record MachineCashVc MCr)
begin
  string 255 CtrlSeq,tstr;
  Integer res,noErr,h;

  h = 1;
  if (nonblank(MCr.Head0)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "5";
    M4PadString(h,2,"0",true,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(MCr.Head0,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LPrintHeader;
    end;
    h = h + 1;
  end;
  if (nonblank(MCr.Head1)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "5";
    M4PadString(h,2,"0",true,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(MCr.Head1,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LPrintHeader;
    end;
    h = h + 1;
  end;
  if (nonblank(MCr.Head2)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "5";
    M4PadString(h,2,"0",true,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(MCr.Head2,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LPrintHeader;
    end;
    h = h + 1;
  end;
  if (nonblank(MCr.Head3)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "5";
    M4PadString(h,2,"0",true,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(MCr.Head3,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LPrintHeader;
    end;
    h = h + 1;
  end;
  if (nonblank(MCr.Head4)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "5";
    M4PadString(h,2,"0",true,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(MCr.Head4,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LPrintHeader;
    end;
    h = h + 1;
  end;
LPrintHeader:;  
  PrintHeader = res;
  return;
end;

function Integer BeginFiscalInvoice(var Integer seqnr,string operator,string offnr,Integer rwcnt,record MachineCashVc MCr,string vatnr,string name,string addr1,string addr2,string addr3,string addr4)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  row LegalInvNrBlock LINrbrw;
  string 255 serie,sernr;
  Integer h;

  if (nonblank(MCr.Head0)) then begin h = h + 1; end;
  if (nonblank(MCr.Head1)) then begin h = h + 1; end;
  if (nonblank(MCr.Head2)) then begin h = h + 1; end;
  if (nonblank(MCr.Head3)) then begin h = h + 1; end;
  if (nonblank(MCr.Head4)) then begin h = h + 1; end;

  GetLegalInvNrRow(offnr,LINrbrw);
  serie = GetLegalInvoiceNrSerie(LINrbrw,offnr);
  sernr = GetLegalInvoiceNrString(LINrbrw,offnr);
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "4";
  CtrlSeq = CtrlSeq & "025";
  M4PadString(sernr,4,"0",true,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "99";
  M4PadString(h,2,"0",true,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "1";
  M4PadString(" ",14," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  M4PadString(serie,10," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LBeginFiscalInvoice;
  end;

  res = PrintHeader(seqnr,operator,MCr);
  if (res!=0) then begin
    goto LBeginFiscalInvoice;
  end;


  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "078";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "6";
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & "1";
  M4PadString(name,40," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LBeginFiscalInvoice;
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "078";
  CtrlSeq = CtrlSeq & operator;
  CtrlSeq = CtrlSeq & "6";
  CtrlSeq = CtrlSeq & "01";
  CtrlSeq = CtrlSeq & "0";
  CtrlSeq = CtrlSeq & "1";
  M4PadString(vatnr,40," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LBeginFiscalInvoice;
  end;
  if (nonblank(addr1)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "6";
    CtrlSeq = CtrlSeq & "02";
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(addr1,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LBeginFiscalInvoice;
    end;
  end;
  if (nonblank(addr2)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "6";
    CtrlSeq = CtrlSeq & "03";
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(addr2,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LBeginFiscalInvoice;
    end;
  end;
  if (nonblank(addr3)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "6";
    CtrlSeq = CtrlSeq & "03";
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(addr3,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LBeginFiscalInvoice;
    end;
  end;
  if (nonblank(addr4)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "1";
    CtrlSeq = CtrlSeq & "078";
    CtrlSeq = CtrlSeq & operator;
    CtrlSeq = CtrlSeq & "6";
    CtrlSeq = CtrlSeq & "03";
    CtrlSeq = CtrlSeq & "0";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(addr4,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LBeginFiscalInvoice;
    end;
  end;


  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "089";
  CtrlSeq = CtrlSeq & operator;
//  M4PadString(sernr,5,"0",true,tstr);
  CtrlSeq = CtrlSeq & sernr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
  if (res!=0) then begin
    goto LBeginFiscalInvoice;
  end;

  if (nonblank(MCr.Foot0)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "4";
    CtrlSeq = CtrlSeq & "027";
    CtrlSeq = CtrlSeq & "1";
    M4PadString(MCr.Foot0,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LBeginFiscalInvoice;
    end;
  end;
  if (nonblank(MCr.Foot1)) then begin
    CtrlSeq = SequenceNr(seqnr);
    CtrlSeq = CtrlSeq & "E";
    CtrlSeq = CtrlSeq & "4";
    CtrlSeq = CtrlSeq & "027";
    CtrlSeq = CtrlSeq & "2";
    M4PadString(MCr.Foot1,40," ",false,tstr);
    CtrlSeq = CtrlSeq & tstr;
    CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
    res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);
    if (res!=0) then begin
      goto LBeginFiscalInvoice;
    end;
  end;

LBeginFiscalInvoice:;  
  BeginFiscalInvoice = res;
  return;
end;

function Integer IVCash_InvoiceDiscountAdditionForItem(var Integer seqnr,string operator,record IVCashVc IVCr,row IVCashVc IVCrw)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  string 255 unit;
  val v,p;
  
  CalcSum(IVCrw.Quant,IVCrw.Price,IVCrw.PriceFactor,0,v,0);
  v = v - FormulaDiscountCalcSum(IVCrw.Quant,IVCrw.Price,IVCrw.PriceFactor,IVCrw.vRebate);  
  p = CalculateDiscountPercentage(IVCrw.Quant,IVCrw.Price,IVCrw.Sum);

  unit = IVCrw.UnitCode;
  if (blank(unit)) then begin
    unit = "PCS";
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  CtrlSeq = CtrlSeq & "023";
  CtrlSeq = CtrlSeq & operator;
  tstr = ValToString(p*100,M40Val,"","",0);
  M4PadString(tstr,4,"0",true,tstr);
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);

  IVCash_InvoiceDiscountAdditionForItem = res;
  return;
end;

function Integer IVCash_PrintFiscalItemRow(var Integer seqnr,string operator,Integer typ,record IVCashVc IVCr,row IVCashVc IVCrw,vector val vatrates)
begin
  INteger res,noErr;
  string 255 CtrlSeq,tstr;
  string 255 unit;
  Boolean negtivef;
  record INVc INr;
  
  ReadFirstItem(IVCrw.ArtCode,INr,false,true);
  if (IVCrw.Quant<0) then begin
    negtivef = true;
    IVCrw.Quant = -IVCrw.Quant;
  end;
  negtivef = negtivef or IVCr.InvType==kPOSInvoiceTypeCredit;
  unit = IVCrw.UnitCode;
  if (blank(unit)) then begin
    unit = "PCS";
  end;
  CtrlSeq = SequenceNr(seqnr);
  CtrlSeq = CtrlSeq & "E";
  CtrlSeq = CtrlSeq & "1";
  if (negtivef) then begin
    CtrlSeq = CtrlSeq & "011";
  end else begin
    CtrlSeq = CtrlSeq & "005";
  end;
  CtrlSeq = CtrlSeq & operator;
  M4PadString(IVCrw.ArtCode,40," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  M4PadString(IVCrw.Spec,20," ",false,tstr);
  CtrlSeq = CtrlSeq & tstr;
  tstr = ValToString(IVCrw.Quant*1000,M40Val,"","",0);
  M4PadString(tstr,7,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & "1";
  tstr = ValToString(IVCrw.Price*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & FindFiscalDepartment(INr);
  tstr = ValToString(IVCrw.Sum*100,M40Val,"","",0);
  M4PadString(tstr,9,"0",true,tstr);          
  CtrlSeq = CtrlSeq & tstr;
  CtrlSeq = CtrlSeq & CalculateLRC(CtrlSeq);
  res = EPSON81IIWrite(seqnr,operator,CtrlSeq,EPSON81II_DELAY);

  if (res==noErr) then begin
    if (nonblank(IVCrw.vRebate)) then begin
      res = IVCash_InvoiceDiscountAdditionForItem(seqnr,operator,IVCr,IVCrw);
    end;
  end;
  
  IVCash_PrintFiscalItemRow = res;
  return;
end;

function Integer IVCash_PrintFiscalInvoiceItemRows(var Integer seqnr,string operator,Integer typ,record IVCashVc IVCr,vector val vatrates)
begin
  INteger res,noErr;
  row IVCashVc IVCrw;
  Integer i,rwcnt;

  rwcnt = MatRowCnt(IVCr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(IVCr,i,IVCrw);
    switch (IVCrw.stp) begin
      case kInvoiceRowTypeStructuredItemComponent:
        goto LkInvoiceRowTypeNormal2_A;
      case kInvoiceRowTypeNormal:
LkInvoiceRowTypeNormal2_A:;
        if (nonblank(IVCrw.ArtCode)) then begin
          res = IVCash_PrintFiscalItemRow(seqnr,operator,typ,IVCr,IVCrw,vatrates);
          if (res!=noErr) then begin
            goto LIVCash_PrintFiscalInvoiceItemRows;
          end;
        end else begin
//          res = IVCash_PrintCommentLine(seqnr,operator,IVCr,IVCrw);
          if (res!=noErr) then begin
            goto LIVCash_PrintFiscalInvoiceItemRows;
          end;
        end;
      case kInvoiceRowTypeReturnIVNr:
      case kInvoiceRowTypeVoid:
    end;
  end;
LIVCash_PrintFiscalInvoiceItemRows:;  
  IVCash_PrintFiscalInvoiceItemRows = res;
  return;
end;


