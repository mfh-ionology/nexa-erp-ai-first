procedure ShowCourseContentData(array record CourseContentVc arrCourseContentr,LongInt course)
begin
  record CourseContentVc CourseContentr;
  Integer i,filenr;
  record RLinkVc RLr;
  record Attach2Vc Attachr;
  string 255 downloadURL,baseURL,hidden,hiddeneditmode;
  transaction Boolean gEditModef;
  
  //https://www.svgrepo.com/collection/files-types/
  //https://www.svgrepo.com/collection/files-folders-4/

  baseURL = "/lms/course";

  for (i=0;i<arrCourseContentr.length;i=i+1) begin
    CourseContentr = arrCourseContentr[i];

    if (CourseContentr.Visible==0) then begin
      if (gEditModef==false) then begin
        hidden = "hidden";
      end else begin
        hiddeneditmode = "hidden-editmode";
      end;
    end;

    switch (CourseContentr.Type) begin
      case kCourseContentTypeAttendance:
        ShowCourseContentData_Attendance(CourseContentr,baseURL,course);
      case kCourseContentTypeFile:
        if (ReadRecordLink(CourseContentr,0,Attachr,RLr)) then begin
          ShowCourseContentData_File(CourseContentr,Attachr,Attachr.FileName,baseURL,GetFileExtension(Attachr.FileName),kCourseContentTypeFile,course,true);
        end;
      case kCourseContentTypeFolder:
        WebOutString("<div");
        WebOutClass("content-line",hidden);
        if (gEditModef) then begin
          WebOutString("draggable='true'");
        end;
        WebOutString("data-recordid='" & CourseContentr.SerNr & "' data-recordtype='CourseContentVc'>");
        WebOutString("<details");
        WebOutClass("",hiddeneditmode);
        WebOutString(">");
        WebOutString("<summary class='summary'>");
        WebOutString("<span class='folder-title'>" & CourseContentr.Name & "</span>");
        WebOutString("</summary>");
        filenr = 1;
        while (ReadRecordLink(CourseContentr,filenr,Attachr,RLr)) begin
          filenr = filenr + 1;
          ShowCourseContentData_File(CourseContentr,Attachr,Attachr.FileName,baseURL,GetFileExtension(Attachr.FileName),kCourseContentTypeFolder,course,false);
        end;
        WebOutString("</details>");
        ShowCourseContentEditIcons(CourseContentr.Visible,false,CourseContentr.Type,CourseContentr.SerNr);
        WebOutString("</div>");
      case kCourseContentTypeURL:
        ShowCourseContentData_URL(CourseContentr,baseURL,course);
      case kCourseContentTypeAssignment:
        ShowCourseContentData_Assignment(CourseContentr,baseURL,course);
      case kCourseContentTypeTest:
        ShowCourseContentData_Test(CourseContentr,baseURL,course);
    end;
  end;
  return;
end;

procedure GetCourseTopics(var array record WebNGLMSTopicVc arrWebNGLMSTopicr,LongInt coursenr)
begin
  Boolean foundf,testf;
  record WebNGLMSTopicVc WebNGLMSTopicr;

  foundf = true;
  WebNGLMSTopicr.Course = coursenr;
  WebNGLMSTopicr.SortOrder = 0;
  while (LoopKey("Course",WebNGLMSTopicr,3,foundf)) begin
    if (WebNGLMSTopicr.Course!=coursenr) then begin foundf = false; end;
    if (foundf) then begin
      arrWebNGLMSTopicr[arrWebNGLMSTopicr.length] = WebNGLMSTopicr;
    end;
  end;

  return;
end;

procedure CourseContentHeader(record Course2Vc Courser,string title,Boolean showeditf)
begin
  transaction Boolean gEditModef;
  string 255 headertitle;
  Boolean returnf;

  headertitle = title;
  if (blank(headertitle)) then begin
    headertitle = Courser.Name;
  end;

  WebOutString("<div class='title-container' data-recordid='" & Courser.SerNr & "' data-recordtype='Course2Vc'>");
  WebOutString("<div class='title'>");
  WebOutString("<h>" & headertitle & "</h>");
  WebOutString("</div>");
  WebOutString("<div class='toggle-edit-container'>");
  if (IsCourseTeacher(Courser.SerNr) or IsLMSAdmin) then begin
    if (showeditf) then begin
      if (gEditModef) then begin
        WebOutString("<details class='user-menu'>");
        WebOutString("<summary>");
        WebOutString("<div class='avatar-container'>");
        WebOutString("<img class='interface-icon gear' src='/images/svg/interface/gear.svg' />");
        WebOutString("</summary>");
        WebOutString("<ul>");
        WebOutString("<li><a href='/lms/courses/edit/" & Courser.SerNr & "'>Edit Settings</a></li>");
        WebOutString("<li><a href='/lms/course/" & Courser.SerNr & "/manage/users'>Manage Users</a></li>");
        WebOutString("</ul>");
        WebOutString("</details>");
      end;
      WebOutString("<button role='button' onclick=\"GoBackWithRefresh()\">Back</button>");
      if (gEditModef) then begin
        WebOutString("<button id='new-topic' role='button' onclick=\"location.href='new?fn=WebNGLMSTopicVc&parentid=" & Courser.SerNr & "';\">New Topic</button>");
      end;
      WebOutString("<button id='edit-toggle' role='button' onClick='toggleEditMode()'>Toggle Edit Mode</button>");
      returnf = true;
    end else begin
      WebOutString("<button role='button' onclick=\"GoBackWithRefresh()\">Back</button>");
      returnf = true;
    end;  
  end;
  if (returnf==false) then begin
    WebOutString("<button role='button' onclick=\"GoBackWithRefresh()\">Back</button>");
  end;
  WebOutString("</div>");
  WebOutString("</div>");

  return;
end;

procedure ContentEditHeader(record Course2Vc Courser,string title,Boolean editmodef)
begin
  transaction Boolean gEditModef;
  string 255 headertitle,buttonstr;
  Boolean returnf;

  headertitle = title;
  if (blank(headertitle)) then begin
    headertitle = Courser.Name;
  end;

  buttonstr = "Create";
  if (editmodef) then begin
    buttonstr = "Save";
  end;

  WebOutString("<div class='title-container' data-recordid='" & Courser.SerNr & "' data-recordtype='Course2Vc'>");
  WebOutString("<div class='title'>");
  WebOutString("<h>" & headertitle & "</h>");
  WebOutString("</div>");
  WebOutString("<div class='toggle-edit-container'>");
  WebOutString("<button type='submit' id='createButton'>" & buttonstr & "</button>");
  WebOutString("<button role='button' onclick=\"GoBackWithRefresh()\">Back</button>");
  WebOutString("</div>");
  WebOutString("</div>");

  return;
end;

procedure ManageUsersHeader(record Course2Vc Courser)
begin
  transaction Boolean gEditModef;
  
  WebOutString("<div class='title-container' data-recordid='" & Courser.SerNr & "' data-recordtype='Course2Vc'>");
  WebOutString("<div class='title'>");
  WebOutString("<h>" & Courser.Name & " - Enrolled Users</h>");
  WebOutString("</div>");
  WebOutString("<div class='toggle-edit-container'>");
  if (gEditModef) then begin
    WebOutString("<button role='button' onClick='unEnrolAll(\"" & Courser.SerNr & "\")'>Remove All Users</button>");
  end;
  WebOutString("<button id='edit-toggle' role='button' onClick='toggleEditMode()'>Toggle Edit Mode</button>");
  WebOutString("<button role='button' onclick=\"GoBackWithRefresh()\">Back</button>");
  WebOutString("</div>");
  WebOutString("</div>");

  return;
end;

procedure CourseContent(LongInt course)
begin
  Boolean foundf,dividerf;
  array record CourseContentVc arrCourseContentr;
  array record WebNGLMSTopicVc arrWebNGLMSTopicr;
  record WebNGLMSTopicVc WebNGLMSTopicr;
  record Course2Vc Courser;
  Integer i;
  transaction Boolean gEditModef;
  string 255 hidden,hiddeneditmode;

  Courser.SerNr = course;
  ReadFirstMain(Courser,1,true);

  GetCourseTopics(arrWebNGLMSTopicr,Courser.SerNr);

  CourseContentHeader(Courser,"",true);
  WebOutString("<div class='course-content'>");
  if (arrWebNGLMSTopicr.length==0) then begin
    WebOutString("<div class='title'>");
    WebOutString("No topics found");
    WebOutString("</div>");
    goto LCourseContent;
  end;

  for (i=0;i<arrWebNGLMSTopicr.length;i=i+1) begin
    WebNGLMSTopicr = arrWebNGLMSTopicr[i];
    GetCourseContentData(arrCourseContentr,WebNGLMSTopicr.SerNr);
    // if (arrCourseContentr.length==0) then begin goto LNextTopic; end;

    if (WebNGLMSTopicr.Visible==0) then begin
      if (gEditModef==false) then begin
        hidden = "hidden";
      end else begin
        hiddeneditmode = "hidden-editmode";
      end;
    end;

    WebOutString("<div");
    WebOutClass("content-list",hidden);
    WebOutString("data-recordid='" & WebNGLMSTopicr.SerNr & "'>");
    WebOutString("<div id='topic' class='title' data-recordid='" & WebNGLMSTopicr.SerNr & "' data-recordtype='WebNGLMSTopicVc' data-courseid='" & Courser.SerNr & "'>");
    WebOutString("<h id='topic-title'");
    WebOutClass("",hiddeneditmode);
    WebOutString(">");
    WebOutString(WebNGLMSTopicr.Desc);
    WebOutstring("</h>");
    ShowTopicEditIcons(WebNGLMSTopicr.Visible,WebNGLMSTopicr.SortOrder,course,WebNGLMSTopicr.SerNr);
    WebOutString("</div>");
    ShowCourseContentData(arrCourseContentr,Courser.SerNr);
    WebOutString("</div>");     
    if (i+1<arrWebNGLMSTopicr.length and WebNGLMSTopicr.Visible or (WebNGLMSTopicr.Visible==0 and gEditModef)) then begin ContentDivider; end; 
LNextTopic:;
  end;
LCourseContent:;
  WebOutString("</div>");
  return;
end;

function Boolean DownloadCourseContentFile(record CourseContentVc CourseContentr,string fname)
begin
  Boolean res;
  record RLinkVc RLr;
  record Attach2Vc Attachr;
  Integer i;

  while (ReadRecordLink(CourseContentr,i,Attachr,RLr)) begin
    if (Attachr.FileName==fname) then begin
      res = true;
      WebSetContentDisposition("attachment;filename=" & Attachr.FileName);
      WebSetContentType("application/" & GetFileExtension(Attachr.FileName));
      WebOutAttachment(Attachr.SerNr);
    end;
    i = i + 1;
  end;

  DownloadCourseContentFile = res;
  return;
end;

procedure WebLMSHandleContentDownload(string path)
begin
  string 255 node,mpath;
  record CourseContentVc CourseContentr;

  mpath = path;
  node = removenextnode(mpath);

  CourseContentr.SerNr = StringToLongInt(node);
  if (ReadFirstMain(CourseContentr,1,true)==false) then begin goto LWebLMSHandleContentDownload; end;
  node = removenextnode(mpath);
  node = removenextnode(mpath);

  if (DownloadCourseContentFile(CourseContentr,node)==false) then begin
    if (DownloadCourseContentFile(CourseContentr,Base64Decode(node))==false) then begin
      //todo handle error
    end;
  end;
  
LWebLMSHandleContentDownload:;
  return;
end;

procedure EmbedPodbean(string url)
begin
  record URLVc URLr;
  array string 255 aqueryparams;
  string 255 podid;
  Integer i;

  URLr.URLString = url;
  ParseURL(URLr);
  SplitString(URLr.Path,"/",aqueryparams);

  for (i=0;i<aqueryparams.length;i=i+1) begin
    if (left(aqueryparams[i],3)=="pb-") then begin
      podid = right(aqueryparams[i],len(aqueryparams[i])-3) & "-pb";
    end;
  end;

  WebOutBegin;
  <div>
    <iframe 
      title="" 
      width="800" 
      height="150"
      style="border: none; min-width: 100%;height:150px;" 
      data-name="pb-iframe-player" 
      src="https://www.podbean.com/player-v2/?i=<?var(podid)?>&from=pb6admin&share=0&download=0&rtl=0&fonts=Arial&skin=f6f6f6&font-color=auto&logo_link=none&btn-skin=3267a3" 
      loading="lazy" 
      allowfullscreen=""
      referrerpolicy="no-referrer"
    >
    </iframe>
  </div>
  EndWebOut;
  return;
end;

procedure EmbedYoutube(string url)
begin
  string 255 vid;
  Integer i;
  record URLVc URLr;
  array string 255 aqueryparams;

  URLr.URLString = url;
  ParseURL(URLr);
  SplitString(URLr.Query,"&",aqueryparams);

  for (i=0;i<aqueryparams.length;i=i+1) begin
    if (left(aqueryparams[i],2)=="v=") then begin
      vid = right(aqueryparams[i],len(aqueryparams[i])-2);
    end;
  end;

  WebOutBegin;
  <div class="mt-5">
    <iframe 
      width="560" 
      height="315" 
      src="https://www.youtube.com/embed/<?var(vid)?>" 
      title="" 
      frameborder="0" 
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
      allowfullscreen
    >
    </iframe>
  </div>
  EndWebOut;
  return;
end;

procedure EmbedURL(string url)
begin
  string 255 service;

  if (IsEmbeddable(url,service)==false) then begin
    WebOutString("<br><br>Embedding not supported for this URL (<a class='course-item' href=\"" & url & "\">" & url & "</a>)");
    goto LEmbedURL;
  end;

  WebOutString("<br><br>");

  switch (service) begin
    case "www.youtube.com": EmbedYouTube(url);
    case "www.podbean.com": EmbedPodbean(url);
  end;

LEmbedURL:;
  return;
end;

procedure ShowCourseContentDetails(string path)
begin
  string 255 node,mpath,tstr,service;
  record CourseContentVc CourseContentr;

  mpath = path;
  node = removenextnode(mpath);

  CourseContentr.SerNr = StringToLongInt(node);
  if (ReadFirstMain(CourseContentr,1,true)==false) then begin goto LShowCourseContentDetails; end;

  WebOutString("<div class='title-container'>");
  WebOutString("<h class='title'>" & CourseContentr.Name & "</h>");
  WebOutString("<div class='toggle-edit-container'>");
  WebOutString("<button role='button' onclick=\"GoBackWithRefresh()\">Back</button>");
  WebOutString("</div>");
  WebOutString("</div>");
  WebOutString("<div class='course-content'>");
  
  // WebOutText(CourseContentr,false,"");
  tstr = GetTextField(CourseContentr);
  WebOutString(CrlfStringToHtml(HTMLEncodeText(tstr)));
  
  if (CourseContentr.Type==kCourseContentTypeURL) then begin
    if ((CourseContentr.URLAppearance==kURLAppearanceEmbed or CourseContentr.URLAppearance==kURLAppearanceAutomatic)) then begin
      EmbedURL(CourseContentr.URL);
    end;
  end;

  WebOutString("</div>");
LShowCourseContentDetails:;
  return;
end;

procedure WebLMSCourseNewRecord_CourseContent(LongInt course,Integer rectype,string parentid,LongInt recnr,Boolean editmodef)
begin
  record Course2Vc Courser;
  record CourseContentVc CourseContentr;
  string 255 tstr,title;

  Courser.SerNr = course;
  ReadFirstMain(Courser,1,true);

  title = Courser.Name & " - Add Course Content";
  if (editmodef) then begin
    CourseContentr.SerNr = recnr;
    ReadFirstMain(CourseContentr,1,true);
    title = CourseContentr.Name & " - Edit";
  end;

  ContentEditHeader(Courser,title,editmodef);
  WebOutString("<form id='createCourseContent' method='post'>");
  WebOutString("<input type='hidden' id='fn' value='CourseContentVc'>");
  WebOutString("<input type='hidden' id='course' value='" & course & "'>");
  WebOutString("<input type='hidden' id='rectype' value='" & rectype & "'>");
  if (editmodef) then begin
    WebOutString("<input type='hidden' id='editmode' value='1'>");
    WebOutString("<input type='hidden' id='recnr' value='" & recnr & "'>");
  end else begin
    WebOutString("<input type='hidden' id='parentid' value='" & parentid & "'>");
    WebOutString("<input type='hidden' id='editmode' value='0'>");
  end;

  WebOutString("<div class='form-group'>");
  WebOutString("<label for='name'>Name:</label>");
  WebOutString("<input type='text' id='name' name='name' ");
  WebOutString("value='" & CourseContentr.Name & "'");
  WebOutString(">");
  WebOutString("</div>");

  if (rectype==kCourseContentTypeURL) then begin
    WebOutString("<div class='form-group'>");
    WebOutString("<label for='url'>URL:</label>");
    WebOutString("<input type='url' id='url' name='url' ");
    WebOutString("value='" & CourseContentr.URL & "'");
    WebOutString(">");
    WebOutString("</div>");

    WebOutString("<div class='form-group'>");
    WebOutString("<label for='appearance'>Appearance:</label>");
    WebOutString("<select id='appearance' name='appearance'>");


    if (CourseContentr.URLAppearance==kURLAppearanceAutomatic) then begin tstr = "selected"; end else begin tstr = ""; end;
    WebOutString("<option value='" & kURLAppearanceAutomatic & "' " & tstr & ">Automatic</option>");
    if (CourseContentr.URLAppearance==kURLAppearanceEmbed) then begin tstr = "selected"; end else begin tstr = ""; end;
    WebOutString("<option value='" & kURLAppearanceEmbed & "' " & tstr & ">Embed</option>");
    if (CourseContentr.URLAppearance==kURLAppearanceNewWindow) then begin tstr = "selected"; end else begin tstr = ""; end;
    WebOutString("<option value='" & kURLAppearanceNewWindow & "' " & tstr & ">New Window</option>");
    if (CourseContentr.URLAppearance==kURLAppearanceOpen) then begin tstr = "selected"; end else begin tstr = ""; end;
    WebOutString("<option value='" & kURLAppearanceOpen & "' " & tstr & ">Open</option>");
    if (CourseContentr.URLAppearance==kURLAppearancePopUp) then begin tstr = "selected"; end else begin tstr = ""; end;
    WebOutString("<option value='" & kURLAppearancePopUp & "' " & tstr & ">Pop-Up</option>");
    WebOutString("</select>");
    WebOutString("</div>");
  end;

  WebOutString("<div class='form-group'>");
  WebOutString("<label for='description'>Description:</label>");
  WebOutString("<textarea id='description' name='description'>");
  WebOutString(GetTextField(CourseContentr));
  WebOutString("</textarea>");
  WebOutString("</div>");

  if (rectype==kCourseContentTypeFile) then begin
    WebOutString("<div class='form-group'>");
    WebOutString("<label for='filedisplay'>Display:</label>");
    WebOutString("<select id='filedisplay' name='filedisplay'>");
    if (CourseContentr.FileDisplay==0) then begin tstr = "selected"; end else begin tstr = ""; end;
    WebOutString("<option value='0' " & tstr & ">Automatic</option>");
    if (CourseContentr.FileDisplay==1) then begin tstr = "selected"; end else begin tstr = ""; end;
    WebOutString("<option value='1' " & tstr & ">Embed</option>");
    if (CourseContentr.FileDisplay==2) then begin tstr = "selected"; end else begin tstr = ""; end;
    WebOutString("<option value='2' " & tstr & ">Force Download</option>");
    if (CourseContentr.FileDisplay==3) then begin tstr = "selected"; end else begin tstr = ""; end;
    WebOutString("<option value='3' " & tstr & ">Open</option>");
    if (CourseContentr.FileDisplay==4) then begin tstr = "selected"; end else begin tstr = ""; end;
    WebOutString("<option value='4' " & tstr & ">Pop-up</option>");
    WebOutString("</select>");
    WebOutString("</div>");

    WebOutString("<div class='form-group checkbox-group'>");
    if (CourseContentr.ShowSize==1) then begin tstr = "checked"; end else begin tstr = ""; end;
    WebOutString("<input type='checkbox' id='showsize' name='showsize' " & tstr & ">");
    WebOutString("<label for='showsize'>Show Size</label>");
    WebOutString("</div>");
    WebOutString("<div class='form-group checkbox-group'>");
    if (CourseContentr.ShowType==1) then begin tstr = "checked"; end else begin tstr = ""; end;
    WebOutString("<input type='checkbox' id='showtype' name='showtype' " & tstr & ">");
    WebOutString("<label for='showtype'>Show Type</label>");
    WebOutString("</div>");
    // WebOutString("<div class='form-group checkbox-group'>");
    // WebOutString("<input type='checkbox' id='showdate' name='showdate' ");
    // WebOutString("value='" & CourseContentr.ShowDate & "'");
    // WebOutString(">");
    // WebOutString("<label for='showdate'>Show Upload / Modified Date</label>");
    // WebOutString("</div>");

    if (editmodef==false) then begin //for now since I don't know how to edit file yet..
      WebOutString("<div class='form-group'>");
      WebOutString("<label for='fileupload'>Upload File:</label>");
      WebOutString("<input type='file' id='fileupload' name='fileupload'>");
      WebOutString("</div>");
    end;
  end;

  if (rectype==kCourseContentTypeTest) then begin
