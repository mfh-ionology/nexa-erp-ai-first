procedure ShowVisibilityIcons(Integer visible)
begin
  transaction Boolean gEditModef;

  WebOutString("<img class='interface-icon show-icon' onclick='toggleShow(this,1," & gEditModef & ")' src='/images/svg/interface/show.svg'");
  if (visible==1) then begin
    WebOutString("style='display:none;'");
  end;
  WebOutString("/>");

  WebOutString("<img class='interface-icon hide-icon' onclick='toggleShow(this,0," & gEditModef & ")' src='/images/svg/interface/hide.svg'");
  if (visible==0) then begin
    WebOutString("style='display:none;'");
  end;
  WebOutString("/>");

  return;
end;

function Boolean TopicHasContent(LongInt topic)
begin
  Boolean res;
  record CourseContentVc CourseContentr;

  CourseContentr.Topic = topic;
  if (ReadFirstKey("Topic",CourseContentr,1,true)) then begin
    res = true;
  end;

  TopicHasContent = res;
  return;
end;

procedure ShowCourseContentEditIcons(Integer visible,Boolean renamef,Integer type,LongInt recnr)
begin
  transaction Boolean gEditModef;

  if (gEditModef==false) then begin goto LShowCourseContentEditIcons; end;

  WebOutString("<div class='edit-container'>");
  Interface_EditIcon("CourseContentVc",type,recnr);
  Interface_DeleteIcon("CourseContentVc");
  ShowVisibilityIcons(visible);
  WebOutString("</div>");

LShowCourseContentEditIcons:;
  return;
end;

procedure ShowSortOrderIcons(LongInt courseId,Integer sortorder)
begin
  if (sortorder>1) then begin
    WebOutString("<img class='interface-icon arrow-up' onclick='updateTopicSortOrder(this)' src='/images/svg/interface/arrow-up.svg' />");
  end;
  if (sortorder+1<=GetLastSortOrder(courseId,"WebNGLMSTopicVc")) then begin
    WebOutString("<img class='interface-icon arrow-down' onclick='updateTopicSortOrder(this)' src='/images/svg/interface/arrow-down.svg' />");
  end;
  return;
end;

procedure ShowTopicEditIcons(Integer visible,Integer sortOrder,LongInt courseId,LongInt recnr)
begin
  transaction Boolean gEditModef;

  if (gEditModef==false) then begin goto LShowTopicEditIcons; end;

  WebOutString("<div class='edit-container'>");
  Interface_EditIcon("WebNGLMSTopicVc",0,recnr);
  Interface_DeleteIcon("WebNGLMSTopicVc");
  ShowVisibilityIcons(visible);
  ShowSortOrderIcons(courseId,sortOrder);
  WebOutString("</div>");

LShowTopicEditIcons:;
  return;
end;

procedure ShowCourseEditIcons(Integer visible,LongInt recnr)
begin
  transaction Boolean gEditModef;

  if (gEditModef==false) then begin goto LShowCourseEditIcons; end;

  WebOutString("<div class='edit-container'>");
  Interface_EditIcon("Course2Vc",0,recnr);
  Interface_DeleteIcon("Course2Vc");
  ShowVisibilityIcons(visible);
  WebOutString("</div>");
LShowCourseEditIcons:;
  return;
end;

function Boolean IsEmbeddable(string url,var string service)
begin
  Boolean res;
  record URLVc URLr;

  res = true;

  URLr.URLString = url;
  ParseURL(URLr);
  service = URLr.Host;

  switch (URLr.Host) begin
    case "www.youtube.com": 
    case "www.podbean.com":
    otherwise
      res = false;
      service = "";
      goto LIsEmbeddable;
  end;

LIsEmbeddable:;
  IsEmbeddable = res;
  return;
end;

function string 255 GetFileExtension(string fn)
begin
  string 255 res;
  Integer i;

  for (i=len(fn)-1;i>=0;i=i-1) begin
    if (mid(fn,i,1)==".") then begin
      goto Lexit;
    end;
    res = mid(fn,i,1) & res;
  end;

Lexit:;
  GetFileExtension = res;
  return;
end;

function string 255 ShowElementTranslation(string el)
begin
  string 255 res;
  Integer lcnt,i;
  record WebNGTranslateVc WTr;

  WTr.Code = el;
  if (ReadFirstMain(WTr,1,true)) then begin
    lcnt = LineTextCnt(WTr);
    for (i=0;i<lcnt;i=i+1) begin
      res = res & LineTextGet(WTr,i);
    end;
  end;

  ShowElementTranslation = res;
  return;
end;

procedure WebOutDepartmentSelection()
begin
  record DepVc Depr;
  Integer i;
  array string 255 arrCode;
  array string 255 arrName;
  string 255 tstr,department;

  department = WebGetArg("department");

  while (LoopMain(Depr,1,true)) begin
    arrCode[arrCode.length] = Depr.Code;
    arrName[arrName.length] = Depr.Description;
  end;

  if (arrCode.length==0) then begin
    tstr = "disabled";
  end;

  WebOutString("<div class='dep-sel-container'>");
  WebOutString("<label for='department'>Department:</label>");
  WebOutString("<select " & tstr & " name='department' id='department-select'>");
  if (arrCode.length>0) then begin
    WebOutString("<option value=''>All Departments</option>");
  end else begin
    WebOutString("<option value=''>No Departments</option>");
  end;
  for (i=0;i<arrCode.length;i=i+1) begin
    tstr = "";
    if (department==arrCode[i]) then begin
      tstr = "selected";
    end;
    WebOutString("<option value='" & arrCode[i] & "' " & tstr & ">" & arrName[i] & "</option>");
  end;
  WebOutString("</select>");
  WebOutString("</div>");

  return;
end;

procedure WebOutTeacherSelection()
begin
  record CUVc CUr;
