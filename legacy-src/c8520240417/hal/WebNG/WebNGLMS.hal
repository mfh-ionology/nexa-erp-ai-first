procedure WebLMSCourseNewRecord_Topic(LongInt course,string parentid,LongInt recnr,Boolean editmodef)
begin
  record Course2Vc Courser;
  record WebNGLMSTopicVc WebNGLMSTopicr;
  string 255 tstr;

  Courser.SerNr = course;
  ReadFirstMain(Courser,1,true);

  WebNGLMSTopicr.SerNr = recnr;
  ReadFirstMain(WebNGLMSTopicr,1,true);

  ContentEditHeader(Courser,Courser.Name & " - Add Topic",editmodef);
  WebOutString("<form id='createTopic' method='post'>");
  if (editmodef) then begin
    WebOutString("<input type='hidden' id='editmode' value='1'>");
    WebOutString("<input type='hidden' id='recnr' value='" & recnr & "'>");
  end else begin
    WebOutString("<input type='hidden' id='parentid' value='" & parentid & "'>");
    WebOutString("<input type='hidden' id='editmode' value='0'>");
    WebOutString("<input type='hidden' id='course' value='" & course & "'>");
  end;
  WebOutString("<input type='hidden' id='fn' value='WebNGLMSTopicVc'>");
 
  WebOutString("<div class='form-group'>");
  WebOutString("<label for='name'>Name:</label>");
  WebOutString("<input type='text' id='name' name='name' ");
  WebOutString("value='");
  if (editmodef) then begin
    WebOutString(WebNGLMSTopicr.Desc);
  end;
  WebOutString("'>");
  WebOutString("</div>");

  WebOutString("<div class='form-group checkbox-group'>");
  if (editmodef==false) then begin
    tstr = "checked";
  end else begin
    if (WebNGLMSTopicr.Visible==1) then begin
      tstr = "checked";
    end else begin
      tstr = "";
    end;
  end;
  WebOutString("<input type='checkbox' id='visible' name='visible' " & tstr & ">");
  WebOutString("<label for='visible'>Visible</label>");
  WebOutString("</div>");
  WebOutString("</form>");
  return;
end;

procedure WebLMSCourseNewRecord(LongInt course,string node,Boolean editmodef)
begin
  string 255 fn,parentid,recnr;
  Integer rectype;
  LongInt pos;

  fn = WebGetArg("fn");
  rectype = StringToInt(WebGetArg("rectype"));
  parentid = WebGetArg("parentid");

  pos = 0;
  GetNextSubString(node,pos,"?",recnr);
  switch (fn) begin
    case "CourseContentVc": WebLMSCourseNewRecord_CourseContent(course,rectype,parentid,StringToLongInt(recnr),editmodef);
    case "WebNGLMSTopicVc": WebLMSCourseNewRecord_Topic(course,parentid,StringToLongInt(recnr),editmodef);
  end;  

  return;
end;

procedure WebLMSManageCourseUsers(LongInt course)
begin
  record Course2Vc Courser;
  record StudentCourseVc StudentCourser;
  record CUVc CUr;
  Boolean foundf;
  array string 255 arrStudent,arrStudentName;
  array LongInt arrSerNr;
  array string 255 arrAvailableFromDate,arrAvailableFromTime;
  array string 255 arrAvailableToDate,arrAvailableToTime;
  array Integer arrApproved;
  Integer i;
  transaction Boolean gEditModef;
  string 255 tstr;

  Courser.SerNr = course;
  ReadFirstMain(Courser,1,true);

  ManageUsersHeader(Courser);
  WebOutString("<div class='course-content'>");

  foundf = true;
  StudentCourser.Course = Courser.SerNr;
  while (LoopKey("Course",StudentCourser,1,foundf)) begin
    if (StudentCourser.Course!=Courser.SerNr) then begin foundf = false; end;
    if (foundf) then begin
      arrStudent[arrStudent.length] = StudentCourser.Student;
      arrStudentName[arrStudentName.length] = StudentCourser.StudentName;
      arrSerNr[arrSerNr.length] = StudentCourser.SerNr;
      arrAvailableFromDate[arrAvailableFromDate.length] = StudentCourser.StartDate;
      arrAvailableFromTime[arrAvailableFromTime.length] = StudentCourser.StartTime;
      arrAvailableToDate[arrAvailableToDate.length] = StudentCourser.EndDate;
      arrAvailableToTime[arrAvailableToTime.length] = StudentCourser.EndTime;
      arrApproved[arrApproved.length] = StudentCourser.Approved;
    end;
  end;


  if (arrStudent.length==0 and gEditModef==false) then begin
    WebOutString("<div class='title'>");
    WebOutString("No users enrolled");
    WebOutString("</div>");
    goto LWebLMSManageCourseUsers;
  end;

  WebOutString("<table border='1'>");
  WebOutString("<thead>");
  WebOutString("<tr>");
  WebOutString("<th>Name</th>");
  WebOutString("<th>From Date</th>");
  WebOutString("<th>From Time</th>");
  WebOutString("<th>To Date</th>");
  WebOutString("<th>To Time</th>");
  WebOutString("<th>Status</th>");
  if (gEditModef) then begin
    WebOutString("<th></th>");
  end;
  WebOutString("</tr>");
  WebOutString("</thead>");
  WebOutString("<tbody>");
  for (i=0;i<arrStudent.length;i=i+1) begin
    WebOutString("<tr data-rownr='" & i & "'>");
    WebOutString("<td>");
    WebOutString(arrStudentName[i]);
    WebOutString("</td>");
    WebOutString("<td>");
    if (gEditModef) then begin
      WebOutString("<input type='date' id='availableFromDate' name='availableFromDate' ");
      WebOutString("value='" & arrAvailableFromDate[i] & "'");
      WebOutString(">");
    end else begin
      if (blank(arrAvailableFromDate[i])) then begin
        WebOutString("-");
      end else begin
        WebOutString(arrAvailableFromDate[i]);
      end;
    end;
    WebOutString("</td>");
    WebOutString("<td>");
    if (gEditModef) then begin
      WebOutString("<input type='time' id='availableFromTime' name='availableFromTime' ");
      WebOutString("value='" & arrAvailableFromTime[i] & "'");
      WebOutString(">");
    end else begin
      if (blank(arrAvailableFromTime[i])) then begin
        WebOutString("-");
      end else begin
        WebOutString(arrAvailableFromTime[i]);
      end;
    end;
    WebOutString("</td>");
    WebOutString("<td>");
    if (gEditModef) then begin
      WebOutString("<input type='date' id='availableToDate' name='availableToDate' ");
      WebOutString("value='" & arrAvailableToDate[i] & "'");
      WebOutString(">");
    end else begin
      if (blank(arrAvailableToDate[i])) then begin
        WebOutString("-");
      end else begin
        WebOutString(arrAvailableToDate[i]);
      end;
    end;
    WebOutString("</td>");
    WebOutString("<td>");
    if (gEditModef) then begin
      WebOutString("<input type='time' id='availableToTime' name='availableToTime' ");
      WebOutString("value='" & arrAvailableToTime[i] & "'");
      WebOutString(">");
    end else begin
      if (blank(arrAvailableToTime[i])) then begin
        WebOutString("-");
      end else begin
        WebOutString(arrAvailableToTime[i]);
      end;
    end;
    WebOutString("</td>");
    tstr = "Not Approved";
    if (arrApproved[i]) then begin
      tstr = "Approved";
    end;
    WebOutString("<td class='" & "approval-status-" & arrApproved[i] & "'>");
    WebOutString(tstr);
    WebOutString("</td>");
    if (gEditModef) then begin
      WebOutString("<td>");
      WebOutString("<div class='toggle-edit-container'>");
      if (arrApproved[i]==0) then begin
        tstr = "Approve";
      end else begin
        tstr = "Save";
      end;
      WebOutString("<button type='button' id='updateStudentButton' data-rownr='" & i & "' data-recordid='" & arrSerNr[i] & "' onclick='updateStudent(this,1)'>" & tstr & "</button>");
      WebOutString("<button type='button' data-rownr='" & i & "' data-recordid='" & arrSerNr[i] & "' onclick='unEnrolStudent(this)'>Remove</button>");
      WebOutString("</div>");
      WebOutString("</td>");
    end;
    WebOutString("</tr>");
  end;
  
  if (gEditModef) then begin
    WebOutString("<tr>");
    WebOutString("<td>");
    WebOutString("<select id='newstudent' name='newstudent'>");
    Select_Student;
    WebOutString("</select>");
    WebOutString("</td>");
    WebOutString("<td>");
    WebOutString("<input type='date' id='availableFromDate' name='availableFromDate'>");
    WebOutString("</td>");
    WebOutString("<td>");
    WebOutString("<input type='time' id='availableFromTime' name='availableFromTime'>");
    WebOutString("</td>");
    WebOutString("<td>");
    WebOutString("<input type='date' id='availableToDate' name='availableToDate'>");
    WebOutString("</td>");
    WebOutString("<td>");
    WebOutString("<input type='time' id='availableToTime' name='availableToTime'>");
    WebOutString("</td>");
    WebOutString("<td class='approval-status-1'>");
    WebOutString("Approved");
    WebOutString("</td>");
    WebOutString("<td>");
    WebOutString("<button id='addStudentButton' type='button' data-courseid='" & Courser.SerNr & "' onclick='addStudent(this)''>Add</button>");
    WebOutString("</td>");
    WebOutString("</tr>");
  end;
  WebOutString("</tbody>");
  WebOutString("</table>");

LWebLMSManageCourseUsers:;
  WebOutString("</div>");
  return;
end;

procedure WebLMSCourseRegister(LongInt course)
begin
  record Course2Vc Courser;
  string 255 tstr;
  Boolean applyf;

  Courser.SerNr = course;
  ReadFirstMain(Courser,1,true);

  CourseContentHeader(Courser,Courser.Name & " - Enrol",false);
  applyf = Courser.AllowApplications;

  WebOutString("<form id='enrolStudent' method='post'>");
  WebOutString("<input type='hidden' id='course' value='" & Courser.SerNr & "'>");
  WebOutString("<input type='hidden' id='student' value='" & CurrentCust & "'>");
  if (Courser.EnableSelfEnrol==1) then begin
    WebOutString("<div>");
    WebOutString("<label for='regkey'>Registration Key:</label>");
    WebOutString("<input type='text' id='regkey' name='regkey'>");
    WebOutString("</div>");
    WebOutString("<div class='form-group'>");
    WebOutString("<button id='enrolButton' data-apply='0' type='submit'>Enrol</button>"); //submits twice, to fix
    WebOutString("</div>");
  end;
  if (StudentPendingApproval(CurrentCust,course)==false) then begin
    if (applyf) then begin
      WebOutString("<div>");
      WebOutString("<p>Apply for this Course</p>")
      WebOutString("</div>");
      WebOutString("<div class='form-group'>");
      WebOutString("<button id='applyButton' data-apply='1' type='submit'>Apply</button>"); //submits twice, to fix
      WebOutString("</div>");
    end;
  end else begin
    WebOutString("<div>");
    WebOutString("<p>Application Pending Approval</p>")
    WebOutString("</div>");
  end;
  WebOutString("</form>");

  return;
end;

procedure WebLMSCourse(record OnlineLearningBlock OLb,LongInt course,string path)
begin
  string 255 node,mpath,mpath2,tstr,link,childnode;
  record WebNGPageVc WPr;
  Boolean foundf;
  transaction Boolean gEditModef;

  mpath = path;
  node = removenextnode(mpath);
  mpath2 = mpath;

  if (WebGetArg("edit")=="true" and (IsLMSAdmin or IsCourseTeacher(course))) then begin
    gEditModef = true;
  end;  

  switch (node) begin
    case "overview":
    case "new":     childnode = node;
    case "edit":    childnode = node;
    case "manage":  childnode = removenextnode(mpath2);
    case "content": 
      childnode = removenextnode(mpath2);
      childnode = removenextnode(mpath2);
      if (childnode=="download") then begin
        WebLMSHandleContentDownload(mpath);
      end;
    case "test":
      // logtext(0,"mpath=" & mpath & ", mpath2=" & mpath2 & ", path=" & path & ", node=" & node);
      switch (mpath) begin
        case "WebHWULMSTARRefresh":  WebHWULMSTARRefresh;
        case "WebHWULMSTestNavigate": WebHWULMSTestNavigate;
        otherwise
           WebHWULMSTest(StringToLongInt(mpath));
      end;
      goto LWebLMSCourse;
    case "register":  childnode = node;
    otherwise
      link = FormatSimpleLink("/lms/course/" & course & "/overview",true);
      RedirectToURL(link);
  end;

  WPr.Code = OLb.PageCourse;
  if (ReadFirstMain(WPr,1,true)) then begin
    ShowWebAppPageStart(WPr,"");
    ShowWebElementTemplate(OLb.ElementCourse,0);
    WebOutString("<div class='content-container'>");
    WebOutString("<div class='course-content-wrapper'>");
    switch (childnode) begin      
      case "details":   ShowCourseContentDetails(mpath);
      case "new":       WebLMSCourseNewRecord(course,-1,false);
      case "edit":      WebLMSCourseNewRecord(course,removenextnode(mpath2),true);
      case "users":     WebLMSManageCourseUsers(course);
      case "register":  WebLMSCourseRegister(course);
      otherwise 
        CourseContent(course);
    end;
    WebOutString("</div>");
    WebOutString("</div>");
  end else begin
    //ERROR PAGE NOT DEFINED
  end;

LWebLMSCourse:;
  return;
end;

procedure WebLMSCourseNew(LongInt coursenr,Boolean editmodef)
begin
  record Course2Vc Courser;
  string 255 title,tstr;
  LongInt pos;

  title = "Add New Course";
  if (editmodef) then begin
    Courser.SerNr = coursenr;
    ReadFirstMain(Courser,1,true);
    title = Courser.Name & " - Edit";
  end;

  WebOutString("<div class='content-container'>");
  WebOutString("<div class='course-content-wrapper'>");
  ContentEditHeader(Courser,title,editmodef);
  WebOutString("<form id='createCourse' method='post'>");
  if (editmodef) then begin
    WebOutString("<input type='hidden' id='editmode' value='1'>");
    WebOutString("<input type='hidden' id='recnr' value='" & coursenr & "'>");
  end;
  WebOutString("<div class='form-group'>");
  WebOutString("<label for='name'>Name:</label>");
  WebOutString("<input type='text' id='name' name='name' ");
  WebOutString("value='" & Courser.Name & "'");
  WebOutString(">");
  WebOutString("</div>");

  WebOutString("<div class='date-time-group'>");
  WebOutString("<div>");
  WebOutString("<label for='startdate'>Start Date:</label>");
  WebOutString("<input type='date' id='startdate' name='startdate' ");
  WebOutString("value='" & Courser.StartDate & "'");
  WebOutString(">");
  WebOutString("</div>");
  WebOutString("<div>");
  WebOutString("<label for='enddate'>End Date:</label>");
  WebOutString("<input type='date' id='enddate' name='enddate' ");
  WebOutString("value='" & Courser.EndDate & "'");
  WebOutString(">");
  WebOutString("</div>");
  WebOutString("</div>");

  WebOutString("<div class='select-group'>");
  WebOutString("<div class='form-group'>");
  WebOutString("<label for='coursetype'>Type:</label>");
  WebOutString("<select id='coursetype' name='coursetype'>");
  Select_CourseType(Courser.Type,editmodef);
  WebOutString("</select>");
  WebOutString("</div>");

  // WebOutString("<div class='form-group'>");
  // WebOutString("<label for='acttype'>Act. Type:</label>");
  // WebOutString("<select id='acttype' name='acttype'>");
  // Select_ActivityType(Courser.ActType,editmodef);
  // WebOutString("</select>");
  // WebOutString("</div>");

  WebOutString("<div class='tags-input-container'>");
  WebOutString("<label for='classification'>Classifications:</label>");
  WebOutString("<select id='classification-form-select'>");
  Select_Classification;
  WebOutString("</select>");
  WebOutString("<div id='classification-list'>");
  if (editmodef) then begin
    pos = 0;
    while (GetNextSubString(Courser.Classification,pos,",",tstr)) begin
      WebOutString("<span class='classification'>");
      WebOutString(tstr);
      WebOutString("<span id='remove-classification'>X</span>");
      WebOutString("</span>");
    end;
  end;
  WebOutString("</div>");
  WebOutString("</div>");
  WebOutString("</div>");

  WebOutString("<div class='form-group'>");
  WebOutString("<label for='description'>Description:</label>");
  WebOutString("<textarea id='description' name='description'>");
  WebOutString(GetTextField(Courser));
  WebOutString("</textarea>");
  WebOutString("</div>");

  WebOutString("<div class='select-group'>");
  WebOutString("<div class='tags-input-container'>");
  WebOutString("<label for='teacher'>Teachers:</label>");
  WebOutString("<select id='teacher-form-select'>");
  Select_Teacher;
  WebOutString("</select>");
  WebOutString("<div id='teacher-list'>");
  if (editmodef) then begin
    pos = 0;
    while (GetNextSubString(Courser.Teachers,pos,",",tstr)) begin
      WebOutString("<span class='teacher'>");
      WebOutString(tstr);
      WebOutString("<span id='remove-teacher'>X</span>");
      WebOutString("</span>");
    end;
  end;
  WebOutString("</div>");
  WebOutString("</div>");

  WebOutString("<div class='tags-input-container'>");
  WebOutString("<label for='department'>Departments:</label>");
  WebOutString("<select id='department-form-select'>");
  Select_Department;
  WebOutString("</select>");
  WebOutString("<div id='department-list'>");
  if (editmodef) then begin
    pos = 0;
    while (GetNextSubString(Courser.Departments,pos,",",tstr)) begin
      WebOutString("<span class='department'>");
      WebOutString(tstr);
      WebOutString("<span id='remove-department'>X</span>");
      WebOutString("</span>");
    end;
  end;
  WebOutString("</div>");
  WebOutString("</div>");

  // WebOutString("<div class='form-group'>");
  // WebOutString("<label for='responsible'>Responsible:</label>");
  // WebOutString("<select id='responsible' name='responsible'>");
  // Select_Responsible(Courser.Responsible,editmodef);
  // WebOutString("</select>");
  // WebOutString("</div>");
  WebOutString("</div>");

  WebOutString("<div class='form-group checkbox-group'>");
  if (editmodef==false) then begin
    tstr = "checked";
  end else begin
    if (Courser.Visibility==1) then begin
      tstr = "checked";
    end else begin
      tstr = "";
    end;
  end;
  WebOutString("<input type='checkbox' id='visible' name='visible' " & tstr & ">");
  WebOutString("<label for='visible'>Visible</label>");
  WebOutString("</div>");

  WebOutString("<fieldset>");
  WebOutString("<legend>Format</legend>");
  if (Courser.Format==0) then begin tstr = "checked"; end else begin tstr = ""; end;
  WebOutString("<label><input type='radio' name='format' value='0' " & tstr & "> Single Activity Format</label>");
  if (Courser.Format==1) then begin tstr = "checked"; end else begin tstr = ""; end;
  WebOutString("<label><input type='radio' name='format' value='1' " & tstr & "> Topics Format</label>");
  if (Courser.Format==2) then begin tstr = "checked"; end else begin tstr = ""; end;
  WebOutString("<label><input type='radio' name='format' value='2' " & tstr & "> Weekly Format</label>");
  WebOutString("</fieldset>");

  WebOutString("<fieldset>");
  WebOutString("<legend>Groups</legend>");
  if (Courser.Groups==0) then begin tstr = "checked"; end else begin tstr = ""; end;
  WebOutString("<label><input type='radio' name='groups' value='0' " & tstr & "> No Group</label>");
  if (Courser.Groups==1) then begin tstr = "checked"; end else begin tstr = ""; end;
  WebOutString("<label><input type='radio' name='groups' value='1' " & tstr & "> Separate Groups</label>");
  WebOutString("</fieldset>");
  WebOutString("<div class='form-group checkbox-group'>");
  WebOutString("<input type='checkbox' id='selfenrol' name='selfenrol' ");
  if (Courser.EnableSelfEnrol==1) then begin 
    WebOutString("checked"); 
  end;
  WebOutString(">");
  WebOutString("<label for='selfenrol'>Enable Self Enrolment</label>");
  WebOutString("</div>");
  WebOutString("<div class='form-group checkbox-group'>");
  WebOutString("<input type='checkbox' id='allowapplications' name='allowapplications' ");
  if (Courser.AllowApplications==1) then begin 
    WebOutString("checked"); 
  end;
  WebOutString(">");
  WebOutString("<label for='allowapplications'>Allow Applications</label>");
  WebOutString("</div>");

  WebOutString("<div class='form-group'>");
  WebOutString("<label for='regkey'>Registration Key:</label>");
  WebOutString("<input type='text' id='regkey' name='regkey' ");
  WebOutString("value='" & Courser.RegKey & "'");
  WebOutString(">");
  WebOutString("</div>");
  WebOutString("</form>");
  WebOutString("</div>");
  WebOutString("</div>");
  return;
end;

procedure WebLMSCourses(record OnlineLearningBlock OLb,string path)
begin
  string 255 node,mpath,tstr;
  record WebNGPageVc WPr;
  record CourseContentVc CourseContentr;
  Boolean foundf;
  transaction Boolean gEditModef;

  mpath = path;
  node = removenextnode(mpath);
  node = removenextnode(mpath);

  WPr.Code = OLb.PageCourses;
  if (ReadFirstMain(WPr,1,true)) then begin
    ShowWebAppPageStart(WPr,"");
    ShowWebElementTemplate(OLb.ElementCourses,0);
    WebOutString("<div class='content-container'>");
    switch (node) begin
      case "new":     WebLMSCourseNew(-1,false);
      case "edit":    WebLMSCourseNew(StringToLongInt(mpath),true);
      otherwise
        WebOutString("<div class='course-list-wrapper'>");
        WebOutString("<div class='course-list-header'>");
        WebOutString("<div class='filter-wrapper'>");
        WebOutDepartmentSelection;
        if (IsTeacher==false) then begin
          WebOutTeacherSelection;
        end;
        WebOutString("</div>");
        if (IsLMSAdmin) then begin
          WebOutString("<div class='toggle-edit-container'>");
          if (gEditModef) then begin
            WebOutString("<button id='new-course' role='button' onclick=\"location.href='/lms/courses/new?fn=Course2Vc'\">New Course</button>");
          end;
          WebOutString("<button id='edit-toggle' role='button' onClick='toggleEditMode()'>Toggle Edit Mode</button>");
          WebOutString("</div>");
        end;
        WebOutString("</div>");
        WebOutString("<div id='course-list'>");
        WebOutCourseList;
        WebOutString("</div>");
        WebOutString("</div>");
    end;
    WebOutString("</div>");
  end else begin
    //ERROR PAGE NOT DEFINED
  end;
   
  return;
end;

procedure WebNGLMSLoginPage(record OnlineLearningBlock OLb)
begin
  record WebNGPageVc WPr;
  record CourseContentVc CourseContentr;
  Boolean foundf;
  string 255 failed;

  failed = WebGetArg("failed");

  WPr.Code = "LMS-LOGIN";
  if (ReadFirstMain(WPr,1,true)) then begin
    ShowWebAppPageStart(WPr,"");
    WebOutString("<div class=\"login-container\">");
    WebOutString("<form class=\"login-form\" action=\"" & FormatLink("/dologin","",true,true) & "\" method=\"post\">");
    WebOutStringFormatNL("<input type=""hidden"" id=""company"" name=""company"" value=\"1\">");
    WebOutStringFormatNL("<input type=""hidden"" id=""failed"" name=""failed"" value=""" & FormatLink("/lms/login","action=afterlogin&failed=1",true,true) & """>");
    WebOutStringFormatNL("<input type=""hidden"" id=""custpage"" name=""custpage"" value=""" & FormatLink("/lms/login","action=afterlogin&cust=1",true,true) & """>");
    WebOutStringFormatNL("<input type=""hidden"" id=""userpage"" name=""userpage"" value=""" & FormatLink("/lms/login","action=afterlogin&user=1",true,true) & """>");
    WebOutString("<h2>Login</h2>");
    WebOutString("<div class=\"form-group\">");
    WebOutString("<label for=\"username\">Email</label>");
    WebOutString("<input type=\"text\" id=\"login\" name=\"login\" required>");
    WebOutString("</div>");
    WebOutString("<div class=\"form-group\">");
    WebOutString("<label for=\"password\">Password</label>");
    WebOutString("<input type=\"password\" id=\"passwd\" name=\"passwd\" required>");
    WebOutString(" </div>");
    WebOutString("<button type=\"submit\" class=\"login-button\">Login</button>");
    if (nonblank(failed)) then begin
      WebOutString("<div class=\"login-error\">");
      WebOutString("Wrong email addres or password");
      WebOutString("</div>");
    end;  
    WebOutString("</form>");
    WebOutString("</div>");
  end else begin
    //ERROR PAGE NOT DEFINED
  end;
   
  return;
end;

function Boolean CourseDisplayTest(LongInt course,string node,var Boolean availablef)
begin
  Boolean res;

  res = true;
  if (course==-1) then begin
    res = false;
    goto LCourseDisplayTest;
  end;
  if (HasCourseAccess(course,node,availablef)==false) then begin
    res = false;
    goto LCourseDisplayTest;
  end;

LCourseDisplayTest:;
  if (res==false) then begin
    RedirectToURL(FormatSimpleLink("/lms/courses",true));
  end;
  CourseDisplayTest = res;
  return;
end;

global
updating procedure LMSCoursesApp(record WebNGStructVc WSr,string path)
begin
  string 255 node,mpath,tstr;
  string 255 course;
  record OnlineLearningBlock OLb;
  record WebNGPageVc WPr;
  transaction string 255 gExtraHeadHTML;
  transaction Boolean gEditModef;
  Boolean availablef,testf;

  BlockLoad(OLb);

  if (OLb.Active==0) then begin 
    goto LLMSCoursesApp; 
  end;

  if (WebGetArg("edit")=="true" and IsLMSAdmin) then begin
    gEditModef = true;
  end;  

  gExtraHeadHTML = LMSAppHead;

  mpath = path;
  node = removenextnode(mpath);

  if (LMSUserLoggedIn==false and node!="login") then begin
    RedirectToURL(FormatSimpleLink("/lms/login",true));
  end;

  switch (node) begin
    case "login":
      if (LMSUserLoggedIn) then begin
        RedirectToURL(FormatSimpleLink("/lms/courses",true));
      end else begin
        WebNGLMSLoginPage(OLb);
      end;
    case "logout": 
      WebLogOut;
      RedirectToURL(FormatSimpleLink("/lms/courses",true));
    case "ajax": WebLMSCourseAction(path);
    case "course":
      node = StringToLongInt(removenextnode(mpath));
      testf = CourseDisplayTest(node,mpath,availablef);
      if (availablef) then begin
        WebLMSCourse(OLb,node,mpath);
      end else begin
        RedirectToURL(FormatSimpleLink("/lms/courses",true));
      end;
    case "courses": WebLMSCourses(OLb,path);
    otherwise
      if (LMSUserLoggedIn) then begin
        RedirectToURL(FormatSimpleLink("/lms/courses",true));
      end;
  end;

  //function string 255 FormatSimpleLink(string path,boolean callfromweb);

  // ShowWebAppPageEnd(WPr);

LLMSCoursesApp:;
  return;
end;

global
procedure ShowLMSSidebarContent()
begin
  record Course2Vc Courser;
  Boolean testf,availablef;

  WebOutString("<div class='sidebar-item'>");
  WebOutString("<a href='" & FormatSimpleLink("/lms",true) & "'>");
  WebOutString("Home");
  WebOutString("</a>");
  WebOutString("</div>");

  while (LoopMain(Courser,1,true)) begin
    testf = true;
    if (Courser.Visibility==0) then begin testf = false; end;
    if (Courser.Terminated==1) then begin testf = false; end;
    if (DateInRange(CurrentDate,Courser.StartDate,Courser.EndDate)==false) then begin testf = false; end;
    if (IsLMSAdmin==false and IsEnrolledStudent(Courser.SerNr,availablef)==false and SetInSet2(CurrentCust,Courser.Teachers)==false) then begin testf = false; end;
    if (testf and availablef) then begin
      WebOutString("<div class='sidebar-item'>");
      WebOutString("<a href='" & FormatSimpleLink("/lms/course/" & Courser.SerNr & "/overview",true) & "'>");
      WebOutString(Courser.Name);
      WebOutString("</a>");
      WebOutString("</div>");
    end;
  end;
  return;
end;

global
