begin
  if (LMSUserLoggedIn) then begin
    WebOutString("<div class='user-name'>" & LMSUserName & "</div>");
    WebOutString("<details class='user-menu'>");
    WebOutString("<summary>");
    WebOutString("<div class='avatar-container'>");
    WebOutString("<svg fill='currentColor' viewBox='0 0 20 20' xmlns='http://www.w3.org/2000/svg'>");
    WebOutString("<path fill-rule='evenodd' d='M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z' clip-rule='evenodd'></path>");
    WebOutString("</svg>");
    WebOutString("</summary>");
    WebOutString("<ul>");
    WebOutString("<li><a href='#'>Change Password</a></li>");
    WebOutString("<li><a href='/lms/logout'>Logout</a></li>");
    WebOutString("</ul>");
    WebOutString("</details>");
    WebOutString("</div>");
  end;
  return;
end;
