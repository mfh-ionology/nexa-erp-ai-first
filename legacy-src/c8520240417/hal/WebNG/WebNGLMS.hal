procedure GetCourseContentData(var array record CourseContentVc arrCourseContentr,LongInt topic)
begin
  Boolean foundf,testf;
  record CourseContentVc CourseContentr;

  ClearArray(arrCourseContentr);

  foundf = true;
  CourseContentr.Topic = topic;
  CourseContentr.SortOrder = 0;
  while (LoopKey("Topic",CourseContentr,2,foundf)) begin
    if (CourseContentr.Topic!=topic) then begin foundf = false; end;
    if (foundf) then begin
      testf = true;
      if (CourseContentr.Type==kCourseContentTypeTest) then begin
        if (blank(CourseContentr.Test)) then begin testf = false; end;
      end;
      // if (CourseContentr.Visible==0) then begin testf = false; end;
      if (testf) then begin
        arrCourseContentr[arrCourseContentr.length] = CourseContentr;
      end;
    end;
  end;
  return;
end;

procedure ShowCourseContentData_File(record CourseContentVc CourseContentr,record Attach2Vc Attachr,string fname,string baseURL,string ext,Integer source,LongInt course,Boolean showrecordidf)
begin
  string 255 downloadURL,hidden,hiddeneditmode;
  transaction Boolean gEditModef;

  downloadURL = baseURL & "/" & course & "/content/" & CourseContentr.SerNr & "/download/" & Base64EncodeURL(Attachr.FileName);

  if (CourseContentr.Visible==0) then begin
    if (gEditModef==false) then begin
      hidden = "hidden";
    end else begin
      if (showrecordidf) then begin
        hiddeneditmode = "hidden-editmode";
      end;
    end;
  end;

  WebOutString("<div");
  WebOutClass("content-line",hidden);
    if (gEditModef) then begin
    WebOutString("draggable='true'");
  end;
  if (gEditModef==false) then begin
    WebOutString("onclick=\"location.href='" & downloadURL & "';\"");
  end;
  if (showrecordidf) then begin
    WebOutString("data-recordid='" & CourseContentr.SerNr & "' data-recordtype='CourseContentVc'");
  end;
  WebOutString(">");
  if (CourseContentr.ShowType and ext!="") then begin
    WebOutString("<img src='/images/svg/files/" & LowerCase(ext) & ".svg'");
    WebOutClass("content-icon",hiddeneditmode);
    WebOutString("/>");
  end;
  WebOutString("<p");
  WebOutClass("",hiddeneditmode);
  WebOutString(">");
  WebOutString(fname);
  WebOutString("</p>");
  if (CourseContentr.ShowSize) then begin
    WebOutString("<p");
    WebOutClass("file-size",hiddeneditmode);
    WebOutString(">");
    WebOutString(Attachr.FileSize & " KB)");
    WebOutString("</p>");
  end;
  if (showrecordidf) then begin
    ShowCourseContentEditIcons(CourseContentr.Visible,false,CourseContentr.Type,CourseContentr.SerNr);
  end;
  WebOutString("</div>");
  return;
end;

function Integer AutomaticURLAppearance(string url)
begin
  Integer res;
  string 255 service;

  if (IsEmbeddable(url,service)) then begin
    res = kURLAppearanceEmbed;
  end else begin
    res = kURLAppearanceNewWindow;
  end;

  AutomaticURLAppearance = res;
  return;
end;

procedure ShowCourseContentData_URL(record CourseContentVc CourseContentr,string baseURL,LongInt course)
begin
  string 255 url,hidden,hiddeneditmode;
  transaction Boolean gEditModef;

  if (CourseContentr.Visible==0) then begin
    if (gEditModef==false) then begin
      hidden = "hidden";
    end else begin
      hiddeneditmode = "hidden-editmode";
    end;
  end;

  WebOutString("<div");
  WebOutClass("content-line",hidden);
  if (gEditModef) then begin
    WebOutString("draggable='true'");
  end;
  if (gEditModef==false) then begin
    url = CourseContentr.URL;
    if (CourseContentr.URLAppearance==kURLAppearanceAutomatic) then begin
      CourseContentr.URLAppearance = AutomaticURLAppearance(CourseContentr.URL);
    end;
    switch (CourseContentr.URLAppearance) begin
      case kURLAppearanceEmbed:       
        url = baseURL & "/" & course & "/content/" & CourseContentr.SerNr & "/details";  
        WebOutString("onclick=\"location.href='" & url & "';\"");
      case kURLAppearanceNewWindow: WebOutString("onclick=\"window.open('" & url & "')\"");
      case kURLAppearanceOpen:      WebOutString("onclick=\"location.href='" & url & "';\"");
      case kURLAppearancePopUp:     WebOutString("onclick=\"openPopup('" & url & "','" & CourseContentr.Name & "',700,500)\"");
    end;
  end;
  WebOutString("data-recordid='" & CourseContentr.SerNr & "' data-recordtype='CourseContentVc'>");
  WebOutString("<img src='/images/svg/hyperlink.svg'");
  WebOutClass("content-icon",hiddeneditmode);
  WebOutString("/>");
  WebOutString("<p");
  WebOutClass("",hiddeneditmode);
  WebOutString(">");
  WebOutString(CourseContentr.Name);
  WebOutString("</p>");
  ShowCourseContentEditIcons(CourseContentr.Visible,true,CourseContentr.Type,CourseContentr.SerNr);
  WebOutString("</div>");

  return;
end;

