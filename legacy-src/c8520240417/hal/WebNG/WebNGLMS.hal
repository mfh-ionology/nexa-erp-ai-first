global
updating procedure LMSCourseApp_DeleteAllStudentCourse()
begin
  record StudentCourseVc StudentCourser;
  LongInt recordnr;
  string 255 status;
  Boolean foundf;

  recordnr = StringToLongInt(WebGetArg("course"));

  foundf = true;
  StudentCourser.Course = recordnr;
  while (LoopKey("Course",StudentCourser,1,foundf)) begin
    if (StudentCourser.Course!=recordnr) then begin foundf = false; end;
    if (foundf) then begin
      RecordDelete(StudentCourser);
      StepBack(StudentCourser);
    end;
  end;

  WebOutString("<div>");
  WebOutString("<status code='success'></status>");
  WebOutString("</div>");
  return;
end;

updating function Boolean ApproveStudent(string student,LongInt course)
begin
  Boolean res;
  record StudentCourseVc oldStudentCourser,StudentCourser;

  StudentCourser.Course = course;
  StudentCourser.Student = student;
  StudentCourser.Approved = 0;
  if (ReadFirstKey("Course",StudentCourser,3,true)) then begin
    RecordCopy(oldStudentCourser,StudentCourser);
    StudentCourser.Approved = 1;
    if (RecordUpdate(oldStudentCourser,StudentCourser,true)==0) then begin
      res = true;
    end;
  end;

  ApproveStudent = res;
  return;
end;

global
updating procedure LMSCourseApp_CreateStudentCourse()
begin
  record Course2Vc Courser;
  record CUVc CUr;
  record StudentCourseVc oldStudentCourser,StudentCourser;
  LongInt course,errno;
  string 255 regkey,student,errmsg,status,selfenrol;
  Date availableFromDate,availableToDate;
  Time availableFromTime,availableToTime;
  Boolean selfenrolf,approvedf,applyf;
  LongInt res;
  string 255 vcname,fieldname;
  Integer rowno;


  regkey = WebGetArg("regkey");
  course = StringToLongInt(WebGetArg("course"));
  student = WebGetArg("student");
  selfenrolf = (WebGetArg("selfenrol")=="1");
  applyf = (WebGetArg("apply")=="1");
  availableFromDate = DateFromString(WebGetArg("availableFromDate"),"YYYY-MM-DD");
  availableToDate = DateFromString(WebGetArg("availableToDate"),"YYYY-MM-DD");
  if (nonblank(WebGetArg("availableFromTime"))) then begin
    availableFromTime = StringToTime(WebGetArg("availableFromTime"));
  end else begin
    availableFromTime = StringToTime("00:00:01");
  end;
  if (nonblank(WebGetArg("availableToTime"))) then begin
    availableToTime = StringToTime(WebGetArg("availableToTime"));
  end else begin
    availableToTime = StringToTime("23:59:59");
  end;

  if (applyf) then begin
    selfenrolf = false;
  end;

  if (blank(course) or blank(student)) then begin
    status = "failed";
    errmsg = "Something went wrong, contact System Administrator";
    goto LLMSCourseApp_CreateStudentCourse;
  end;

  if (blank(regkey) and selfenrolf) then begin
    status = "failed";
    errmsg = "Registration key may not be blank";
    goto LLMSCourseApp_CreateStudentCourse;
  end;

  Courser.SerNr = course;
  if (ReadFirstMain(Courser,1,true)) then begin
    if (selfenrolf) then begin
      if (Courser.EnableSelfEnrol==0) then begin 
        status = "failed";
        errmsg = "Course does not allow self enrolment";
        goto LLMSCourseApp_CreateStudentCourse;
      end;
      if (Courser.RegKey!=regkey) then begin
        status = "failed";
        errmsg = "Invalid registration key";
        goto LLMSCourseApp_CreateStudentCourse;
      end;
      approvedf = true;
    end;
  end;

  if (StudentPendingApproval(student,course) and selfenrolf) then begin
    if (ApproveStudent(student,course)) then begin
      status = "success";
    end else begin
      status = "failed";
      errmsg = "Unknown error, contact System Administrator";
    end;
    goto LLMSCourseApp_CreateStudentCourse;
  end;

  RecordNew(StudentCourser);
  RecordCopy(oldStudentCourser,StudentCourser);
  StudentCourser.SerNr = NextSerNr("StudentCourseVc",CurrentDate,-1,false,"");
  StudentCourser.Course = course;
  StudentCourser.CourseName = Courser.Name;
  StudentCourser.Student = student;
  CUr.Code = student;
  ReadFirstMain(CUr,1,true);
  StudentCourser.StudentName = CUr.Name;
  StudentCourser.StartDate = availableFromDate;
  StudentCourser.StartTime = availableFromTime;
  StudentCourser.EndDate = availableToDate;
  StudentCourser.EndTime = availableToTime;
  if (approvedf or WebGetArg("approved")=="1") then begin
    StudentCourser.Approved = 1;
  end;

  if (StudentCourser.Approved==0) then begin
    if (StudentPendingApproval(student,course)) then begin
        status = "failed";
        errmsg = "Student already has a pending application for this course";
        goto LLMSCourseApp_CreateStudentCourse;
    end;
  end;

  SetRecordCheckVc("StudentCourser");
  res = StudentCourseVcRecordCheck(StudentCourser,oldStudentCourser,-1,-1);

  if (GetRecordCheckError(vcname,errno,errmsg,rowno,fieldname)) then begin
    status = "failed";
    errmsg = USetStr(errno) & " " & errmsg;
  end else begin
    if (RecordStore(StudentCourser,true)) then begin
      status = "success";
    end else begin
      status = "failed";
      errmsg = "Unknown error, contact System Administrator";
    end;
  end;
LLMSCourseApp_CreateStudentCourse:;
  WebOutString("<div>");
  WebOutString("<status code='" & status & "' errmsg='" & errmsg & "'></status>");
  WebOutString("</div>");
  return;
end;

global
updating procedure LMSCourseApp_UpdateStudentCourse()
begin
  record Course2Vc Courser;
  record CUVc CUr;
  record StudentCourseVc oldStudentCourser,StudentCourser;
  LongInt course,errno;
  string 255 errmsg,status,selfenrol;
  Date availableFromDate,availableToDate;
  Time availableFromTime,availableToTime;
  LongInt res;
  string 255 vcname,fieldname;
  Integer rowno;

  availableFromDate = DateFromString(WebGetArg("availableFromDate"),"YYYY-MM-DD");
  availableToDate = DateFromString(WebGetArg("availableToDate"),"YYYY-MM-DD");
  if (nonblank(WebGetArg("availableFromTime"))) then begin
    availableFromTime = StringToTime(WebGetArg("availableFromTime"));
  end else begin
    availableFromTime = StringToTime("00:00:01");
  end;
  if (nonblank(WebGetArg("availableToTime"))) then begin
    availableToTime = StringToTime(WebGetArg("availableToTime"));
  end else begin
    availableToTime = StringToTime("23:59:59");
  end;

  StudentCourser.SerNr = StringToLongInt(WebGetArg("student"));
  if (ReadFirstMain(StudentCourser,1,true)==false) then begin
    status = "failed";
    errmsg = "Something went wrong, contact System Administrator";
    goto LLMSCourseApp_UpdateStudentCourse;
  end;

  Courser.SerNr = StudentCourser.Course;
  ReadFirstMain(Courser,1,true);

  RecordCopy(oldStudentCourser,StudentCourser);
  StudentCourser.StartDate = availableFromDate;
  StudentCourser.StartTime = availableFromTime;
  StudentCourser.EndDate = availableToDate;
  StudentCourser.EndTime = availableToTime;
  StudentCourser.Approved = StringToInt(WebGetArg("approved"));

  SetRecordCheckVc("StudentCourser");
  res = StudentCourseVcRecordCheck(StudentCourser,oldStudentCourser,-1,-1);

  if (GetRecordCheckError(vcname,errno,errmsg,rowno,fieldname)) then begin
    status = "failed";
    errmsg = USetStr(errno) & " " & errmsg;
  end else begin
    if (RecordUpdate(oldStudentCourser,StudentCourser,true)==0) then begin
      status = "success";
    end else begin
      status = "failed";
      errmsg = "Unknown error, contact System Administrator";
    end;
  end;
LLMSCourseApp_UpdateStudentCourse:;
  WebOutString("<div>");
  WebOutString("<status code='" & status & "' errmsg='" & errmsg & "'></status>");
  WebOutString("</div>");
  return;
end;

global
updating procedure LMSCourseApp_DeleteTopic()
begin
  record WebNGLMSTopicVc WebNGLMSTopicr;
  LongInt topicnr,course;
  string 255 status,errmsg;

  topicnr = StringToLongInt(WebGetArg("recordId"));
  course = StringToLongInt(WebGetArg("course"));

  WebNGLMSTopicr.SerNr = topicnr;
  if (ReadFirstMain(WebNGLMSTopicr,1,true)) then begin
    if (TopicHasContent(WebNGLMSTopicr.SerNr)==false) then begin
      RecordDelete(WebNGLMSTopicr);
      RefreshTopicSortOrder(course);
      status = "success";
    end else begin
      status = "failed";
      errmsg = "Topic must be empty";
    end;
  end;

  if (blank(status)) then begin
    status = "failed";
    errmsg = "Unknown error, contact System Administrator";
  end;

  WebOutString("<div>");
  WebOutString("<status code='" & status & "' errmsg='" & errmsg & "'></status>");
  WebOutString("</div>");
  
  return;
end;

global
updating procedure LMSCourseApp_UpdateCourseContentSortOrder()
begin
  record CourseContentVc oldCourseContentr,CourseContentr;
  string 255 actiontype;
  LongInt sortOrder,contentnr;

  actiontype = WebGetArg("actiontype"); //for now, might not be necessary
  contentnr = StringToLongInt(WebGetArg("coursecontent"));
  sortOrder = StringToLongInt(WebGetArg("sortOrder"));

  CourseContentr.SerNr = contentnr;
  if (ReadFirstMain(CourseContentr,1,true)) then begin
    RecordCopy(oldCourseContentr,CourseContentr);
    if (sortOrder!=CourseContentr.SortOrder and sortOrder!=-1) then begin
      CourseContentr.SortOrder = sortOrder;
    end;
    RecordUpdate(oldCourseContentr,CourseContentr,true);
  end;
  return;
end;

global
updating procedure LMSCourseApp_UpdateCourseContentVisible()
begin
  record CourseContentVc oldCourseContentr,CourseContentr;
  string 255 actiontype;
  LongInt visible,contentnr;

  actiontype = WebGetArg("actiontype"); //for now, might not be necessary
  contentnr = StringToLongInt(WebGetArg("coursecontent"));
  visible = StringToLongInt(WebGetArg("visible"));

  CourseContentr.SerNr = contentnr;
  if (ReadFirstMain(CourseContentr,1,true)) then begin
    RecordCopy(oldCourseContentr,CourseContentr);
    if (visible!=CourseContentr.Visible and visible!=-1) then begin
      CourseContentr.Visible = visible;
    end;
    RecordUpdate(oldCourseContentr,CourseContentr,true);
  end;

LLMSCourseApp_UpdateCourseContentVisible:;
  return;
end;

global
updating procedure LMSCourseApp_UpdateCourseVisible()
begin
  record Course2Vc oldCourser,Courser;
  string 255 actiontype;
  LongInt visible,coursenr;

  actiontype = WebGetArg("actiontype"); //for now, might not be necessary
  coursenr = StringToLongInt(WebGetArg("course"));
  visible = StringToLongInt(WebGetArg("visible"));

  Courser.SerNr = coursenr;
  if (ReadFirstMain(Courser,1,true)) then begin
    RecordCopy(oldCourser,Courser);
    if (visible!=Courser.Visibility and visible!=-1) then begin
      Courser.Visibility = visible;
    end;
    RecordUpdate(oldCourser,Courser,true);
  end;

  return;
end;

