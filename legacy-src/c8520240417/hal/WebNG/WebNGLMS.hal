    WebOutString("<select id='webtest' name='webtest'>");
    Select_WebTest(CourseContentr.Test,editmodef);
    WebOutString("</select>");
    WebOutString("</div>");
  end;

  if (rectype==kCourseContentTypeAttendance) then begin
    WebOutString("<div class='date-time-group'>");

    WebOutString("<div>");
    WebOutString("<label for='attendanceDate'>Attendance From:</label>");
    WebOutString("<input type='date' id='attendanceDate' name='attendanceDate' ");
    WebOutString("value='");
    if (editmodef) then begin
      WebOutString(DateToString(CourseContentr.AttendanceDate,"YYYY-MM-DD"));
    end else begin
      WebOutString(DateToString(CurrentDate,"YYYY-MM-DD"));
    end;
    WebOutString("'>");
    WebOutString("</div>");

    WebOutString("<div>");
    WebOutString("<label for='attendanceFromTime'>From Time:</label>");
    WebOutString("<input type='time' id='attendanceFromTime' name='attendanceFromTime' ");
    WebOutString("value='" & CourseContentr.AttendanceFromTime & "'");
    WebOutString(">");
    WebOutString("</div>");

    WebOutString("<div>");
    WebOutString("<label for='attendanceToTime'>To Time:</label>");
    WebOutString("<input type='time' id='attendanceToTime' name='attendanceToTime' ");
    WebOutString("value='" & CourseContentr.AttendanceToTime & "'");
    WebOutString(">");
    WebOutString("</div>");
    WebOutString("</div>");


    WebOutString("<div class='date-time-group'>");
    WebOutString("<div>");
    WebOutString("<label for='repeatUntilDate'>Repeat Until:</label>");
    WebOutString("<input type='date' id='repeatUntilDate' name='repeatUntilDate' ");
    WebOutString("value='");
    WebOutString(DateToString(CourseContentr.RepeatUntilDate,"YYYY-MM-DD"));
    WebOutString("'>");
    WebOutString("</div>");
    WebOutString("<div>");
    WebOutString("<label for='repeatPeriod'>Repeat Every:</label>");
    WebOutString("<input type='number' id='repeatPeriod' name='repeatPeriod' ");
    WebOutString("value='" & CourseContentr.RepeatPeriod & "'");
    WebOutString(">");
    WebOutString("</div>");
    WebOutString("</div>");

    WebOutString("<div class='form-group checkbox-group'>");
    if (CourseContentr.EveryMonday==1) then begin tstr = "checked"; end else begin tstr = ""; end;
    WebOutString("<input type='checkbox' id='everyMonday' name='everyMonday' " & tstr & ">");
    WebOutString("<label for='everyMonday'>Monday</label>");
    if (CourseContentr.EveryTuesday==1) then begin tstr = "checked"; end else begin tstr = ""; end;
    WebOutString("<input type='checkbox' id='everyTuesday' name='everyTuesday' " & tstr & ">");
    WebOutString("<label for='everyTuesday'>Tuesday</label>");
    if (CourseContentr.EveryWednesday==1) then begin tstr = "checked"; end else begin tstr = ""; end;
    WebOutString("<input type='checkbox' id='everyWednesday' name='everyWednesday' " & tstr & ">");
    WebOutString("<label for='everyWednesday'>Wednesday</label>");
    if (CourseContentr.EveryThursday==1) then begin tstr = "checked"; end else begin tstr = ""; end;
    WebOutString("<input type='checkbox' id='everyThursday' name='everyThursday' " & tstr & ">");
    WebOutString("<label for='everyThursday'>Thursday</label>");
    if (CourseContentr.EveryFriday==1) then begin tstr = "checked"; end else begin tstr = ""; end;
    WebOutString("<input type='checkbox' id='everyFriday' name='everyFriday' " & tstr & ">");
    WebOutString("<label for='everyFriday'>Friday</label>");
    if (CourseContentr.EverySaturday==1) then begin tstr = "checked"; end else begin tstr = ""; end;
    WebOutString("<input type='checkbox' id='everySaturday' name='everySaturday' " & tstr & ">");
    WebOutString("<label for='everySaturday'>Saturday</label>");
    if (CourseContentr.EverySunday==1) then begin tstr = "checked"; end else begin tstr = ""; end;
    WebOutString("<input type='checkbox' id='everySunday' name='everySunday' " & tstr & ">");
    WebOutString("<label for='everySunday'>Sunday</label>");
    WebOutString("</div>");

    WebOutString("<div class='form-group checkbox-group'>");
    if (CourseContentr.InclHolidays==1) then begin tstr = "checked"; end else begin tstr = ""; end;
    WebOutString("<input type='checkbox' id='inclHolidays' name='inclHolidays' " & tstr & ">");
    WebOutString("<label for='inclHolidays'>Including Holidays</label>");
    WebOutString("</div>");
  end;

// Checkbox - need both in WEB and Interface - "Including Holidays" - by default not ticked

  WebOutString("<div class='form-group checkbox-group'>");
  if (editmodef==false) then begin
    tstr = "checked";
  end else begin
    if (CourseContentr.Visible==1) then begin
      tstr = "checked";
    end else begin
      tstr = "";
    end;
  end;
  WebOutString("<input type='checkbox' id='visible' name='visible' " & tstr & ">");
  WebOutString("<label for='visible'>Visible</label>");
  WebOutString("</div>");

  WebOutString("<div class='date-time-group'>");
  WebOutString("<div>");
  WebOutString("<label for='visibleFromDate'>Visible From Date:</label>");
  WebOutString("<input type='date' id='visibleFromDate' name='visibleFromDate' ");
