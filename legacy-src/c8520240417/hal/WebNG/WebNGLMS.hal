  WebOutString("</div>");
  return;
end;

procedure WebOutCourseList()
begin
  record Course2Vc Courser;
  string 255 res,url,node,department,teacher,tstr,hidden,hiddeneditmode,extraclass;
  Boolean testf,availablef;
  Integer i;
  array record Course2Vc arrMyCourser,arrOtherCourser;
  array Boolean arrAvailablef;
  transaction Boolean gEditModef;

  department = WebGetArg("department");
  teacher = WebGetArg("teacher");
  if (IsTeacher) then begin
    teacher = CurrentCust;
  end;

  while (LoopMain(Courser,1,true)) begin
    testf = true;
    if ((IsEnrolledStudent(Courser.SerNr,availablef)==false and Courser.EnableSelfEnrol==0) and Courser.AllowApplications==0) then begin
      testf = false;
    end;
    if (testf==false) then begin
      if (SetInSet2(CurrentCust,Courser.Teachers)) then begin
        testf = true;
      end;
      if (IsLMSAdmin) then begin
        testf = true; 
      end;
    end;
    //Filters
    if (nonblank(department)) then begin
      if (SetInSet2(department,Courser.Departments)==false) then begin testf = false; end;
    end;
    if (nonblank(teacher)) then begin
      if (SetInSet2(teacher,Courser.Teachers)==false) then begin testf = false; end;
    end;
    if (IsLMSAdmin==false and SetInSet2(CurrentCust,Courser.Teachers)==false) then begin
      if (Courser.Visibility==0) then begin testf = false; end;
      if (DateInRange(CurrentDate,Courser.StartDate,Courser.EndDate)==false) then begin 
        if (CurrentDate>Courser.EndDate) then begin testf = false; end;
      end;
    end;
    if (Courser.Terminated==1) then begin testf = false; end;
    if (testf) then begin
      if (IsEnrolledStudent(Courser.SerNr,availablef) or IsLMSAdmin or SetInSet2(CurrentCust,Courser.Teachers)) then begin
        arrMyCourser[arrMyCourser.length] = Courser;
        if (IsLMSAdmin or SetInSet2(CurrentCust,Courser.Teachers)) then begin
          arrAvailablef[arrAvailablef.length] = true;
        end else begin
          arrAvailablef[arrAvailablef.length] = availablef;
        end;
      end else begin
        if (IsTeacher==false or Courser.AllowApplications==1) then begin
          arrOtherCourser[arrOtherCourser.length] = Courser;
        end;
      end;
    end;
  end;

  WebOutString("<div class='my-courses-container'>");
  tstr = "My Courses";
  if (IsLMSAdmin or IsTeacher) then begin
    tstr = "Courses";
  end;
  WebOutString("<h3 class='course-list-header-title'>" & tstr & "</h3>");
  if (arrMyCourser.length>0) then begin
    for (i=0;i<arrMyCourser.length;i=i+1) begin
      node = "overview";
      if (gEditModef) then begin
        node = "manage/enrolment";
      end;
      Courser = arrMyCourser[i];

      hidden = "";
      hiddeneditmode = "";
      if (Courser.Visibility==0) then begin
        if (gEditModef==false) then begin
          hidden = "hidden";
        end else begin
          hiddeneditmode = "hidden-editmode";
        end;
      end;
      url = FormatSimpleLink("/lms/course/" & Courser.SerNr & "/" & node,true);
      extraclass = "";
      if (arrAvailablef[i]==false) then begin
        extraclass = "course-unavailable";
      end;
      WebOutString("<div data-recordid='" & Courser.SerNr & "' data-recordtype='Course2Vc'");
      WebOutClass("content-line course-line " & extraclass & "",hidden);
      WebOutString(">");
      if (arrAvailablef[i]) then begin
        WebOutString("<a href='" & url & "'");
        WebOutClass("",hiddeneditmode);  
        WebOutString(">");
      end;
      tstr = "";
      WebOutString("<li class='course-item " & extraclass & "'>" & Courser.Name & "</li>");
      if (arrAvailablef[i]) then begin
        WebOutString("</a>");
      end;
      if (DateInRange(CurrentDate,Courser.StartDate,Courser.EndDate)==false or arrAvailablef[i]==false) then begin
        if (nonblankdate(Courser.StartDate) and nonblankdate(Courser.EndDate)) then begin
          tstr = Courser.StartDate & " - " & Courser.EndDate;
        end else begin
          if (blank(Courser.StartDate) and nonblank(Courser.EndDate)) then begin
            tstr = "Ended on " & Courser.EndDate;
          end;
          if (nonblank(Courser.StartDate) and blank(Courser.EndDate)) then begin
            tstr = "Starts on " & Courser.StartDate;
          end;
        end;
        WebOutString("<span class='course-unavailable-text'>(" & tstr & ")</span>");
      end;
      ShowCourseEditIcons(Courser.Visibility,Courser.SerNr);
      WebOutString("</div>");
    end;
  end else begin
    WebOutString("<span class='no-content'>No courses</span>");
  end;
  WebOutString("</div>");

  if (arrOtherCourser.length>0) then begin
    WebOutString("<div class='other-courses-container'>");
    WebOutString("<h3 class='course-list-header-title'>Other Courses</h3>");
    for (i=0;i<arrOtherCourser.length;i=i+1) begin
      Courser = arrOtherCourser[i];

      hidden = "";
      hiddeneditmode = "";
      if (Courser.Visibility==0) then begin
        if (gEditModef==false) then begin
          hidden = "hidden";
        end else begin
          hiddeneditmode = "hidden-editmode";
        end;
      end;
      node = "register";
      url = FormatSimpleLink("/lms/course/" & Courser.SerNr & "/" & node,true);
      WebOutString("<div data-recordid='" & Courser.SerNr & "' data-recordtype='Course2Vc'");
      WebOutClass("course-line",hidden);
      WebOutString(">");
      WebOutString("<a href='" & url & "'");
      WebOutClass("",hiddeneditmode);
      WebOutString(">");
      WebOutString("<li class='course-item'>" & Courser.Name & "</li>");
      WebOutString("</a>");
      ShowCourseEditIcons(Courser.Visibility,Courser.SerNr);
      WebOutString("</div>");
    end;
    WebOutString("</div>");
  end;
  
LWebOutCourseList:;
  return;
end;

global
updating procedure LMSCourseApp_UpdateTopicVisible()
begin
  record WebNGLMSTopicVc oldWebNGLMSTopicr,WebNGLMSTopicr;
  string 255 actiontype,topic;
  LongInt visible;

  actiontype = WebGetArg("actiontype");
  topic = WebGetArg("topic");
  visible = StringToLongInt(WebGetArg("visible"));

  WebNGLMSTopicr.SerNr = topic;
  if (ReadFirstMain(WebNGLMSTopicr,1,true)) then begin
    RecordCopy(oldWebNGLMSTopicr,WebNGLMSTopicr);
    if (visible!=WebNGLMSTopicr.Visible and visible!=-1) then begin
      WebNGLMSTopicr.Visible = visible;
    end;
    RecordUpdate(oldWebNGLMSTopicr,WebNGLMSTopicr,true);
  end;

  return;
end;

global
updating procedure LMSCourseApp_UpdateTopicSortOrder()
begin
  record WebNGLMSTopicVc oldWebNGLMSTopicr,WebNGLMSTopicr;
  record WebNGLMSTopicVc oldWebNGLMSTopic2r,WebNGLMSTopic2r;
  string 255 actiontype,topicId,direction,status,errmsg;
  Integer poschange;

  actiontype = WebGetArg("actiontype");
  topicId = WebGetArg("topic");
  direction = WebGetArg("direction");

  if (direction=="up") then begin
    poschange = -1;
  end else begin
    poschange = 1;
  end;

  WebNGLMSTopicr.SerNr = topicId;
  if (ReadFirstMain(WebNGLMSTopicr,1,true)) then begin
    RecordCopy(oldWebNGLMSTopicr,WebNGLMSTopicr);
    WebNGLMSTopicr.SortOrder = WebNGLMSTopicr.SortOrder + poschange;

    WebNGLMSTopic2r.SortOrder = WebNGLMSTopicr.SortOrder;
    WebNGLMSTopic2r.Course = WebNGLMSTopicr.Course;
    if (ReadFirstKey("SortOrder",WebNGLMSTopic2r,2,true)) then begin
      RecordCopy(oldWebNGLMSTopic2r,WebNGLMSTopic2r);
      WebNGLMSTopic2r.SortOrder = WebNGLMSTopic2r.SortOrder - poschange;
      if (WebNGLMSTopic2r.SortOrder<1) then begin
        WebNGLMSTopic2r.SortOrder = 1;
      end;
      RecordUpdate(oldWebNGLMSTopic2r,WebNGLMSTopic2r,true);
    end;
    if (WebNGLMSTopicr.SortOrder<1) then begin
      WebNGLMSTopicr.SortOrder = 1;
    end;
    if (RecordUpdate(oldWebNGLMSTopicr,WebNGLMSTopicr,true)==0) then begin
      status = "success";
    end else begin
      status = "failed";
      errmsg = "Unknown error, contact System Administrator";
    end;
  end;

  WebOutString("<div>");
  WebOutString("<status code='" & status & "' errmsg='" & errmsg & "'></status>");
  WebOutString("</div>");
  return;
end;

