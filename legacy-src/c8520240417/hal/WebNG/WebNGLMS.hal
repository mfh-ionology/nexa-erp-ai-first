global
updating procedure LMSCourseApp_CreateCourseContent()
begin
  record CourseContentVc CourseContentr,oldCourseContentr;
  string 255 actiontype,status,errmsg,filename;
  string 255 filecontents;
  Integer topicId,rowno;
  area filearea;
  LongInt pos,res,errno;
  Boolean savedf;
  string 255 vcname,fieldname;

  actiontype = WebGetArg("actiontype");
  topicId = StringToInt(WebGetArg("topicId"));

  RecordNew(CourseContentr);
  RecordCopy(oldCourseContentr,CourseContentr);
  CourseContentr.SerNr = NextSerNr("CourseContentVc",CurrentDate,-1,false,"");
  CourseContentr.SortOrder = (GetLastSortOrder(topicId,"CourseContentVc") + 1);
  CourseContentr.Type = StringToInt(WebGetArg("rectype"));
  CourseContentr.Topic = topicId;
  CourseContentr.Name = WebGetArg("name");
  CourseContentr.URL = WebGetArg("url");
  CourseContentr.URLAppearance = StringToInt(WebGetArg("appearance"));
  SetTextField(CourseContentr,WebGetArg("description"));
  CourseContentr.Visible = StringToInt(WebGetArg("visible"));
  CourseContentr.FileDisplay = StringToInt(WebGetArg("filedisplay"));
  CourseContentr.ShowType = StringToInt(WebGetArg("showtype"));
  CourseContentr.ShowSize = StringToInt(WebGetArg("showsize"));
  CourseContentr.ShowDate = StringToInt(WebGetArg("showdate"));
  CourseContentr.VisibleFromDate = DateFromString(WebGetArg("visibleFromDate"),"YYYY-MM-DD");
  CourseContentr.VisibleToDate = DateFromString(WebGetArg("visibleToDate"),"YYYY-MM-DD");
  CourseContentr.AttendanceDate = DateFromString(WebGetArg("attendanceDate"),"YYYY-MM-DD");
  CourseContentr.AttendanceFromTime = WebGetArg("attendanceFromTime");
  CourseContentr.AttendanceToTime = WebGetArg("attendanceToTime");
  CourseContentr.RepeatUntilDate = DateFromString(WebGetArg("repeatUntilDate"),"YYYY-MM-DD");
  CourseContentr.RepeatPeriod = StringToInt(WebGetArg("repeatPeriod"));
  CourseContentr.EveryMonday = StringToInt(WebGetArg("everyMonday"));
  CourseContentr.EveryTuesday = StringToInt(WebGetArg("everyTuesday"));
  CourseContentr.EveryWednesday = StringToInt(WebGetArg("everyWednesday"));
  CourseContentr.EveryThursday = StringToInt(WebGetArg("everyThursday"));
  CourseContentr.EveryFriday = StringToInt(WebGetArg("everyFriday"));
  CourseContentr.EverySaturday = StringToInt(WebGetArg("everySaturday"));
  CourseContentr.EverySunday = StringToInt(WebGetArg("everySunday"));
  CourseContentr.InclHolidays = StringToInt(WebGetArg("inclHolidays"));  
  CourseContentr.Test = StringToLongInt(WebGetArg("webtest"));

  pos = 0;
  GetNextSubString(WebGetArg("filecontent"),pos,",",filecontents);
  GetNextSubString(WebGetArg("filecontent"),pos,",",filecontents);
  AddTextToArea(Base64Decode(filecontents),filearea); //SHOULD BE REFACTORED AS ITS NOT OPTIMISED
  if (GetAreaLength(filearea)>0) then begin
    filename = WebGetArg("filename");
    WriteAreaToFile(filearea,"tmp/" & filename,0);
    if (FileExists("tmp/" & filename)) then begin
      RecordLinkFile("tmp/" & filename,0,CourseContentr,CurrentCompany);
      Delete_File("tmp/" & filename);
    end;
  end;

  SetRecordCheckVc("CourseContentVc");
  res = CourseContentVcRecordCheck(CourseContentr,oldCourseContentr,-1,-1);

  if (GetRecordCheckError(vcname,errno,errmsg,rowno,fieldname)) then begin
    status = "failed";
    errmsg = USetStr(errno) & " " & errmsg;
  end else begin
    switch (actiontype) begin
      case "update_record": res = RecordUpdate(oldCourseContentr,CourseContentr,true);
      case "create_record": savedf = RecordStore(CourseContentr,true);
    end;
    if (res==0 and savedf) then begin
      status = "success";
    end else begin
      status = "failed";
      errmsg = "Unknown error, contact System Administrator";
    end;
  end;
  WebOutString("<div>");
  WebOutString("<status code='" & status & "' errmsg='" & errmsg & "'></status>");
  WebOutString("</div>");
  return;
end;

