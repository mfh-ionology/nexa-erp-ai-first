function string 255 LMSAppHead()
begin
  string 255 res;

  
  res = res & "<script type='text/javascript' src='https://code.jquery.com/jquery-3.6.0.min.js'></script>" & LF;
  AddFileAsTag(res,"WebNGLMSCoursesApp.js","script","text/javascript");
  AddFileAsTag(res,"WebNGLMSCoursesApp.css","style","text/css");
  
  // res = res & "<script type='text/javascript' src='/js/WebNGLMSCoursesApp.js'></script>" & LF; //TEMP!!!!!!!!!!
  // res = res & "<link type='text/css' rel='stylesheet' href='/styles/WebNGLMSCoursesApp.css'>" & LF; //TEMP!!!!!!!!!!
  // res = res & "<script src='https://cdnjs.cloudflare.com/ajax/libs/selectize.js/0.12.6/js/standalone/selectize.min.js' integrity='sha256-+C0A5Ilqmu4QcSPxrlGpaZxJ04VjsRjKu+G82kl5UJk=' crossorigin='anonymous'></script>" & LF;
  // res = res & "<link rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/selectize.js/0.12.6/css/selectize.bootstrap3.min.css' integrity='sha256-ze/OEYGcFbPRmvCnrSeKbRTtjG4vGLHXgOqsyLFTRjg=' crossorigin='anonymous' />" & LF;

  res = res & "<script type='text/javascript'>" & LF;
  res = res & "  LMSCourses.UpdateCourse                      = '/" & GetEncryptedLink("lms/ajax?action=updatecourse") & "';" & LF;
  res = res & "  LMSCourses.CreateCourse                      = '/" & GetEncryptedLink("lms/ajax?action=createcourse") & "';" & LF;
  res = res & "  LMSCourses.DeleteCourse                      = '/" & GetEncryptedLink("lms/ajax?action=deletecourse") & "';" & LF;
  res = res & "  LMSCourses.UpdateCourseVisible               = '/" & GetEncryptedLink("lms/ajax?action=updatecoursevisible") & "';" & LF;
  res = res & "  LMSCourses.UpdateTopic                       = '/" & GetEncryptedLink("lms/ajax?action=updatetopic") & "';" & LF;
  res = res & "  LMSCourses.UpdateTopicVisible                = '/" & GetEncryptedLink("lms/ajax?action=updatetopicvisible") & "';" & LF;
  res = res & "  LMSCourses.UpdateTopicSortOrder              = '/" & GetEncryptedLink("lms/ajax?action=updatetopicsortorder") & "';" & LF;
  res = res & "  LMSCourses.UpdateCourseContent               = '/" & GetEncryptedLink("lms/ajax?action=updatecoursecontent") & "';" & LF;
  res = res & "  LMSCourses.UpdateCourseContentSortOrder      = '/" & GetEncryptedLink("lms/ajax?action=updatecoursecontentsortorder") & "';" & LF;
  res = res & "  LMSCourses.UpdateCourseContentVisible        = '/" & GetEncryptedLink("lms/ajax?action=updatecoursecontentvisible") & "';" & LF;
  res = res & "  LMSCourses.CreateCourseContent               = '/" & GetEncryptedLink("lms/ajax?action=createcoursecontent") & "';" & LF;
  res = res & "  LMSCourses.DeleteCourseContent               = '/" & GetEncryptedLink("lms/ajax?action=deletecoursecontent") & "';" & LF;
  res = res & "  LMSCourses.DeleteTopic                       = '/" & GetEncryptedLink("lms/ajax?action=deletetopic") & "';" & LF;
  res = res & "  LMSCourses.CreateTopic                       = '/" & GetEncryptedLink("lms/ajax?action=createtopic") & "';" & LF;
  res = res & "  LMSCourses.UpdateStudentCourse               = '/" & GetEncryptedLink("lms/ajax?action=updatestudentcourse") & "';" & LF;
  res = res & "  LMSCourses.DeleteStudentCourse               = '/" & GetEncryptedLink("lms/ajax?action=deletestudentcourse") & "';" & LF;
  res = res & "  LMSCourses.CreateStudentCourse               = '/" & GetEncryptedLink("lms/ajax?action=createstudentcourse") & "';" & LF;
  res = res & "  LMSCourses.DeleteAllStudentCourse            = '/" & GetEncryptedLink("lms/ajax?action=deleteallstudentcourse") & "';" & LF;
  res = res & "</script>" & LF;

  LMSAppHead = res;
end;

function Integer GetLastSortOrder(Integer parentId,string fn)
begin
  Integer res;
  Boolean foundf;
  record CourseContentVc CourseContentr;
  record WebNGLMSTopicVc WebNGLMSTopicr;

  foundf = true;

  switch (fn) begin
    case "CourseContentVc":
      CourseContentr.Topic = parentId;
      CourseContentr.SortOrder = 99999999999;
      if (LoopBackKey("Topic",CourseContentr,2,foundf)) then begin
        if (CourseContentr.Topic!=parentId) then begin foundf = false; end;
        if (foundf) then begin
          res = CourseContentr.SortOrder;
          goto LGetLastSortOrder;
        end;
      end;
    case "WebNGLMSTopicVc":
      WebNGLMSTopicr.Course = parentId;
      WebNGLMSTopicr.SortOrder = 99999999999;
      if (LoopBackKey("Course",WebNGLMSTopicr,2,foundf)) then begin
        if (WebNGLMSTopicr.Course!=parentId) then begin foundf = false; end;
        if (foundf) then begin
          res = WebNGLMSTopicr.SortOrder;
          goto LGetLastSortOrder;
        end;
      end;
  end;

LGetLastSortOrder:;
  GetLastSortOrder = res;
  return;
end;

procedure Interface_EditIcon(string fn,Integer rectype,string recnr)
begin
  WebOutString("<img class='interface-icon edit-icon' onclick='editRecord(this,\"" & fn & "\",\"" & rectype & "\",\"" & recnr & "\")' src='/images/svg/interface/edit.svg' />");
  return;
end;

procedure Interface_DeleteIcon(string fn)
begin
  WebOutString("<img class='interface-icon delete-icon' onclick='deleteRecord(this,\"" & fn & "\")' src='/images/svg/interface/delete.svg' />");
  return;
end;

procedure Select_Student()
begin
  record CUVc CUr;

  WebOutString("<option value=''>Select</option>");
  while (LoopMain(CUr,1,true)) begin
    if (CUr.StudentType==1) then begin
      WebOutString("<option value='" & CUr.Code & "'>" & CUr.Name & "</option>");
    end;
  end;

  return;
end;

procedure Select_ActivityType(string type,Boolean editmodef)
begin
  record ActTypeVc ATr;
  string 255 tstr;

  WebOutString("<option value=''>Select</option>");
  while (LoopMain(ATr,1,true)) begin
    if (editmodef) then begin
      tstr = "";
      if (ATr.Code==type) then begin
        tstr = "selected";
      end;
    end;
    WebOutString("<option value='" & ATr.Code & "' " & tstr & ">" & ATr.Comment & "</option>");
  end;

  return;
end;

