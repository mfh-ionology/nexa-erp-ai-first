function Boolean Start3DSPage(var record WebNGStructVc WSr,var record WebNGPageVc WPr,string paysessionid,var record WebNGPaySessionVc WPSr)
begin
  Boolean res;
  
  if (GetPaySession(paysessionid,WPSr)) begin
    if (ReadFirstMain(WSr,1,true)) then begin
      WPr.Code = WSr.WebPage;
      if (ReadFirstMain(WPr,1,true)) then begin end;
    end;

    Log3DS("WPSr.Completed: " & WPSr.Completed & " WPSr.Status: " & WPSr.Status);
    
    WPr.TemporaryPage = 0; // 1; // ??
    res = true;
  end;
  
  Start3DSPage = res;
end;

function Boolean CCPaymentSettings(record WebNGPaySessionVc WPSr,var record CCAccountIDVc CCAccountIDr,var record CCMerchantIDVc CCMerchantIDr)
begin
  Boolean res;
  
  FindCCAccountID(WPSr.Currency,"",kCCAccountTypeWeb,CCAccountIDr,kCardHolderNotPresent);
    
  CCMerchantIDr.Code = CCAccountIDr.MerchantID;
  if (ReadFirstMain(CCMerchantIDr,1,true)) then begin
    res =  true;
  end;
  
  Log3DS("CCPaymentSettings " & WPSr.Currency & " found " & CCAccountIDr.Code & "/" & CCAccountIDr.MerchantID & "/" & CCMerchantIDr.Code & " -> " & res);
  
  CCPaymentSettings = res;
end;

procedure ShopPaymentByCreditCard_3DS_checkEnroll(record WebNGStructVc WSr,string paysessionid)
begin
  record WebNGPaySessionVc WPSr;
  record WebNGPageVc WPr;
  transaction string 255 gExtraHeadHTML;
  string 255 keyid;
  string 255 shared_secret;
  string 255 merchant_id,org_unit;
  json jwt_claims_js;
  record CCAccountIDVc CCAccountIDr;
  record CCMerchantIDVc CCMerchantIDr;

  if (CCPaymentSettings(WPSr,CCAccountIDr,CCMerchantIDr)) then begin
    keyid = CCAccountIDr.CardinalKeyID;
    shared_secret = CCAccountIDr.CardinalSharedSecret;
    org_unit = CCAccountIDr.CardinalOrgUnit;
    
    Log3DS("ShopPaymentByCreditCard_3DS_checkEnroll " & keyid & "/" & shared_secret & "/" & org_unit);
  end else begin
    Log3DS("ShopPaymentByCreditCard_3DS_checkEnroll no payment settings");
  end;

  //keyid = "5d727a256fe3d12f188e8169";
  //shared_secret = "85ab3fd6-520a-44ff-8cad-b8ad23fe5815";
  //org_unit = "5d67be7d031e732958be7099";

  if (keyid=="" or shared_secret=="" or org_unit=="") then begin
    Log3DS("ShopPaymentByCreditCard_3DS_checkEnroll blank settings");
    ShowErrorPage(25063);
    goto LShopPaymentByCreditCard_3DS_checkEnroll_out;
  end;

  if (Start3DSPage(WSr,WPr,paysessionid,WPSr)==false) then begin
    Log3DS("ShopPaymentByCreditCard_3DS_checkEnroll page start failed");
    ShowErrorPage(25000);
    goto LShopPaymentByCreditCard_3DS_checkEnroll_out;
  end;

  gExtraHeadHTML = CyberSource3DSJavascript_checkEnroll(CCMerchantIDr);

  ShowWebAppPageStart(WPr,"");

  WebOutStringFormatNL("<h1>check enroll</h1><br><br>");

  WebOutStringFormatNL("<iframe name=""ddc-iframe"" height=""10"" width=""10"" style=""display: none;""> </iframe>");
  WebOutStringFormatNL("<form id=""ddc-form"" target=""ddc-iframe"" method=""POST"" action=""" & GetSessionString("cybs_3ds_cai_deviceDataCollectionUrl") & """>");

  JSONAddField(jwt_claims_js,"/iss",keyid);   // Issuer - identifier of who is issuing the JWT. Contains the API key identifier or name
  JSONAddField(jwt_claims_js,"/iat",CurrentUnixUTCTime); // Issued at - the epoch time in seconds beginning when the JWT is issued. This
                                                         // value indicates how long a JWT has existed and can be used to determine if
                                                         // it is expired.
  JSONAddField(jwt_claims_js,"/jti",RandomChars(20));
  JSONAddField(jwt_claims_js,"/OrgUnitId",org_unit);
  JSONAddField(jwt_claims_js,"/Payload","{}");
  JSONAddField(jwt_claims_js,"/Payload/ActionCode","");
  JSONAddField(jwt_claims_js,"/Payload/SessionId","");
  JSONAddInteger(jwt_claims_js,"/Payload/ErrorNumber",0);
  JSONAddField(jwt_claims_js,"/Payload/ErrorDescription","Success");

  WebOutStringFormatNL("<input type=""hidden"" name=""JWT"" value=""" & MakeJWT(jwt_claims_js,"HS256",shared_secret) & """ />");
  WebOutStringFormatNL("</form>");

  WebOutStringFormatNL("<form id=""result-form"" method=""POST"" action=""" & GetLinkToShop & "payment/creditcard/" & paysessionid & "/3ds_resultEnroll"">");
  //target=""ddc-iframe""

  WebOutStringFormatNL("<input type=""hidden"" name=""checkEnrollResult"" id=""checkEnrollResult"" />");
  WebOutStringFormatNL("</form>");

  ShowWebAppPageEnd(WPr);
LShopPaymentByCreditCard_3DS_checkEnroll_out:;
  return;
end;

procedure AddCSCardFromSession(json js,string prefix,Boolean fullcardf)
begin
  string 255 cctypecode,cctype,cctypecybersouce;
  
  JSONAddField(js,prefix & "card","{}");
  JSONAddField(js,prefix & "card/number",GetSessionString("cybs_3ds_cardnumber"));
  
  if (fullcardf) then begin
    cctypecode = GetSessionString("cybs_3ds_cardtype");
    cctype = CardTypeCodeResolve(cctypecode);
    cctypecybersouce = CyberSourceCardType(cctype);
    
    JSONAddField(js,prefix & "card/type",cctypecybersouce);
    JSONAddField(js,prefix & "card/expirationMonth",GetSessionString("cybs_3ds_expirymonth"));
    JSONAddField(js,prefix & "card/expirationYear",GetSessionString("cybs_3ds_expiryyear"));
  end;
end;

procedure AddCSPaymentInformationFromSession(json js)
begin
  JSONAddField(js,"/paymentInformation","{}");
  AddCSCardFromSession(js,"/paymentInformation/",true);
end;

procedure AddCSInstrumentIDFromSession(json js,string prefix)
begin
  JSONAddField(js,prefix & "instrumentIdentifier","{}");
  JSONAddField(js,prefix & "instrumentIdentifier/id",GetSessionString("cybs_3ds_instrumentId"));
end;

procedure AddCSBuyerInfoFromSession(json js,string prefix)
begin
  JSONAddField(js,prefix & "billTo","{}");
  JSONAddField(js,prefix & "billTo/locality",GetSessionString("cybs_3ds_address_city")); // city
  JSONAddField(js,prefix & "billTo/lastName",GetSessionString("cybs_3ds_cardlastname"));
  JSONAddField(js,prefix & "billTo/firstName",GetSessionString("cybs_3ds_cardfirstname"));
  JSONAddField(js,prefix & "billTo/email",GetSessionString("cybs_3ds_address_email"));
  JSONAddField(js,prefix & "billTo/address1",GetSessionString("cybs_3ds_address_street"));
  JSONAddField(js,prefix & "billTo/country",GetSessionString("cybs_3ds_address_country"));
  JSONAddField(js,prefix & "billTo/administrativeArea",GetSessionString("cybs_3ds_address_state"));
  JSONAddField(js,prefix & "billTo/postalCode",GetSessionString("cybs_3ds_address_postalcode"));
end;


// ## items if needed could be added at some points
//JSONAddArray(js,"/orderInformation/lineItems");
//JSONAddField(js,"/orderInformation/lineItems[0]","{}");
//JSONAddField(js,"/orderInformation/lineItems[0]/unitPrice",   );
//JSONAddField(js,"/orderInformation/lineItems[0]/quantity",   );
