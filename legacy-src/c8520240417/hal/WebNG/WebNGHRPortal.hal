function string 255 HRPortalRoot()
begin
  HRPortalRoot = "HRPortal";
  return;
end;

function string 255 GetFileExtension(string fn)
begin
  string 255 res;
  Integer i;

  for (i=len(fn)-1;i>=0;i=i-1) begin
    if (mid(fn,i,1)==".") then begin
      goto Lexit;
    end;
    res = mid(fn,i,1) & res;
  end;

Lexit:;
  GetFileExtension = res;
  return;
end;

function Boolean HasAttachments(string filename,LongInt recnr)
begin
  Boolean res;
  record RLinkVc RLr;
  record Attach2Vc Attachr;
  record HRMCOVc HRMCOr;
  record HRMCOChangeVc HRMCOCr;

  switch (filename) begin
    case "HRMCOVc":
      HRMCOr.SerNr = recnr;
      if (ReadFirstMain(HRMCOr,1,true)) then begin
        res = ReadRecordLink(HRMCOr,0,Attachr,RLr);
      end;
    case "HRMCOChangeVc":
      HRMCOCr.SerNr = recnr;
      if (ReadFirstMain(HRMCOCr,1,true)) then begin
        res = ReadRecordLink(HRMCOCr,0,Attachr,RLr);
      end;
    otherwise
      goto LHasAttachments;
  end;

LHasAttachments:;
  HasAttachments = res;
  return;
end;

procedure GenerateDownloadURLs(string filename,LongInt recnr,string attachname)
begin
  string 255 url;
  
  url = "/" & HRPortalRoot & "/" & GetEncryptedLink("download/" & filename & "/" & recnr & "/" & Base64EncodeURL(attachname));
  WebOutBegin;
  <p><a href="<?var(url)?>"><?var(attachname)?></a></p>
  EndWebOut;

  return;
end;

procedure AttachmentList(string filename,LongInt recnr)
begin
  record RLinkVc RLr;
  record Attach2Vc Attachr;
  record HRMCOVc HRMCOr;
  record HRMCOChangeVc HRMCOCr;
  Integer filenr;

  switch (filename) begin
    case "HRMCOVc":
      HRMCOr.SerNr = recnr;
      if (ReadFirstMain(HRMCOr,1,true)==false) then begin goto LAttachmentList; end;
      filenr = 1;
      while (ReadRecordLink(HRMCOr,filenr,Attachr,RLr)) begin
        filenr = filenr + 1;
        GenerateDownloadURLs(filename,HRMCOr.SerNr,Attachr.FileName);
      end;
    case "HRMCOChangeVc":
      HRMCOCr.SerNr = recnr;
      if (ReadFirstMain(HRMCOCr,1,true)==false) then begin goto LAttachmentList; end;
      filenr = 1;
      while (ReadRecordLink(HRMCOCr,filenr,Attachr,RLr)) begin
        filenr = filenr + 1;
        GenerateDownloadURLs(filename,HRMCOCr.SerNr,Attachr.FileName);
      end;
    otherwise
      goto LAttachmentList;
  end;

LAttachmentList:;
  return;
end;

function Boolean FindEmployee(var record CUVc CUr)
begin
  Boolean res;
  record UserVc Userr;
  
  CUr.Code = CurrentCust;
  if (ReadFirstMain(CUr,1,true)==false) then begin
    GetCurrentUser(Userr);
    Userr.Code = CurrentUser;
    if (ReadFirstMain(Userr,1,true)==false) then begin
      res = false;
      goto LFindEmployee;
    end;
    CUr.Code = Userr.CustCode;
    if (ReadFirstMain(CUr,1,true)==false) then begin
      res = false;
      goto LFindEmployee;
    end;
  end;
  if (CUr.EmployeeType==1) then begin res = true; end;
LFindEmployee:;
  FindEmployee = res;
  return;
end;

procedure DownloadsModal(string filename,LongInt recnr)
begin
  if (HasAttachments(filename,recnr)) then begin
    WebOutBegin;
    <td data-label="Downloads">
      <label for="modal-downloads" class="button primary">Downloads</label>
      <input type="checkbox" id="modal-downloads" class="modal">
      <div>
        <div class="card">
        <label for="modal-downloads" class="modal-close"></label>
          <h4 class="section">Downloads </h4>
          EndWebOut;
          AttachmentList(filename,recnr);
          WebOutBegin;
        </div>
      </div>	
    </td>
    EndWebOut;
  end else begin
    WebOutBegin;
    <td data-label="Downloads"><div class="button primary" disabled>Downloads</div></td>
    EndWebOut;
  end;
  return;
end;

global
function Boolean HRPortalUserLoggedIn()
begin
  Boolean res;

  if (nonblank(CurrentCust) or nonblank(CurrentUser)) then begin
    res = true;
  end;

  HRPortalUserLoggedIn = res;
  return;
end;

