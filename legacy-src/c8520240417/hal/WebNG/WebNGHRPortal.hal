procedure HRPortalShowPage(string page)
begin
  record WebNGPageVc WPr;
  record WebNGStructVc WSr;

  WPr.Code = page;
  if (ReadFirstMain(WPr,1,true)) then begin
    WSr.WebPage = WPr.Code;
    ShowWebPage(WSr);
  end;

  return;
end;

