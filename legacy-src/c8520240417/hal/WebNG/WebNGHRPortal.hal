procedure ShowContractChangeRow(array record HRMCOChangeVc arrHRMCOCr)
begin
  Integer i;
  record HRMCOChangeVc HRMCOCr;

  for (i=0;i<arrHRMCOCr.length;i=i+1) begin
    HRMCOCr = arrHRMCOCr[i];
    WebOutBegin;
    <tr>
      <td data-label="Job Title"><?var(HRMCOCr.JobTitleDesc)?></td>
      <td data-label="Start Date"><?var(DateToString(HRMCOCr.TransDate,"YYYY-MM-DD"))?></td>
      <td data-label="Trial period end date"><?var(DateToString(HRMCOCr.TrialEndDate,"YYYY-MM-DD"))?></td>
      <td data-label="Gross Salary"><?var(ValToString(HRMCOCr.GrossSalary,M4Val,"",".",2))?></td>
      <td data-label="Currency"><?var(HRMCOCr.CurncyCode)?></td>
      <td data-label="Salary Type"><?var(StringFromSet(463,HRMCOCr.SalaryType))?></td>
      EndWebOut;
      DownloadsModal("HRMCOChangeVc",HRMCOCr.SerNr);
      WebOutBegin;
    </tr>
    EndWebOut;
  end;
  return;
end;

procedure ShowContractBenefits(LongInt conr)
begin
  record CUVc CUr;
  record HRMCOVc HRMCOr;
  row HRMCOVc HRMCOrw;
  Integer rwcnt,i;

  if (FindEmployee(CUr)==false) then begin
    ShowErrorPage("Employee not found"); //TODO IMPROVE
    goto LShowContractBenefits;
  end;

  HRMCOr.SerNr = conr;
  if (ReadLastMain(HRMCOr,1,true)==false) then begin
    ShowErrorPage("Contract not found");
    goto LShowContractBenefits;
  end;

  WebOutBegin;
  <div class="container">
    <br>
    <h1><?var(CUr.Name)?></h1>
    <br>
    <h4>Employment Contracts - Benefits</h4>	
    <br>
    <table class="striped">
      <thead>
        <tr>
          EndWebOut;
          ShowBenefitsHeader;
          WebOutBegin;
        </tr>
      </thead>
      <tbody>
      EndWebOut;
      rwcnt = MatRowCnt(HRMCOr);
      for (i=0;i<rwcnt;i=i+1) begin
        MatRowGet(HRMCOr,i,HRMCOrw);
        WebOutBegin;
          <tr>
            <td data-label="Description"><?var(HRMCOrw.Description)?></td>
            <td data-label="Type"><?var(HRMCOrw.Type)?></td>
            <td data-label="Terms"><?var(HRMCOrw.Terms)?></td>
            <td data-label="Amount"><?var(ValToString(HRMCOrw.Amount,M4Val,"",".",2))?></td>
            <td data-label="Currency"><?var(HRMCOrw.CurncyCode)?></td>
            <td data-label="Frequency"><?var(StringFromSet(753,HRMCOrw.Frequency))?></td>
            <td data-label="Start Date<"><?var(DateToString(HRMCOrw.StartDate,"YYYY-MM-DD"))?></td>
            <td data-label="End Date"><?var(DateToString(HRMCOrw.EndDate,"YYYY-MM-DD"))?></td>
          </tr>
        EndWebOut;
      end;
      WebOutBegin;
      </tbody>
    </table>
  </div>
  EndWebOut;
LShowContractBenefits:;
  return;
end;

procedure ShowEmploymentRow(record HRMCOVc HRMCOr)
begin
  string 255 status,details,benefits,disabled;
  Integer rwcnt;

  status = "Active";
  if (HRMCOr.TerminatedFlag) then begin
    status = "Terminated";
  end;
  details = "employment/view/" & HRMCOr.SerNr;
  benefits = "employment/benefits/" & HRMCOr.SerNr;
  rwcnt = MatRowCnt(HRMCOr);
  if (rwcnt==0) then begin
    disabled = "disabled";
    benefits = "";
  end;

  WebOutBegin;
  <tr>
    <td data-label="Status"><?var(status)?></td>
    <td data-label="Job Title"><?var(HRMCOr.JobTitleDesc)?></td>
    <td data-label="Start date"><?var(DateToString(HRMCOr.StartDate,"YYYY-MM-DD"))?></td>
    <td data-label="Trial period end date"><?var(DateToString(HRMCOr.TrialEndDate,"YYYY-MM-DD"))?></td>
    <td data-label="Gross Salary"><?var(ValToString(HRMCOr.GrossSalary,M4Val,"",".",2))?></td>
    <td data-label="Currency"><?var(HRMCOr.CurncyCode)?></td>
    <td data-label="Salary Type"><?var(StringFromSet(463,HRMCOr.SalaryType))?></td>
    EndWebOut;
    DownloadsModal("HRMCOVc",HRMCOr.SerNr);
    WebOutBegin;
    <td data-label="Uploads"><button class="primary">Upload</button></td>
    <td data-label="Benefits"><a href="<?var(benefits)?>" class="button primary" <?var(disabled)?>>View</a></td>
    <td data-label="Details"><a href="<?var(details)?>" class="button primary">View</a></td>
  </tr>
  EndWebOut;
  return;
end;

procedure GetContractChanges(var record HRMCOVc HRMCOr,var array record HRMCOChangeVc arrHRMCOCr,Boolean loopbackf)
begin
  Boolean foundf,testf;
  record HRMCOChangeVc HRMCOCr;
  
  ClearArray(arrHRMCOCr);
  foundf = true;
  HRMCOCr.HRMCOSerNr = HRMCOr.SerNr;

  while (foundf) begin
    if (loopbackf) then begin
      foundf = LoopBackKey("HRMCONrDate",HRMCOCr,1,foundf);
    end else begin
      foundf = LoopKey("HRMCONrDate",HRMCOCr,1,foundf);
    end;
    if (foundf) then begin
      testf = true;
      if (HRMCOCr.HRMCOSerNr!=HRMCOr.SerNr) then begin testf = false; end;
      if (HRMCOCr.OKFlag==0) then begin testf = false; end;
      if (testf) then begin
        testf = false;
        if (nonblank(HRMCOCr.TrialEndDate)  and HRMCOCr.TrialEndDate!=HRMCOr.TrialEndDate)  then begin testf = true; end;
        if (nonblank(HRMCOCr.JobTitleDesc)  and HRMCOCr.JobTitleDesc!=HRMCOr.JobTitleDesc)  then begin testf = true; end;
        if (nonblank(HRMCOCr.JobTitle)      and HRMCOCr.JobTitle!=HRMCOr.JobTitle)          then begin testf = true; end;
        if (nonblank(HRMCOCr.SalaryType)    and HRMCOCr.SalaryType!=HRMCOr.SalaryType)      then begin testf = true; end;
        if (nonblank(HRMCOCr.GrossSalary)   and HRMCOCr.GrossSalary!=HRMCOr.GrossSalary)    then begin testf = true; end;
        if (nonblank(HRMCOCr.CurncyCode)    and HRMCOCr.CurncyCode!=HRMCOr.CurncyCode)      then begin testf = true; end;
        if (testf) then begin
          HRMCOr.TrialEndDate = HRMCOCr.TrialEndDate;
          HRMCOr.JobTitleDesc = HRMCOCr.JobTitleDesc;
          HRMCOr.JobTitle = HRMCOCr.JobTitle;
          HRMCOr.SalaryType = HRMCOCr.SalaryType;
          HRMCOr.GrossSalary = HRMCOCr.GrossSalary;
          HRMCOr.CurncyCode = HRMCOCr.CurncyCode;
        end;
        arrHRMCOCr[arrHRMCOCr.length] = HRMCOCr;
      end;
    end;
  end;
  return;
end;

procedure ShowContractChanges(LongInt conr)
begin
  record HRMCOVc HRMCOr,initialHRMCOr;
  array record HRMCOChangeVc arrHRMCOCr;
  record CUVc CUr;

  if (FindEmployee(CUr)==false) then begin
    ShowErrorPage("Employee not found"); //TODO IMPROVE
    goto LShowContractChanges;
  end;

  HRMCOr.SerNr = conr;
  if (ReadLastMain(HRMCOr,1,true)==false) then begin
    ShowErrorPage("Contract not found");
    goto LShowContractChanges;
  end;

  initialHRMCOr = HRMCOr;
  GetContractChanges(HRMCOr,arrHRMCOCr,true);

  WebOutBegin;
  <div class="container">
    <br>
    <h1><?var(CUr.Name)?></h1>
    <br>
    <h4>Employment Contracts - Changes Overview</h4>	
    <br>
    <table class="striped">
      <thead>
        <tr>
          EndWebOut;
          ContractChangesHeader;
          WebOutBegin;
        </tr>
      </thead>
      <tbody>
          EndWebOut;
          ShowContractChangeRow(arrHRMCOCr);
          WebOutBegin;
          <tr>
          <td data-label="Job Title"><?var(initialHRMCOr.JobTitleDesc)?></td>
          <td data-label="Start Date"><?var(DateToString(initialHRMCOr.StartDate,"YYYY-MM-DD"))?></td>
          <td data-label="Trial period end date"><?var(DateToString(initialHRMCOr.TrialEndDate,"YYYY-MM-DD"))?></td>
          <td data-label="Gross Salary"><?var(ValToString(initialHRMCOr.GrossSalary,M4Val,"",".",2))?></td>
          <td data-label="Currency"><?var(initialHRMCOr.CurncyCode)?></td>
          <td data-label="Salary Type"><?var(StringFromSet(463,initialHRMCOr.SalaryType))?></td>
          EndWebOut;
          DownloadsModal("HRMCOr",initialHRMCOr.SerNr);
          WebOutBegin;
        </tr>
      </tbody>
    </table>
  </div>
  EndWebOut;
LShowContractChanges:;
  return;
end;

global
procedure ShowHRPortalEmploymentPage(string path)
begin
  record CUVc CUr;
  record HRMCOVc HRMCOr;
  array record HRMCOChangeVc arrHRMCOCr;
  Boolean foundf,testf;
  Integer cnt;  
  string 255 mpath,node;
  transaction string 255 gHRPortalPath;

  mpath = path;
  node = removenextnode(mpath);

  if (FindEmployee(CUr)==false) then begin
    ShowErrorPage("Employee not found"); //TODO IMPROVE
    goto LShowHRPortalEmploymentPage;
  end;

  if (nonblank(mpath)) then begin
    switch (node) begin
      case "view":      ShowContractChanges(StringToLongInt(mpath));
      case "edit":      ShowErrorPage("Not Implemented");
      case "benefits":  ShowContractBenefits(StringToLongInt(mpath));
    end;
    goto LShowHRPortalEmploymentPage;
  end;

  WebOutBegin;
  <div class="container">
    <br>
    <h1><?var(CUr.Name)?></h1>
    <br>
    <h4>Employment Contracts</h4>	
    <br>
    <table class="striped">
      <thead>
        <tr>
          EndWebOut;
          EmploymentRowHeader;
          WebOutBegin;
        </tr>
      </thead>
      <tbody>
  EndWebOut;

  foundf = true;
  HRMCOr.Employee = CUr.Code;
  while (LoopBackKey("EmployeeDateSerNr",HRMCOr,1,foundf)) begin
    if (HRMCOr.Employee!=CUr.Code) then begin foundf = false; end;
    if (foundf) then begin
      testf = true;
      if (HRMCOr.OKFlag!=1) then begin testf = false; end;
      if (testf) then begin
        cnt = cnt + 1;
        GetContractChanges(HRMCOr,arrHRMCOCr,false);
        ShowEmploymentRow(HRMCOr);
      end;
    end;
  end;
  if (cnt==0) then begin
    WebOutBegin;    
      <tr>
        <td colspan="9">No employment contracts found</td>
      </tr>
    EndWebOut;
  end;
  WebOutBegin;
      </tbody>
    </table>
  </div>
  EndWebOut;
LShowHRPortalEmploymentPage:;
  return;
end;

procedure DoHandleDownloadRequest(string filename,LongInt recnr,string attachname)
begin
  Boolean foundf;
  record RLinkVc RLr;
  record Attach2Vc Attachr;
  record HRMCOVc HRMCOr;
  record HRMCOChangeVc HRMCOCr;
  Integer i;

  switch (filename) begin
    case "HRMCOVc":
      HRMCOr.SerNr = recnr;
      if (ReadFirstMain(HRMCOr,1,true)==false) then begin goto LDoHandleDownloadRequest; end;
      while (ReadRecordLink(HRMCOr,i,Attachr,RLr)) begin
        if (Attachr.FileName==attachname) then begin goto LWebOut; end;
        i = i + 1;
      end;
    case "HRMCOChangeVc":
      HRMCOCr.SerNr = recnr;
      if (ReadFirstMain(HRMCOCr,1,true)==false) then begin goto LDoHandleDownloadRequest; end;
      while (ReadRecordLink(HRMCOCr,i,Attachr,RLr)) begin
        if (Attachr.FileName==attachname) then begin goto LWebOut; end;
        i = i + 1;
      end;
  end;

  if (false) then begin //intentional
LWebOut:;
    WebSetContentDisposition("attachment;filename=" & Attachr.FileName);
    WebSetContentType("application/" & GetFileExtension(Attachr.FileName));
    WebOutAttachment(Attachr.SerNr);
  end;
LDoHandleDownloadRequest:;
  return;
end;

procedure HandleDownloadRequest(string path)
begin
  string 255 node,mpath;
  string 255 filename,attachname;
  LongInt recnr;

  mpath = path;
  filename = removenextnode(mpath);
  recnr = StringToLongInt(removenextnode(mpath));
  attachname = Base64Decode(removenextnode(mpath));
  
  switch (filename) begin
    case "HRMCOVc":       DoHandleDownloadRequest(filename,recnr,attachname);
    case "HRMCOChangeVc": DoHandleDownloadRequest(filename,recnr,attachname);
  end;
LHandleDownloadRequest:;
  return;
end;

global 
procedure ShowHRPortalContentPage()
begin
  record CUVc CUr;
  transaction string 255 gHRPortalPath;
  string 255 mpath,node;

  mpath = gHRPortalPath;
  node = removenextnode(mpath);

  switch (node) begin
    // case "learning":    HRPortalShowPage(HRPb.PageApp);
    case "employment":  ShowHRPortalEmploymentPage(mpath);
    // case "leave":       HRPortalShowPage(HRPb.PageApp);
    // case "expenses":    HRPortalShowPage(HRPb.PageApp);
    case "personal":    ShowHRPortalPersonalPage;
    case "download":    HandleDownloadRequest(mpath);
  end;
LShowHRPortalContentPage:;
  return;
end;

global
updating procedure HRPortalApp(record WebNGStructVc WSr,string path)
begin
  string 255 node,mpath,tstr;
  record HRPortalBlock HRPb;
  transaction string 255 gExtraHeadHTML;
  transaction string 255 gHRPortalPath;

  BlockLoad(HRPb);

  if (HRPb.Active==0) then begin 
    goto LHRPortalApp; 
  end;

  gExtraHeadHTML = HRPortalAppHead;

  mpath = path;
  gHRPortalPath = mpath;
  node = removenextnode(mpath);

  if (HRPortalUserLoggedIn==false and node!="login") then begin
    RedirectToURL(FormatSimpleLink("/" & HRPortalRoot & "/login",true));
  end;

  switch (node) begin
    case "login":
      if (HRPortalUserLoggedIn) then begin
        RedirectToURL(FormatSimpleLink("/" & HRPortalRoot & "/personal",true));
      end else begin
        HRPortalShowPage(HRPb.PageLogin);
      end;
    case "logout": 
      WebLogOut;
      RedirectToURL(FormatSimpleLink("/" & HRPortalRoot,true));
    case "learning":    HRPortalShowPage(HRPb.PageApp);
    case "employment":  HRPortalShowPage(HRPb.PageApp);
    case "leave":       HRPortalShowPage(HRPb.PageApp);
    case "expenses":    HRPortalShowPage(HRPb.PageApp);
    case "personal":    HRPortalShowPage(HRPb.PageApp);
    case "download":    HRPortalShowPage(HRPb.PageApp);
    otherwise
      if (HRPortalUserLoggedIn) then begin
        RedirectToURL(FormatSimpleLink("/" & HRPortalRoot & "/personal",true));
      end;
  end;
LHRPortalApp:;
  return;
end;