global
updating function LongInt MarketCityVcRecordCheck(record MarketCityVc MarketCityr,record MarketCityVc MarketCity2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(MarketCityr.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LMarketCityVcRecordCheck;
  end;
LMarketCityVcRecordCheck:;  
  MarketCityVcRecordCheck = res;
  return;
end;
