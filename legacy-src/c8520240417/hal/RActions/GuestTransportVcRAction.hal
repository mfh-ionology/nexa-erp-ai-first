global
updating function LongInt GuestTransportVcRecordCheck(record GuestTransportVc GuestTransportr,record GuestTransportVc GuestTransport2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(GuestTransportr.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LGuestTransportVcRecordCheck;
  end;
LGuestTransportVcRecordCheck:;  
  GuestTransportVcRecordCheck = res;
  return;
end;