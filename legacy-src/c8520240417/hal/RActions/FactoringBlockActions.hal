global
updating function LongInt FactoringBlockCheck(var record FactoringBlock Fb,record FactoringBlock F2b,LongInt stat,LongInt long4)
begin
  LongInt res;

  res = 0;  
  if (Fb.Bank==kFactoringFormatOsuusPankkiFIN) then begin
    if (Len(Fb.User)>8) then begin
      RecordCheckError(43080,"",-1,"User");
      res = -1;
      goto LFactoringBlockCheck;
    end;
  end;
LFactoringBlockCheck:;  
  FactoringBlockCheck = res;
  return;
end;