global
updating function LongInt TerminModelVcRecordCheck(record TerminModelVc TerminModelr,record TerminModelVc TerminModel2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(TerminModelr.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LTerminModelVcRecordCheck;
  end;
LTerminModelVcRecordCheck:;  
  TerminModelVcRecordCheck = res;
  return;
end;