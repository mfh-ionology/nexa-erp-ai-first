global
function LongInt ResourceStatusVcRecordCheck(var record ResourceStatusVc RSr,record ResourceStatusVc RS2r,LongInt stat,LongInt long4)
begin
  LongInt res;
  record ResUsageVc ResUsager;
  record INVc INr;
  record CClassDVc CClassDr;

  res = 0;
  if (blank(RSr.Code)) then begin
    RecordCheckError(2210,"",-1,"Code");      
    res = -1;
    goto LResourceStatusVcRecordCheck;
  end;  
LResourceStatusVcRecordCheck:;
  ResourceStatusVcRecordCheck = res;
  return;
end;
