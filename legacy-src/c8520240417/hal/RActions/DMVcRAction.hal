global
function LongInt DMVcRecordCheck(var record DMVc DMr,record DMVc DM2r,LongInt stat,LongInt long4)
begin
  LongInt res;

  res = 0;
  if (blank(DMr.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");    
    res = -1;
    goto LDMVcRecordCheck;
  end;  
  
LDMVcRecordCheck:;
  DMVcRecordCheck = res;
  return;
end;
