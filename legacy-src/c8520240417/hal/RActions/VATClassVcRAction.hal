global
function LongInt VATClassVcRecordCheck(var record VATClassVc VATClassr,record VATClassVc VATClass2r,LongInt stat,LongInt long4)
begin
  LongInt res;
  
  res = 0;
  if (blank(VATClassr.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LVATClassVcRecordCheck;
  end;

LVATClassVcRecordCheck:;
  VATClassVcRecordCheck = res; 
  return;
end; 
