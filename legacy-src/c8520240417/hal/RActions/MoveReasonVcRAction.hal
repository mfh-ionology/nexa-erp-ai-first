global
updating function LongInt MoveReasonVcRecordCheck(record MoveReasonVc MoveReasonr,record MoveReasonVc MoveReason2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(MoveReasonr.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LMoveReasonVcRecordCheck;
  end;
LMoveReasonVcRecordCheck:;  
  MoveReasonVcRecordCheck = res;
  return;
end;