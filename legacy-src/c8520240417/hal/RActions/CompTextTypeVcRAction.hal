
global
updating function LongInt CompTextTypeVcRecordCheck(var record CompTextTypeVc CompTextTyper,record CompTextTypeVc CompTextType2r,LongInt stat,LongInt long4)
begin
  LongInt res;

  res = 0;
  if (blank(CompTextTyper.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LCompTextTypeVcRecordCheck;
  end;  
LCompTextTypeVcRecordCheck:;
  CompTextTypeVcRecordCheck = res;
  return;
end;
