global
updating function LongInt SystaxSenderProfVcRecordCheck(record SystaxSenderProfVc SystaxSenderProfr,record SystaxSenderProfVc SystaxSenderProf2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(SystaxSenderProfr.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LSystaxSenderProfVcRecordCheck;
  end;
LSystaxSenderProfVcRecordCheck:;  
  SystaxSenderProfVcRecordCheck = res;
  return;
end;