global
updating function LongInt TalkBotDialogEntryVcRecordSave(var record TalkBotDialogEntryVc TBDEr,record TalkBotDialogEntryVc TBDE2r,LongInt stat,LongInt long4)
begin
  LongInt res;
  record TalkBotDialogVc TBDr;
  record TalkBotDialogEntryVc TBDE3r;
  row TalkBotDialogEntryVc TBDErw;
  LongInt rwcnt,rwn;
  
  if (TBDEr.SerNr==-1) then begin
    TBDEr.SerNr = NextSerNr("TalkBotDialogEntryVc",CurrentDate,-1,false,"");
  end;

  if (TBDEr.DialogNr!=-1) then begin
    TBDr.SerNr = TBDEr.DialogNr;
    if (ReadFirstMain(TBDr,1,true)) then begin
      TBDEr.DialogComment = TBDr.Comment;
    end;
  end;
  
  if (TBDEr.NextDialogEntryNr!=-1) then begin
    TBDE3r.SerNr = TBDEr.NextDialogEntryNr;
    if (ReadFirstMain(TBDE3r,1,true)) then begin
      TBDEr.NextDialogEntryComment = TBDE3r.Comment;
    end;
  end;
  
  rwcnt = MatRowCnt(TBDEr);
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(TBDEr,rwn,TBDErw);
    if (TBDErw.DialogEntryNr!=-1) then begin
      TBDE3r.SerNr = TBDErw.DialogEntryNr;
      if (ReadFirstMain(TBDE3r,1,true)) then begin
        TBDErw.DialogEntryComment = TBDE3r.Comment;
        MatRowPut(TBDEr,rwn,TBDErw);
      end;
    end;
  end;
    
  if (blank(TBDEr.Comment)) then begin
    TBDEr.Comment = "Untitled entry " & TBDEr.SerNr;
  end;
  
  TalkBotDialogEntryVcRecordSave = res;
  return;
end;

global
updating function LongInt TalkBotDialogEntryVcRecordUpdate(var record TalkBotDialogEntryVc TBDEr,record TalkBotDialogEntryVc TBDE2r,LongInt stat,LongInt long4)
begin
  LongInt res;
  record TalkBotDialogVc TBDr;
  record TalkBotDialogEntryVc TBDE3r;
  row TalkBotDialogEntryVc TBDErw;
  LongInt rwcnt,rwn;

  if (TBDEr.DialogNr!=-1) then begin
    TBDr.SerNr = TBDEr.DialogNr;
    if (ReadFirstMain(TBDr,1,true)) then begin
      TBDEr.DialogComment = TBDr.Comment;
    end;
  end;
  
  if (TBDEr.NextDialogEntryNr!=-1) then begin
    TBDE3r.SerNr = TBDEr.NextDialogEntryNr;
    if (ReadFirstMain(TBDE3r,1,true)) then begin
      TBDEr.NextDialogEntryComment = TBDE3r.Comment;
    end;
  end;
  
  rwcnt = MatRowCnt(TBDEr);
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(TBDEr,rwn,TBDErw);
    if (TBDErw.DialogEntryNr!=-1) then begin
      TBDE3r.SerNr = TBDErw.DialogEntryNr;
      if (ReadFirstMain(TBDE3r,1,true)) then begin
        TBDErw.DialogEntryComment = TBDE3r.Comment;
        MatRowPut(TBDEr,rwn,TBDErw);
      end;
    end;
  end;
  
  if (blank(TBDEr.Comment)) then begin
    TBDEr.Comment = "Untitled entry " & TBDEr.SerNr;
  end;
  
  TalkBotDialogEntryVcRecordUpdate = res;
  return;
end;

global
updating function LongInt TalkBotDialogEntryVcRecordUpdateAfter(var record TalkBotDialogEntryVc TBDEr,record TalkBotDialogEntryVc TBDE2r,LongInt stat,LongInt long4)
begin
  LongInt res,rwn,rwcnt;
  record TalkBotDialogTextsVc TBDTr,OldTBDTr;
  record TalkBotDialogVc TBDr,oldTBDr;
  record TalkBotDialogEntryVc TBDE3r,oldTBDE3r;
  row TalkBotDialogEntryVc TBDE3rw;
  row TalkBotDialogVc TBDrw;
  Boolean foundf;
  
  if (TBDEr.Comment<>TBDE2r.Comment) then begin goto LTalkBotDialogEntryVcRecordUpdateAfter; end;
  
  foundf = true;
  TBDTr.DialogEntryNr = TBDE2r.SerNr;
  while (LoopKey("DialogEntryNr",TBDTr,1,foundf)) begin
    if (TBDTr.DialogEntryNr!=TBDEr.SerNr) then begin foundf = false; end;
    if (foundf) then begin
      RecordCopy(OldTBDTr,TBDTr);
      TBDTr.DialogEntryComment = TBDEr.Comment;
      RecordUpdate(OldTBDTr,TBDTr,true);
    end;
  end;
  
  foundf = true;
  TBDE3r.DialogNr = TBDE2r.DialogNr;
  while (LoopKey("DialogNr",TBDE3r,1,foundf)) begin
    for (rwn=0;rwn<rwcnt;rwn=rwn+1) begin
      MatRowGet(TBDE3r,rwn,TBDE3rw);
      if (TBDE3rw.DialogEntryNr==TBDE2r.SerNr) then begin
        RecordCopy(OldTBDE3r,TBDE3r);
        TBDE3rw.DialogEntryComment = TBDE2r.Comment;
        MatRowPut(TBDE3r,rwn,TBDE3rw);
        RecordUpdate(OldTBDE3r,TBDE3r,true);
      end;
    end;
  end;
  
  TBDr.SerNr = TBDEr.DialogNr;
  if (ReadFirstMain(TBDr,1,true)) then begin
    RecordCopy(OldTBDr,TBDr);
    rwcnt = MatRowCnt(TBDr);
    for (rwn=0;rwn<rwcnt;rwn=rwn+1) begin
      MatRowGet(TBDr,rwn,TBDrw);
      if (TBDrw.DialogEntryNr==TBDEr.SerNr) then begin
        TBDrw.DialogEntryComment = TBDEr.Comment;
        MatRowPut(TBDr,rwn,TBDrw);
        RecordUpdate(OldTBDr,TBDr,true);
        rwn = rwcnt;
      end;
    end;
  end;

  LTalkBotDialogEntryVcRecordUpdateAfter:;
  TalkBotDialogEntryVcRecordUpdateAfter = res;
  return;
end;

