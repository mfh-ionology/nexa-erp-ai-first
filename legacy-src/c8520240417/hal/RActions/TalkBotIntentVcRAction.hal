global
updating function LongInt TalkBotDialogVcRecordSave(var record TalkBotDialogVc TBDr,record TalkBotDialogVc TBD2r,LongInt stat,LongInt long4)
begin
  LongInt res;
  record TalkBotDialogEntryVc TBDEr;
  
  if (TBDr.SerNr==-1) then begin
    TBDr.SerNr = NextSerNr("TalkBotDialogVc",CurrentDate,-1,false,"");
  end;

  if (TBDr.FirstDialogEntryNr!=-1) then begin
    TBDEr.SerNr = TBDr.FirstDialogEntryNr;
    if (ReadFirstMain(TBDEr,1,true)) then begin
      TBDr.FirstDialogEntryComment = TBDEr.Comment;
    end;
  end;

  if (TBDr.UnmatchedDialogEntryNr!=-1) then begin
    TBDEr.SerNr = TBDr.UnmatchedDialogEntryNr;
    if (ReadFirstMain(TBDEr,1,true)) then begin
      TBDr.UnmatchedDialogEntryComment = TBDEr.Comment;
    end;
  end;
  
  if (blank(TBDr.Comment)) then begin
    TBDr.Comment = "Untitled skill " & TBDr.SerNr;
  end;

  TalkBotDialogVcRecordSave = res;
  return;
end;

