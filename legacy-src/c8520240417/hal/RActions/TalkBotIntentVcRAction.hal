procedure CheckEmbeddings(var record TalkBotIntentVc TBIr,record TalkBotIntentVc oldTBIr)
begin
  LongInt rwn,rwcnt,orwcnt;
  row TalkBotIntentVc TBIrw;
  row TalkBotIntentVc oldTBIrw;

  rwcnt = MatRowCnt(TBIr);
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(TBIr,rwn,TBIrw);
    
    if (rwn>=orwcnt) then begin
      TBIrw.Embedding = "";
      MatRowPut(TBIr,rwn,TBIrw);
    end else begin
      MatRowGet(oldTBIr,rwn,oldTBIrw);
      if (TBIrw.UserExample<>oldTBIrw.UserExample) then begin
        TBIrw.Embedding = "";
        MatRowPut(TBIr,rwn,TBIrw);
      end;
    end;
  end;
end;

procedure ClearEmbeddings(var record TalkBotIntentVc TBIr)
begin
  LongInt rwn,rwcnt,orwcnt;
  row TalkBotIntentVc TBIrw;
  
  rwcnt = MatRowCnt(TBIr);
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(TBIr,rwn,TBIrw);
    TBIrw.Embedding = "";
    MatRowPut(TBIr,rwn,TBIrw);
  end;
end;

