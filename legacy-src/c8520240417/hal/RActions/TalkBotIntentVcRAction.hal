global
updating function LongInt TalkBotDialogVcRecordUpdateAfter(var record TalkBotDialogVc TBDr,record TalkBotDialogVc TBD2r,LongInt stat,LongInt long4)
begin
  LongInt res;
  record TalkBotDialogEntryVc TBDEr,OldTBDEr;
  record TalkBotEntityVc TBEr,OldTBEr;
  record TalkBotIntentVc TBIr,OldTBIr;
  Boolean foundf;
  
  if (TBDr.Comment==TBD2r.Comment) then begin goto LTalkBotDialogVcRecordUpdateAfter; end;
  foundf = true;
  TBDEr.DialogNr = TBDr.SerNr;
  while (LoopKey("DialogNr",TBDEr,1,foundf)) begin
    if (TBDEr.DialogNr!=TBDr.SerNr) then begin foundf = false; end;
    if (foundf) then begin
      RecordCopy(OldTBDEr,TBDEr);
      TBDEr.DialogComment = TBDr.Comment;
      RecordUpdate(OldTBDEr,TBDEr,true);
    end;
  end;
  
  foundf = true;
  TBEr.DialogNr = TBDr.SerNr;
  while (LoopMain(TBEr,1,foundf)) begin
    if (TBEr.DialogNr!=TBDr.SerNr) then begin foundf = false; end;
    if (foundf) then begin
      RecordCopy(OldTBEr,TBEr);
      TBEr.DialogComment = TBDr.Comment;
      RecordUpdate(OldTBEr,TBEr,true);
    end;
  end;
  
  foundf = true;
  TBIr.DialogNr = TBDr.SerNr;
  while (LoopMain(TBIr,1,foundf)) begin
    if (TBIr.DialogNr!=TBDr.SerNr) then begin foundf = false; end;
    if (foundf) then begin
      RecordCopy(OldTBIr,TBIr);
      TBIr.DialogComment = TBDr.Comment;
      RecordUpdate(OldTBIr,TBIr,true);
    end;
  end;

  LTalkBotDialogVcRecordUpdateAfter:;
  TalkBotDialogVcRecordUpdateAfter = res;
  return;
end;

