global
updating function LongInt TalkBotIntentVcRecordSave(var record TalkBotIntentVc TBIr,record TalkBotIntentVc TBI2r,LongInt stat,LongInt long4)
begin
  LongInt res;
  record TalkBotDialogVc TBDr;
  
  ClearEmbeddings(TBIr);
  
  if (TBIr.DialogNr!=-1) then begin
    TBDr.SerNr = TBIr.DialogNr;
    if (ReadFirstMain(TBDr,1,true)) then begin
      TBIr.DialogComment = TBDr.Comment;
    end;
  end;
  
  TalkBotIntentVcRecordSave = res;
  return;
end;

global
updating function LongInt TalkBotIntentVcRecordUpdate(var record TalkBotIntentVc TBIr,record TalkBotIntentVc TBI2r,LongInt stat,LongInt long4)
begin
  LongInt res;
  record TalkBotDialogVc TBDr;

  if (stat==Rs_update) then begin
    CheckEmbeddings(TBIr,TBI2r);
  end;
  
  if (TBIr.DialogNr!=-1) then begin
    TBDr.SerNr = TBIr.DialogNr;
    if (ReadFirstMain(TBDr,1,true)) then begin
      TBIr.DialogComment = TBDr.Comment;
    end;
  end;
  
  TalkBotIntentVcRecordUpdate = res;
  return;
end;

