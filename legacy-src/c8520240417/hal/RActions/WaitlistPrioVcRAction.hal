global
updating function LongInt WaitlistPrioVcRecordCheck(record WaitlistPrioVc WaitlistPrior,record WaitlistPrioVc WaitlistPrio2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(WaitlistPrior.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LWaitlistPrioVcRecordCheck;
  end;
LWaitlistPrioVcRecordCheck:;  
  WaitlistPrioVcRecordCheck = res;
  return;
end;
