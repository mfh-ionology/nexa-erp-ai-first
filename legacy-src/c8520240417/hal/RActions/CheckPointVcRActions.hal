global
function LongInt CheckPointVcRecordCheck(var record CheckPointVc CheckPointr,record CheckPointVc CheckPointr2,LongInt a,LongInt b)
begin
  LongInt res;

  res = 0;
  if (CheckPointr.Code=="") then begin
    RecordCheckError(1058,CheckPointr.Code,-1,"Code");      
    res = -1;
    goto LCheckPointVcRecordCheck;
  end;
LCheckPointVcRecordCheck:;
  CheckPointVcRecordCheck = res;
  return;
end;
