global
updating function LongInt GuestTransportTypeVcRecordCheck(record GuestTransportTypeVc GuestTransportTyper,record GuestTransportTypeVc GuestTransportType2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(GuestTransportTyper.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LGuestTransportTypeVcRecordCheck;
  end;
LGuestTransportTypeVcRecordCheck:;  
  GuestTransportTypeVcRecordCheck = res;
  return;
end;