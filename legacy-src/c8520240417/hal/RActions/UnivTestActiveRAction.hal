global
updating function LongInt UnivTestActiveVcRecordCheck(var record UnivTestActiveVc UTAr,record UnivTestActiveVc UTA2r,LongInt stat,LongInt check)
begin
  LongInt res;
  
  res = 0;
  if (blankdate(UTAr.CourseCode)) then begin
    RecordCheckError(1058,"",-1,"CourseCode");
    res = -1;
    goto LUnivTestActiveVcRecordCheck;
  end;
//  res = inner.UnivTestActiveVcRecordCheck(UTAr,UTA2r,stat,check);
  
LUnivTestActiveVcRecordCheck:;
  UnivTestActiveVcRecordCheck = res;
  return;
end;
