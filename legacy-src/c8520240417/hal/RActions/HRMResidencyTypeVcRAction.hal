global
updating function LongInt HRMResidencyTypeVcRecordCheck(record HRMResidencyTypeVc HRMRTr,record HRMResidencyTypeVc HRMRT2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(HRMRTr.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LHRMResidencyTypeVcRecordCheck;
  end;
LHRMResidencyTypeVcRecordCheck:;  
  HRMResidencyTypeVcRecordCheck = res;
  return;
end;