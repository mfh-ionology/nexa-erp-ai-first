global
function LongInt VatPeriodVcRecordCheck(var record VatPeriodVc VatPeriodr,record VatPeriodVc VatPeriodr2,LongInt a,LongInt b)
begin
  LongInt res;

  res = 0;
  if (VatPeriodr.Code=="") then begin
    RecordCheckError(1058,VatPeriodr.Code,-1,"Code");      
    res = -1;
    goto LVatPeriodVcRecordCheck;
  end;
LVatPeriodVcRecordCheck:;
  VatPeriodVcRecordCheck = res;
  return;
end;
