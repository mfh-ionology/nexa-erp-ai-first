global
updating function LongInt HRMBenefitTypeVcRecordCheck(record HRMBenefitTypeVc HRMBenefitTyper,record HRMBenefitTypeVc HRMBenefitType2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(HRMBenefitTyper.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LHRMBenefitTypeVcRecordCheck;
  end;
LHRMBenefitTypeVcRecordCheck:;  
  HRMBenefitTypeVcRecordCheck = res;
  return;
end;