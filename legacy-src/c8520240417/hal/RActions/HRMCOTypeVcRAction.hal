global
updating function LongInt HRMCOTypeVcRecordCheck(record HRMCOTypeVc HRMCOTyper,record HRMCOTypeVc HRMCOType2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(HRMCOTyper.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LHRMCOTypeVcRecordCheck;
  end;
LHRMCOTypeVcRecordCheck:;  
  HRMCOTypeVcRecordCheck = res;
  return;
end;