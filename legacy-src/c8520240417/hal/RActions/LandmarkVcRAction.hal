global
updating function LongInt LandmarkVcRecordCheck(record LandmarkVc Landmarkr,record LandmarkVc Landmark2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(Landmarkr.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LLandmarkVcRecordCheck;
  end;
LLandmarkVcRecordCheck:;  
  LandmarkVcRecordCheck = res;
  return;
end;