global
updating function LongInt LandmarkTypeVcRecordCheck(record LandmarkTypeVc LandmarkTyper,record LandmarkTypeVc LandmarkType2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(LandmarkTyper.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LLandmarkTypeVcRecordCheck;
  end;
LLandmarkTypeVcRecordCheck:;  
  LandmarkTypeVcRecordCheck = res;
  return;
end;