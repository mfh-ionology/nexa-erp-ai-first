global
updating function LongInt FeatureTypeVcRecordCheck(record FeatureVc FeatureTyper,record FeatureTypeVc FeatureType2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(FeatureTyper.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LFeatureTypeVcRecordCheck;
  end;
LFeatureTypeVcRecordCheck:;  
  FeatureTypeVcRecordCheck = res;
  return;
end;