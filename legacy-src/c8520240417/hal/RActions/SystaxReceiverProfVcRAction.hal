global
updating function LongInt SystaxReceiverProfVcRecordCheck(record SystaxReceiverProfVc SystaxReceiverProfr,record SystaxReceiverProfVc SystaxReceiverProf2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(SystaxReceiverProfr.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LSystaxReceiverProfVcRecordCheck;
  end;
LSystaxReceiverProfVcRecordCheck:;  
  SystaxReceiverProfVcRecordCheck = res;
  return;
end;

