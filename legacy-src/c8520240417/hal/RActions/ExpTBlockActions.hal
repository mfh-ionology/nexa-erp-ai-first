global
function LongInt ExpTBlockCheck(var record ExpTBlock ETb,record ExpTBlock ET2b,LongInt stat,LongInt long4)
begin
  LongInt res;
  
  res = 0;
  if (ETb.PayDay!=-1) then begin
    if (ETb.PayDay<1 or ETb.PayDay>31) then begin
      RecordCheckError(42365,"",-1,"PayDay");
      res = -1;
      goto LExpTBlockCheck;
    end;
  end;
  
LExpTBlockCheck:;  
  ExpTBlockCheck = res;
  return;
end;