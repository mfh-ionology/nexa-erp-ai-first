global
updating function LongInt AttractionClassVcRecordCheck(record AttractionClassVc AttractionClassr,record AttractionClassVc AttractionClass2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(AttractionClassr.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LAttractionClassVcRecordCheck;
  end;
LAttractionClassVcRecordCheck:;  
  AttractionClassVcRecordCheck = res;
  return;
end;