global
function LongInt UserASTVcRecordCheck(var record UserASTVc UserASTVr,record UserASTVc UserASTV2r,LongInt stat,LongInt long4)
BEGIN
  LongInt res;
  
  res = 0;
  if (blank(UserASTVr.Signature)) then begin
    RecordCheckError(1058,"",-1,"Signature");      
    res = -1; 
    goto LUserASTVcRecordCheck;
  end;
LUserASTVcRecordCheck:;
  UserASTVcRecordCheck = res;
  RETURN;
END;
