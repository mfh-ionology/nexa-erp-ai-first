global
function LongInt DepVcRecordCheck(var record DepVc Depr,record DepVc Dep2r,LongInt stat,LongInt long4)
begin
  LongInt res;

  res = 0;
  
  if (blank(Depr.Code)) then begin    
    RecordCheckError(1058,"",-1,"Code");   
    res = -1; 
    goto LDepVcRecordCheck;  
  end;
  if (blank(Depr.Description)) then begin    
    RecordCheckError(1058,"",-1,"Description");   
    res = -1; 
    goto LDepVcRecordCheck;  
  end;
  
LDepVcRecordCheck:;
  DepVcRecordCheck = res;
  return;
end;
