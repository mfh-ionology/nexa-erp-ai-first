global
updating function LongInt AttractionVcRecordCheck(record AttractionVc Attractionr,record AttractionVc Attraction2r,LongInt stat,LongInt check)
begin
  LongInt res;

  res = 0;
  if (blank(Attractionr.Code)) then begin
    RecordCheckError(1058,"",-1,"Code");      
    res = -1;
    goto LAttractionVcRecordCheck;
  end;
LAttractionVcRecordCheck:;  
  AttractionVcRecordCheck = res;
  return;
end;