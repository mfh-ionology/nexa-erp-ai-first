//  res = VerifoneBanksys_ProcessTransaction("Void",v,paymode,label,transactionid,timestamp,ProcessingWn,codepage,SentCtrlSeq,results);
  res = VerifoneBanksys_ProcessTransaction("Void",v,paymode,label,"",timestamp,ProcessingWn,codepage,SentCtrlSeq,results,comportclosedf);
LVerifoneBanksys_Reversal:;  
//LogText(0,"5.CloseComPort");  
  res = CloseComPort(0);  
LVerifoneBanksys_Void:;  
//LogText(0,"Magic ");
