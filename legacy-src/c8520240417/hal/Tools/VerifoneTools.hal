function Integer VerifoneBanksys_ReportRequestStart(string transtype,string optype,var string SentCtrlSeq)
begin
  Integer res,noErr;
  string 255 CtrlSeq,tstr; 
  area aterminalreq;
  transaction Integer gVerfioneCounter; 


  gVerfioneCounter = 0;
//[0x02]1[0x1c]
//100[0x1c]0[0x1c]1[0x1c]0[0x1c]6[0x1c][0x1c]978[0x1c][0x1c][0x1c]1[0x1c]
//[0x1c]4.5.5[0x1c]0[0x1c]1[0x1c][0x1c]UI[0x1c][0x1c][0x1c][0x1c][0x1c]
//[0x1c]MLOY;[0x1c][0x1c][0x1c][0x1c][0x1c]Win8 x64[0x1c][0x1c][0x1c][0x1c]
//ECR Simulator 2.1.0.0[0x1c]OCX 2.3.5.0[0x03]::

  CtrlSeq = CtrlSeq & "1" & chr(CC_FS);  //0
  switch (transtype) begin
    case "Report":
      CtrlSeq = CtrlSeq & optype;
  end;
  CtrlSeq = CtrlSeq & chr(CC_FS);
  M4PadString(ValToString(0*100,M4UVal,"","",1),12,"",false,tstr);
  CtrlSeq = CtrlSeq & tstr & chr(CC_FS);
  CtrlSeq = CtrlSeq & "1" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "0" & chr(CC_FS);  //0 = latvian
  CtrlSeq = CtrlSeq & "6" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);  
  CtrlSeq = CtrlSeq & "978" & chr(CC_FS);  //EUR
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "1" & chr(CC_FS);  //10  
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "4.5.5" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "2" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "1" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "UI" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);  //20
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "MLOY;" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);//Win8 x64
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
  CtrlSeq = CtrlSeq & "" & chr(CC_FS);
//  CtrlSeq = CtrlSeq & "PAYYAP 8.2" & chr(CC_FS);
  CtrlSeq = CtrlSeq & BuildProductCode & " " & HansaVersion & chr(CC_FS);//
  CtrlSeq = CtrlSeq & "OCX 2.3.5.0";
  CtrlSeq = CtrlSeq & uchr(CC_ETX);
  CtrlSeq = CtrlSeq & VerifoneBanksys_CalculateLRC(CtrlSeq);  
  CtrlSeq = uchr(CC_STX) & CtrlSeq;

  LogRequest("VerifoneBanksys_ReportRequestStart",CtrlSeq,res);


  res = VerifoneBanksys_SendCommand(CtrlSeq);
  if (res!=noErr) then begin
    goto LVerifoneBanksys_ReportRequestStart;
  end;
  res = VerifoneBanksys_ReadACK(10,CC_ENQ);
  if (res!=noErr) then begin
    goto LVerifoneBanksys_ReportRequestStart;
  end;  

  SentCtrlSeq = CtrlSeq;
LVerifoneBanksys_ReportRequestStart:;  
  VerifoneBanksys_ReportRequestStart = res;
  return;
end;

updating function Integer VerifoneBanksys_ProcessReport(string transtype,string optype,string timestamp,Integer ProcessingWn,string codepage,
                          var string SentCtrlSeq,var string results)
begin
  Integer res,noErr;
  Boolean transsuccessf,comportclosedf;

/*  
  res = VerifoneBanksys_IsTerminalActive;
  if (res!=noErr) then begin
    goto LVerifoneBanksys_ProcessReport;
  end;
*/  
/*  
  res = VerifoneBanksys_GetState(ProcessingWn,paymode,label,"State",transactionid,timestamp,codepage,results);
//Trace("2.VerifoneBanksys_GetState res " & res ,"");
  if (res!=noErr) then begin
    goto LVerifoneBanksys_ProcessReport;
  end;
*/
  
  res = VerifoneBanksys_ReportRequestStart(transtype,optype,SentCtrlSeq);

  if (res!=noErr) then begin
    VerifoneBanksys_TransactionStatus(ProcessingWn,transtype,"2","Error","1000",results,transsuccessf);
    goto LVerifoneBanksys_ProcessReport;
  end;

  res = VerifoneBanksys_WaitForTransactionResult(ProcessingWn,optype,"",transtype,"","",codepage,"",results,comportclosedf);

  if (res!=noErr) then begin
    goto LVerifoneBanksys_ProcessReport;
  end;    

LVerifoneBanksys_ProcessReport:;  
  VerifoneBanksys_ProcessReport = res;
  return;
end;

global
updating procedure CreditCardTerminalReports(Integer mwn,string reportcode)
begin
  record RahaxiBlock Rahaxib; 
  record LocalMachineBlock LMb;  
  record LSerialPortDeviceVc LSPDr;
  Integer res,noErr;
  string 255 SentCtrlSeq,results,codepage;
  Integer wn;
  record RcVc RepSpec;

  BlockLoad(LMb);
  BlockLoad(Rahaxib);

  switch (Rahaxib.TerminalType) begin
    case kLocalCCTerminalVerifoneBanksys:
      if (FindLocalSerialPortDevice(kSerialPortDeviceClassCreditCardTerminal,kSerialPortDeviceModelCreditCardTerminalVerifoneWX675,LMb.LocalMachineCode,LSPDr)) then begin  
        RepSpec.f11 = "Report";
        RepSpec.f10 = "RcVc";
        wn = OpenWindow("CCPayVerifoneProcessingWClass",0,mwn,"","",RepSpec);
        DeselectWindow(wn,false);

        TCPIPVerifoneWX675_Report(LMb,LSPDr,reportcode,wn);
        goto LCreditCardTerminalReports;
      end;

      if (FindLocalSerialPortDevice(kSerialPortDeviceClassCreditCardTerminal,kSerialPortDeviceModelCreditCardTerminalVerifoneBanksys,LMb.LocalMachineCode,LSPDr)==false) then begin  
        goto LCreditCardTerminalReports;
      end;  
    case kLocalCCTerminalWorldPay:
      if (FindLocalSerialPortDevice(kSerialPortDeviceClassCreditCardTerminal,kSerialPortDeviceModelCreditCardTerminalWorldPay,LMb.LocalMachineCode,LSPDr)) then begin  
        RepSpec.f12 = reportcode;
        wn = OpenWindow("WorldPayTerminalReportWClass",0,mwn,"","",RepSpec);
        DeselectWindow(wn,false);

        TCPIPWorldPay_Report(LMb,LSPDr,reportcode,wn);
        goto LCreditCardTerminalReports;
      end;
  end;
//LogText(0,"8.OpenComPort");  
  if (OpenComPort(0,LSPDr.Port,LSPDr.BaudRate,LSPDr.Parity,LSPDr.ByteSize,LSPDr.StopBits,LSPDr.FlowControl)==0) then begin
    goto LCreditCardTerminalReports;
  end;
  RepSpec.f11 = "Report";
  RepSpec.f10 = "RcVc";
  wn = OpenWindow("CCPayVerifoneProcessingWClass",0,mwn,"","",RepSpec);
  DeselectWindow(wn,false);

  codepage = StringSetFromString(89,LSPDr.Codepage);
  BlockLoad(Rahaxib);
  switch (Rahaxib.TerminalType) begin
    case kLocalCCTerminalVerifoneBanksys:
      res = VerifoneBanksys_ProcessReport("Report",reportcode,"",wn,codepage,SentCtrlSeq,results);
  end;
//LogText(0,"8.CloseComPort");  
  CloseComPort(0);  
LCreditCardTerminalReports:;
//LogText(0,"Magic ");
  return;
end;

global
procedure CancelCCPayVerifoneCashierActionOClass()
begin
  record RahaxiBlock Rahaxib; 
  record LocalMachineBlock LMb;  
  record LSerialPortDeviceVc LSPDr;
  Integer wn;
  record RcVc RepSpec;
  transaction Integer gVerfioneCounter; 
  transaction Integer gVerfioneTimeOut; 

  wn = CurWindow;
  GetWindowRecord(wn,RepSpec);
  gVerfioneCounter = RepSpec.FirstVer;
  BlockLoad(LMb);
  BlockLoad(Rahaxib);
  switch (Rahaxib.TerminalType) begin
    case kLocalCCTerminalVerifoneBanksys:
      if (FindLocalSerialPortDevice(kSerialPortDeviceClassCreditCardTerminal,kSerialPortDeviceModelCreditCardTerminalVerifoneBanksys,LMb.LocalMachineCode,LSPDr)==false) then begin  
        goto LCancelCCPayVerifoneCashierActionOClass;
      end;  
  end;
//LogText(0,"9.OpenComPort");  
  if (OpenComPort(0,LSPDr.Port,LSPDr.BaudRate,LSPDr.Parity,LSPDr.ByteSize,LSPDr.StopBits,LSPDr.FlowControl)==0) then begin
    goto LCancelCCPayVerifoneCashierActionOClass;
  end;
//LogText(0,"3.VerifoneBanksys_TransactionCancellation");  
  VerifoneBanksys_TransactionCancellation;  

//LogText(0,"9.CloseComPort");  
  CloseComPort(0);  
LCancelCCPayVerifoneCashierActionOClass:;  
  CloseWindow(wn);
  gVerfioneTimeOut = 0;
//LogText(0,"Magic ");
  return;
end;

global
updating procedure ProceedCCPayVerifoneCashierActionOClass()
begin
  record RahaxiBlock Rahaxib; 
  record LocalMachineBlock LMb;  
  record LSerialPortDeviceVc LSPDr;
  Integer wn,res,status,vwn;
  record RcVc RepSpec;
  record RcVc vRepSpec;
  string 255 codepage,tagstr;
  transaction Integer gVerfioneCounter; 
  Integer mindatalen,maxdatalen;
  transaction Integer gVerfioneTimeOut; 
  LongInt verfionestarttick;
  Boolean selectwnf;

  tagstr = PushButtonTag;
  wn = CurWindow;
  DeselectWindow(wn,false);
  GetWindowRecord(wn,RepSpec);
  mindatalen = StringToInt(GetWindowString(wn,"mindatalen"));
  maxdatalen = StringToInt(GetWindowString(wn,"maxdatalen"));
  gVerfioneTimeOut = StringToInt(GetWindowString(wn,"verfionetimeout")); 
  verfionestarttick = StringToLongInt(GetWindowString(wn,"verfionestarttick"));

//LogText(0,"10.ProceedCCPayVerifoneCashierActionOClass f1 " & RepSpec.f1 & " f8 " & RepSpec.f8  & " f9 " & RepSpec.f9 & " f10 " & RepSpec.f10 & " codepage " & codepage);
//LogText(0,"11.ProceedCCPayVerifoneCashierActionOClass AccStr " & RepSpec.AccStr & " f5 " & RepSpec.f5);

  if (verfionestarttick>0 and gVerfioneTimeOut>0) then begin
//LogText(0," GetCurTick " & GetCurTick & " verfionestarttick " & verfionestarttick & " gVerfioneTimeOut " & gVerfioneTimeOut & " tagstr " & tagstr);  
    if ((GetCurTick-verfionestarttick)>=gVerfioneTimeOut*1000.00) then begin
      if (tagstr=="4") then begin
        CloseWindow(wn);
      end else begin
        RepSpec.f11 = "Timeout";
        PutWindowRecord(wn,RepSpec);
//LogText(0,"Z100. VerifoneBanksys_InputFormReply 3 ");
      end;
      goto LProceedCCPayVerifoneCashierActionOClass;
    end;
  end;
  if (tagstr!="4") then begin
    selectwnf = true;
    if (blank(RepSpec.f1)) then begin
      MessageBox(40450,"");
      goto LProceedCCPayVerifoneCashierActionOClass;
    end;
    if (mindatalen>0) then begin
      if (len(RepSpec.f1)<mindatalen) then begin
        MessageBox(40450,"");
        goto LProceedCCPayVerifoneCashierActionOClass;
      end;
    end;
    if (maxdatalen>0) then begin
      if (len(RepSpec.f1)>maxdatalen) then begin
        MessageBox(40451,"");
        goto LProceedCCPayVerifoneCashierActionOClass;
      end;
    end;
  end;
  gVerfioneCounter = RepSpec.FirstVer;
  BlockLoad(LMb);
  BlockLoad(Rahaxib);
  switch (Rahaxib.TerminalType) begin
    case kLocalCCTerminalVerifoneBanksys:
      if (FindLocalSerialPortDevice(kSerialPortDeviceClassCreditCardTerminal,kSerialPortDeviceModelCreditCardTerminalVerifoneBanksys,LMb.LocalMachineCode,LSPDr)==false) then begin  
        CloseWindow(wn);
        goto LProceedCCPayVerifoneCashierActionOClass;
      end;  
  end;
////LogText(0,"10.OpenComPort");  
  if (OpenComPort(0,LSPDr.Port,LSPDr.BaudRate,LSPDr.Parity,LSPDr.ByteSize,LSPDr.StopBits,LSPDr.FlowControl)==0) then begin
    CloseWindow(wn);
    goto LProceedCCPayVerifoneCashierActionOClass;
  end;
  codepage = StringSetFromString(89,LSPDr.Codepage);
  SetComPortCodepage(codepage);
  vRepSpec.UsedOnly = kLocalCCTerminalVerifoneBanksys;
  vRepSpec.ArtMode = 1;
  vRepSpec.long1 = RepSpec.long1;
  vRepSpec.AccStr = RepSpec.f9;
  vRepSpec.f5 = RepSpec.f10;
  vRepSpec.CurncyCode = RepSpec.CurncyCode;
  vwn = OpenWindow("CCPayVerifoneProcessingWClass",0,MotherWindow(wn),"","",vRepSpec);
  DeselectWindow(vwn,false);
  switch (tagstr) begin
    case "4":
      status = 4;
    otherwise
      status = 0;
      if (nonblank(RepSpec.f1)) then begin
        status = 0;
      end;
  end;
  
  CloseWindow(wn);

  res = VerifoneBanksys_InputFormReply(vwn,codepage,RepSpec.f8,RepSpec.f9,RepSpec.f10,RepSpec.f12,status,RepSpec.f1);
  selectwnf = false;

////LogText(0,"20.CloseComPort");  
  CloseComPort(0);  
//LogText(0,"Magic");  

LProceedCCPayVerifoneCashierActionOClass:;  
  if (selectwnf) then begin
    SelectWindow(wn);
    WindowFieldGoto(wn,RepSpec,-1,"f1",true);
  end;
  RemoveTask("FRVerifoneTimeoutTest");
  return;
end;

global
updating procedure ProceedCCPayVerifoneCashierYesNoActionOClass()
begin
  record RahaxiBlock Rahaxib; 
  record LocalMachineBlock LMb;  
  record LSerialPortDeviceVc LSPDr;
  Integer wn,res,status,vwn;
  record RcVc RepSpec;
  record RcVc vRepSpec;
  string 255 codepage,data;
  transaction Integer gVerfioneCounter; 
  transaction Integer gVerfioneTimeOut; 
  
  wn = CurWindow;
  DeselectWindow(wn,false);
  GetWindowRecord(wn,RepSpec);
  gVerfioneCounter = RepSpec.FirstVer;
  BlockLoad(LMb);
  BlockLoad(Rahaxib);
  switch (Rahaxib.TerminalType) begin
    case kLocalCCTerminalVerifoneBanksys:
      if (FindLocalSerialPortDevice(kSerialPortDeviceClassCreditCardTerminal,kSerialPortDeviceModelCreditCardTerminalVerifoneBanksys,LMb.LocalMachineCode,LSPDr)==false) then begin  
        CloseWindow(wn);
        goto LProceedCCPayVerifoneCashierActionOClass;
      end;  
  end;
//LogText(0,"11.OpenComPort");  
  if (OpenComPort(0,LSPDr.Port,LSPDr.BaudRate,LSPDr.Parity,LSPDr.ByteSize,LSPDr.StopBits,LSPDr.FlowControl)==0) then begin
    CloseWindow(wn);
    goto LProceedCCPayVerifoneCashierActionOClass;
  end;
  codepage = StringSetFromString(89,LSPDr.Codepage);
  SetComPortCodepage(codepage);
  vRepSpec.UsedOnly = kLocalCCTerminalVerifoneBanksys;
  vRepSpec.ArtMode = 1;
  vRepSpec.long1 = RepSpec.long1;
  vRepSpec.AccStr = RepSpec.f9;
  vRepSpec.f5 = RepSpec.f10;
  vRepSpec.CurncyCode = RepSpec.CurncyCode;
  gVerfioneTimeOut = StringToInt(GetWindowString(wn,"verfionetimeout")); 
  vwn = OpenWindow("CCPayVerifoneProcessingWClass",0,RepSpec.long2,"","",vRepSpec);
  DeselectWindow(vwn,false);
  data = PushButtonTag;
  switch (data) begin
    case "1": status = 0;
    case "2": status = 4;
    otherwise status = 3;
  end;
  
  CloseWindow(wn);
  res = VerifoneBanksys_InputFormReply(vwn,codepage,RepSpec.f8,RepSpec.f9,RepSpec.f10,RepSpec.f12,status,data);

//LogText(0,"11.CloseComPort");  
  CloseComPort(0);  
  RemoveTask("FRVerifoneTimeoutTest");

LProceedCCPayVerifoneCashierActionOClass:;  
//LogText(0,"Magic ");
  return;
end;

global
procedure CloseCCPayVerifoneProcessingWClass()
begin
  Integer mwn;
  record RcVc RepSpec;
  string 255 rinfo,rstatus;
  Integer wn;
  transaction Integer gVerfioneTimeOut; 
  Boolean noclosingf;

  wn = CurWindow;
  rinfo = GetWindowString(wn,"ReplyInfo");
  rstatus = GetWindowString(wn,"ReplyStatus");
  noclosingf = GetWindowString(wn,"ProcessingFinished")=="false";
  if ((rinfo=="9" or rinfo=="5" or blank(rinfo)) and (noclosingf==false)) then begin
    GetWindowRecord(wn,RepSpec);
    mwn =  MotherWindow(CurWindow);
    CloseWindow(wn);
    gVerfioneTimeOut = 0;
    WindowFieldGotoForTouchScreen(mwn,-1,"ivcashcommand",true); 
    if (RepSpec.UsedOnly==kLocalCCTerminalVerifoneBanksys) then begin
      RemoveTask("FRVerifoneTimeoutTest");
    end;
  end;
  return;
end;

global
procedure VerifoneTimeoutRemoveIdleTask(string arg)
begin
  RemoveTask("FRVerifoneTimeoutTest");
  return;
end;

global
updating procedure VerifoneTimeoutIdleTask(string args)
begin
  string 255 replystatus,tstr,codepage;
  LongInt pos,timeout;
  LongInt starttick;
  Integer res,wn,pwn,mwn;
  record RcVc RepSpec;
  record LocalMachineBlock LMb;  
  record LSerialPortDeviceVc LSPDr;
  record RahaxiBlock Rahb;
  
  pos = 0;
  GetNextSubstring(args,pos,",",tstr);
  timeout = StringToLongInt(tstr);
  GetNextSubstring(args,pos,",",tstr);
  starttick = StringToLongInt(tstr);
  GetNextSubstring(args,pos,",",replystatus);
  GetNextSubstring(args,pos,",",tstr);
  wn = StringToInt(tstr);

//LogText(0,"VerifoneTimeoutIdleTask timeout " & timeout  & " starttick " & starttick & " replystatus " & replystatus & " codepage " & codepage);  

  if (timeout>0 and starttick>0) then begin
    if ((GetCurTick-starttick)>=(timeout+1)*1000.00) then begin
      BlockLoad(LMb);
      BlockLoad(Rahb);
      switch (Rahb.TerminalType) begin
        case kLocalCCTerminalVerifoneBanksys:
          if (FindLocalSerialPortDevice(kSerialPortDeviceClassCreditCardTerminal,kSerialPortDeviceModelCreditCardTerminalVerifoneBanksys,LMb.LocalMachineCode,LSPDr)==false) then begin  
            goto LVerifoneTimeoutIdleTask;
          end;  
      end;
    ////LogText(0,"10.OpenComPort");  
      if (OpenComPort(0,LSPDr.Port,LSPDr.BaudRate,LSPDr.Parity,LSPDr.ByteSize,LSPDr.StopBits,LSPDr.FlowControl)==0) then begin
        goto LVerifoneTimeoutIdleTask;
      end;
      codepage = StringSetFromString(89,LSPDr.Codepage);
      SetComPortCodepage(codepage);
  
      pwn = OpenWindow("CCPayVerifoneProcessingWClass",0,mwn,"","",RepSpec);
      DeselectWindow(pwn,false);

      res = VerifoneBanksys_InputFormReply(pwn,codepage,"","","",replystatus,3,RepSpec.f1);
LVerifoneTimeoutIdleTask:;
      CloseComPort(0);  
      if (res==0) then begin//noErr
        CloseWindow(wn);
      end;
      RemoveTask("FRVerifoneTimeoutTest");
//      tt = AddSeconds(CurrentTime,1);
//      NewTimedTask("VerifoneTimeoutIdleTask","VerifoneTimeoutIdleTask","VerifoneTimeoutIdleTask","",CurrentDate,tt,"","");
    end;
  end else begin
    RemoveTask("FRVerifoneTimeoutTest");
  end;
  return;
end;
