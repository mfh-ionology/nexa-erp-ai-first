function string 255 TCPIP_Verifone_CalculateLRC(string CtrlSeq)
begin
  string 255 res;
  Integer i,crc;
  
  crc = 127;
  for (i=0;i<len(CtrlSeq);i=i+1) begin
    crc = BitXor(crc,asc(Mid(CtrlSeq,i,1)));
  end;

  res = res & chr(crc);
  TCPIP_Verifone_CalculateLRC = res;
  return;
end;

function Integer TCPIPVerifoneReplyStatus(string response)
begin
  Integer res;
  
//LogAreaToFile("Verifone/TCPIPVerifoneReplyStatus_reply" & TimeToString(CurrentTime,"HHMMSS",false) & ".txt",reply);
  
//  res = StringToInt(GetStringFromArea(reply,0,1));
  res = asc(Mid(response,0,1));
//  LogText(0," TCPIPVerifoneReplyStatus response=" & response);
//  LogText(0," TCPIPVerifoneReplyStatus Mid(response,0,1)=" & Mid(response,0,1) & " res=" & res & " asc(Mid(response,0,1))=" & asc(Mid(response,0,1)));
  TCPIPVerifoneReplyStatus = res;
  return;  
end;

function Integer TCPIPVerifoneReply(string response,var vector string vreplyfields)
begin
  Integer res,i;
  string 255 tstr;
  Date td;
 
  vreplyfields["authorisation"] = ""; vreplyfields["timestamp"] = ""; vreplyfields["error"] = ""; vreplyfields["result"] = "";
 //123456780E01TRANSAZIONE ANNULLATA   00000000000000000000000000000000000 
  if (len(response)<10) then begin
    vreplyfields["response"] = Mid(response,1,1);
  end else begin
    vreplyfields["response"] = Mid(response,9,2);
    switch (vreplyfields["response"]) begin
      case "0S":
      case "0E":
        vreplyfields["result"] = Mid(response,11,2);
        switch (vreplyfields["result"]) begin
          case "00":
            vreplyfields["authorisation"] = Mid(response,35,6);
            vreplyfields["timestamp"] = Mid(response,41,7);

            i = StringToInt(Left(vreplyfields["timestamp"],3)) - 1;
            tstr = Mid(response,13,19);
            td = CurrentDate;
            td.day = 1; td.month = 1;
            td = AddDay(td,i);
            vreplyfields["timestamp"] = DateToString(td,"YYYYMMDD") & Right(vreplyfields["timestamp"],len(vreplyfields["timestamp"])-3);      
            vreplyfields["cardnr"] = Mid(response,13,19);
          case "01":
            vreplyfields["error"] = Mid(response,13,24);
        end;
    end;
  end;
//LogText(0," fullresponse=" & response);
//LogText(0," response=" & vreplyfields["response"]);
//LogText(0," trresult=" & vreplyfields["result"]);
//LogText(0," trauth=" & vreplyfields["authorisation"]);
//LogText(0," trtimestamp=" & vreplyfields["timestamp"]);
//LogText(0," trerror=" & vreplyfields["error"]);
  TCPIPVerifoneReply = res;
  return;  
end;

procedure TCPIPVerifone_DisplayStatus(Integer ProcessingWn,string txt,Integer sid)
begin
  record RcVc RepSpec;

  if (ProcessingWn>0) then begin
    GetWindowRecord(ProcessingWn,RepSpec);
    if (nonblank(txt)) then begin
      PutWindowString(ProcessingWn,"Status",txt);        
    end else begin
      PutWindowString(ProcessingWn,"Status",USetStr(sid));        
    end;
//      PutWindowString(ProcessingWn,"Result",txt);        
    PutWindowRecord(ProcessingWn,RepSpec);
  end;
  return;
end;

updating procedure AddPaymentRow(Integer ProcessingWn,string vstr,string paymode,string label,vector string vreplyfields)
begin
  Integer mwn;
  record IVCashVc IVCr;
  row IVCashVc IVCrw;
  Date td;
  
  mwn = MotherWindow(ProcessingWn);
  switch (GetWindowFileName(mwn)) begin
    case "IVCashVc":
      GetWindowRecord(mwn,IVCr);
      ClearRow(IVCr,IVCrw,kInvoiceRowTypeCreditCardPayment);  
      IVCrw.Sum = ValFromString(vstr,"","")/100.00;
      IVCrw.AuthorizationCode = vreplyfields["authorisation"];
      IVCrw.PayMode = paymode;
      IVCrw.Spec = label;
      td = DateFromString(vreplyfields["8"],"DDMMYYYY");
      IVCrw.CCTimestamp = vreplyfields["timestamp"];
      IVCrw.CCTransID = vreplyfields["transid"];
      IVCrw.CCReceiptNr = vreplyfields["receiptnr"];
      MatRowPut(IVCr,MatRowCnt(IVCr),IVCrw);
      IVCashSumup(IVCr,true);
      PutWindowRecord(mwn,IVCr);
      IVCashDClass_RefreshStringList(mwn,IVCr);
      if (ProcessingWn>0) then begin
        PutWindowString(ProcessingWn,"sernr",IVCr.SerNr);
        PutWindowString(ProcessingWn,"authorisation",IVCrw.AuthorizationCode);        
        PutWindowString(ProcessingWn,"timestamp",IVCrw.CCTimestamp);        
        PutWindowString(ProcessingWn,"transid",IVCrw.CCTransID);        
        PutWindowString(ProcessingWn,"receiptnr",IVCrw.CCReceiptNr);        
        PutWindowString(ProcessingWn,"localmachine",IVCr.LocalMachineCode);        
        PutWindowString(ProcessingWn,"sum",vstr);
      end;
      if (WindowDoOK(mwn,0)) then begin
        TCPIPVerifone_DisplayStatus(ProcessingWn,"",27384);
        if (IVCr.RetValue>=0) then begin
          if (IVCashPOSButtonAutoFinish(mwn)==kPOSButtonAutoFinishYes) then begin
            IVCashDClassTouchScreenFinishButton;
          end;
        end;
      end;
  end;
  return;
end;

updating procedure TCPIPVerifone_WaitForTransactionResult(string command,Boolean waitfordataf,Integer ProcessingWn,string lm,LongInt socket,string vstr,string paymode,string label,var string merchantNote)
begin
  string 255 response,tstr,tstr2,CtrlSeq;
  Time ct,t;
  Date td;
  Integer stat,i,lines;
  Boolean timedf,testf,sendackf;
  record RcVc RepSpec;
  LongInt pos,l;
  area a;
  vector string 255 vreplyfields;
  record NotepadVc merchantNoter;
  record CCTRVc CCTRr;
  area merchantNoteArea;

  GetStringFromSocket(socket,response,100);

  if (nonblank(response)) then begin
    stat = TCPIPVerifoneReplyStatus(response);

//LogText(0," fullresponse=" & response);
//LogText(0," stat=" & stat & " command " & command);

    switch (command) begin
      otherwise
        switch (stat) begin
          case CC_SOH:
            timedf = true;
            pos = 0;
            GetNextSubstring(response,pos,CC_EOT,tstr);
            TCPIPVerifone_DisplayStatus(ProcessingWn,tstr,27387);

          case CC_STX:
            TCPIPVerifoneReply(response,vreplyfields);

            sendackf = waitfordataf;
//LogText(0,"vreplyfields[response] " & vreplyfields["response"]);
            switch (vreplyfields["response"]) begin 
              case "0S":
                if (waitfordataf) then begin
                  pos = 0;
                  GetNextSubstring(response,pos,"0S",tstr);
                  tstr = Right(response,len(response)-pos-1);
                  pos = 0;
                  GetNextSubstring(tstr,pos,chr(CC_ETX),tstr);
                  merchantNote = merchantNote & tstr & chr(10);
                  timedf = InString2(response,"}}}}}")<0;
                end;
              case "0T":        
                timedf = waitfordataf;
              case "0C":        
                timedf = waitfordataf;
              case "0E":        
                timedf = waitfordataf;
                switch (vreplyfields["result"]) begin            
                  case "00":
                    AddPaymentRow(ProcessingWn,vstr,paymode,label,vreplyfields);
                    timedf = true;
                  otherwise
                    TCPIPVerifone_DisplayStatus(ProcessingWn,vreplyfields["error"],27385);
                    timedf = false;
                end;
              otherwise
                timedf = waitfordataf;
            end;

//LogText(0,"sendackf " & sendackf);
            if (sendackf) then begin
              CtrlSeq = chr(CC_ACK);
              CtrlSeq = CtrlSeq & chr(CC_ETX);
              CtrlSeq = CtrlSeq & TCPIP_Verifone_CalculateLRC(CtrlSeq); 
              sendackf = SendStringOnSocket(socket,CtrlSeq);
            end;

          case CC_ACK:
            SendStringOnSocket(socket,chr(CC_ACK));
            timedf = true;
          case CC_NAK:
    //              TCPIPVerifoneReply(reply,trresult,trauth,trtimestamp,trerror);
        end;
    end;
  end else begin
    timedf = true;
  end;

//LogText(0," timedf=" & timedf);

  if (timedf) then begin
    RemoveTask("TCPIPVerifone_WaitForTransactionResult");
    ct = CurrentTime;
    t = ct;
    t.second = t.second + 1;
    td = CurrentDate;
    if (ct>t) then begin
      td = AddDay(td,1);
    end;
    NewTimedTask("TCPIPVerifone_WaitForTransactionResult","TCPIPVerifone_WaitForTransactionResult","TCPIPVerifone_WaitForTransactionResultIdleTask",command & "|" & waitfordataf & "|" & socket & "|" & ProcessingWn & "|" & lm & "|" & vstr & "|" & paymode & "|" & label & "|" & merchantNote,td,t,"","");
  end else begin
    SetAreaZeroSize(merchantNoteArea);
    merchantNote = ReplaceStringWithString(merchantNote,"}",chr(10));
    AddTextToArea(merchantNote,merchantNoteArea);

    SetAreaZeroSize(a);
    lines = CountLinesInArea(merchantNoteArea);
    for (i=0;i<lines;i=i+1) begin
      tstr = GetLineFromArea(merchantNoteArea,i);
      if (len(tstr)>24) then begin
        l = len(tstr);
        pos = 0;
        testf = true;
        while (testf) begin
          tstr2 = Mid(tstr,pos,24);
          if (nonblank(tstr2)) then begin
            AddTextToArea(tstr2,a);
            AddTextToArea(chr(13) & chr(10),a);
          end;
          pos = pos + len(tstr2);
          testf = (len(tstr) - pos)>0;
        end;
      end else begin
        AddTextToArea(tstr,a);
        AddTextToArea(chr(13) & chr(10),a);
      end;
    end;

    switch (command) begin
      case "Purchase":
        if (GetAreaLength(a)>0) then begin
          AddAreaToTextField(a,merchantNoter);
          if (ProcessingWn>0) then begin
            StoreCredCardSlip_VerifoneBanksys3("A",ValFromString(GetWindowString(ProcessingWn,"sum"),"","")/100.00,GetWindowString(ProcessingWn,"transid"),GetWindowString(ProcessingWn,"receiptnr"),GetWindowString(ProcessingWn,"authorisation"),GetWindowString(ProcessingWn,"timestamp"),"","","",GetWindowString(ProcessingWn,"sernr"),"IVCashVc",0,GetWindowString(ProcessingWn,"localmachine"),merchantNoter,merchantNoter);
          end;
        end;
      case "Report":
        if (GetAreaLength(a)>0) then begin
          RecordNew(CCTRr);
          CCTRr.ReportType = paymode;
          if (blank(CCTRr.LocalMachineCode)) then begin
            CCTRr.LocalMachineCode = lm;
          end;          
          if (CCTRr.SerNr<=0) then begin
            CCTRr.SerNr = NextSerNr("CCTRVc",CCTRr.TransDate,-1,false,"");
          end;
          if (CCTRr.SerNr>0) then begin  
          
            AddAreaToTextField(a,CCTRr);
          
            if (RecordStore(CCTRr,false)) then begin
  //              PrintCreditCardTerminalReport(CCTRr);
  //              PrintDocument(CCTRr,"CCTRForm",false);
            end;
          end;
        end;
//LogText(0," merchantNote=" & merchantNote);
    end;

/*
    SetAreaZeroSize(a);
    GetAreaFromTextField(merchantNoter,a);
    LogAreaToFile("Verifone/gVerfifone_merchantNoteFinal" & ".txt",a);
*/    
    CloseSocket(socket);
  end;
  return;
end;

global
updating procedure TCPIPVerifone_WaitForTransactionResultIdleTask(string arg)
begin
  LongInt pos;
  string 255 command,tstr,vstr,paymode,label,lm;
  LongInt socket;
  Integer ProcessingWn;
  string 255 merchantNote;
  Boolean waitfordataf;
  
  pos = 0;
  GetNextSubstring(arg,pos,"|",command);
  GetNextSubstring(arg,pos,"|",tstr);
  waitfordataf = StringToInt(tstr)!=0;
  GetNextSubstring(arg,pos,"|",tstr);
  socket = StringToLongInt(tstr);
  GetNextSubstring(arg,pos,"|",tstr);
  ProcessingWn = StringToLongInt(tstr);
  GetNextSubstring(arg,pos,"|",lm);
  GetNextSubstring(arg,pos,"|",vstr);
  GetNextSubstring(arg,pos,"|",paymode);
  GetNextSubstring(arg,pos,"|",label);
  GetNextSubstring(arg,pos,"|",merchantNote);

  TCPIPVerifone_WaitForTransactionResult(command,waitfordataf,ProcessingWn,lm,socket,vstr,paymode,label,merchantNote);  
  return;
end;

