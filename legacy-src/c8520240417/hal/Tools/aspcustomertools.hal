  end;
  return;
end;

global
procedure UpdateClientBrowsesIfNeeded(string vcname)
begin
  string 255 gtag;

  gtag = "%UCB_" & vcname;
  if (GetGlobalBoolean(gtag)==true) then begin
    allclientsremoteasync.DoUpdateBrowses(vcname);
    SetGlobalBoolean(gtag,false);
  end;
  return;
end;

global
procedure Do_HttpAsyncDownloadHACallback(string indir,record HansaVersionVc HVr,record HansaVersionVc OldHVr,Boolean update_after_download,string server,string destpath)
begin
  LongInt old_version_build,new_version_build;
  Boolean okverf,foundf;
  record LocalCloudServerVc LCSr;
  record HansaVersionVc HV2r;
  array uuid lcsuuidarr;
  record CloudSettingsBlock CSb;
  string 255 url,updatetmpfolder;
  Integer stat;

  //LogText(0,"Do_HttpAsyncDownloadHACallback(" & HVr.Code & ") " & StateName(HVr.CurrentState) & " -> " & StateName(kHansaVersionStateNormal));

  HVr.CurrentState = kHansaVersionStateNormal;

  updatetmpfolder = HVr.ProgramFolder & ".tmpupdate";
  DeleteFolder(updatetmpfolder);

  if (nonblank(OldHVr.Code)) then begin
    old_version_build = (OldHVr.Version * 1000000) + (OldHVr.SubVersion * 10000) + OldHVr.RunningBuild;
    new_version_build = (HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild;
    okverf = CheckVersion(OldHVr);

    if ((old_version_build<new_version_build) or (OldHVr.ForceReplaceVersionf!=0) or (okverf==false)) then begin
      DeleteFolder(HVr.ProgramFolder);
          
      switch (ProgramPlatform) begin
        case kPlatformMac:
          Delete_File(indir & "/newver/hansa-debug-server");
          Delete_File(indir & "/newver/hansa-debug-server64");
          Delete_File(indir & "/newver/hansa-debug-serverarm64");
          Delete_File(indir & "/newver/hansa-windows-optimized-server.exe");
          Delete_File(indir & "/newver/hansa-windows-optimized-server64.exe");
          Delete_File(indir & "/newver/hansa-debug-optimized-server");
          Delete_File(indir & "/newver/hansa-debug-optimized-server64");
          Delete_File(indir & "/newver/hansa-debug-optimized-serverarm64");
          Delete_File(indir & "/newver/hansa-slave");
          Delete_File(indir & "/newver/hansa-debug-slave");
          Delete_File(indir & "/newver/hansa-debug-optimized-slave");
          Delete_File(indir & "/newver/hansa-debug-slave64");
          Delete_File(indir & "/newver/hansa-debug-slavearm64");
          Delete_File(indir & "/newver/hansa-debug-optimized-slave64");
          Delete_File(indir & "/newver/hansa-debug-optimized-slavearm64");
          Delete_File(indir & "/newver/hansa-windows-optimized-slave.exe");
          Delete_File(indir & "/newver/hansa-windows-optimized-slave64.exe");
        case kPlatformWindows32:
          Delete_File(indir & "/newver/hansa-debug-server");
          Delete_File(indir & "/newver/hansa-debug-server64");
          Delete_File(indir & "/newver/hansa-debug-serverarm64");
          Delete_File(indir & "/newver/hansa-windows-optimized-server64.exe");
          Delete_File(indir & "/newver/hansa-macosx-optimized-server");
          Delete_File(indir & "/newver/hansa-debug-optimized-server");
          Delete_File(indir & "/newver/hansa-debug-optimized-server64");
          Delete_File(indir & "/newver/hansa-debug-optimized-serverarm64");
          Delete_File(indir & "/newver/hansa-slave");
          Delete_File(indir & "/newver/hansa-debug-slave");
          Delete_File(indir & "/newver/hansa-debug-optimized-slave");
          Delete_File(indir & "/newver/hansa-debug-slave64");
          Delete_File(indir & "/newver/hansa-debug-slavearm64");
          Delete_File(indir & "/newver/hansa-debug-optimized-slave64");
          Delete_File(indir & "/newver/hansa-debug-optimized-slavearm64");
          Delete_File(indir & "/newver/hansa-windows-optimized-slave64.exe");
          Delete_File(indir & "/newver/hansa-macosx-optimized-slave");
        case kPlatformWindows64:
          Delete_File(indir & "/newver/hansa-debug-server");
          Delete_File(indir & "/newver/hansa-debug-server64");
          Delete_File(indir & "/newver/hansa-debug-serverarm64");
          Delete_File(indir & "/newver/hansa-windows-optimized-server.exe");
          Delete_File(indir & "/newver/hansa-macosx-optimized-server");
          Delete_File(indir & "/newver/hansa-debug-optimized-server");
          Delete_File(indir & "/newver/hansa-debug-optimized-server64");
          Delete_File(indir & "/newver/hansa-debug-optimized-serverarm64");
          Delete_File(indir & "/newver/hansa-slave");
          Delete_File(indir & "/newver/hansa-debug-slave");
          Delete_File(indir & "/newver/hansa-debug-optimized-slave");
          Delete_File(indir & "/newver/hansa-debug-slave64");
          Delete_File(indir & "/newver/hansa-debug-slavearm64");
          Delete_File(indir & "/newver/hansa-debug-optimized-slave64");
          Delete_File(indir & "/newver/hansa-debug-optimized-slavearm64");
          Delete_File(indir & "/newver/hansa-windows-optimized-slave.exe");
          Delete_File(indir & "/newver/hansa-macosx-optimized-slave");
        case kPlatformLinux32:
          if (HVr.AdditionalPlatform!=kPlatformLinux64) then begin
            Delete_File(indir & "/newver/hansa-debug-server64");
            Delete_File(indir & "/newver/hansa-debug-optimized-server64");
            Delete_File(indir & "/newver/hansa-debug-slave64");
            Delete_File(indir & "/newver/hansa-debug-optimized-slave64");
          end;
          if (HVr.AdditionalPlatform!=kPlatformLinuxArm64) then begin
            Delete_File(indir & "/newver/hansa-debug-serverarm64");
            Delete_File(indir & "/newver/hansa-debug-optimized-serverarm64");
            Delete_File(indir & "/newver/hansa-debug-slavearm64");
            Delete_File(indir & "/newver/hansa-debug-optimized-slavearm64");
          end;
          Delete_File(indir & "/newver/hansa-windows-optimized-server.exe");
          Delete_File(indir & "/newver/hansa-windows-optimized-server64.exe");
          Delete_File(indir & "/newver/hansa-macosx-optimized-server");
          Delete_File(indir & "/newver/hansa-windows-optimized-slave.exe");
          Delete_File(indir & "/newver/hansa-windows-optimized-slave64.exe");
          Delete_File(indir & "/newver/hansa-macosx-optimized-slave");
        case kPlatformLinux64:
          if (HVr.AdditionalPlatform!=kPlatformLinux32) then begin
            Delete_File(indir & "/newver/hansa-debug-server");
            Delete_File(indir & "/newver/hansa-debug-optimized-server");
            Delete_File(indir & "/newver/hansa-slave");
            Delete_File(indir & "/newver/hansa-debug-slave");
            Delete_File(indir & "/newver/hansa-debug-optimized-slave");
          end;
          if (HVr.AdditionalPlatform!=kPlatformLinuxArm64) then begin
            Delete_File(indir & "/newver/hansa-debug-serverarm64");
            Delete_File(indir & "/newver/hansa-debug-optimized-serverarm64");
            Delete_File(indir & "/newver/hansa-debug-slavearm64");
            Delete_File(indir & "/newver/hansa-debug-optimized-slavearm64");
          end;
          Delete_File(indir & "/newver/hansa-windows-optimized-server.exe");
          Delete_File(indir & "/newver/hansa-windows-optimized-server64.exe");
          Delete_File(indir & "/newver/hansa-macosx-optimized-server");
          Delete_File(indir & "/newver/hansa-windows-optimized-slave.exe");
          Delete_File(indir & "/newver/hansa-windows-optimized-slave64.exe");
          Delete_File(indir & "/newver/hansa-macosx-optimized-slave");
        case kPlatformLinuxArm64:
          if (HVr.AdditionalPlatform!=kPlatformLinux64) then begin
            Delete_File(indir & "/newver/hansa-debug-server64");
            Delete_File(indir & "/newver/hansa-debug-optimized-server64");
            Delete_File(indir & "/newver/hansa-debug-slave64");
            Delete_File(indir & "/newver/hansa-debug-optimized-slave64");
          end;
          if (HVr.AdditionalPlatform!=kPlatformLinux32) then begin
            Delete_File(indir & "/newver/hansa-debug-server");
            Delete_File(indir & "/newver/hansa-debug-optimized-server");
            Delete_File(indir & "/newver/hansa-slave");
            Delete_File(indir & "/newver/hansa-debug-slave");
            Delete_File(indir & "/newver/hansa-debug-optimized-slave");
          end;
          Delete_File(indir & "/newver/hansa-windows-optimized-server.exe");
          Delete_File(indir & "/newver/hansa-windows-optimized-server64.exe");
          Delete_File(indir & "/newver/hansa-macosx-optimized-server");
          Delete_File(indir & "/newver/hansa-windows-optimized-slave.exe");
          Delete_File(indir & "/newver/hansa-windows-optimized-slave64.exe");
          Delete_File(indir & "/newver/hansa-macosx-optimized-slave");
        otherwise
      end;
      
      switch (ProgramPlatform) begin
        case kPlatformWindows32:
          DeleteFolder(indir & "/newver/ps-x64");
        case kPlatformWindows64:
          DeleteFolder(indir & "/newver/ps-x86");
        otherwise
          DeleteFolder(indir & "/newver/ps-x64");
          DeleteFolder(indir & "/newver/ps-x86");
      end;

      CopyFolder(indir & "/newver",updatetmpfolder);
      RenameFile(updatetmpfolder,HVr.ProgramFolder);

      LogText(0,"Updating version " & OldHVr.Code & " from build " & old_version_build & " to build " & new_version_build);
      if (update_after_download) then begin
        SetCloudControllerStatus(kJobStatusFinished,"Downloaded and unpacked version " & HVr.Code);
      end;
      HVr.ForceReplaceVersionf = 0;
      qupdating.DoUpdateHVr(OldHVr,HVr);
      HVr.Code = OldHVr.Code;
    end;
  end else begin
    qupdating.DoDeleteHVr(HVr);
    new_version_build = (HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild;

    CopyFolder(indir & "/newver",updatetmpfolder);
    DeleteFolder(HVr.ProgramFolder);
    RenameFile(updatetmpfolder,HVr.ProgramFolder);

    LogText(0,"Saving version " & HVr.Code & " build " & new_version_build);
    qupdating.DoStoreHVr(HVr);
  end;

  okverf = CheckVersion(HVr);
  if (okverf==false) then begin
    qupdating.SetHansaVersionState(HVr,kHansaVersionStateError);
  end else begin
    if (update_after_download) then begin
      queued.UpdateToVersion(HVr);
    end else begin
      LCSr.HansaVersion = HVr.Code;
      foundf = true;
      while (LoopKey("HansaVersion",LCSr,1,foundf)) begin
        if (LCSr.HansaVersion!=HVr.Code) then begin foundf = false; end;
        if ((foundf==true) and (LCSr.WantedStatus==kWantedStatusStopAndRefresh)) then begin
          lcsuuidarr[lcsuuidarr.length] = LCSr.UUID;
        end;
      end;
      if (lcsuuidarr.length>0) then begin
        BlockLoad(CSb);
        url = Trim(CSb.CCAddr) & ":" & CSb.CCHTTPSPort;
        stat = CallService(url).UpdateWantedStatusOnServers(lcsuuidarr,kWantedStatusRun);
// error handling
      end;
    end;
  end;

  SetShouldDownloadVersion(HVr.Code,false);
  SetDownloadingVersion(HVr.Code,false);

  DeleteFolder(destpath);
  qupdating.StartPendingVersionDownloads;
  
  UpdateClientBrowsesIfNeeded("HansaVersionVc");
  return;
end;

global
procedure CallDownloadHA(string xserver,LongInt xport,string xpath,string xdestpath,string xhacretries,record HansaVersionVc xHVr,record HansaVersionVc xOldHVr,Boolean xupdate_after_download)
begin
  transaction record HansaVersionVc HVr;
  transaction record HansaVersionVc OldHVr;
  transaction Boolean update_after_download;
  transaction string 255 server,path,destpath;
  transaction LongInt port,hacretries;
  Integer waitsecs;
  
  if (QuitingApplication) then begin goto LCallDownloadHA; end;
  
  // because transaction strings isn't brought forward with threadasync... which probably is a bug ::lvg190904
  HVr = xHVr;
  OldHVr = xOldHVr;
  update_after_download = xupdate_after_download;
  server = xserver;
  path = xpath;
  destpath = xdestpath;
  port = xport;
  hacretries = xhacretries;
  
LCallDownloadHA_again:;
  waitsecs = 30;
  while (waitsecs>0) begin
    Sleep(1);
    if (QuitingApplication) then begin goto LCallDownloadHA; end;
    waitsecs = waitsecs - 1;
  end;
  if (IncreaseVmLong("downloadversions",3)) then begin // max 3 at the time
    LogText(0,"Downloading http://" & server & ":" & port & path & ", attempt " & hacretries & ", retrying");
    HttpAsyncDownloadHA(server,port,path,30,destpath,"HttpAsyncDownloadHACallback");
  end else begin
    goto LCallDownloadHA_again;
  end;
  
LCallDownloadHA:;
  return;
end;

global
updating procedure HttpAsyncDownloadHACallback(Boolean successf,LongInt httpres,Boolean timeout,string indir)
begin
  transaction record HansaVersionVc HVr;
  transaction record HansaVersionVc OldHVr;
  transaction Boolean update_after_download;
  transaction string 255 server,path,destpath;
  transaction LongInt port,hacretries;

  ChangeVmLong("downloadversions",-1);
  hacretries = hacretries + 1;
  if (timeout==true) then begin
    LogText(0,"HttpAsyncDownloadHACallback(" & HVr.Code & ") timed out");
    VersionPackagesServerConnectionFailed;
    goto LHttpAsyncDownloadHACallback_Retry;
  end;

  switch (httpres) begin
    case kHttpStatusNotFound:
      LogText(0,"HttpAsyncDownloadHACallback(" & HVr.Code & ") failed (httpres=404 not found)");
//      VersionPackagesServerConnectionFailed; // no need to clear the lookup cache if the file wasn't found
      goto LHttpAsyncDownloadHACallback_Retry; // why retry, the file isn't there...
    case kHttpStatusOK:
    otherwise
      LogText(0,"HttpAsyncDownloadHACallback(" & HVr.Code & ") failed (httpres=" & httpres & ")");
      VersionPackagesServerConnectionFailed;
      goto LHttpAsyncDownloadHACallback_Retry;
  end;

  if (successf==false) then begin
    LogText(0,"HttpAsyncDownloadHACallback(" & HVr.Code & ") failed");
    VersionPackagesServerConnectionFailed;
    goto LHttpAsyncDownloadHACallback_Retry;
  end;

  threadasync.Do_HttpAsyncDownloadHACallback(indir,HVr,OldHVr,update_after_download,server,destpath);
  goto LHttpAsyncDownloadHACallback;

LHttpAsyncDownloadHACallback_Retry:;
  if (hacretries<5) then begin
    if (IsCloudController) then begin
      if (GetGlobalBoolean("update_after_download")) then begin
        SetCloudControllerStatus(kJobStatusRunning,"Downloading new version for Cloud Controller, retrying");
      end;
    end;
    threadasync.CallDownloadHA(server,port,path,destpath,hacretries,HVr,OldHVr,update_after_download);
  end else begin
    SetShouldDownloadVersion(HVr.Code,false); // false should be OK, during update the CC should be forcing the update anyhow
    SetDownloadingVersion(HVr.Code,false);
    if (httpres==kHttpStatusNotFound) then begin
      SetHansaVersionState(HVr,kHansaVersionStateUnavailable);
    end;
    hacretries = -1;
  end;

LHttpAsyncDownloadHACallback:;
  return;
end;
