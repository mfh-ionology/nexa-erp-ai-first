global
updating procedure DoUpdateHVr(record HansaVersionVc OldHVr,record HansaVersionVc HVr)
begin
  RecordUpdate(OldHVr,HVr,true);
  return;
end;

global
updating procedure DoDeleteHVr(record HansaVersionVc HVr)
begin
  RecordDelete(HVr);
  return;
end;

global
updating procedure DoStoreHVr(record HansaVersionVc HVr)
begin
  RecordStore(HVr,true);
  return;
end;

global
updating procedure SetHansaVersionState(var record HansaVersionVc HVr,LongInt state)
begin
  record HansaVersionVc HV2r;
  record HansaVersionVc OldHV2r;

  RecordCopy(HV2r,HVr);

  if (ReadFirstMain(HV2r,1,true)) then begin
    if (HV2r.CurrentState<>state) then begin
      LogText(0,"SetHansaVersionState(" & HV2r.Code & ") " & StateName(HV2r.CurrentState) & " -> " & StateName(state));
      RecordCopy(OldHV2r,HV2r);
      HV2r.CurrentState = state;
      RecordUpdate(OldHV2r,HV2r,true);
    end else begin
      //LogText(0,"SetHansaVersionState(" & HV2r.Code & "," & StateName(state) & ") already has state");
    end;
  end else begin
    RecordCopy(HV2r,HVr);
    HV2r.CurrentState = state;
    if (RecordStore(HV2r,false)==false) then begin
      LogText(0,"SetHansaVersionState(" & HV2r.Code & "," & StateName(state) & ") failed");
//    end else begin
//      LogText(0,"SetHansaVersionState(" & HV2r.Code & "," & StateName(state) & ") new");
    end;
  end;

  HVr.CurrentState = state;
  return;
end;

