global
updating procedure StoreASPEvent(LongInt evtype,string comment,string usercode,uuid svruuid,string controller)
begin
  record ASPEventsVc AEr;

  AEr.TransDate = CurrentDate;
  AEr.TransTime = CurrentTime;
