global
procedure UnoccupTableSClassArrayOnOpen(var Array string astr, var Integer acnt,var Array integer aseats)
begin
  record NeighbourHoodVc Tabler;
  Boolean found;
  Boolean testf;
  record RestAccVc RAr;
  record LocalMachineBlock LMb;
  
  BlockLoad(LMb);
  found = true;

  while (LoopMain(Tabler,1,found)) begin
    if (found) then begin
      testf = true;
      RAr.CustCode = Tabler.Table;
      testf = !ReadFirstKey("OpenTabs",RAr,1,true);
      if (nonblank(LMb.BranchID)) then begin
        if (LMb.BranchID!=Tabler.BranchID) then begin testf = false; end;
      end;  
      if (testf) then begin
        astr[acnt] = Tabler.Table;
        aseats[acnt] = Tabler.Seats;
        acnt = acnt + 1;
      end;
    end;
  end;
  return;
end;

