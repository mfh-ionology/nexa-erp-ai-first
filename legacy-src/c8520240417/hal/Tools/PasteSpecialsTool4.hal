global
procedure POSOpenSHSClassArrayOnOpen(var Array string asernr,var Array string acustomer,var Array string aname)
begin
  record SHVc SHr;
  record ORVc ORr;
  row SHVc SHrw;
  integer i,rwcnt,acnt,reccnt;
  Boolean testf,foundf;
  
  foundf = true;
  SHr.ShipDate = CurrentDate;
  while (LoopBackKey("ShipDate",SHr,1,foundf)) begin
    ORr.SerNr = SHr.OrderNr;
    ReadFirstMain(ORr,1,true);
    if (ORr.InvMark==18) then begin
      goto POSOpenSHSClassArrayOnOpen_LSkip;
    end;
    testf = false;
    rwcnt = MatRowCnt(SHr);
    for (i=0;i<rwcnt;i=i+1) begin
      MatRowGet(SHr,i,SHrw);
      if (SHrw.Invd<>SHrw.Ordered) then begin
        testf = true;
      end;
    end;
    if (testf) then begin
      asernr[acnt] = SHr.SerNr;
      acustomer[acnt] = SHr.CustCode;
      aname[acnt] = SHr.Addr0;
      acnt = acnt + 1;
    end;
POSOpenSHSClassArrayOnOpen_LSkip:;
    reccnt = reccnt + 1;
    if (reccnt>100) then begin
      foundf = false;
    end;
  end;
  return;
end;

global
procedure POSOpenORSClassArrayOnOpen(var array string asernr,var array date adate,var array string acustcode,var array string acustname,var array val asum)
begin
  record QTVc QTr;
  record ORVc ORr;
  row QTVc QTrw;
  integer i,rwcnt,acnt,reccnt;
  Boolean testf,invoicedf,foundf;
    
  foundf = true;
  ORr.OrdDate = CurrentDate;
  while (LoopBackKey("OrdDate",ORr,1,foundf)) begin
    testf = true;
    invoicedf = false;
    QTr.SerNr = ORr.QuoteNr;
    if (ReadFirstMain(QTr,1,true)) then begin
      invoicedf = true;
      rwcnt = MatRowCnt(QTr);
      for (i=0;i<rwcnt;i=i+1) begin
        MatRowGet(QTr,i,QTrw);
        if (QTrw.Invd!=QTrw.Quant) then begin
          invoicedf = false;
          testf = true;
          goto POSOpenORSClassArrayOnOpen_LSkip;
        end;
      end;
      testf = false;
    end;
POSOpenORSClassArrayOnOpen_LSkip:;
    if (ORr.InvMark==18 and invoicedf==false) then begin
      testf = false;
    end;
    if (testf) then begin
      asernr[acnt] = ORr.SerNr;
      adate[acnt] = ORr.OrdDate;
      acustcode[acnt] = ORr.CustCode;
      acustname[acnt] = ORr.Addr0;
      asum[acnt] = ORr.Sum4;
      acnt = acnt + 1;
    end;
    reccnt = reccnt + 1;
    if (reccnt>100) then begin
      foundf = false;
    end;
  end;
  return;
end;

global
procedure POSOpenSVOSClassArrayOnOpen(var array string asernr,var array Date adate,var array string acustordnr,var array string acustcode,var array string acustname)
begin
  record SVOVc SVOr;
  row SVOVc SVOrw;
  integer i,rwcnt,acnt,reccnt;
  Boolean testf,foundf;
  
  foundf = true;
  SVOr.TransDate = CurrentDate;
  while (LoopBackKey("TransDate",SVOr,1,foundf)) begin
    testf = true;
    if (SVOr.InvMark==18) then begin
      testf = false;
      goto POSOpenSVOSClassArrayOnOpen_LSkip;
    end;
    rwcnt = MatRowCnt(SVOr);
    for (i=0;i<rwcnt;i=i+1) begin
      MatRowGet(SVOr,i,SVOrw);
      if (SVOrw.Invd!=SVOrw.Quant) then begin
        testf = true;
        goto POSOpenSVOSClassArrayOnOpen_LSkip;
      end;
    end;
    testf = false;
POSOpenSVOSClassArrayOnOpen_LSkip:;
    if (testf) then begin
      asernr[acnt] = SVOr.SerNr;
      adate[acnt] = SVOr.TransDate;
      acustordnr[acnt] = SVOr.CustOrdNr;
      acustcode[acnt] = SVOr.CustCode;
      acustname[acnt] = SVOr.Addr0;
      acnt = acnt + 1;
    end;
    reccnt = reccnt + 1;
    if (reccnt>100) then begin
      foundf = false;
    end;
  end;
  return;
end;

global
procedure JobVcOpenResSClassArrayOnOpen(var array string acode,var array string aloc,var array string atype,var array string aclass, var array string aname, string type)
begin
  record ResVc Resr;
  record ResTypeVc ResTyper;
  record JobVc Jobr;
  integer i,rwcnt,acnt,reccnt;
  Boolean testf,foundf;
  
  foundf = true;
  Resr.Type = type;

  while (LoopKey("Type",Resr,1,foundf)) begin
    if (Resr.Type!=type) then begin
      foundf = false;
    end;
    if (foundf) then begin
      testf = true;
      if (Resr.Terminated==1) then begin
        testf = false;
      end;
      if (testf) then begin
        acode[acnt] = Resr.Code;
        aloc[acnt] = Resr.ResLoc;
        atype[acnt] = Resr.Type;
        aclass[acnt] = Resr.Class;
        aname[acnt] = Resr.Name;
        acnt = acnt + 1;
      end;
      reccnt = reccnt + 1;
    end;
  end;
  LJobVcOpenResSClassArrayOnOpen:;
  return;
end;

