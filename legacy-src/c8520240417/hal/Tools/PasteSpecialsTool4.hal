  return;
end;

global
procedure OpenRentIN2SClassArrayOnOpen(var array string asernr,var array string acode,var array string agroup,var array string aorgloc,var array string aname,var array val abaseprice)
begin
  Integer acnt;
  Boolean testf;
  record RentINVc RentINr; 

  while (LoopKey("SerialNr",RentINr,1,true)) begin
    testf = true;
    if (RentINr.Terminated==1) then begin
      testf = false;
    end;
    if (RentINr.RentINStatus>=1) then begin
      testf = false;
    end;
    if (testf) then begin
      asernr[acnt] = RentINr.SerialNr;  
      acode[acnt] = RentINr.Code;
      agroup[acnt] = RentINr.Group;      
      aorgloc[acnt] = RentINr.OrgLocation;
      aname[acnt] = RentINr.Name;     
      abaseprice[acnt] = RentINr.ApxBasePrice;
      acnt = acnt + 1;
    end;
  end;
  LOpenRentIN2SClassArrayOnOpen:;
  return;
end;

