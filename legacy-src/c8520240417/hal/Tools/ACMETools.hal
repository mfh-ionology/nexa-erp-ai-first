external procedure ACME_OpenDebugWindow(record ACMELogVc);

function string 255 CR()
begin
  CR = chr(13);
end;

function string 255 LF()
begin
  LF = chr(10);
end;

function string 255 NL()
begin
  if (ServingClient) then begin
    NL = LF;
  end else begin
    NL = CR & LF;
  end;
end;

