global
function string 255 PBXPublicSSHKeyName()
begin
  PBXPublicSSHKeyName = "pbx-ssh-public-key.pem";
  return;
end;

global
function string 255 PBXPrivateSSHKeyName()
begin
  PBXPrivateSSHKeyName = "pbx-ssh-private-key.pem";
  return;
end;

global
updating procedure DoReInitLinphone()
begin
  ReInitLinphone;
  return;
end;

global
procedure ReInitLinphoneOnClient()
begin
  queued.DoReInitLinphone;
  return;
end;
