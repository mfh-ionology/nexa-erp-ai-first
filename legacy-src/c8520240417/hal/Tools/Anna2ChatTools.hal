procedure A2CProc_QT_AddItem(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  string 255 item,qty,cucode,qtnr;
  string 255 incode;
  Boolean retval;

  item = FindParameter(Ctxr,nodestack,"item","the item or product that the user wants to add to the quotation",chatmessage,response);
  qty = FindParameter(Ctxr,nodestack,"qty","how many " & NameOrString(item,"[item] or products") & " the user wants to add to the quotation",chatmessage,response);
  qtnr = FindParameter(Ctxr,nodestack,"QTr.SerNr","which quotation the user wants to add items to",chatmessage,response);
  cucode = FindParameter(Ctxr,nodestack,"CUr.Code","the customer that the user wants to add items for",chatmessage,response);

  ValidateItem(item,incode);
  ValidateQuantity(qty,1,100);
  ValidateCUVc(cucode);
  ValidateQTVc(qtnr,cucode);

  if (cucode=="") then begin FindCustomerFromQuotation(qtnr,cucode); end;
  if (qtnr=="") then begin FindQuotationFromCustomer(cucode,qtnr); end;

  EnsureParameter(Ctxr,incode,"item","Which item would you like to add?",response);
  EnsureParameter(Ctxr,qtnr & cucode,"QTr.SerNr","Which quotation would you like to add items to?",response);
  //EnsureParameter(Ctxr,qtnr,"QTr.SerNr","Which quotation would you like to add to?",response);

  StoreParameter(Ctxr,nodestack,"item",incode);

  if (Ctxr.Status<>"processing") then begin
    goto A2CProc_QT_AddItem_out;
  end;

  if (qtnr=="" or cucode=="" or incode=="") then begin
    Anna2Chat_SystemError(Ctxr,nodestack,response);
    goto A2CProc_QT_AddItem_out;
  end;

  StoreParameterInContext(Ctxr,"CUr.Code",cucode);
  StoreParameterInContext(Ctxr,"QTr.SerNr",qtnr);

  if (qty=="") then begin qty = "1"; end;

  retval = qupdating.A2CProc_QT_AddItem_Do(incode,qty,cucode,qtnr);

  if (retval) then begin
    response = response & "Item " & item & " was added to quotation " & qtnr;
    PopNode(nodestack);
    Ctxr.Status = "waiting";
  end else begin
    Anna2Chat_SystemError(Ctxr,nodestack,response);
    response = response & "It is not possible to perform this action at the moment";
    Ctxr.Status = "waiting";
  end;
  
A2CProc_QT_AddItem_out:;
end;

global
updating function Boolean A2CProc_QT_Email_Do(string cucode,string qtnr,var string errorstr)
begin
  record QTVc QTr;
  record MailVc oldMailr,Mailr;
  string 255 warning;
  Integer err;
  
  QTr.SerNr = qtnr;
  ReadFirstMain(QTr,1,true);

  err = CreateMailFromQTD(QTr,Mailr,warning,"");
  if (err!=0) then begin
    if (err>0) then begin
      errorstr = USetStr(err) & " " & warning;
    end;
    A2CProc_QT_Email_Do = false;
  end else begin
    oldMailr = Mailr;
    Mailr.SendFlag = 1;
    RecordUpdate(oldMailr,Mailr,true);
    A2CProc_QT_Email_Do = true;
  end;
end;

procedure A2CProc_QT_Email(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  string 255 cucode,qtnr,errorstr;
  Boolean retval;
  
  qtnr = FindParameter(Ctxr,nodestack,"QTr.SerNr","which quotation the user wants to e-mail",chatmessage,response);
  cucode = FindParameter(Ctxr,nodestack,"CUr.Code","the customer that the user wants to e-mail an quotation to",chatmessage,response);

  ValidateCUVc(cucode);
  ValidateQTVc(qtnr,cucode);

  if (cucode=="") then begin FindCustomerFromQuotation(qtnr,cucode); end;
  if (qtnr=="") then begin FindQuotationFromCustomer(cucode,qtnr); end;

  EnsureParameter(Ctxr,qtnr,"QTr.SerNr","Which quotation would you like to e-mail?",response);
  
  if (Ctxr.Status<>"processing") then begin
    goto A2CProc_QT_Email_out;
  end;
  
  if (qtnr=="" or cucode=="") then begin
    Anna2Chat_SystemError(Ctxr,nodestack,response);
    goto A2CProc_QT_Email_out;
  end;
  
  StoreParameterInContext(Ctxr,"CUr.Code",cucode);
  StoreParameterInContext(Ctxr,"QTr.SerNr",qtnr);

  retval = qupdating.A2CProc_QT_Email_Do(cucode,qtnr,errorstr);

  if (retval) then begin
    response = response & "Quotation " & qtnr & " was e-mailed";
    PopNode(nodestack);
    Ctxr.Status = "waiting";
  end else begin
    Anna2Chat_SystemError(Ctxr,nodestack,response);
    if (errorstr<>"") then begin
      response = response & "E-mailing Quotation failed with the error " & errorstr;
    end else begin
      response = response & "It is not possible to perform this action at the moment";
    end;
    Ctxr.Status = "waiting";
  end;
  
A2CProc_QT_Email_out:;
end;

global
updating function Boolean A2CProc_QT_Create_Do(string cucode,var string qtnr)
begin
  record QTVc oldQTr,QTr;
  LongInt rwcnt;
  string 255 warning;

  RecordNew(QTr);
  if (QTr.SerNr<0) then begin
    QTr.SerNr = NextSerNr("QTVc",QTr.QTDate,-1,false,"");
  end;
  QTr.CustCode = cucode;
  PasteCustInQT(QTr,QTr.CustCode,"",warning,true);

  A2CProc_QT_Create_Do = RecordStore(QTr,false);
  qtnr = QTr.SerNr;
end;

procedure A2CProc_QT_Create(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  string 255 cucode,qtnr;
  string 255 incode;
  Boolean retval;

  cucode = FindParameter(Ctxr,nodestack,"CUr.Code","the customer that the user wants to create an quotation for",chatmessage,response);

  ValidateCUVc(cucode);

  EnsureParameter(Ctxr,cucode,"CUr.Code","Which customer would you like to create an quotation for?",response);

  StoreParameterInContext(Ctxr,"CUr.Code",cucode);

  if (Ctxr.Status<>"processing") then begin
    goto A2CProc_QT_Create_out;
  end;

  retval = qupdating.A2CProc_QT_Create_Do(cucode,qtnr);

  StoreParameterInContext(Ctxr,"QTr.SerNr",qtnr);

  if (retval) then begin
    response = response & "Quotation " & qtnr & " was created for " & cucode;
    PopNode(nodestack);
    Ctxr.Status = "waiting";
  end else begin
    response = response & "It is not possible to perform this action at the moment";
    Ctxr.Status = "waiting";
  end;
  
A2CProc_QT_Create_out:;
end;

function string 255 SayInvoiceStatus(Integer ivstat)
begin
  switch (ivstat) begin
    case 0: SayInvoiceStatus = "paid";
    case 1: SayInvoiceStatus = "awaiting payment";
    case 2: SayInvoiceStatus = "overdue";
    case 3: SayInvoiceStatus = "not registered";
    otherwise SayInvoiceStatus = "unknown";
  end;
end;

procedure A2CProc_CheckInvoiceStatus(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  string 255 cucode,ivnr,status_string,currency_code;
  Boolean retval;
  record CompaniesBlock CBl;
  row CompaniesBlock CBlrw;
  Integer oldcomp,invstat;
  LongInt ivser,rwcnt,rwn;
  val amount_due,amount_full;
  Boolean foundf;
  record Anna2SettingsBlock A2Sb;
  
  BlockLoad(A2Sb);

  cucode = FindParameter(Ctxr,nodestack,"CUr.Code","the customer that the user wants to inquire about",chatmessage,response);
  ivnr = FindParameterStartingInMessage(Ctxr,nodestack,"IVr.SerNr","the invoice number that the user wants inquire about",chatmessage,response);

  if (A2Sb.AnnaDebugLog<>0) then begin
    LogText(0,"A2CProc_CheckInvoiceStatus cucode " & cucode);
    LogText(0,"A2CProc_CheckInvoiceStatus ivnr " & ivnr);
  end;
  
  ValidateCUVc(cucode);
  ValidateIVVc(ivnr,cucode);

  if (A2Sb.AnnaDebugLog<>0) then begin
    LogText(0,"A2CProc_CheckInvoiceStatus cucode >>" & cucode & "<<");
    LogText(0,"A2CProc_CheckInvoiceStatus ivnr >>" & ivnr & "<<");
  end;
  
  EnsureParameter(Ctxr,ivnr,"IVr.SerNr","Which invoice do you want to know the status of?",response);

  if (cucode<>"") then begin StoreParameterInContext(Ctxr,"CUr.Code",cucode); end;

  StoreParameterInContext(Ctxr,"IVr.SerNr",ivnr);

  if (Ctxr.Status<>"processing") then begin
    goto LA2CProc_CheckInvoiceStatus_out;
  end;

  ivser = StringToLongInt(ivnr);

  if (FindCustomerAndInvoice(cucode,ivser,invstat,amount_due,amount_full,currency_code)) then begin
    response = response & " invoice " & ivser & " is " & SayInvoiceStatus(invstat);
    if (amount_due>0) then begin
      response = response & ", the outstanding amount is " & SayValAsCurrency(amount_due,currency_code);
    end;
  end else begin
    switch (invstat) begin
      case 3:
        response = response & " invoice " & ivser & " was not found";
      case 4:
        response = response & " customer " & cucode & " was not found";
      otherwise
        response = response & " an unknown error occured";
    end;
  end;
  
  //oldcomp = CurrentCompany;
  //BlockLoad(CBl);
  //rwcnt = MatRowCnt(CBl);
  //for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
  //  MatRowGet(CBl,rwn,CBlrw);
  //  if (SetCompany(rwn + 1,false)) then begin
  //    if (FindCustomerAndInvoice(cucode,ivser,invstat,amount_due,amount_full,currency_code)) then begin
  //      foundf = true;
  //      goto LA2CProc_CheckInvoiceStatus_Reply;
  //    end;
  //  end;
  //end;
  //LA2CProc_CheckInvoiceStatus_Reply:;
  //  ResetCompany(oldcomp);
  
  PopNode(nodestack);
  Ctxr.Status = "waiting";
LA2CProc_CheckInvoiceStatus_out:;
end;

global
updating function Boolean A2CProc_Invoice_Email_Do(string cucode,string ivnr,var string errorstr)
begin
  record IVVc IVr;
  record MailVc oldMailr,Mailr;
  string 255 warning;
  Integer err;
  
  IVr.SerNr = ivnr;
  ReadFirstMain(IVr,1,true);

  err = CreateMailFromIVD(IVr,Mailr,warning,true,"");
  if (err!=0) then begin
    if (err>0) then begin
      errorstr = USetStr(err) & " " & warning;
    end;
    A2CProc_Invoice_Email_Do = false;
  end else begin
    oldMailr = Mailr;
    Mailr.SendFlag = 1;
    RecordUpdate(oldMailr,Mailr,true);
    A2CProc_Invoice_Email_Do = true;
  end;
end;

procedure A2CProc_Invoice_Email(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  string 255 cucode,ivnr,errorstr;
  Boolean retval;
  
  ivnr = FindParameter(Ctxr,nodestack,"IVr.SerNr","which invoice the user wants to e-mail",chatmessage,response);
  cucode = FindParameter(Ctxr,nodestack,"CUr.Code","the customer that the user wants to e-mail an invoice to",chatmessage,response);

  ValidateCUVc(cucode);
  ValidateIVVc(ivnr,cucode);

  if (cucode=="") then begin FindCustomerFromInvoice(ivnr,cucode); end;
  if (ivnr=="") then begin FindInvoiceFromCustomer(cucode,ivnr); end;

  EnsureParameter(Ctxr,ivnr,"IVr.SerNr","Which invoice would you like to e-mail?",response);
  
  if (Ctxr.Status<>"processing") then begin
    goto A2CProc_Invoice_Email_out;
  end;
  
  if (ivnr=="" or cucode=="") then begin
    Anna2Chat_SystemError(Ctxr,nodestack,response);
    goto A2CProc_Invoice_Email_out;
  end;
  
  StoreParameterInContext(Ctxr,"CUr.Code",cucode);
  StoreParameterInContext(Ctxr,"IVr.SerNr",ivnr);

  retval = qupdating.A2CProc_Invoice_Email_Do(cucode,ivnr,errorstr);

  if (retval) then begin
    response = response & "Invoice " & ivnr & " was e-mailed";
    PopNode(nodestack);
    Ctxr.Status = "waiting";
  end else begin
    Anna2Chat_SystemError(Ctxr,nodestack,response);
    if (errorstr<>"") then begin
      response = response & "E-mailing Invoice failed with the error " & errorstr;
    end else begin
      response = response & "It is not possible to perform this action at the moment";
    end;
    Ctxr.Status = "waiting";
  end;
  
  A2CProc_Invoice_Email_out:;
end;
    
procedure A2CProc_IN_GetStockLevel(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  string 255 item;
  string 255 incode;
  Boolean retval;
  val stock_level;

  item = FindParameter(Ctxr,nodestack,"item","the item or product that the user wants to know the stock level for",chatmessage,response);

  ValidateItem(item,incode);

  EnsureParameter(Ctxr,incode,"item","Which item would you like to know the stock level of?",response);

  StoreParameter(Ctxr,nodestack,"item",incode);
  
  if (Ctxr.Status<>"processing") then begin
    goto A2CProc_IN_GetStockLevel_out;
  end;
  
  if (incode=="") then begin
    Anna2Chat_SystemError(Ctxr,nodestack,response);
    goto A2CProc_IN_GetStockLevel_out;
  end;
  
  FindStockLevelOfItem(incode,stock_level);
  
  //stock_levelstr = Trim(ValToString(stock_level,M4Val,"",".",1));
  //if (blank(stock_levelstr)) then begin stock_levelstr = "0"; end;

  if (stock_level>0) then begin
    response = response & "There are " & Trim(ValToString(stock_level,M4Val,"",".",1)) & " " & InCodeToName(incode) & " in stock";
  end else begin
    response = response & InCodeToName(incode) & " is not in stock";
  end;

  PopNode(nodestack);
  Ctxr.Status = "waiting";

  A2CProc_IN_GetStockLevel_out:;
end;

procedure A2CProc_GetLastPayments(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  Boolean foundf;
  string 255 count,cucode;
  Integer n,oldcomp;
  LongInt i;
  array date payment_date_arr;
  array val payment_amount_arr;
  array string 255 payment_currency_arr;
  date blankdateval;
  
  cucode = FindParameter(Ctxr,nodestack,"CUr.Code","the customer that the user wants to inquire about",chatmessage,response);
  count = FindParameter(Ctxr,nodestack,"count","the number of payments the user wants information about",chatmessage,response);
  
  ValidateCUVc(cucode);
  ValidateNumber(count,1,10,"5");

  EnsureParameter(Ctxr,cucode,"CUr.Code","Which customer would you like to list payments for?",response);
  StoreParameterInContext(Ctxr,"CUr.Code",cucode);
  
  if (Ctxr.Status<>"processing") then begin
    goto LA2CProc_GetLastPayments_out;
  end;
  
  n = StringToInt(count);
  
  oldcomp = CurrentCompany;
  SetCompany(1,false);
  FindLastPayments(cucode,n,blankdateval,payment_date_arr,payment_amount_arr,payment_currency_arr);
  ResetCompany(oldcomp);
  
  response = response & "The last payments are: " & NL NL;
  
  for (i = 0; i<payment_date_arr.length; i = i + 1) begin
    response = response & SayValAsCurrency(payment_amount_arr[i],payment_currency_arr[i]) & ", on " & SayAsDate(payment_date_arr[i]);
    if (i<(payment_date_arr.length-1)) then begin
      response = response & ".<break strength='medium'></break> " & NL;
    end;
  end;
  
  response = response & NL;
  
  PopNode(nodestack);
  Ctxr.Status = "waiting";
  
LA2CProc_GetLastPayments_out:;
end;

procedure FindLastInvoices(string customer_code,Integer maxcount,date mindate,
                           var array string invoice_nr_arr,
                           var array date invoice_date_arr,
                           var array val invoice_amount_arr,
                           var array string invoice_currency_arr)
begin
  record IVVc IVr;
  Boolean addf;
  Integer cnt,ix;
  Integer i,rwcnt;
  vector Boolean viprowprntdf;
  val pay_amount;
  string 255 pay_currency;
  vector LongInt vfound;
  
  IVr.CustCode = customer_code;
  while (LoopBackKey("CustCode",IVr,1,true)) begin
    
    if (IVr.CustCode<>customer_code) then begin goto LFindLastInvoices_out; end;
    if ((maxcount>0) and (cnt>=maxcount)) then begin goto LFindLastInvoices_out; end;
    if (nonblankDate(mindate) and (mindate>IVr.InvDate)) then begin goto LFindLastInvoices_out; end;
    
    ix = invoice_nr_arr.length;
    invoice_nr_arr[ix] = IVr.SerNr;
    invoice_date_arr[ix] = IVr.InvDate;
    invoice_amount_arr[ix] = IVr.Sum4;
    invoice_currency_arr[ix] = IVr.CurncyCode;
  end;
  
LFindLastInvoices_out:;
end;

procedure A2CProc_GetLastInvoices(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  Boolean foundf;
  string 255 count,cucode;
  Integer n,oldcomp;
  LongInt i;
  array string 255 invoice_nr_arr;
  array date invoice_date_arr;
  array val invoice_amount_arr;
  array string 255 invoice_currency_arr;
  date blankdateval;
  
  cucode = FindParameter(Ctxr,nodestack,"CUr.Code","the customer that the user wants to inquire about",chatmessage,response);
  count = FindParameter(Ctxr,nodestack,"count","the number of invoices the user wants information about",chatmessage,response);
  
  ValidateCUVc(cucode);
  ValidateNumber(count,1,10,"5");

  EnsureParameter(Ctxr,cucode,"CUr.Code","Which customer would you like to list invoices for?",response);
  StoreParameterInContext(Ctxr,"CUr.Code",cucode);
  
  if (Ctxr.Status<>"processing") then begin
    goto LA2CProc_GetLastInvoices_out;
  end;
  
  n = StringToInt(count);
  
  oldcomp = CurrentCompany;
  SetCompany(1,false);
  FindLastInvoices(cucode,n,blankdateval,invoice_nr_arr,invoice_date_arr,invoice_amount_arr,invoice_currency_arr);
  ResetCompany(oldcomp);
  
  response = response & "The last invoices for customer " & cucode & " are " & NL & NL;
  
  for (i = 0; i<invoice_date_arr.length; i = i + 1) begin
    response = response & SayNumberAsCardinal(invoice_nr_arr[i]) & " for " & SayValAsCurrency(invoice_amount_arr[i],invoice_currency_arr[i]) & ", on " & SayAsDate(invoice_date_arr[i])  & "." & NL;
    //if (i<(invoice_date_arr.length-1)) then begin
    //  response = response & "<break strength='medium'></break> ";
    //end;
  end;
  
  response = response & NL;
  
  PopNode(nodestack);
  Ctxr.Status = "waiting";
  
LA2CProc_GetLastInvoices_out:;
end;

procedure A2CProc_GetCompanyInfo(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response,string field)
begin
  record CYBlock CYb;
  string 255 value;
  
  BlockLoad(CYb);
  
  switch (field) begin
    case "accountant": value = CYb.ChiefAccountant;
    case "address": value = CYb.Addr0 & " " & CYb.Addr1 & " " & CYb.Addr2 & " " & CYb.Addr3;
    case "CEO": value = CYb.Manager;
    case "e-mail": value = CYb.emailAddr;
    case "postcode": value = CYb.Addr4;
    case "VAT": value = CYb.VATNr;
    case "website": value = CYb.wwwAddr;
  end;
  
  if (value<>"") then begin
    response = response & "The company " & field & " is " & value;
  end else begin
    response = response & "The company " & field & " is not available, is there something else I can help you with?";
  end;
  
  PopNode(nodestack);
  Ctxr.Status = "waiting";
end;

global
procedure Anna2Chat_ProcessNode(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  record Anna2ChatNodeVc Noder;
  record Anna2SettingsBlock A2Sb;
  
  BlockLoad(A2Sb);

  Noder = nodestack[nodestack.length - 1];
  
  if (A2Sb.AnnaDebugLog<>0) then begin
    LogText(0,"Anna2, ProcessNode, " & Noder.SerNr & " stackdepth " & nodestack.length);
  end;
  
  Noder.TryCount = Noder.TryCount + 1;
  nodestack[nodestack.length - 1] = Noder;
  
  if (Noder.TryCount>3) then begin
    Anna2Chat_SystemError(Ctxr,nodestack,response);
    goto Anna2Chat_ProcessNode_out;
  end;
  
  if (Noder.State==kChatNodeState_Init) then begin
    if (Noder.Greeting<>"") then begin
      response = response & Noder.Greeting & NL & NL;
    end;
    
    Noder.State = kChatNodeState_Processing;
    nodestack[nodestack.length - 1] = Noder;
  end;
  
  if (A2Sb.AnnaDebugLog<>0) then begin
    LogText(0,"Anna2, ProcessNode, function " & Noder.SystemFunction);
    LogText(0,"Anna2, ProcessNode, chatmessage " & chatmessage);
  end;
  
  switch (Noder.SystemFunction) begin
    case "Menu": A2CProc_Menu(Ctxr,nodestack,chatmessage,response);
    
    case "Answer": A2CProc_Answer(Ctxr,nodestack,chatmessage,response,false);
    case "RandomAnswer": A2CProc_Answer(Ctxr,nodestack,chatmessage,response,true);
    
    case "CreateNewOrder": A2CProc_OR_Create(Ctxr,nodestack,chatmessage,response);
    case "AddItemToOrder": A2CProc_OR_AddItem(Ctxr,nodestack,chatmessage,response);
    case "EmailOrder": A2CProc_OR_Email(Ctxr,nodestack,chatmessage,response);
    case "GetOrdersPendingDelivery": A2CProc_OR_GetDeliverable(Ctxr,nodestack,chatmessage,response);
    case "GetPlannedDelivery": A2CProc_OR_PlannedDelivery(Ctxr,nodestack,chatmessage,response);
    
    case "CreateNewQuotation": A2CProc_QT_Create(Ctxr,nodestack,chatmessage,response);
    case "AddItemToQuotation": A2CProc_QT_AddItem(Ctxr,nodestack,chatmessage,response);
    case "EmailQuotation": A2CProc_QT_Email(Ctxr,nodestack,chatmessage,response);

    case "CheckInvoiceStatus": A2CProc_CheckInvoiceStatus(Ctxr,nodestack,chatmessage,response);
    case "RequestInvoices": A2CProc_GetLastInvoices(Ctxr,nodestack,chatmessage,response);
    case "EmailInvoice": A2CProc_Invoice_Email(Ctxr,nodestack,chatmessage,response);

    case "GetLastPayments": A2CProc_GetLastPayments(Ctxr,nodestack,chatmessage,response);
    
    case "GetStockLevelOfItem": A2CProc_IN_GetStockLevel(Ctxr,nodestack,chatmessage,response);
    
    case "RequestCompanyAccountant": A2CProc_GetCompanyInfo(Ctxr,nodestack,chatmessage,response,"accountant");
    case "RequestCompanyAddress": A2CProc_GetCompanyInfo(Ctxr,nodestack,chatmessage,response,"address");
    case "RequestCompanyCEO": A2CProc_GetCompanyInfo(Ctxr,nodestack,chatmessage,response,"CEO");
    case "RequestCompanyEmail": A2CProc_GetCompanyInfo(Ctxr,nodestack,chatmessage,response,"e-mail");
    case "RequestCompanyPostcode": A2CProc_GetCompanyInfo(Ctxr,nodestack,chatmessage,response,"postcode");
    case "RequestCompanyVAT": A2CProc_GetCompanyInfo(Ctxr,nodestack,chatmessage,response,"VAT");
    case "RequestCompanyWebsite": A2CProc_GetCompanyInfo(Ctxr,nodestack,chatmessage,response,"website");
    // case "TellJoke":
    
    // case "Hangup":
    // case "ChangeLanguage":
    otherwise
      response = "unknown function '" & Noder.SystemFunction & "' for intent " & Noder.Intent & " on chat node " & Noder.SerNr;
      PopNode(nodestack);
      Ctxr.Status = "waiting";
  end;
  
Anna2Chat_ProcessNode_out:;
end;

global
function string 255 Anna2Chat_Process(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,string achatmessage)
begin
  string 255 res,chatmessage;
  
  //if (Ctxr.CurrentNode<=0) then begin Ctxr.CurrentNode = Anna2StartNode; end;
  
  Ctxr.Status = "processing";
  chatmessage = achatmessage;
    
  while (Ctxr.Status=="processing") begin
    Anna2Chat_ProcessNode(Ctxr,nodestack,chatmessage,res);
  end;
    
  Anna2Chat_Process = res;
end;

global
function string 255 ContextToString(record Anna2ContextVc Ctxr)
begin
  string 255 res;
  area ra;
  
  AddRecordToArea(Ctxr,"Anna2ContextVc",ra);
  res = AreaToString(ra);
  res = Base64Encode(res);
  
  ContextToString = res;
end;

global
procedure StringToContext(string astr,var record Anna2ContextVc Ctxr)
begin
  area ra;
  string 255 str;

  str = astr;

  if (str<>"") then begin
    str = Base64Decode(str);
  end;
  
  if (str<>"") then begin
    AddTextToArea(str,ra);
    GetRecordFromArea(Ctxr,"Anna2ContextVc",0,ra);
  end;
end;

global
function string 255 NodeToString(record Anna2ChatNodeVc Noder)
begin
  string 255 res;
  area ra;
  
  AddRecordToArea(Noder,"Anna2ChatNodeVc",ra);
  res = AreaToString(ra);
  res = Base64Encode(res);
  
  NodeToString = res;
end;

global
procedure StringToNode(string astr,var record Anna2ChatNodeVc Noder)
begin
  area ra;
  string 255 str;

  str = astr;

  if (str<>"") then begin
    str = Base64Decode(str);
  end;
  
  if (str<>"") then begin
    AddStringToArea(str,ra);
    GetRecordFromArea(Noder,"Anna2ChatNodeVc",0,ra);
  end;
end;

global
procedure Anna2_LoadCbctx(string cbctx,var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,
                     var array string roles,var array string messages)
begin
  string 255 nodestr,ctxstr;
  record Anna2ChatNodeVc Noder,StartNode;
  
  ChatBotContext_SetRecord(cbctx,"A2Ctx",Ctxr);

  ClearArray(nodestack);
  nodestr = GetChatBotContextValue(cbctx,"Nodestack[0]");
  while (nodestr<>"") begin
    StringToNode(nodestr,Noder);
    PushNode(nodestack,Noder);
    nodestr = GetChatBotContextValue(cbctx,"Nodestack[" & nodestack.length & "]");
  end;
  
  if (nodestack.length==0) then begin
    StartNode.SerNr = Anna2StartNode;
    ReadFirstMain(StartNode,1,true);
    nodestack[0] = StartNode;
  end;
  
  AIChat_LoadCbctx(cbctx,roles,messages);
end;

procedure AddDebugContextRows(record Anna2ContextVc Ctxr,string aprefix,var string debugstr)
begin
  row Anna2ContextVc Ctxrw;
  LongInt i,rwcnt;
  string 255 prefix,value;
  
  prefix = aprefix & ":";
  
  rwcnt = MatRowCnt(Ctxr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(Ctxr,i,Ctxrw);
    if (left(Ctxrw.Object,len(prefix))==prefix) then begin
      value = Base64Decode(Ctxrw.Value);
      RemoveParenExprFromString(value,"[[","]]");
      RemoveParenExprFromString(value,"[","]");

      debugstr = debugstr & Ctxrw.Object & " = " & value & NL;
    end;
  end;

end;

global
function string 255 Anna2_Ctx_DebugStr(record Anna2ContextVc Ctxr,array record Anna2ChatNodeVc nodestack)
begin
  string 255 debugstr;
  record Anna2ChatNodeVc A2CNr;
  LongInt i;
  
  debugstr = debugstr &      "----------- stack -----------" & NL;

  for (i = 0; i<nodestack.length; i = i + 1) begin
    A2CNr = nodestack[i];
    debugstr = debugstr & A2CNr.SerNr & "   " & A2CNr.Intent & "   " & A2CNr.Comment & "   " & A2CNr.State & NL;
  end;

  debugstr = debugstr & NL & "---------- context ----------" & NL;
  debugstr = debugstr & Ctxr.CurrentNode & " " & Ctxr.Status & NL & NL;
  AddDebugContextRows(Ctxr,"parameter",debugstr);

  //debugstr = debugstr & NL & "---------- history ----------" & NL;
  //AddDebugContextRows(Ctxr,"role",debugstr);
  
  Anna2_Ctx_DebugStr = debugstr;
end;

global
procedure Anna2_StoreCbctx(string cbctx,record Anna2ContextVc Ctxr,array record Anna2ChatNodeVc nodestack,
                      var array string roles,var array string messages)
begin
  LongInt i,rwcnt;
  string 255 ctxstr,debugstr; //,filename;
  record Anna2SettingsBlock A2Sb;
  
  BlockLoad(A2Sb);

  ctxstr = ContextToString(Ctxr);
  
  SetChatBotContextValue(cbctx,"Anna2Contextr",ctxstr);

  //filename = CreateTempFile("Anna2_Context_Put_" & TimeStampStr,".txt");
  //WriteStringToFile(ctxstr,filename,0);

  for (i = 0; i<nodestack.length; i = i + 1) begin
    SetChatBotContextValue(cbctx,"Nodestack[" & i & "]",NodeToString(nodestack[i]));
  end;

  SetChatBotContextValue(cbctx,"Nodestack[" & nodestack.length & "]","");

  AIChat_StoreCbctx(cbctx,roles,messages,false,true,true);

  if (A2Sb.AnnaDebugLog<>0) then begin
    LogText(0,"Anna2_StoreCbctx" & NL & NL & Anna2_Ctx_DebugStr(Ctxr,nodestack));
  end;
end;

global
procedure Anna2_Init()
begin
  AI_InitIntents;
end;
