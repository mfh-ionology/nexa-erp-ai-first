  ValidateORVc(ornr,cucode);

  //if (cucode=="") then begin FindCustomerFromOrder(ornr,cucode); end;
  //if (ornr=="") then begin FindOrderFromCustomer(cucode,ornr); end;

  EnsureParameter(Ctxr,ornr,"ORr.SerNr","Which order would you like know the planned delivery date of?",response);
  
  if (Ctxr.Status<>"processing") then begin
    goto A2CProc_OR_PlannedDelivery_out;
  end;
  
  if (ornr=="" or cucode=="") then begin
    Anna2Chat_SystemError(Ctxr,nodestack,response);
    goto A2CProc_OR_PlannedDelivery_out;
  end;
  
  //StoreParameterInContext(Ctxr,"CUr.Code",cucode);
  StoreParameterInContext(Ctxr,"ORr.SerNr",ornr);

  /*resf =*/ FindPlannedDeliveryDate(cucode,StringToLongInt(ornr),planned_delivery_date);

  response = response & "The planned delivery date for order " & ornr & " is " & SayAsDate(planned_delivery_date);
  
/*
  if (resf==false) then begin
    status_code = 3; // Order not found
  end;
*/
  
  PopNode(nodestack);
  Ctxr.Status = "waiting";
  
  A2CProc_OR_PlannedDelivery_out:;
end;

