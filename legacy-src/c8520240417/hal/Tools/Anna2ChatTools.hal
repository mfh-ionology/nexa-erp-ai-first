global
updating function Boolean A2CProc_OR_AddItem_Do(string item,string qty,string cucode,string ornr)
begin
  record ORVc oldORr,ORr;
  row ORVc ORrw;
  LongInt rwcnt;
  string 255 inwarning,warning;
  record Anna2SettingsBlock A2Sb;

  BlockLoad(A2Sb);

  if (A2Sb.AnnaDebugLog<>0) then begin
    LogText(0,"AddItemToOrder add " & qty & " " & item & "(s) to order " & ornr & " for " & cucode);
  end;
  
  ORr.SerNr = ornr;
  ReadFirstMain(ORr,1,true);
  oldORr = ORr;
  
  rwcnt = MatRowCnt(ORr);
  ORrw.ArtCode = item;
  ORrw.Quant = StringToVal(qty,M4Val);
  MatRowPut(ORr,rwcnt,ORrw);
  ORVc_PasteArtCode(ORr,rwcnt,inwarning,warning,false);
  
  if (RecordUpdate(oldORr,ORr,true)==0) then begin
    A2CProc_OR_AddItem_Do = true;
  end else begin
    A2CProc_OR_AddItem_Do = false;
  end;
end;

function string 255 NameOrString(string name,string default)
begin
  string 255 res;
  
  res = Trim(name);
  if (res=="") then begin
    res = default;
  end;
  
  NameOrString = res;
end;

function string 255 InCodeToName(string incode)
begin
  string 255 res;
  record INVc INr;
  
  INr.Code = incode;
  if (ReadFirstMain(INr,1,true)) then begin
    res = INr.Name;
  end else begin
    res = "unknown item";
  end;
  
  InCodeToName = res;
end;

procedure A2CProc_OR_AddItem(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  string 255 item,qty,cucode,ornr;
  string 255 incode;
  Boolean retval;
    
  item = FindParameter(Ctxr,nodestack,"item","the next item or product that the user wanted to add to the order",chatmessage,response);
  qty = FindParameter(Ctxr,nodestack,"qty","how many " & NameOrString(item,"[item] or products") & " the user wants to add to the order",chatmessage,response);
  ornr = FindParameter(Ctxr,nodestack,"ORr.SerNr","which order the user wants to add items to",chatmessage,response);
  cucode = FindParameter(Ctxr,nodestack,"CUr.Code","the customer that the user wants to add items for",chatmessage,response);

  ValidateItem(item,incode);
  ValidateQuantity(qty,1,100);
  ValidateCUVc(cucode);
  ValidateORVc(ornr,cucode);

  if (cucode=="") then begin FindCustomerFromOrder(ornr,cucode); end;
  if (ornr=="") then begin FindOrderFromCustomer(cucode,ornr); end;

  EnsureParameter(Ctxr,incode,"item","Which item would you like to add?",response);
  EnsureParameter(Ctxr,ornr & cucode,"ORr.SerNr","Which order would you like to add items to?",response);
  //EnsureParameter(Ctxr,ornr,"ORr.SerNr","Which order would you like to add to?",response);

  StoreParameter(Ctxr,nodestack,"item",incode);
  
  if (Ctxr.Status<>"processing") then begin
    goto A2CProc_OR_AddItem_out;
  end;
  
  if (ornr=="" or cucode=="" or incode=="") then begin
    Anna2Chat_SystemError(Ctxr,nodestack,response);
    goto A2CProc_OR_AddItem_out;
  end;
  
  StoreParameterInContext(Ctxr,"CUr.Code",cucode);
  StoreParameterInContext(Ctxr,"ORr.SerNr",ornr);

  if (qty=="") then begin qty = "1"; end;

  retval = qupdating.A2CProc_OR_AddItem_Do(incode,qty,cucode,ornr);

  if (retval) then begin
    response = response & "Item " & InCodeToName(incode) & " was added to order " & ornr;
    PopNode(nodestack);
    Ctxr.Status = "waiting";
  end else begin
    Anna2Chat_SystemError(Ctxr,nodestack,response);
    response = response & "It is not possible to perform this action at the moment";
    Ctxr.Status = "waiting";
  end;
  
  A2CProc_OR_AddItem_out:;
end;

global
updating function Boolean A2CProc_OR_Email_Do(string cucode,string ornr,var string errorstr)
begin
  record ORVc ORr;
  record MailVc oldMailr,Mailr;
  string 255 warning;
  Integer err;
  
  ORr.SerNr = ornr;
  ReadFirstMain(ORr,1,true);

  err = CreateMailFromORD(ORr,Mailr,warning,"");
  if (err!=0) then begin
    if (err>0) then begin
      errorstr = USetStr(err) & " " & warning;
    end;
    A2CProc_OR_Email_Do = false;
  end else begin
    oldMailr = Mailr;
    Mailr.SendFlag = 1;
    RecordUpdate(oldMailr,Mailr,true);
    A2CProc_OR_Email_Do = true;
  end;
end;

procedure A2CProc_OR_Email(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  string 255 cucode,ornr,errorstr;
  Boolean retval;
  
  ornr = FindParameter(Ctxr,nodestack,"ORr.SerNr","which order the user wants to e-mail",chatmessage,response);
  cucode = FindParameter(Ctxr,nodestack,"CUr.Code","the customer that the user wants to e-mail an order to",chatmessage,response);

  ValidateCUVc(cucode);
  ValidateORVc(ornr,cucode);

  if (cucode=="") then begin FindCustomerFromOrder(ornr,cucode); end;
  if (ornr=="") then begin FindOrderFromCustomer(cucode,ornr); end;

  EnsureParameter(Ctxr,ornr,"ORr.SerNr","Which order would you like to e-mail?",response);
  
  if (Ctxr.Status<>"processing") then begin
    goto A2CProc_OR_Email_out;
  end;
  
  if (ornr=="" or cucode=="") then begin
    Anna2Chat_SystemError(Ctxr,nodestack,response);
    goto A2CProc_OR_Email_out;
  end;
  
  StoreParameterInContext(Ctxr,"CUr.Code",cucode);
  StoreParameterInContext(Ctxr,"ORr.SerNr",ornr);

  retval = qupdating.A2CProc_OR_Email_Do(cucode,ornr,errorstr);

  if (retval) then begin
    response = response & "Order " & ornr & " was e-mailed";
    PopNode(nodestack);
    Ctxr.Status = "waiting";
  end else begin
    Anna2Chat_SystemError(Ctxr,nodestack,response);
    if (errorstr<>"") then begin
      response = response & "E-mailing order failed with the error " & errorstr;
    end else begin
      response = response & "It is not possible to perform this action at the moment";
    end;
    Ctxr.Status = "waiting";
  end;
  
  A2CProc_OR_Email_out:;
end;

function Boolean ORVc_IsDeliverable(record ORVc ORr)
begin
  Boolean res;
  
  if (ORr.ShipFlag==0) then begin
    if ((ORr.InvFlag<2) or (ORr.InvBeforeShip==1)) then begin res = true; end;
    if ((ORr.InvFlag==0) or (ORr.InvFlag==2)) then begin res = true; end;
  end;
  
  ORVc_IsDeliverable = res;
end;

procedure A2CProc_OR_GetDeliverable(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  string 255 cucode,errorstr,count;
  Boolean retval;
  record ORVc ORr;
  Integer cnt,cnt_max;

  cucode = FindParameter(Ctxr,nodestack,"CUr.Code","the customer that the user wants to get deliverable orders for",chatmessage,response);
  count = FindParameter(Ctxr,nodestack,"count","how many orders, if any, the user wants to include in the list",chatmessage,response);

  ValidateCUVc(cucode);
  ValidateNumber(count,1,100,"5");

  EnsureParameter(Ctxr,cucode,"CUr.Code","Which customer would you like to list orders for?",response);

  if (Ctxr.Status<>"processing") then begin
    LogText(0,"A2CProc_OR_GetDeliverable Ctxr.Status " & Ctxr.Status);
    goto LA2CProc_OR_GetDeliverable_out;
  end;
  
  if (cucode=="") then begin
    LogText(0,"A2CProc_OR_GetDeliverable cucode " & cucode);
    Anna2Chat_SystemError(Ctxr,nodestack,response);
    goto LA2CProc_OR_GetDeliverable_out;
  end;

  StoreParameterInContext(Ctxr,"CUr.Code",cucode);

  cnt_max = StringToInt(count);
  if (cnt_max==0) then begin cnt_max = 5; end;

  ORr.OSFlag = 1;
  ORr.CustCode = cucode;

  while (LoopBackKey("OSCU",ORr,2,true)) begin
    if (ORr.OSFlag<>1) then begin goto LA2CProc_OR_GetDeliverable_done; end;
    if (ORr.CustCode<>cucode) then begin goto LA2CProc_OR_GetDeliverable_done; end;
    if (cnt>=cnt_max) then begin goto LA2CProc_OR_GetDeliverable_done; end;
    
    if (ORVc_IsDeliverable(ORr)) then begin
      if (cnt>=1) then begin
        response = response & ",<break strength='medium'></break> " & NL;
      end;
      
      response = response & "order " & SayNumberAsCardinal(ORr.SerNr) & ", " & SayAsDate(ORr.OrdDate);
      cnt = cnt + 1;
    end;
  end;

LA2CProc_OR_GetDeliverable_done:;
  if (cnt==0) then begin
    response = response & "there are no deliverable orders for cusgtomer " & cucode;
  end;
  
  PopNode(nodestack);
  Ctxr.Status = "waiting";
  
LA2CProc_OR_GetDeliverable_out:;
  return;
end;

global
updating function Boolean A2CProc_OR_Create_Do(string cucode,var string ornr)
begin
  record ORVc oldORr,ORr;
  LongInt rwcnt;
  string 255 warning,errstr;

  RecordNew(ORr);
  if (ORr.SerNr<0) then begin
    ORr.SerNr = NextSerNr("ORVc",ORr.OrdDate,-1,false,"");
  end;
  ORr.CustCode = cucode;
  PasteCustInOrder(ORr,ORr.CustCode,"",warning,errstr);

  A2CProc_OR_Create_Do = RecordStore(ORr,false);
  ornr = ORr.SerNr;
end;

procedure A2CProc_OR_Create(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  string 255 cucode,ornr;
  string 255 incode;
  Boolean retval;

  cucode = FindParameter(Ctxr,nodestack,"CUr.Code","the customer that the user wants to create an order for",chatmessage,response);

  ValidateCUVc(cucode);

  EnsureParameter(Ctxr,cucode,"CUr.Code","Which customer would you like to create an order for?",response);

  StoreParameterInContext(Ctxr,"CUr.Code",cucode);

  if (Ctxr.Status<>"processing") then begin
    goto A2CProc_OR_Create_out;
  end;

  retval = qupdating.A2CProc_OR_Create_Do(cucode,ornr);

  StoreParameterInContext(Ctxr,"ORr.SerNr",ornr);

  if (retval) then begin
    response = response & "Order " & ornr & " was created for " & cucode;
    PopNode(nodestack);
    Ctxr.Status = "waiting";
  end else begin
    response = response & "It is not possible to perform this action at the moment";
    Ctxr.Status = "waiting";
  end;
  
A2CProc_OR_Create_out:;
end;

procedure A2CProc_OR_PlannedDelivery(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  string 255 cucode,ornr,errorstr;
  date planned_delivery_date;
  Boolean retval;
  
  ornr = FindParameter(Ctxr,nodestack,"ORr.SerNr","which order the user wants to know the planned delivery date of",chatmessage,response);
