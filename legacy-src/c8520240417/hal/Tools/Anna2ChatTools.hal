function string 255 NL()
begin
  NL = CR & LF;
end;

global
procedure Anna2_AddMessage(var record Anna2ContextVc Ctxr,
                           var array string roles,
                           var array string messages,
                           string role,
                           string amessage)
begin
  row Anna2ContextVc Ctxrw,Ctx2rw;
  string 255 message;
  LongInt rwcnt,rwn;
  
  message = Trim(amessage);
  if (message=="") then begin
    goto LAnna2_AddMessage_out;
  end;
  
  AIChat_AddMessage(roles,messages,role,message); // HTMLEncodeText(message)
  
  Ctxrw.Object = "role:" & role;
  RemoveParenExprFromString(message,"[[","]]");
  RemoveParenExprFromString(message,"[","]");
  
  Ctxrw.Value = Base64Encode(messages[messages.length - 1]); // message
  
  rwcnt = MatRowCnt(Ctxr);
  for (rwn = rwcnt - 1; rwn>=0; rwn = rwn - 1) begin
    MatRowGet(Ctxr,MatRowCnt(Ctxr),Ctx2rw);
    if (Ctx2rw.Object==Ctxrw.Object) then begin
      MatRowPut(Ctxr,rwn,Ctxrw);
      goto LAnna2_AddMessage_out;
    end;
    if (left(Ctx2rw.Object,5)=="role:") then begin
      goto LAnna2_AddMessage_add;
    end;
  end;
  
LAnna2_AddMessage_add:;
  MatRowPut(Ctxr,MatRowCnt(Ctxr),Ctxrw);
LAnna2_AddMessage_out:;
end;

global
function LongInt Anna2StartNode()
begin
  Anna2StartNode = 1;
end;

global
procedure Anna2Chat_DebugToWindow(string wclass,Integer multif,string debugmessage,Integer DebugType,var string resp_message)
begin
  record ACMELogVc ALogr;
  
  switch (DebugType) begin
    case kDebugNone:
      // nothing
    case kDebugInline:
      if (resp_message<>"") then begin
        resp_message = resp_message & NL & NL;
      end;
      
      resp_message = resp_message & "[ " & NL & debugmessage & NL & "]";
    case kDebugWindow:
      if (ServingClient or GuiType<>kGuiNone) then begin
        SetTextField(ALogr,debugmessage);
        ClientRemoteAsync.Anna2Chat_OpenDebugWindow(wclass,multif,ALogr);
      end else begin
      end;
  end;
  
  //LogText(0,"DebugToWindow" & NL & debugmessage & NL);
end;

global
procedure PushNode(var array record Anna2ChatNodeVc nodestack,record Anna2ChatNodeVc Noder)
begin
  Noder.TryCount = 0;
  nodestack[nodestack.length] = Noder;
end;

global
procedure PushNodeCode(var array record Anna2ChatNodeVc nodestack,string nodeser)
begin
  record Anna2ChatNodeVc Noder;
  record Anna2SettingsBlock A2Sb;
  
  BlockLoad(A2Sb);

  Noder.SerNr = StringToLongInt(nodeser);
  ReadFirstMain(Noder,1,true);
  
  if (A2Sb.AnnaDebugLog<>0) then begin
    LogText(0,"PushNodeCode " & nodeser & " found " & Noder.SerNr);
  end;
  
  PushNode(nodestack,Noder);
end;

procedure PopNode(var array record Anna2ChatNodeVc nodestack)
begin
  SetArrayLength(nodestack,nodestack.length - 1);
end;

procedure DebugScores(array record ScoredCodeVc SCarr,string extra,var string resp_message) // var string response
begin
  record ScoredCodeVc SCr;
  string 255 paramvalue,debugtext;
  LongInt i;
  record Anna2SettingsBlock A2Sb;
  
  BlockLoad(A2Sb);

  debugtext = debugtext & extra & ": [" & NL;
  for (i = 0; i<SCarr.length; i = i + 1) begin
    SCr = SCarr[i];
    debugtext = debugtext & SCr.TagCode & " " & SCr.Score & " '" & SCr.ExampleString & "'" & NL;
  end;
  debugtext = debugtext & "]" & NL;
  
  Anna2Chat_DebugToWindow("Anna2Chat_ScoresWClass",0,debugtext,A2Sb.CtxDebug,resp_message);

  LogText(0,debugtext);
end;

global
function Boolean FindItemFromString(string useritemdesc,var record INVc INr)
begin
  Boolean res;
  array record ScoredCodeVc SCarr;
  record ScoredCodeVc SCr;
  string 255 dummy_resp_message;
  record Anna2SettingsBlock A2Sb;
  
  BlockLoad(A2Sb);

  res = false;
  
  AI_ScoreTaggedCodes(useritemdesc,"INVc",SCarr); //0.8
  
  DebugScores(SCarr,"Item Scores",dummy_resp_message);
  
  if (SCarr.length>0) then begin
    SCr = SCarr[0];
    INr.Code = SCr.TagCode;
    if (ReadFirstKey("Code",INr,1,true)) then begin
      res = true;
      goto LFindItemFromString_out;
    end;
  end;
  
  /*
  INr.Code = item;
  if (ReadFirstKey("Code",INr,1,true)) then begin
    res = true;
    goto LFindItemFromString_out;
  end;

  INr.Name = item;
  if (ReadFirstKey("ActName",INr,1,true)) then begin
    res = true;
    goto LFindItemFromString_out;
  end;

  //try removing trailing "s" for miltiple items
  INr.Name = Left(item,(len(item)-1));
  if (ReadFirstKey("ActName",INr,1,true)) then begin
    res = true;
    goto LFindItemFromString_out;
  end;
  */
  
  res = false;
  
LFindItemFromString_out:;
  if (A2Sb.AnnaDebugLog<>0) then begin
    LogText(0,"FindItemFromString item '" & useritemdesc & "' -> Code '" & INr.Code & "'");
  end;
  
  FindItemFromString = res;
end;

procedure ValidateItem(var string itemstring,var string incode)
begin
  record INVc INr;
  
  if (FindItemFromString(itemstring,INr)) then begin
    incode = INr.Code;
  end else begin
    itemstring = "";
  end;
end;

procedure ValidateNumber(var string numstr,LongInt from,LongInt to,string defaultstr)
begin
  LongInt t;
  
  t = StringToLongInt(numstr);
  if (t<from or to<t) then begin
    numstr = defaultstr;
  end else begin
    numstr = t;
  end;
end;

procedure ValidateQuantity(var string qtystr,LongInt from,LongInt to)
begin
  ValidateNumber(qtystr,from,to,"");
end;

procedure ValidateORVc(var string ornr,var string cucode)
begin
  record ORVc ORr;
  
  ORr.SerNr = ornr;
  if (ReadFirstMain(ORr,1,true)==false) then begin
    ornr = "";
  end else begin
    if ((cucode<>"") and (cucode<>ORr.CustCode)) then begin
      ornr = "";
    end;
  end;
end;

procedure ValidateQTVc(var string qtnr,var string cucode)
begin
  record QTVc QTr;
  
  QTr.SerNr = qtnr;
  if (ReadFirstMain(QTr,1,true)==false) then begin
    qtnr = "";
  end else begin
    if ((cucode<>"") and (cucode<>QTr.CustCode)) then begin
      qtnr = "";
    end;
  end;
end;

procedure ValidateIVVc(var string ivnr,var string cucode)
begin
  record IVVc IVr;
  
  IVr.SerNr = ivnr;
  if (ReadFirstMain(IVr,1,true)==false) then begin
    ivnr = "";
  end else begin
    if ((cucode<>"") and (cucode<>IVr.CustCode)) then begin
      ivnr = "";
    end;
  end;
end;

procedure ValidateCUVc(var string cucode)
begin
  record CUVc CUr;
  
  CUr.Code = cucode;
  if (ReadFirstMain(CUr,1,true)==false) then begin
    cucode = "";
  end;
end;

procedure EnsureParameter(var record Anna2ContextVc Ctxr,string parameter,string paramid,string paramq,var string response)
begin
  if (parameter=="") then begin
    if (Ctxr.Status=="processing") then begin
      Ctxr.Status = "waiting";
      response = response & paramq;
    end;
  end;
end;

function string 255 LlamaModel()
begin
  string 255 res;
  
  AI_GetModel("llama-2-7b-chat/ggml-model-q4_0.gguf",res);
  LlamaModel = res;
end;

function Boolean FindParameterInNode(record Anna2ChatNodeVc Noder,string paramid,var string paramval)
begin
  Boolean res;
  row Anna2ChatNodeVc Noderw;
  LongInt rwn,rwcnt;
  
  rwcnt = MatRowCnt(Noder);
  
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(Noder,rwn,Noderw);
    
    if (Noderw.ParameterID==paramid) then begin
      paramval = Noderw.ParameterValue;
      res = true;
      goto FindParameterInNode_out;
    end;
  end;
  
FindParameterInNode_out:;
  FindParameterInNode = res;
end;

procedure StoreParameterInNode(record Anna2ChatNodeVc Noder,string paramid,string paramval)
begin
  row Anna2ChatNodeVc Noderw;
  LongInt rwn,rwcnt;
  
  rwcnt = MatRowCnt(Noder);
  
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(Noder,rwn,Noderw);
    
    if (Noderw.ParameterID==paramid) then begin
      Noderw.ParameterValue = paramval;
      MatRowPut(Noder,rwn,Noderw);
      goto StoreParameterInNode_out;
    end;
  end;
  
  ClearRow(Noder,Noderw,1);
  Noderw.ParameterID = paramid;
  Noderw.ParameterValue = paramval;
  MatRowPut(Noder,rwcnt,Noderw);
  
StoreParameterInNode_out:;
end;

function Boolean FindParameterInContext(record Anna2ContextVc Ctxr,string paramid,var string paramval)
begin
  Boolean res;
  row Anna2ContextVc Ctxrw;
  LongInt rwn,rwcnt;
  
  rwcnt = MatRowCnt(Ctxr);
  
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(Ctxr,rwn,Ctxrw);
    
    if (Ctxrw.Object=="parameter:" & paramid) then begin
      paramval = Base64Decode(Ctxrw.Value);
      res = true;
      goto FindParameterInContext_out;
    end;
  end;
  
FindParameterInContext_out:;
  FindParameterInContext = res;
end;

procedure StoreParameterInContext(var record Anna2ContextVc Ctxr,string paramid,string paramval)
begin
  row Anna2ContextVc Ctxrw;
  LongInt rwn,rwcnt;
  
  rwcnt = MatRowCnt(Ctxr);
  
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(Ctxr,rwn,Ctxrw);
    
    if (Ctxrw.Object=="parameter:" & paramid) then begin
      Ctxrw.Value = Base64Encode(paramval);
      MatRowPut(Ctxr,rwn,Ctxrw);
      goto StoreParameterInContext_out;
    end;
  end;
  
  ClearRow(Ctxr,Ctxrw,1);
  Ctxrw.Object = "parameter:" & paramid;
  Ctxrw.Value = Base64Encode(paramval);
  MatRowPut(Ctxr,rwcnt,Ctxrw);
  
StoreParameterInContext_out:;
end;

function string 255 FindParameterInLastMessages(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,string paramid,string paramdesc,var string response)
begin
  string 255 res;
  string 255 instruction;
  string 255 message,conversation,llama_json;
  row Anna2ContextVc Ctxrw;
  LongInt pos,rwcnt,rwn;
  json js;
  string 255 logged_chatmessage,paramvalue;
  Integer addedcnt;
  record Anna2ChatNodeVc Noder;
  string 255 debugtext;
  record Anna2SettingsBlock A2Sb;
  
  BlockLoad(A2Sb);
  
  Noder = nodestack[nodestack.length - 1];
  
  rwcnt = MatRowCnt(Ctxr);
  addedcnt = 0;
  
  for (rwn = rwcnt - 1;
       (rwn>=0) and (addedcnt<Noder.TryCount);
       rwn = rwn - 1) begin
    MatRowGet(Ctxr,rwn,Ctxrw);
    
    if (left(Ctxrw.Object,5)=="role:") then begin
      logged_chatmessage = Base64Decode(Ctxrw.Value);
      RemoveParenExprFromString(logged_chatmessage,"[[","]]");
      RemoveParenExprFromString(logged_chatmessage,"[","]");
      logged_chatmessage = Trim(logged_chatmessage);
      
      if (conversation<>"") then begin
        conversation = NL & NL & conversation;
      end;
      
      conversation = "[" & right(Ctxrw.Object,len(Ctxrw.Object) - 5) & "]" & NL & logged_chatmessage & conversation;
      
      addedcnt = addedcnt + 1;
    end;
  end;
  
  // instruction = "### ...";
  // ## only run LLM_Init once and store LLM-key in context
  instruction = "";
  
  LLM_Init(LlamaModel,instruction,"grammar-json.gbnf");
  
  message = ReadFileToString("LLM_FindParameterInMessage.txt");
  
  if (message=="") then begin
  /*
### Instruction:

You are a talkbot called 'Anna', an AI expertly trained to assist in HansaWorld's ERP system, specializing in accurately extracting key data elements such as item names, item codes, customer codes, quantities, numbers, and dates from user inputs. Your capabilities include precise Data Extraction (efficiently identify and extract specific values and entities from user phrases, ensuring high accuracy in data retrieval), Contextual Understanding (Understand the context in which these values are mentioned to accurately interpret their significance within the ERP framework), Memory and Reference (Remember key values and entities during a user session for relevant follow-up queries, enhancing the continuity and relevance of interactions), Handling Complex Queries (Skillfully manage complex phrases and multiple data points within a single query, ensuring all relevant information is captured and processed). Your role is pivotal in streamlining data handling and improving the efficiency of interactions with the ERP system. Aim for precision and contextual understanding in all data extraction tasks. It is very important for us that you do it perfectly and that you do not make up or change values.
Analyze the below messages and answer only with a json object with the key "%param-id%".
The [value] of "%param-id%" must be %param-desc%.
Only use a value if the user is clear and you are sure of the user's intent, otherwise use the [value] "unknown"

### Conversation:

%user-conversation%

### Instruction:
1. Answer with a json object in the format {"%param-id%":"[value]"}
2. Remember to use the [value] "unknown" if it is not clear what the user wants
3. Do not make things up
4. Only provide the JSON object

### JSON result:
    */
    
    message = message & "### Instruction:" & NL;
    message = message & "You are a helpful AI called Anna" & NL;
    message = message & "Analyze the below messages and answer only with a json object with the key ""%param-id%""." & NL;
    message = message & "The [value] of ""%param-id%"" must be %param-desc%." & NL;
    message = message & "Only use a value if the user is clear and you are sure of the user's intent, otherwise use the [value] ""unknown""" & NL & NL;
    message = message & "### Conversation:" & NL & NL;
    message = message & "%user-conversation%" & NL & NL;
    message = message & "### Instruction:" & NL;
    message = message & "1. Answer with a json object in the format {""%param-id%"":""[value]""}" & NL;
    message = message & "2. Remember to use the [value] ""unknown"" if it is not clear what the user wants" & NL;
    message = message & "3. Do not make things up" & NL;
    message = message & "4. Only provide the JSON object" & NL & NL;
    message = message & "### JSON result:" & NL & NL;
  end;
  
  message =  ReplaceStringWithString(message,"%param-id%",paramid);
  message =  ReplaceStringWithString(message,"%param-desc%",paramdesc);
  message =  ReplaceStringWithString(message,"%user-conversation%",conversation);
    
  llama_json = LLM_Process(message);
  
  LLM_Close;
    
  debugtext = debugtext & "[[to LLM [ " & NL & message & NL & "]" & NL;
  debugtext = debugtext & "from LLM [ " & NL & llama_json & NL & "] ]]" & NL;

  Anna2Chat_DebugToWindow("Anna2Chat_LLMWClass",0,debugtext,A2Sb.LLMDebug,response);
  
  pos = InString(llama_json,"{");
  if (pos<0) then begin goto LNoJSON; end;
  llama_json = right(llama_json,len(llama_json) - pos + 1);
  
  pos = InString(llama_json,"}"); // should be last '}'
  if (pos<0) then begin goto LNoJSON; end;
  llama_json = left(llama_json,pos);
  
  //LogText(0,"LLAMA JSON " & llama_json);
  
  js = ParseJSONString(llama_json);
  res = JSONGetStrict(js,paramid);
  if (res=="") then begin
    res = JSONGetStrict(js,paramid & "/[0]");
  end;
  
LNoJSON:;
  FindParameterInLastMessages = res;
end;

function string 255 FindParameter(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,string paramid,string paramdesc,string chatmessage,var string response)
begin
  string 255 res;
  record Anna2ChatNodeVc Noder;

  Noder = nodestack[nodestack.length - 1];
  FindParameterInNode(Noder,paramid,res);
  if (res<>"") then begin goto LFindParameter_out; end;

  // ## find parameter in rest of node stack
  
  FindParameterInContext(Ctxr,paramid,res);
  if (res<>"") then begin goto LFindParameter_out; end;
  
  res = FindParameterInLastMessages(Ctxr,nodestack,paramid,paramdesc,response);
  if (res<>"") then begin
    goto LFindParameter_out;
  end;
  
LFindParameter_out:;
  if (res<>"") then begin
    Noder.TryCount = 1;
    nodestack[nodestack.length - 1] = Noder;
  end;
  FindParameter = res;
end;

function string 255 FindParameterStartingInMessage(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,string paramid,string paramdesc,string chatmessage,var string response)
begin
  string 255 res;
  record Anna2ChatNodeVc Noder;

  res = FindParameterInLastMessages(Ctxr,nodestack,paramid,paramdesc,response);
  if (res<>"") then begin goto LFindParameterStartingInMessage_out; end;
  
  Noder = nodestack[nodestack.length - 1];
  FindParameterInNode(Noder,paramid,res);
  if (res<>"") then begin goto LFindParameterStartingInMessage_out; end;

  // ## find parameter in rest of node stack
  
  FindParameterInContext(Ctxr,paramid,res);
  if (res<>"") then begin goto LFindParameterStartingInMessage_out; end;
  
LFindParameterStartingInMessage_out:;
  if (res<>"") then begin
    Noder.TryCount = 1;
    nodestack[nodestack.length - 1] = Noder;
  end;

  FindParameterStartingInMessage = res;
end;

function string 255 StoreParameter(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,string paramid,string paramval)
begin
  record Anna2ChatNodeVc Noder;

  Noder = nodestack[nodestack.length - 1];
  StoreParameterInNode(Noder,paramid,paramval);
  nodestack[nodestack.length - 1] = Noder;
end;

procedure DebugIntents(array record ScoredIntentVc Intents,string extra,var string response)
begin
  record ScoredIntentVc Intent;
  string 255 debugtext;
  LongInt i;
  record Anna2SettingsBlock A2Sb;
  
  BlockLoad(A2Sb);

  debugtext = debugtext & NL & "[[ ";
  debugtext = debugtext & extra & ": [" & NL;
  for (i = 0; i<Intents.length; i = i + 1) begin
    Intent = Intents[i];
    debugtext = debugtext & Intent.Intent & " " & Intent.Score & " '" & Intent.ExampleString & "'" & NL;
  end;
  debugtext = debugtext & "] ]]" & NL;
  
  Anna2Chat_DebugToWindow("Anna2Chat_ScoresWClass",0,debugtext,A2Sb.IntentDebug,response);
end;

function Boolean IntentIsCorrect(var record Anna2ContextVc Ctxr,var string chatmessage,record ScoredIntentVc SIr,var vector string validv,var string response)
begin
  Boolean res;
  string 255 sres;
  string 255 instruction;
  string 255 chattext,llama_json,message;
  row Anna2ContextVc Ctxrw;
  LongInt pos,rwcnt,rwn;
  json js;
  string 255 logged_chatmessage;
  record TalkBotIntentVc TBIr;
  string 255 debugtext;
  record Anna2SettingsBlock A2Sb;
  
  BlockLoad(A2Sb);

  TBIr.Code = SIr.Intent;
  if (ReadFirstKey("Code",TBIr,1,false)==false) then begin
    LogText(0,"ANNA2: Warning, intent " & SIr.Intent & " not found");
  end;
  
  if (A2Sb.AnnaDebugLog<>0) then begin
    LogText(0,"ANNA2: intent " & TBIr.Code & " found");
  end;
  
  if ((TBIr.Code<>SIr.Intent) or (TBIr.IntentLLMDescription=="")) then begin
    res = true;
    LogText(0,"ANNA2: Warning, intent " & SIr.Intent & " has no LLM description");
    goto LIntentIsCorrect_out;
  end;
  
  if (validv[SIr.Intent]<>"") then begin
    sres = validv[SIr.Intent];
    goto LIntentIsCorrect_gotstring;
  end;
  
  // ## only run LLM_Init once and store LLM-key in context
  instruction = "";
  
  LLM_Init(LlamaModel,instruction,"grammar-json.gbnf");

  message = ReadFileToString("LLM_IntentIsCorrect.txt");
  
  if (message=="") then begin
    message = message & "### Instruction" & NL;
    message = message & "You are a helpful AI called Anna" & NL;
    message = message & "Analyze the below message and answer with a json object with the key ""%intent-code%""." & NL;
    message = message & "The value of ""%intent-code%"" must be true if [user] wants to ""%intent-llm-description%""." & NL;
    message = message & "and false if [user] wants to perform some other action." & NL & NL;
    message = message & "### Message" & NL & NL;
    message = message & "%user-message%" & NL & NL;
    message = message & "### Instruction" & NL;
    message = message & "1. Answer with a json object in the format {""%intent-code%"":""[value]""}" & NL;
    message = message & "2. [value] must be true or false" & NL;
    message = message & "3. Provide a JSON object" & NL & NL;
    message = message & "### JSON Result" & NL & NL;
  end;
  
  message =  ReplaceStringWithString(message,"%intent-code%",SIr.Intent);
  message =  ReplaceStringWithString(message,"%intent-llm-description%",TBIr.IntentLLMDescription);
  message =  ReplaceStringWithString(message,"%user-message%",chatmessage);

  llama_json = LLM_Process(message);
  
  LLM_Close;
  
  debugtext = debugtext & "[[to LLM [ " & NL & message & NL & "]" & NL;
  debugtext = debugtext & "from LLM [ " & NL & llama_json & NL & "] ]]" & NL;
  Anna2Chat_DebugToWindow("Anna2Chat_LLMWClass",0,debugtext,A2Sb.LLMDebug,response);

  pos = InString(llama_json,"{");
  if (pos<0) then begin goto LIntentIsCorrect_out; end;
  llama_json = right(llama_json,len(llama_json) - pos + 1);
  
  pos = InString(llama_json,"}"); // should be last '}'
  if (pos<0) then begin goto LIntentIsCorrect_out; end;
  llama_json = left(llama_json,pos);
  
  //LogText(0,"LLAMA JSON " & llama_json);
  
  js = ParseJSONString(llama_json);
  sres = JSONGetStrict(js,SIr.Intent);
  if (sres=="") then begin
    sres = JSONGetStrict(js,SIr.Intent & "/[0]");
  end;
  
LIntentIsCorrect_gotstring:;

  if (sres=="true") then begin
    res = true;
    validv[SIr.Intent] = "true";
  end else begin
    validv[SIr.Intent] = "false";
  end;
  
LIntentIsCorrect_out:;
  IntentIsCorrect = res;
end;

procedure Anna2Chat_SystemError(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string response)
begin
  response = response & "It is not possible to perform this action at the moment, returning to the main menu";
  while (nodestack.length>1) begin
    PopNode(nodestack);
  end;
  Ctxr.Status = "waiting";
end;

function real IntentCutoffLimit()
begin
  IntentCutoffLimit = 0.8;
end;

procedure A2CProc_Menu(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response)
begin
  record Anna2ChatNodeVc Noder,nextNoder;
  string 255 childkey;
  array record ScoredIntentVc SIntents1;
  array record ScoredIntentVc SIntents2;
  record ScoredIntentVc Intent;
  vector Boolean ValidIntents;
  vector LongInt IntentToNode;
  string 255 paramvalue;
  LongInt intentcnt,i;
  vector string 255 validv;
  record Anna2SettingsBlock A2Sb;
  
  BlockLoad(A2Sb);

  if (chatmessage=="" or chatmessage=="%HELLO%") then begin
    Ctxr.Status = "waiting";
    goto LA2CProc_Menu_out;
  end;

  Noder = nodestack[nodestack.length - 1];

  childkey = "MainKey:" & Noder.SerNr;
  intentcnt = 0;
  while (LoopKey(childkey,nextNoder,1,true)) begin
    if (nextNoder.Intent<>"") then begin
      ValidIntents[nextNoder.Intent] = true;
      IntentToNode[nextNoder.Intent] = nextNoder.SerNr;
      intentcnt = intentcnt + 1;
    end;
  end;

  Anna2Chat_DebugToWindow("Anna2Chat_ScoresWClass",0,"[[scoring " & intentcnt & " intents at node " & Noder.SerNr & "]]",A2Sb.IntentDebug,response);
  
  AI_ScoreIntents(chatmessage,ValidIntents,SIntents1);

  DebugIntents(SIntents1,"After 1st scoring",response);

  for (i = 0; i<SIntents1.length; i = i + 1) begin
    Intent = SIntents1[i];

    if (Intent.Score>IntentCutoffLimit) then begin
      if (IntentIsCorrect(Ctxr,chatmessage,SIntents1[i],validv,response)) then begin
        SIntents2[SIntents2.length] = SIntents1[i];
      end;
    end;
  end;

  DebugIntents(SIntents2,"After 2nd scoring",response);

  Intent = SIntents2[0];

  if (Intent.Score>IntentCutoffLimit) then begin
    PushNodeCode(nodestack,IntentToNode[Intent.Intent]);
    Ctxr.Status = "processing";
  end else begin
    response = response & "I am sorry, I don't know how to do that, can I help you with something else?";
    Ctxr.Status = "waiting";
  end;

LA2CProc_Menu_out:;
end;

procedure A2CProc_Answer(var record Anna2ContextVc Ctxr,var array record Anna2ChatNodeVc nodestack,var string chatmessage,var string response,Boolean randomf)
begin
  record Anna2ChatNodeVc Noder;
  row Anna2ChatNodeVc Noderw;
  LongInt rwn,rwcnt,nanswers,answerid;
  
  nanswers = 0;
  
  Noder = nodestack[nodestack.length - 1];
  rwcnt = MatRowCnt(Noder);
  
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(Noder,rwn,Noderw);
    if (Noderw.ParameterID=="answer") then begin
      nanswers = nanswers + 1;
    end;
  end;
  
  if (nanswers>0) then begin
    if (randomf) then begin
      answerid = Random(0,nanswers - 1);
      nanswers = 0;
    end;
    
    for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
      MatRowGet(Noder,rwn,Noderw);
      if (Noderw.ParameterID=="answer") then begin
        if (randomf) then begin
          if (answerid==nanswers) then begin
            response = response & Noderw.ParameterQuestion;
            goto LA2CProc_Answer_out;
          end;
          nanswers = nanswers + 1;
        end else begin
          response = response & Noderw.ParameterQuestion & " ";
        end;
      end;
    end;
  end;
  
LA2CProc_Answer_out:;
  response = Trim(response);
  PopNode(nodestack);
  Ctxr.Status = "waiting";
end;
    
procedure FindCustomerFromOrder(string ornr,var string cucode)
begin
  record ORVc ORr;
  
  ORr.SerNr = ornr;
  if (ReadFirstMain(ORr,1,true)) then begin
    cucode = ORr.CustCode;
  end;
end;

procedure FindOrderFromCustomer(string cucode,var string ornr)
begin
  record CUVc CUr;
  record ORVc ORr;

  CUr.Code = cucode;
  if (ReadFirstMain(CUr,1,true)) then begin
    ORr.CustCode = CUr.Code;
    while (LoopBackKey("CustCode",ORr,1,true)) begin
      if (ORr.CustCode<>CUr.Code) then begin
        goto LFindOrderFromCustomer_out;
      end;
      if (ORr.Closed==0 and ORr.InvFlag==0 and ORr.ShipFlag==0) then begin
        ornr = ORr.SerNr;
        goto LFindOrderFromCustomer_out;
      end;
    end;
  end;
LFindOrderFromCustomer_out:;
end;

procedure FindCustomerFromQuotation(string qtnr,var string cucode)
begin
  record QTVc QTr;
  
  QTr.SerNr = qtnr;
  if (ReadFirstMain(QTr,1,true)) then begin
    cucode = QTr.CustCode;
  end;
end;

procedure FindQuotationFromCustomer(string cucode,var string qtnr)
begin
  record CUVc CUr;
  record QTVc QTr;

  CUr.Code = cucode;
  if (ReadFirstMain(CUr,1,true)) then begin
    QTr.CustCode = CUr.Code;
    while (LoopBackKey("CustCode",QTr,1,true)) begin
      if (QTr.CustCode<>CUr.Code) then begin
        goto LFindQuotationFromCustomer_out;
      end;
      if (QTr.Closed==0 /*and QTr.InvFlag==0 and QTr.ShipFlag==0*/) then begin
        qtnr = QTr.SerNr;
        goto LFindQuotationFromCustomer_out;
      end;
    end;
  end;
LFindQuotationFromCustomer_out:;
end;

procedure FindCustomerFromInvoice(string ivnr,var string cucode)
begin
  record IVVc IVr;
  
  IVr.SerNr = ivnr;
  if (ReadFirstMain(IVr,1,true)) then begin
    cucode = IVr.CustCode;
  end;
end;

procedure FindInvoiceFromCustomer(string cucode,var string ivnr)
begin
  record CUVc CUr;
  record IVVc IVr;

  CUr.Code = cucode;
  if (ReadFirstMain(CUr,1,true)) then begin
    IVr.CustCode = CUr.Code;
    while (LoopBackKey("CustCode",IVr,1,true)) begin
      if (IVr.CustCode<>CUr.Code) then begin
        goto LFindInvoiceFromCustomer_out;
      end;
      if (true /*IVr.Closed==0 and IVr.InvFlag==0 and IVr.ShipFlag==0*/) then begin
        ivnr = IVr.SerNr;
