procedure AddInCurtoTBIVwithRate(var record TBIVVc TBIVr,string crncy,val fr,val to1,val to2,val br1,val br2)
begin
  val t;

  if (nonblank(TBIVr.CurncyCode)) then begin
  end else begin
    CalcInCurtoTBIV(TBIVr);
  end;
  return;
end;

global
updating procedure ServerMakeActEndedPhoneCall(string cucode,string person,string callerid,string user,LongInt oldAct)
begin
end;

global
updating procedure ServerMakeActEndedPhoneCall3(string cucode,string person,string callerid,string user,LongInt oldAct,Integer oldCompno,string nr1,string nr2,Boolean missedf,string queue)
begin
  record CUVc CUr;
  Boolean res;
  Integer oldcomp,queuecompany;
  record GlobalCRMBlock GCRMb;
  record ActVc Actr;
  record ASTBlock ASTb;
  record ContactRelVc ContactRelr;
  record PBXQueueVc PBXQr;
  record ActVc Act2r;
  string 255 queuename;
  string 255 queuecode;
  Integer tmp;

  LogText(0,"DEBUG ServerMakeActEndedPhoneCall3 1 cucode=" & cucode & ", person=" & person & ", callerid=" & callerid & ", user=" & user & ", oldAct=" & oldAct & ", oldCompno=" & oldCompno & ", nr1=" & nr1 & ", nr2=" & nr2 & ", missedf=" & missedf & ", queue=" & queue);
  
  ServerMakeActEndedPhoneCall(cucode,person,callerid,user,oldAct); //For halcust backward compatibility

  oldcomp = CurrentCompany;

  if (missedf and oldAct==-1) then begin
    if (blank(callerid) and blank(nr1) and blank(nr2)) then begin
      goto LServerMakeActEndedPhoneCall3;
    end;
    BlockLoad(GCRMb);
    queuename = queue;
    if (queue!="") then begin
      queuecode = right(queue,len(queue)-len("HWQUEUE"));
      PBXQr.Code = queuecode;
      if (ReadFirstMain(PBXQr,1,true)) then begin
        queuecompany = StringToLongInt(PBXQr.CRMCompany);
        queuename = PBXQr.Code;
      end;
    end;
    if (queue!="" and queuecompany>0) then begin
      SetCompany(queuecompany,false);
    end else begin
      if (nonblank(GCRMb.MainCRMCompany)) then begin
        SetCompanyCode(GCRMb.MainCRMCompany,false);
      end;
    end;
    BlockLoad(ASTb);
    GetUserDefActTypes(CurrentUser,"MissedAsteriskCalls",ASTb.MissedAsteriskCalls,tmp,ASTb.MissedAsteriskCallsDone);
    GetUserDefActTypes(CurrentUser,"ServerMissedAsteriskCalls",ASTb.ServerMissedAsteriskCalls,tmp,ASTb.ServerMissedAsteriskCallsDone);
    RecordNew(Actr);
    ActVcRecordDefServer(Actr);
    Actr.SerNr = -1;
    Actr.Invalid = 0;
    Actr.TodoFlag = 1;
    Actr.SymbNr = kActivitySymbolCall;
    Actr.CUCode = cucode;
    Actr.Comment = "";
    CUr.Code = cucode;
    if (ReadFirstMain(CUr,1,true)) then begin
      Actr.CUName = CUr.Name;
      Actr.Contact = CUr.Person;
      Actr.Phone = CUr.Phone;
      if ((CUr.CUType==0) and (CUr.VEType==0)) then begin
        ContactRelr.ContactCode = CUr.Code;
        if (ReadFirstKey("ActContactCode",ContactRelr,1,true)) then begin
          Actr.CUCode = ContactRelr.CustCode;
          Actr.CUName = ContactRelr.CustName;
          Actr.Contact = CUr.Name;
        end;
      end;
    end;
    if (person!="") then begin
      Actr.Contact = person;
    end;
    if (callerid!="") then begin
      Actr.Phone = callerid;
    end;
    if (Actr.Phone=="") then begin
      if (nonblank(nr1) and InString(nr1,"@")==0) then begin
        Actr.Phone = nr1;
      end else begin
        if (nonblank(nr2) and InString(nr2,"@")==0) then begin
          Actr.Phone = nr2;
        end;
      end;
    end;
    if (queuecode!="") then begin
      Actr.PBXQueues = queuecode;
    end;
    Actr.ActType = ASTb.MissedAsteriskCalls;
    Actr.OKFlag = ASTb.MissedAsteriskCallsDone;
    PasteActTypeInAct("",Actr);
    SetActTypeValues(Actr);
    Actr.MainPersons = user;
    Actr.CCPersons = "";
    Actr.AutoGenCallFlag = 1;
    if (nonblank(ASTb.ServerMissedAsteriskCalls)) then begin
      RecordNew(Act2r);
      RecordCopy(Act2r,Actr);
      Act2r.ActType = ASTb.ServerMissedAsteriskCalls;
      Act2r.OKFlag = ASTb.ServerMissedAsteriskCallsDone;
      PasteActTypeInAct("",Act2r);
      SetActTypeValues(Act2r);
      Act2r.SerNr = NextSerNr("ActVc",Act2r.TransDate,-1,false,"");
      LogText(0,"DEBUG ServerMakeActEndedPhoneCall3 2 Act2r.ActType=" & Act2r.ActType & ", ASTb.ServerMissedAsteriskCallsDone=" & ASTb.ServerMissedAsteriskCallsDone);
      RecordStore(Act2r,true);
    end;
    LogText(0,"DEBUG ServerMakeActEndedPhoneCall3 3 Actr.ActType=" & Actr.ActType & ", ASTb.MissedAsteriskCallsDone=" & ASTb.MissedAsteriskCallsDone);
    Actr.SerNr = NextSerNr("ActVc",Actr.TransDate,-1,false,"");
    RecordStore(Actr,false);
  end;
  
LServerMakeActEndedPhoneCall3:;
  ResetCompany(oldcomp);
  return;
end;

global
updating procedure ServerMakeActEndedPhoneCall2(string cucode,string person,string callerid,string user,LongInt oldAct,Integer oldCompno,string nr1,string nr2,Boolean missedf)
begin
  ServerMakeActEndedPhoneCall3(cucode,person,callerid,user,oldAct,oldCompno,nr1,nr2,missedf,"");
end;

//Kept for backward compatibility
global
updating function LongInt ServerOnPhoneCallConnected2(string cucode,string person,string callerid,string user,Integer comidtyp)
begin
  ServerOnPhoneCallConnected2 = -1;
  return;
end;

function Boolean ContactIsUser(string cucode,var string usercode,var Integer compno)
begin
  record UserVc USr;
  record GlobalUserVc GUSr;
  Boolean foundf,res;

  if (blank(cucode)) then begin goto LContactIsUser; end;
  
  foundf = true;
  GUSr.CustCode = cucode;
  while (LoopKey("CustCode",GUSr,1,foundf)) begin
    if (GUSr.CustCode!=cucode) then begin foundf = false; end;
    if (foundf) then begin
      if (GUSr.Closed==0) then begin
        res = true;
        usercode = GUSr.Code;
        compno = StringToInt(GUSr.MainCRMCompany);
        goto LContactIsUser;
      end;
    end;
  end;
  
  foundf = true;
  USr.CustCode = cucode;
  while (LoopKey("CustCode",USr,1,foundf)) begin
    if (USr.CustCode!=cucode) then begin foundf = false; end;
    if (foundf) then begin
      if (USr.Closed==0) then begin
        res = true;
        usercode = USr.Code;
        goto LContactIsUser;
      end;
    end;
  end;

LContactIsUser:;
  ContactIsUser = res;
  return;
end;

global
updating function Boolean CreateActivityForPhonecall(string pccode,string pbxcallid,Boolean cu_foundf,record CUVc CUr,string normcustphoneno,
                                                     var LongInt actsernr,var Integer actcompno)
begin
  Boolean res;
  record ActVc Actr;
  record PBXConnectionVc PCr;
  record GlobalCRMBlock GCRMb;
  record ASTBlock ASTb;
  record ContactRelVc ContactRelr;
  Integer old_compno,gcompno;
  string 255 dummystr,mainpersons;
  
  old_compno = CurrentCompany;
  
  PCr.Code = pccode;
  if (ReadFirstMain(PCr,1,true)==false) then begin
    goto LCreateActivityForPhonecall;
  end;
  
  if ((cu_foundf==false) or (actcompno==0)) then begin
    BlockLoad(GCRMb);
    if (nonblank(GCRMb.MainCRMCompany)) then begin
      SetServerCompanyCode(GCRMb.MainCRMCompany);
    end else begin
      LogText(0,"WARNING: Global CRM Settings>Main CRM Company is blank, activities for calls with unidentified contacts will be created in company 1");
      SetServerCompany(1);
    end;
  end else begin
    SetServerCompany(actcompno);
  end;
  
  actcompno = CurrentCompany;

  if (cu_foundf) then begin
    if (ContactIsUser(CUr.Code,mainpersons,gcompno)) then begin
      if (gcompno>0) then begin
        actcompno = gcompno;
        SetServerCompany(actcompno);
      end;
    end;
  end;

  RecordNew(Actr);
  ActVcRecordDefServer(Actr);
  Actr.SerNr = NextSerNr("ActVc",Actr.TransDate,-1,false,"");
  Actr.Invalid = 0;
  Actr.TodoFlag = 0;
  Actr.CalTimeFlag = 1;
  Actr.AutoGenCallFlag = 1;
  Actr.SymbNr = kActivitySymbolCall;
  Actr.Comment = "";
  Actr.PBXCallID = pbxcallid;
  Actr.PBXConnection = pccode;
  Actr.CUCode = CUr.Code;
  Actr.CUName = CUr.Name;
  Actr.Contact = CUr.Person;
  Actr.Phone = normcustphoneno;
  Actr.MainPersons = mainpersons;

  if ((CUr.CUType==0) and (CUr.VEType==0) and (CUr.EmployeeType==0)) then begin
    ContactRelr.ContactCode = CUr.Code;
    if (ReadFirstKey("ActContactCode",ContactRelr,1,true)) then begin
      Actr.CUCode = ContactRelr.CustCode;
      Actr.CUName = ContactRelr.CustName;
      Actr.Contact = CUr.Name;
    end;
  end;
  
  if (IsAsteriskPBXType(PCr.PBXType)) then begin
    BlockLoad(ASTb);
    Actr.ActType = ASTb.AsteriskCalls;
    PasteActTypeInAct("",Actr);
    SetActTypeValues(Actr);
  end;
  
  actsernr = Actr.SerNr;
  RecordStore(Actr,false);

  ResetCompany(old_compno);
  res = true;

LCreateActivityForPhonecall:;
  CreateActivityForPhonecall = res;
  return;
end;

