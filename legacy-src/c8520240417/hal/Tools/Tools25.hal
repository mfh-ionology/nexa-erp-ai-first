global
function Boolean ResolveReportingPeriod(record ReportingPeriodVc RPr,var date fromdate,var date todate,var Boolean dynf)
begin
  date cd;
  
  cd = CurrentDate;
  dynf = false;
  
  if (RPr.Start_Year_Fixed==-1) then begin
    fromdate.year = cd.year + RPr.Start_Year_Delta;
    dynf = true;
  end else begin
    fromdate.year = RPr.Start_Year_Fixed;
  end;
  
  if (RPr.Start_Month_Fixed==-1) then begin
    fromdate.month = cd.month;
    fromdate = AddMonth(fromdate,RPr.Start_Month_Delta);
    dynf = true;
  end else begin
    fromdate.month = RPr.Start_Month_Fixed;
  end;
  
  if (RPr.Start_Day_Fixed==-1) then begin
    fromdate.day = cd.day;
    fromdate = AddDay(fromdate,RPr.Start_Day_Delta);
    dynf = true;
  end else begin
    fromdate.day = RPr.Start_Day_Fixed;
  end;

  if (RPr.End_Year_Fixed==-1) then begin
    todate.year = cd.year + RPr.End_Year_Delta;
    dynf = true;
  end else begin
    todate.year = RPr.End_Year_Fixed;
  end;
  
  if (RPr.End_Month_Fixed==-1) then begin
    todate.month = cd.month;
    todate = AddMonth(todate,RPr.End_Month_Delta);
    dynf = true;
  end else begin
    todate.month = RPr.End_Month_Fixed;
  end;
  
  if (RPr.End_Day_Fixed==-1) then begin
    todate.day = cd.day;
    todate = AddDay(todate,RPr.End_Day_Delta);
    dynf = true;
  end else begin
    todate.day = RPr.End_Day_Fixed;
  end;

  if (fromdate.day>DaysInMonth(fromdate.year,fromdate.month)) then begin fromdate.day = DaysInMonth(fromdate.year,fromdate.month); end;
  if (todate.day>DaysInMonth(todate.year,todate.month)) then begin todate.day = DaysInMonth(todate.year,todate.month); end;

  ResolveReportingPeriod = true;
end;

