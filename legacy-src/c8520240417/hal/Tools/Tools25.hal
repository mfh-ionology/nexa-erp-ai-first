global
function string 2 GetISO2code(string CountryCode)
begin
  string 2 res;
  record CountryVc Countryr;
  
  Countryr.Code = CountryCode;
  if (ReadFirstMain(Countryr,1,true)) then begin
    if (len(Countryr.ISOCode)==2) then begin
      res = Countryr.ISOCode;
    end else begin
      if (len(Countryr.Code)==2) then begin
        res = Countryr.Code;
      end;
    end;
  end;

  GetISO2code = res;
  return;
end;

global
function string 3 GetISO3code(string CountryCode)
begin
  string 3 res;
  record CountryVc Countryr;
  
  Countryr.Code = CountryCode;
  if (ReadFirstMain(Countryr,1,true)) then begin
    if (len(Countryr.ISO3Code)==3) then begin
      res = Countryr.ISO3Code;
    end else begin
      if (len(Countryr.Code)==3) then begin
        res = Countryr.Code;
      end else begin
        if (len(Countryr.ISOCode)==3) then begin
          res = Countryr.ISOCode;
        end;
      end;
    end;
  end;

  GetISO3code = res;
  return;
end;

global
function string 255 GetCountryCodeByISOCode(string ISOCode)
begin
  string 255 res;
  record CountryVc Countryr;
  
  switch (len(ISOCode)) begin
    case 2:
      Countryr.ISOCode = ISOCode;
      if (ReadFirstKey("ISOCode",Countryr,1,true)) then begin
        res = Countryr.Code;
      end;
    case 3:
      Countryr.ISO3Code = ISOCode;
      if (ReadFirstKey("ISO3Code",Countryr,1,true)) then begin
        res = Countryr.Code;
      end;
  end;

  if (blank(res)) then begin
    Countryr.Code = ISOCode;
    if (ReadFirstMain(Countryr,1,true)) then begin
      res = Countryr.Code;
    end;
  end;

  GetCountryCodeByISOCode = res;
  return;
end;
