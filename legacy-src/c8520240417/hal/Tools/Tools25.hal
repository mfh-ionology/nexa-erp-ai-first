  if (TRp.IntYc==CheckYc) then begin
    OwnCheckr.SerNr = TRp.Number;
    if (ReadFirstMain(OwnCheckr,1,true)) then begin
      CUr.Code = OwnCheckr.VECode;
      if (ReadFirstMain(CUr,1,true)) then begin
        res = true;
      end;
    end;
  end;
  if (TRp.IntYc==Check2Yc) then begin
