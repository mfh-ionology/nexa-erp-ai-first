global
updating procedure WorldlinePayOnResponse(string response)
begin
  json js;
  string 255 result,errorCondition,remark;
  string 255 pmcode,receiptcust,receiptmerch;
  val stramt;
  Integer wn,mwn,mmwn;
  record IVCashVc IVCashr,prevIVCashr;
  row IVCashVc IVCashrw;
  record DefCashBlock DefCashRec;
  record CCTSVc CCTSr,CCTS2r;
  area acustomer;
  Date dt;
  Time tm;

  // maybe we should use ProceedCCPayTouchScreenDClass...but might have to use transaction string for response...let's see
  
  wn = CurWindow;
  
  if (GetWindowClass(wn)<>"CCPayVerifoneProcessingWClass") then begin goto LWorldlinePayOnResponse; end;
  
  mwn = MotherWindow(wn);
  if (GetWindowClass(mwn)=="NPTSPaymentOneModeTClass") then begin
    mwn = MotherWindow(mwn);
  end;

  js = ParseJSONString(response);
  result = JSONGet(js,"result");

  //TODO implement actionCode
  switch (result) begin
    case "WPI_RESULT_FAILURE": WorldlinkPay_DisplayStatus(wn,JSONGet(js,"remark"));
    case "WPI_RESULT_SUCCESS": 
      stramt = StringToVal(JSONGet(js,"authorizedAmount"),M4Val)/100;

      CloseWindow(wn); //Close CC payment status window - only if actioncode not required

      BlockLoad(DefCashRec);
      if (blank(pmcode)) then begin
        pmcode =  DefCashRec.DefCCPayMode;
      end;
      switch (GetWindowClass(mwn)) begin
        case "NPTSIVCashDClass":
          switch (WindowState(mwn)) begin
            case Rs_update:
              GetPrevWindowRecord(mwn,prevIVCashr);
              if (prevIVCashr.OKFlag!=0) then begin
                CloseWindow(wn);
                goto LWorldlinePayOnResponse;
              end;
              if (prevIVCashr.Invalid!=0) then begin
                CloseWindow(wn);
                goto LWorldlinePayOnResponse;
              end;
            case Rs_normal:
              GetWindowRecord(mwn,prevIVCashr);
              if (prevIVCashr.OKFlag!=0) then begin
                CloseWindow(wn);
                goto LWorldlinePayOnResponse;
              end;
              if (IVCashr.Invalid!=0) then begin
                CloseWindow(wn);
                goto LWorldlinePayOnResponse;
              end;
          end;
          GetWindowRecord(mwn,IVCashr);
          ClearRow(IVCashr,IVCashrw,kInvoiceRowTypeCreditCardPayment);
          IVCashrw.stp = kInvoiceRowTypeCreditCardPayment;
          IVCashrw.Sum = stramt;
          IVCashrw.PayMode = pmcode;
          IVCashrw.CurncyCode = JSONGet(js,"currency");
          IVCashrw.CCReceiptNr = JSONGet(js,"paymentSolutionReference");
          IVCashrw.CCTimestamp = JSONGet(js,"timestamp");
          MatRowPut(IVCashr,MatRowCnt(IVCashr),IVCashrw);
          POSAudit_LogIVCashVcRow(IVCashr,IVCashrw,kPOSEventTypeAddRow);
          IVCashSumup(IVCashr,true);
          PutWindowRecord(mwn,IVCashr);
          
          IVCashDClass_RefreshStringList(mwn,IVCashr);
          OpenCashDrawer_IVCashVc(IVCashr);
          if (IVCashPOSButtonAutoFinish(mwn)==kPOSButtonAutoFinishYes) then begin
            IVCashDClassTouchScreenFinishButton;
          end;
  
          RecordNew(CCTSr);
          TimestampToDateTime(JSONGet(js,"timestamp"),dt,tm);
          CCTSr.TransDate = dt;
          CCTSr.TransTime = tm;
          CCTSr.SlipType = "CUSTOMER";
          CCTSr.LocalMachineCode = CurMachineName;
          CCTSr.Comment = "Purchase: " & JSONGet(js,"paymentSolutionReference");
          CCTSr.FileName = "IVCashVc";
          CCTSr.TransNr = IVCashr.SerNr;

          receiptcust = JSONGet(js,"formattedReceipt/client");
          ReplaceStringWithString(receiptcust,"\\n","chr(13) & chr(10)");
          AddTextToArea(receiptcust,acustomer);
          AddAreaToTextField(acustomer,CCTSr);
          CCTSr.SerNr = NextSerNr("CCTSVc",CCTSr.TransDate,-1,false,"");
          if (RecordStore(CCTSr,false)) then begin end;

          RecordNew(CCTS2r);
          TimestampToDateTime(JSONGet(js,"timestamp"),dt,tm);
          CCTS2r.TransDate = dt;
          CCTS2r.TransTime = tm;
          CCTS2r.SlipType = "MERCHANT";
          CCTS2r.LocalMachineCode = CurMachineName;
          CCTS2r.Comment = "Purchase: " & JSONGet(js,"paymentSolutionReference");
          CCTS2r.FileName = "IVCashVc";
          CCTS2r.TransNr = IVCashr.SerNr;

          receiptcust = JSONGet(js,"formattedReceipt/merchant");
          ReplaceStringWithString(receiptcust,"\\n","chr(13) & chr(10)");
          AddTextToArea(receiptcust,acustomer);
          AddAreaToTextField(acustomer,CCTS2r);
          CCTS2r.SerNr = NextSerNr("CCTSVc",CCTS2r.TransDate,-1,false,"");
          if (RecordStore(CCTS2r,false)) then begin end;
      end;
  end;
LWorldlinePayOnResponse:;
  return;
end;
