external procedure OpenCashDrawer_IVCashVc(record IVCashVc);
external updating procedure IVCashDClassTouchScreenFinishButton();
remote function Integer IVCashPOSButtonAutoFinish(Integer);

procedure TimestampToDateTime(string timestamp,var Date dt,var Time tm)
begin

  dt.year  = StringToInt(Left(timestamp,4));
  dt.month = StringToInt(Mid(timestamp,5,2));
  dt.day   = StringToInt(Mid(timestamp,8,2));

  tm.hour = StringToInt(Mid(timestamp,11,2));
  tm.minute = StringToInt(Mid(timestamp,15,2));
  tm.second = StringToInt(Mid(timestamp,17,2));

  return;
end;

procedure WorldlinkPay_DisplayStatus(Integer ProcessingWn,string errstr)
begin
  record RcVc RepSpec;

  if (nonblank(GetWindowClass(ProcessingWn))) then begin
    GetWindowRecord(ProcessingWn,RepSpec);
    PutWindowString(ProcessingWn,"Status",errstr);        
    PutWindowRecord(ProcessingWn,RepSpec);
  end;
  return;
end;

procedure BuildWorldlineToMJSONRequest(var string jsr,LongInt refnr,string curncycode,val sum)
begin

  JSONStringStart(jsr);
  JSONStringAdd(jsr,"currency",curncycode);
  JSONNotStringAdd(jsr,"requestedAmount",ValToString(sum,M4Val,"","",0));
  JSONStringPut(jsr,"reference",refnr);
  JSONStringEnd(jsr);

  return;
end;

global
updating procedure WorldlineToMCreditCard_Purchase(LongInt refnr,string curncycode,val sum,Integer ProcessingWn)
begin
  record LocalMachineBlock LMb;  
  record LSerialPortDeviceVc LSPDr;
  string 255 jsr;
  json jsonreply,js;
  string 255 host,CtrlSeq,tstr;
  LongInt socket,receiptsocket,port,receiptport,pos,messagesocket,messageport,errorcode;

  errorcode = 27427;
  PutWindowString(ProcessingWn,"ProcessingFinished","false");

  BlockLoad(LMb);
  if (FindLocalSerialPortDevice(kSerialPortDeviceClassCreditCardTerminal,kSerialPortDeviceModelWorldlineToM,LMb.LocalMachineCode,LSPDr)==false) then begin  
    goto LWorldlineToMCreditCard_Purchase;
  end;

  BuildWorldlineToMJSONRequest(jsr,refnr,curncycode,sum);
  js = ParseJSONString(jsr);
  WorldlinePay(js,kWorldline_Pay,jsonreply,ProcessingWn);
  
  errorcode = 0;
LWorldlineToMCreditCard_Purchase:;
  if (errorcode<>0) then begin
    TCPIPWorldPay_DisplayStatus(ProcessingWn,errorcode);
  end;

  PutWindowString(ProcessingWn,"ProcessingFinished","true");

  return;
end;  

