//  newstate = FindMatchingOrderClass(RepSpec,ORr.OrderClass,fromcol,tocol);
  
  if (nonblank(newstate)) then begin
    RecordCopy(oldActr,Actr);
    Actr.ActState = newstate;
    RecordUpdate(oldActr,Actr,true);
  end;
  
LColumnGridDraggedProjectActivity:;
end;

global
updating procedure ColumnGridDraggedMail(integer comp,record RcVc RepSpec,record MailVc Mailr,LongInt fromcol,LongInt tocol)
begin
  record MailVc oldMailr;
  row MailVc Mailrw;
  integer i,rwcnt;
  string 255 newconference,oldconference,newconfname,oldconfname;
  record ConfVc Confr;
  string 20 fromlevel,tolevel;
  boolean mailupdated;

  if (ReadFirstMain(Mailr,0,true)==false) then begin
    Beep;
    goto LColumnGridDraggedMail;
  end;
  newconference = FindMatchingConference(RepSpec,fromlevel,tolevel,oldconference,fromcol,tocol);
  if (oldconference==newconference) then begin
    Beep;
    goto LColumnGridDraggedMail;
  end;
  Confr.SerNr = oldconference;
  ReadFirstMain(Confr,1,true);
  if (blank(Confr.SerNr) or UserHasConfAccess(Confr.SerNr)==false) then begin
    Beep;
    goto LColumnGridDraggedMail;
  end;
  oldconfname = Confr.AddrName;
  RecordClear(Confr);
  Confr.SerNr = newconference;
  ReadFirstMain(Confr,1,true);
  newconfname = Confr.AddrName;
  if nonblank(newconfname) and nonblank(oldconfname) then begin
    RecordCopy(oldMailr,Mailr);
    rwcnt = MatRowCnt(Mailr);
    for (i = 0; i<rwcnt; i = i + 1) begin
      MatRowGet(Mailr,i,Mailrw);
      if (Mailrw.AddrCode==oldconfname) then begin
        Mailrw.AddrCode = newconfname;
        MatRowPut(Mailr,i,Mailrw);
        mailupdated = true;
      end;  
    end;  
    if (fromlevel!=tolevel) then begin
      Mailr.PrioLevel = tolevel;
      mailupdated = true;
    end;
    if mailupdated then begin
      RecordUpdate(oldMailr,Mailr,true);
    end;
  end else begin
    Beep;
  end;
  
  LColumnGridDraggedMail:;
end;
