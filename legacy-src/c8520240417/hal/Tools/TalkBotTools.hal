global
updating function string 255 AnnaCreateNewQuotation(string customercode)
begin
  record QTVc QTr;
  string 255 warning,errstr,res;
  Integer status_code,nwn;

  if (CreateBlankQTWSerial(QTr,customercode)==false) then begin
    status_code = 2; //Quotation could not be created
    goto LAnnaCreateNewQuotation_response;
  end;
  QTr.CustCode = customercode;
  PasteCustInQT(QTr,QTr.CustCode,"",warning,true);

  if (RecordStore(QTr,true)==false) then begin
    status_code = 3; //Quotation could not be saved
    goto LAnnaCreateNewQuotation_response;
  end;
/*
  //TODO check if users client is open then try to open window
  nwn = OpenWindow("QTDClass",1,0,"","",ORr);
*/
