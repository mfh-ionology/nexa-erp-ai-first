function Integer TTSProvider()
begin
  record TTSSettingsBlock TTSb;
  
  BlockLoad(TTSb);
  
  TTSProvider = TTSb.Provider;
end;

updating
procedure AttachWorkspace(var area a_workspace,record WatsonAssistantWorkspaceVc WAWr)
begin
  record Attach2Vc AT2r;
  record RLinkVc RLr;
  Integer i;
  string 255 filename;

  filename = "workspace.json";

  i = 0;
  while (ReadRecordLink(WAWr,i,AT2r,RLr)) begin
    if (AT2r.FileName==filename) then begin
      RecordDelete(RLr);
      StepBack(RLr);
    end;
    i = i + 1;
  end;

  Delete_File("tmp/" & filename);
  WriteAreaToFile(a_workspace,"tmp/" & filename,0);
  RecordLinkFile("tmp/" & filename,0,WAWr,CurrentCompany);
  Delete_File("tmp/" & filename);

  return;
end;

function string 255 SayAsPhoneNumber(string phonestr)
begin
  string 255 res;

  if (TTSProvider==kTextToSpeechEngineGoogle) then begin
    res = "<say-as interpret-as='telephone'>"; // google:style='zero-as-zero' -- this makes it say 'zero' instead of 'oh'
  end else begin
    res = "<say-as interpret-as='vxml:phone'>";
  end;
  
  res = res & phonestr;
  res = res & "</say-as>";

  SayAsPhoneNumber = res;
  return;
end;

function string 255 SayAsTime(string instr)
begin
  string 255 res;

  if (TTSProvider==kTextToSpeechEngineGoogle) then begin
    res = "<say-as interpret-as='time'>";
  end else begin
    res = "<say-as interpret-as='vxml:time'>";
  end;

  res = res & instr;
  res = res & "</say-as>";

  SayAsTime = res;
  return;
end;

global
function string 255 SayValAsCurrency(val inval,string currency_code)
begin
  string 255 res;
  
  if (TTSProvider==kTextToSpeechEngineGoogle) then begin
    res = "<say-as interpret-as='currency'>";
  end else begin;
    res = "<say-as interpret-as='vxml:currency'>";
  end;
  
  res = res & UpperCase(currency_code);
  res = res & ValToString(inval,M4Val,"",".",0);
  res = res & "</say-as>";

  SayValAsCurrency = res;
  return;
end;

global
function string 255 SayAsDate(date d)
begin
  string 255 res;
  
  //TODO add yesterday tomorrow
  if (CurrentDate==d) then begin
    res = "today";
  end else begin
  res = "<say-as interpret-as='date' format='mdy'>";
  res = res & DateToString(d,"MM/DD/YYYY");
  res = res & "</say-as>";
  end;

  SayAsDate = res;
  return;
end;

function string 255 SayAsDigits(string instr)
begin
  string 255 res;

  res = "<say-as interpret-as='digits'>";
  res = res & instr;
  res = res & "</say-as>";

  SayAsDigits = res;
end;

function string 255 SayValAsDigits(val inval)
begin
  string 255 res,tstr;

  tstr = Trim(ValToString(inval,M4Val,"",".",1));
  if (blank(tstr)) then begin tstr = "0"; end;
  res = SayAsDigits(tstr);

  SayValAsDigits = res;
  return;
end;

global
function string 255 SayNumberAsCardinal(string numberstr)
begin
  string 255 res;

  res = "<say-as interpret-as='cardinal'>";
  res = res & numberstr;
  res = res & "</say-as>";

  SayNumberAsCardinal = res;
end;

procedure GetIVStatus(record IVVc IVr,var integer stat,var val amount_due,var val amount_full)
begin
  record ARVc ARr;

  amount_due = blankval;
  amount_full = blankval;
  
  ARr.InvoiceNr = IVr.SerNr;
  
  if (IVr.OKFlag==0) then begin
    stat = 3;
    goto LGetIVStatus_out;
  end;
  
  amount_full = IVr.Sum4;
  
  if (ReadFirstMain(ARr,1,true)==false) then begin
    stat = 0;
    goto LGetIVStatus_out;
  end;
  
  if (ARr.DueDate>CurrentDate) then begin
    stat = 1;
  end else begin
    stat = 2;
  end;
  
  amount_due = ARr.RVal;

LGetIVStatus_out:;
end;

function string 255 FindCurrency(string currency_code)
begin
  string 255 res;
  record CurncyCodeVc CCr;

  CCr.CurncyCode = currency_code;
  if (ReadFirstMain(CCr,1,true)) then begin
    if (CCr.CurncyCode==currency_code) then begin
      res = CCr.CurText;
    end;
  end;

  FindCurrency = res;
  return;
end;

function Boolean FindInvoice(Longint invoiceno,string custcode,var Integer invstat,var val amount_due,var val amount_full,var string currency_code)
begin
  Boolean res;
  record IVVc IVr;

  IVr.SerNr = invoiceno;
  if (ReadFirstMain(IVr,1,true)) then begin
    if ((custcode=="") or (IVr.CustCode==custcode)) then begin
      res = true;
      GetIVStatus(IVr,invstat,amount_due,amount_full);
    end else begin
      invstat = 3;
    end;
    currency_code = IVr.CurncyCode;
  end;

  FindInvoice = res;
end;

global
function Boolean FindCustomerAndInvoice(string customer_code,Longint invoiceno,var Integer invstat,var val amount_due,var val amount_full,var string currency_code)
begin
  record CUVc CUr;
  Boolean res;
  
  if (customer_code<>"") then begin
    CUr.Code = customer_code;
    res = ReadFirstMain(CUr,1,true);
    if (res==false) then begin
      invstat = 4;
      goto LFindCustomerAndInvoice_out;
    end;
  end;
  
  res = FindInvoice(invoiceno,CUr.Code,invstat,amount_due,amount_full,currency_code);

LFindCustomerAndInvoice_out:;
  FindCustomerAndInvoice = res;
end;

