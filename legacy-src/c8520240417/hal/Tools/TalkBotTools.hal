global
function string 255 AnnaGetLastPayments(string customercode,string paycount)
begin
  Boolean foundf;
  string 255 res;
  Integer count,oldcomp;
  LongInt i;
  array date payment_date_arr;
  array val payment_amount_arr;
  array string 255 payment_currency_arr;
  date blankdateval;
  
  count = StringToInt(paycount);
  if (blank(count) or count<1 or count>6) then begin
    count = 6;
  end;

  oldcomp = CurrentCompany;
  SetCompany(1,false);
  FindLastPayments(customercode,count,blankdateval,payment_date_arr,payment_amount_arr,payment_currency_arr);
  ResetCompany(oldcomp);
  res = "{";
  res = res & "\"statusCode\": \"0\",";
  res = res & "\"count\": \"" & count & "\",";
  res = res & "\"responseText\": \"";
  for (i=0; i<payment_date_arr.length; i = i + 1) begin
    res = res & SayValAsCurrency(payment_amount_arr[i],payment_currency_arr[i]) & ", " & SayAsDate(payment_date_arr[i]);
    if (i<(payment_date_arr.length-1)) then begin
      res = res & "<break strength='medium'></break> ";
    end;
  end;
  res = res & "\"";
  res = res & "}";

  AnnaGetLastPayments = res;
  return;
end;

/* Expected delivery date */
global
function Boolean FindPlannedDeliveryDate(string customer_code,LongInt order_no,var date planed_delivery_date)
begin
  Boolean res;
  record ORVc ORr;
  record SHVc SHr;
  Integer cnt;

  ORr.SerNr = order_no;
  if (ReadFirstMain(ORr,1,true)==false) then begin
    goto LFindPlannedDeliveryDate;
  end;

  if (ORr.CustCode!=customer_code) then begin
    goto LFindPlannedDeliveryDate;
  end;

  planed_delivery_date = ORr.PlanShip;
  if (blank(planed_delivery_date)) then begin
    SHr.OrderNr = ORr.SerNr;
    if (ReadLastKey("OrderKey",SHr,1,true)==false) then begin
      goto LFindPlannedDeliveryDate;
    end;
    planed_delivery_date = SHr.ShipDate;
  end;

  res = true;

LFindPlannedDeliveryDate:;
  FindPlannedDeliveryDate = res;
end;

global
function string 255 AnnaGetPlannedDeliveryDate(string customercode,string ordernr)
begin
  Boolean foundf;
  string 255 res;
  Integer oldcomp;
  LongInt orderno;
  Boolean resf;
  Integer status_code;
  date planned_delivery_date;

  orderno = StringToLongInt(ordernr);

  if (orderno<=0) then begin
    status_code = 2; // Order no parse error
    goto LAnnaGetPlannedDeliveryDate_response;
  end;

  oldcomp = CurrentCompany;
  SetCompany(1,false);
  resf = FindPlannedDeliveryDate(customercode,orderno,planned_delivery_date);
  ResetCompany(oldcomp);

  if (resf==false) then begin
    status_code = 3; // Order not found
  end;

LAnnaGetPlannedDeliveryDate_response:;
  res = "{";
  if (status_code==0) then begin
    res = res & "\"plannedDeliveryDate\": \"" & SayAsDate(planned_delivery_date) & "\",";
  end;
  res = res & "\"statusCode\": \"" & status_code & "\"";
  res = res & "}";
  
  AnnaGetPlannedDeliveryDate = res;
  return;
end;

/* Orders not yet delivered */
procedure FindOrdersPendingDelivery(string customer_code,Integer count,var array LongInt order_no_arr,var array date order_date_arr)
begin
  Boolean res;
  record ORVc ORr;
  Boolean foundf,testf;
  Integer cnt,cnt_max;

  cnt_max = count;
  if (cnt_max==0) then begin cnt_max = 5; end;

  foundf = true;
  ORr.OSFlag = 1;
  ORr.CustCode = customer_code;

  while (LoopBackKey("OSCU",ORr,2,foundf)) begin
    if (ORr.OSFlag!=1) then begin foundf = false; end;
    if (ORr.CustCode!=customer_code) then begin foundf = false; end;
    if (cnt>(cnt_max-1)) then begin foundf = false; end;
    if (foundf) then begin
      testf = false;
      if ((ORr.ShipFlag==0) and (ORr.InvFlag<2 or ORr.InvBeforeShip==1)) then begin testf = true; end;
      if ((ORr.ShipFlag==0) and ((ORr.InvFlag==0) or (ORr.InvFlag==2))) then begin testf = true; end;
      if (testf) then begin
        order_no_arr[cnt] = ORr.SerNr;
        order_date_arr[cnt] = ORr.OrdDate;
        cnt = cnt + 1;
      end;
    end;
  end;

  return;
end;

global
function string 255 AnnaGetOrdersPendingDelivery(string customercode,string pdcount)
begin
  string 255 res;
  Integer oldcomp,status_code,count;
  array LongInt order_no_arr;
  array date order_date_arr;
  LongInt i;

  count = StringToInt(pdcount);
  if (blank(count) or count<1 or count>6) then begin
    count = 6;
  end;

  oldcomp = CurrentCompany;
  SetCompany(1,false);
  FindOrdersPendingDelivery(customercode,count,order_no_arr,order_date_arr);
  ResetCompany(oldcomp);
  if (order_no_arr.length==0) then begin
    status_code = 2; // No orders found
  end;

LAnnaGetOrdersPendingDelivery_response:;
  res = "{";
  if (status_code==0) then begin
    res = res & "\"responseText\": \"";
    for (i = 0; i<order_no_arr.length; i = i + 1) begin
      res = res & "order " & SayNumberAsCardinal(order_no_arr[i]) & ", " & SayAsDate(order_date_arr[i]);
      if (i<(order_no_arr.length-1)) then begin
        res = res & ", <break strength='medium'></break>";
      end;
    end;
    res = res & "\",";
  end;
  res = res & "\"statusCode\": \"" & status_code & "\"";
  res = res & "}";

  AnnaGetOrdersPendingDelivery = res;
  return;
end;

/* Stock level of item */
global
procedure FindStockLevelOfItem(string item_code,var val instock)
begin
  Boolean res;
  record ItemStatusVc ISr;

  FindStockValue(item_code,"",ISr);
  instock = ISr.Instock;

  return;
end;

global
function Boolean FindItemFromString_old(string item,var record INVc INr)
begin
  Boolean res;
  //get ArtCode from itemname

  INr.Code = item;
  if (ReadFirstKey("Code",INr,1,true)) then begin
    res = true;
    goto LFindItemFromString_old_out;
  end;

  INr.Name = item;
  if (ReadFirstKey("ActName",INr,1,true)) then begin
    res = true;
    goto LFindItemFromString_old_out;
  end;

  //try removing trailing "s" for miltiple items
  INr.Name = Left(item,(len(item)-1));
  if (ReadFirstKey("ActName",INr,1,true)) then begin
    res = true;
    goto LFindItemFromString_old_out;
  end;
  
  res = false;
  
LFindItemFromString_old_out:;
  LogText(0,"FindItemFromString_old item '" & item & "' -> Code '" & INr.Code & "'");
  FindItemFromString_old = res;
end;

global
function string 255 AnnaGetStockLevelOfItem(string customercode,string itemcode)
begin
  string 255 item_code,res,stock_levelstr;
  Integer oldcomp,status_code;
  val stock_level;
  record INVc INr;

  item_code = Trim(itemcode);
  if (blank(item_code)) then begin
    status_code = 2; // Item code blank
    goto LAnnaGetStockLevelOfItem_response;
  end;

  if (FindItemFromString_old(itemcode,INr)==false) then begin
    status_code = 3; // Item not found
    goto LAnnaGetStockLevelOfItem_response;
  end;

  oldcomp = CurrentCompany;
  SetCompany(1,false);
  FindStockLevelOfItem(item_code,stock_level);
  ResetCompany(oldcomp);
  stock_levelstr = Trim(ValToString(stock_level,M4Val,"",".",1));
  if (blank(stock_levelstr)) then begin stock_levelstr = "0"; end;

LAnnaGetStockLevelOfItem_response:;
  res = "{";
  if (status_code==0) then begin
    res = res & "\"stockLevel\": \"" & stock_levelstr & "\",";
  end;
  res = res & "\"statusCode\": \"" & status_code & "\"";
  res = res & "}";

  AnnaGetStockLevelOfItem = res;
  return;
end;

/* Identify caller */
function Boolean FindCustomerFromNormalizedPhoneNr(string normnum,var record CUVc CUr)
begin
  Boolean res;
  record NormPhoneNumVc NPNr;

  NPNr.NormNum = normnum;
  if (ReadFirstMain(NPNr,1,true)==true) then begin
    CUr.Code = NPNr.CustCode; // TODO: Company...
    if (ReadFirstMain(CUr,1,true)==true) then begin
      res = true;
    end;
  end;

  FindCustomerFromNormalizedPhoneNr = res;
  return;
end;

function Boolean FindCustomerFromCaller(string ident,var record CUVc CUr)
begin
  Integer status_code,compno;
  record PBXConnectionVc PBXr;
  Boolean foundf,res;

  if (FindCustomerFromNormalizedPhoneNr(ident,CUr)) then begin res = true; goto LFindCustomerFromCaller; end;
  foundf = true;
  PBXr.Closed = 0;
  while (LoopKey("Closed",PBXr,1,foundf)) begin
    if (PBXr.Closed!=0) then begin foundf = false; end;
    if (foundf) then begin
      res = FindCustomerFromNormalizedPhoneNr(ident & "@" & PBXr.PBXHost,CUr);
      if (res) then begin goto LFindCustomerFromCaller; end;
    end;
  end;
  if (FindCustomerFromNormalizedPhoneNr(NormalizePhoneNumber(ident),CUr)) then begin res = true; goto LFindCustomerFromCaller; end;
  if (FindCustomerFromNormalizedPhoneNr(NormalizePhoneNumber("+" & ident),CUr)) then begin res = true; goto LFindCustomerFromCaller; end;
  res = GetUserContactCard(ident,CUr,compno);

LFindCustomerFromCaller:;
  FindCustomerFromCaller = res;
  return;
end;

procedure SetChatBotContextUserInfo(string ctxkey,string compcode,record CUVc CUr)
begin

  if (nonblank(ctxkey)) then begin
    SetChatBotContextValue(ctxkey,"contactcode",CUr.Code);
    SetChatBotContextValue(ctxkey,"companycode",compcode);
    if (nonblank(CUr.SearchKey)) then begin
      SetChatBotContextValue(ctxkey,"shortcode",CUr.SearchKey);
    end;
  end;

  return;
end;

function string 255 AnnaIdentifyCaller(string ctxkey,string ident)
begin
  string 255 res;
  Integer oldcomp,status_code,i,rwcnt;
  record CUVc CUr;
  record CompaniesBlock Compb;
  row CompaniesBlock Comprw;

  status_code = 3;
  if (ident=="anonymous") then begin
    status_code = 4;
    goto LAnnaIdentifyCaller_response;
  end;
  if (blank(trim(ident))) then begin
    status_code = 2;
    goto LAnnaIdentifyCaller_response;
  end;
  
  oldcomp = CurrentCompany;
  BlockLoad(Compb);
  rwcnt = MatRowCnt(Compb);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(Compb,i,Comprw);
    if (SetCompanyCode(Comprw.CompCode,false)) then begin
      if (FindCustomerFromCaller(ident,CUr)) then begin
        SetChatBotContextUserInfo(ctxkey,Comprw.CompCode,CUr);
        status_code = 0;
        i = rwcnt;
      end;
    end;
  end;
  ResetCompany(oldcomp);
  
LAnnaIdentifyCaller_response:;
  LogText(0,"TalkBotTools.hal:AnnaIdentifyCaller() ident=" & ident & ", Normalized as=" & NormalizePhoneNumber("+" & ident) & ", CUr.Name=" & CUr.Name);
  res = "{";
  res = res & "\"customerPhone\": \"+" & SayAsPhoneNumber(ident) & "\",";
  if (status_code==0) then begin
    res = res & "\"customerName\": \"" & CUr.Name & "\",";
    res = res & "\"customerCode\": \"" & CUr.Code & "\",";
  end;
  res = res & "\"statusCode\": \"" & status_code & "\"";
  res = res & "}";
  
  AnnaIdentifyCaller = res;

  return;
end;

/* Identify employee */
function Boolean FindEmployeeURI(string contact_no,var string sip_uri)
begin
  Boolean res;
  record CUVc CUr;

  CUr.Code = contact_no;
  if (ReadFirstMain(CUr,1,true)==true) then begin
    res = true;
    if (nonblank(CUr.SIPCode)) then begin
      sip_uri = "sip:" & CUr.SIPCode;
      ReplaceStringWithString(sip_uri,"@","\\\\@");
      goto LFindEmployeeURI;
    end;
    if (nonblank(CUr.Mobile)) then begin
      sip_uri = "sip:" & CUr.Mobile & "\\\\@sip.us.hansaworld.com"; //TODO take from pbx connection
      goto LFindEmployeeURI;
    end;
    if (nonblank(CUr.AltPhone)) then begin
      sip_uri = "sip:" & CUr.AltPhone & "\\\\@sip.us.hansaworld.com"; //TODO take from pbx connection
      goto LFindEmployeeURI;
    end;
    if (nonblank(CUr.Phone)) then begin
      sip_uri = "sip:" & CUr.Phone & "\\\\@sip.us.hansaworld.com"; //TODO take from pbx connection
      goto LFindEmployeeURI;
    end;
    res = false;
  end;

LFindEmployeeURI:;
  FindEmployeeURI = res;
  return;
end;

function string 255 AnnaGetEmployeeTransferURI(string contactno)
begin
  string 255 contact_no,transfer_uri,res;
  Integer oldcomp,status_code;
  Boolean foundf;

  contact_no = Trim(contactno);
  if (blank(contact_no)) then begin
    status_code = 2; // Must have contact no
    goto LAnnaGetEmployeeTransferURI_response;
  end;

  oldcomp = CurrentCompany;
  SetCompany(1,false);
  foundf = FindEmployeeURI(contact_no,transfer_uri);
  ResetCompany(oldcomp);

  if (foundf==false) then begin
    status_code = 3; // Employee not identified
    goto LAnnaGetEmployeeTransferURI_response;
  end;

LAnnaGetEmployeeTransferURI_response:;
  res = "{";
  if (status_code==0) then begin
    res = res & "\"transferURI\": \"" & transfer_uri & "\",";
  end;
  res = res & "\"statusCode\": \"" & status_code & "\"";
  res = res & "}";

  AnnaGetEmployeeTransferURI = res;
  return;
end;

/* Open a report on the client if the contact is logged in */
function Integer OpenReportForContact(string contact_no,record RcVc RepSpec)
begin
  Integer res;
  record CUVc CUr;

  CUr.Code = contact_no;
  if (ReadFirstMain(CUr,1,true)==false) then begin
    LogText(0,"OpenReportForContact failed to find contact " & contact_no);
    goto LOpenReportForContact;
  end;

  res = RunReportFromClient(CUr,RepSpec);

LOpenReportForContact:;
  OpenReportForContact = res;
  return;
end;

global
updating function string 255 AnnaAddItemToOrder(string customercode,string item,string quantity)
begin
  record ORVc ORr;
  record ORVc oldORr;
  record INVc INr;
  row ORVc ORrw;
  integer rwcnt,status_code,wn;
  LongInt serial;
  string 255 inwarning,warning,res;
  record CUVc CUr;
  
  CUr.Code = customercode;
  if (customercode=="" or ReadFirstMain(CUr,1,true)==false) then begin
    status_code = 2; // Order not found -> should be customer not found
    goto LAnnaAddItemToOrder;
  end;
  
  //get last order serial
  if (CreateBlankOrderWSerial(ORr)==false) then begin
    status_code = 2; // Order not found
    goto LAnnaAddItemToOrder;
  end;
  
  serial = ORr.SerNr - 1;
  RecordClear(ORr);
  ORr.SerNr = serial;
  if (ReadFirstMain(ORr,1,true)==false) then begin
    status_code = 2; // Order not found
    goto LAnnaAddItemToOrder;
  end;
  
  if (ORr.CustCode<>CUr.Code) then begin
    status_code = 2; // Order not found -> should be customer not found
    goto LAnnaAddItemToOrder;
  end;

  if (FindItemFromString_old(item,INr)==false) then begin
    status_code = 3; // Item not found
    goto LAnnaAddItemToOrder;
  end;
  
  rwcnt = MatRowCnt(ORr);
  ORrw.ArtCode = INr.Code;
  ORrw.Quant = StringToVal(quantity,M4Val);
  MatRowPut(ORr,rwcnt,ORrw);
  recordCopy(oldORr,ORr);
  ORVc_PasteArtCode(ORr,rwcnt,inwarning,warning,false);
  if (RecordUpdate(oldORr,ORr,false)!=0) then begin
    status_code = 4; // Record update failed
    goto LAnnaAddItemToOrder;
  end;
/*
  //TODO check if user logged in?
  wn = FindWindow("ORDClass");
  if (wn>0) then begin
    PutWindowRecord(wn,ORr);
  end;
*/
LAnnaAddItemToOrder:;
LogText(0,"AnnaAddItemToOrder END status_code=" & status_code & ", wn=" & wn);
  res = "{";
  res = res & "\"statusCode\": \"" & status_code & "\"";
  res = res & "}";

  AnnaAddItemToOrder = res;
  return;
end;

global
updating function string 255 AnnaCreateNewOrder(string customercode)
begin
  record ORVc ORr;
  string 255 warning,errstr,res;
  Integer status_code,nwn;

  if(CreateBlankOrderWSerial(ORr)==false) then begin
    status_code = 2; //order could not be created
    goto LAnnaCreateNewOrder_response;
  end;
  ORr.CustCode = customercode;
  PasteCustInOrder(ORr,ORr.CustCode,"",warning,errstr);
  if (RecordStore(ORr,true)==false) then begin
    status_code = 3; //order could not be saved
    goto LAnnaCreateNewOrder_response;
  end;
/*
  //TODO check if users client is open then try to open window
  nwn = OpenWindow("ORDClass",1,0,"","",ORr);
*/
LAnnaCreateNewOrder_response:;
  res = "{";
  res = res & "\"statusCode\": \"" & status_code & "\",";
  res = res & "\"orderNumber\": \"" & ORr.SerNr & "\"";
  res = res & "}";
  
  AnnaCreateNewOrder = res;
  return;
end;

