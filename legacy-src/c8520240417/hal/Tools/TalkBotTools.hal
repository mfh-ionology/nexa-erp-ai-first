global
procedure DTMFReceived(string dtmf,string conversationid)
begin
  //TODO add cbctx as parameter
  //TODO needs decision weather what we want to actually do with this, needs context. Transfer immidietly, play transfer options, other?
  
  //how bad is it speed wise if we have a get context (loop through gp->annacontencxt to find correct anna, then return its context).
  //can we be too smart for our good and have a hstring variable returned to hal that is the datapointer to that anna object?
  
  switch (0) begin
    case "contextTransfer":
    case "contextOther":
    otherwise
      UnexpectedDTMF(dtmf,conversationid);
  end;
  
  LogText(0,"DTMF received " & dtmf & " on conversation " & conversationid);

  return;
end;

global
procedure PhonecallToChatBot(string callid,string callerid,string calledext,string sipserveraddr,string text_in,var string text_out)
begin
  Boolean result;
  string 255 ctxkey,sanitized_text_in,reply,initstr;
  area a_context;
  record Anna2ContextVc Ctxr;
  array record Anna2ChatNodeVc nodestack;
  array string 255 roles,messages;
  Integer oldcomp;

  ctxkey = callid;
  
  switch (ActiveIntentEngine) begin
    case "Anna2":
      oldcomp = CurrentCompany;
      SetCompany(1,false);
      
      initstr = GetChatBotContextValue(ctxkey,"initstr");
      
      if (initstr<>"initialized") then begin
        LogText(0,"PhonecallToChatBot, initializing Anna2");
        
        AI_InitIntents;
        
        RecordNew(Ctxr);
        PushNodeCode(nodestack,Anna2StartNode);

        ChatBotContext_SetRecord(ctxkey,"A2Ctx",Ctxr);

        SetChatBotContextValue(ctxkey,"currentLanguage","en");

        SetChatBotContextValue(ctxkey,"initstr","initialized");
      end else begin
        Anna2_LoadCbctx(ctxkey,Ctxr,nodestack,roles,messages);
      end;
      
      text_out = Anna2Chat_Process(Ctxr,nodestack,text_in);
      
      LogText(0,"PhonecallToChatBot text_out " & text_out);
      
      Anna2_StoreCbctx(ctxkey,Ctxr,nodestack,roles,messages);
      
      ResetCompany(oldcomp);
    case "IBM":
      GetChatbotContextArea(ctxkey,"AssistantContext",a_context);
      if (GetAreaLength(a_context)==0) then begin
        AddTextToArea("{",a_context);
        AddTextToArea("\"context\": {",a_context);
        AddTextToArea("\"annaSIPCallerID\": \"" & callerid & "\",",a_context);
        AddTextToArea("\"annaSIPCalledExtension\": \"" & calledext & "\",",a_context);
        AddTextToArea("\"chatBotContextKey\": \"" & ctxkey & "\"",a_context);
        AddTextToArea("},",a_context);
        AddTextToArea("\"user_id\": \"HansaWorld\",",a_context);   //Billing: Customer number? contract number? phone number?
        AddTextToArea("\"input\": {",a_context);
        AddTextToArea("\"text\": \"" & text_in & "\"",a_context);
        AddTextToArea("}",a_context);
        AddTextToArea("}",a_context);
        SetChatbotContextArea(ctxkey,"AssistantContext",a_context);
      end;
      
      TalkBotReplaceText(ctxkey,text_in,sanitized_text_in,false);
      
      WatsonSendToChatBot(ctxkey,sanitized_text_in,reply);
//    case "botpress":
//      BotpressPhonecallToChatBot(sanitized_text_in,text_out,sessionID,"text");
  end;
  
  //TalkBotReplaceText(ctxkey,reply,text_out,true);
end;
