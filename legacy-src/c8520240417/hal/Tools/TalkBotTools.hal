global
function string 255 AnnaDisplayActivities(string ctxkey,json js)
begin
  record ActVc Actr;
  string 255 res,stat,keystr,shortcode,sdate;
  date ddate;
  integer cnt;
  boolean TrHs,foundf;
  
  shortcode = GetChatBotContextValue(ctxkey,"shortcode");
  if (blank(shortcode)) then begin
    res = "You do not have a shortcode setup, so I am unable to check your activities";
    goto LAnnaDisplayActivities;
  end;
  sdate = JSONGet(js,"actions/[0]/parameters/date");
  if (blank(sdate)) then begin
    ddate = CurrentDate;
  end else begin
    ddate = stringtodate(sdate);
  end;
  keystr = "DateUserMain:" & shortcode;
  Actr.CalTimeFlag = 1;
  Actr.TransDate = ddate;
  TrHs = true;
  cnt = 0;
  while (LoopKey(keystr,Actr,2,TrHs)) begin
    foundf = true;
    if (SetInSet(shortcode,Actr.MainPersons)==false) then begin TrHs = false; foundf = false; end;
    if (Actr.TodoFlag!=2 and Actr.TodoFlag!=0) then begin foundf = false; end;
    if (Actr.TransDate!=ddate) then begin TrHs = false; foundf = false; end;
    if (foundf) then begin
      res = res & Actr.Comment & " at " & SayAsTime(Left(Actr.StartTime,5));
      cnt = cnt + 1;
      if (cnt>10) then begin   //limit to 10 for now
        TrHs = false;
      end;
      if (cnt>0) then begin
        res = res & ", ";
      end;
    end;
  end;
  if (cnt>0) then begin
    res = "Here are your activities for " & SayAsDate(ddate) & ". " & res;
  end else begin
    res = "You have no activities for " & SayAsDate(ddate);
  end;
  
LAnnaDisplayActivities:;
  
  AnnaDisplayActivities = res;
  return;
end;

function string 255 AnnaJsonWrapResponseText(string text)
begin
  string 255 res;
  
  res = "{";
  res = res & "\"statusCode\": \"1\",";
  res = res & "\"text\": \"" & text & "\"";
  res = res & "}";
  
  AnnaJsonWrapResponseText = res;
  return;
end;

global
function string 255 DoLocalAnnaRequest(var json js,string action_name,LongInt action_idx)
begin
  string 255 server,path,res,param1,param2,param3,conversationid,ctxkey,compcode;
  Boolean phonef;
  Integer oldcomp;
  
  conversationid = JSONGet(js,"context/conversation_id");
  if (IsConversationThroughPhonecall(conversationid)) then begin
    phonef = true;
    oldcomp = CurrentCompany;
    compcode = GetChatBotContextValue(ctxkey,"companycode");
    SetCompanyCode(compcode,false);
  end;
  ctxkey = JSONGet(js,"context/chatBotContextKey");
  
  switch (action_name) begin
    case "IdentifyCaller":
      if (JSONNodeExists(js,"context/annaSIPCallerID")) then begin
        param1 = JSONGet(js,"context/annaSIPCallerID");
      end;
      if (JSONNodeExists(js,"context/chatBotUserCode")) then begin
        param1 = JSONGet(js,"context/chatBotUserCode");
      end;
      res = AnnaIdentifyCaller(ctxkey,param1);
    case "GetEmployeeTransferURI":
      param1 = JSONGet(js,"actions/[" & action_idx & "]/parameters/contactno");
      res = AnnaGetEmployeeTransferURI(param1);
    case "AddItemToOrder":
      param1 = JSONGet(js,"context/caller_id/customerCode");
      param2 = URLEncode(JSONGet(js,"actions/[" & action_idx & "]/parameters/item"));
      param3 = URLEncode(JSONGet(js,"actions/[" & action_idx & "]/parameters/number"));
      res = qupdating.AnnaAddItemToOrder(param1,param2,param3);
    case "CheckInvoiceStatus":
      param1 = JSONGet(js,"context/caller_id/customerCode");
      param2 = JSONGet(js,"actions/[" & action_idx & "]/parameters/invoiceno");
      res = AnnaCheckInvoiceStatus(param1,param2);
    case "GetLastPayments":
      param1 = JSONGet(js,"context/caller_id/customerCode");
      param2 = JSONGet(js,"actions/[" & action_idx & "]/parameters/count");
      res = AnnaGetLastPayments(param1,param2);
    case "GetPlannedDeliveryDate":
      param1 = JSONGet(js,"context/caller_id/customerCode");
      param2 = JSONGet(js,"actions/[" & action_idx & "]/parameters/orderno");
      res = AnnaGetPlannedDeliveryDate(param1,param2);
    case "GetOrdersPendingDelivery":
      param1 = JSONGet(js,"context/caller_id/customerCode");
      param2 = JSONGet(js,"actions/[" & action_idx & "]/parameters/count");
      res = AnnaGetOrdersPendingDelivery(param1,param2);
    case "GetStockLevelOfItem":
      param1 = JSONGet(js,"context/caller_id/customerCode");
      param2 = JSONGet(js,"actions/[" & action_idx & "]/parameters/item_code");
      res = AnnaGetStockLevelOfItem(param1,param2);
    case "CreateNewOrder":
      param1 = JSONGet(js,"context/caller_id/customerCode");
      res = qupdating.AnnaCreateNewOrder(param1);
    case "CreateNewQuotation":
      param1 = JSONGet(js,"context/caller_id/customerCode");
      res = qupdating.AnnaCreateNewQuotation(param1);
    case "AddItemToQuotation":
      param1 = JSONGet(js,"context/caller_id/customerCode");
      param2 = URLEncode(JSONGet(js,"actions/[" & action_idx & "]/parameters/item"));
      param3 = URLEncode(JSONGet(js,"actions/[" & action_idx & "]/parameters/number"));
      res = qupdating.AnnaAddItemToQuotation(param1,param2,param3);
    case "EmailInvoice":
      param1 = JSONGet(js,"context/caller_id/customerCode");
      param2 = JSONGet(js,"actions/[" & action_idx & "]/parameters/invoiceno");
      res = qupdating.AnnaEmailInvoice(param1,param2);
    case "EmailOrder":
      param1 = JSONGet(js,"context/caller_id/customerCode");
      param2 = JSONGet(js,"actions/[" & action_idx & "]/parameters/orderno");
      res = qupdating.AnnaEmailOrder(param1,param2);
    case "EmailQuotation":
      param1 = JSONGet(js,"context/caller_id/customerCode");
      param2 = JSONGet(js,"actions/[" & action_idx & "]/parameters/quoteno");
      res = qupdating.AnnaEmailQuotation(param1,param2);
    case "OpenBalanceSheetForContact":
      param1 = JSONGet(js,"context/caller_id/customerCode");
      param2 = JSONGet(js,"actions/[" & action_idx & "]/parameters/date");
      res = AnnaOpenBalanceSheetForContact(param1,param2);
    case "UICommand":
      param1 = JSONGet(js,"actions/[" & action_idx & "]/parameters/action");
      param2 = JSONGet(js,"context/caller_id/customerCode");
      res = AnnaUICommand(param1,param2);
    case "RequestInvoices":
      param1 = JSONGet(js,"context/caller_id/customerCode");
      param2 = JSONGet(js,"actions/[" & action_idx & "]/parameters/count");
      param3 = JSONGet(js,"actions/[" & action_idx & "]/parameters/type");
      res = AnnaRequestInvoices(param1,param2,param3);
    case "RequestCompanyAddress":
      res = AnnaRequestCompanyAddress;
    case "RequestCompanyCEO":
      res = AnnaRequestCompanyCEO;
    case "RequestCompanyAccountant":
      res = AnnaRequestCompanyAccountant;
    case "RequestCompanyEmail":
      res = AnnaRequestCompanyEmail;
    case "RequestCompanyPostcode":
      res = AnnaRequestCompanyPostcode;
    case "RequestCompanyWebsite":
      res = AnnaRequestCompanyWebsite;
    case "RequestCompanyVAT":
      res = AnnaRequestCompanyVAT2;
    case "StopTalking":
      AnnaStop(conversationid);  //when adding to anna session dont save intent, should we use ctxkey
    case "Hangup":
      AnnaHangup(conversationid); //should we use ctxkey
    case "TransferToQueue":
      param1 = JSONGet(js,"actions/[" & action_idx & "]/parameters/type");
      res = AnnaTransferCall(conversationid,param1);
    case "RequestActivities":
      //param1 = JSONGet(js,"actions/[" & action_idx & "]/parameters/date");
      param1 = AnnaDisplayActivities(ctxkey,js);
      res = AnnaJsonWrapResponseText(param1);
  end;
  LogTextToFile("WatsonSOE.hal:DoLocalAnnaRequest SERP performed Anna action '" & action_name & "', with result " & res,"json.log");
  
  if (phonef) then begin ResetCompany(oldcomp); end;
  DoLocalAnnaRequest = res;
  return;
end;

//we are kind of neglecting this, should it be discontinued?
global
procedure WebAI_AnnaAction()
begin
  string 255 key,action_name,res,param1,param2,param3,ctxkey;
  Integer status_code;
//TODO if we want to use this ctxkey needs to be supplied from the call ctxkey = JSONGet(js,"context/conversation_id");

  key = WebGetArg("key");
  if (key!="N6U4B1uzxCQB") then begin
    status_code = 1; // Bad key
    WebOutString("{");
    WebOutString("\"statusCode\": \"" & status_code & "\"");
    WebOutString("}");
    goto LWebAI_AnnaAction;
  end;
  action_name = WebGetArg("action");
  param1 = WebGetArg("param1");
  param2 = WebGetArg("param2");
  param3 = WebGetArg("param3");
  
  switch (action_name) begin
    case "IdentifyCaller":              res = AnnaIdentifyCaller(ctxkey,param1);
    case "GetEmployeeTransferURI":      res = AnnaGetEmployeeTransferURI(param1);
    case "AddItemToOrder":              res = qupdating.AnnaAddItemToOrder(param1,param2,param3);
    case "CheckInvoiceStatus":          res = AnnaCheckInvoiceStatus(param1,param2);
    case "GetLastPayments":             res = AnnaGetLastPayments(param1,param2);
    case "GetPlannedDeliveryDate":      res = AnnaGetPlannedDeliveryDate(param1,param2);
    case "GetOrdersPendingDelivery":    res = AnnaGetOrdersPendingDelivery(param1,param2);
    case "GetStockLevelOfItem":         res = AnnaGetStockLevelOfItem(param1,param2);
    case "CreateNewOrder":              res = qupdating.AnnaCreateNewOrder(param1);
    case "CreateNewQuotation":          res = qupdating.AnnaCreateNewQuotation(param1);
    case "AddItemToQuotation":          res = qupdating.AnnaAddItemToQuotation(param1,param2,param3);
    case "EmailInvoice":                res = qupdating.AnnaEmailInvoice(param1,param2);
    case "EmailOrder":                  res = qupdating.AnnaEmailOrder(param1,param2);
    case "EmailQuotation":              res = qupdating.AnnaEmailQuotation(param1,param2);
    case "OpenBalanceSheetForContact":  res = AnnaOpenBalanceSheetForContact(param1,param2);
    case "UICommand":                   res = AnnaUICommand(param1,param2);
    case "RequestInvoices":             res = AnnaRequestInvoices(param1,param2,param3);
    case "RequestCompanyAddress":       res = AnnaRequestCompanyAddress;
    case "RequestCompanyCEO":           res = AnnaRequestCompanyCEO;
    case "RequestCompanyAccountant":    res = AnnaRequestCompanyAccountant;
    case "RequestCompanyEmail":         res = AnnaRequestCompanyEmail;
    case "RequestCompanyPostcode":      res = AnnaRequestCompanyPostcode;
    case "RequestCompanyWebsite":       res = AnnaRequestCompanyWebsite;
    case "RequestCompanyVAT":           res = AnnaRequestCompanyVAT;
  end;
  WebOutString(res);
  LogTextToFile("WatsonSOE.hal:WebAI_AnnaAction SOE performed Anna action '" & action_name & "', with result " & res,"json.log");
  
LWebAI_AnnaAction:;

end;

