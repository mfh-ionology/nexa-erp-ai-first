/* N last payments */
function LongInt FindLastPayment(var Integer cnt,var vector LongInt vfound,LongInt TransType,LongInt TransNr)
begin
  string 255 transkey;
  LongInt res;
  
  transkey = TransType & ":" & TransNr;
  res = vfound[transkey];
  if (res==-1) then begin
    res = cnt;
    cnt = cnt + 1;
    vfound[transkey] = res;
  end;
  
  FindLastPayment = res;
end;

function Boolean GetPaymentFromIPrs(string customer_code,record IPrsVc IPrsr,var val pay_amount,var string pay_currency)
begin
  Boolean res;
  record IVVc IVr;
  record IPVc IPr;
  row IPVc IPrw;
  record TRVc TRr;
  row TRVc TRrw;
  record CLInVc CLINr;
  row CLInVc CLINrw;
  LongInt rw;
  
  res = false;
  pay_amount = blankval;
  
  switch (IPrsr.TransType) begin
    case kIPrsTransTypeInvoice:
      /*
      IVr.SerNr = IPrsr.TransNr;
      if (ReadFirstMain(IVr,1,true)) then begin
        if (IVr.InvType==kInvoiceTypeCredit or IVr.InvType==kInvoiceTypeCreditSpecialSales) then begin
          res = true;
          pay_amount = IVr.Sum4;
          pay_currency = IVr.CurncyCode;
        end;
      end;
      */
    case kIPrsTransTypeReceipt:
      LogText(0,"GetPaymentFromIPrs IP " & IPrsr.TransNr & ":" & IPrsr.TransRow);
      
      IPr.SerNr = IPrsr.TransNr;
      if (ReadFirstMain(IPr,1,true)) then begin
        for (rw = 0; rw<MatRowCnt(IPr); rw = rw + 1) begin
          MatRowGet(IPr,rw,IPrw);
          if (IPrw.CustCode==customer_code) then begin
            pay_amount = pay_amount + IPrw.BankVal;
            pay_currency = IPrw.BankCurncy;
            res = true;
          end;
        end;
//        if (IPrsr.TransRow>=0 and MatRowCnt(IPr)>IPrsr.TransRow) then begin
//          MatRowGet(IPr,IPrsr.TransRow,IPrw);
//          pay_amount = IPrw.BankVal;
//          pay_currency = IPrw.BankCurncy;
//          res = true;
//        end;
      end;
    case kIPrsTransTypeNLTransaction:
      TRr.Number = IPrsr.TransNr;
      TRr.IntYc = GetIntYc(IPrsr.TransDate);
      if (ReadFirstMain(TRr,2,true)) then begin
        if (MatRowCnt(TRr)>IPrsr.TransRow) then begin
          MatRowGet(TRr,IPrsr.TransRow,TRrw);
          if (TRrw.ovst==0 and
              TRrw.stp==1 and
              TRrw.SerNr==-1 and
              TRrw.Typ==1) then begin
            
            pay_amount = TRrw.CredVal;
            if (blank(pay_amount)) then begin pay_amount = -TRrw.DebVal; end;
            pay_currency = TRrw.Curncy;
            res = true;
          end;
        end;
      end;
    case kIPrsTransTypeCashIn:
      if (MatRowCnt(CLInr)>IPrsr.TransRow) then begin
        MatRowGet(CLInr,IPrsr.TransRow,CLInrw);
        if ((CLInrw.Type==1) and
            (CLInrw.TransNr==IPrsr.IVNr) and
            (CLInr.CUCode==IPrsr.CustCode)) then begin
          pay_amount = CLInrw.Sum;
          pay_currency = CLInr.CurncyCode;
          res = true;
        end;
      end;
  end;
  
  GetPaymentFromIPrs = res;
end;

global
procedure FindLastPayments(string customer_code,Integer maxcount,date mindate,
                           var array date payment_date_arr,
                           var array val payment_amount_arr,
                           var array string payment_currency_arr)
begin
  record IPrsVc IPrsr;
  Boolean addf;
  Integer cnt,ix;
  Integer i,rwcnt;
  vector Boolean viprowprntdf;
  val pay_amount;
  string 255 pay_currency;
  vector LongInt vfound;
  
  IPrsr.CustCode = customer_code;
  while (LoopBackKey("MainKey",IPrsr,1,true)) begin
    
    if (IPrsr.CustCode<>customer_code) then begin goto LFindLastPayments_out; end;
    if ((maxcount>0) and (cnt>=maxcount)) then begin goto LFindLastPayments_out; end;
    if (nonblankDate(mindate) and (mindate>IPrsr.CustDate)) then begin goto LFindLastPayments_out; end;
    
    if (GetPaymentFromIPrs(customer_code,IPrsr,pay_amount,pay_currency)) then begin
      ix = FindLastPayment(cnt,vfound,IPrsr.TransType,IPrsr.TransNr);
      payment_date_arr[ix] = IPrsr.CustDate;
      
      if (ix>=payment_amount_arr.length) then begin
        payment_amount_arr[ix] = pay_amount;
      end else begin
        payment_amount_arr[ix] = payment_amount_arr[ix] + pay_amount;
      end;
      
      payment_currency_arr[ix] = pay_currency;
    end;
  end;
  
LFindLastPayments_out:;
end;

