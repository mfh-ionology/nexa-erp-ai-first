  Longint quoteno;

  invstat = 1;
  quoteno = StringToLongint(quote);

  oldcomp = CurrentCompany;
  BlockLoad(CBl);
  rwcnt = MatRowCnt(CBl);

LogText(0,"AnnaEmailQuotation tqno: " & quoteno & " cu: " & customercode);

  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(CBl,i,CBlrw);
    if (SetCompany(i+1,false)) then begin
      if (FindCustomerAndQuotation(customercode,quoteno,invstat,amount_due,currency_code)) then begin
        QTr.SerNr = quoteno;
        if (ReadFirstMain(QTr,1,true)) then begin
          err = CreateMailFromQTD(QTr,Mailr,tstr,"");
          if (err!=0) then begin
