  res = "{";
  res = res & "\"statusCode\": \"" & status_code & "\",";
  res = res & "\"quotationNumber\": \"" & QTr.SerNr & "\"";
  res = res & "}";

  AnnaCreateNewQuotation = res;
  return;
end;

global
updating function string 255 AnnaAddItemToQuotation(string customercode,string item,string quantity)
begin
  record QTVc QTr;
  record QTVc oldQTr;
  record INVc INr;
  row QTVc QTrw;
  integer rwcnt,status_code,wn;
  LongInt serial;
  string 255 res,inwarning,warning;
  
  //get last order serial
  if (GetCustomersCurrentQT(QTr,customercode)==false) then begin
    status_code = 2; // Quotation not found
    goto LAnnaAddItemToQuotation_response;
  end;
  
  serial = QTr.SerNr - 1;
  RecordClear(QTr);
  QTr.SerNr = serial;
  if (ReadFirstMain(QTr,1,true)==false) then begin
    status_code = 2; // Quotation not found
    goto LAnnaAddItemToQuotation_response;
  end;
  
LogText(0,"AnnaAddItemToQuotation QTr.SerNr=" & QTr.SerNr & ", item=" & item & ", quantity=" & quantity);

  if (FindItemFromString_old(item,INr)==false) then begin
    status_code = 3; // Item not found
    goto LAnnaAddItemToQuotation_response;
  end;
  
  rwcnt = MatRowCnt(QTr);
  QTrw.ArtCode = INr.Code;
  QTrw.Quant = StringToVal(quantity,M4Val);
  MatRowPut(QTr,rwcnt,QTrw);
  RecordCopy(oldQTr,QTr);
  QTVc_PasteArtCode(QTr,rwcnt,inwarning,warning);
  if (RecordUpdate(oldQTr,QTr,false)!=0) then begin
    status_code = 4; // Record update failed
    goto LAnnaAddItemToQuotation_response;
  end;
/*
//TODO check if user logged in?
  wn = FindWindow("QTDClass");
  if (wn>0) then begin
    PutWindowRecord(wn,QTr);
  end;
*/
  LAnnaAddItemToQuotation_response:;
LogText(0,"AnnaAddItemToQuotation END status_code=" & status_code & ", wn=" & wn);
  res = "{";
  res = res & "\"statusCode\": \"" & status_code & "\"";
  res = res & "}";

  AnnaAddItemToQuotation = res;
  return;
end;

global
updating function string 255 AnnaEmailInvoice(string customercode,string invoice)
begin
  record IVVc IVr;
  record MailVc Mailr;
  record MailVc OldMailr;
  record CompaniesBlock CBl;
  row CompaniesBlock CBlrw;
  Integer oldcomp,rwcnt,i,cnt,invstat,err;
  Boolean foundf;
  string 255 res,status_string,currency_code,tstr;
  val amount_due,amount_full;
  Longint invoiceno;
  Boolean resf;

  invstat = 1;
  invoiceno = StringToLongint(invoice);

  oldcomp = CurrentCompany;
  BlockLoad(CBl);
  rwcnt = MatRowCnt(CBl);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(CBl,i,CBlrw);
    if (SetCompany(i+1,false)) then begin
      if (FindCustomerAndInvoice(customercode,invoiceno,invstat,amount_due,amount_full,currency_code)) then begin
        IVr.SerNr = invoiceno;
        if (ReadFirstMain(IVr,1,true)) then begin
          err = CreateMailFromIVD(IVr,Mailr,tstr,false,"");
          if (err!=0) then begin
            if (err>0) then begin
              status_string = USetStr(err) & " " & tstr;
            end;
          end else begin
            // RecordCopy(oldIVr,IVr);
            // IVr.Prntdf = 1;
            // RecordUpdate(oldIVr,IVr,false);
            RecordCopy(OldMailr,Mailr);
            Mailr.SendFlag = 1;
            RecordUpdate(OldMailr,Mailr,true);
            invstat = 0;
            resf = true;
          end;
          goto LAnnaEmailInvoice;
        end;
      end;
    end;
  end;
  status_string = "not found";
LAnnaEmailInvoice:;
  ResetCompany(oldcomp);
  if (resf==true) then begin
    status_string = "email sent";
  end else begin
    if (status_string=="") then begin
      status_string = "could not send email";
    end;
  end;

  res = "{";
  res = res & "\"statusCode\": \"" & invstat & "\",";
  res = res & "\"statusText\": \"" & status_string & "\",";
  res = res & "\"amountDue\": \"" & SayValAsCurrency(amount_due,currency_code) & "\"";
  res = res & "}";
  
  AnnaEmailInvoice = res;
  return;
end;

