              status_string = USetStr(err) & " " & tstr;
            end;
          end else begin
            // RecordCopy(oldQTr,QTr);
            // QTr.Prntdf = 1;
            // RecordUpdate(oldQTr,QTr,false);
            RecordCopy(OldMailr,Mailr);
            Mailr.SendFlag = 1;
            RecordUpdate(OldMailr,Mailr,true);
            resf = true;
            invstat = 0;
          end;
          goto LAnnaEmailQuotation;
        end;
      end;
    end;
  end;

  status_string = "not found";

LAnnaEmailQuotation:;
  ResetCompany(oldcomp);

  if (resf==true) then begin
    status_string = "email sent";
  end else begin
    if (status_string=="") then begin
      status_string = "could not send email";
    end;
  end;

  res = "{";
  res = res & "\"statusCode\": \"" & invstat & "\",";
  res = res & "\"statusText\": \"" & status_string & "\",";
  res = res & "\"amountDue\": \"" & SayValAsCurrency(amount_due,currency_code) & "\"";
  res = res & "}";
  
  AnnaEmailQuotation = res;
  return;
end;

global
function string 255 AnnaOpenBalanceSheetForContact(string contactno,string datestr1)
begin
  string 255 contact_no,res,tstr,datestr;
  Integer oldcomp;
  Integer status_code,res1,month,year;
  record RcVc RepSpec;
  date dt,sd,ed;

  contact_no = Trim(contactno);
  if (blank(contact_no)) then begin
    status_code = 2; // Must have contact no
    goto LAnnaOpenBalanceSheetForContact_response;
  end;

  datestr = Trim(datestr1);
  if (nonblank(datestr)) then begin
    dt = DateFromString(datestr,"YYYY-MM-DD");
    month = GetMonth(dt);
    year = GetYear(dt);
  end else begin
    month = GetMonth(AddMonth(CurrentDate,-1));
    year = GetYear(CurrentDate);
  end;
  sd.Month = month;
  sd.Year = year;

  ReportDefaults(RepSpec,"BalRClass");
  sd.Day = 1;
  ed = AddDay(AddMonth(sd,1),-1);
  RepSpec.sStartDate = sd;
  RepSpec.sEndDate = ed;
  RepSpec.Media = mtScreen;
  RepSpec.repname = "BalRn";
  FindRepDefHeader(RepSpec.repname,RepSpec.shortname,tstr);
  RepSpec.f1 = tstr;
  RepSpec.AccSpec = 1;

  oldcomp = CurrentCompany;
  SetCompany(1,false);
  res1 = OpenReportForContact(contact_no,RepSpec);
  ResetCompany(oldcomp);

  if (res1!=0) then begin
    status_code = 9 + res1; // Couldn't open report, code from RunReportFromClient in C
    goto LAnnaOpenBalanceSheetForContact_response;
  end;

LAnnaOpenBalanceSheetForContact_response:;
  res = "{";
  res = res & "\"statusCode\": \"" & status_code & "\"";
  res = res & "}";

  AnnaOpenBalanceSheetForContact = res;
  return;
end;

//not acyually setup in code
global
function string 255 AnnaRefreshCurrencyRates(string datestr1)
begin
  record ERBlock ERb;
  record RcVc RepSpec;
  string 255 contact_no,tstr,datestr,errstr,res;
  Integer oldcomp,status_code,month,year;
  date dt,sd,ed;
  LongInt errno;
  //Integer nwn;
  //record RcVc RepSpec;
  Boolean found;

  datestr = Trim(datestr1);
  if (nonblank(datestr)) then begin
    dt = DateFromString(datestr,"YYYY-MM-DD");
    month = GetMonth(dt);
    year = GetYear(dt);
  end else begin
    month = GetMonth(AddMonth(CurrentDate,-1));
    year = GetYear(CurrentDate);
  end;


  BlockLoad(ERb);
  RepSpec.d1 = AddDay(CurrentDate,-1);
//  RepSpec.flags[0] = 1;
  RepSpec.flags[1] = ERb.OverwriteExistRate;

  found = GetExchangeRateFromBank(RepSpec,true,errno,errstr);

  if (found) then begin
    status_code = 9 + 1; // Couldn't open report, code from RunReportFromClient in C
    goto LAnnaRefreshCurrencyRates_response;
  end;

LAnnaRefreshCurrencyRates_response:;
  res = "{";
  res = res & "\"statusCode\": \"" & status_code & "\"";
  res = res & "}";

  AnnaRefreshCurrencyRates = res;
  return;
end;

global
function string 255 AnnaUICommand(string contact_no,string action)
begin
  string 255 res;
  Integer status_code;
  record CUVc CUr;
  Integer wn;

LogText(0,"AnnaUICommand RAN");
/*
  if (blank(contact_no)) then begin
  status_code = 2; // Must have contact no
  goto LAnnaUICommand;
  end;
  CUr.Code = contact_no;
  if (ReadFirstMain(CUr,1,true)==false) then begin
    LogText(0,"OpenReportForContact failed to find contact " & contact_no);
    goto LAnnaUICommand;
  end;
*/
  switch (action) begin
    case "UIOpenTempTest":
      ToolAction(1,ToolNext,0,false);
    case "UIOpenCalendar":
      ToolAction(1,ToolCalendar,0,false);
    case "ToolMail":
      ToolAction(1,ToolMail,0,false);         //does not work because mailbox is not set (user not set correctly)
    case "UIOpenConferences":
      ToolAction(1,ToolConferences,0,false);  //does not work because mailbox is not set (user not set correctly)
    case "UIOpenTasks":
      ToolAction(1,ToolTodo,0,false);         //crashes because user is not set prooperly
    case "UIOpenResources":
      ToolAction(1,ToolResources,0,false);    //crashes because user is not set prooperly
    case "UIOpenSmartApps":
      ToolAction(1,ToolForms,0,false);        //does not open
    case "UIOpenFeedReader":
      ToolAction(1,ToolAggregator,0,false);   //does not open
    case "UIOpenRegisters":
      ToolAction(1,ToolRegs,0,false);
    case "UIOpenSettings":
      ToolAction(1,ToolSetup,0,false);
    case "UIOpenReports":
      ToolAction(1,ToolReport,0,false);
    case "UIOpenRoutines":
      ToolAction(1,ToolRoutines,0,false);
    case "UIOpenForms":
      ToolAction(1,ToolDocument,0,false);
    case "UIOpenModules":
      ToolAction(1,ToolModule,0,false);
    case "UIOpenCompanies":
      ToolAction(1,ToolOpen,0,false);
    case "UICloseWindow":
//TODO probably need to be moved to a seprate function
      wn = CurWindow;
      CloseWindow(wn);
    otherwise
      LogText(0,"received invalid action: " & action);
      status_code = 3; //invalid parameters
  end;

LAnnaUICommand:;
  res = "{";
  res = res & "\"statusCode\": \"" & status_code & "\"";
  res = res & "}";
  
  AnnaUICommand = res;
  return;
end;


/*      Invoices      */

function string 255 AnnaCheckInvoiceStatus(string customercode,string invoicenumstr)
begin
  record CompaniesBlock CBl;
  row CompaniesBlock CBlrw;
  Integer oldcomp,rwcnt,i,cnt,invstat;
  Boolean foundf;
  string 255 status_string,currency_code,res;
  val amount_due,amount_full;
  Longint invoiceno;

  invoiceno = StringToLongint(invoicenumstr);

  oldcomp = CurrentCompany;
  BlockLoad(CBl);
  rwcnt = MatRowCnt(CBl);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(CBl,i,CBlrw);
    if (SetCompany(i+1,false)) then begin
      if (FindCustomerAndInvoice(customercode,invoiceno,invstat,amount_due,amount_full,currency_code)) then begin
        foundf = true;
        goto LAnnaCheckInvoiceStatus;
      end;
    end;
  end;

LAnnaCheckInvoiceStatus:;
  ResetCompany(oldcomp);

  status_string = "not found";
  if (foundf==true) then begin
    switch (invstat) begin
      case 0: status_string = "paid";
      case 1: status_string = "awaiting payment";
      case 2: status_string = "overdue";
      case 3: status_string = "not registered";
    end;
  end;
  res = "{";
  res = res & "\"statusCode\": \"" & invstat & "\",";
  res = res & "\"statusText\": \"" & status_string & "\",";
  res = res & "\"amountDue\": \"" & SayValAsCurrency(amount_due,currency_code) & "\"";
  res = res & "}";
  
  AnnaCheckInvoiceStatus = res;
  return;
end;

function integer FindInvoicesReverse(var integer count,string custcode,var string invoicelist,boolean paidonlyf)
begin
  Boolean THrS;
  record IVVc IVr;
  integer count2,invstat,res;
  string 255 comma;
  val amount_due,amount_full;

  count2 = count;
  count = 0;
  THrS = true;
  IVr.CustCode=custcode;
  while (LoopKey("CustCode",IVr,1,THrS)) begin
    if (IVr.CustCode!=custcode) then begin THrS = false; end;
    if (THrS and IVr.OKFlag<>0) then begin
      GetIVStatus(IVr,invstat,amount_due,amount_full);
      if (paidonlyf==false or invstat!=0) then begin
        invoicelist = invoicelist & comma & IVr.SerNr & " for " & SayValAsCurrency(amount_due,IVr.CurncyCode) & " " & SayAsDate(IVr.InvDate);
        count = count + 1;
        res = 2;
        if (count>=count2) then begin
          THrS = false;
          res = 1;
        end;
        comma = ", ";
      end;
    end;
  end;

  FindInvoicesReverse = res;
  return;
end;

function integer FindInvoices(var integer count,string custcode,var string invoicelist,Boolean openinvoices)
begin
  Boolean THrS;
  record IVVc IVr;
  integer count2,invstat,res;
  string 255 comma;
  val amount_due,amount_full;

  count2 = count;
  count = 0;
  THrS = true;
  IVr.CustCode=custcode;
  while (LoopBackKey("CustCode",IVr,1,THrS)) begin
    if (IVr.CustCode!=custcode) then begin THrS = false; end;
    if (THrS and IVr.OKFlag<>0) then begin
      GetIVStatus(IVr,invstat,amount_due,amount_full);
      if (openinvoices==false or invstat!=0) then begin
        invoicelist = invoicelist & comma & IVr.SerNr;
        
        if (openinvoices) then begin
          invoicelist = invoicelist & " due amount " & SayValAsCurrency(amount_due,IVr.CurncyCode);
        end else begin
          invoicelist = invoicelist & " for " & SayValAsCurrency(amount_full,IVr.CurncyCode);
        end;
        
        invoicelist = invoicelist & " " & SayAsDate(IVr.InvDate);
        
        count = count + 1;
        res = 2;
        if (count>=count2) then begin
          THrS = false;
          res = 1;
        end;
        comma = ", ";
      end;
    end;
  end;

  FindInvoices = res;
  return;
end;

global
function string 255 AnnaRequestInvoices(string custcode,string countstr,string typestr)
begin
  record CompaniesBlock CBl;
  row CompaniesBlock CBlrw;
  Integer oldcomp,rwcnt,i,cnt;
  string 255 res,invoicelist;
  Integer count,type,status_code;

  count = StringToInt(countstr);
  type = StringToInt(typestr);
  if (blank(count) or count<1 or count>6) then begin
    count = 6;
  end;
  
  oldcomp = CurrentCompany;
  BlockLoad(CBl);
  rwcnt = MatRowCnt(CBl);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(CBl,i,CBlrw);
    if (SetCompany(i+1,false)) then begin
      switch (type) begin
        case 0:   //search all
          status_code = FindInvoices(count,custcode,invoicelist,false);
        case 1:   //search unpaid
          status_code = FindInvoices(count,custcode,invoicelist,true);
        case 2:   //search unpaid reverse
          status_code = FindInvoicesReverse(count,custcode,invoicelist,true);
        default:
          goto LAnnaRequestInvoices;
      end;
    end;
  end;
LAnnaRequestInvoices:;
  ResetCompany(oldcomp);
  res = "{";
  res = res & "\"statusCode\": \"" & status_code & "\",";
  res = res & "\"statusText\": \"" & invoicelist & "\",";
  res = res & "\"InvoiceCount\": \"" & count & "\"";
  res = res & "}";
  
  AnnaRequestInvoices = res;
  return;
end;

