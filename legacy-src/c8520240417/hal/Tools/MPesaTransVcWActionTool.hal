global 
updating procedure MPesaGetReplyFromMPesaAboutTransactionStatus(area a) 
begin
  json js;
  record MPesaTransVc MPesaTransr;
  string 255 code,resultcode,amount,status,value, mainkey,result,phone,timee,reason,id,time2;
  integer i;

  AddFileToArea("WebKenianTransactionStatusRequestsReply.txt",a,false);
  if (GetAreaLength(a)>0) then begin  
    js = ParseJSONArea(a);
    resultcode = JSONGet(js,"Result/ResultCode");
    result = JSONGet(js,"Result/ResultDesc");
    switch (resultcode) begin
      case "0": code = "Success";
      RecordNew(MPesaTransr);
      MPesaTransr.TransTillNumber = ""; 
      MPesaTransr.TransTillUser = ""; 
      MPesaTransr.MSISDN = left(JSONGet(js,"Result/ResultParameters/ResultParameter/[0]/Value"),12);
      time2 = JSONGet(js,"Result/ResultParameters/ResultParameter/[3]/Value"); 
      MPesaTransr.TransDate = DateFromString(time2,"yyyymmdd");
      MPesaTransr.TransTime = TimeFromMPesaTimeString(time2);
      MPesaTransr.TransAmount = JSONGet(js,"Result/ResultParameters/ResultParameter/[10]/Value");
      MPesaTransr.TransactionType = JSONGet(js,"Result/ResultParameters/ResultParameter/[7]/Value");
      MPesaTransr.TransID = JSONGet(js,"Result/ResultParameters/ResultParameter/[12]/Value"); 
      MPesaTransr.SerNr = NextSerNr("MPesaTransVc",MPesaTransr.TransDate,-1,false,"");
      if (MPesaTransr.SerNr>0) then begin
        RecordStore(MPesaTransr,false);
      end;
    end; 
      AllClientsRemoteAsync.SendMpesaTransactionStatusMessage(MPesaTransr,resultcode,result);
  end;   
  return;
end;

global 
updating procedure MPesaGetTransactionInfoFromTransactionsReply(area a)
begin
  json js;
  record MPesaTransVc MPesaTransr;
  string 255 tstr;

  AddFileToArea("WebKenianConfirmationUrl.txt",a,false);
  if (GetAreaLength(a)>0) then begin  
    js = ParseJSONArea(a);
    RecordNew(MPesaTransr);
    MPesaTransr.TransTillNumber = "";
    MPesaTransr.TransTillUser = "";
    MPesaTransr.TransID = JSONGet(js,"TransID");
    MPesaTransr.TransactionType = JSONGet(js,"TransactionType");
    tstr = JSONGet(js,"TransTime");
    MPesaTransr.TransDate = DateFromString(tstr,"yyyymmdd");
    MPesaTransr.TransTime = TimeFromMPesaTimeString(tstr);
    MPesaTransr.TransAmount = JSONGet(js,"TransAmount");
    MPesaTransr.BillRefNumber = JSONGet(js,"BillRefNumber");
    MPesaTransr.MSISDN = JSONGet(js,"MSISDN");
    MPesaTransr.SerNr = NextSerNr("MPesaTransVc",MPesaTransr.TransDate,-1,false,"");
    if (MPesaTransr.SerNr>0) then begin
      RecordStore(MPesaTransr,false);
      WebOutString( "{""ResultCode"":0,""ResultDesc"":""Success""}" );
    end;
  end;
return;
end;

