global
function Boolean MPesaRegisterURL(record CCAccountIDVc CCAccountIDr,record IVCashVc IVCr,string transid,var string message)
begin
  string 255 tstr,jsr,auth,url,urlconfirmation,urlvalidation;
  Area a_req,a_reply;
  Boolean res;
  json js;

  // if (WebSecureMode) then begin
  //   url = "https://" & Webhost;
  // end else begin
  //   url = "http://" & Webhost;
  // end;

  url = CCAccountIDr.MPesaDomain;
  //url = "https://" & GetWebHostAndPort3(false);
  urlconfirmation = url & "/WebKenianConfirmationUrl.hal";
  urlvalidation =  url & "/WebKenianValidationUrl.hal";

  // urlconfirmation = "https://lending.gainteqafrika.co.ke/money_transfer/callback_response/";
  // urlvalidation = "https://lending.gainteqafrika.co.ke/money_transfer/callback_response/";
  message = USetStr(41900);
  JSONStringStart(jsr);
  JSONStringAdd(jsr,"ShortCode",CCAccountIDr.MPesaTill);
  JSONStringAdd(jsr,"ResponseType","Completed"); 
  JSONStringAdd(jsr,"ConfirmationURL",urlconfirmation);
  JSONStringPut(jsr,"ValidationURL",urlvalidation);
  JSONStringEnd(jsr);
  AddTextToArea(jsr,a_req);
  auth = GetMPesaToken(CCAccountIDr);
  if (nonblank(auth)) then begin
    tstr = "Authorization: Bearer " & auth;
    SetWebHeaders(tstr);
    SendWebRequest(CCAccountIDr.URL,443,-1,true,"POST","/mpesa/c2b/v1/registerurl","application/json","",false,a_req,a_reply,20); 
    LogAreaToFile("MPesaVALIDATIONReply" & ".txt",a_reply);
    LogAreaToFile("MPesaVALIDATIONReq" & ".txt",a_req);
    js = ParseJSONArea(a_reply);
    if (JSONGet(js,"ResponseCode")=="0") then begin
      res = true;
      message = "Successfully registered";
    end else begin
      message = JSONGet(js,"errorMessage");
    end;
  end;
MPesaRegisterURL = res;
  return;
end;

function string 255 MPesaCredentialFromPassword(string password)
begin
  string 255 res;
  area a_password;
  
  AddTextToArea(password,a_password);
  res = CryptRSAPublicEncrypt(a_password,"certnew.cer","",kCryptKeyFormatX509);
  res = Base64Encode(res);
  MPesaCredentialFromPassword = res;
  return;
end;

global
function Boolean ProceedMPesaPayTouchScreenRemote(record RcVc RepSpec,record CCAccountIDVc CCAccountIDr,record IVCashVc IVCr,Integer txtype,string transid,var string message)
begin
  string 255 tstr,jsr,auth,initiator,secretcred,jsr2,returnurl,timeouturl,seccred,url,conversationid,phone,amount;
  Area a_req,a_reply,a_seccred;
  Boolean res,found,TrHs;
  json js;
  LongInt diff;
  record MPesaTransVc MPesaTransr;
  record SysFormatBlock SysFormatRec;

  // if (WebSecureMode) then begin
  //   url = "https://" & Webhost;
  // end else begin
  //   url = "http://" & Webhost;
  // end;
  //url = "http://" & GetWebHostAndPort3(false);
  url = CCAccountIDr.MPesaDomain;
  returnurl = url & "/WebKenianTransactionStatusRequestsReply.hal?posinvnr=" & IVCr.SerNr;
  timeouturl = url & "/WebKenianTransactionStatusRequestTimeOutReply.hal?timeout";

  message = USetStr(41900);
  BlockLoad(SysFormatRec);
  switch (txtype) begin
    case kCardTransactionRefund:
    case kCardTransactionPay:
      jsr = "";
      phone = RepSpec.f1;
      amount = ValToString(RepSpec.vals0,M4Val,"",SysFormatRec.decimalPt,0);
      GetMPesaInitiator(RepSpec.CurncyCode,initiator,seccred);
      conversationid = FindMpesaTransactionID(phone,amount);
      if (nonblank(conversationid)) then begin
        res = true;
      end else begin
        conversationid = RepSpec.f3;
        secretcred = GetTextField(CCAccountIDr);
        //secretcred = MPesaCredentialFromPassword(seccred);
        JSONStringStart(jsr);
        JSONStringAdd(jsr,"Initiator",initiator);
        JSONStringAdd(jsr,"SecurityCredential",secretcred);
        JSONStringAdd(jsr,"CommandID","TransactionStatusQuery");
        JSONStringAdd(jsr,"TransactionID",conversationid);
        JSONStringAdd(jsr,"PartyA",CCAccountIDr.MPesaTill);
        JSONStringAdd(jsr,"IdentifierType","4"); 
        JSONStringAdd(jsr,"ResultURL",returnurl);       
        JSONStringAdd(jsr,"QueueTimeOutURL",timeouturl);
        JSONStringPut(jsr2,"Remarks","TransactionStatusQuery");
        // JSONStringAdd(jsr,"Occasion",""); 
        jsr = jsr &  jsr2;
        JSONStringEnd(jsr);
        AddTextToArea(jsr,a_req);
        auth = GetMPesaToken(CCAccountIDr);
        if (nonblank(auth)) then begin
          tstr = "Authorization: Bearer " & auth;
          SetWebHeaders(tstr);
          SendWebRequest(CCAccountIDr.URL,443,-1,true,"POST","/mpesa/transactionstatus/v1/query","application/json","",false,a_req,a_reply,20);
          LogAreaToFile("MPesatransactionstatusReply" & ".txt",a_reply);
          LogAreaToFile("MPesatransactionstatusReq" & ".txt",a_req);
          js = ParseJSONArea(a_reply);
          if (JSONGet(js,"ResponseCode")=="0") then begin
            res = true;
          end else begin
            message = JSONGet(js,"errorMessage");
          end;
        end;
      end;
  end;
  ProceedMPesaPayTouchScreenRemote = res;
  return;
end;

global
updating function boolean MpesaConfirmTransaction(string transactionID,string billrefrence) begin
  boolean res;
  record MPesaTransVc MPesaTransr,oldMPesaTransr;
  
  MPesaTransr.TransID = transactionID;
  if (ReadFirstKey("TransID",MPesaTransr,1,true)) then begin
    if (MPesaTransr.MPesaf==0) then begin
      recordCopy(oldMPesaTransr,MPesaTransr);
      MPesaTransr.MPesaf = 1;
      MPesaTransr.BillRefNumber = billrefrence;
      RecordUpdate(oldMPesaTransr,MPesaTransr,true);
      res = true;
      MessageBox(0,"Confirmed");
    end else begin
      MessageBox(21683,": " & MPesaTransr.TransID);
    end;
  end else begin
    MessageBox(21684,": " & MPesaTransr.TransID);
  end;
  MpesaConfirmTransaction = res;
  return;
end;

/* code for the revert transaction 
global
function Boolean MPesaReverseTransaction(record RcVc RepSpec,record CCAccountIDVc CCAccountIDr,record IVCashVc IVCr,Integer txtype,var string message)
begin
  string 255 tstr,jsr,auth,initiator,secretcred,jsr2,resulturl,timeouturl,seccred,url,conversationid,amount;
  Area a_req,a_reply;
  Boolean res;
  record SysFormatBlock SysFormatRec;
  json js;

  url = CCAccountIDr.MPesaDomain;
  resulturl = url & "/WebMPesaReverseTransactionResult.hal";
  timeouturl = url & "/WebMPesaReverseTransactionResultTimeOutReply.hal";
  message = USetStr(41900);
  BlockLoad(SysFormatRec);
  switch (txtype) begin
    case kCardTransactionRefund:
    case kCardTransactionPay:
      jsr = "";
      GetMPesaInitiator(RepSpec.CurncyCode,initiator,seccred);
        //secretcred = MPesaCredentialFromPassword(seccred);
      conversationid = RepSpec.f3;
      amount = ValToString(RepSpec.vals0,M4Val,"",SysFormatRec.decimalPt,0);
      secretcred = GetTextField(CCAccountIDr);
      JSONStringStart(jsr);
      JSONStringAdd(jsr,"Initiator",initiator);
      JSONStringAdd(jsr,"SecurityCredential",secretcred);
      JSONStringAdd(jsr,"CommandID","TransactionReversal");
      JSONStringAdd(jsr,"TransactionID",conversationid);
      JSONStringAdd(jsr,"Amount",amount);
      JSONStringPut(jsr,"ReceiverParty",CCAccountIDr.MPesaTill);
      JSONStringPut(jsr,"RecieverIdentifierType","4");
      JSONStringPut(jsr,"ResultURL",resulturl);
      JSONStringPut(jsr,"QueueTimeOutURL",timeouturl);
      JSONStringAdd(jsr2,"Remarks","cancelling transaction");
      // JSONStringAdd(jsr,"Occasion",""); 
      JSONStringEnd(jsr);
      AddTextToArea(jsr,a_req);
      auth = GetMPesaToken(CCAccountIDr);
      if (nonblank(auth)) then begin
        tstr = "Authorization: Bearer " & auth;
        SetWebHeaders(tstr);
        SendWebRequest(CCAccountIDr.URL,443,-1,true,"POST","/mpesa/reversal/v1/request","application/json","",false,a_req,a_reply,20);
        LogAreaToFile("MPesaReverseTransactionReply" & ".txt",a_reply);
        LogAreaToFile("MPesaReverseTransactionReq" & ".txt",a_req);
        js = ParseJSONArea(a_reply);
        if (JSONGet(js,"ResponseCode")=="500") then begin 
          res = true;
        end else begin
          message = JSONGet(js,"errorMessage");
        end;
      end;
  end;
  MPesaReverseTransaction = res;
  return;
end;

