function string 255 GetMPesaToken(record CCAccountIDVc CCAccountIDr)
begin
  string 255 tstr,res;
  Area a_req,a_reply;
  json js;

  tstr = "Authorization: Basic ";
  tstr = tstr & base64encode(CCAccountIDr.MPesaConsKey & ":" & CCAccountIDr.MPesaConsSecret) & chr(13) & chr(10);
  SetWebHeaders(tstr);
  SendWebRequest(CCAccountIDr.URL,443,-1,true,"GET","/oauth/v1/generate?grant_type=client_credentials","","",false,a_req,a_reply,5);
  js = ParseJSONArea(a_reply);
  res = JSONGet(js,"access_token");
  GetMPesaToken = res;
  return;
end;

global
function string 255 FindMpesaTransactionID(string phone,string amount)
begin
  Boolean TrHs,found;
  string 255 conversationid;
  record MPesaTransVc MPesaTransr;
  LongInt diff;

  MPesaTransr.MSISDN = phone;
  TrHs = true;
  while (LoopBackKey("MSISDN",MPesaTransr,1,TrHs)) begin
    if (MPesaTransr.MSISDN!=phone) then begin
      TrHs = false;
      found = false;
    end;
    found = true;
    if (TrHs) then begin
      if (DateInRange(MPesaTransr.TransDate,CurrentDate,CurrentDate)==false) then begin
        found = false;
      end;
      diff = TimeDiffinMinutes(CurrentTime,MPesaTransr.TransTime);
      if (diff>500) then begin 
        found = false;
      end;
      if (MPesaTransr.TransAmount!=amount) then begin 
        found = false;
      end;
      if (MPesaTransr.MPesaf==1) then begin
        found = false;
      end;
      if (MPesaTransr.Cancld==1) then begin
        found = false;
      end;
      if (found) then begin
        conversationid = MPesaTransr.TransID;
        MessageBox(0,"Transaction " & conversationid  & " has been found. It took place at " & MPesaTransr.TransTime); 
        TrHs = false;
      end;
    end;
  end;
  if (found==false) begin
    MessageBox(0,"No matching transaction found!");
  end;
  FindMpesaTransactionID = conversationid;
  return;
end;

global
function string 255 GetMPesaTill(string curncy)
begin
  record LocalMachineBlock LMb;
  record LocalMachineVc LocalMachiner;
  record CCAccountIDVc CCAccountIDr;
  string 255 res;
  Boolean foundf;

  BlockLoad(LMb);
  LocalMachiner.Code = LMb.LocalMachineCode;
  if (ReadFirstMain(LocalMachiner,1,true)) then begin
    if (nonblank(LocalMachiner.ShortCode)) then begin
      res = LocalMachiner.ShortCode;
      foundf = true;
    end;
  end;
  if (!foundf) then begin
    FindPaymentGateway(curncy,LMb.LocalMachineCode,kCCAccountTypePOS,CCAccountIDr,kCardHolderAny,kCCPartnerMPesa);
    res = CCAccountIDr.MPesaTill;
  end;
  GetMPesaTill = res;
  return;
end;

global
function string 255 GetMPesaPhone(string custcode)
begin
  record CUVc CUr;
  string 255 res;

  CUr.Code = custcode;
  if (ReadFirstMain(CUr,1,true)) then begin
    res = CUr.Phone;
  end;
  GetMPesaPhone = res;
  return;
end;

global
function string 255 GetMPesaTransactionId(string phone)
begin
  string 255 res;
  record MPesaTransVc MPesaTransr;

  MPesaTransr.MSISDN = phone;
  if (ReadFirstMain(MPesaTransr,1,true)) then begin
    res = MPesaTransr.TransID;
  end;
  GetMPesaTransactionId = res;
  return;
end;

global 
procedure MPesaTransVc_PasteTransactionId(var record RcVc RepSpec)
begin
  record MPesaTransVc MPesaTransr;
  record SysFormatBlock SysFormatRec;
  integer diff;
  boolean TrHs;
  string 255 amount;

  BlockLoad(SysFormatRec);
  TrHs = true;
  MPesaTransr.MSISDN = RepSpec.f1;
  while (LoopBackKey("MSISDN",MPesaTransr,1,TrHs)) begin
    if (DateInRange(MPesaTransr.TransDate,CurrentDate,CurrentDate)==false) then begin
      TrHs = false;
    end;
    diff = TimeDiffinMinutes(CurrentTime,MPesaTransr.TransTime);
    if (diff>500) then begin
      TrHs = false;
    end;
    amount = ValToString(RepSpec.vals0,M4Val,"",SysFormatRec.decimalPt,0);
    if (MPesaTransr.TransAmount!=amount) then begin
      TrHs = false;
    end;
    if (MPesaTransr.MPesaf==1) then begin
      TrHs = false;
    end;
    if (MPesaTransr.Cancld==1) then begin
      TrHs = false;
    end;
    if (TrHs) then begin
      RepSpec.f3 = MPesaTransr.TransID;
    end;
  end;
  return;
end;

global
procedure GetMPesaInitiator(string curncy,var string initiator,var string seccred)
begin
  record LocalMachineBlock LMb;
  record LocalMachineVc LocalMachiner;
  record CCAccountIDVc CCAccountIDr;  
  string 255 res;
  Boolean foundf;

  BlockLoad(LMb);
  LocalMachiner.Code = LMb.LocalMachineCode;
  if (ReadFirstMain(LocalMachiner,1,true)) then begin
    if (nonblank(LocalMachiner.Initiator) and nonblank(LocalMachiner.SecurityCredential)) then begin
      initiator = LocalMachiner.Initiator;
      seccred = LocalMachiner.SecurityCredential;
      foundf = true;
    end;
  end;
  if (!foundf) then begin
    FindPaymentGateway(curncy,LMb.LocalMachineCode,kCCAccountTypePOS,CCAccountIDr,kCardHolderAny,kCCPartnerMPesa);
    initiator = CCAccountIDr.MPesaInitiator;
    seccred = CCAccountIDr.MPesaSecCred;
  end;
  return;
end;

function time TimeFromMPesaTimeString(string timestamp)
begin
  time res;
  string 255 timestr;

  timestr = right(timestamp,6);
  res.hour = StringToInt(left(timestr,2));
  timestr = right(timestr,4);
  res.minute = StringToInt(left(timestr,2));
  res.second = StringToInt(right(timestr,2));
  TimeFromMPesaTimeString = res;
  return;
end;

