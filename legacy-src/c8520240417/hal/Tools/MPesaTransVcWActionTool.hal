global
function Boolean MPesaPaymentTransaction(record RcVc RepSpec,record CCAccountIDVc CCAccountIDr,record IVCashVc IVCr,Integer txtype,var string message)
begin
  string 255 tstr,jsr,auth,initiator,secretcred,jsr2,returnurl,timeouturl,seccred,url;
  Area a_req,a_reply;
  Boolean res;
  json js;
  // if (WebSecureMode) then begin
  //   returnurl = "https://" & Webhost;//10061
  // end else begin
  //   returnurl = "http://" & Webhost;//10060
  // end;
  //url = "http://" & "54.228.181.112:80"; //mine test server
  //url = "https://" & "54.228.181.112:443"; //mine test server
    url = "http://" & "54.75.243.183:10600"; //michael server
    //url = "https://" & "54.75.243.183:10601"; //michael server
  returnurl = url & "/WebMPesaPaymentTransactionReply.hal";
  timeouturl = url & "/WebMPesaPaymentTransactionTimeOutReply.hal";
  message = USetStr(41900);
  switch (txtype) begin
    case kCardTransactionRefund:
    case kCardTransactionPay:
      jsr = "";
      GetMPesaInitiator(RepSpec.CurncyCode,initiator,seccred);
      secretcred =  "";
      JSONStringStart(jsr);
      JSONStringAdd(jsr,"InitiatorName","initiator_1");
      JSONStringAdd(jsr,"SecurityCredential",secretcred);
      JSONStringAdd(jsr,"CommandID","BusinessPayment");
      JSONStringAdd(jsr,"Amount","100");
      JSONStringAdd(jsr,"PartyA",CCAccountIDr.MPesaTill);//RepSpec.f1);//601383);
      JSONStringAdd(jsr,"PartyB","254708374149");
      JSONStringAdd(jsr2,"Remarks","B2C Payment Request");
      jsr = jsr &  jsr2;
      JSONStringAdd(jsr,"QueueTimeOutURL",timeouturl);
      JSONStringPut(jsr,"ResultURL",returnurl);
      // JSONStringAdd(jsr,"Occasion",""); 
      JSONStringEnd(jsr);
      AddTextToArea(jsr,a_req);
      auth = GetMPesaToken(CCAccountIDr);
      if (nonblank(auth)) then begin
        tstr = "Authorization: Bearer " & auth;
        SetWebHeaders(tstr);
        SendWebRequest(CCAccountIDr.URL,443,-1,true,"POST","/mpesa//b2c/v1/paymentrequest","application/json","",false,a_req,a_reply,20);
        LogAreaToFile("MPesaPaymentRequestReply" & ".txt",a_reply);
        LogAreaToFile("MPesaPaymentRequestReq" & ".txt",a_req);
        js = ParseJSONArea(a_reply);
        if (JSONGet(js,"ResponseCode")=="0") then begin 
          res = true;
        end else begin
          message = JSONGet(js,"errorMessage");
        end;
      end;
  end;
  MPesaPaymentTransaction = res;
  return;
end;

function string 255 MPesaTimeToString(time t)
begin
  string 255 res;
  
  if (t.hour<10) then begin res = res & "0"; end;
  res = res & t.hour;
  if (t.minute<10) then begin res = res & "0"; end;
  res = res & t.minute;
  if (t.second<10) then begin res = res & "0"; end;
  res = res & t.second;

  MPesaTimeToString = res;
  return;
end;

