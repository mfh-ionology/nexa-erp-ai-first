  CtrlSeq = "2=401" & chr(10) & "3=1" & chr(10) & "99=0";//test this
  //CtrlSeq = "1=1200" & chr(10) & "2=99" & chr(10) & "99=0";
  if (!SendStringOnSocket(messagesocket,CtrlSeq)) then begin
    CloseSocket(messagesocket);
  end;
  return;
end;

global
procedure WorldPayConfirmCall()
begin
  Integer wn,mwn;
  record RcVc RepSpec;
  string 255 CtrlSeq;
  LongInt messagesocket;

  wn = CurWindow;
  DeselectWindow(wn,false);
  GetWindowRecord(wn,RepSpec);
  if (nonblank(RepSpec.f3)) then begin
    messagesocket = RepSpec.long1;
    mwn = MotherWindow(wn);
    CloseWindow(wn);
    TCPIPWorldPay_DisplayStatus(mwn,42419);
    CtrlSeq = "2=400" & chr(10) & "3=0" & chr(10) & "4=" & RepSpec.f3 & chr(10) & "99=0";
    if (!SendStringOnSocket(messagesocket,CtrlSeq)) then begin
      CloseSocket(messagesocket);
    end;
  end else begin
    MessageBox(42431,"");
  end;
  return;
end;

global
procedure WorldPayDeclineCall()
begin
  Integer wn,mwn;
  record RcVc RepSpec;
  string 255 CtrlSeq;
  LongInt messagesocket;

  wn = CurWindow;
  DeselectWindow(wn,false);
  GetWindowRecord(wn,RepSpec);
  messagesocket = RepSpec.long1;
  mwn = MotherWindow(wn);
  CloseWindow(wn);
  TCPIPWorldPay_DisplayStatus(mwn,42428);
