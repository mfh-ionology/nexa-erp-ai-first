external function val AbsoluteVal(val);
remote updating procedure StoreCredCardSlip_VerifoneBanksys3(string,val,string,string,string,string,string,string,string,LongInt,string,Integer,string,var record NotepadVc,var record NotepadVc);
remote procedure IVCashSumup(var record IVCashVc,Boolean);
external procedure IVCashDClass_RefreshStringList(Integer,record IVCashVc);
external function Date DateFromString(string,string);
external procedure LogAreaToFile(string,Area);
external function Boolean FindLocalSerialPortDevice(Integer,LongInt,string,var record LSerialPortDeviceVc);
external function string 255 StrReplace(string,string,string);

function string 255 StripSpaces(string source)
begin
  integer i,l;
  boolean testf;
  string 255 res;
  
  l = len(source);
  for (i=0;i<l;i=i+1) begin
    testf = true;
    if (mid(source,i,1)==" ") then begin
      testf = false;
    end;
    if (testf) then begin
      res = res & mid(source,i,1);
    end;
  end;
  
  StripSpaces = res;
  return;
end;

global
function LongInt TCPIPWorldPayMessageSize(var area reply)
begin
  LongInt pos;
  
  pos = FindStringInArea("99=0",reply);
  if (pos>=0) then begin
    pos = pos + 4;
  end;
  
  TCPIPWorldPayMessageSize = pos;
end;

global
function LongInt TCPIPWorldPayReceiptSize(var area reply)
begin
  LongInt i,res,pos_eot,leng;
  string 255 response,resp,resp2,filename;
  area reply2,ttst,ttst2;

  filename = "TCPIPWorldPayReceiptSize" & Random(1,24) & ".txt";
  pos_eot = FindStringInArea("CUSTOMER:CUSTOMER RECEIPT",reply);
  leng=GetAreaLength(reply)-pos_eot;
  GetAreaFromArea(reply,pos_eot,leng,reply2);
  pos_eot = -1;
  pos_eot = FindStringInArea("AUTH CODE:",reply2);
  if (pos_eot<0) then begin
    pos_eot = FindStringInArea("TRANSACTION VOID",reply2);
  end;
  if (pos_eot>=0) then begin
    res = GetAreaLength(reply);
    goto LTCPIPWorldPayReceiptSize;
  end;

LTCPIPWorldPayReceiptSize:;
  response = AreaToString(reply);
  TCPIPWorldPayReceiptSize = res;
  return;
end;

procedure ParseResponseField(string field,var string fname,var string fvalue)
begin
  LongInt pos;
  string 255 tstr;

  pos = 0;
  GetNextSubstring(field,pos,"=",fname);
  GetNextSubstring(field,pos,"=",fvalue);
  return;
end;

global
procedure TCPIPWorldPay_DisplayStatus(Integer ProcessingWn,LongInt sid)
begin
  record RcVc RepSpec;
//*******TODO Make window unable to be closed nameofthewindow+OnClose(wn,wn2); just return false
  if (nonblank(GetWindowClass(ProcessingWn))) then begin
    GetWindowRecord(ProcessingWn,RepSpec);
    PutWindowString(ProcessingWn,"Status",USetStr(sid));        
    PutWindowRecord(ProcessingWn,RepSpec);
  end;
  return;
end;

procedure SeparateMerchantCustomerReceipts(area receipt,var record NotepadVc merchantNoter,var record NotepadVc customerNoter)
begin
  area merchantReceipt,customerReceipt;
  Integer pos,leng;

  leng = GetAreaLength(receipt);
  pos = FindStringInArea("CUSTOMER:CUSTOMER RECEIPT",receipt);
  GetAreaFromArea(receipt,0,pos,merchantReceipt);
  AddAreaToTextField(merchantReceipt,merchantNoter);
  GetAreaFromArea(receipt,pos,leng,customerReceipt);
  AddAreaToTextField(customerReceipt,customerNoter);
  AddAreaToTextField(customerReceipt,customerNoter);
  return;
end;

updating procedure AddPaymentRow(Integer ProcessingWn,val v,string paymode,string label,string receipt,vector string vreplyfields)
begin
  Integer mwn;
  record IVCashVc IVCr;
  row IVCashVc IVCrw;
  Date td;
  record NotepadVc merchantNoter,customerNoter;
  area a;
  
  mwn = MotherWindow(ProcessingWn);
  if (GetWindowFileName(mwn)=="RcVc") then begin
    mwn = MotherWindow(mwn);
  end;
  switch (GetWindowFileName(mwn)) begin
    case "IVCashVc":
      GetWindowRecord(mwn,IVCr);
      ClearRow(IVCr,IVCrw,kInvoiceRowTypeCreditCardPayment);  
      IVCrw.Sum = v;
      IVCrw.AuthorizationCode = vreplyfields["4"];
      IVCrw.PayMode = paymode;
      IVCrw.Spec = label;
      td = DateFromString(vreplyfields["8"],"DDMMYYYY");
      IVCrw.CCTimestamp = DateToString(td,"YYYYMMDD") & vreplyfields["9"];
      IVCrw.CCTransID = vreplyfields["28"]; //vreplyfields["61"];
      IVCrw.CCReceiptNr = vreplyfields["36"];
      MatRowPut(IVCr,MatRowCnt(IVCr),IVCrw);
      IVCashSumup(IVCr,true);
      PutWindowRecord(mwn,IVCr);
      IVCashDClass_RefreshStringList(mwn,IVCr);
      if (WindowDoOK(mwn,0)) then begin
        if (len(receipt)>0) then begin
          AddTextToArea(receipt,a);
          SeparateMerchantCustomerReceipts(a,merchantNoter,customerNoter);
          AddAreaToTextField(a,merchantNoter);
          StoreCredCardSlip_VerifoneBanksys3("A",v,vreplyfields["28"],vreplyfields["36"],vreplyfields["4"],IVCrw.CCTimestamp,"","","",IVCr.SerNr,"IVCashVc",0,IVCr.LocalMachineCode,merchantNoter,customerNoter);
        end;
        TCPIPWorldPay_DisplayStatus(ProcessingWn,27384);
      end;
  end;
  return;
end;

updating procedure WorldPayTransactionDeclined(Integer ProcessingWn,val v,string paymode,string label,string receipt,vector string vreplyfields, Integer DisplayStat)
begin
  record IVCashVc IVCr;
  row IVCashVc IVCrw;
  Date td;
  record NotepadVc merchantNoter,customerNoter;
  area a;

  td = DateFromString(vreplyfields["8"],"DDMMYYYY");
  IVCrw.CCTimestamp = DateToString(td,"YYYYMMDD") & vreplyfields["9"];
  if (len(receipt)>0) then begin
    AddTextToArea(receipt,a);
    SeparateMerchantCustomerReceipts(a,merchantNoter,customerNoter);
    AddAreaToTextField(a,merchantNoter);
    StoreCredCardSlip_VerifoneBanksys3("V",v,vreplyfields["28"],vreplyfields["36"],vreplyfields["4"],IVCrw.CCTimestamp,"","","",IVCr.SerNr,"IVCashVc",0,IVCr.LocalMachineCode,merchantNoter,customerNoter);
  end;
  TCPIPWorldPay_DisplayStatus(ProcessingWn,DisplayStat);
  return;
end;

global
procedure WorldPayConfirmSignature()
begin
  Integer wn,mwn;
  record RcVc RepSpec;
  string 255 CtrlSeq;
  LongInt messagesocket;

  wn = CurWindow;
  DeselectWindow(wn,false);
  GetWindowRecord(wn,RepSpec);
  messagesocket = RepSpec.long1;
  mwn = MotherWindow(wn);
  CloseWindow(wn);
  TCPIPWorldPay_DisplayStatus(mwn,42429);
  CtrlSeq = "2=401" & chr(10) & "3=0" & chr(10) & "99=0";
  if (!SendStringOnSocket(messagesocket,CtrlSeq)) then begin
    CloseSocket(messagesocket);
  end;
  return;
end;

global
procedure WorldPayDeclineSignature()
begin
  Integer wn,mwn;
  record RcVc RepSpec;
  string 255 CtrlSeq;
  LongInt messagesocket;

  wn = CurWindow;
  DeselectWindow(wn,false);
  GetWindowRecord(wn,RepSpec);
  messagesocket = RepSpec.long1;
