
global
procedure TestRn(record RcVc RepSpec)
begin
  LongInt i;
  
  StartReportJob("Test Report");
  
  Header(1,"Runs for " & RepSpec.long1 & " seconds",1);
  EndHeader;
  
  for (i = 0; i<RepSpec.long1; i = i + 1) begin
    StartFormat(15);
    OutString(20,0,"Number " & i,false);
    EndFormat;
    Sleep(1);
  end;
  
  EndJob;
end;
