global
updating procedure RepWClass_AIChat()
begin
  string 255 model,instruction;
  array string 255 roles,messages;
  LongInt wn;
  record AIChatVc AICr;
  
  wn = CurWindow;
  
  //AI_GetModel("llama-2-7b-chat/ggml-model-q4_0.gguf",model);
  
  instruction =               "### Instruction " & NL & NL;
  instruction = instruction & "You are a helpful AI assistant called Anna. You answer questions shortly, correctly, and precisely" & NL;
  instruction = instruction & "Do not explain how you come to an answer, simply give the answer" & NL;
  instruction = instruction & "You are are helping the user to analyze a report" & NL;
  instruction = instruction & NL;
  instruction = instruction & "### Report " & NL & NL;
  instruction = instruction & ReportWindowToText(wn);
  instruction = instruction & "### Questions and Answers " & NL & NL;

  AICr.Instruction = instruction;
  AICr.DisclaimerFlag = 0;
  AICr.InstructionFlag = 0;
  AICr.AIModel = "llama-2-13b-chat/ggml-model-q4_0.gguf";
  
  OpenWindow("LlamaChatWClass",0,0,"","",AICr);

/*
  LLM_Init(model,instruction,"");
  
  AIChat_AddMessage(roles,messages,"instruction",instruction);
  AIChat_StoreWn(wn,roles,messages,false);
*/
end;
