function Boolean IsCloudController()
begin
  Boolean res;
  record CloudSettingsBlock CSb;

  BlockLoad(CSb);
  if (CSb.ServerIsCloudController==kServerTypeCloudController) then begin
    res = true;
  end;

  IsCloudController = res;
  return;
end;

