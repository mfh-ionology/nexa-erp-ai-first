procedure CheckHansaVersionsQuick(string args)
begin
  //SemaphoreWait("DownloadVersions");
  
  if (CountRecords("HansaVersionVc")<1000) then begin
    LogText(0,"CheckHansaVersionsQuick, forcing full check, no. versions: " & CountRecords("HansaVersionVc"));
    DownloadNewVersionsForCx(true,true);
  end else begin
//    LogText(0,"CheckHansaVersionsQuick no. versions: " & CountRecords("HansaVersionVc"));
    DownloadNewVersionsForCx(false,true);
  end;
  
  //SemaphorePost("DownloadVersions");
  return;
end;

