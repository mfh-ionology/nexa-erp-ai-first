global
updating procedure RestartRemoteCloudServer(record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  record RemoteCloudServerVc OldRCSr;
  record CloudNodeVc CNr;

  RecordCopy(OldRCSr,RCSr);
  RCSr.WantedStatus = kWantedStatusRestart;
  RecordUpdate(OldRCSr,RCSr,true);
  SyncOneRCS(RCSr,true,true,"7");
  threadasync.ClearQuickRestartsOnNode(RCSr);
  SetCloudControllerStatus(kJobStatusRunning,"Restarting cloud server " & RCSName(RCSr));
  return;
end;

global
procedure RestartRemoteCloudServers(array uuid recarr)
begin
  record RemoteCloudServerVc RCSr;
  Integer i;
  Boolean testf;

  i = 0;
  for (i = 0; i<recarr.length; i = i + 1) begin
    RCSr.UUID = recarr[i];
    if (ReadFirstMain(RCSr,1,true)) then begin
      testf = true;
      if (RCSr.Closed!=0) then begin testf = false; end;
      if (testf) then begin
        qupdating.RestartRemoteCloudServer(RCSr);
      end else begin
        SetCloudControllerStatus(kJobStatusWarning,"Ignoring restart command for cloud server " & RCSName(RCSr));
      end;
    end;
  end;
end;

global
updating procedure StartRemoteCloudServers(array uuid recarr,Boolean maintf)
begin
  record RemoteCloudServerVc RCSr;
  record RemoteCloudServerVc oRCSr;
  Integer i;

  for (i = 0; i<recarr.length; i = i + 1) begin
    RCSr.UUID = recarr[i];
    if (ReadFirstMain(RCSr,1,true)) then begin
      StartRemoteCloudServer(RCSr,maintf);
    end;
  end;
  return;
end;

global
function LongInt CanStopRemoteCloudServer(record RemoteCloudServerVc RCSr)
begin
  record LocalCloudServerVc LCSr;
  LongInt res;
  string 255 url;
  LongInt stat;
  Boolean scfailf;

  res = 0;

  url = RcsNodeURL(RCSr);
  if (blank(url)) then begin goto LCanStopRemoteCloudServer; end;
  if (RCSr.Closed!=0) then begin goto LCanStopRemoteCloudServer; end;
  if ((RCSr.CurrentStatus!=kStatusRunning) and
      (RCSr.CurrentStatus!=kStatusMaintenance) and
      (RCSr.CurrentStatus!=kStatusRunningPendingStop) and
      (RCSr.CurrentStatus!=kStatusRunningTest)) then begin
    goto LCanStopRemoteCloudServer;
  end;

  LCSr.UUID = RCSr.UUID;
  stat = CallService(url).ActiveServerUsers(LCSr,false,res);
  scfailf = TreatServiceError(stat,url,"ActiveServerUsers");
  queued.SaveCloudNodeReachable(RCSr.Controller,!scfailf);
  if (scfailf) then begin
    res = -1;
    LogText(0,"Failed counting active server users on " & RCSName(RCSr));
    SetCloudControllerStatus(kJobStatusError,"Failed counting active server users on " & RCSName(RCSr));
  end;

LCanStopRemoteCloudServer:;
  LogText2(0,"CanStopRemoteCloudServer res = " & res,kVerbosityDebugDetailed);
  CanStopRemoteCloudServer = res;
  return;
end;

global
updating procedure StopRemoteCloudServers(array uuid recarr,Boolean forcef)
begin
  record RemoteCloudServerVc RCSr;
  Integer i;

  for (i = 0; i<recarr.length; i = i + 1) begin
    RCSr.UUID = recarr[i];
    if (ReadFirstMain(RCSr,1,true)) then begin
      StopRemoteCloudServer(RCSr,forcef);
    end;
  end;
  UpdateClientBrowsesIfNeeded("RemoteCloudServerVc");
  return;
end;

global
procedure StopRemoteCloudServers2(array uuid recarr)
begin
  record RemoteCloudServerVc RCSr;
  Integer i;
  LongInt usercnt,l;

  usercnt = 0;
  for (i = 0; i<recarr.length; i = i + 1) begin
    RCSr.UUID = recarr[i];
    if (ReadFirstMain(RCSr,1,true)) then begin
      l = CanStopRemoteCloudServer(RCSr);
      if (l==-1) then begin
        SetCloudControllerStatus(kJobStatusWarning,"Ignoring stop command for server " & RCSName(RCSr));
        goto LStopRemoteCloudServers2;
      end;
      usercnt = usercnt + l;
    end;
  end;

  if (usercnt>0) then begin
    clientremoteasync.StopRemoteCloudServers2_Reply(recarr,usercnt);
  end else begin
    qupdating.StopRemoteCloudServers(recarr,false);
  end;

LStopRemoteCloudServers2:;
  return;
end;

global
procedure SoftStopLocalCloudServer(record LocalCloudServerVc LCSr,string user,string message,Integer mins,var Boolean res)
begin
  area a_enact;

  res = false;

  if (ReadFirstMain(LCSr,1,true)==false) then begin
    goto LSoftStopLocalCloudServer;
  end;

  CreateFolderHierarchy(EnablerActionsFolder(LCSr) & "/");
  AddLineToArea(user,a_enact);
  AddLineToArea(message,a_enact);
  AddLineToArea("" & mins,a_enact);
  WriteAreaToFile(a_enact,EnablerActionsFolder(LCSr) & "/EnSendMsg",0);
  res = true;

LSoftStopLocalCloudServer:;
  return;
end;

global
function Boolean SoftStopRemoteCloudServer(record RemoteCloudServerVc RCSr,string user,string message,Integer mins)
begin
  record LocalCloudServerVc LCSr;
  Boolean res;
  string 255 url;
  LongInt stat;
  Boolean scfailf;

  url = RcsNodeURL(RCSr);
  if (blank(url)) then begin goto LSoftStopRemoteCloudServer; end;
  if (RCSr.Closed!=0) then begin goto LSoftStopRemoteCloudServer; end;
  if ((RCSr.CurrentStatus!=kStatusRunning) and
      (RCSr.CurrentStatus!=kStatusConfigInError) and
      (RCSr.CurrentStatus!=kStatusMaintenance) and
      (RCSr.CurrentStatus!=kStatusRunningPendingStop) and
      (RCSr.CurrentStatus!=kStatusRunningTest)) then begin
    SetCloudControllerStatus(kJobStatusError,"Server " & RCSName(RCSr) & " couldn't be stopped because it isn't running");
    goto LSoftStopRemoteCloudServer;
  end;

  LCSr.UUID = RCSr.UUID;
  stat = CallService(url).SoftStopLocalCloudServer(LCSr,user,message,mins,res);
  scfailf = TreatServiceError(stat,url,"SoftStopLocalCloudServer");
  queued.SaveCloudNodeReachable(RCSr.Controller,!scfailf);
  if (scfailf) then begin
    queued.StopRemoteCloudServer(RCSr,false);
    goto LSoftStopRemoteCloudServer;
  end;

  res = true;

LSoftStopRemoteCloudServer:;
  SoftStopRemoteCloudServer = res;
  return;
end;

global
procedure SoftStopRemoteCloudServers(array uuid recarr,string message,Integer mins)
begin
  record RemoteCloudServerVc RCSr;
  Boolean testf;
  LongInt usercnt;
  Integer i;
  record UserVc Userr;

  DoGetCurUser(Userr);

  for (i = 0; i<recarr.length; i = i + 1) begin
    RCSr.UUID = recarr[i];
    if (ReadFirstMain(RCSr,1,true)) then begin
      testf = SoftStopRemoteCloudServer(RCSr,Userr.Name,message,mins);
      if (testf==false) then begin
        SetCloudControllerStatus(kJobStatusError,"Server " & RCSName(RCSr) & " couldn't be stopped, failed communicating with node " & RCSr.Controller);
      end else begin
        SetCloudControllerStatus(kJobStatusRunning,"Requesting soft stop of server " & RCSName(RCSr));
      end;
    end;
  end;
  return;
end;

function Boolean IsChildSystem(record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  record RemoteCloudServerVc RCS2r;
  row RemoteCloudServerVc RCSrw;
  LongInt rwcnt,rwn;
  string 255 url,tstr;

  rwcnt = MatRowCnt(RCSr);
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(RCSr,rwn,RCSrw);
    if (RCSrw.Item==kManagedServerItemMotherSystem and RCSrw.Disabled==0) then begin
      RCS2r.UUID = StringToUUID(RCSrw.ItemName);
      if (ReadFirstMain(RCS2r,1,true)) then begin
        res = true;
      end;
    end;
  end;
  
LIsChildSystem:;
  IsChildSystem = res;
  return;
end;

global
updating procedure DoCloseRemoteCloudServer(var record RemoteCloudServerVc RCSr)
begin
  record RemoteCloudServerVc OldRCSr,RCS2r,OldRCS2r;
  
  RecordCopy(OldRCSr,RCSr);
  if (IsChildSystem(RCSr)) then begin
    RCS2r.UUID = MotherSystemUUID(RCSr);
    if (ReadFirstMain(RCS2r,1,true)) then begin
      RecordCopy(OldRCS2r,RCS2r);
      RemoveManagedServerItemByName(RCS2r,RCSr.UUID);
      if (ComparePosts(OldRCS2r,RCS2r)==false) then begin
        RecordUpdate(OldRCS2r,RCS2r,true);
      end;
    end;
  end;
  RCSr.Closed = 1;
  if (ComparePosts(OldRCSr,RCSr)==false) then begin
    RecordUpdate(OldRCSr,RCSr,true);
  end;
  
  return;
end;

global
updating procedure RemoveOneCloudNodeAction(LongInt sernr)
begin
  record CloudNodeActionQueueVc CNAQr;

  if (sernr>0) then begin
    CNAQr.SerNr = sernr;
    if (ReadFirstMain(CNAQr,1,true)) then begin
      RecordDelete(CNAQr);
      UpdateClientBrowsesIfNeeded("CloudNodeActionQueueVc");
    end;
  end;
  
  return;
end;

global
updating procedure SetServerMoveDoneFlagIfNeeded(var record ServerMoveVc SMr)
begin
  record ServerMoveVc OldSMr;
  record CloudNodeActionQueueVc CNAQr;
  
  CNAQr.Action = kCloudActionStartMoveServer;
  CNAQr.LongParam1 = SMr.SerNr;
  if (ReadFirstKey("ActionLongParam1",CNAQr,2,true)) then begin goto LSetServerMoveDoneFlagIfNeeded; end;
  
  CNAQr.Action = kCloudActionEndMoveServer;
  CNAQr.LongParam1 = SMr.SerNr;
  if (ReadFirstKey("ActionLongParam1",CNAQr,2,true)) then begin goto LSetServerMoveDoneFlagIfNeeded; end;
  
  CNAQr.Action = kCloudActionFinishMoveServer;
  CNAQr.LongParam1 = SMr.SerNr;
  if (ReadFirstKey("ActionLongParam1",CNAQr,2,true)) then begin goto LSetServerMoveDoneFlagIfNeeded; end;
  
  if (ReadFirstMain(SMr,1,true)) then begin
    RecordCopy(OldSMr,SMr);
    SMr.DoneDate = CurrentDate;
    SMr.DoneTime = CurrentTime;
    SMr.DoneFlag = 1;
    RecordUpdate(OldSMr,SMr,true);
    UpdateClientBrowsesIfNeeded("ServerMoveVc");
  end;

LSetServerMoveDoneFlagIfNeeded:;
  return;
end;

global
updating procedure IncreaseServerMovePendingCount(var record ServerMoveVc SMr)
begin
  record ServerMoveVc OldSMr;

  if (ReadFirstMain(SMr,1,true)) then begin
    RecordCopy(OldSMr,SMr);
    if (SMr.PendingServerCount>0) then begin
      SMr.PendingServerCount = SMr.PendingServerCount + 1;
    end else begin
      SMr.PendingServerCount = 1;
    end;
    RecordUpdate(OldSMr,SMr,true);
    UpdateClientBrowsesIfNeeded("ServerMoveVc");
  end;
  
  return;
end;

global
updating procedure DecreaseServerMovePendingCount(var record ServerMoveVc SMr)
begin
  record ServerMoveVc OldSMr;

  if (ReadFirstMain(SMr,1,true)) then begin
    RecordCopy(OldSMr,SMr);
    if (SMr.PendingServerCount>1) then begin
      SMr.PendingServerCount = SMr.PendingServerCount - 1;
    end else begin
      SMr.PendingServerCount = 0;
    end;
    RecordUpdate(OldSMr,SMr,true);
    UpdateClientBrowsesIfNeeded("ServerMoveVc");
  end;
  
  return;
end;

global
updating procedure IncreaseServerMoveFailedCount(var record ServerMoveVc SMr)
begin
  record ServerMoveVc OldSMr;

  if (ReadFirstMain(SMr,1,true)) then begin
    RecordCopy(OldSMr,SMr);
    if (SMr.FailedServerCount>0) then begin
      SMr.FailedServerCount = SMr.FailedServerCount + 1;
    end else begin
      SMr.FailedServerCount = 1;
    end;
    RecordUpdate(OldSMr,SMr,true);
    UpdateClientBrowsesIfNeeded("ServerMoveVc");
  end;
  
  SetServerMoveDoneFlagIfNeeded(SMr);
  
  return;
end;

global
updating procedure IncreaseServerMoveClosedCount(var record ServerMoveVc SMr)
begin
  record ServerMoveVc OldSMr;

  if (ReadFirstMain(SMr,1,true)) then begin
    RecordCopy(OldSMr,SMr);
    if (SMr.ClosedServerCount>0) then begin
      SMr.ClosedServerCount = SMr.ClosedServerCount + 1;
    end else begin
      SMr.ClosedServerCount = 1;
    end;
    RecordUpdate(OldSMr,SMr,true);
    UpdateClientBrowsesIfNeeded("ServerMoveVc");
  end;
  
  SetServerMoveDoneFlagIfNeeded(SMr);
  
  return;
end;

global
updating procedure IncreaseServerMoveCompletedCount(var record ServerMoveVc SMr)
begin
  record ServerMoveVc OldSMr;

  if (ReadFirstMain(SMr,1,true)) then begin
    RecordCopy(OldSMr,SMr);
    if (SMr.CompletedServerCount>0) then begin
      SMr.CompletedServerCount = SMr.CompletedServerCount + 1;
    end else begin
      SMr.CompletedServerCount = 1;
    end;
    RecordUpdate(OldSMr,SMr,true);
    UpdateClientBrowsesIfNeeded("ServerMoveVc");
  end;
  
  SetServerMoveDoneFlagIfNeeded(SMr);
  
  return;
end;

global
updating procedure NodeCancelledArchivingOfServer(UUID server_uuid,LongInt reason)
begin
  record RemoteCloudServerVc RCSr;
  record ServerArchivingQueueVc SAQr;
  record ServerMoveVc SMr;
  record CloudNodeActionQueueVc CNAQr;
  Boolean foundf;

  foundf = true;
  CNAQr.Action = kCloudActionEndMoveServer;
  while (LoopKey("ActionLongParam1",CNAQr,1,foundf)) begin
    if (CNAQr.Action!=kCloudActionEndMoveServer) then begin foundf = false; end;
    if (foundf) then begin
      if (CNAQr.UUIDParam1==server_uuid) then begin
        SMr.SerNr = CNAQr.LongParam1;
        if (ReadFirstMain(SMr,1,true)) then begin
          if (reason==kCloudArchivingErrorServerGone) then begin
            RCSr.UUID = server_uuid;
            if (ReadFirstMain(RCSr,1,true)) then begin
              UpdateRCSController(RCSr,SMr.ToController);
              IncreaseServerMoveCompletedCount(SMr);
              AddLineToServerMoveLog(SMr,"The Cloud Node cancelled archiving of server with UUID " & server_uuid & " because the data folder was gone, moving anyway");
            end else begin
              IncreaseServerMoveFailedCount(SMr);
              AddLineToServerMoveLog(SMr,"The Cloud Node cancelled archiving of server with UUID " & server_uuid & ", record not found");
            end;
          end else begin
            IncreaseServerMoveFailedCount(SMr);
            AddLineToServerMoveLog(SMr,"The Cloud Node cancelled archiving of server with UUID " & server_uuid);
          end;
        end;
        RemoveOneCloudNodeAction(CNAQr.SerNr);
        DecreaseServerMovePendingCount(SMr);
        goto LNodeCancelledArchivingOfServer_cancel;
      end;
    end;
  end;

  RCSr.UUID = server_uuid;
  if (ReadFirstMain(RCSr,1,true)) then begin
    DoCloseRemoteCloudServer(RCSr);
  end;
  
LNodeCancelledArchivingOfServer_cancel:;
  SAQr.ServerUUID = server_uuid;
  if (ReadFirstMain(SAQr,1,true)) then begin
    RecordDelete(SAQr);
  end;
  
  return;
end;

global
updating procedure CloseRemoteCloudServers(array uuid recarr)
begin
  record RemoteCloudServerVc RCSr;
  Integer i;
  Boolean testf;
  
  for (i = 0; i<recarr.length; i = i + 1) begin
    RCSr.UUID = recarr[i];
    if (ReadFirstMain(RCSr,1,true)) then begin
      testf = AllowCloseRemoteCloudServer(RCSr);
      if (testf) then begin
        DoCloseRemoteCloudServer(RCSr);
      end;
    end;
  end;
  return;
end;

global
updating procedure DoUnCloseRemoteCloudServer(uuid rcsid)
begin
  record RemoteCloudServerVc RCSr;
  record RemoteCloudServerVc OldRCSr;
  Integer i;
  Boolean testf;
  
  RCSr.UUID = rcsid;
  if (ReadFirstMain(RCSr,1,true)) then begin
    RecordCopy(OldRCSr,RCSr);
    RCSr.Closed = 0;
    RCSr.ShouldCloseFlag = 0;
    RCSr.ClosedOnNodeFlag = 0;
    RecordUpdate(OldRCSr,RCSr,false);
  end;
  return;
end;

global
updating procedure DoUnCloseLocalCloudServer(uuid server_uuid)
begin
  record LocalCloudServerVc LCSr;
  record LocalCloudServerVc OldLCSr;
  Integer i;
  Boolean testf;
  
  LCSr.UUID = server_uuid;
  if (ReadFirstMain(LCSr,1,true)) then begin
    RecordCopy(OldLCSr,LCSr);
    LCSr.Closed = 0;
    LCSr.ShouldCloseFlag = 0;
    LCSr.ClosedOnNodeFlag = 0;
    RecordUpdate(OldLCSr,LCSr,false);
  end;
  return;
end;

global
procedure UnCloseRemoteCloudServers(array uuid recarr)
begin
  record RemoteCloudServerVc RCSr;
  record RemoteCloudServerVc OldRCSr;
  Integer i;
  string 255 url;
  LongInt stat;
  Boolean scfailf;

  for (i = 0; i<recarr.length; i = i + 1) begin
    RCSr.UUID = recarr[i];
    if (ReadFirstMain(RCSr,1,true)) then begin
      if (RCSr.Closed==1 and nonblank(RCSr.Controller)) then begin
        qupdating.DoUnCloseRemoteCloudServer(recarr[i]);
        url = RcsNodeURL(RCSr);
        stat = CallService(url).DoUnCloseLocalCloudServer(recarr[i]);
        scfailf = TreatServiceError(stat,url,"DoUnCloseLocalCloudServer");
        queued.SaveCloudNodeReachable(RCSr.Controller,!scfailf);
      end;
    end;
  end;
  
  return;
end;

function Boolean IsAvailNewVersionImportFile(string filename)
begin
  Boolean res;
  
  res = false;
  
  if (Right(filename,12)!=".version.txt") then begin goto LIsAvailNewVersionImportFile; end;
  
  res = true;
  
LIsAvailNewVersionImportFile:;
  IsAvailNewVersionImportFile = res;
end;

function Boolean HasServersInVersionIndex(string indexname,string vercode)
begin
  Boolean res;
  record LocalCloudServerVc LCSr;
  string 255 tstr;

  switch (indexname) begin
    case "HansaVersion":    LCSr.HansaVersion = vercode;
    case "NewHansaVersion": LCSr.NewHansaVersion = vercode;
    case "OldHansaVersion": LCSr.OldHansaVersion = vercode;
    otherwise
      goto LHasServersInVersionIndex;
  end;
  res = ReadFirstKey(indexname,LCSr,1,true);

LHasServersInVersionIndex:;
  HasServersInVersionIndex = res;
  return;
end;

global
function Boolean IsVersionInUse(string vercode)
begin
  Boolean res,foundf;
  record LocalCloudServerVc LCSr;
  record CloudSettingsBlock CSb;

  res = true;
  if (ShouldDownloadVersion(vercode)) then begin goto LIsVersionInUse; end;
  if (IsDownloadingVersion(vercode)) then begin goto LIsVersionInUse; end;

  if (HasServersInVersionIndex("HansaVersion",vercode)) then begin goto LIsVersionInUse; end;
  if (HasServersInVersionIndex("NewHansaVersion",vercode)) then begin goto LIsVersionInUse; end;
  
  if (IsDevelopmentVersion(vercode)==false) then begin
    if (HasServersInVersionIndex("OldHansaVersion",vercode)) then begin goto LIsVersionInUse; end;
  end;

  BlockLoad(CSb);
  if (CSb.HansaVersion==vercode) then begin goto LIsVersionInUse; end;
  if (CSb.NewHansaVersion==vercode) then begin goto LIsVersionInUse; end;

  res = false;

LIsVersionInUse:;
  IsVersionInUse = res;
  return;
end;

global
updating function Boolean CloudControllerCreateNewVersionIfNeeded(string vcode,string vname,LongInt vno,LongInt vsubno,LongInt vbuild,LongInt vptyp,string vpcode)
begin
  string 255 vfolder,newvfolder;
  record HansaVersionVc HV2r;
  transaction record HansaVersionVc HVr;
  transaction record HansaVersionVc OldHVr;
  Boolean res;
  area a_req;
  LongInt vrepubcount;
  LongInt old_version_build,new_version_build,next_version_build;
  transaction string 255 version_to_download;
  transaction string 255 server,path,destpath;
  transaction LongInt port;
  transaction Boolean checkonlyf;
  Boolean okverf;

  if (IsDownloadingVersion(vcode)) then begin
    goto LCloudControllerCreateNewVersionIfNeeded;
  end;

  HVr.Code = vcode;
  if (ReadFirstMain(HVr,1,true)==true) then begin
    if ((HVr.Closed!=0) or (HVr.CurrentState==kHansaVersionStateUnavailable)) then begin
      if ((HVr.AdditionalPlatform==ProgramPlatform) or (HVr.AdditionalPlatform!=kPlatformLinux64)) then begin
        res = true;
        goto LCloudControllerCreateNewVersionIfNeeded;
      end;
    end;
    RecordCopy(OldHVr,HVr);
  end else begin
    RecordClear(OldHVr);
    RecordClear(HVr);
    HVr.Code = vcode;
    HVr.RePubCount = 0;
  end;

  vfolder = VersionsFolder & vcode;

  HVr.Name = vname;
  HVr.Version = vno;
  HVr.SubVersion = vsubno;
  HVr.RunningBuild = vbuild;
  HVr.ProgramType = vptyp;
  HVr.ProgramFolder = vfolder;
  HVr.ProductCode = vpcode;

  if (nonblank(OldHVr.Code) and (OldHVr.CurrentState!=kHansaVersionStateError)) then begin
    old_version_build = (OldHVr.Version * 1000000) + (OldHVr.SubVersion * 10000) + OldHVr.RunningBuild;
    new_version_build = (HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild;
    next_version_build = (OldHVr.NextVersion * 1000000) + (OldHVr.NextSubVersion * 10000) + OldHVr.NextRunningBuild;
    if ((OldHVr.CurrentState!=kHansaVersionStateUpdating) and (OldHVr.CurrentState!=kHansaVersionStateInstalling)) then begin
      if (OldHVr.CurrentState!=kHansaVersionStateNotDownloaded) then begin
        if (OldHVr.ForceReplaceVersionf!=0) then begin
          if (DirExists(HVr.ProgramFolder)==true) then begin
            SetHansaVersionState(HVr,kHansaVersionStateOld);
          end else begin
            SetHansaVersionState(HVr,kHansaVersionStateNotDownloaded);
          end;
        end else begin
          if (DirExists(HVr.ProgramFolder)==true) then begin
            SetHansaVersionState(HVr,kHansaVersionStateNormal);
          end else begin
            SetHansaVersionState(HVr,kHansaVersionStateNotDownloaded);
          end;
        end;
      end;
    end;
  end else begin
    SetHansaVersionState(HVr,kHansaVersionStateNotDownloaded);
  end;

  if (((OldHVr.ForceReplaceVersionf!=0) or (HVr.CurrentState==kHansaVersionStateNotDownloaded)) and
      IsDownloadingVersion(HVr.Code)==false and IsVersionInUse(HVr.Code)) then begin
    SetShouldDownloadVersion(HVr.Code,true);
  end;

  if (nonblank(version_to_download)) then begin
    if (ShouldDownloadVersion(vcode)==false) then begin
      res = true;
      goto LCloudControllerCreateNewVersionIfNeeded;
    end;
  end;

  if ((checkonlyf==true) and (ShouldDownloadVersion(vcode)==false)) then begin
    res = true;
    goto LCloudControllerCreateNewVersionIfNeeded;
  end;

  server = VersionPackagesServer;
  port = VersionPackagesPort;
  path = "/downloads/cloud_packages/" & vcode & ".ha";

  destpath = vfolder & ".download";
  DeleteFolder(destpath);

  if (nonblank(OldHVr.Code)) then begin
    old_version_build = (OldHVr.Version * 1000000) + (OldHVr.SubVersion * 10000) + OldHVr.RunningBuild;
    new_version_build = (HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild;
    okverf = CheckVersion(OldHVr);
    if ((old_version_build<new_version_build) or (OldHVr.ForceReplaceVersionf!=0) or
        (HVr.CurrentState==kHansaVersionStateError) or
        (HVr.CurrentState==kHansaVersionStateNotDownloaded) or (okverf==false)) then begin
      if (new_version_build<85350335) then begin
        if (ProgramPlatform==kPlatformLinuxArm64 and HVr.AdditionalPlatform!=kPlatformLinux64) then begin
          SetDownloadingVersion(HVr.Code,false);
          SetShouldDownloadVersion(HVr.Code,false);
          goto LCloudControllerCreateNewVersionIfNeeded;
        end;
      end;
      if (IncreaseVmLong("downloadversions",3)) then begin // max 3 at the time
        if (IsCloudController) then begin
          if (GetGlobalBoolean("update_after_download")) then begin
            SetCloudControllerStatus(kJobStatusRunning,"Downloading new version for Cloud Controller (" & new_version_build & ")");
          end;
        end;
        LogText(0,"Downloading http://" & server & ":" & port & path);
        vrepubcount = OldHVr.RePubCount;
        vrepubcount = vrepubcount + 1;
        HVr.RePubCount = vrepubcount;
        SetDownloadingVersion(HVr.Code,true);
        if (HVr.CurrentState==kHansaVersionStateNotDownloaded) then begin
          SetHansaVersionState(HVr,kHansaVersionStateInstalling);
        end else begin
          SetHansaVersionState(HVr,kHansaVersionStateUpdating);
        end;
        HttpAsyncDownloadHA(server,port,path,30,destpath,"HttpAsyncDownloadHACallback");
      end;
    end else begin
      if (IsCloudController) then begin
        if (GetGlobalBoolean("update_after_download")) then begin
          SetCloudControllerStatus(kJobStatusWarning,"Cloud Controller update cancelled, no new version is available (latest version is " & new_version_build & ", running version is " & VersionBuild);
        end;
      end else begin
        if (GetGlobalBoolean("update_after_download")) then begin
          if (VersionBuild<new_version_build) then begin
            if (CheckVersion(HVr)==false) then begin
              SetCloudControllerStatus(kJobStatusError,"ERROR: Cloud Controller couldn't be updated to version " & new_version_build & ", it might be corrupt");
              SetHansaVersionState(HVr,kHansaVersionStateError);
            end else begin
              LogText(0,"Updating node from version " & VersionBuild & " to " & HVr.Code & " (" & new_version_build & ")");
              SetCloudControllerStatus(kJobStatusRunning,"Updating Cloud Controller from version " & VersionBuild & " to " & new_version_build);
              UpdateToVersion_WTF(HVr);
              goto LCloudControllerCreateNewVersionIfNeeded;
            end;
          end;
        end;
      end;
      LogText(0,"Skipping " & HVr.Code & " because my version>=available version (" & old_version_build & ">=" & new_version_build & ")");
      SetDownloadingVersion(vcode,false);
      SetShouldDownloadVersion(vcode,false);
    end;
  end else begin
    new_version_build = (HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild;
    if (new_version_build<85350335) then begin
      if (ProgramPlatform==kPlatformLinuxArm64) then begin
        SetDownloadingVersion(HVr.Code,false);
        SetShouldDownloadVersion(HVr.Code,false);
        goto LCloudControllerCreateNewVersionIfNeeded;
      end;
    end;
//    LogText(0,"DEBUG Downloading " & new_version_build & ", code=" & HVr.Code);
    if (IncreaseVmLong("downloadversions",3)) then begin // max 3 at the time
      if (GetGlobalBoolean("update_after_download")) then begin
        SetCloudControllerStatus(kJobStatusRunning,"Downloading new version for Cloud Controller (" & new_version_build & ")");
      end;
      LogText(0,"Downloading http://" & server & ":" & port & path);
      SetDownloadingVersion(HVr.Code,true);
      SetHansaVersionState(HVr,kHansaVersionStateInstalling);
      HttpAsyncDownloadHA(server,port,path,30,destpath,"HttpAsyncDownloadHACallback");
    end else begin
      SetDownloadingVersion(HVr.Code,false);
    end;
  end;

  res = true;

LCloudControllerCreateNewVersionIfNeeded:;
  CloudControllerCreateNewVersionIfNeeded = res;
  return;
end;

global
procedure DownloadNewVersionsForCx(Boolean fullf,Boolean acheckonly)
begin
  Integer wn;
  Integer err;
  area a_req;
  area a_reply;
  string 255 server,path,callback;
  LongInt port;
  transaction string 255 version_to_download,allversions_urlstr;
  transaction Boolean checkonlyf;
  string 255 url;
  
  LogText2(0,"DownloadNewVersionsForCx(" & fullf & "," & acheckonly & ") starting, versions: " & CountRecords("HansaVersionVc"),kVerbosityDebugDetailed);
  
  checkonlyf = acheckonly;
  server = VersionPackagesServer;
  port = VersionPackagesPort;
  
  
  if (fullf or (GetGlobalBoolean("DownloadNewVersions_NotFirstTime")!=true)) then begin
    path = "/downloads/cloud_packages/allversions.txt";
    callback = "DownloadNewVersionsForCxReply";
    if (GetVmString("AllVersionsModified")!="") then begin
      SetWebHeaders("If-Modified-Since: " & GetVmString("AllVersionsModified"));
    end;
    SetGlobalBoolean("DownloadNewVersions_NotFirstTime",true);
  end else begin
    path = "/downloads/cloud_packages/allversions_last.txt";
    callback = "DownloadNewVersionsForCxReplyLastRows";
    if (GetVmString("AllVersionsLastrowsModified")<>"") then begin
      SetWebHeaders("If-Modified-Since: " & GetVmString("AllVersionsLastrowsModified"));
    end;
  end;
  
  allversions_urlstr = "http://" & VersionPackagesServer & ":" & VersionPackagesPort & path;
  
  // url = "http://127.0.0.1:8080/allversions.txt";
  // callback = "DownloadNewVersionsForCxReply";
  
  SetDownloadingVersion("AllVersionsTag",true);

  LogText2(0,"Downloading list of available versions from " & allversions_urlstr,kVerbosityDebugDetailed);
  SendAsyncWebRequest(server,port,-1,false,"GET",path,"text/xml; charset=""utf-8""","",a_req,callback,30);

LDownloadNewVersionsForCx:;
  //UpdateClientBrowsesIfNeeded("HansaVersionVc");
  return;
end;

global
updating procedure DownloadNewVersionsForCx_Old(Boolean fullf,Boolean acheckonly)
begin
  Integer wn;
  Integer err;
  record HansaVersionVc HVr;
  record HansaVersionVc HV2r;
  Area a_req;
  Area a_reply;
  string 255 server,path,callback;
  LongInt port;
  transaction string 255 version_to_download,allversions_urlstr;
  transaction Boolean checkonlyf;

  LogText2(0,"DownloadNewVersionsForCx(" & fullf & "," & acheckonly & ") starting, versions: " & CountRecords("HansaVersionVc"),kVerbosityDebugDetailed);
  
  checkonlyf = acheckonly;
  server = VersionPackagesServer;
  port = VersionPackagesPort;
  
  path = "/downloads/cloud_packages/allversions.txt";
  callback = "DownloadNewVersionsForCxReply";
  if (!fullf) then begin
    //path = "/downloads/cloud_packages/allversions.txt"; // ## smaller file with only last N lines
    if (GetGlobalBoolean("DownloadNewVersions_NotFirstTime")==true) then begin
      callback = "DownloadNewVersionsForCxReplyLastRows";
    end else begin
      SetGlobalBoolean("DownloadNewVersions_NotFirstTime",true);
    end;
  end;
  
  //server = "127.0.0.1";
  //port = 8080;
  //path = "/allversions.txt";
  
  allversions_urlstr = "http://" & server & ":" & port & path;

  SetShouldDownloadVersion(version_to_download,true);
  if (IsDownloadingVersion(version_to_download) or IsDownloadingVersion("AllVersionsTag")) then begin
    LogText2(0,"Skipping downloading of " & version_to_download & " because a download of that version already is in progress",kVerbosityDebugDetailed);
    LogText2(0,"IsDownloadingVersion(version_to_download)=" & IsDownloadingVersion(version_to_download),kVerbosityDebugDetailed);
    LogText2(0,"IsDownloadingVersion(\"AllVersionsTag\")=" & IsDownloadingVersion("AllVersionsTag"),kVerbosityDebugDetailed);
    goto LDownloadNewVersionsForCx;
  end;

  if (IsDownloadingVersion("AllVersionsTag")==false and fullf) then begin
    while (LoopMain(HVr,1,true)) begin
      if (IsDownloadingVersion(HVr.Code)==false) then begin
        if (HVr.Closed==0) then begin
          //SetHansaVersionState(HVr,kHansaVersionStateChecking);
        end else begin
          SetHansaVersionState(HVr,kHansaVersionStateUnknown);
        end;
      end;
    end;
  end;
  
  RecordClear(HVr);
  UpdateClientBrowsesIfNeeded("HansaVersionVc");

  SetDownloadingVersion("AllVersionsTag",true);

  LogText2(0,"Downloading list of available versions from http://" & server & ":" & port & path,kVerbosityDebugDetailed);
  SendAsyncWebRequest(server,port,-1,false,"GET",path,"text/xml; charset=""utf-8""","",a_req,callback,30);

LDownloadNewVersionsForCx:;
  UpdateClientBrowsesIfNeeded("HansaVersionVc");
  return;
end;

global
updating procedure StartPendingVersionDownloads()
begin
  record HansaVersionVc HVr;
  
  if (IsCloudController or IsCloudNode) then begin
    while (LoopMain(HVr,1,true)) begin
      if (ShouldDownloadVersion(HVr.Code)) then begin
        CloudControllerCreateNewVersionIfNeeded(HVr.Code,HVr.Name,HVr.Version,HVr.SubVersion,
                                                HVr.RunningBuild,HVr.ProgramType,HVr.ProductCode);
      end;
    end;
  end;
  
  return;
end;

global
updating procedure Do_DownloadNewVersionsForCxReply(area a_reply,area a_replyheader,Boolean timeout,LongInt lastrows)
begin
  Integer httpstatus;
  transaction string 255 version_to_download,allversions_urlstr;
  record HansaVersionVc HVr;
  vector Boolean gotversions;
  vector string 255 httpheaders;
  string 255 vcode,vname,vpcode,curlinestr,tstr,httpversion;
  LongInt vno,vsubno,vbuild,vptyp,linecnt,curline,pos,startline;
  Boolean corruptf;

  SetDownloadingVersion("AllVersionsTag",false);

  if (timeout==true) then begin
    LogText(0,"DownloadNewVersionsForCxReply(allversions.txt) web call to " & allversions_urlstr & " timed out");
    VersionPackagesServerConnectionFailed;
    goto LDownloadNewVersionsForCxReply;
  end;

  httpstatus = ParseHTTPHeaderArea(a_replyheader,httpheaders,httpversion);
  
  switch (httpstatus) begin
    case kHttpStatusNotFound:
      LogText(0,"DownloadNewVersionsForCxReply() web call to " & allversions_urlstr & " failed (HTTP 404 not found)");
      VersionPackagesServerConnectionFailed;
      goto LDownloadNewVersionsForCxReply;
    case kHttpStatusOK:
      if (blank(version_to_download)) then begin
        LogText2(0,"Downloading new and updated versions",kVerbosityDebugDetailed);
      end;
    case kHttpStatusNotModified:
      LogText2(0,"Version list at " & allversions_urlstr & " not modified",kVerbosityDebugDetailed);
      StartPendingVersionDownloads;
      goto LDownloadNewVersionsForCxReply;
    otherwise
      LogText(0,"DownloadNewVersionsForCxReply() web call to " & allversions_urlstr & " failed (HTTP " & httpstatus & ")");
      VersionPackagesServerConnectionFailed;
      goto LDownloadNewVersionsForCxReply;
  end;
  
  if (lastrows==-1) then begin
    if (GetVmString("AllVersionsModified")<>httpheaders["last-modified"] and
        GetVmString("AllVersionsModified")<>"") then begin
      NotifyAllNodesOfNewVersions;
    end;
    
    SetVmString("AllVersionsModified",httpheaders["last-modified"]);
    LogText2(0,"AllVersionsModified: " & httpheaders["last-modified"],kVerbosityDebugDetailed);
  end else begin
    if (GetVmString("AllVersionsLastrowsModified")<>httpheaders["last-modified"] and
        GetVmString("AllVersionsLastrowsModified")<>"") then begin
      NotifyAllNodesOfNewVersions;
    end;

    SetVmString("AllVersionsLastrowsModified",httpheaders["last-modified"]);
    LogText2(0,"AllVersionsLastrowsModified: " & httpheaders["last-modified"],kVerbosityDebug);
  end;
  
  linecnt = CountLinesInArea(a_reply);
  
  LogText2(0,"DownloadNewVersionsForCxReply: creating versions, got " & linecnt & " lines",kVerbosityDebugDetailed);
  
  if (lastrows>0 and linecnt>lastrows) then begin
    startline = linecnt - lastrows - 1;
  end else begin
    startline = 0;
  end;
  
  for (curline = startline; curline<linecnt; curline = curline + 1) begin
    curlinestr = GetLineFromArea(a_reply,curline);
    if (curlinestr=="") then begin goto LDownloadNewVersionsForCxReply_SkipLine; end;

    pos = -1;
    GetNextSubstring(curlinestr,pos,chr(9),vcode);
    vcode = Trim(vcode);
    if ((nonblank(vcode) and (len(vcode)>50)) or (Left(vcode,1)=="<")) then begin // no codes longer than 50 chars are considered valid, might be too strong for some branches
      corruptf = true;
      VersionPackagesServerConnectionFailed;
      goto LDownloadNewVersionsForCxReply_Skip; // we consider this a corrupt input file
    end;
    GetNextSubstring(curlinestr,pos,chr(9),vname);
    vname = Trim(vname);
    GetNextSubstring(curlinestr,pos,chr(9),tstr);
    vno = StringToLongInt(tstr);
    if (vno<=0) then begin
      corruptf = true;
      VersionPackagesServerConnectionFailed;
      goto LDownloadNewVersionsForCxReply_Skip; // we consider this a corrupt input file
    end;
    GetNextSubstring(curlinestr,pos,chr(9),tstr);
    vsubno = StringToLongInt(tstr);
    GetNextSubstring(curlinestr,pos,chr(9),tstr);
    vbuild = StringToLongInt(tstr);
    GetNextSubstring(curlinestr,pos,chr(9),tstr);
    vptyp = StringToLongInt(tstr);
    GetNextSubstring(curlinestr,pos,chr(9),vpcode);
    vpcode = Trim(vpcode);
    if (nonblank(vpcode) and (len(vpcode)>25)) then begin // no product codes longer than 25 chars are considered valid
      corruptf = true;
      VersionPackagesServerConnectionFailed;
      goto LDownloadNewVersionsForCxReply_Skip; // we consider this a corrupt input file
    end;
    
    gotversions[vcode] = true;
    
    CloudControllerCreateNewVersionIfNeeded(vcode,vname,vno,vsubno,vbuild,vptyp,vpcode);
LDownloadNewVersionsForCxReply_SkipLine:;
  end;

LDownloadNewVersionsForCxReply_Skip:;
  if (corruptf) then begin
    Delete_File("version_download_failure.html");
    WriteAreaToFile(a_reply,"version_download_failure.html",0);
    LogText(0,"Downloading " & allversions_urlstr & " failed, check version_download_failure.html for more information");
  end;

  LogText2(0,"DownloadNewVersionsForCxReply: done creating versions",kVerbosityDebugDetailed);

  if (lastrows<0) then begin
    while (LoopMain(HVr,1,true)) begin
      if (gotversions[HVr.Code]==false) then begin
        if (DirExists(HVr.ProgramFolder)==true) then begin
          SetHansaVersionState(HVr,kHansaVersionStateDeprecated);
        end else begin
          SetHansaVersionState(HVr,kHansaVersionStateUnavailable);
        end;
      end;
    end;
  end;
  
LDownloadNewVersionsForCxReply:;
  UpdateClientBrowsesIfNeeded("HansaVersionVc");
  return;
end;

global
updating procedure DownloadNewVersionsForCxReply(area a_reply,area a_replyheader,Boolean timeout)
begin
  Do_DownloadNewVersionsForCxReply(a_reply,a_replyheader,timeout,-1);
end;

