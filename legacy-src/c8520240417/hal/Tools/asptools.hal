end;
          
function Boolean GetLastLCSBackup(record LocalCloudServerVc LCSr,var string backupfile)
begin
  Boolean res;
  string 255 wd,filename;
  Integer cnt,i;


  if (FileExists(LCSr.DataFolder & "/" & LCSr.BackupFolder & "/TB.TXT")) then begin
    backupfile = LCSr.DataFolder & "/" & LCSr.BackupFolder & "/TB.TXT";
    res = true;
  end;

  if (res==false) then begin
    wd = LCSr.DataFolder;
    if (right(wd,1)!="/") then begin
      wd = wd & "/";
    end;
    wd = wd & LCSr.BackupFolder;
    cnt = CountFilesInDir(wd);
    for (i = 0; i<cnt; i = i + 1) begin
      filename = GetFileNameInDir(wd,i);
      if (right(filename,4)==".TXT" and left(filename,2)=="TB") then begin
        if (filename>backupfile or blank(backupfile)) then begin
          backupfile = wd & "/" & filename;
          res = true;
        end;
      end;
    end;
  end;

  if (!res) then begin
    if (FileExists(LCSr.DataFolder & "/LCSEXPIMP.TXT")) then begin
      backupfile = LCSr.DataFolder & "/LCSEXPIMP.TXT";
      res = true;
    end;
  end;
  
  if (!res) then begin
    if (FileExists(LCSr.DataFolder & "/LCSUPDATE.TXT")) then begin
      backupfile = LCSr.DataFolder & "/LCSUPDATE.TXT";
      res = true;
    end;
  end;

  if (!res) then begin
    if (FileExists(LCSr.DataFolder & "/TBSETUP.TXT")) then begin
      backupfile = LCSr.DataFolder & "/TBSETUP.TXT";
      res = true;
    end;
  end;

  GetLastLCSBackup = res;
  return;
end;

global
updating procedure ImportProgramStatusBlockFromArea(area a_tmp,record LocalCloudServerVc LCSr)
begin
  area nl;
  string 255 tag;
  record ProgramStatusBlock PSb;
  record LocalCloudServerVc OldLCSr;

  if (!ReadFirstMain(LCSr,1,true)) then begin goto LImportProgramStatusBlockFromArea; end;
  
  AddTextToArea(chr(10),nl);
  InsertAreaBeforeArea(nl,a_tmp);
  tag = Trim(GetLineFromArea(a_tmp,1));
  GetBlockFromArea(PSb,tag,0,a_tmp);

  RecordCopy(OldLCSr,LCSr);
  LCSr.SSLCertFile = PSb.SSLCertFile;
  LCSr.SSLPrivKeyFile = PSb.SSLPrivKeyFile;
  LCSr.SSLPrivKeyPassword = PSb.SSLPrivKeyPassword;
  RecordUpdate(OldLCSr,LCSr,true);

LImportProgramStatusBlockFromArea:;
  return;
end;

global
procedure CatchProgramStatusBlockExport(record LocalCloudServerVc LCSr,string infpath)
begin
  Integer retries;
  string 255 fpath;
  area a_tmp;

  if (!ReadFirstMain(LCSr,1,true)) then begin goto LCatchProgramStatusBlockExport; end;
  
  fpath = AddPathComponent(infpath,LCSr.DataFolder);

  while ((retries<360) and !QuitingApplication) begin
    if (FileExists(fpath)) then begin
      Sleep(3); // Just in case it's not fully written yet
      AddFileToArea(fpath,a_tmp,false);
      qupdating.ImportProgramStatusBlockFromArea(a_tmp,LCSr); // not thread safe
      Delete_File(fpath);
      goto LCatchProgramStatusBlockExport;
    end;
    Sleep(1);
    retries = retries + 1;
  end;

LCatchProgramStatusBlockExport:;
  return;
end;

global
procedure GatherLCSDataTask(string args)
begin
  record LocalCloudServerVc LCSr;
  record InternetEnablerBlock IEb;
  record CYBlock CYb;
  string 255 backupfile,hmcustcode,fpath;
  Boolean oldwrwi;
  Longint contract;
  val foldersize;
  Integer regincountry;

  if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LGatherLCSDataTask; end;

  ChangeTaskTiming("GatherLCSDataTask",84000); // once per day, no surprises
    
  while (LoopMain(LCSr,1,true) and (QuitingApplication==false)) begin
    if (LCSr.Closed==0) then begin
  /*
      hmcustcode = LCSr.HMCUCode;
      contract = LCSr.Contract;
      regincountry = LCSr.HMRegInCountry;
      foldersize = 0;
      if (GetLastLCSBackup(LCSr,backupfile)) then begin
        if (FileExists(backupfile)) then begin
          while (IncreaseVmLong("importing",1)==false) begin
            MilliSleep(200);
          end;
          oldwrwi = SetWebRequestsWhileImporting(true);
          ReadCompanyInfoBlocksFromTB(backupfile,IEb,CYb);
          SetWebRequestsWhileImporting(oldwrwi);
          ChangeVmLong("importing",-1);
          if (nonblank(IEb.CustomerCode) and (LCSr.Contract!=IEb.Contract or LCSr.HMCUCode!=IEb.CustomerCode)) then begin
            hmcustcode = IEb.CustomerCode;
            contract = IEb.Contract;
            regincountry = IEb.RegInCountry;
          end;
        end;
      end;
      if (nonblank(LCSr.DataFolder)) then begin
        foldersize = GetFolderSize(LCSr.DataFolder);
      end;
      queued.CNUpdateHMCUCode(LCSr,hmcustcode,regincountry,contract,foldersize);
*/
      if (nonblank(LCSr.DataFolder)) then begin
        if (LCSr.CurrentStatus==kStatusRunning or LCSr.CurrentStatus==kStatusRunningTest) then begin
          CreateFolderHierarchy(EnablerActionsFolder(LCSr) & "/");
          WriteStringToFile("1" & chr(9) & "ProgramStatusBlock" & chr(9) & "tmp/ProgramStatus.txt",EnablerActionsFolder(LCSr) & "/EnExportBlock",0);
          threadasync.CatchProgramStatusBlockExport(LCSr,"tmp/ProgramStatus.txt");
        end;
      end;
    end;
  end;

LGatherLCSDataTask:;
  return;
end;

function Boolean TestPortIsOpen(array string portarr,LongInt portno)
begin
  Boolean res;
  LongInt l,pos;
  string 255 fromport,toport;

  for (l = 0; l<portarr.length; l = l + 1) begin
    pos = -1;
    GetNextSubstring(portarr[l],pos,"-",fromport);
    GetNextSubstring(portarr[l],pos,"-",toport);
    if (blank(toport)) then begin
      if (StringToLongInt(fromport)==portno) then begin
        res = true;
        goto LTestPortIsOpen;
      end;
    end else begin
      if ((portno>=StringToLongInt(fromport)) and (portno<=StringToLongInt(toport))) then begin
        res = true;
        goto LTestPortIsOpen;
      end;
    end;
  end;

LTestPortIsOpen:;
  TestPortIsOpen = res;
  return;
end;

procedure AddToPortVecIfNeeded(LongInt portno,array string tcparr,var vector string tcpvec,var Boolean changef)
begin
  if (portno>0) then begin
    if (TestPortIsOpen(tcparr,portno)==false) then begin
      tcpvec[portno] = portno;
      changef = true;
    end;
  end;
  return;
end;

global
procedure OpenPortList(record HostingConfigurationVc HCr,record CloudNodeVc CNr,string portlist,var string errmsg)
begin
  array string 255 tcparr,udparr;
  vector string 255 tcpvec,udpvec;
  Boolean testf,changef;
  string 255 fwid;
  LongInt pos;
  string 255 port;

  switch (HCr.HostingType) begin
    case kHostingTypeAmazon:
      if (blank(HCr.AmazonAccessKeyID) or blank(HCr.AmazonSecretAccessKey)) then begin
        errmsg = "Couldn't open ports on node " & CNr.Code & " because the hosting configuration " & HCr.SerNr & " doesn't have Amazon credentials specified.";
        goto LOpenPortList;
      end;
      testf = AmazonFirewallGetOpenPorts(HCr,CNr.Code,tcparr,udparr);
    case kHostingTypeIBMCloud:
      testf = IBMCloudFirewallGetOpenPorts(HCr,CNr,tcparr,udparr,fwid);
    otherwise
      goto LOpenPortList;
  end;

  if (testf==false) then begin
    errmsg = "Couldn't open ports on node " & CNr.Code & " because current firewall configuration couldn't be read.";
// TODO: Schedule retry three times
// TODO: Add error to error LogText
// TODO: Add watchpoint
    goto LOpenPortList;
  end;

  pos = -1;
  while (GetNextSubstring(portlist,pos,",",port)) begin
    AddToPortVecIfNeeded(StringToLongInt(port),tcparr,tcpvec,changef);
  end;

  if (changef) then begin
    switch (HCr.HostingType) begin
      case kHostingTypeAmazon:
        AmazonFirewallOpenPorts(HCr,CNr.Code,tcpvec,udpvec);
      case kHostingTypeIBMCloud:
        IBMCloudFirewallOpenPorts(HCr,CNr,tcpvec,udpvec);
    end;
  end;

LOpenPortList:;
  return;
end;

global
procedure OpenPortsForServer(record RemoteCloudServerVc RCSr)
begin
  string 255 errmsg;
  record CloudNodeVc CNr;
  record HostingConfigurationVc HCr;

  if (IsCloudController==false) then begin goto LOpenPortsForServer; end;
  
  CNr.Code = RCSr.Controller;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    CNr.Code = RCSr.NewController;
    if (ReadFirstMain(CNr,1,true)==false) then begin
      goto LOpenPortsForServer;
    end;
  end;

  HCr.SerNr = CNr.HostingConfig;
  if (ReadFirstMain(HCr,1,true)==false) then begin
    goto LOpenPortsForServer;
  end;

  if (HCr.Closed!=0) then begin
    goto LOpenPortsForServer;
  end;

  OpenPortList(HCr,CNr,RCSr.Port & "," & RCSr.HTTPPort & "," & RCSr.HTTPSPort & "," & RCSr.MaintPort,errmsg);
  if (nonblank(errmsg)) then begin
    LogText(0,"ERROR: " & errmsg);
    goto LOpenPortsForServer;
  end;

LOpenPortsForServer:;
  return;
end;

global
procedure GetLCSRecordWithPos(var array UUID recarr,var Longint looppos,Integer cnt)
begin
  record LocalCloudServerVc LCSr;
  Integer i;

  if (looppos>-1) then begin
    SetLoopPosition(LCSr,looppos+1);
  end;
  while (LoopMain(LCSr,1,true)) begin
    if (i<cnt) then begin
      recarr[recarr.length] = LCSr.UUID;
      i = i + 1;
      looppos = GetLoopPosition(LCSr);
    end else begin
      goto lout;
    end;
  end;

lout:;
  return;
end;

global
updating procedure ForceDeleteLCSList(array uuid recarr)
begin
  record LocalCloudServerVc LCSr;
  Integer i;

  for (i=0;i<recarr.length;i=i+1) begin
    LCSr.UUID = recarr[i];
    if (ReadFirstMain(LCSr,1,true)) then begin
      RecordDelete(LCSr);
    end;
  end;

  return;
end;

global
updating procedure UpdateListOfServerControllers(array uuid recarr,string corrcn)
begin
  record RemoteCloudServerVc RCSr,oldRCSr;
  Integer i;

  for (i=0;i<recarr.length;i=i+1) begin
    RCSr.UUID = recarr[i];
    if (ReadFirstMain(RCSr,1,true)) then begin
      if (RCSr.Controller!=corrcn) then begin
        RecordCopy(oldRCSr,RCSr);
        RCSr.Controller = corrcn;
        RecordUpdate(oldRCSr,RCSr,true);
        SetCloudControllerStatus(kJobStatusFinished,"Resolved node conflict for server " & RCSName(RCSr));
      end;
    end;
  end;

  return;
end;


global
procedure ResolveNodeConflictForNode(string corrcn,string incorrcn)
begin
  record RemoteCloudServerVc RCSr,OldRCSr;
  record CloudNodeVc CNr,CN2r;
  string 255 corrurl,incorrurl,remotefname;
  LongInt stat;
  Boolean foundf;
  Boolean scfailf,checknodef;
  array UUID recarr;
  Longint looppos;

  CNr.Code = corrcn;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    SetCloudControllerStatus(kJobStatusError,"The node " & CNr.Code & " doesn't exist, can't resolve node conflict ");
    goto LResolveNodeConflictForNode;
  end;

  CN2r.Code = incorrcn;
  if (ReadFirstMain(CN2r,1,true)==false) then begin
    SetCloudControllerStatus(kJobStatusError,"The node " & CN2r.Code & " doesn't exist, can't resolve node conflict ");
    goto LResolveNodeConflictForNode;
  end;

  incorrurl = NodeURL(CN2r);
  if (blank(incorrurl)) then begin
    SetCloudControllerStatus(kJobStatusError,"Blank URL for Node " & CN2r.Code & ", can't resolve node conflict ");
    goto LResolveNodeConflictForNode;
  end;

  corrurl = NodeURL(CNr);
  if (blank(corrurl)) then begin
    SetCloudControllerStatus(kJobStatusError,"Blank URL for Node " & CNr.Code & ", can't resolve node conflict ");
    goto LResolveNodeConflictForNode;
  end;

/*
  RCSr.NewController = CNr.Code;
  foundf = true;
*/


/*
  while (LoopMain(RCSr,1,true)) begin//KSZ::NewController index can't be used here cause of "RecordInIndex" function
    foundf = true;
    if (RCSr.NewController!=CNr.Code) then begin foundf = false; end;
    if (foundf) then begin
      if (RCSr.Closed==0) then begin
        stat = CallService(url).ForceDeleteLCS(RCSr.UUID);
        scfailf = TreatServiceError(stat,url,"ForceDeleteLCS");
        queued.SaveCloudNodeReachable(CN2r.Code,!scfailf);
        if (scfailf) then begin
          SetCloudControllerStatus(kJobStatusError,"Failed resolving node conflict, " & CN2r.Code & " didn't respond");
          LogText(0,"Failed resolving node conflict, " & CN2r.Code & " didn't respond");
//          goto LResolveNodeConflictForNode;
        end else begin
          if (RCSr.Controller==CN2r.Code) then begin
            RecordCopy(oldRCSr,RCSr);
            RCSr.Controller = CNr.Code;
            RecordUpdate(oldRCSr,RCSr,true);
          end;
        end;
        SetCloudControllerStatus(kJobStatusFinished,"Resolved node conflict for server " & RCSName(RCSr) & ", removing it from node " & CN2r.Code);
      end;
    end;
  end;
*/
  checknodef = true;
  while (checknodef) begin
    ClearArray(recarr);
    stat = CallService(corrurl).GetLCSRecordWithPos(recarr,looppos,20);
    if (recarr.length>0) then begin
      stat = CallService(incorrurl).ForceDeleteLCSList(recarr);
      scfailf = TreatServiceError(stat,incorrurl,"ForceDeleteLCSList");
      if (scfailf) then begin
        SetCloudControllerStatus(kJobStatusError,"Failed resolving node conflict, " & CN2r.Code & " didn't respond");
      end else begin
        qupdating.UpdateListOfServerControllers(recarr,CNr.Code);
      end;
    end;
    checknodef = recarr.length>0;
  end;


LResolveNodeConflictForNode:;
  return;
end;

global
updating procedure SetLocalCloudServerCustomer(UUID serverid,string customercode,Longint contractno,Integer regincountry)
begin
  record LocalCloudServerVc LCSr,OldLCSr;

  LCSr.UUID = serverid;
  if (ReadFirstMain(LCSr,1,true)) then begin
    RecordCopy(OldLCSr,LCSr);
    LCSr.HMCUCode = customercode;
    LCSr.HMRegInCountry = regincountry;
    LCSr.Contract = contractno;
    if (ComparePosts(OldLCSr,LCSr)==false) then begin
      RecordUpdate(OldLCSr,LCSr,true);
    end;
  end;

  return;
end;

global
procedure SetRemoteCloudServerCustomer(record RemoteCloudServerVc RCSr,string customercode,Longint contractno,Integer regincountry,var string err)
begin
  string 255 url;
  Integer stat;
  Boolean scfailf;

  url = RcsNodeURL(RCSr);
  if (nonblank(url)) then begin
    LogText(0,"SetLocalCloudServerCustomer " & RCSr.Name);
    stat = CallService(url).SetLocalCloudServerCustomer(RCSr.UUID,customercode,contractno,regincountry);
    scfailf = TreatServiceError(stat,url,"SetLocalCloudServerCustomer");
    queued.SaveCloudNodeReachable(RCSr.Controller,!scfailf);
    if (scfailf) then begin
      err = "Failed to connect to server";
    end;
  end else begin
    err = "Failed to get Node's Address";
  end;

  return;
end;

global
updating procedure FinishSendFileToLocalCloudServer(string remotefname,string fpath,Boolean folderf)
begin
  if (FileExists(remotefname)) then begin
    LogText(0,"Inbound file transfer of " & remotefname & " completed, saving as " & fpath & ", folderf=" & folderf);
    CreateFolderHierarchy(DirName(fpath));
    if (folderf==false) then begin
      CopyFile(remotefname,fpath);
    end else begin
      LogText(0,"RestoreArchive fpath=" & DirName(fpath) & ", remotefname=" & remotefname);
      RestoreArchive(DirName(fpath),remotefname);
    end;
    Delete_File(remotefname);
  end;
  return;
end;

global
updating procedure RemoveAttachRecord(var record Attach2Vc AT2r)
begin
  if (ReadFirstMain(AT2r,1,true)) begin
    RecordRemove(AT2r);
  end;
  return;
end;

global
procedure SendFileToRemoteCloudServer(uuid rcsid,string fpath,string dname,string path,Boolean folderf)
begin
  record RemoteCloudServerVc RCSr;
  Integer i;
  Boolean testf;
  string 255 url,ffirstname,remotefname;
  LongInt stat,pos,blocklen;
  Val fsz;
  area part;
  transaction Integer waits_for_upload;
  Integer retries;

  if (FileExists(fpath)==false) then begin
    SetCloudControllerStatus(kJobStatusError,"Transferring file " & dname & " to node " & RCSr.Controller & " failed, file missing");
    LogText(0,"Failed to send file " & dname & " to cloud node " & RCSr.Controller & ", file missing");
    goto LSendFileToRemoteCloudServer;
  end;

  RCSr.UUID = rcsid;
  if (ReadFirstMain(RCSr,1,true)) then begin
    SetCloudControllerStatus(kJobStatusRunning,"Transferring file " & dname & " to node " & RCSr.Controller);
    LogText(0,"Starting to send file " & dname & " to cloud node " & RCSr.Controller);
    url = RcsNodeURL(RCSr);
    fsz = FileSize(fpath);
    pos = 0;
    while (pos<fsz) begin
      retries = 0;
      blocklen = MIN(fsz - pos,512000); // 500Kb at a time...
      LoadFileToArea(fpath,pos,blocklen,part);
LSendFileToRemoteCloudServer_Retry:
      stat = CallService(url).ReceiveFilePart(remotefname,dname,"",part);
      if (TreatServiceError(stat,url,"ReceiveFilePart")) then begin
        LogText(0,"Failed to send file part to " & RCSr.BackupFolder & " for cloud server " & RCSName(RCSr));
        retries = retries + 1;
        Sleep(5);
// TODO: give up eventually, add error handling in caller
        goto LSendFileToRemoteCloudServer_Retry;
      end else begin
        pos = pos + blocklen;
      end;
    end;
    if (pos>=fsz) then begin
      retries = 0;
LSendFileToRemoteCloudServer_RetryFinish:
      stat = CallService(url).FinishSendFileToLocalCloudServer(remotefname,path & "/" & dname,folderf);
      if (TreatServiceError(stat,url,"FinishSendFileToLocalCloudServer")) then begin
        LogText(0,"Failed to send file part to " & RCSr.BackupFolder & " for cloud server " & RCSName(RCSr));
        retries = retries + 1;
        Sleep(5);
// TODO: give up eventually, add error handling in caller
        goto LSendFileToRemoteCloudServer_RetryFinish;
      end;
    end;
  end else begin
    SetCloudControllerStatus(kJobStatusError,"Failed transferring file " & dname & " because RCS " & rcsid & " is missing");
    LogText(0,"Failed transferring file " & dname & " because RCS " & rcsid & " is missing");
  end;

  Delete_File(fpath);
  SetCloudControllerStatus(kJobStatusFinished,"File " & dname & " transferred to node " & RCSr.Controller);
  allclientsremoteasync.DoFileListReload(rcsid);

LSendFileToRemoteCloudServer:;
  return;
end;

global
updating procedure UpdateAttachRecord(var record Attach2Vc AT2r,string filename)
begin
  record Attach2Vc OldAT2r;

  if (ReadFirstMain(AT2r,1,true)) begin
    RecordCopy(OldAT2r,AT2r);
    AT2r.FileName = filename;
    RecordUpdate(OldAT2r,AT2r,true);
  end;
  return;
end;

global
updating procedure DoRecordLinkFile(string tmpfile,record RemoteCloudServerVc RCSr)
begin
  RecordLinkFile(tmpfile,0,RCSr,CurrentCompany);
  return;
end;

global
procedure StopFileDownloadFromRemoteCloudServer(uuid rcsid,string fname,string pickupfile)
begin
  string 255 tagstr,pickupfilestr;

  tagstr = ":" & rcsid & ":" & fname;
  pickupfilestr = "tmp/filetrans-" & rcsid & "-" & fname;
  SetGlobalBoolean("Downloading-stop" & tagstr,true);
  SetGlobalBoolean("Downloading" & tagstr,false);
  SetGlobalBoolean("Downloading-done" & tagstr,false);
  if (right(pickupfile,4)==".tmp" and FileExists(pickupfile)) then begin
    Delete_File(pickupfile);
  end;
  if (FileExists(pickupfilestr)) then begin
    Delete_file(pickupfilestr);
  end;
  return;
end;

global
procedure DoGetFileFromRemoteCloudServer(uuid rcsid,string fname,string fpath,string pickupfile,string tagstr)
begin
  record RemoteCloudServerVc RCSr;
  Integer i;
  Boolean testf;
  string 255 url,ffirstname,remotefname;
  LongInt stat,blocklen;
  val fsz;
  area part;
  Integer retries;
  ULong64 pos;

  if (QuitingApplication) then begin goto LDoGetFileFromRemoteCloudServer; end;

  RCSr.UUID = rcsid;
  if (ReadFirstMain(RCSr,1,true)) then begin
    SetCloudControllerStatus(kJobStatusRunning,"Transferring file " & fname & " from node " & RCSr.Controller);
    LogText(0,"Transferring file " & fname & " from node " & RCSr.Controller & " as " & pickupfile & ":tagstr=" & tagstr);
//HalCallStack;
    url = RcsNodeURL(RCSr);
    if (blank(url)) then begin goto LDoGetFileFromRemoteCloudServer; end;

    remotefname = fpath & "/" & fname;
    if (Left(remotefname,len(RCSr.DataFolder))!=RCSr.DataFolder) then begin
      SetCloudControllerStatus(kJobStatusError,"Transfer of file " & remotefname & " from node " & RCSr.Controller & " blocked, invalid path");
      LogText(0,"Transfer of file " & remotefname & " from node " & RCSr.Controller & " blocked, invalid path");
    end;
    stat = CallService(url).GetFileSizeOnLCS(remotefname,fsz);
    if (TreatServiceError(stat,url,"GetFileSize")) then begin
      LogText(0,"Failed to get file size of " & remotefname & " from cloud node " & RCSr.Controller);
      goto LDoGetFileFromRemoteCloudServer;
    end;
    pos = 0;

    while ((pos<fsz) and (GetGlobalBoolean("Downloading-stop" & tagstr)==false) and (QuitingApplication==false)) begin
      retries = 0;
      blocklen = MIN(fsz - pos,512000); // 500Kb at a time...
LDoGetFileFromRemoteCloudServer_Retry:;
      SetAreaZeroSize(part);
      stat = CallService(url).DoLoadFilePart(remotefname,pos,blocklen,part);
      if (TreatServiceError(stat,url,"DoLoadFilePart")) then begin
        LogText(0,"Failed to get file " & remotefname & " from cloud node " & RCSr.Controller);
        retries = retries + 1;
        if (QuitingApplication or (retries>60)) then begin goto LDoGetFileFromRemoteCloudServer; end;
        goto LDoGetFileFromRemoteCloudServer_Retry;
      end else begin
        if ((pos+blocklen)<pos) then begin
          LogText(0,"Failed to get file " & remotefname & " from cloud node " & RCSr.Controller & ", file size too big");
          StopFileDownloadFromRemoteCloudServer(rcsid,fname,pickupfile);
          goto LDoGetFileFromRemoteCloudServer;
        end;
        pos = pos + blocklen;
        AppendAreaToFile(pickupfile,part);
      end;
    end;
  end;

  LogText(0,"Transfer file " & fname & " from cloud node " & RCSr.Controller & " finished, waiting for client to pick it up");
  SetGlobalBoolean("Downloading-done" & tagstr,true);

LDoGetFileFromRemoteCloudServer:;
  return;
end;


global
procedure GetFileFromRemoteCloudServer(uuid rcsid,string fname,string fpath,var Boolean readyf,var string pickupfile)
begin
  record RemoteCloudServerVc RCSr;
  Integer i;
  Boolean testf;
  string 255 url,ffirstname,remotefname,tagstr,pickupfilestr;
  LongInt stat,pos,blocklen;
  area part;

  tagstr = ":" & rcsid & ":" & fname;
  pickupfilestr = "tmp/filetrans-" & rcsid & "-" & fname;
  if (GetGlobalBoolean("Downloading" & tagstr)==true) then begin
    pickupfile = ReadStringFromFile(pickupfilestr);
    if (GetGlobalBoolean("Downloading-done" & tagstr)==true) then begin
      SetGlobalBoolean("Downloading" & tagstr,false);
      SetGlobalBoolean("Downloading-stop" & tagstr,false);
      SetGlobalBoolean("Downloading-done" & tagstr,false);
      LogText(0,"Transfer of file " & fname & " to CC completed, " & pickupfile & " is about to be picked up by client");
      readyf = true;
    end else begin
      LogText(0,"Transfer of file " & fname & " to CC in progress, saving as " & pickupfile);
    end;
  end else begin
    if (QuitingApplication==false) then begin
      SetGlobalBoolean("Downloading" & tagstr,true);
      SetGlobalBoolean("Downloading-stop" & tagstr,false);
      SetGlobalBoolean("Downloading-done" & tagstr,false);

      pickupfile = CreateTempFile("filetrans",".tmp");
      WriteStringToFile(pickupfile,pickupfilestr,0);
      
      threadasync.DoGetFileFromRemoteCloudServer(rcsid,fname,fpath,pickupfile,tagstr);
    end;
  end;
  
  return;
end;

global
procedure GetFileFromRemoteCloudServerFromMyStandard(uuid rcsid,string fname,string fpath,var Boolean readyf,var string pickupfile)
begin

  GetFileFromRemoteCloudServer(rcsid,fname,fpath,readyf,pickupfile);
  if (!readyf) then begin
    if (FileSize2(pickupfile)>500000) then begin
      readyf = true;
    end;
  end;

  return;
end;


global
procedure RefreshStatusOfRemoteCloudServers(array uuid recarr)
begin
  record RemoteCloudServerVc RCSr;
  Integer i;

  for (i=0;i<recarr.length;i=i+1) begin
    RCSr.UUID = recarr[i];
    if (ReadFirstMain(RCSr,1,true) and (QuitingApplication==false)) then begin
      RCSr.RcsSeqNr = -1; // to force
      threadasync.SyncOneRCS(RCSr,true,true,"8");
    end;
  end;

  return;
end;


procedure CleanCoreDumpsInFolder(string folder,Boolean cleanallf)
begin
  Boolean res,csf;
  string 255 filename,filename_log,newest_filename,oldest_filename,s3filename;
  Integer cnt,i,deleted_cnt,sent_cnt;
  date dt,newest_dt,oldest_dt;
  time tm,newest_tm,oldest_tm;
  record CloudCrashDumpBlock CCDb;
  record CloudSettingsBlock CSb;

  BlockLoad(CCDb);
  BlockLoad(CSb);

  if (blank(CCDb.AmazonAccessKeyID) or blank(CCDb.AmazonSecretAccessKey) or
      blank(CCDb.AmazonRegion) or blank(CCDb.AmazonS3Bucket)) then begin
    LogText(0,"Warning: Cloud storage of crash dumps is not configured, crash dumps will be deleted");
  end else begin
    csf = true;
  end;

  oldest_dt = CurrentDate;
  oldest_tm = CurrentTime;

  cnt = CountFilesInDir(folder);
  if (cleanallf==false) then begin
    for (i = 0; i < cnt; i = i + 1) begin
      filename = GetFileNameInDir(folder,i);
      if (left(filename,5)=="core.") then begin
        if (FileChangedDate(folder & "/" & filename,dt,tm)==true) then begin
          if (IsMinutesPastTime(dt,tm,CurrentDate,CurrentTime,30)==true) then begin
            if (DateTimeDiff(dt,tm,newest_dt,newest_tm)>0) then begin
              newest_dt = dt;
              newest_tm = tm;
              newest_filename = filename;
            end;
            if (DateTimeDiff(dt,tm,oldest_dt,oldest_tm)<0) then begin
              oldest_dt = dt;
              oldest_tm = tm;
              oldest_filename = filename;
            end;
          end;
        end else begin
          LogText(0,"Error: Couldn't get file change time on file: " & folder & "/" & filename);
        end;
      end;
    end;
  end;

  for (i = cnt; i>0; i = i - 1) begin
    filename = GetFileNameInDir(folder,i-1);
    if (left(filename,5)=="core.") then begin
      if (FileChangedDate(folder & "/" & filename,dt,tm)==true) then begin
        if ((IsMinutesPastTime(dt,tm,CurrentDate,CurrentTime,30)==true) or cleanallf) then begin
          if ((filename!=newest_filename) and (filename!=oldest_filename)) then begin
            filename_log = filename & "-hansa.log";
            if (csf) then begin
              if (IsCloudController) then begin
                s3filename = "CloudControllers/" & StringFromSet(10005,CSb.HostingPartner);
              end else begin
                s3filename = "CloudNodes/" & CSb.NodeCode;
              end;
              if (blank(s3filename)) then begin
                s3filename = "unknown/" & PublicHostName;
              end;
              s3filename = s3filename & "/" & DateToString(dt,"YYYYMMDD");
              s3filename = s3filename & "/" & TimeToString(tm,"HHMMSS",false) & "-" & filename;
              res = UploadFileToS3Bucket(CCDb.AmazonAccessKeyID,CCDb.AmazonSecretAccessKey,
                                         CCDb.AmazonRegion,CCDb.AmazonS3Bucket,
                                         folder & "/" & filename,s3filename,"","");
              if (res and FileExists(folder & "/" & filename_log)) then begin
                res = UploadFileToS3Bucket(CCDb.AmazonAccessKeyID,CCDb.AmazonSecretAccessKey,
                                           CCDb.AmazonRegion,CCDb.AmazonS3Bucket,
                                           folder & "/" & filename_log,s3filename & "-hansa.log","","");
              end;
              if (res) then begin sent_cnt = sent_cnt + 1; end;
            end;
            if (!csf or res) then begin
              LogText2(0,"Deleting file " & folder & "/" & filename,kVerbosityDebug);
              Delete_file(folder & "/" & filename);
              Delete_file(folder & "/" & filename_log);
              deleted_cnt = deleted_cnt + 1;
            end else begin
              LogText(0,"Error: Failed to upload crash dump " & filename & " to cloud storage");
            end;
          end;
        end;
      end;
    end;
  end;

  if (deleted_cnt>0) then begin
    LogText(0,"Deleted " & deleted_cnt & " crash dumps from " & folder);
  end;
  if (sent_cnt>0) then begin
    LogText(0,"Sent " & sent_cnt & " crash dumps from " & folder & " to cloud storage");
  end;

  return;
end;

global
procedure ASPCleanCoreDumpsTask(string arg)
begin
  // Note: This task is designed only for CC and CN, which should keep recent cores
  switch (ProgramPlatform) begin
    case kPlatformMac:        CleanCoreDumpsInFolder(ProgramFolder,false);
    case kPlatformLinux32:    CleanCoreDumpsInFolder(ProgramFolder,false);
    case kPlatformLinux64:    CleanCoreDumpsInFolder(ProgramFolder,false);
    case kPlatformLinuxArm64: CleanCoreDumpsInFolder(ProgramFolder,false);
    otherwise
  end;

  return;
end;

function Boolean TestSystemTmpFolderWrite()
begin
  string 255 fname;
  Boolean res;
  
  fname = "/tmp/testwrite." & DatabaseID & ".tmp";

  if (FileExists(fname)) then begin Delete_file(fname); end;
  if (FileExists(fname)) then begin goto LTestSystemTmpFolderWrite; end;
  
  CreateFile(fname);
  CloseFile;
  res = FileExists(fname);
  if (res) then begin Delete_file(fname); end;
  
LTestSystemTmpFolderWrite:;
  TestSystemTmpFolderWrite = res;
  return;
end;

global
updating procedure RebootLocalSystem()
begin
  record CloudSettingsBlock CSb;
  
  BlockLoad(CSb);
  CSb.LastAutoRebootDate = CurrentDate;
  CSb.LastAutoRebootTime = CurrentTime;
  BlockStore(CSb);

  LogText(0,"*** Rebooting system because we are either out of i-nodes, or the root device is full. Forcing a disk check and removing old files from mail spool ***");
  
  if (TestSystemTmpFolderWrite==false) then begin
    RunShellScript("fsck -fy /");
    RunShellScript("mount -o rw,remount /");
  end;
  
  RunShellScript("find /var/spool/clientmqueue -maxdepth 1 -mtime +90 -exec rm -f {} \\;");
  RunShellScript("echo y > /forcefsck");
  RunShellScript("reboot &");

  return;
end;

global
procedure ASPAutoRebootTask(string arg)
begin
  Boolean rebootf,auto_reboot_supportedf;
  record CloudSettingsBlock CSb;
  

  switch (ProgramPlatform) begin
    case kPlatformMac:        auto_reboot_supportedf = true;
    case kPlatformLinux32:    auto_reboot_supportedf = true;
    case kPlatformLinux64:    auto_reboot_supportedf = true;
    case kPlatformLinuxArm64: auto_reboot_supportedf = true;
    otherwise
  end;
  
  if (auto_reboot_supportedf==false) then begin goto LASPAutoRebootTask; end;
  
  BlockLoad(CSb);

  if (TestSystemTmpFolderWrite==false) then begin rebootf = true; end;
  
  if (rebootf) then begin
    if (IsMinutesPastTime(CSb.LastAutoRebootDate,CSb.LastAutoRebootTime,CurrentDate,CurrentTime,60)==true) then begin
      queued.RebootLocalSystem;
    end;
  end;
  
LASPAutoRebootTask:;
  return;
end;

global
updating procedure RemoveCloudNode(record CloudNodeVc CNr,var string errmsg)
begin
  record CloudNodeVc CN2r;
  CN2r.Code = CNr.Code;
  if (ReadFirstMain(CN2r,1,true)) then begin
    RecordDelete(CN2r);
  end;
  UpdateClientBrowses("CloudNodeVc");

  return;
end;

global
updating procedure StoreCloudNode(record CloudNodeVc CNr,record HostingConfigurationVc HCr,
                                  string aws_key,string ibmcloud_key,string ibmcloud_pubkey,var string errmsg)
begin
  record CloudNodeVc CN2r;
  record HostingConfigurationVc HC2r,HC3r,HC4r;

  CN2r.Code = CNr.Code;
  if (ReadFirstMain(CN2r,1,true)) then begin
    if (CN2r.Closed==0) then begin
      errmsg = "An open node with this name already exists in the selected Cloud Controller.";
      goto LStoreCloudNode;
    end else begin
      LogText(0,"Deleting closed node " & CN2r.Code);
      RecordDelete(CN2r);
    end;
  end;

  RecordCopy(HC4r,HCr);
  HC4r.SerNr = -1;

  while (LoopMain(HC2r,0,true)) begin
    RecordCopy(HC3r,HC2r);
    HC3r.SerNr = -1;
    if (ComparePosts(HC3r,HC4r)==true) then begin
      CNr.HostingConfig = HC2r.SerNr;
      goto LStoreCloudNode_FoundHCr;
    end;
  end;

  HCr.SerNr = NextSerNr("HostingConfigurationVc",CurrentDate,-1,false,"");
  CNr.HostingConfig = HCr.SerNr;
  LogText(0,"Storing hosting configuration " & HCr.SerNr & " (" & HCr.Comment & ")");
  RecordStore(HCr,false);

  if (nonblank(aws_key)) then begin
    WriteStringToFile(aws_key,"tmp/amazon-ec2-key.pem",0);
    RecordLinkFile("tmp/amazon-ec2-key.pem",0,HCr,CurrentCompany);
    Delete_File("tmp/amazon-ec2-key.pem");
  end;

  if (nonblank(ibmcloud_key)) then begin
    WriteStringToFile(ibmcloud_key,"tmp/ibmcloud-ssh-key.pem",0);
    RecordLinkFile("tmp/ibmcloud-ssh-key.pem",0,HCr,CurrentCompany);
    Delete_File("tmp/ibmcloud-ssh-key.pem");
  end;

  if (nonblank(ibmcloud_pubkey)) then begin
    WriteStringToFile(ibmcloud_pubkey,"tmp/ibmcloud-ssh-public-key.pem",0);
    RecordLinkFile("tmp/ibmcloud-ssh-public-key.pem",0,HCr,CurrentCompany);
    Delete_File("tmp/ibmcloud-ssh-public-key.pem");
  end;

LStoreCloudNode_FoundHCr:;
  RecordStore(CNr,true);
  LogText(0,"Storing incoming node " & CNr.Code);
  UpdateClientBrowses("CloudNodeVc");

LStoreCloudNode:;
  return;
end;

global
procedure GetCloudControllerInfo1(var LongInt ccport,var LongInt cchttpport,var LongInt ccrevhttpsport,var string ccrevhttpsportlist,var Integer hostingpartner)
begin
  record CloudSettingsBlock CSb;
  record ProgramStatusBlock PSb;

  BlockLoad(CSb);
  BlockLoad(PSb);

  ccport = ServerTCPPort;
  cchttpport = ServerHttpPort;
  ccrevhttpsport = PSb.revHttpsServerPort;
  ccrevhttpsportlist = PSb.revHttpsServerPortList;
  hostingpartner = CSb.HostingPartner;

  return;
end;

global
updating procedure InitializeNodeWithNewController(string url,string key,var string errmsg)
begin
  record CloudSettingsBlock CSb;
  string 255 addr,tstr,ccrevhttpsportlist;
  LongInt pos,port,ccport,cchttpport,ccrevhttpsport;
  Integer stat,hostingpartner;
  Boolean scfailf,addrchangedf;

  GetNextSubstring(url,pos,":",addr);
  GetNextSubstring(url,pos,":",tstr);
  port = StringToLongInt(tstr);
  if (blank(addr) or (port<=0)) then begin
    errmsg = "Failed to initialize node with new Cloud Controller because the address/port was invalid.";
  end;

  if (blank(errmsg)) then begin
    stat = CallService2(url,key).GetCloudControllerInfo1(ccport,cchttpport,ccrevhttpsport,ccrevhttpsportlist,hostingpartner);
    scfailf = TreatServiceError(stat,url,"GetCloudControllerInfo1");
    if (scfailf) then begin
      errmsg = "Failed to initialize node with new Cloud Controller because the Cloud Controller didn't respond.";
    end;
  end;

  if (blank(errmsg)) then begin

    BlockLoad(CSb);
    if ((CSb.CCAddr!=trim(addr)) or (CSb.CCHTTPSPort!=port)) then begin
      addrchangedf = true;
    end;

    CSb.CCAddr = trim(addr);
    CSb.CCPort = ccport;
    CSb.CCHTTPPort = cchttpport;
    CSb.CCHTTPSPort = port;
    CSb.CCRevHTTPSPort = ccrevhttpsport;
    CSb.CCRevHTTPSPortList = ccrevhttpsportlist;
    CSb.HostingPartner = hostingpartner;
    CSb.APIKey = key;
    BlockStore(CSb);
    
    if (addrchangedf) then begin
      LogText(0,"The Cloud Controller address was changed to " & trim(addr) & ":" & ccport & " (" & StringFromSet(614,hostingpartner) & ")");
      QuitApplication(0,false);
    end;
  end else begin
    LogText(0,"Error: " & errmsg);
  end;

  return;
end;

procedure AddFunctionOnWebBlockRow(record FunctionsOnWebBlock FOWb,string func,Integer sslf)
begin
  row FunctionsOnWebBlock FOWrw;

  FOWrw.Function = func;
  FOWrw.UserType = 0;
  FOWrw.SSLRequired = sslf;
  FOWrw.HMACRequired = 0;
  FOWrw.AllowedIPs = "";
  MatRowPut(FOWb,MatRowCnt(FOWb),FOWrw);

  return;
end;

procedure AddAccessVcRow(record AccessVc Ar,LongInt type,string name,LongInt level)
begin
  row AccessVc Arw;

  Arw.AccType = type;
  Arw.AccName = name;
  Arw.AccLevel = level;
  Arw.OpenType = kOpenTypeList;
  MatRowPut(Ar,MatRowCnt(Ar),Arw);

  return;
end;

procedure AddASPControllersBlockRow(record ASPControllersBlock ACb,LongInt type,string ipaddr,LongInt polling_port,
                                    LongInt http_port,LongInt https_port,string pollingportlist,string key)
begin
  row ASPControllersBlock ACrw;

  ACrw.IPAddress = ipaddr;
  ACrw.PollingPort = polling_port;
  ACrw.HttpPort = http_port;
  ACrw.Port = https_port;
  ACrw.Key = key;
  ACrw.ServerIsCloudController = type;
  ACrw.PollingPortList = pollingportlist;
  MatRowPut(ACb,MatRowCnt(ACb),ACrw);

  return;
end;

