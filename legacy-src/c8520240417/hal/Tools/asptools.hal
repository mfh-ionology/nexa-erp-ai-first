global
function Integer CloudNodeStatus(record CloudNodeVc CNr)
begin
  Integer res;

  if (CNr.Closed!=0) then begin
    res = kCloudNodeStatusUnreachable;
    goto LCloudNodeStatus;
  end;

  switch (CNr.CurrentState) begin
    case kCloudNodeStateCreating:     res = kCloudNodeStatusUnreachable; goto LCloudNodeStatus;
    case kCloudNodeStateStopping:     res = kCloudNodeStatusUnreachable; goto LCloudNodeStatus;
    case kCloudNodeStateStopped:      res = kCloudNodeStatusUnreachable; goto LCloudNodeStatus;
    case kCloudNodeStateStarting:     res = kCloudNodeStatusUnreachable; goto LCloudNodeStatus;
    case kCloudNodeStateMoving:       res = kCloudNodeStatusUnreachable; goto LCloudNodeStatus;
    case kCloudNodeStateTerminating:  res = kCloudNodeStatusUnreachable; goto LCloudNodeStatus;
    case kCloudNodeStateModifying:    res = kCloudNodeStatusUnreachable; goto LCloudNodeStatus;
  end;

  if (CNr.ReachableFlag==0) then begin
    res = kCloudNodeStatusUnreachable;
    goto LCloudNodeStatus;
  end;

  if (CNr.VersionBuild!=VersionBuild) then begin
    res = kCloudNodeStatusDifferentVersion;
    goto LCloudNodeStatus;
  end;

  res = kCloudNodeStatusReachable;

LCloudNodeStatus:;
  CloudNodeStatus = res;
  return;
end;

function Boolean RCSIsQueuedForAction(UUID server_uuid,LongInt cnaction)
begin
  Boolean res,foundf;
  record CloudNodeActionQueueVc CNAQr;
  
  res = true;
  CNAQr.Action = cnaction;
  while (LoopKey("ActionLongParam1",CNAQr,1,foundf)) begin
    if (CNAQr.Action!=cnaction) then begin foundf = false; end;
    if (foundf) then begin
      if (CNAQr.UUIDParam1==server_uuid) then begin
        if (cnaction==kCloudActionStartMoveServer) then begin
          if (NonBlankTime(CNAQr.BlockedStartTime) and NonBlankTime(CNAQr.BlockedEndTime)) then begin
            if ((CurrentTime<CNAQr.BlockedStartTime) or (CurrentTime>CNAQr.BlockedEndTime)) then begin
              goto LRCSIsQueuedForAction;
            end;
          end;
        end else begin
          goto LRCSIsQueuedForAction;
        end;
      end;
    end;
  end;
  res = false;
  
LRCSIsQueuedForAction:;
  RCSIsQueuedForAction = res;
  return;
end;

global
function Boolean RCSIsAllowedToStart(record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  record ServerArchivingQueueVc SAQr;

  SAQr.ServerUUID = RCSr.UUID;
  if (ReadFirstMain(SAQr,1,true)) then begin
    if (RCSr.WantedStatus==kWantedStatusExportDatabase) then begin
      if (blankdate(SAQr.RequestedDate) and blanktime(SAQr.RequestedTime)) then begin
        res = true;
      end;
    end;
    goto LRCSIsAllowedToStart;
  end;
  
  if (RCSIsQueuedForAction(RCSr.UUID,kCloudActionStartMoveServer)) then begin goto LRCSIsAllowedToStart; end;
  if (RCSIsQueuedForAction(RCSr.UUID,kCloudActionEndMoveServer)) then begin goto LRCSIsAllowedToStart; end;
  if (RCSIsQueuedForAction(RCSr.UUID,kCloudActionFinishMoveServer)) then begin goto LRCSIsAllowedToStart; end;
  
  res = true;

LRCSIsAllowedToStart:;
  RCSIsAllowedToStart = res;
  return;
end;

