global
updating procedure SetServerBlockStartupOnNodeFlag(UUID server_uuid,Integer blockf)
begin
  record LocalCloudServerVc OldLCSr,LCSr;

  LCSr.UUID = server_uuid;
  if (ReadFirstMain(LCSr,1,true)) then begin
    RecordCopy(OldLCSr,LCSr);
    LCSr.BlockStartupOnNodeFlag = blockf;
    RecordUpdate(OldLCSr,LCSr,true);
  end;
  
  return;
end;

global
procedure DoServerArchiveCancel(UUID server_uuid,LongInt reason)
begin
  record CloudSettingsBlock CSb;
  string 255 cncode,url;
  LongInt stat;

  BlockLoad(CSb);
  
  qupdating.SetServerBlockStartupOnNodeFlag(server_uuid,0);
  SetGlobalBoolean("%CN-ARCHIVE-" & server_uuid,false);

LDoServerArchiveCancel_again:;
  cncode = CSb.NodeCode;
  if (nonblank(CSb.CCAddr) and (CSb.CCHTTPSPort>0)) then begin
    url = Trim(CSb.CCAddr) & ":" & CSb.CCHTTPSPort;
    stat = CallService(url).NodeCancelledArchivingOfServer(server_uuid,reason);
    if (stat!=kCallServiceOK) then begin
      Sleep(10);
      goto LDoServerArchiveCancel_again;
    end;
    if (reason==kCloudArchivingErrorServerGone) then begin
      qupdating.ForceDeleteLCS(server_uuid);
    end;
  end;

  return;
end;

global
updating procedure ServerArchiveCancel(uuid server_uuid,LongInt reason)
begin
  threadasync.DoServerArchiveCancel(server_uuid,reason);
  return;
end;

global
procedure IsArchivingCloudServerOnNode(UUID server_uuid,var Boolean is_archivingf)
begin
  is_archivingf = GetGlobalBoolean("%CN-ARCHIVE-" & server_uuid);
  return;
end;

global
procedure DoArchiveOneCloudServerOnNode(UUID server_uuid)
begin
  record LocalCloudServerVc LCSr;
  string 255 url,lcsr_file,ha_file,cucode;
  Integer stat;
  area a_lcsr;
  val foldersz;
  ULong64 min_diskfree;
  LongInt freespace,totalspace;
  Integer stop_retries;
  
  if (BlankUUID(server_uuid)) begin goto LDoArchiveOneCloudServerOnNode; end;
  
  LCSr.UUID = server_uuid;
  if (qupdating.GetLCSOnMainThread(LCSr)==false) then begin
    goto LDoArchiveOneCloudServerOnNode_ServerGone;
  end;

  if (LCSr.Closed!=0) then begin
    goto LDoArchiveOneCloudServerOnNode_ServerGone;
  end;
  if (blank(trim(LCSr.DataFolder))) then begin
    goto LDoArchiveOneCloudServerOnNode_ServerGone;
  end;
  if (DirExists(LCSr.DataFolder)==false) then begin
    goto LDoArchiveOneCloudServerOnNode_ServerGone;
  end;

  SetGlobalBoolean("%CN-ARCHIVE-" & server_uuid,true);
  qupdating.SetServerBlockStartupOnNodeFlag(server_uuid,1);

LDoArchiveOneCloudServerOnNode_waitforstop:;
  if ((LCSr.CurrentStatus!=kStatusStopped) and (LCSr.CurrentStatus!=kStatusConfigInError)) then begin
    stop_retries = stop_retries + 1;
    if (stop_retries<60) then begin
      Sleep(1);
      goto LDoArchiveOneCloudServerOnNode_waitforstop;
    end;
    SetGlobalBoolean("%CN-ARCHIVE-" & server_uuid,false);
    qupdating.SetServerBlockStartupOnNodeFlag(server_uuid,0);
    goto LDoArchiveOneCloudServerOnNode;
  end;

  ha_file = "tmp/" & server_uuid & "/DF" & DateToString(CurrentDate,"YYYYMMDD") & "-" & TimeToString(CurrentTime,"HHMM",false) & ".ha";
  if (FileExists(ha_file)) then begin
    Delete_file(ha_file);
  end;

  foldersz = GetFolderSize(LCSr.DataFolder);
  freespace = GetDiskSpace("tmp",totalspace);
  min_diskfree = foldersz;
  min_diskfree = min_diskfree/1024/1024;
  min_diskfree = min_diskfree + (2*1024); // 2Gb margin
  if (freespace<min_diskfree) then begin
    qupdating.SetLocalCloudServerErrorStatus(LCSr,10046,"Archiving suspended because there is not enough disk space, need at least an extra " & FileSizeToString((min_diskfree-freespace)*1024*1024),FileSizeToString((min_diskfree-freespace)*1024*1024));
    SetGlobalBoolean("%CN-ARCHIVE-" & server_uuid,false);
    qupdating.SetServerBlockStartupOnNodeFlag(server_uuid,0);
    goto LDoArchiveOneCloudServerOnNode;
  end;
  
  if (LCSr.MyStandardStatusCode==10046) then begin
    LCSr.StatusText = "";
    LCSr.MyStandardStatusCode = -1;
    LCSr.MyStandardStatusStr = "";
  end;

  lcsr_file = LCSr.DataFolder & "/server_uuid.dat";
  Delete_file(lcsr_file);
  if (FileExists(PidFile(LCSr))) then begin
    Delete_file(PidFile(LCSr));
  end;
  LCSr.BlockStartupOnNodeFlag = 0;
  LCSr.RetainRecordDatesFlag = 0;
  AddRecordToArea(LCSr,"LocalCloudServerVc",a_lcsr);
  WriteAreaToFile(a_lcsr,lcsr_file,0);

  CreateFolderHierarchy(DirName(ha_file));
  BeginArchiveToFile(ha_file);
  AddArchiveDir(".",LCSr.DataFolder); //TODO: add exclusion list
  EndArchive;

  cucode = trim(LCSr.HMCUCode);
  if (blank(cucode)) then begin cucode = LCSr.CUCode; end;
  qupdating.CallStartServerArchiveUpload(ha_file,server_uuid,cucode,LCSr.Contract,LCSr.HMRegInCountry,true);
  goto LDoArchiveOneCloudServerOnNode;
  
LDoArchiveOneCloudServerOnNode_ServerGone:;
  queued.ServerArchiveCancel(server_uuid,kCloudArchivingErrorServerGone);
  
LDoArchiveOneCloudServerOnNode:;
  return;
end;

global
procedure ArchiveOneCloudServerOnNode(UUID server_uuid)
begin
  ThreadAsync.DoArchiveOneCloudServerOnNode(server_uuid);
  return;
end;

