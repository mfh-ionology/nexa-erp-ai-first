/*** THIS FUNCTION IS CALLED FROM C - DO NOT CHANGE THE PARAMETERS ***/
global
procedure CleanFilesOnAllLCSs()
begin
  record LocalCloudServerVc LCSr;
  LongInt srvcnt;
  Boolean loggedf;
  
  LogText2(0,"*** Starting to clean files in cloud server folders ***",kVerbosityDebug);
  srvcnt = 0;
  while (LoopMain(LCSr,1,true)) begin
    CleanFilesOnOneLCS(LCSr,loggedf);
    srvcnt = srvcnt + 1;
  end;
  LogText2(0,"*** Finished cleaning files in " & srvcnt & " cloud server folders ***",kVerbosityDebug);
end;

global
procedure ASPCleanLCSFilesTask(string arg)
begin
  Boolean criticalf,loggedf;
  
  criticalf = IsServerSpaceCriticallyLow(loggedf);

  if (criticalf or Right(TimeToString(CurrentTime,"MM",false),1)=="5") then begin // once every 10 minutes unless critical
    goto LASPCleanLCSFilesTask_Clean;
  end;
  goto LASPCleanLCSFilesTask;

LASPCleanLCSFilesTask_Clean:;
  DeleteCoreFiles;
  DeleteOldverFolders;
  CleanVersionsFolders;
  CleanFilesOnAllLCSs;
  
  if (!criticalf) then begin
    // to prevent this running twice during this minute
    while ((QuitingApplication==false) and (Right(TimeToString(CurrentTime,"MM",false),1)=="5")) begin
      MilliSleep(200);
    end;
  end;

LASPCleanLCSFilesTask:;
  return;
end;

