global
updating procedure SetServerTBExportRequested(UUID server_uuid)
begin
  record ServerArchivingQueueVc OldSAQr,SAQr;
  
  SAQr.ServerUUID = server_uuid;
  if (ReadFirstMain(SAQr,1,true)) then begin
    RecordCopy(OldSAQr,SAQr);
    SAQr.BackupDate = CurrentDate;
    SAQr.BackupTime = CurrentTime;
    RecordUpdate(OldSAQr,SAQr,true);
  end;
  
  return;
end;

function Boolean HasChildSystemInSubfolder(record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  record RemoteCloudServerVc RCS2r;
  row RemoteCloudServerVc RCSrw;
  LongInt rwcnt,rwn;
  string 255 tstr;

  rwcnt = MatRowCnt(RCSr);
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(RCSr,rwn,RCSrw);
    if (((RCSrw.Item==kManagedServerItemReserveSystem) or
        (RCSrw.Item==kManagedServerItemTestSystem) or
        (RCSrw.Item==kManagedServerItemUpdateSystem)) and (RCSrw.Disabled==0)) then begin
      RCS2r.UUID = StringToUUID(RCSrw.ItemName);
      if (ReadFirstMain(RCS2r,1,true)) then begin
        if (RCS2r.Closed==0 and RCS2r.Controller==RCSr.Controller) then begin
          tstr = RCSr.DataFolder;
          if (Right(tstr,1)!="/") then begin tstr = tstr & "/"; end;
          if (Left(RCS2r.DataFolder,len(tstr))==tstr) then begin
            res = true;
            goto LHasChildSystemInSubfolder;
          end;
        end;
      end;
    end;
  end;
  
LHasChildSystemInSubfolder:;
  HasChildSystemInSubfolder = res;
  return;
end;

global
updating procedure QueueOnePlannedCloudNodeAction(LongInt sernr,LongInt mothernr,Integer cnaction,UUID uuidparam1,Integer intparam1,
                                                  LongInt longparam1,Time blocked_start_time,Time blocked_end_time,Date planned_date,
                                                  Time planned_time)
begin
  record CloudNodeActionQueueVc CNAQr;
  LongInt retry_cnt;

  retry_cnt = 0;
  if (sernr>0) then begin
    CNAQr.SerNr = sernr;
    if (ReadFirstMain(CNAQr,1,true)) then begin
      retry_cnt = CNAQr.RetryCount;
      if (retry_cnt<0) then begin retry_cnt = 0; end;
      retry_cnt = retry_cnt + 1;
      RecordDelete(CNAQr);
    end;
  end;
  
  RecordNew(CNAQr);
  CNAQr.SerNr = NextSerNr("CloudNodeActionQueueVc",CurrentDate,-1,false,"");
  CNAQr.QueuedDate = CurrentDate;
  CNAQr.QueuedTime = CurrentTime;
  CNAQr.RetryCount = retry_cnt;
  CNAQr.UUIDParam1 = uuidparam1;
  CNAQr.IntParam1 = intparam1;
  CNAQr.LongParam1 = longparam1;
  CNAQr.Action = cnaction;
  CNAQr.MotherAction = mothernr;
  CNAQr.PendingActionCount = 0;
  CNAQr.BlockedStartTime = blocked_start_time;
  CNAQr.BlockedEndTime = blocked_end_time;
  CNAQr.PlannedDate = planned_date;
  CNAQr.PlannedTime = planned_time;
  if (RecordStore(CNAQr,true)) then begin end;
  UpdateClientBrowsesIfNeeded("CloudNodeActionQueueVc");

  return;
end;

global
updating procedure QueueOneCloudNodeAction(LongInt sernr,LongInt mothernr,Integer cnaction,UUID uuidparam1,Integer intparam1,LongInt longparam1,
                                           Time blocked_start_time,Time blocked_end_time)
begin
  Date blank_dt;
  Time blank_tm;
  QueueOnePlannedCloudNodeAction(sernr,mothernr,cnaction,uuidparam1,intparam1,longparam1,
                                 blocked_start_time,blocked_end_time,blank_dt,blank_tm);
  return;
end;


global
updating procedure FixupMoveOfChildSystemsInSubfolder(record ServerMoveVc SMr,record RemoteCloudServerVc RCSr)
begin
  Boolean res,foundf,found_cnaqr;
  record CloudNodeActionQueueVc CNAQr;
  record RemoteCloudServerVc RCS2r;
  row RemoteCloudServerVc RCSrw;
  LongInt rwcnt,rwn;
  string 255 tstr;

  rwcnt = MatRowCnt(RCSr);
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(RCSr,rwn,RCSrw);
    if (((RCSrw.Item==kManagedServerItemReserveSystem) or
        (RCSrw.Item==kManagedServerItemTestSystem) or
        (RCSrw.Item==kManagedServerItemUpdateSystem)) and (RCSrw.Disabled==0)) then begin
      RCS2r.UUID = StringToUUID(RCSrw.ItemName);
      if (ReadFirstMain(RCS2r,1,true)) then begin
        if (RCS2r.Closed==0 and RCS2r.Controller==RCSr.Controller) then begin
          tstr = RCSr.DataFolder;
          if (Right(tstr,1)!="/") then begin tstr = tstr & "/"; end;
          if (Left(RCS2r.DataFolder,len(tstr))==tstr) then begin
            found_cnaqr = false;
            CNAQr.Action = kCloudActionStartMoveServer;
            CNAQr.LongParam1 = SMr.SerNr;
            foundf = true;
            while (LoopKey("ActionLongParam1",CNAQr,2,foundf)) begin
              if (CNAQr.LongParam1!=SMr.SerNr) then begin foundf = false; end;
              if (CNAQr.Action!=kCloudActionStartMoveServer) then begin foundf = false; end;
              if (foundf) then begin
                if (CNAQr.UUIDParam1==RCS2r.UUID) then begin
                  found_cnaqr = true;
                  foundf = false;
                end;
              end;
            end;
            if (found_cnaqr==false) then begin
              CallService(RcsNodeURL(RCS2r)).ForceDeleteLCS(RCS2r.UUID);
              UpdateRCSController(RCS2r,SMr.ToController);
            end;
          end;
        end;
      end;
    end;
  end;
  
  return;
end;

function Boolean IsChildSystemOfClosedSystem(record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  record RemoteCloudServerVc RCS2r;
  row RemoteCloudServerVc RCSrw;
  LongInt rwcnt,rwn;
  string 255 url,tstr;

  rwcnt = MatRowCnt(RCSr);
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(RCSr,rwn,RCSrw);
    if (RCSrw.Item==kManagedServerItemMotherSystem and RCSrw.Disabled==0) then begin
      RCS2r.UUID = StringToUUID(RCSrw.ItemName);
      if (ReadFirstMain(RCS2r,1,true)) then begin
        if (RCS2r.Closed!=0 or RCS2r.ArchivedFlag!=0) then begin
          res = true;
          goto LIsChildSystemOfClosedSystem;
        end;
      end else begin
        res = true;
        goto LIsChildSystemOfClosedSystem;
      end;
    end;
  end;
  
LIsChildSystemOfClosedSystem:;
  IsChildSystemOfClosedSystem = res;
  return;
end;

global
function Boolean IsChildSystemInSubfolder(record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  record RemoteCloudServerVc RCS2r;
  row RemoteCloudServerVc RCSrw;
  LongInt rwcnt,rwn;
  string 255 url,tstr;

  rwcnt = MatRowCnt(RCSr);
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(RCSr,rwn,RCSrw);
    if (RCSrw.Item==kManagedServerItemMotherSystem and RCSrw.Disabled==0) then begin
      RCS2r.UUID = StringToUUID(RCSrw.ItemName);
      if (ReadFirstMain(RCS2r,1,true)) then begin
        if (RCS2r.Controller==RCSr.Controller) then begin
          tstr = RCS2r.DataFolder;
          if (Right(tstr,1)!="/") then begin tstr = tstr & "/"; end;
          if (Left(RCSr.DataFolder,len(tstr))==tstr) then begin
            res = true;
            goto LIsChildSystemInSubfolder;
          end;
        end;
      end;
    end;
  end;
  
LIsChildSystemInSubfolder:;
  IsChildSystemInSubfolder = res;
  return;
end;

global
updating procedure QueueOneServerForArchiving(uuid server_uuid,LongInt force_without_tbf)
begin
  record RemoteCloudServerVc RCSr;
  record ServerArchivingQueueVc SAQr;
  record CloudSettingsBlock CSb;
  LongInt retry_cnt;

  BlockLoad(CSb);
  if (force_without_tbf<1) then begin
    switch (CSb.CloudArchivingState) begin
      case kCloudArchivingStateQueueOnly:
      case kCloudArchivingStateOn:
      case kCloudArchivingStateOnWithoutTB:
      otherwise
        goto LQueueOneServerForArchiving;
    end;
  end;

  if (BlankUUID(server_uuid)) then begin goto LQueueOneServerForArchiving; end;
  
  RCSr.UUID = server_uuid;
  if (ReadFirstMain(RCSr,1,true)==false) begin goto LQueueOneServerForArchiving; end;

  retry_cnt = 0;
  SAQr.ServerUUID = server_uuid;
  if (ReadFirstMain(SAQr,1,true)) then begin
    retry_cnt = SAQr.RetryCount;
    if (retry_cnt<0) then begin retry_cnt = 0; end;
    retry_cnt = retry_cnt + 1;
    RecordDelete(SAQr);
    RecordClear(SAQr);
  end;
  
  RecordNew(SAQr);
  SAQr.ServerUUID = server_uuid;
  SAQr.QueuedDate = CurrentDate;
  SAQr.QueuedTime = CurrentTime;
  SAQr.Controller = RCSr.Controller;
  SAQr.RetryCount = retry_cnt;
  SAQr.InitiatedManuallyFlag = force_without_tbf;
  if (RecordStore(SAQr,true)) then begin end;

LQueueOneServerForArchiving:;
  return;
end;

global
updating procedure ArchiveChildSystemsInSubFolder(record RemoteCloudServerVc RCSr,LongInt force_without_tbf)
begin
  Boolean res;
  record RemoteCloudServerVc RCS2r;
  row RemoteCloudServerVc RCSrw;
  LongInt rwcnt,rwn;

  rwcnt = MatRowCnt(RCSr);
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(RCSr,rwn,RCSrw);
    if (IsChildSystemServerItem(RCSrw.Item)) then begin
      RCS2r.UUID = StringToUUID(RCSrw.ItemName);
      if (ReadFirstMain(RCS2r,1,true)) then begin
        if (IsChildSystemInSubfolder(RCS2r)) then begin
          QueueOneServerForArchiving(RCS2r.UUID,force_without_tbf);
        end;
      end;
    end;
  end;
  
  return;
end;

global
function Boolean ArchiveOneRemoteCloudServer(uuid server_uuid)
begin
  record RemoteCloudServerVc RCSr;
  string 255 url;
  Integer stat;
  record CloudSettingsBlock CSb;
  record ServerArchivingQueueVc SAQr;
  record CloudNodeVc CNr;
  Boolean node_is_busyf;
  Boolean deletef;

  if (BlankUUID(server_uuid)) begin goto LArchiveOneRemoteCloudServer; end;

  SAQr.ServerUUID = server_uuid;
  if (!qupdating.GetServerArchivingRec(SAQr)) then begin goto LArchiveOneRemoteCloudServer; end;
  
  deletef = true;
  RCSr.UUID = server_uuid;
  if (qupdating.GetRCSOnMainThread(RCSr)==false) then begin goto LArchiveOneRemoteCloudServer; end;

  if (RCSr.Closed!=0 and blankdate(SAQr.RequestedDate)) then begin goto LArchiveOneRemoteCloudServer; end;

  url = RcsNodeURL(RCSr);
  if (blank(url)) then begin goto LArchiveOneRemoteCloudServer; end;

  if (blank(trim(RCSr.DataFolder))) then begin goto LArchiveOneRemoteCloudServer; end;

  CNr.Code = RCSr.Controller;
  if (ReadFirstMain(CNr,1,true)==false) then begin goto LArchiveOneRemoteCloudServer; end;

  deletef = false;
  
  if (SAQr.InitiatedManuallyFlag==0 and NodeIsBeingMoved(CNr.Code)) then begin goto LArchiveOneRemoteCloudServer; end;
  if (CloudNodeStatus(CNr)!=kCloudNodeStatusReachable) then begin goto LArchiveOneRemoteCloudServer; end;

  if (SAQr.InitiatedManuallyFlag==0) then begin
    if (IsChildSystemOfClosedSystem(RCSr)) then begin
      qupdating.DoCloseRemoteCloudServer(RCSr);
      stat = CallService(url).ForceDeleteLCS(RCSr.UUID);
      if (TreatServiceError(stat,url,"ForceDeleteLCS")) then begin goto LArchiveOneRemoteCloudServer; end;
      deletef = true;
      goto LArchiveOneRemoteCloudServer;
    end;
    
    if (IsChildSystemInSubfolder(RCSr)) then begin
      if (RCSr.CurrentStatus!=kStatusStopped) then begin
        qupdating.SetServerRetainRecordDatesFlag(RCSr.UUID,1);
        if (IsMinutesPastCurrentTime(SAQr.QueuedDate,SAQr.QueuedTime,30)) then begin
          // We gave the server 30 minutes to stop, let's give up
          qupdating.ForceStopRemoteCloudServer(RCSr);
        end else begin
          qupdating.StopRemoteCloudServer(RCSr,false);
        end;
        goto LArchiveOneRemoteCloudServer;
      end;

      qupdating.DoCloseRemoteCloudServer(RCSr);
      stat = CallService(url).ForceDeleteLCS(RCSr.UUID);
      if (TreatServiceError(stat,url,"ForceDeleteLCS")) then begin goto LArchiveOneRemoteCloudServer; end;
      deletef = true;
      goto LArchiveOneRemoteCloudServer;
    end;
  end;
  
  if (HasChildSystemInSubfolder(RCSr)) then begin
    qupdating.ArchiveChildSystemsInSubFolder(RCSr,SAQr.InitiatedManuallyFlag);
    goto LArchiveOneRemoteCloudServer; // We delay the move until all child systems in the same folder have been moved
  end;
  
  node_is_busyf = true;
  
  BlockLoad(CSb);
  if (SAQr.InitiatedManuallyFlag>=1) then begin
    if (RCSr.CurrentStatus!=kStatusStopped) then begin
      qupdating.SetServerRetainRecordDatesFlag(server_uuid,1);
      if (IsMinutesPastCurrentTime(SAQr.QueuedDate,SAQr.QueuedTime,30)) then begin
        // We gave the server 30 minutes to stop, let's give up
        qupdating.ForceStopRemoteCloudServer(RCSr);
      end else begin
        qupdating.StopRemoteCloudServer(RCSr,false);
      end;
      goto LArchiveOneRemoteCloudServer;
    end;
    
    if (IsDateOlderThanDays(SAQr.QueuedDate,2)) then begin // if not completed after 2 days, we'll archive it anyway
      if ((RCSr.CurrentStatus!=kStatusStopped)) then begin
        qupdating.SetServerRetainRecordDatesFlag(server_uuid,1);
        qupdating.ForceStopRemoteCloudServer(RCSr);
        goto LArchiveOneRemoteCloudServer;
      end;
    end;
  end else begin
    switch (CSb.CloudArchivingState) begin
      case kCloudArchivingStateOn:
        if (BlankDate(SAQr.BackupDate) and
            (RCSr.CloneFlag==kSystemTypeNormal) and
            (RCSr.WantedStatus!=kWantedStatusExportDatabase) and
            (RCSr.CurrentStatus==kStatusStopped)) then begin
          // Config error etc, means no TB, just archive
          qupdating.SetServerRetainRecordDatesFlag(server_uuid,1);
          qupdating.ExportRemoteCloudServerDatabase(RCSr);
          qupdating.SetServerTBExportRequested(server_uuid);
          goto LArchiveOneRemoteCloudServer;
        end else begin
          if (RCSr.WantedStatus==kWantedStatusExportDatabase) then begin
            if ((RCSr.CurrentStatus!=kStatusStopped) and IsMinutesPastCurrentTime(SAQr.BackupDate,SAQr.BackupTime,30)) then begin
              // We gave the node 30 minutes to do the TB, let's give up
              if ((RCSr.CurrentStatus!=kStatusStopped)) then begin
                qupdating.ForceStopRemoteCloudServer(RCSr);
                goto LArchiveOneRemoteCloudServer;
              end;
            end;
            if (IsDateOlderThanDays(SAQr.QueuedDate,2) or (RCSr.CurrentStatus==kStatusConfigInError)) then begin
              // if not completed after 2 days, we'll archive it anyway
              if ((RCSr.CurrentStatus!=kStatusStopped) and (RCSr.CurrentStatus!=kStatusConfigInError)) then begin
                qupdating.ForceStopRemoteCloudServer(RCSr);
                goto LArchiveOneRemoteCloudServer;
              end;
            end else begin
              goto LArchiveOneRemoteCloudServer;
            end;
          end;
        end;
      case kCloudArchivingStateOnWithoutTB:
      otherwise
        node_is_busyf = false;
        goto LArchiveOneRemoteCloudServer;
    end;
  end;

  switch (RCSr.CurrentStatus) begin
    case kStatusStopped:
    case kStatusConfigInError:
    otherwise
      goto LArchiveOneRemoteCloudServer;
  end;

  stat = CallService(url).ArchiveOneCloudServerOnNode(RCSr.UUID);
  if (TreatServiceError(stat,url,"ArchiveOneCloudServerOnNode")) then begin
    SetCloudControllerStatus(kJobStatusError,"Failed archiving of server '" & RCSName(RCSr) & "', couldn't contact node '" & RCSr.Controller & "'");
    LogText(0,"Failed archiving of server '" & RCSName(RCSr) & "', couldn't contact node '" & RCSr.Controller & "'");
    node_is_busyf = false;
    goto LArchiveOneRemoteCloudServer;
  end;
  qupdating.SetServerArchivingRequested(server_uuid);
  
LArchiveOneRemoteCloudServer:;
  if (deletef) then begin
    qupdating.DeleteArchiveQueueRec(server_uuid);
    node_is_busyf = false;
  end;
  ArchiveOneRemoteCloudServer = node_is_busyf;
  return;
end;

global
procedure BackupOneRemoteCloudServer(uuid server_uuid)
begin
  record RemoteCloudServerVc RCSr;
  string 255 url;
  Integer stat;
  record ServerCloudBackupQueueVc SCBQr;

  if (BlankUUID(server_uuid)) begin goto LBackupOneRemoteCloudServer; end;

  SCBQr.ServerUUID = server_uuid;
  if (ReadFirstMain(SCBQr,1,true)==false) then begin goto LBackupOneRemoteCloudServer; end;
    
  RCSr.UUID = server_uuid;
  if (qupdating.GetRCSOnMainThread(RCSr)==false) then begin goto LBackupOneRemoteCloudServer; end;

  if (RCSr.Closed!=0) then begin goto LBackupOneRemoteCloudServer; end;
  if (blank(trim(RCSr.DataFolder))) then begin goto LBackupOneRemoteCloudServer; end;

  url = RcsNodeURL(RCSr);
  if (blank(url)) then begin goto LBackupOneRemoteCloudServer; end;

//  stat = CallService(url).BackupOneCloudServerOnNode(RCSr.UUID);
  if (TreatServiceError(stat,url,"BackupOneCloudServerOnNode")) then begin
    SetCloudControllerStatus(kJobStatusError,"Failed requesting cloud backup for server '" & RCSName(RCSr) & "', couldn't contact node '" & RCSr.Controller & "'");
    LogText(0,"Failed requesting cloud backup for server '" & RCSName(RCSr) & "', couldn't contact node '" & RCSr.Controller & "'");
    goto LBackupOneRemoteCloudServer;
  end;
  qupdating.SetServerCloudBackupRequested(server_uuid);
  
LBackupOneRemoteCloudServer:;
  return;
end;

function Boolean DownloadArchivedServerOnNode(uuid server_uuid,string haurl)
begin
  string 255 host,path,destfolder;
  LongInt portno;
  Boolean res,sslf;
  
  if (blank(haurl)) then begin
    LogText(0,"ERROR DownloadArchivedServerOnNode url is blank");
    goto LDownloadArchivedServerOnNode;
  end;

  destfolder = ServersFolder & "Auto/";
  if (!DirExists(destfolder)) then begin
    CreateFolderHierarchy(destfolder);
  end;
  destfolder = destfolder & server_uuid;
  if (DirExists(destfolder)) then begin
    MoveFile("/",destfolder,DetermineNextName(destfolder,true,true));
  end;
  GetHostAndPathFromUrl(haurl,host,portno,path,sslf);
  HttpAsyncDownloadHA2(host,portno,sslf,path,30,destfolder,"DownloadArchivedServerOnNodeCallback");
  res = true;

LDownloadArchivedServerOnNode:;
  DownloadArchivedServerOnNode = res;
  return;
end;

function Boolean ServerArchivingTimedout(UUID server_uuid)
begin
  record ServerArchivingQueueVc SAQr;
  record CloudNodeVc CNr;
  Boolean res,is_archivingf;
  Integer stat;
  string 255 url;

  SAQr.ServerUUID = server_uuid;
  if (!qupdating.GetServerArchivingRec(SAQr)) then begin goto LServerArchivingTimedout; end;
  
  if (blankdate(SAQr.RequestedDate)) then begin goto LServerArchivingTimedout; end;

  res = IsDateOlderThanDays(SAQr.RequestedDate,3); // if not completed after 3 days, we'll re-queue it

  if (res==false) then begin
    CNr.Code = SAQr.Controller;
    if (ReadFirstMain(CNr,1,true)==false) then begin
      res = true;
      goto LServerArchivingTimedout;
    end;
    if (CNr.VersionBuild>=85552069) then begin
      url = NodeURL(CNr);
      if (blank(url)) then begin
        res = true;
        goto LServerArchivingTimedout;
      end;
      if (IsMinutesPastCurrentTime(SAQr.RequestedDate,SAQr.RequestedTime,5)) then begin
        stat = CallService(url).IsArchivingCloudServerOnNode(server_uuid,is_archivingf);
        if (TreatServiceError(stat,url,"IsArchivingCloudServerOnNode")) then begin goto LServerArchivingTimedout; end;
        if (is_archivingf==false) then begin
          res = true;
        end;
      end;
    end;
  end;

LServerArchivingTimedout:;
  ServerArchivingTimedout = res;
  return;
end;

function Boolean ServerIsQueuedForArchiving(record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  record ServerArchivingQueueVc SAQr;

  SAQr.ServerUUID = RCSr.UUID;
  if (ReadFirstMain(SAQr,1,true)==false) then begin goto LServerIsQueuedForArchiving; end;
  if (ServerArchivingTimedout(SAQr.ServerUUID)) then begin
    goto LServerIsQueuedForArchiving; // if not completed after 3 days, we'll re-queue it
  end;
  
  res = true;

LServerIsQueuedForArchiving:;
  ServerIsQueuedForArchiving = res;
  return;
end;

function Boolean IsCloudServerOursAndTreatable(record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  record CloudNodeVc CNr;
  
  if (RCSr.Closed!=0) then begin goto LIsCloudServerOursAndTreatable; end;
  if (blank(trim(RCSr.DataFolder))) then begin goto LIsCloudServerOursAndTreatable; end;
  if (RCSr.ArchivedFlag!=0) then begin goto LIsCloudServerOursAndTreatable; end;
  if (blank(RCSr.Controller)) then begin goto LIsCloudServerOursAndTreatable; end;
  
  CNr.Code = RCSr.Controller;
  if (ReadFirstMain(CNr,1,true)==false) then begin goto LIsCloudServerOursAndTreatable; end;
  if (CNr.Closed!=0) then begin goto LIsCloudServerOursAndTreatable; end;
  if (IsInOurHosting(CNr.HostingConfig,CNr.HostingPartner)==false) then begin goto LIsCloudServerOursAndTreatable; end;

  switch (CloudNodeStatus(CNr)) begin
    case kCloudNodeStatusReachable:
    case kCloudNodeStatusDifferentVersion:
    otherwise
      goto LIsCloudServerOursAndTreatable;
  end;
  
  res = true;

LIsCloudServerOursAndTreatable:;
  IsCloudServerOursAndTreatable = res;
  return;
end;

function Boolean IsCloudServerOursAndTreatableForCertCheck(record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  record CloudNodeVc CNr;
  record IntServerTypeBlock ISTb;

  BlockLoad(ISTb);

  if (RCSr.Closed!=0) then begin goto LIsCloudServerOursAndTreatableForCertCheck; end;
  //if (RCSr.HTTPSPort<=0) then begin goto LIsCloudServerOursAndTreatableForCertCheck; end; // we check the cert file
  if (blank(trim(RCSr.DataFolder))) then begin goto LIsCloudServerOursAndTreatableForCertCheck; end;
  if (RCSr.ArchivedFlag!=0) then begin goto LIsCloudServerOursAndTreatableForCertCheck; end;
  if (blank(RCSr.Controller)) then begin goto LIsCloudServerOursAndTreatableForCertCheck; end;
  if (ISTB.Server!=kInternalServerConsCloudController) then begin
    if ((RCSr.CurrentStatus!=kStatusRunning) and
        (RCSr.CurrentStatus!=kStatusMaintenance) and
        (RCSr.CurrentStatus!=kStatusRunningPendingStop) and
        (RCSr.CurrentStatus!=kStatusRunningTest)) then begin
      if (blank(RCSr.SSLCertFile) and blank(RCSr.SSLPrivKeyFile)) then begin goto LIsCloudServerOursAndTreatableForCertCheck; end;
    end;
  end;
  
  CNr.Code = RCSr.Controller;
  if (ReadFirstMain(CNr,1,true)==false) then begin goto LIsCloudServerOursAndTreatableForCertCheck; end;
  if (CNr.Closed!=0) then begin goto LIsCloudServerOursAndTreatableForCertCheck; end;
  if (IsInOurHosting(CNr.HostingConfig,CNr.HostingPartner)==false) then begin goto LIsCloudServerOursAndTreatableForCertCheck; end;
  
  res = true;

LIsCloudServerOursAndTreatableForCertCheck:;
  IsCloudServerOursAndTreatableForCertCheck = res;
  return;
end;

function Boolean ServerShouldBeArchived(record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  record CloudNodeVc CNr;
  LongInt days;
  record CloudSettingsBlock CSb;
  
  if (IsCloudServerOursAndTreatable(RCSr)==false) then begin goto LServerShouldBeArchived; end;
  if ((RCSr.CurrentStatus!=kStatusStopped) and (RCSr.CurrentStatus!=kStatusConfigInError)) then begin goto LServerShouldBeArchived; end;
  if (blank(trim(RCSr.DataFolder))) then begin goto LServerShouldBeArchived; end;
  
  BlockLoad(CSb);
  if (IsDevelopmentVersion(RCSr.HansaVersion)) then begin
    days = CSb.ArchDevAfter;
    if (days<=0) then begin days = 30; end; // 1 month
    if (RemoteCloudServerSeenInDays(RCSr,days)) then begin goto LServerShouldBeArchived; end;
    if (ServerIsQueuedForArchiving(RCSr)==false) then begin
      res = true;
    end;
    goto LServerShouldBeArchived;
  end;
  
  if (ServerIsStandardServer(RCSr)) then begin
    days = CSb.ArchStdSvrAfter;
    if (days<=0) then begin days = 730; end; // 2 years
    if (RemoteCloudServerSeenInDays(RCSr,days)) then begin goto LServerShouldBeArchived; end;
    if (ServerIsQueuedForArchiving(RCSr)==false) then begin
      res = true;
    end;
    goto LServerShouldBeArchived;
  end;
  
  days = CSb.ArchStdERPAfter;
  if (days<=0) then begin days = 1095; end; // 3 years
  if (RemoteCloudServerSeenInDays(RCSr,days)) then begin goto LServerShouldBeArchived; end;
  if (ServerIsQueuedForArchiving(RCSr)==false) then begin
    res = true;
  end;

LServerShouldBeArchived:;
  ServerShouldBeArchived = res;
  return;
end;

function Boolean ServerShouldBeCertChecked(record RemoteCloudServerVc RCSr,LongInt days)
begin
  Boolean res;
  record CertCheckHistVc CCHr;
  
  if (IsCloudServerOursAndTreatableForCertCheck(RCSr)==false) then begin goto LServerShouldBeCertChecked; end;
    
  CCHr.UUID = RCSr.UUID;
  if (ReadFirstMain(CCHr,1,true)) then begin
    if (CertCheckHistoryCheckedInDays(CCHr,days)) then begin goto LServerShouldBeCertChecked; end;
  end;
  
  res = true;

LServerShouldBeCertChecked:;
  ServerShouldBeCertChecked = res;
  return;
end;

function Boolean ServerShouldDoCloudBackup(record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  LongInt days;
  
  if (IsCloudServerOursAndTreatable(RCSr)==false) then begin goto LServerShouldDoCloudBackup; end;
  if ((RCSr.CurrentStatus!=kStatusStopped) and (RCSr.CurrentStatus!=kStatusConfigInError)) then begin goto LServerShouldDoCloudBackup; end;
  if (IsDevelopmentVersion(RCSr.HansaVersion)) then begin goto LServerShouldDoCloudBackup; end;
  if (ServerIsStandardServer(RCSr)==false) then begin goto LServerShouldDoCloudBackup; end;

  if (nonblankdate(RCSr.LastCloudBackupDate)) then begin
    if (LastActivityDateForServer(RCSr)>RCSr.LastCloudBackupDate) then begin goto LServerShouldDoCloudBackup; end;
  end;

  res = true;
  
LServerShouldDoCloudBackup:;
  ServerShouldDoCloudBackup = res;
  return;
end;

global
updating procedure NodeFinishedArchivingServer(UUID server_uuid,Boolean successf,LongInt in_force_without_tbf)
begin
  date dt;
  time tm;
  record RemoteCloudServerVc OldRCSr,RCSr;
  record ServerArchivingQueueVc SAQr;
  LongInt force_without_tbf;
  
  force_without_tbf = in_force_without_tbf;

  dt = CurrentDate;
  tm = CurrentTime;
  
  RCSr.UUID = server_uuid;
  if (ReadFirstMain(RCSr,1,true)==false) then begin goto LNodeFinishedArchivingServer; end;

  if (successf) then begin
    RecordCopy(OldRCSr,RCSr);
    RCSr.ArchivedFlag = 1;
    RCSr.ArchivedDate = dt;
    RCSr.ArchivedTime = tm;
    RCSr.Closed = 1;
    RCSr.Controller = "";
    RCSr.NewController = "";
    RCSr.WantedStatus = kWantedStatusStop;
    RCSr.CurrentStatus = kStatusStopped;
    RCSr.WantedSubStatus = kWantedSubStatusNone;
    RCSr.CurrentSubStatus = kSubStatusNone;
    RCSr.RetainRecordDatesFlag = 0;
    RecordUpdate(OldRCSr,RCSr,true);
    
    SAQr.ServerUUID = RCSr.UUID;
    if (ReadFirstMain(SAQr,1,true)) then begin
      RecordDelete(SAQr);
    end;
  end else begin
    if (force_without_tbf<1) then begin
      SAQr.ServerUUID = server_uuid;
      if (ReadFirstMain(SAQr,1,true)) then begin
        force_without_tbf = SAQr.InitiatedManuallyFlag;
      end;
    end;
    QueueOneServerForArchiving(server_uuid,force_without_tbf);
  end;

LNodeFinishedArchivingServer:;
  return;
end;

global
procedure NotifyControllerOfArchivedServer(LongInt queuesernr,UUID server_uuid,Integer isuccess,LongInt force_without_tbf)
begin
  record CloudSettingsBlock CSb;
  string 255 cncode,url;
  Boolean successf;
  LongInt stat;
  Time blank_tm;

  if (isuccess!=0) then begin successf = true; end;
  
  BlockLoad(CSb);
  
  cncode = CSb.NodeCode;
  if (nonblank(CSb.CCAddr) and (CSb.CCHTTPSPort>0)) then begin
    url = Trim(CSb.CCAddr) & ":" & CSb.CCHTTPSPort;
    stat = CallService(url).NodeFinishedArchivingServer(server_uuid,successf,force_without_tbf);
    if (stat!=kCallServiceOK) then begin
      qupdating.QueueOneCloudNodeAction(queuesernr,-1,kCloudActionServerArchivingCompleted,server_uuid,isuccess,force_without_tbf,blank_tm,blank_tm);
      goto LNotifyControllerOfArchivedServer;
    end;
    if (successf) then begin
      qupdating.DoDeleteLocalCloudServer(server_uuid);
    end;
    qupdating.RemoveOneCloudNodeAction(queuesernr);
    SetGlobalBoolean("%CN-ARCHIVE-" & server_uuid,false);
  end;
  
LNotifyControllerOfArchivedServer:;
  return;
end;

global
procedure ServerArchiveUploadCompleted(Boolean successf,string arg)
begin
  record LocalCloudServerVc LCSr;
  uuid server_uuid;
  Integer isuccess;
  Time blank_tm;
  
  if (successf) then begin isuccess = 1; end;
  
  server_uuid = StringToUUID(arg);
  if (BlankUUID(server_uuid)) then begin goto LServerArchiveUploadCompleted; end;
  
  if (successf==true) then begin
    LCSr.UUID = server_uuid;
    if (ReadFirstMain(LCSr,1,true)==false) then begin
      goto LServerArchiveUploadCompleted;
    end;
    if (blank(trim(LCSr.DataFolder))) then begin goto LServerArchiveUploadCompleted; end;
    DeleteFolder(LCSr.DataFolder);
  end;
  
  qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionServerArchivingCompleted,server_uuid,isuccess,-1,blank_tm,blank_tm);

LServerArchiveUploadCompleted:;
  return;
end;

global
procedure CloudServerDailyArchiving(record RemoteCloudServerVc RCSr)
begin
  record CloudSettingsBlock CSb;

  BlockLoad(CSb);
  switch (CSb.CloudArchivingState) begin
    case kCloudArchivingStateOn:
    case kCloudArchivingStateOnWithoutTB:
    case kCloudArchivingStateQueueOnly:
    otherwise
      goto LCloudServerDailyArchiving;
  end;

  if (ServerShouldBeArchived(RCSr)) then begin
    qupdating.QueueOneServerForArchiving(RCSr.UUID,-1);
  end;
  
LCloudServerDailyArchiving:;
  return;
end;

global
updating procedure StoreCertCheckForOneServer(record RemoteCloudServerVc RCSr,string hostname,string name,string issuer,Date expires,Boolean successf)
begin
  record CertCheckHistVc CCHr,OldCCHr;

  CCHr.UUID = RCSr.UUID;
  if (ReadFirstMain(CCHr,1,true)) then begin
    if (successf) then begin
      RecordCopy(OldCCHr,CCHr);
      CCHr.Host = hostname;
      CCHr.Port = RCSr.HTTPSPort;
      CCHr.Name = name;
      CCHr.IssuedBy = issuer;
      CCHr.Expires = expires;
      CCHr.SuccessFlag = 1;
      CCHr.LastChecked = CurrentDate;
      RecordUpdate(OldCCHr,CCHr,true);
    end else begin
      RecordCopy(OldCCHr,CCHr);
      CCHr.Host = hostname;
      CCHr.Port = RCSr.HTTPSPort;
      CCHr.SuccessFlag = 0;
      CCHr.LastChecked = CurrentDate;
      RecordUpdate(OldCCHr,CCHr,true);
    end;
  end else begin
    if (successf) then begin
      RecordNew(CCHr);
      CCHr.UUID = RCSr.UUID;
      CCHr.Host = hostname;
      CCHr.Port = RCSr.HTTPSPort;
      CCHr.Name = name;
      CCHr.IssuedBy = issuer;
      CCHr.Expires = expires;
      CCHr.SuccessFlag = 1;
      CCHr.LastChecked = CurrentDate;
      if (RecordStore(CCHr,true)) then begin end;
    end;
  end;

  return;
end;

global
procedure CertCheckForOneServer(record RemoteCloudServerVc RCSr,var record CertCheckHistVc CCHr)
begin
  record CloudNodeVc CNr;
  string 255 subject,issuer,ccurl,cckey,cnurl,certstr,certnames;
  Integer stat;
  Date expires;
  Boolean successf,scfailf;
  record IntServerTypeBlock ISTb;
  record LocalCloudServerVc LCSr;
  record X509AttributesVc x509attrsr,x509attrs2r;
  Boolean firstf;

  BlockLoad(ISTb);
  if (CCHr.Closed==0) then begin firstf = true; end;
  
  RecordClear(CCHr);
  if (firstf) then begin CCHr.Closed = 1; end;
  
  if (IsCloudNode) then begin
    LCSr.UUID = RCSr.UUID;
    if (ReadFirstMain(LCSr,1,true)) then begin
      if ((LCSr.CurrentStatus!=kStatusRunning) and
          (LCSr.CurrentStatus!=kStatusMaintenance) and
          (LCSr.CurrentStatus!=kStatusRunningPendingStop) and
          (LCSr.CurrentStatus!=kStatusRunningTest)) then begin
        if (blank(LCSr.SSLCertFile) and blank(LCSr.SSLPrivKeyFile)) then begin goto LCertCheckForOneServer; end;
      end;

      if (FileExists(LCSr.DataFolder & "/" & LCSr.SSLCertFile) and !DirExists(LCSr.DataFolder & "/" & LCSr.SSLCertFile)) then begin
        certstr = ReadFileToString(LCSr.DataFolder & "/" & LCSr.SSLCertFile);
        if (nonblank(certstr)) then begin
          GetCertificateDetailsFromString(certstr,subject,issuer,expires,certnames);
          ParseX509Attributes(issuer,x509attrsr);
          ParseX509Attributes(subject,x509attrs2r);
          CCHr.Name = x509attrs2r.CommonName;
          CCHr.IssuedBy = x509attrsr.Organization;
          CCHr.Expires = expires;
          CCHr.SuccessFlag = 1;
        end;
      end;
    end;
    goto LCertCheckForOneServer;
  end;

  CNr.Code = RCSr.Controller;
  if (ReadFirstMain(CNr,1,true)==false) then begin goto LCertCheckForOneServer; end;
  
  if (IsCloudController) then begin
    switch (CloudNodeStatus(CNr)) begin
      case kCloudNodeStatusReachable:
      case kCloudNodeStatusDifferentVersion:
      otherwise
        goto LCertCheckForOneServer;
    end;
    
    if (RCSr.CurrentStatus!=kStatusRunning) then begin
      if (blank(RCSr.SSLCertFile) and blank(RCSr.SSLPrivKeyFile)) then begin goto LCertCheckForOneServer; end;
    end;
    
    cnurl = NodeURL(CNr);
    stat = CallService(cnurl).CertCheckForOneServer(RCSr,CCHr);
    scfailf = TreatServiceError(stat,cnurl,"CertCheckForOneServer");
    queued.SaveCloudNodeReachable(CNr.Code,!scfailf);
  end;

  if (ISTB.Server==kInternalServerConsCloudController) then begin
/*
    if (nonblank(CNr.HostName) and nonblank(RCSr.HTTPSPort)) then begin
      successf = GetCertificateDetails(CNr.HostName,RCSr.HTTPSPort,subject,issuer,expires);
      if (successf) then begin
        CCHr.Name = GetCertSubField(subject,"CN");
        CCHr.IssuedBy = GetCertSubField(issuer,"O");
        CCHr.Expires = expires;
        CCHr.SuccessFlag = 1;
        goto LCertCheckForOneServer;
      end;
    end;
*/
    if (GetCloudControllerForPartner(CNr.HostingPartner,ccurl,cckey)) then begin
      stat = CallService2(ccurl,cckey).CertCheckForOneServer(RCSr,CCHr);
      if (stat!=kCallServiceOK) then begin
        LogText(0,"Certificate check for  " & RCSName(RCSr) & " failed: The node " & CNr.Code & " could not be called because cloud controller " & StringFromSet(614,CNr.HostingPartner) & " couldn't be called");
      end;
    end;
  end;
  
  if (firstf) then begin
    qupdating.StoreCertCheckForOneServer(RCSr,CNr.HostName,CCHr.Name,CCHr.IssuedBy,CCHr.Expires,CCHr.SuccessFlag);
  end;
  
LCertCheckForOneServer:;
  return;
end;

global
procedure CloudServerDailyCertCheck(string arg)
begin
  record RemoteCloudServerVc RCSr;
  record CertCheckHistVc CCHr;
  LongInt cnt;

  cnt = 0;
  while (LoopKey("Controller",RCSr,0,true) and (QuitingApplication==false) and (GetGlobalBoolean("ASPIdleTasksStopped")==false)) begin
    if (ServerShouldBeCertChecked(RCSr,7)) then begin
      RecordClear(CCHr);
      CertCheckForOneServer(RCSr,CCHr);
      cnt = cnt + 1;
    end;
  end;
  if (cnt>0) then begin
    LogText(0,"*** Finished checking certificate status on " & cnt & " cloud servers ***");
  end;

  return;
end;

global
procedure CloudServerCertCheckMn(record RcVc RepSpec)
begin
  record RemoteCloudServerVc RCSr;
  LongInt cnt,i;
  record CertCheckHistVc CCHr;

  cnt = CountRecords("RemoteCloudServerVc");
  i = 0;
  
  while (LoopKey("Controller",RCSr,0,true) and (QuitingApplication==false) and (GetGlobalBoolean("ASPIdleTasksStopped")==false)) begin
    UpdateReportProgress(cnt,i,"");
    if (ServerShouldBeCertChecked(RCSr,-1)) then begin
      RecordClear(CCHr);
      CertCheckForOneServer(RCSr,CCHr);
    end;
    i = i + 1;
  end;
end;

global
updating procedure QueueOneServerForCloudBackup(uuid server_uuid)
begin
  record RemoteCloudServerVc RCSr;
  record ServerCloudBackupQueueVc SCBQr;
  LongInt retry_cnt;

  if (BlankUUID(server_uuid)) then begin goto LQueueOneServerForCloudBackup; end;
  
  RCSr.UUID = server_uuid;
  if (ReadFirstMain(RCSr,1,true)==false) begin goto LQueueOneServerForCloudBackup; end;

  retry_cnt = 0;
  SCBQr.ServerUUID = server_uuid;
  if (ReadFirstMain(SCBQr,1,true)) then begin
    retry_cnt = SCBQr.RetryCount;
    if (retry_cnt<0) then begin retry_cnt = 0; end;
    retry_cnt = retry_cnt + 1;
    RecordDelete(SCBQr);
  end;
  
  RecordNew(SCBQr);
  SCBQr.ServerUUID = server_uuid;
  SCBQr.QueuedDate = CurrentDate;
  SCBQr.QueuedTime = CurrentTime;
  SCBQr.Controller = RCSr.Controller;
  SCBQr.RetryCount = retry_cnt;
  if (RecordStore(SCBQr,true)) then begin end;

LQueueOneServerForCloudBackup:;
  return;
end;

global
procedure CloudServerDailyCloudBackup(record RemoteCloudServerVc RCSr)
begin
  if (ServerShouldDoCloudBackup(RCSr)) then begin
    qupdating.QueueOneServerForCloudBackup(RCSr.UUID);
  end;
  
  return;
end;

global
procedure CloudServerDailyTask(string arg)
begin
  record RemoteCloudServerVc RCSr;

  while (LoopKey("Controller",RCSr,0,true) and (QuitingApplication==false) and (GetGlobalBoolean("ASPIdleTasksStopped")==false)) begin
    CloudServerDailyArchiving(RCSr);
    //CloudServerDailyCloudBackup(RCSr);
  end;
  
  return;
end;

global
procedure ArchiveRemoteCloudServers(array uuid recarr)
begin
  Integer i;
  record CloudSettingsBlock CSb;
  
  BlockLoad(CSb);
  switch (CSb.CloudArchivingState) begin
    case kCloudArchivingStateQueueOnly:
    case kCloudArchivingStateOn:
    case kCloudArchivingStateOnWithoutTB:
    otherwise
      goto LArchiveRemoteCloudServers;
  end;
  
  for (i = 0; i<recarr.length; i = i + 1) begin
    qupdating.QueueOneServerForArchiving(recarr[i],-1);
  end;
  
LArchiveRemoteCloudServers:;
  return;
end;

global
updating procedure ClearServerArchivingQueue()
begin
  RemoveAllRecords("ServerArchivingQueueVc");
  return;
end;

global
updating procedure ResetServerArchivingQueue()
begin
  record ServerArchivingQueueVc OldSAQr,SAQr;
  date blankdt;
  time blanktm;
  
  while (LoopMain(SAQr,1,true)) begin
    RecordCopy(OldSAQr,SAQr);
    SAQr.RequestedDate = blankdt;
    SAQr.RequestedTime = blanktm;
    SAQr.BackupDate = blankdt;
    SAQr.BackupTime = blanktm;
    RecordUpdate(OldSAQr,SAQr,true);
  end;
  return;
end;

global
procedure ReloadEC2InstanceTypesTask(string arg)
begin
  record RcVc RepSpec;

  DoReloadAWSRegionsMn(RepSpec);
  DoReloadEC2InstanceTypes(RepSpec);
  return;
end;

global
procedure TreatCloudArchivingQueueTask(string arg)
begin
  record ServerArchivingQueueVc SAQr,SAQ2r;
  record CloudSettingsBlock CSb;
  vector Boolean active_nodes_vec;
  
  BlockLoad(CSb);

  while (LoopKey("QueuedDate",SAQr,0,true) and (QuitingApplication==false) and (GetGlobalBoolean("ASPIdleTasksStopped")==false)) begin
    SAQ2r.ServerUUID = SAQr.ServerUUID;
    if (!qupdating.GetServerArchivingRec(SAQ2r)) then begin goto LTreatCloudArchivingQueueTask_next; end;
    
    if (SAQ2r.InitiatedManuallyFlag<1) then begin
      switch (CSb.CloudArchivingState) begin
        case kCloudArchivingStateOn:
        case kCloudArchivingStateOnWithoutTB:
        otherwise
          goto LTreatCloudArchivingQueueTask_next;
      end;
    end;
    if (active_nodes_vec[SAQ2r.Controller]==false) then begin
      if (BlankDate(SAQ2r.RequestedDate)) then begin
        active_nodes_vec[SAQ2r.Controller] = ArchiveOneRemoteCloudServer(SAQ2r.ServerUUID);
      end else begin
        if (ServerArchivingTimedout(SAQ2r.ServerUUID)) then begin
          qupdating.QueueOneServerForArchiving(SAQ2r.ServerUUID,-1);
          goto LTreatCloudArchivingQueueTask;
        end else begin
          active_nodes_vec[SAQ2r.Controller] = true;
        end;
      end;
    end;
LTreatCloudArchivingQueueTask_next:;
  end;

LTreatCloudArchivingQueueTask:;
  return;
end;

global
updating procedure UpdateRCSNextWantedStatus(var record RemoteCloudServerVc RCSr,Integer wanted_status)
begin
  record RemoteCloudServerVc OldRCSr;

  if (ReadFirstMain(RCSr,1,true)) then begin
    RecordCopy(OldRCSr,RCSr);
    RCSr.NextWantedStatus = wanted_status;
    if (ComparePosts(OldRCSr,RCSr)==false) then begin
      RecordUpdate(OldRCSr,RCSr,true);
    end;
  end;
  if (ReadFirstMain(RCSr,1,true)) then begin end;
  return;
end;

global
updating procedure RepairHCrMn(record RcVc RepSpec)
begin
  record HostingConfigurationVc HCr;
  LongInt pos;
  record RLinkVc OldRLr,RLr;
  record Attach2Vc AT2r;
  string 255 rlink,tstr;
  Integer compnr;
  string 255 vcname;
  
  while (LoopMain(HCr,0,true)) begin
    ResetLoop(RLr);
    RecordClear(RLr);
    while (LoopMain(RLr,0,true)) begin
      compnr = GetRecordLinkFields(RLr.FromRecidStr,vcname);
      if (vcname=="HostingConfigurationVc") then begin
        compnr = GetRecordLinkFields(RLr.ToRecidStr,vcname);
        if (vcname=="Attach2Vc") then begin
          tstr = "";
          pos = 1;
          while (asc(right(RLr.FromRecidStr,pos))>0) begin
            tstr = asc(right(RLr.FromRecidStr,pos)) & tstr;
            pos = pos + 1;
          end;
          if (nonblank(tstr)) then begin
            if (StringToInt(tstr)==HCr.SerNr) then begin
              RecordCopy(OldRLr,RLr);
              RLr.FromRecidStr = GetRecordLink(HCr);
              RecordUpdate(OldRLr,RLr,false);
              LogText(0,"DEBUG vcname=" & vcname & ", compnr=" & compnr & ", t=" & tstr);
            end;
          end;
        end;
      end;
    end;
  end;
  
  return;
end;

global
updating procedure InitASPIdleTasks()
begin
  record ModuleBlock Modr;
  record CloudSettingsBlock CSb;
  record HansaVersionVc HVr;
  LongInt poll_lcs_interval,sync_cn_interval,check_cn_interval,watchpoint_interval,expire_invites_interval;
  LongInt fastcheck_interval,clean_stats_interval,check_versions_quick_interval,check_versions_slow_interval,autoupdate_interval,cc_status_interval;
  LongInt refreship_interval,archive_lcs_interval,cn_status_interval,update_cn_archive_interval;
  LongInt transfer_to_cloudarchive_interval,download_localizations_interval,clean_versions_interval;
  LongInt clean_cloudarchive_interval,sync_aspevents_interval,clean_lcsfiles_interval,pool_interval;
  LongInt hmcu_interval,cn_update_interval,check_lcs_pid_interval,planned_updates_interval;
  LongInt clean_coredumps_interval,recover_pid_interval,reset_status_interval,auto_reboot_interval;
  LongInt cloud_server_daily_interval,treat_archiving_queue_interval,treat_nodeaction_queue_interval;
  LongInt gather_lcs_info_interval,clean_aspevents_interval;
  Date td;
  Time tm,blank_tm;
  string 255 tstr,pollingport,assignedcncode,ccaddr,pollingportlist,cchttpport,cchttpsport,cchansaport;
  Integer assignedpollingf;
/*
td = AddDay(CurrentDate,0);
tm = AddHours(CurrentTime,0);
td = CurrentDate;
tm = AddMinutes(CurrentTime,1);
LogText(0,"DEBUG diff=" & DateTimeDiffInSeconds(td,tm,CurrentDate,CurrentTime));
tm = AddMinutes(tm,-50);
LogText(0,"DEBUG " & DateToString(td,"YYYY-MM-DD") & " " & TimeToString(tm,"HHMMSS",false));
LogText(0,"DEBUG " & DateToString(CurrentDate,"YYYY-MM-DD") & " " & TimeToString(CurrentTime,"HHMMSS",false));
//if (IsMinutesPastTime(CurrentDate,CurrentTime,td,tm,30)) then begin
if (IsMinutesPastCurrentTime(td,tm,30)) then begin
LogText(0,"DEBUG 1");
end;
if (IsMinutesPastCurrentTime(td,tm,50)) then begin
LogText(0,"DEBUG 2");
end;
if (IsMinutesPastCurrentTime(td,tm,55)) then begin
LogText(0,"DEBUG 3");
end;
*/

  BlockLoad(Modr);
  if (Modr.ASPEnabler) then begin
    BlockLoad(CSb);
    poll_lcs_interval = CSb.PollLocalServersSeconds;
    if (poll_lcs_interval<=0) then begin
      poll_lcs_interval = 5;
    end;
    sync_cn_interval = CSb.PollRemoteServersSeconds;
    if (sync_cn_interval<=0) then begin
      sync_cn_interval = 60;
    end;
    check_cn_interval = sync_cn_interval;
    sync_aspevents_interval = 300; // 5 minutes
    watchpoint_interval = 20;
    expire_invites_interval = 1800; // 30 minutes
    watchpoint_interval = 5;
    fastcheck_interval = 1;
    cc_status_interval = 1;
    cn_status_interval = 1;
    clean_stats_interval = 3600; // 60 minutes
    clean_aspevents_interval = 1;
    
    if (IsCloudController) then begin
      check_versions_quick_interval = 60; // 1 minute
      check_versions_slow_interval = 60 * 15; // 15 minutes
    end else begin
      check_versions_quick_interval = 600; // 10 minutes
      check_versions_slow_interval = 60 * 60 * 4; // 4 hours
    end;
    
    autoupdate_interval = 30; // 30 seconds
    refreship_interval = 10;
    archive_lcs_interval = 3600; // 60 minutes
    update_cn_archive_interval = 300; // 5 minutes
    clean_cloudarchive_interval = 3600; // 60 minutes
    transfer_to_cloudarchive_interval = 3600; // 60 minutes
    download_localizations_interval = 60; // 1 minute
    clean_versions_interval = 1800; // 30 minutes
    pool_interval = 60; // 1 minute
    hmcu_interval = 1800; // 30 minutes
    check_lcs_pid_interval = 30; // 30 seconds
    planned_updates_interval = 15; // 1/4 minute
    if (CSb.NodeUpdateSlowIntervalMins<=0) then begin
      cn_update_interval = 300; // 5 minutes
    end else begin
      cn_update_interval = CSb.NodeUpdateSlowIntervalMins*60;
    end;
    clean_lcsfiles_interval = CleanLCSFilesInterval;
    clean_coredumps_interval = 300; // 5 minutes
    recover_pid_interval = 10; // 10s // too often?
    reset_status_interval = 3600; // 60 minutes
    auto_reboot_interval = 300; // 5 minutes
    cloud_server_daily_interval = 84000; // once per day, no surprises
    treat_archiving_queue_interval = 1;
    treat_nodeaction_queue_interval = 1;
    gather_lcs_info_interval = 300; // after 5 minutes, task will reschedule itself to once per day
          
    if (IsCloudController or IsCloudNode) then begin
      LogText2(0,"Setting up periodic ASP Cloud tasks",kVerbosityDebugDetailed);
      CheckSystemArchitecture;
      if (IsCloudNode) then begin
        ResetCloudArchiveOnCN;
      end else begin
        ResetCloudArchiveOnCC;
        PeriodicNodeStatsCleanup("");
        PeriodicASPEventsCleanup("");
      end;
      ResetVersionsRegister;
      SetGlobalBoolean("ASPIdleTasksStopped",false);
      UpdateCorehandler;
      NewPeriodicTask2("CheckHansaVersionsQuick","Check hansa versions state","CheckHansaVersionsQuick","",check_versions_quick_interval,"");
      //NewPeriodicTask2("CheckHansaVersionsFull","Check hansa versions state","CheckHansaVersionsFull","",check_versions_slow_interval,"");
      NewPeriodicTask2("ASPFastPollServersTask","Fast Poll Cloud Servers","ASPFastPollServersTask","",fastcheck_interval,"");
      NewPeriodicTask2("ASPPollServersTask","Poll Cloud Servers","ASPPollServersTask","",poll_lcs_interval,"");
      NewPeriodicTask2("ASPCleanVersionsTask","Delete version folders that are not in use","ASPCleanVersionsTask","",clean_versions_interval,"");
      NewPeriodicTask2("ASPCleanCoreDumpsTask","Delete core dumps","ASPCleanCoreDumpsTask","",clean_coredumps_interval,"");
      NewPeriodicTask2("ASPAutoRebootTask","Automatically reboot if needed","ASPAutoRebootTask","",auto_reboot_interval,"");
      NewPeriodicTask2("TreatCloudActionQueueTask","Treat Cloud Actions Queue","TreatCloudActionQueueTask","",treat_nodeaction_queue_interval,"");
      RetryNodeUpdate;
    end;

    if (IsCloudController) then begin
      LogText(0,"*** Running as Cloud Controller ***");
      Delete_file("run-cloudcontroller.log");
      Delete_file("run-hansa.log");
      Delete_file("run-hansa-cloudcontroller.log");
      FixupNodeLogs;
      ResetNodeUpdatingStates;

      NewPeriodicTask2("TreatPlannedUpdates","Update RCSs in batch","TreatPlannedUpdates","",planned_updates_interval,"");
      NewPeriodicTask2("SyncRCSDataWithAllCNs","Update RCS status from nodes and node LCS records from CC","SyncRCSDataWithAllCNs","",sync_cn_interval,"");
      NewPeriodicTask2("CheckCloudNodes","Poll Cloud Nodes","CheckCloudNodes","",check_cn_interval,"");
      NewPeriodicTask2("FastCheckCN","Short-interval stats collection from Cloud Nodes","FastCheckCN","",fastcheck_interval,"");
      NewPeriodicTask2("FastCheckCN_Slow","Short-interval stats collection from Cloud Nodes","FastCheckCN","notseenforlong",fastcheck_interval,"");
      NewPeriodicTask2("FastCheckRCS","Short-interval update RCS status from nodes","FastCheckRCS","",fastcheck_interval,"");
      NewPeriodicTask2("UpdateArchiveFromNodesTask","Update Archive from Cloud Nodes","UpdateArchiveFromNodesTask","",update_cn_archive_interval,"");
      NewPeriodicTask2("TransferToCloudArchiveTask","Transfer Locally Archived Files on Cloud Nodes to Cloud Archive","TransferToCloudArchiveTask","",transfer_to_cloudarchive_interval,"");
      NewPeriodicTask("ASPRemoveExpiredInvitesTask","Delete Expired Invitation","ASPRemoveExpiredInvitesTask","",expire_invites_interval,""); // 30 minutes
      NewPeriodicTask("PeriodicNodeStatsCleanup","Delete old cloud statistics records","PeriodicNodeStatsCleanup","",clean_stats_interval,"");
      NewPeriodicTask("PeriodicASPEventsCleanup","Delete old ASP event records","PeriodicASPEventsCleanup","",clean_aspevents_interval,"");

      NewPeriodicTask("ASPCheckStatusTaskCC","Check Cloud Controller Status","ASPCheckStatusTaskCC","",cc_status_interval,"");
      NewPeriodicTask2("ASPRefreshIPCC","Refresh Node IP Addresses","ASPRefreshIPCC","",refreship_interval,"");
      NewPeriodicTask2("ASPCloudsWatchpoints","Watch Cloud","ASPCloudsWatchpointsIdleTask","",watchpoint_interval,"");
      NewPeriodicTask2("ASPCloudWatchdogSendToServerTask","Watch Cloud Issues","ASPCloudWatchdogSendToServerTask","",watchpoint_interval,"");
      NewPeriodicTask2("ASPCheckHostPools","Keep pool of available servers filled up","ASPCheckHostPoolsTask","",pool_interval,"");
      NewPeriodicTask2("SyncASPEventsFromAllCNs","Get ASP events from nodes","SyncASPEventsFromAllCNs","",sync_aspevents_interval,"");

      NewPeriodicTask2("UpdateNodesTask","Update nodes to CC version","UpdateNodesTask","",cn_update_interval,"");
      NewPeriodicTask2("CleanupRCSRecords","Close servers and refresh status of servers","CleanupRCSRecordsTask","",sync_aspevents_interval,"");
      NewPeriodicTask2("ResetRemoteServerErrorStatusTask","Automatic Reset of Server Error Status","ResetRemoteServerErrorStatusTask","",reset_status_interval,"");
      NewPeriodicTask2("CloudServerDailyTask","Cloud Server Daily Tasks","CloudServerDailyTask","",cloud_server_daily_interval,"");
      NewPeriodicTask2("TreatCloudArchivingQueueTask","Treat Cloud Archiving Queue","TreatCloudArchivingQueueTask","",treat_archiving_queue_interval,"");

      NewPeriodicTask2("ReloadEC2InstanceTypesTask","Reload EC2 Instance Types","ReloadEC2InstanceTypesTask","",cloud_server_daily_interval,"");
      //threadasync.ReloadEC2InstanceTypesTask("");
      
      td = CurrentDate;
      td.day = 1;
      if (td<CurrentDate) then begin
        td = AddMonth(td,1);
      end else begin
        if (td==CurrentDate) then begin
          if (CurrentTime>StringToTime("02:00:00")) then begin
            td = AddMonth(td,1);
          end;
        end;
      end;

      // Disabled functionality for now ::lvg190322
      //NewTimedTask2("UpdateAmazonCostStatsTask","Update Amazon Cost Statistics","UpdateAmazonCostStatsTask","",td,"02:00:00","","");
      RemoveAllRecords("AmazonEC2PriceListVc"); //comment out when enabling
      RemoveAllRecords("AmazonInstanceListVc"); //comment out when enabling
      //--
      threadasync.InitAllNodes;

      // Things to do at startup
      if (CSb.UpdateNodesFlag!=0) then begin
        if (GetVersion(CSb.HansaVersion,HVr)==true) then begin
//          queued.UpdateAllNodesToVersion(HVr);
          threadasync.MakeCurrentVersionDownloadableArchive(HVr);
//        end else begin
//          LogText(0,"Failed updating all CN:s to " & HVr.Code & " (GetVersion()==false)");
        end;
      end;
    end;

    if (IsCloudNode) then begin
      LogText(0,"*** Running as Cloud Node ***");
      Delete_file("run-cloudnode.log");
      Delete_file("run-hansa.log");
      Delete_file("run-hansa-cloudnode.log");
      //CNResetAllFastCheckFlags; //shouldn't be needed lvg190904
      ResetLCSRecords;
      NewPeriodicTask2("ArchiveLocalCloudServerFiles","Archive Local Cloud Server Files","ArchiveLocalCloudServerFiles","",archive_lcs_interval,"");
      NewPeriodicTask2("CleanCloudArchiveTask","Remove Files That Have Been Long-Term Archived","CleanCloudArchiveTask","",clean_cloudarchive_interval,"");
      NewPeriodicTask2("DownloadLocalizationsForLCSsTask","Download Missing Localizations for all Cloud Servers","DownloadLocalizationsForLCSsTask","",download_localizations_interval,"");
      NewPeriodicTask2("ASPClearTempFileDownloadSessionTask","Clear File Download Sessions","ASPClearTempFileDownloadSessionTask","",transfer_to_cloudarchive_interval,"");
      NewPeriodicTask2("ASPCleanLCSFilesTask","Clean Local Cloud Server Files","ASPCleanLCSFilesTask","",clean_lcsfiles_interval,"");
      //NewPeriodicTask2("GetHMCustCodeFromBackupTask","Get HM Cust Code","GetHMCustCodeFromBackupTask","",hmcu_interval,"");
      td = CurrentDate;
      if (CurrentTime>StringToTime("00:05:00")) then begin
        td = AddDay(CurrentDate,1);
      end;
      NewPeriodicTask2("GatherLCSDataTask","Gather Cloud Server Information","GatherLCSDataTask","",gather_lcs_info_interval,"");
      NewPeriodicTask2("CheckAndRecoverLSCPidFileTask","Automatic Recover of Server PID Files","CheckAndRecoverLSCPidFileTask","",recover_pid_interval,"");
      NewPeriodicTask2("ResetLocalServerErrorStatusTask","Automatic Reset of Server Error Status","ResetLocalServerErrorStatusTask","",reset_status_interval,"");

      td = CurrentDate;
      if (CurrentTime>StringToTime("22:00:00")) then begin
        td = AddDay(CurrentDate,1);
      end;
      NewTimedTask2("UpdateCustConfFromCN","Get Customer Backup Plan Config","ReadCustConfigFromServerTask","",td,"22:00:00","","");
      if ((blank(Trim(CSb.CCAddr)) or (CSb.CCHTTPSPort<=0)) and nonblank(CSb.APIKey)) then begin
        tstr = "";
        FindMyControllerAndGetSettings(tstr,CSb.APIKey,tstr,pollingport,assignedpollingf,assignedcncode,ccaddr,
                                       pollingportlist,cchttpport,cchttpsport,cchansaport);
        if (nonblank(Trim(ccaddr))) then begin
          LogText(0,"Updating Cloud Controller address to " & ccaddr & ":" & cchttpsport & " (other ports also updated)");
          CSb.CCRevHTTPSPort = pollingport;
          CSb.CCRevHTTPSPortList = pollingportlist;
          CSb.CCAddr = Trim(ccaddr);
          CSb.CCPort = StringToLongInt(Trim(cchansaport));
          CSb.CCHTTPPort = StringToLongInt(Trim(cchttpport));
          CSb.CCHTTPSPort = StringToLongInt(Trim(cchttpsport));
          BlockStore(CSb);
        end;
      end;
    end;

    if (TestEnablerFile("EnASPAU")) then begin
      LogText(0,"Setting up periodic ASP Autoupdate Server tasks");
      NewPeriodicTask("ImportAutoupdateRecords","Import Autoupdate Records","ImportAutoupdateRecords","",autoupdate_interval,"");
      queued.ImportAutoupdateRecords("");
    end;
  end;

LInitASPIdleTasks:;
  return;
end;

global
procedure UpdateClosedRCS(record RemoteCloudServerVc RCSr)
begin
  string 255 url;
  array record LocalCloudServerVc lcsarr;
  array record RemoteCloudServerVc rcsarr;
  record CloudNodeVc CNr;
  LongInt stat;
  Boolean scfailf;

  url = RcsNodeURL(RCSr);
  if (blank(url)) then begin goto LUpdateClosedRCS; end;

  CNr.Code = RCSr.Controller;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    LogText(0,"UpdateClosedRCS(\"" & RCSr.Controller & "\") failed, CN record not found");
    goto LUpdateClosedRCS;
  end;

  RCSr.FastCheckFlag = GetFastCheckFlag(RCSr.Controller,RCSr.WantedStatus,RCSr.WantedStatus,RCSr.WantedSubStatus,RCSr.CurrentStatus,RCSr.Closed);
  rcsarr[0] = RCSr;
  stat = CallService(url).FastSyncLCSDataAtCN_WTF(rcsarr,lcsarr);
  scfailf = TreatServiceError(stat,url,"FastSyncLCSDataAtCN");
  queued.SaveCloudNodeReachable(RCSr.Controller,!scfailf);
  if (scfailf) then begin
    LogText(0,"[Close] Failed to synchronize " & rcsarr.length & " CC cloud server records with node " & CNr.Code);
    goto LUpdateClosedRCS;
  end;

  LogText(0,"[Close] Synchronizing " & rcsarr.length & " CC and " & lcsarr.length & " CN cloud server records with node " & CNr.Code);
//LogText(0,"UpdateClosedRCS calling SaveNewAndUpdatedRCSs");
  qupdating.SaveNewAndUpdatedRCSs(CNr,lcsarr);

LUpdateClosedRCS:;
  return;
end;

global
procedure GetVersionUpdateServerList(string vercode,var array uuid serveridarr,var array string servernamearr,var array string servernodearr,var array string serverstatusarr)
begin
  record RemoteCloudServerVc RCSr;
  record HansaVersionVc HVr;
  LongInt i;

  HVr.Code = vercode;
  if (ReadFirstMain(HVr,1,true)) then begin
    i = 0;
    while (LoopMain(RCSr,0,true)) begin
      if (RCSr.Closed==0) then begin
        if ((RCSr.HansaVersion==HVr.Code) or (RCSr.NewHansaVersion==HVr.Code)) then begin
          serveridarr[i] = RCSr.UUID;
          servernamearr[i] = RCSr.Name;
          servernodearr[i] = RCSr.Controller;
          serverstatusarr[i] = StatusName(RCSr.CurrentStatus);
          i = i + 1;
        end;
      end;
    end;
  end;
end;

global
function Boolean CheckOrRunScript(record CloudNodeVc CNr,Boolean checkf,record RcVc RepSpec,var record RcVc ResRepSpec)
begin
  Boolean res;
  LongInt lineno,lcnt;
  string 255 tstr,script,tmpfile,outfile,errfile,sucfile,scriptfile,bsfile;
  string 255 scext,scriptstr;
  area atmp;

  scriptstr = GetTextField(RepSpec);
  ReplaceStringWithString(scriptstr,CRLF,chr(10));
  ReplaceStringWithString(scriptstr,chr(13),chr(10));

  if (ProgramPlatform==kPlatformWindows32 or ProgramPlatform==kPlatformWindows64) then begin
    scext = ".cmd";
  end else begin
    scext = ".sh";
  end;

  scriptfile = CreateTempFile("script",scext);
  WriteStringToFile(scriptstr,scriptfile,0);

  tmpfile = CreateTempFile("script",".out");
  outfile = tmpfile & ".out";
  errfile = tmpfile & ".err";
  sucfile = tmpfile & ".suc";
  bsfile = CreateTempFile("scriptstarter",scext);

  if (ProgramPlatform==kPlatformWindows32 or ProgramPlatform==kPlatformWindows64) then begin
    if (checkf==true) then begin
      LineTextPut2(ResRepSpec,LineTextCnt2(ResRepSpec),"The Windows platform doesn't support script syntax checking.");
      goto LCheckOrRunScript; // No check functionality on Windows
    end else begin
      AddLineToArea("cmd /Q /D /A /E:ON /F:ON /C " & scriptfile & " > " & outfile & " 2>&1 && echo $null >> " & sucfile & " || echo $null >> " & errfile,atmp);
    end;
  end else begin
    AddLineToArea("#!/bin/bash",atmp);
    if (checkf==true) then begin
      AddLineToArea("bash -n " & scriptfile & " &>" & outfile & " && touch " & sucfile & " || touch " & errfile,atmp);
    end else begin
      AddLineToArea("bash " & scriptfile & " &>" & outfile & " && touch " & sucfile & " || touch " & errfile,atmp);
    end;
  end;

  WriteAreaToFile(atmp,bsfile,0);

  if (ProgramPlatform==kPlatformWindows32 or ProgramPlatform==kPlatformWindows64) then begin
    script = "cmd /Q /D /A /E:ON /F:ON /C " & bsfile;
  end else begin
    script = "bash " & bsfile;
  end;
  RunShellScript(script);
  Delete_File(bsfile);
  Delete_File(scriptfile);

  if (FileExists(sucfile)) then begin
    Delete_File(sucfile);
    res = true;
    if (checkf==false) then begin
      LineTextPut2(ResRepSpec,LineTextCnt2(ResRepSpec),"The script executed successfully on node " & CNr.Code & ":");
    end;
  end else begin
    if (checkf==true) then begin
      if (FileExists(errfile)) then begin
        LineTextPut2(ResRepSpec,LineTextCnt2(ResRepSpec),"ERROR: Script failed the syntax check:");
        Delete_File(errfile);
      end else begin
        LineTextPut2(ResRepSpec,LineTextCnt2(ResRepSpec),"FATAL ERROR: The script could not  be tested.");
      end;
      LineTextPut2(ResRepSpec,LineTextCnt2(ResRepSpec),"");
      LineTextPut2(ResRepSpec,LineTextCnt2(ResRepSpec),"Output:");
      LineTextPut2(ResRepSpec,LineTextCnt2(ResRepSpec),"");
    end else begin
      if (FileExists(errfile)) then begin
        LineTextPut2(ResRepSpec,LineTextCnt2(ResRepSpec),"ERROR: When running on " & CNr.Code & ":");
        Delete_File(errfile);
      end else begin
        LineTextPut2(ResRepSpec,LineTextCnt2(ResRepSpec),"FATAL ERROR: The node " &  CNr.Code & " could not start the script.");
      end;
      LineTextPut2(ResRepSpec,LineTextCnt2(ResRepSpec),"");
    end;
  end;

  SetAreaZeroSize(atmp);
  AddFileToArea(outfile,atmp,false);
  if (ProgramPlatform==kPlatformWindows32 or ProgramPlatform==kPlatformWindows64) then begin
    //AreaUCS2Decode(atmp);
    tstr = AreaToString(atmp);
    tstr = ReplaceStringWithString(tstr,chr(10),"");
    SetAreaZeroSize(atmp);
    AddTextToArea(tstr,atmp);
  end;
  lcnt = CountLinesInArea(atmp);
  for (lineno = 0; lineno<lcnt; lineno = lineno + 1) begin
    tstr = GetLineFromArea(atmp,lineno);
    LineTextPut2(ResRepSpec,LineTextCnt2(ResRepSpec),tstr);
  end;
  if (checkf==false and lineno>0) then begin
    LineTextPut2(ResRepSpec,LineTextCnt2(ResRepSpec),"");
  end;

LCheckOrRunScript:;
  Delete_File(outfile);
  Delete_File(tmpfile);
  CheckOrRunScript = res;
  return;
end;

global
procedure CheckScript(record RcVc RepSpec,var record RcVc ResRepSpec,var Boolean res)
begin
  record CloudNodeVc CNr;
  
  res = CheckOrRunScript(CNr,true,RepSpec,ResRepSpec);
  return;
end;

global
procedure RunScriptOnHost(record CloudNodeVc CNr,record RcVc RepSpec,var record RcVc ResRepSpec,var Boolean res)
begin
  res = CheckOrRunScript(CNr,false,RepSpec,ResRepSpec);
end;

global
procedure RunScriptOnHosts(array string nodearr,record RcVc RepSpec,var record RcVc ResRepSpec,var Boolean res)
begin
  record CloudNodeVc CNr;
  string 255 url;
  LongInt stat;
  Integer i;
  Boolean scfailf;

  for (i = 0; i<nodearr.length; i = i + 1) begin
    CNr.Code = nodearr[i];
    if (ReadFirstMain(CNr,1,true)) then begin
      if (CNr.Closed==0) then begin
        url = NodeURL(CNr);
        stat = CallService(url).RunScriptOnHost(CNr,RepSpec,ResRepSpec,res);
        scfailf = TreatServiceError(stat,url,"RunScriptOnHost");
        queued.SaveCloudNodeReachable(CNr.Code,!scfailf);
        if (scfailf) then begin
          LineTextPut2(ResRepSpec,LineTextCnt2(ResRepSpec),"Could not contact node " & CNr.Code & ", skipped");
          goto LRunScript;
        end;
      end;
    end;
  end;

LRunScript:;
  return;
end;


global
function Boolean GetKeyForHostingConfiguration(record HostingConfigurationVc HCr,var record Attach2Vc AT2r)
begin
  Integer i;
  record RLinkVc RLr;
  Boolean res;

  while (ReadRecordLink(HCr,i,AT2r,RLr)) begin
    switch (HCr.HostingType) begin
      case kHostingTypeIBMCloud:
        if (AT2r.FileName=="ibmcloud-ssh-key.pem") then begin
          goto LGetKeyForHostingConfiguration_FoundKey;
        end;
      case kHostingTypeAmazon:
        if (AT2r.FileName=="amazon-ec2-key.pem") then begin
          goto LGetKeyForHostingConfiguration_FoundKey;
        end;
      case kHostingTypeUnknown:
        if (AT2r.FileName=="unknown-ssh-key.pem") then begin
          goto LGetKeyForHostingConfiguration_FoundKey;
        end;
    end;
    i = i + 1;
  end;
  goto LGetKeyForHostingConfiguration;

LGetKeyForHostingConfiguration_FoundKey:;
  res = true;

LGetKeyForHostingConfiguration:;
  GetKeyForHostingConfiguration = res;
  return;
end;

global
function Boolean GetKeyForHostingConfigurationToArea(record HostingConfigurationVc HCr,string keyfile,var area a_ec2_key)
begin
  Boolean res;
  record Attach2Vc AT2r;
  LongInt blocklen;

  if (GetKeyForHostingConfiguration(HCr,AT2r)==true) then begin
    blocklen = AttachFileSize(AT2r);
    SetAreaZeroSize(a_ec2_key);
    LoadAttachFilePartToArea(AT2r,0,blocklen,a_ec2_key);
    res = true;
  end;

  GetKeyForHostingConfigurationToArea = res;
  return;
end;

