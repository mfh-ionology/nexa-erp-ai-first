global
updating procedure GetNextNodeNo(var LongInt nextno,var string errmsg)
begin
  record CloudSettingsBlock CSb;

  BlockLoad(CSb);
  nextno = CSb.NextNodeNo;
  CSb.NextNodeNo = nextno + 1;
  BlockStore(CSb);
  
  return;
