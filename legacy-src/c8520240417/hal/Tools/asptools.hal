global
procedure NotifyNodeOfNewVersions()
begin
  LogText(0,"NotifyNodeOfNewVersions got called");
  DownloadNewVersionsForCx(false,true);
  return;
end;

global
procedure NotifyAllNodesOfNewVersions()
begin
  record CloudNodeVc CNr;
  string 255 cnurl;
  LongInt stat;
  
  if (IsCloudController==false) then begin
    goto LNotifyAllNodesOfNewVersions;
  end;
  
  while (LoopMain(CNr,1,true)) begin
    if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LNotifyAllNodesOfNewVersions; end;
    if (QuitingApplication==true) then begin goto LNotifyAllNodesOfNewVersions; end;
    
    if (CNr.Closed==0 and
        nonblank(CNr.Code) and
        ((CloudNodeStatus(CNr)==kCloudNodeStatusReachable) or
         (CloudNodeStatus(CNr)==kCloudNodeStatusDifferentVersion))) then begin
      cnurl = ReadNodeUrl(CNr);
      LogText(0,"calling NotifyNodeOfNewVersions at " & cnurl);
      CallServiceAsync(cnurl).NotifyNodeOfNewVersions;
    end;
  end;

LNotifyAllNodesOfNewVersions:;
  return;
end;

global
updating procedure HttpAsyncDownloadHACallbackProgress(string url,val progress_prc)
begin
  record HansaVersionVc OldHVr,HVr;
  string 255 vcode;
  
  vcode = BaseName(Right(url,len(url)-5));
  vcode = Left(vcode,len(vcode)-3);
  HVr.Code = vcode;
  if (ReadFirstMain(HVr,1,true)) then begin
    RecordCopy(OldHVr,HVr);
    HVr.DownloadProgress = progress_prc;
    RecordUpdate(OldHVr,HVr,false);
  end;
  return;
end;

global
function Boolean ASPRebuildNodeVClassCheckNode(var record RcVc RepSpec,var string errmsg)
begin
  Boolean res;
  record HostingConfigurationVc HCr;
  record CloudNodeVc CNr;
  row CloudNodeVc CNrw;
  record EC2InstanceTypeVc EC2ITr;
  string 255 url,username,key;
  Integer stat,cn_idx,cn_rwcnt;
  Boolean scfailf;
  LongInt platform,keypos;
  array string 255 known_users_arr;
  
  CNr.Code = RepSpec.f1;
  if (blank(CNr.Code)) then begin
    errmsg = "Cloud Node may not be blank";
    goto LASPRebuildNodeVClassCheckNode;
  end;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    errmsg = "Cloud Node " & RepSpec.f1 & " not found";
    goto LASPRebuildNodeVClassCheckNode;
  end;
  HCr.SerNr = CNr.HostingConfig;
  if (ReadFirstMain(HCr,1,true)==false) then begin
    errmsg = "Hosting configuration with SerNr=" & HCr.SerNr & " " & CNr.HostingConfig & " (" & CNr.HostingConfigComment & ") not found";
    goto LASPRebuildNodeVClassCheckNode;
  end;
  if (HCr.HostingType!=kHostingTypeAmazon) then begin
    errmsg = "Cloud Node " & RepSpec.f1 & " is not hosted on Amazon AWS";
    goto LASPRebuildNodeVClassCheckNode;
  end;
  if (blank(HCr.AmazonRegion)) then begin
    errmsg = "Hosting configuration with SerNr=" & HCr.SerNr & " " & CNr.HostingConfig & " (" & CNr.HostingConfigComment & ") has no AWS region";
    goto LASPRebuildNodeVClassCheckNode;
  end;
  
  if (nonblank(RepSpec.f2)) then begin
    EC2ITr.InstanceType = RepSpec.f2;
    EC2ITr.Region = HCr.AmazonRegion;
    if (ReadFirstMain(EC2ITr,2,true)) then begin
      switch (ArchitectureFromEC2InstanceType(EC2ITr)) begin
        case "arm64":   platform = kPlatformLinuxArm64;
        case "x86_64":  platform = kPlatformLinux64;
        otherwise
      end;
    end else begin
      res = false;
      errmsg = "Invalid instance type: " & RepSpec.f2;
      goto LASPRebuildNodeVClassCheckNode;
    end;
  end;

  cn_rwcnt = MatRowCnt(CNr);
  for (cn_idx=cn_rwcnt;cn_idx>0;cn_idx=cn_idx-1) begin
    MatRowGet(CNr,cn_idx-1,CNrw);
    if (blank(CNrw.DiskFileSystem) or blank(CNrw.DiskMountPoint)) then begin
      errmsg = "The cloud node disk configuration is invalid, missing file system or mount point(s) in the node matrix";
      goto LASPRebuildNodeVClassCheckNode;
    end;
  end;


  while (ReadUserKey(keypos,username,key)) begin
    known_users_arr[known_users_arr.length] = username;
  end;
  if (nonblank(CNr.AdminUser)) then begin
    known_users_arr[known_users_arr.length] = CNr.AdminUser;
  end;

  url = NodeURL(CNr);
  stat = CallService(url).NodeRebuildPreCheck(CNr.Code,RepSpec.f2,platform,known_users_arr,res,errmsg);
  scfailf = TreatServiceError(stat,url,"NodeRebuildPreCheck");
  if (scfailf) then begin
    res = false;
    errmsg = "Node cloud not be reached";
    goto LASPRebuildNodeVClassCheckNode;
  end;
  
LASPRebuildNodeVClassCheckNode:;
  ASPRebuildNodeVClassCheckNode = res;
  return;
end;

global
updating procedure ReplaceCertificateForLCS(UUID server_uuid,string new_cert,string new_key,var string msg)
begin
  record RemoteCloudServerVc RCSr;
  record LocalCloudServerVc LCSr;
  record CloudSettingsBlock CSb;
  record CertCheckHistVc CCHr;
  string 255 cnurl,bakcertfile,bakkeyfile;
  Integer stat;
  Boolean scfailf,stopres;
  
  BlockLoad(CSb);
  msg = "";

  if (IsCloudController) then begin
    RCSr.UUID = server_uuid;
    ReadFirstMain(RCSr,1,true);
    cnurl = RCSNodeUrl(RCSr);
    if (nonblank(cnurl)) then begin
      stat = CallService(cnurl).ReplaceCertificateForLCS(server_uuid,new_cert,new_key,msg);
      scfailf = TreatServiceError(stat,cnurl,"ReplaceCertificateForLCS");
      if (scfailf) then begin
        msg = "Couldn't get send certificate data for cloud server " & RCSName(RCSr) & " to cloud node " & RCSr.Controller;
      end;
      RecordClear(CCHr);
      CertCheckForOneServer(RCSr,CCHr);
    end else begin
      msg = "Couldn't get cloud node URL for cloud server " & RCSName(RCSr);
    end;
    goto LReplaceCertificateForLCS;
  end;
  
  LCSr.UUID = server_uuid;
  if (!ReadFirstMain(LCSr,1,true)) then begin
    msg = "The cloud server ' " & LCSName(LCSr) & " ' does not exist on the node " & CSb.NodeCode;
    goto LReplaceCertificateForLCS;
  end;
  if (blank(LCSr.SSLCertFile)) then begin
    msg = "The cloud server ' " & LCSName(LCSr) & " ' does not have the SSL certificate field set";
    goto LReplaceCertificateForLCS;
  end;
  if (blank(LCSr.SSLPrivKeyFile)) then begin
    msg = "The cloud server ' " & LCSName(LCSr) & " ' does not have the SSL key field set";
    goto LReplaceCertificateForLCS;
  end;
  if (blank(LCSr.DataFolder)) then begin
    msg = "The cloud server ' " & LCSName(LCSr) & " ' does not have the data folder set";
    goto LReplaceCertificateForLCS;
  end;

  if (blank(new_cert)) then begin
    msg = "The given SSL certificate or key was blank";
    goto LReplaceCertificateForLCS;
  end;
  
  bakcertfile = DetermineNextName(LCSr.DataFolder & "/" & LCSr.SSLCertFile,false,true);
  RenameFile(LCSr.DataFolder & "/" & LCSr.SSLCertFile,bakcertfile);
  WriteStringToFile(new_cert,LCSr.DataFolder & "/" & LCSr.SSLCertFile,0);
  if (nonblank(new_key)) then begin
    bakkeyfile = DetermineNextName(LCSr.DataFolder & "/" & LCSr.SSLPrivKeyFile,false,true);
    RenameFile(LCSr.DataFolder & "/" & LCSr.SSLPrivKeyFile,bakkeyfile);
    WriteStringToFile(new_key,LCSr.DataFolder & "/" & LCSr.SSLPrivKeyFile,0)
  end;
  SoftStopLocalCloudServer(LCSr,"SYSTEM","New web server certificate installed, the server will restart in 5 minutes.",5,stopres);

LReplaceCertificateForLCS:;
  return;
end;
