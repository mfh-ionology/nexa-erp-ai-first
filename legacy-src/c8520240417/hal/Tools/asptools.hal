global
updating procedure InitNodeAtCN6(string cncode,array record UserVc userarr,string cchost,LongInt ccport,
                                 LongInt cchttpport,LongInt cchttpsport,LongInt hostingpartner,
                                 array string active_usersarr,array string active_keysarr,array string closed_usersarr,
                                 string revHttpsPort,Integer pollingf,string revHttpsPortList,var string osversion,vector string vVals)
begin
  record CloudSettingsBlock CSb;
  record CloudCrashDumpBlock CCDb;

  InitNodeAtCN5(cncode,userarr,cchost,ccport,cchttpport,cchttpsport,hostingpartner,
                active_usersarr,active_keysarr,closed_usersarr,revHttpsPort,pollingf,
                revHttpsPortList,osversion);

  BlockLoad(CSb);
  CSb.NodeUsesSMTP = StringToInt(vVals["UseSMTP"]);
  BlockStore(CSb);

  if (CSb.NodeUsesSMTP==1) then begin
    if (TaskExists("CheckRunSMTPTunnel")==false) then begin
      threadasync.CheckAndStartSMTPTunnelling;
    end;
  end else begin
    if (CSb.SMTPPid>0) then begin
      if (TaskExists("CheckRunSMTPTunnel")) then begin
        RemoveTask("CheckRunSMTPTunnel");
      end;
      StopExternalProcess(CSb.SMTPPid);
      if (SMTPTunnelPidIsRunning) then begin //this will check if the pid is running and reset the pid in setting to -1 if it's not
        ForceStopExternalProcess(CSb.SMTPPid);
        SMTPTunnelPidIsRunning;
      end;
    end;
  end;

  BlockLoad(CCDb);
  CCDb.AmazonAccessKeyID = vVals["CCDb.AmazonAccessKeyID"];
  CCDb.AmazonSecretAccessKey = vVals["CCDb.AmazonSecretAccessKey"];
  CCDb.AmazonRegion = vVals["CCDb.AmazonRegion"];
  CCDb.AmazonS3Bucket = vVals["CCDb.AmazonS3Bucket"];
  BlockStore(CCDb);

  return;
end;

function Boolean IsNewSectionStarting(string tstr)
begin
  Boolean res;
  if (Left(tstr,1)=="[" and Right(tstr,1)=="]") then begin res = true; end;
  IsNewSectionStarting = res;
  return;
end;

function Boolean IsConfigurationStatement(string linestr,string tstr)
begin
  Boolean res;
  string 255 t2;
  t2 = tstr & "=";
  if (Left(linestr,len(t2))==t2) then begin res = true; end;
  IsConfigurationStatement = res;
  return;
end;

global
procedure FixSystemdConfigurationIfNeeded(LongInt hostingtype)
begin
  string 255 service_file,tstr,syslog_file,script_file;
  area a_service_def,a_service_def_new,a_tmp;
  LongInt lcnt,l;
  Boolean updf,fix_syslogf;
  Boolean in_service_sectionf,in_unit_sectionf,found_stdout_settingf,found_stderr_settingf;
  Boolean found_startlimitintervalsecf,found_startlimitburstf;
  
  switch (ProgramPlatform) begin
    case kPlatformLinux32:
    case kPlatformLinux64:
    case kPlatformLinuxArm64:
    otherwise
      goto LFixSystemdConfigurationIfNeeded;
  end;

  service_file = "/etc/systemd/system/hansa-cloudnode.service";
  if (FileExists(service_file)) then begin
    AddFileToArea(service_file,a_service_def,false);
    lcnt = CountLinesInArea(a_service_def);
    for (l = 0; l<lcnt; l = l + 1) begin
      tstr = Trim(GetLineFromArea(a_service_def,l));

      if (IsConfigurationStatement(tstr,"StandardOutput")) then begin found_stdout_settingf = true; end;
      if (IsConfigurationStatement(tstr,"StandardError")) then begin found_stderr_settingf = true; end;
      if (IsConfigurationStatement(tstr,"StartLimitIntervalSec")) then begin found_startlimitintervalsecf = true; end;
      if (IsConfigurationStatement(tstr,"StartLimitBurst")) then begin found_startlimitburstf = true; end;

      if (IsNewSectionStarting(tstr)) then begin
        if (in_service_sectionf) then begin
          if (found_stdout_settingf==false) then begin
            AddLineToArea("StandardOutput=null",a_service_def_new);
            updf = true;
            fix_syslogf = true;
          end;
          if (found_stderr_settingf==false) then begin
            AddLineToArea("StandardError=null",a_service_def_new);
            updf = true;
            fix_syslogf = true;
          end;
        end;
        if (in_unit_sectionf) then begin
          if (found_startlimitintervalsecf==false) then begin
            AddLineToArea("StartLimitIntervalSec=0",a_service_def_new);
            updf = true;
          end;
          if (found_startlimitburstf==false) then begin
            AddLineToArea("StartLimitBurst=999999999",a_service_def_new);
            updf = true;
          end;
        end;
      end;
      AddLineToArea(tstr,a_service_def_new);
      
      switch (tstr) begin
        case "[Service]": in_service_sectionf = true; in_unit_sectionf = false;
        case "[Unit]":    in_unit_sectionf = true; in_service_sectionf = false;
      end;
    end;
    
    if (updf) then begin
      WriteAreaToFile(a_service_def_new,service_file,0);
      RunShellScript("systemctl daemon-reload");

      if (fix_syslogf) then begin
        // Only for misconfigured systemd hosts - because syslog probably contains GBs of hansa.log because above redirection didn't exist
        syslog_file = "/var/log/syslog";
        if (FileSize2(syslog_file)>5368709120) then begin // 5Gb
          Delete_file(syslog_file);
          RunShellScript("service syslog restart");
        end;
      end;
      
      LogText(0,"*** Corrected systemd Cloud Node service definition ***");
      
      RunShellScript("systemctl restart hansa-cloudnode.service");
    end;
  end;

  switch (hostingtype) begin
    case kHostingTypeIBMCloud:
      script_file = "/usr/local/bin/cloudnode-system-shutdown.sh";
      if (FileExists(script_file)==false) then begin
        SetAreaZeroSize(a_tmp);
        AddLineToArea("#!/bin/bash",a_tmp);
        AddLineToArea("systemctl stop hansa-cloudnode",a_tmp);
        AddLineToArea("killall -qw hansa-debug-optimized-server64",a_tmp);
        AddLineToArea("killall -qwr 'hansa-*'",a_tmp);
        AddLineToArea("killall -qwr 'asterisk*'",a_tmp);
        AddLineToArea("killall -qwr 'fail2ban-server*'",a_tmp);
        AddLineToArea("kill $(lsof -t /Servers)",a_tmp);
        WriteAreaToFile(a_tmp,script_file,0);
        RunShellScript("chmod a+x " & script_file);
        LogText(0,"*** Created systemd shutdown script ***");
      end;
      service_file = "/etc/systemd/system/cloudnode-shutdown.service";
      if (FileExists(service_file)==false) then begin
        SetAreaZeroSize(a_tmp);
        AddLineToArea("[Unit]",a_tmp);
        AddLineToArea("Description=Standard ERP Cloud Node System Shutdown",a_tmp);
        AddLineToArea("After=remote-fs-pre.target",a_tmp);
        AddLineToArea("[Service]",a_tmp);
        AddLineToArea("Type=oneshot",a_tmp);
        AddLineToArea("ExecStart=/bin/true",a_tmp);
        AddLineToArea("ExecStop=" & script_file,a_tmp);
        AddLineToArea("RemainAfterExit=true",a_tmp);
        AddLineToArea("[Install]",a_tmp);
        AddLineToArea("WantedBy=sysinit.target",a_tmp);
        WriteAreaToFile(a_tmp,service_file,0);
        RunShellScript("systemctl daemon-reload");
        RunShellScript("systemctl enable cloudnode-shutdown.service");
        RunShellScript("systemctl start cloudnode-shutdown.service");
        LogText(0,"*** Created systemd shutdown service ***");
      end;
  end;

LFixSystemdConfigurationIfNeeded:;
  return;
end;

global
procedure FixGrubConfigurationIfNeeded(LongInt hostingtype)
begin
  string 255 menu_file;

  switch (ProgramPlatform) begin
    case kPlatformLinux32:
    case kPlatformLinux64:
    case kPlatformLinuxArm64:
    otherwise
      goto LFixGrubConfigurationIfNeeded;
  end;

  menu_file = "/boot/grub/menu.lst";
  if (FileExists(menu_file)==false) then begin goto LFixGrubConfigurationIfNeeded; end;

  RunShellScript("sed -i\"\" 's/groot=LABEL=cloudimg-rootfs/groot=(hd0)/g' " & menu_file);
  LogText(0,"*** Corrected GRUB configuration ***");

LFixGrubConfigurationIfNeeded:;
  return;
end;

global
procedure FixDNSConfigurationIfNeeded(LongInt hostingtype)
begin
  string 255 tstr;
  area a_resolv_conf;

  switch (ProgramPlatform) begin
    case kPlatformLinux32:
    case kPlatformLinux64:
    case kPlatformLinuxArm64:
    otherwise
      goto LFixDNSConfigIfNeeded;
  end;

  switch (hostingtype) begin
    case kHostingTypeIBMCloud:
    otherwise
      goto LFixDNSConfigIfNeeded;
  end;

  RunShellScriptGetStdout("[[ -L /etc/resolv.conf ]] && echo true || echo false",tstr);
  tstr = trim(tstr);
  if (tstr!="true") then begin goto LFixDNSConfigIfNeeded; end;
  
  RunShellScript("[ -d /run/systemd/resolve ] || (mkdir -p /run/systemd/resolve; touch /run/systemd/resolve/stub-resolv.conf; chmod 755 /run/systemd/resolve; chown -R systemd-network:systemd-network /run/systemd/resolve)");

  AddLineToArea("nameserver 8.8.8.8",a_resolv_conf);
  AddLineToArea("nameserver 8.8.4.4",a_resolv_conf);
  WriteAreaToFile(a_resolv_conf,"/etc/resolv.conf",0);
  LogText(0,"*** Corrected DNS configuration ***");

LFixDNSConfigIfNeeded:;
  return;
end;

global
updating procedure InitNodeAtCN7(array record UserVc userarr,array string active_usersarr,array string active_keysarr,
                                 array string closed_usersarr,vector string vValsIn,var vector string vValsOut)
begin
  string 255 cncode,cchost,revHttpsPort,revHttpsPortList,osversion,hostingtype,sfbstr,sfbtag,autoquittime;
  LongInt ccport,cchttpport,cchttpsport,hostingpartner;
  Integer pollingf;
  area a_tmp;
  record SysFormatBlock SFb;
  record BackupBlock Bbl;
  record InternetEnablerBlock IEb;

  cncode = vValsIn["CNr.Code"];
  cchost = vValsIn["PublicHostName"];
  ccport = StringToLongInt(vValsIn["ServerTCPPort"]);
  cchttpport = StringToLongInt(vValsIn["ServerHttpPort"]);
  cchttpsport = StringToLongInt(vValsIn["ServerHttpsPort"]);
  hostingpartner = StringToLongInt(vValsIn["CSb.HostingPartner"]);
  revHttpsPort = vValsIn["PSb.revHttpsServerPort"];
  pollingf = StringToInt(vValsIn["CNr.PollingFlag"]);
  revHttpsPortList = vValsIn["PSb.revHttpsServerPortList"];
  hostingtype = vValsIn["HostingType"];
  sfbstr = vValsIn["SFb"];
  sfbtag = vValsIn["SysFormatBlockTag"];
  autoquittime = vValsIn["AutoQuitTime"];
  
  if (nonblank(sfbstr)) then begin
    SetAreaZeroSize(a_tmp);
    AddTextToArea(sfbstr,a_tmp);
    BlockLoad(SFb);
    GetBlockFromArea(SFb,sfbtag,0,a_tmp);
    BlockStore(SFb);
  end;

  InitNodeAtCN6(cncode,userarr,cchost,ccport,cchttpport,cchttpsport,hostingpartner,
                active_usersarr,active_keysarr,closed_usersarr,revHttpsPort,pollingf,
                revHttpsPortList,osversion,vValsIn);

  vValsOut["OSVersion"] = osversion;
  vValsOut["CNr.VersionBuild"] = VersionBuild;
  vValsOut["CNr.NodeInstallPath"] = ProgramFolder;
  vValsOut["CNr.Platform"] = ProgramPlatform;
  
  if (nonblank(hostingtype)) then begin
    ThreadAsync.FixSystemdConfigurationIfNeeded(hostingtype);
    ThreadAsync.FixGrubConfigurationIfNeeded(hostingtype);
    ThreadAsync.FixDNSConfigurationIfNeeded(hostingtype);
  end;

  BlockLoad(Bbl);
  if (nonblank(autoquittime)) then begin
    LogText(0,"*** Setting automatic server restart time to " & autoquittime & " ***");
  end else begin
    LogText(0,"*** Automatic server restart is disabled ***");
  end;
  Bbl.AutoQuitTime = autoquittime;
  BlockStore(Bbl);
  
  if (nonblank(vValsIn["IEb.RegInCountry"])) then begin
    BlockLoad(IEb);
    if (IEb.RegInCountry!=StringToInt(vValsIn["IEb.RegInCountry"])) then begin
      IEb.RegInCountry = StringToInt(vValsIn["IEb.RegInCountry"]);
      IEb.CustomerCode = vValsIn["IEb.CustomerCode"];
      BlockStore(IEb);
    end;
  end;
  
  return;
end;

global
updating procedure UpdateNodeVersion(record CloudNodeVc CNr,LongInt newver)
begin
  record CloudNodeVc OldCNr;
  record HansaVersionVc HVr;
  LongInt newbuild;

  if (newver<=0) then begin goto LUpdateNodeVersion; end;

  if (ReadFirstMain(CNr,1,true)) then begin
    RecordCopy(OldCNr,CNr);

    CNr.LastUpdateFailedFlag = 0;
    if (nonblank(CNr.NewHansaVersion)) then begin
      HVr.Code = CNr.NewHansaVersion;
      if (ReadFirstMain(HVr,1,true)) then begin
        newbuild = StringToLongInt(HansaVersionLClassVersionColumn(HVr));
        if (newbuild!=newver) then begin
          CNr.LastUpdateFailedFlag = 1;
        end;
      end;
    end;

    CNr.VersionBuild = newver;
    RecordUpdate(OldCNr,CNr,true);
  end;

LUpdateNodeVersion:;
  return;
end;

global
updating procedure UpdateNodeNodeInstallPath(record CloudNodeVc CNr,string install_path)
begin
  record CloudNodeVc OldCNr;
  string 255 trimmed_path;

  trimmed_path = Trim(install_path);
  if (blank(trimmed_path)) then begin goto LUpdateNodeNodeInstallPath; end;

  if (ReadFirstMain(CNr,1,true)) then begin
    if (nonblank(CNr.NodeInstallPath)) then begin
      if (CNr.NodeInstallPath!=trimmed_path) then begin
        LogText(0,"NOTE: The Cloud Node " & CNr.Code & " changed installation folder from " & CNr.NodeInstallPath & " to " & trimmed_path);
        //TODO: deal with double-install nodes
      end;
    end;
    
    RecordCopy(OldCNr,CNr);
    CNr.NodeInstallPath = trimmed_path;
    RecordUpdate(OldCNr,CNr,true);
  end;

LUpdateNodeNodeInstallPath:;
  return;
end;

global
updating procedure UpdateNodeOS(record CloudNodeVc CNr,string newos)
begin
  record CloudNodeVc OldCNr;

  if (ReadFirstMain(CNr,1,true)) then begin
    RecordCopy(OldCNr,CNr);
    CNr.OperatingSystem = newos;
    RecordUpdate(OldCNr,CNr,true);
  end;
  return;
end;

global
updating procedure UpdateNodePlatform(record CloudNodeVc CNr,LongInt platform)
begin
  record CloudNodeVc OldCNr;

  if (ReadFirstMain(CNr,1,true)) then begin
    RecordCopy(OldCNr,CNr);
    CNr.Platform = platform;
    RecordUpdate(OldCNr,CNr,true);
  end;
  return;
end;
global
procedure InitNode(record CloudNodeVc CNr)
begin
  string 255 url,funcstr,osversion,tstr;
  LongInt stat,platform;
  array record UserVc userarr; //not used
  record CloudSettingsBlock CSb;
  record ProgramStatusBlock PSb;
  array string 255 closed_usersarr,active_usersarr,active_keysarr;
  vector string 255 vValsIn,vValsOut;
  record CloudCrashDumpBlock CCDb;
  record HostingConfigurationVc HCr;
  record SysFormatBlock SFb;
  record InternetEnablerBlock IEb;
  area a_tmp;

  if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LInitNode; end;

  if (CNr.VersionBuild<81300008) then begin
    goto LInitNode;
  end;

  switch (CNr.CurrentState) begin
    case kCloudNodeStateCreating:     goto LInitNode;
    case kCloudNodeStateStopping:     goto LInitNode;
    case kCloudNodeStateStopped:      goto LInitNode;
    case kCloudNodeStateStarting:     goto LInitNode;
    case kCloudNodeStateTerminating:  goto LInitNode;
    case kCloudNodeStateMoving:       goto LInitNode;
    case kCloudNodeStateModifying:    goto LInitNode;
  end;

  BlockLoad(CSb);
  LogText(0,"Initializing node " & CNr.Code & " with CC at " & PublicHostName & ":" & ServerHttpsPort);
  url = NodeURL(CNr);
  if (blank(url)) then begin
    stat = 1;
    LogText(0,"Initializing node failed with blank url");
    goto LInitNode_Initialized;
  end;
  if (CNr.VersionBuild<83090019) then begin
    stat = CallService(url).InitNodeAtCN(CNr.Code,userarr,PublicHostName,ServerTCPPort,ServerHttpPort,ServerHttpsPort,CSb.HostingPartner);
    funcstr = "InitNodeAtCN";
    goto LInitNode_Initialized;
  end;
  GetActiveUsers(active_usersarr,active_keysarr);
  GetClosedUsers(closed_usersarr);
  if (CNr.VersionBuild<84000001) then begin
    stat = CallService(url).InitNodeAtCN2(CNr.Code,userarr,PublicHostName,ServerTCPPort,ServerHttpPort,ServerHttpsPort,
                                          CSb.HostingPartner,active_usersarr,active_keysarr,closed_usersarr);
    funcstr = "InitNodeAtCN2";
    goto LInitNode_Initialized;
  end;
  BlockLoad(PSb);
  if (CNr.VersionBuild<84000109) then begin
    stat = CallService(url).InitNodeAtCN3(CNr.Code,userarr,PublicHostName,ServerTCPPort,ServerHttpPort,ServerHttpsPort,
                                          CSb.HostingPartner,active_usersarr,active_keysarr,closed_usersarr,PSb.revHttpsServerPort,
                                          CNr.PollingFlag);
    funcstr = "InitNodeAtCN3";
    goto LInitNode_Initialized;
  end;

  if (CNr.VersionBuild<84060134) then begin
    funcstr = "InitNodeAtCN4";
    stat = CallService(url).InitNodeAtCN4(CNr.Code,userarr,PublicHostName,ServerTCPPort,ServerHttpPort,ServerHttpsPort,
                                          CSb.HostingPartner,active_usersarr,active_keysarr,closed_usersarr,PSb.revHttpsServerPort,
                                          CNr.PollingFlag,PSb.revHttpsServerPortList);
    goto LInitNode_Initialized;
  end;


  if (CNr.VersionBuild<85210057) then begin
    funcstr = "InitNodeAtCN5";
    stat = CallService(url).InitNodeAtCN5(CNr.Code,userarr,PublicHostName,ServerTCPPort,ServerHttpPort,ServerHttpsPort,
                                          CSb.HostingPartner,active_usersarr,active_keysarr,closed_usersarr,PSb.revHttpsServerPort,
                                          CNr.PollingFlag,PSb.revHttpsServerPortList,osversion);
    goto LInitNode_Initialized;
  end;

  vValsIn["UseSMTP"] = nonblank(CNr.SMTPController);

  BlockLoad(CCDb);
  vValsIn["CCDb.AmazonAccessKeyID"] = CCDb.AmazonAccessKeyID;
  vValsIn["CCDb.AmazonSecretAccessKey"] = CCDb.AmazonSecretAccessKey;
  vValsIn["CCDb.AmazonRegion"] = CCDb.AmazonRegion;
  vValsIn["CCDb.AmazonS3Bucket"] = CCDb.AmazonS3Bucket;

  if (CNr.VersionBuild<85290266) then begin
    funcstr = "InitNodeAtCN6";
    stat = CallService(url).InitNodeAtCN6(CNr.Code,userarr,PublicHostName,ServerTCPPort,ServerHttpPort,ServerHttpsPort,
                                          CSb.HostingPartner,active_usersarr,active_keysarr,closed_usersarr,PSb.revHttpsServerPort,
                                          CNr.PollingFlag,PSb.revHttpsServerPortList,osversion,vValsIn);
    goto LInitNode_Initialized;
  end;

  vValsIn["CNr.Code"] = CNr.Code;
  vValsIn["PublicHostName"] = PublicHostName;
  vValsIn["ServerTCPPort"] = ServerTCPPort;
  vValsIn["ServerHttpPort"] = ServerHttpPort;
  vValsIn["ServerHttpsPort"] = ServerHttpsPort;
  vValsIn["CSb.HostingPartner"] = CSb.HostingPartner;
  vValsIn["PSb.revHttpsServerPort"] = PSb.revHttpsServerPort;
  vValsIn["CNr.PollingFlag"] = CNr.PollingFlag;
  vValsIn["PSb.revHttpsServerPortList"] = PSb.revHttpsServerPortList;

  HCr.SerNr = CNr.HostingConfig;
  if (ReadFirstMain(HCr,1,true)) then begin
    vValsIn["HostingType"] = HCr.HostingType;
  end else begin
    vValsIn["HostingType"] = kHostingTypeUnknown;
  end;

  BlockLoad(SFb);
  SetAreaZeroSize(a_tmp);
  AddBlockToArea(SFb,a_tmp);
  vValsIn["SFb"] = GetStringFromArea(a_tmp,0,GetAreaLength(a_tmp));
  vValsIn["SysFormatBlockTag"] = GetBlockTag("SysFormatBlock");

  vValsIn["AutoQuitTime"] = CSb.NodeAutoQuitTime;
  
  if (IsInOurHosting(CNr.HostingConfig,CNr.HostingPartner)) begin
    BlockLoad(IEb);
    vValsIn["IEb.RegInCountry"] = IEb.RegInCountry;
    vValsIn["IEb.CustomerCode"] = IEb.CustomerCode;
  end;

  funcstr = "InitNodeAtCN7";
  stat = CallService(url).InitNodeAtCN7(userarr,active_usersarr,active_keysarr,closed_usersarr,vValsIn,vValsOut);
  osversion = vValsOut["OSVersion"];

LInitNode_Initialized:;
  if (TreatServiceError(stat,url,funcstr)) then begin
    LogText(0,"Failed to initialize CN " & CNr.Code);
    goto LInitNode;
  end;

  queued.UpdateNodeVersion(CNr,StringToLongInt(vValsOut["CNr.VersionBuild"]));
  queued.UpdateNodeNodeInstallPath(CNr,vValsOut["CNr.NodeInstallPath"]);
  platform = StringToLongInt(vValsOut["CNr.Platform"]);
  if ((platform>0) and (platform!=CNr.Platform)) then begin
    queued.UpdateNodePlatform(CNr,StringToLongInt(vValsOut["CNr.Platform"]));
  end;
  if (osversion!=CNr.OperatingSystem) then begin
    queued.UpdateNodeOS(CNr,osversion);
  end;

LInitNode:;
  return;
end;

global
procedure InitAllNodes()
begin
  record CloudNodeVc CNr;

  LogText(0,"Initializing all cloud nodes");
  while (LoopMain(CNr,1,true)) begin
    if (CNr.Closed==0) then begin
      InitNode(CNr);
    end;
  end;
  return;
end;


procedure UpdateCNDiskRows(var record CloudNodeVc CNr,record CloudMachineStatsVc CMSr)
begin
  Integer cms_idx,cms_rwcnt,cn_idx,cn_rwcnt;
  row CloudNodeVc CNrw;
  row CloudMachineStatsVc CMSrw;
  Boolean foundf;
  
  cms_rwcnt = MatRowCnt(CMSr);
  for (cms_idx=0;cms_idx<cms_rwcnt;cms_idx=cms_idx+1) begin
    MatRowGet(CMSr,cms_idx,CMSrw);
    cn_rwcnt = MatRowCnt(CNr);
    foundf = false;
    for (cn_idx=0;cn_idx<cn_rwcnt;cn_idx=cn_idx+1) begin
      MatRowGet(CNr,cn_idx,CNrw);
      if (CNrw.DiskDevice==CMSrw.DiskDevice) then begin
        foundf = true;
        CNrw.DiskDevice = CMSrw.DiskDevice;
        CNrw.DiskUUID = CMSrw.DiskUUID;
        CNrw.DiskFileSystem = CMSrw.DiskFileSystem;
        CNrw.DiskMountPoint = CMSrw.DiskMountPoint;
        CNrw.DiskMountPass = CMSrw.DiskMountPass;
        CNrw.DiskFreeMB = CMSrw.DiskFreeMB;
        CNrw.DiskTotalMB = CMSrw.DiskTotalMB;
        CNrw.DiskMaxUsedMB = MAX(CNrw.DiskMaxUsedMB,CNrw.DiskTotalMB-CNrw.DiskFreeMB);
        if (CNrw.DiskMaxUsedMB>CNrw.DiskTotalMB) then begin
          CNrw.DiskMaxUsedMB = 0;
        end;
        MatRowPut(CNr,cn_idx,CNrw);
      end;
    end;
    if (!foundf) then begin
      ClearRow(CNr,CNrw,1);
      CNrw.DiskDevice = CMSrw.DiskDevice;
      CNrw.DiskUUID = CMSrw.DiskUUID;
      CNrw.DiskFileSystem = CMSrw.DiskFileSystem;
      CNrw.DiskMountPoint = CMSrw.DiskMountPoint;
      CNrw.DiskMountPass = CMSrw.DiskMountPass;
      CNrw.DiskFreeMB = CMSrw.DiskFreeMB;
      CNrw.DiskTotalMB = CMSrw.DiskTotalMB;
      CNrw.DiskMaxUsedMB = CNrw.DiskTotalMB-CNrw.DiskFreeMB;
      if (CNrw.DiskMaxUsedMB>CNrw.DiskTotalMB) then begin
        CNrw.DiskMaxUsedMB = 0;
      end;
      MatRowInsert(CNr,MatRowCnt(CNr),CNrw);
    end;
  end;
  
  cn_rwcnt = MatRowCnt(CNr);
  for (cn_idx=cn_rwcnt;cn_idx>0;cn_idx=cn_idx-1) begin
    MatRowGet(CNr,cn_idx-1,CNrw);
    cms_rwcnt = MatRowCnt(CMSr);
    foundf = false;
    for (cms_idx=0;cms_idx<cms_rwcnt;cms_idx=cms_idx+1) begin
      MatRowGet(CMSr,cms_idx,CMSrw);
      if (CNrw.DiskDevice==CMSrw.DiskDevice) then begin foundf = true; end;
    end;
    if (!foundf or blank(CNrw.DiskDevice)) then begin
      MatRowDelete(CNr,cn_idx-1);
    end;
  end;

  return;
end;

global
updating procedure SaveCloudNodeStats(record CloudNodeVc CNr,record CloudMachineStatsVc CMSr,Boolean failf)
begin
  record CloudNodeVc OldCNr;
  record RemoteCloudServerVc RCSr;
  record RemoteCloudServerVc OldRCSr;
  Integer reachablef;
  Boolean foundf;
  Boolean reachability_changedf;
  Longint newbuild;
  record HansaVersionVc HVr;

  ReadFirstMain(CNr,1,true);
  RecordCopy(OldCNr,CNr);
  
  
  if (failf==false) then begin reachablef = 1; end;
  if (reachablef!=CNr.ReachableFlag) then begin reachability_changedf = true; end;

  CMSr.ServerCode = CNr.Code;
  CMSr.Date = CurrentDate;
  CMSr.Time = CurrentTime;
  CMSr.ReachableFlag = reachablef;

  if (reachablef) then begin
    CNr.ServerDiskTotal = CMSr.ServerDiskTotal;
    CNr.ServerDiskFree = CMSr.ServerDiskFree;
    CNr.ServerDiskMaxUsed = MAX(CNr.ServerDiskMaxUsed,CNr.ServerDiskTotal-CNr.ServerDiskFree);
    if (CNr.ServerDiskMaxUsed>CNr.ServerDiskTotal) then begin
      CNr.ServerDiskMaxUsed = 0;
    end;
    CNr.VersionBuild = CMsr.VersionBuild;
    CNr.Is64BitFlag = CMsr.Is64BitFlag;
    
    UpdateCNDiskRows(CNr,CMSr);

    RecordUpdate(OldCNr,CNr,true);
  end;
  
  if ((CNr.FastCheckFlag==0) or (CloudNodeStatus(CNr)==kCloudNodeStatusReachable) or
      (CloudNodeStatus(CNr)==kCloudNodeStatusDifferentVersion) or reachability_changedf) then begin
    RecordStore(CMSr,false);
  end;

LSaveCloudNodeStats:;
  return;
end;

global
procedure InitNodeFromCC(record CloudNodeVc CNr)
begin
  LongInt stat;
  string 255 url;
  Boolean scfailf;
  record CloudMachineStatsVc CMSr;

  if (ReadFirstMain(CNr,1,true)) then begin
    url = NodeURL(CNr);
    if (nonblank(url)) then begin
      InitNode(CNr);
      stat = CallService(url).GetCloudNodeStats(CMSr);
      scfailf = TreatServiceError(stat,url,"GetCloudNodeStats");
      queued.SaveCloudNodeStats(CNr,CMSr,scfailf);
    end;
  end;
  return;
end;

global
procedure DoCheckCloudNode(record CloudNodeVc CNr,Boolean syncrcsf)
begin
  record CloudMachineStatsVc CMSr;
  string 255 url;
  LongInt stat;
  Boolean scfailf;

  url = NodeURL(CNr);
  if (nonblank(url)) then begin
    stat = CallService(url).GetCloudNodeStats(CMSr);
    scfailf = TreatServiceError(stat,url,"GetCloudNodeStats");
    queued.SaveCloudNodeStats(CNr,CMSr,scfailf);
    queued.SaveCloudNodeReachable(CNr.Code,!scfailf);
    if (scfailf==false) then begin
      if (syncrcsf) then begin
        SyncRCSDataWithOneCN(CNr,true,false);
      end;
    end;
  end;
  return;
end;

procedure CheckCloudNode(record CloudNodeVc CNr)
begin
  if (CNr.Closed!=0) then begin
    goto LCheckCloudNode;
  end;

  switch (CNr.CurrentState) begin
    case kCloudNodeStateCreating:     if (CNr.HansaPort<=0) then begin goto LCheckCloudNode; end;
    case kCloudNodeStateStopping:     goto LCheckCloudNode;
    case kCloudNodeStateStopped:      goto LCheckCloudNode;
    case kCloudNodeStateTerminating:  goto LCheckCloudNode;
    case kCloudNodeStateMoving:       goto LCheckCloudNode;
    case kCloudNodeStateModifying:    goto LCheckCloudNode;
  end;

  DoCheckCloudNode(CNr,false);

LCheckCloudNode:;
  return;
end;

global
procedure CheckCloudNodes(string args)
begin
  record CloudNodeVc CNr;
  Boolean foundf,testf;

  CNr.Closed = 0;
  foundf = true;
  while (LoopKey("State",CNr,1,foundf)) begin
    if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LCheckCloudNodes; end;
    if (QuitingApplication==true) then begin goto LCheckCloudNodes; end;
    if (CNr.Closed!=0) then begin foundf = false; end;
    testf = foundf;
    if (testf) then begin
      CheckCloudNode(CNr);
    end;
  end;

  UpdateClientBrowsesIfNeeded("CloudNodeVc");

LCheckCloudNodes:;
  return;
end;

function Boolean ArchiveRemovedServer(string FromDataFolder)
begin
  string 255 ServerUUIDStr,ServerFolderStr,ArchiveRootFolder,ArchiveToFolder;
  string 255 substr,parastr;
  LongInt pos;
  Boolean res;
  Integer i;
  date d;

  ServerFolderStr = FromDataFolder;
  while (GetNextSubstring(ServerFolderStr,pos,"/",substr)) begin
    ServerUUIDStr = substr;
  end;  
  
  ArchiveRootFolder = ServersFolder & "ToBeArchivedOrDeleted/";
  if (DirExists(ArchiveRootFolder)==false) then begin
    CreateFolder(ArchiveRootFolder);
  end; 
  if (DirExists(ArchiveRootFolder)==false) then begin
    res = false;
    LogText(0,"Failed To create Archive root folder: " & ArchiveRootFolder);
    goto LArchiveRemovedServer;
  end;

  d = CurrentDate;
  ArchiveToFolder = ArchiveRootFolder & ServerUUIDStr & "." & DateToString(d,"YYYYMMDD");
  while (DirExists(ArchiveToFolder)) begin
    i = i + 1;
    ArchiveToFolder = ArchiveRootFolder & ServerUUIDStr & "." & DateToString(d,"YYYYMMDD") & "-" & i;
  end;

  parastr = FromDataFolder & " " & ArchiveToFolder;
   
  res = MoveFile("/",FromDataFolder,ArchiveToFolder);
  MilliSleep(100);
  
  if (DirExists(ArchiveToFolder) and (DirExists(FromDataFolder)==false)) then begin
    res = true;
  end else begin
    res = false;
  end;
  if (res==false) then begin 
    LogText(0,"Failed to move folder : " & FromDataFolder & " to archived folder: " & ArchiveToFolder);
  end else begin
    LogText(0,"Successfully moved folder : " & FromDataFolder & " to archived folder: " & ArchiveToFolder);
  end;

LArchiveRemovedServer:;
  ArchiveRemovedServer = res;
  return;
end;

global
function Boolean DoRemoveServer(record LocalCloudServerVc LCSr)
begin
  Boolean res;

  res = false;
  if (DirExists(LCSr.DataFolder)==false) then begin
    res = true;
    goto LDoRemoveServer;
  end;
    
  if (nonblank(LCSr.DataFolder) and LCSr.Closed!=0) then begin
    res = ArchiveRemovedServer(LCSr.DataFolder);
  end;

LDoRemoveServer:;
  DoRemoveServer = res;
  return;
end;

global
updating procedure DoRemoveLCS(record LocalCloudServerVc LCSr)
begin
  RecordDelete(LCSr);
  return;
end;

global
updating procedure DoMarkLCSasMovedAway(uuid lcs_uuid)
begin
  record LocalCloudServerVc LCSr,OldLCSr;
  
  LCSr.UUID = lcs_uuid;
  if (ReadFirstMain(LCSr,1,true)) then begin
    RecordCopy(OldLCSr,LCSr);
    LCSr.Closed = 1;
    LCSr.MovedAwayFlag = 1;
    LCSr.CurrentStatus = kStatusStopped;
    LCSr.WantedStatus = kWantedStatusStop;
    RecordUpdate(OldLCSr,LCSr,true);
  end;
  return;
end;

global
updating procedure DoCreateMovedRCS(record RemoteCloudServerVc RCSr)
begin
  record LocalCloudServerVc LCSr,OldLCSr;
  string 255 workdir,stattext;

  LCSr.UUID = RCSr.UUID;
  if (ReadFirstMain(LCSr,1,true)) then begin
    RecordCopy(OldLCSr,LCSr);
    CopyRCSDatatoLCS(RCSr,LCSr);
    LCSr.Closed = 0;
    LCSr.MovedAwayFlag = 0;
    LCSr.CurrentStatus = kStatusStopped;
    LCSr.WantedStatus = kWantedStatusStop;
    RecordUpdate(OldLCSr,LCSr,true);
  end else begin
    CopyRCSDatatoLCS(RCSr,LCSr);
    LCSr.Closed = 0;
    LCSr.UUID = RCSr.UUID;
    LCSr.CurrentStatus = kStatusStopped;
    LCSr.WantedStatus = kWantedStatusStop;
    RecordInsert(LCSr,false);
  end;
  if (LCSr.DBStatusUpdateType==kDBStatusUpdateAutomatic) then begin
    workdir = LCSr.DataFolder;
    if (FileExists(workdir & "/DatabaseStatus.txt")) then begin
      stattext = GetDatabaseStatus(workdir);
      CreateFolderHierarchy(EnablerActionsFolder(LCSr) & "/");
      WriteStringToFile(stattext,EnablerActionsFolder(LCSr) & "/EnSetDBStatus",kDBStatusUnknown);
    end;
  end;
  return;
end;

global
updating procedure ForceDeleteLCS(uuid serverid)
begin
  record LocalCloudServerVc LCSr;
  LCSr.UUID = serverid;
  if (ReadFirstMain(LCSr,1,true)) then begin
    RecordDelete(LCSr);
  end;
  return;
end;

global
procedure RemoveLCS(uuid serverid,Boolean fromcontrollerf,var Boolean res)
begin
  record LocalCloudServerVc LCSr;
  Boolean foundf;

  res = false;
  foundf = false;
  LCSr.UUID = serverid;
  if (ReadFirstMain(LCSr,1,true)) then begin foundf = true; end;

  if (foundf==false) then begin
    res = true;
    goto LRemoveLCS;
  end;

  if (blank(LCSr.DataFolder) or (DirExists(LCSr.DataFolder)==false) or (foundf==false)) then begin
    res = true;
    if (fromcontrollerf) then begin
      queued.DoRemoveLCS(LCSr);
    end;
    goto LRemoveLCS;
  end;

  if (LCSr.Closed==0) then begin
    LogText(0,"The CC tried to delete an LCS that isn't closed (" & LCSr.UUID & ")");
    res = false;
    goto LRemoveLCS;
  end;

  if (LCSr.Closed!=0) then begin
    res = ArchiveRemovedServer(LCSr.DataFolder);
  end;

  if (fromcontrollerf) then begin
    queued.DoRemoveLCS(LCSr);
  end;

LRemoveLCS:;
  return;
end;

global
procedure RemoveRCS(record RemoteCloudServerVc RCSr,var Boolean res)
begin
  string 255 url;
  LongInt stat;
  record LocalCloudServerVc LCSr;
  Boolean scfailf;

  res = false;

  url = RcsNodeURL(RCSr);
  if (blank(url)) then begin
    res = true; // No CN, OK to delete
    goto LRemoveRCS;
  end;

  stat = CallService(url).RemoveLCS(RCSr.UUID,true,res);
  scfailf = TreatServiceError(stat,url,"RemoveLCS");
  queued.SaveCloudNodeReachable(RCSr.Controller,!scfailf);
  if (TreatServiceError(stat,url,"RemoveLCS")) then begin end;

LRemoveRCS:;
  return;
end;

global
updating function Boolean RemoveServer(record LocalCloudServerVc LCSr)
begin
  Boolean res;
  record LocalCloudServerVc OldLCSr;

  res = false;
  if (ReadFirstMain(LCSr,1,true)) then begin
    RecordCopy(OldLCSr,LCSr);
    if (nonblank(LCSr.DataFolder) and LCSr.Closed!=0) then begin
      res = DoRemoveServer(LCSr);
      if (res==true) then begin
        LCSr.CurrentStatus = kStatusDeleted;
        LCSr.CurrentSubStatus = kSubStatusNone;
        RecordUpdate(OldLCSr,LCSr,true);
      end;
    end;
  end;

  RemoveServer = res;
  return;
end;

global
updating procedure StartCloudServers(array uuid recarr)
begin
  record LocalCloudServerVc LCSr;
  record LocalCloudServerVc OldLCSr;
  Integer i;
  Boolean testf;
  
  for (i=0;i<recarr.length;i=i+1) begin
    LCSr.UUID = recarr[i];
    if (ReadFirstMain(LCSr,1,true)) then begin
      RecordCopy(OldLCSr,LCSr);
      testf = true;
      if (LCSr.MovedAwayFlag!=0) then begin testf = false; end;
      if (LCSr.Closed!=0) then begin testf = false; end;
      if (LCSr.CurrentStatus!=kStatusStopped) then begin testf = false; end;
      if (testf) then begin
        LCSr.WantedStatus = kWantedStatusRun;
        RecordUpdate(OldLCSr,LCSr,true);
      end;
    end;
  end;
  return;
end;

global
updating procedure StopCloudServers(array uuid recarr,Boolean forcef)
begin
  record LocalCloudServerVc LCSr;
  record LocalCloudServerVc OldLCSr;
  Integer i;
  Boolean testf;
  
  for (i=0;i<recarr.length;i=i+1) begin
    LCSr.UUID = recarr[i];
    if (ReadFirstMain(LCSr,1,true)) then begin
      RecordCopy(OldLCSr,LCSr);
      testf = true;
//      if (LCSr.MovedAwayFlag!=0) then begin testf = false; end;
      if (LCSr.Closed!=0) then begin testf = false; end;
      if (testf) then begin
        if (forcef) then begin
          LCSr.WantedStatus = kWantedStatusForceStop;
        end else begin
          LCSr.WantedStatus = kWantedStatusStop;
        end;
        LCSr.WantedSubStatus = kWantedSubStatusNone;
        RecordUpdate(OldLCSr,LCSr,true);
      end;
    end;
  end;
  return;
end;

global
updating procedure RestartCloudServers(array uuid recarr)
begin
  record LocalCloudServerVc LCSr;
  record LocalCloudServerVc OldLCSr;
  Integer i;
  Boolean testf;

  for (i=0;i<recarr.length;i=i+1) begin
    LCSr.UUID = recarr[i];
    if (ReadFirstMain(LCSr,1,true)) then begin
      RecordCopy(OldLCSr,LCSr);
      testf = true;
      if (LCSr.MovedAwayFlag!=0) then begin testf = false; end;
      if (LCSr.Closed!=0) then begin testf = false; end;
      if (testf) then begin
        LCSr.WantedStatus = kWantedStatusRestart;
        RecordUpdate(OldLCSr,LCSr,true);
      end;
    end;
  end;
  return;
end;

global
updating procedure CloseCloudServers(array uuid recarr)
begin
  record LocalCloudServerVc LCSr;
  record LocalCloudServerVc OldLCSr;
  Integer i;
  Boolean testf;
  
  for (i=0;i<recarr.length;i=i+1) begin
    LCSr.UUID = recarr[i];
    if (ReadFirstMain(LCSr,1,true)) then begin
      RecordCopy(OldLCSr,LCSr);
      testf = true;
      if (LCSr.Closed!=0) then begin testf = false; end;
      if ((LCSr.CurrentStatus!=kStatusConfigInError) and (LCSr.CurrentStatus!=kStatusStopped)) then begin testf = false; end;
      if (testf) then begin
        LCSr.CurrentStatus = kStatusStopped;
        LCSr.Closed = 1;
        RecordUpdate(OldLCSr,LCSr,true);
      end;
    end;
  end;
  return;
end;

global
updating procedure RemoveCloudServers(array uuid recarr)
begin
  record LocalCloudServerVc LCSr;
  Integer i;
  Boolean testf;
  
  for (i=0;i<recarr.length;i=i+1) begin
    LCSr.UUID = recarr[i];
    if (ReadFirstMain(LCSr,1,true)) then begin
      testf = true;
      if (LCSr.Closed==0) then begin testf = false; end;
      if (LCSr.CurrentStatus<>kStatusStopped) then begin testf = false; end;
      if (testf) then begin
        if (RemoveServer(LCSr)==true) then begin
          RecordDelete(LCSr);
        end; 
      end;
    end;
  end;
  UpdateClientBrowsesIfNeeded("LocalCloudServerVc");
  return;
end;

global
updating procedure SendVersionToAllNodes(record HansaVersionVc HVr)
begin
  record CloudNodeVc CNr;
  string 255 archive;
  
  archive = CreateTempFile("version",".ha");
  BeginArchiveToFile(archive);
  AddArchiveDir(".",HVr.ProgramFolder); // BaseName(HVr.ProgramFolder)
  EndArchive;

  while (LoopMain(CNr,1,true)) begin
    if (CNr.Closed==0) then begin
      SendVersionToNode(HVr,archive,CNr);
    end;
  end;
  
  Delete_File(archive);
  return;
end;


global
procedure GetCloudServerData(var array record LocalCloudServerVc lcsarr)
begin
  record LocalCloudServerVc LCSr;
  Integer i;
  
  i = 0;
  while (LoopMain(LCSr,1,true)) begin
    lcsarr[i] = LCSr;
    i = i + 1;
  end;
  return;
end;

global
updating procedure SaveNewAndUpdatedRCSsWithTag(record CloudNodeVc CNr,array record LocalCloudServerVc lcsarr,string tagstr)
begin
  record RemoteCloudServerVc RCSr;
  record RemoteCloudServerVc OldRCSr;
  record LocalCloudServerVc LCSr;
  record CloudNodeVc CN2r;
  Integer i;
  LongInt old_wantedstatus,old_wantedsubstatus,cnt;
  Boolean rcsfoundf;

//LogText(0,"SaveNewAndUpdatedRCSsWithTag tagstr=" & tagstr);
  if (ReadFirstMain(CNr,1,true)==false) then begin
    LogText(0,"ERROR: SaveNewAndUpdatedRCSsWithTag on non-existing node " & CNr.Code);
    goto LSaveNewAndUpdatedRCSsWithTag;
  end;
  

  for (i = 0; i<lcsarr.length; i = i + 1) begin
    LCSr = lcsarr[i];
    RCSr.UUID = LCSr.UUID;
    rcsfoundf = ReadFirstMain(RCSr,1,true);
    
    if (rcsfoundf and (LCSr.MovedAwayFlag!=0) or (LCSr.Closed!=0) or (LCSr.ClosedOnNodeFlag!=0)) then begin
      if (RCSr.Controller==CNr.Code) then begin
        RecordCopy(OldRCSr,RCSr);
        RCSr.CurrentStatus = LCSr.CurrentStatus;
        if (ComparePosts(OldRCSr,RCSr)==false) then begin
          RecordUpdate(OldRCSr,RCSr,true);
        end;
      end;
    end else begin
      if (rcsfoundf) then begin
        RecordCopy(OldRCSr,RCSr);
        CopyLCSControlledDataToRCS(LCSr,RCSr);
        if (RCSr.Controller!=CNr.Code) then begin
          if (NodeIsBeingMoved(CNr.Code)) then begin
            goto LSaveNewAndUpdatedRCSsWithTag;
          end else begin
            queued.StoreASPEvent(kASPEventTypeNodeSyncError,"The Remote Cloud Server (1) '" & RCSName(RCSr) & "' changed node from " & RCSr.Controller & " to " & CNr.Code,"",RCSr.UUID,RCSr.Controller);
            SetCloudControllerStatus(kJobStatusWarning,"The Remote Cloud Server (1) '" & RCSName(RCSr) & "' changed node from " & RCSr.Controller & " to " & CNr.Code);
          end;
        end;
        if (RCSr.Controller!=OldRCSr.Controller) then begin
          if (NodeIsBeingMoved(OldRCSr.Controller)) then begin
            goto LSaveNewAndUpdatedRCSsWithTag;
          end else begin
            queued.StoreASPEvent(kASPEventTypeNodeSyncError,"The Remote Cloud Server (2) '" & RCSName(RCSr) & "' changed node from " & RCSr.Controller & " to " & OldRCSr.Controller,"",RCSr.UUID,RCSr.Controller);
            SetCloudControllerStatus(kJobStatusWarning,"The Remote Cloud Server (2) '" & RCSName(RCSr) & "' changed node from " & RCSr.Controller & " to " & OldRCSr.Controller);
          end;
        end;
        RCSr.Controller = CNr.Code;
        if (RCSr.Closed!=0) then begin
          RCSr.ClosedOnNodeFlag = 1;
        end;
        if ((RCSr.ShouldCloseFlag!=0) and (RCSr.Closed==0)) then begin
          LogText(0,"Server " & RCSName(RCSr) & " was closed on node " & RCSr.Controller & ", marking it closed");
          RCSr.Closed = 1;
        end;
        if (ComparePosts(OldRCSr,RCSr)==false) then begin
          if (OldRCSr.CurrentStatus!=RCSr.CurrentStatus) then begin
            if ((OldRCSr.CurrentStatus==kStatusRunning or OldRCSr.CurrentStatus==kStatusRunningPendingStop) and
                RCSr.CurrentStatus==kStatusStopped) then begin
              queued.StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
            end;
            LogText(0,"SaveNewAndUpdatedRCSsWithTag: CurrentStatus for " & RCSr.UUID & " changed from " & StatusName(OldRCSr.CurrentStatus) & " to " & StatusName(RCSr.CurrentStatus) & ", RCSr.MyStandardStatusCode=" & RCSr.MyStandardStatusCode);
          end;
          if (OldRCSr.CurrentSubStatus!=RCSr.CurrentSubStatus) then begin
            LogText(0,"SaveNewAndUpdatedRCSsWithTag: CurrentSubStatus for " & RCSr.UUID & " changed from " & SubStatusName(OldRCSr.CurrentSubStatus) & " to " & SubStatusName(RCSr.CurrentSubStatus));
          end;
          if (ComparePosts(OldRCSr,RCSr)==false) then begin
            RecordUpdate(OldRCSr,RCSr,true);
          end;
        end;
//        if (OldRCSr.CurrentStatus!=RCSr.CurrentStatus and RCSr.CurrentStatus==kStatusRunning) then begin
//          StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,true,true);
//        end;
// 2023-07-10 starting to deprecate ASPEventsVc in its current form
//        if (OldRCSr.CurrentStatus!=RCSr.CurrentStatus and RCSr.CurrentStatus==kStatusConfigInError) then begin
//          queued.StoreASPEvent(kASPEventTypeCloudServerError,RCSr.StatusText,"",RCSr.UUID,RCSr.Controller);
//        end;
      end else begin
        RecordClear(RCSr);
        CopyLCSDataToRCS(LCSr,RCSr);
        RCSr.UUID = LCSr.UUID;
        RCSr.Controller = CNr.Code;
        if (RCSr.Closed!=0) then begin
          RCSr.ClosedOnNodeFlag = 1;
        end;
        RecordInsert(RCSr,false);
      end;
      RCSr.UUID = LCSr.UUID;
      if (ReadFirstMain(RCSr,1,true)) then begin
        old_wantedstatus = RCSr.WantedStatus;
        old_wantedsubstatus = RCSr.WantedSubStatus;
        if (((RCSr.CurrentStatus==kStatusUpdatingVersion) or (RCSr.CurrentStatus==kStatusRebuildingDatabase)) and
            (RCSr.WantedStatus!=kWantedStatusStop) and
            (RCSr.WantedStatus!=kWantedStatusStopAndRefresh) and
            (RCSr.WantedStatus!=kWantedStatusForceStop) and
            (RCSr.WantedStatus!=kWantedStatusRestart)) then begin
          UpdateServerWantedSubStatus(RCSr,cnt);
        end;
        if (ReadFirstMain(RCSr,1,true)) then begin
          UpdateServerWantedStatus(RCSr,cnt);
          if ((RCSr.WantedStatus!=old_wantedstatus) or (RCSr.WantedSubStatus!=old_wantedsubstatus)) then begin
            threadasync.SyncOneRCS(RCSr,true,true,"6");
          end;
        end;
      end;
    end;
  end;

LSaveNewAndUpdatedRCSsWithTag:;
  return;
end;

global
updating procedure SaveNewAndUpdatedRCSs(record CloudNodeVc CNr,array record LocalCloudServerVc lcsarr)
begin
  SaveNewAndUpdatedRCSsWithTag(CNr,lcsarr,"no tag");
  return;
end;

global
procedure SyncLCSDataAtCN(array record RemoteCloudServerVc rcsarr,var array record LocalCloudServerVc lcsarr)
begin
  record LocalCloudServerVc LCSr;
  record RemoteCloudServerVc RCSr;
  Integer i;

  i = 0;
  while (LoopMain(LCSr,1,true)) begin
    if (LCSr.ClosedOnNodeFlag==0) then begin
      lcsarr[i] = LCSr;
      i = i + 1;
    end;
  end;

LSyncLCSDataAtCN_OnlyOne:;
//  LogText(0,"Synchronizing " & rcsarr.length & " CC and " & i & " CN cloud server records with cloud controller");

  if (rcsarr.length>0) then begin
    queued.SaveNewAndUpdatedLCSs(rcsarr);
  end;

  return;
end;

function Integer MaxRecordsInSyncOp()
begin
  MaxRecordsInSyncOp = 1500;
  return;
end;

global
updating procedure GetLCSsAtCN(var array record LocalCloudServerVc lcsarr,var Integer pos,var Boolean moref)
begin
  record LocalCloudServerVc LCSr;
  Integer i,j;

  moref = false;
  i = 0;
  j = 0;
  while (LoopMain(LCSr,1,true)) begin
    if (i>=pos) then begin
      if (j==MaxRecordsInSyncOp) then begin
        moref = true;
        goto LGetLCSsAtCN;
      end;
      if (LCsr.ClosedOnNodeFlag==0) then begin
        lcsarr[j] = LCSr;
        j = j + 1;
      end;
    end;
    i = i + 1;
  end;

LGetLCSsAtCN:;
//LCSr = lcsarr[0];
//LogText(0,"GetLCSsAtCN status=" & StatusName(LCSr.CurrentStatus));

  pos = i;
  return;
end;

global
procedure FastSyncLCSDataAtCN(array record RemoteCloudServerVc rcsarr,var array record LocalCloudServerVc lcsarr)
begin
  record LocalCloudServerVc LCSr;
  record RemoteCloudServerVc RCSr;
  LongInt i,j;

  j = 0;
  for (i = 0; i<rcsarr.length; i = i + 1) begin
    RCSr = rcsarr[i];
    LCSr.UUID = RCSr.UUID;
    if (ReadFirstMain(LCSr,1,true)) then begin
      lcsarr[j] = LCSr;
      j = j + 1;
    end;
  end;

  if (rcsarr.length>0) then begin
    queued.SaveNewAndUpdatedLCSs(rcsarr);
  end;

  return;
end;
