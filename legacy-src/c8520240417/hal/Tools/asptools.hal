          DeleteFileIfExists(path & "/" & fname & "/hansa-slave");
          DeleteFileIfExists(path & "/" & fname & "/hansa-debug-slave");
          DeleteFileIfExists(path & "/" & fname & "/hansa-debug-optimized-slave");
