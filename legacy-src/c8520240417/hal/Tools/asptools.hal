    CreateRecordLink(NRr,CurrentCompany,NPr,CurrentCompany);
    if (ReadRecordLink(NRr,notenr,NPr,RLr)) then begin
    RLr.Comment = "Node Rebuild Log";
      if (RecordStore(RLr,true)) then begin end;
