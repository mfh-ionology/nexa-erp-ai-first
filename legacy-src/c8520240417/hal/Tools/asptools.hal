global
procedure DoCopyFileOrFolderFromLCS(area a_ssh_key,string username,string remoteaddr,string afrom_fpath,string to_fpath)
begin
  string 255 cmdline,keyfile,sshopt,transsz,from_fpath;

  from_fpath = afrom_fpath;
  sshopt = "-o UserKnownHostsFile=/dev/null -o ServerAliveInterval=60 -o StrictHostKeyChecking=no -o PasswordAuthentication=no -i ";

  keyfile = CreateTempFile("ssh-key",".dat");
  WriteAreaToFile(a_ssh_key,keyfile,0);

  RunShellScriptGetStdOut("du -bs \"" & from_fpath & "\" |cut -f1",transsz);

  cmdline = "ssh " & sshopt & keyfile & " " & username & "@" & remoteaddr & " \"sudo bash -c '( echo " & Trim(transsz) & " >\"" & to_fpath & ".cn-fstrans\" )'\"";
  RunShellScript(cmdline);

  cmdline = "ssh " & sshopt & keyfile & " " & username & "@" & remoteaddr & " \"sudo bash -c '( rm -rf \"" & to_fpath & "\" )'\"";
  RunShellScript(cmdline);

  if (DirExists(from_fpath)) then begin from_fpath = from_fpath & "/"; end;
  cmdline = "rsync -aq --partial --inplace -e \"ssh " & sshopt & keyfile & "\" --rsync-path=\"sudo rsync\" \"" & from_fpath & "\" " & username & "@" & remoteaddr & ":\"" & to_fpath & "\"";
  RunShellScript(cmdline);

  cmdline = "ssh " & sshopt & keyfile & " " & username & "@" & remoteaddr & " \"sudo bash -c '( rm -f \"" & to_fpath & ".cn-fstrans\" )'\"";
  RunShellScript(cmdline);

  Delete_file(keyfile);

  return;
end;

global
procedure CopyFileOrFolderFromLCS(area a_ssh_key,string username,string remoteaddr,string from_fpath,string to_fpath)
begin
  ThreadAsync.DoCopyFileOrFolderFromLCS(a_ssh_key,username,remoteaddr,from_fpath,to_fpath);
  return;
end;

global
updating procedure CopyFileOrFolderToRemoteCloudServer(uuid from_rcsid,string fpath,string fname,uuid to_rcsid,Integer dirf,var string msg)
begin
  record RemoteCloudServerVc fromRCSr,toRCSr;
  Boolean testf;
  string 255 from_url,from_remotefname,to_remotefname;
  LongInt stat;
  Boolean scfailf;
  record HostingConfigurationVc HCr;
  record Attach2Vc AT2r;
  record CloudNodeVc CNr;
  area a_ssh_key;

  fromRCSr.UUID = from_rcsid;
  if (ReadFirstMain(fromRCSr,1,true)==false) then begin
    msg = "Failed reading source RCS record";
    goto LCopyFileOrFolderToRemoteCloudServer;
  end;
  from_url = RcsNodeURL(fromRCSr);
  if (blank(from_url)) then begin
    msg = "Failed reading source RCS node URL";
    goto LCopyFileOrFolderToRemoteCloudServer;
  end;

  toRCSr.UUID = to_rcsid;
  if (ReadFirstMain(toRCSr,1,true)==false) then begin
    msg = "Failed reading destination RCS record";
    goto LCopyFileOrFolderToRemoteCloudServer;
  end;

  CNr.Code = toRCSr.Controller;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    msg = "Failed reading destination RCS node record";
    goto LCopyFileOrFolderToRemoteCloudServer;
  end;
  HCr.SerNr = CNr.HostingConfig;
  if (ReadFirstMain(HCr,1,true)==false) then begin
    msg = "Invalid destination node hosting configuration";
    goto LCopyFileOrFolderToRemoteCloudServer;
  end;
  if (GetKeyForHostingConfigurationToArea(HCr,"",a_ssh_key)==false) then begin
    msg = "Invalid destination node hosting configuration key";
    goto LCopyFileOrFolderToRemoteCloudServer;
  end;
  if (blank(CNr.HostName)) then begin
    msg = "Invalid destination node address";
    goto LCopyFileOrFolderToRemoteCloudServer;
    end;
  if (blank(CNr.AdminUser)) then begin
    msg = "Invalid destination node admin user";
    goto LCopyFileOrFolderToRemoteCloudServer;
  end;

  from_remotefname = fromRCSr.DataFolder & "/" & fpath & "/" & fname;
  to_remotefname = toRCSr.DataFolder & "/" & fpath & "/" & fname;

  SetCloudControllerStatus(kJobStatusRunning,"Copying " & from_remotefname & " for server " & RCSName(fromRCSr) & " on node " & fromRCSr.Controller  & " to server " & RCSName(toRCSr) & " on node " & toRCSr.Controller);
  LogText(0,"Copying " & from_remotefname & " for server " & RCSName(fromRCSr) & " on node " & fromRCSr.Controller  & " to server " & RCSName(toRCSr) & " on node " & toRCSr.Controller);
  stat = CallService(from_url).CopyFileOrFolderFromLCS(a_ssh_key,CNr.AdminUser,CNr.HostName,from_remotefname,to_remotefname);
  scfailf = TreatServiceError(stat,from_url,"CopyFileOrFolderFromLCS");
  queued.SaveCloudNodeReachable(fromRCSr.Controller,!scfailf);
  if (scfailf) then begin
    LogText(0,"Failed to copy file or folder " & fpath & "/" & fname & " for server " & RCSName(fromRCSr) & " on node " & fromRCSr.Controller & " to server " & RCSName(toRCSr) & " on node " & toRCSr.Controller);
    msg = "Communications failure while sending request to source node";
    goto LCopyFileOrFolderToRemoteCloudServer;
  end;

LCopyFileOrFolderToRemoteCloudServer:;
  return;
end;

global
procedure CheckServerMigrationStatus(string sid,var string servername,var Integer stat)
begin
  record RemoteCloudServerVc RCSr;

  stat = 0;
  RCSr.UUID = StringToUUID(sid);
  if (ReadFirstMain(RCSr,1,true)) then begin
    if (RCSr.MigrationFlag==1) then begin
      stat = 1;
      servername = RCSr.Name;
    end;
  end;

  return;
end;

global
updating procedure DoStoreMigrationServerCustomer(string sid,string email,string name,var Integer stat)
begin
  record RemoteCloudServerVc RCSr,oldRCSr;
  record CUVc CUr;
  string 255 tstr;

  stat = 0;
  RCSr.UUID = StringToUUID(sid);
  if (ReadFirstMain(RCSr,1,true)) then begin
    if (RCSr.MigrationFlag==1) then begin
      RecordNew(CUr);
      GetNextCustNr(tstr);
      CUr.Code = tstr;
      CUr.eMail = email;
      CUr.Name = name;
      if (RecordStore(CUr,false)) then begin
        RecordCopy(oldRCSr,RCSr);
        RCSr.CUCode = tstr;
        if (RecordUpdate(oldRCSr,RCSr,true)==0) then begin
          stat = 1;
        end;
      end;
    end;
  end;

  return;
end;

global
procedure NextHostPoolNodeName(var string node_name)
begin
  Integer node_no;
  record CloudNodeVc CNr;
  record CloudSettingsBlock CSb;
  string 255 node_basename;

  BlockLoad(CSb);
  node_basename = "NODE-" & StringFromSet(10005,CSb.HostingPartner) & "-";

LNextHostPoolNodeName_Next:;
  node_no = node_no + 1;
  CNr.Code = node_basename & node_no;
  if (ReadFirstMain(CNr,1,true)) then begin goto LNextHostPoolNodeName_Next; end;
  node_name = node_basename & node_no;

  return;
end;

