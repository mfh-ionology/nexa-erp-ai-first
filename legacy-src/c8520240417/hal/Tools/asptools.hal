      SetCloudControllerStatus(kJobStatusRunning,"Renaming " & old_remotefname & " to " & new_remotefname & " for server " & RCSName(RCSr) & " on node " & RCSr.Controller);
      LogText(0,"Renaming " & old_remotefname & " to " & new_remotefname & " for server " & RCSName(RCSr) & " on node " & RCSr.Controller);
      stat = CallService(url).RenameFileOrFolderOnLCS(old_remotefname,new_remotefname);
