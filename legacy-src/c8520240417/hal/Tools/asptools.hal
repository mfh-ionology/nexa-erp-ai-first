global
updating procedure CNUpdateHMCUCode(record LocalCloudServerVc LCSr,string cucode,Integer regincountry,Longint contract,val foldersize)
begin
  record LocalCloudServerVc OldLCSr;

  if (ReadFirstMain(LCSr,1,true)) then begin
    RecordCopy(OldLCSr,LCSr);
    LCSr.HMCUCode = cucode;
    LCSr.Contract = contract;
