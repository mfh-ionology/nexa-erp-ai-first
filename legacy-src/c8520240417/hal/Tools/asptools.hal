global
updating procedure ReadCustConfigAndStore(array record LocalCloudServerVc aLCSr)
begin
  record LocalCloudServerVc LCSr,OldLCSr;
  record ModuleBlock Mb;
  Integer i;
  area afile,nl;
  Longint fsz;
  string 255 fn,tag;

  AddTextToArea(chr(10),nl);
  for (i=0;i<aLCSr.length;i=i+1) begin
    LCSr = aLCSr[i];
    fn = LCSr.DataFolder & "/CustConfig.txt";
    if (FileExists(fn)) then begin
      fsz = FileSize(fn);
      LoadFileToArea(fn,0,fsz,afile);
      InsertAreaBeforeArea(nl,afile);
      tag = Trim(GetLineFromArea(afile,1));
      GetBlockFromArea(Mb,tag,0,afile);
      if (nonblank(Mb.ControlString)) then begin
        RecordCopy(OldLCSr,LCSr);
        LCSr.LocalBackupPlan = Mb.LocalBackupPlan;
        LCSr.CloudBackupPlan = Mb.CloudBackupPlan;
        LCSr.DBCopyPlan = Mb.DatabaseCopies;
        if (ComparePosts(LCSr,OldLCSr)==false) then begin
          RecordUpdate(OldLCSr,LCSr,true);
        end;
      end;
      Delete_File(fn);
    end;
  end;

  return;
end;

global
procedure ReadCustConfigFromServerTask(string args)
begin
  Boolean testf;
  record LocalCloudServerVc LCSr,oldLCSr;
  array record LocalCloudServerVc aLCSr;
  Date td;
  while (LoopMain(LCSr,1,true)) begin
    testf = true;
    if (LCSr.CurrentStatus!=kStatusRunning) then begin
      testf = false;
    end;
    if (blank(LCSr.HansaVersion) or LCSr.HansaVersion<"STDERP_8.5-2018-01-01") then begin//for new versions only
      testf = false;
    end;
    if (testf) then begin
      CreateFolderHierarchy(EnablerActionsFolder(LCSr) & "/");
      WriteStringToFile("1" & chr(9) & "ModuleBlock" & chr(9) & "CustConfig.txt",EnablerActionsFolder(LCSr) & "/EnExportBlock",0);
      aLCSr[aLCSr.length] = LCSr;
    end;
  end;

  if (aLCSr.length>0) then begin
    Sleep(10);//this is not ideal, but as it's on a trhead, it shoudl be fine
    qupdating.ReadCustConfigAndStore(aLCSr);
  end;

  RemoveTask("UpdateCustConfFromCN");
  td = AddDay(CurrentDate,1);
  NewTimedTask2("UpdateCustConfFromCN","Get Customer Backup Plan Config","ReadCustConfigFromServerTask","",td,"22:00:00","","");

  return;
end;

global
procedure GetServerImportProgressAtCN(UUID serverid,var Integer res)
begin
  record LocalCloudServerVc LCSr;
  string 255 fn,tstr;
  Longint sz,flen,lines,l;
  area logfile;
  Integer pos,pos2,tpos;

  res = 0;
  LCSr.UUID = serverid;
  if (ReadFirstMain(LCSr,1,true)) then begin
    fn = LCSr.DataFolder & "/hansa.log";
    if (FileExists(fn)) then begin
      sz = FileSize2(fn);
      if (sz>0) then begin
        flen = 30000;//1mb
        if (sz-flen<0) then begin
          flen = sz;
        end;
        LoadFileToArea(fn,sz-flen,flen,logfile);
        lines = CountLinesInArea(logfile);
        for (l=lines-1;l>=0;l=l-1) begin
          tstr = GetLineFromArea(logfile,l);
          pos = InString(tstr,"Imported");
          if (pos>0) then begin
            pos2 = InString(tstr,".");
            if (pos2>0) then begin
              tpos = pos+7;
              res = StringToInt(mid(tstr,tpos,pos2-tpos));
              l = 0;
            end;
          end;
        end;
      end;
    end;
  end;
  return;
end;

global
function Integer GetServerImportProgress(record RemoteCloudServerVc RCSr)
begin
  Integer res,stat;
  string 255 url;

  url = RcsNodeURL(RCSr);
  if (nonblank(url)) then begin
    stat = CallService(url).GetServerImportProgressAtCN(RCSr.UUID,res);
  end;

  GetServerImportProgress = res;
  return;
end;

function Boolean ShouldTreatPlannedUpdate(record ASPPlannedUpdatesVc APUr)
begin
  Boolean res;
  date cd,sd,ed;
  time ct,st,et;

  if (APUr.Closed!=0) then begin goto LShouldTreatPlannedUpdate; end;
  if (APUr.Completed!=0) then begin goto LShouldTreatPlannedUpdate; end;

  cd = CurrentDate;
  ct = CurrentTime;
  
  sd = APUr.StartDate;
  if ((APUr.MaxHours>0) and (APUr.MaxHours<24)) then begin // Run daily for MaxHours, beginning on StartDate/StartTime, or forever if MaxHours is blank/invalid
    if (sd<cd) then begin sd = cd; end;
  end;
  st = APUr.StartTime;
  
  ed = cd;
  et = st;
  if ((APUr.MaxHours>0) and (APUr.MaxHours<24)) then begin
    et = AddHours(st,APUr.MaxHours);
    if (et<st) then begin ed = AddDay(ed,1); end;
  end else begin
    ed = AddDay(ed,1);
  end;
  
  res = DateTimeInRange(cd,ct,sd,st,ed,et);
//LogText(0,"DEBUG DateTimeInRange res=" & res & ", cd=" & cd & ", ct=" & ct & ", sd=" & sd & ", st=" & st & ", ed=" & ed & ", et=" & et);

LShouldTreatPlannedUpdate:;
  ShouldTreatPlannedUpdate = res;
  return;
end;

function Boolean IsServerExcludedFromPlannedUpdate(record ASPPlannedUpdatesVc APUr,record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  row ASPPlannedUpdatesVc APUrw;
  Integer rwcnt,i;

  rwcnt = MatRowCnt(APUr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(APUr,i,APUrw);
    if (APUrw.stp==1) then begin
      if (APUrw.ExcludeServer==RCSr.UUID) then begin
        res = true;
        goto LIsServerExcludedFromPlannedUpdate;
      end;
    end;
  end;

LIsServerExcludedFromPlannedUpdate:;
  IsServerExcludedFromPlannedUpdate = res;
  return;
end;

global
function Boolean IsFailedServerInPlannedUpdate(record RemoteCloudServerVc RCSr,record ASPPlannedUpdatesVc APUr)
begin
  Boolean foundf;
  Integer idx,rwcnt;
  row ASPPlannedUpdatesVc APUrw;
  
  rwcnt = MatRowCnt(APUr);
  for (idx=rwcnt;idx>0;idx=idx-1) begin
    MatRowGet(APUr,idx-1,APUrw);
    if (APUrw.stp==2) then begin
      if (RCSr.UUID==APUrw.FailedServer) then begin
        foundf = true;
        goto LIsFailedServerInPlannedUpdate;
      end;
    end;
  end;

LIsFailedServerInPlannedUpdate:;
  IsFailedServerInPlannedUpdate = foundf;
  return;
end;

procedure AddFailedServerToPlannedUpdateIfNeeded(record RemoteCloudServerVc RCSr,var record ASPPlannedUpdatesVc APUr)
begin
  row ASPPlannedUpdatesVc APUrw;

  if (IsFailedServerInPlannedUpdate(RCSr,APUr)) then begin
    goto LAddFailedServerToPlannedUpdateIfNeeded;
  end;
  
  ClearRow(APUr,APUrw,1);
  APUrw.stp = 2;
  if (nonblank(RCSr.CUCode)) then begin
    APUrw.FailedServerName = RCSName(RCSr) & " (Customer No. " & RCSr.CUCode & ")";
  end else begin
    APUrw.FailedServerName = RCSName(RCSr);
  end;
  APUrw.FailedServer = RCSr.UUID;
  MatRowPut(APUr,MatRowCnt(APUr),APUrw);
  
LAddFailedServerToPlannedUpdateIfNeeded:;
  return;
end;

global
function Boolean StartOnePlannedUpdateIfNeeded(var record ASPPlannedUpdatesVc APUr,record RemoteCloudServerVc RCS2r,var LongInt ongoing_cnt)
begin
  Boolean nextf;
  uuid blank_uuid;
  array uuid uuid_arr;
  string 255 tstr,errmsg;
  record RemoteCloudServerVc RCSr;
  
  RecordCopy(RCSr,RCS2r);
  if (qupdating.GetRCSOnMainThread(RCSr)==false) then begin
    AddFailedServerToPlannedUpdateIfNeeded(RCS2r,APUr);
    goto LStartOnePlannedUpdateIfNeeded;
  end;

  if ((RCSr.HansaVersion==APUr.ToHansaVersion) or (RCSr.WantedStatus==kWantedStatusUpdateVersion)) then begin
    if (RCSr.CurrentStatus==kStatusConfigInError) then begin
      AddFailedServerToPlannedUpdateIfNeeded(RCSr,APUr);
      nextf = true;
    end;
    goto LStartOnePlannedUpdateIfNeeded;
  end;

  if ((RCSr.IsInPlannedUpdateFlag!=0) and (RCSr.WantedStatus!=kWantedStatusUpdateVersion)) then begin
    if (RCSr.HansaVersion!=APUr.ToHansaVersion) then begin
      AddFailedServerToPlannedUpdateIfNeeded(RCSr,APUr);
      qupdating.SetServerRetainRecordDatesFlag(RCSr.UUID,0);
      qupdating.SetServerIsInPlannedUpdateFlag(RCSr.UUID,0);
      nextf = true;
      goto LStartOnePlannedUpdateIfNeeded;
    end;
  end;
  
  qupdating.SetServerRetainRecordDatesFlag(RCSr.UUID,1);
  qupdating.SetServerIsInPlannedUpdateFlag(RCSr.UUID,1);
  if (RCSr.WantedStatus==kWantedStatusStop or RCSr.WantedStatus==kWantedStatusOnDemand) then begin
    qupdating.UpdateRCSNextWantedStatus(RCSr,kWantedStatusStop);
  end else begin
    qupdating.UpdateRCSNextWantedStatus(RCSr,RCSr.WantedStatus);
  end;

  uuid_arr[uuid_arr.length] = RCSr.UUID;
  qupdating.UpdateRemoteCloudServers(uuid_arr,APUr.ToHansaVersion,APUr.DBCache,errmsg);
  if (nonblank(errmsg)) then begin
    tstr = "Planned Update failed updating " & RCSName(RCSr) & ", " & errmsg;
    LogText(0,tstr);
    AddFailedServerToPlannedUpdateIfNeeded(RCSr,APUr);
    nextf = true;
  end else begin
    if (ongoing_cnt==0) then begin
      APUr.CurrentServer = RCSr.UUID;
      APUr.CurrentServerName = RCSName(RCSr);
    end;
  end;

LStartOnePlannedUpdateIfNeeded:;
  if (nextf==false) then begin
    ongoing_cnt = ongoing_cnt + 1;
    if (APUr.MaxConcurrent>0) then begin
      if (ongoing_cnt<APUr.MaxConcurrent) then begin
        nextf = true;
      end;
    end;
  end;

  StartOnePlannedUpdateIfNeeded = nextf;
  return;
end;

procedure CopyPlannedUpdateMat(var record ASPPlannedUpdatesVc APUr,record ASPPlannedUpdatesVc APU2r)
begin
  Integer idx,rwcnt;
  row ASPPlannedUpdatesVc APUrw;
  
  while (MatRowCnt(APUr)>0) begin
    MatRowDelete(APUr,MatRowCnt(APUr)-1);
  end;

  rwcnt = MatRowCnt(APU2r);
  for (idx=0;idx<rwcnt;idx=idx+1) begin
    MatRowGet(APU2r,idx,APUrw);
    MatRowPut(APUr,MatRowCnt(APUr),APUrw);
  end;

  return;
end;

global
updating procedure UpdatePlanedUpdateRec(record ASPPlannedUpdatesVc APUr)
begin
  record ASPPlannedUpdatesVc APU2r,OldAPU2r;

  RecordCopy(APU2r,APUr);

  if (ReadFirstMain(APU2r,1,true)) then begin
    RecordCopy(OldAPU2r,APU2r);
    APU2r.CurrentServer = APUr.CurrentServer;
    APU2r.CurrentServerName = APUr.CurrentServerName;
    APU2r.NumServersLeft = APUr.NumServersLeft;
    APU2r.Completed = APUr.Completed;
    APU2r.NumFailed = APUr.NumFailed;
    if (APU2r.NumTotal==-1) then begin
      APU2r.NumTotal = APUr.NumTotal;
    end;
    CopyPlannedUpdateMat(APU2r,APUr);
    RecordUpdate(OldAPU2r,APU2r,false);
  end;
  
  UpdateClientBrowses("ASPPlannedUpdatesVc");
  return;
end;

function LongInt CountFailedServersInPlannedUpdate(record ASPPlannedUpdatesVc APUr)
begin
  LongInt cnt;
  Integer idx,rwcnt;
  row ASPPlannedUpdatesVc APUrw;
  
  cnt = 0;
  rwcnt = MatRowCnt(APUr);
  for (idx=rwcnt;idx>0;idx=idx-1) begin
    MatRowGet(APUr,idx-1,APUrw);
    if (APUrw.stp==2) then begin
      cnt = cnt + 1;
    end;
  end;

  CountFailedServersInPlannedUpdate = cnt;
  return;
end;

global
function Boolean PlannedUpdateShouldTreatServer(var record ASPPlannedUpdatesVc APUr,record RemoteCloudServerVc RCSr,var Boolean failuref)
begin
  Boolean res;
  record HansaVersionVc HVr,HV2r;
  record CloudNodeVc CNr;
  Integer i,rwcnt;
  LongInt old_version_build,new_version_build;

  failuref = false;
  if (RCSr.Closed!=0) then begin goto LPlannedUpdateShouldTreatServer; end;
  
  if (IsFailedServerInPlannedUpdate(RCSr,APUr)) then begin
    failuref = true;
    goto LPlannedUpdateShouldTreatServer;
  end;
  
  if (blank(RCSr.HansaVersion)) then begin
    if (nonblank(APUr.Node)) then begin
      if (RCSr.Controller==APUr.Node) then begin
        if (blank(APUr.FromHansaVersion)) then begin
          failuref = true;
        end;
      end;
    end else begin
      failuref = true;
    end;
  end else begin
    HVr.Code = APUr.FromHansaVersion;
    if (ReadFirstMain(HVr,1,true)) then begin
      if (APUr.FromHansaVersion==RCSr.HansaVersion) then begin res = true; end;
    end else begin
      if (IsDevelopmentVersion(RCSr.HansaVersion) or (!IsInternalVersion(RCSr.HansaVersion) and IsNonBranchedVersion(RCSr.HansaVersion))) then begin
        if (Left(RCSr.HansaVersion,len(APUr.FromHansaVersion))==APUr.FromHansaVersion) then begin
          res = true;
        end;
      end;
    end;
    
    HVr.Code = RCSr.HansaVersion;
    if (ReadFirstMain(HVr,1,true)==false) then begin
      res = false;
      failuref = true;
    end;
  end;
  
  HV2r.Code = APUr.ToHansaVersion;
  if (ReadFirstMain(HV2r,1,true)==false) then begin res = false; end;
  
  old_version_build = (HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild;
  new_version_build = (HV2r.Version * 1000000) + (HV2r.SubVersion * 10000) + HV2r.RunningBuild;
  if (old_version_build>=new_version_build) then begin res = false; end;

  if (res) then begin
    if (nonblank(APUr.Node)) then begin
      if (RCSr.Controller!=APUr.Node) then begin
        res = false;
        failuref = false;
      end;
    end;
  
    if (nonblank(APUr.ServerClassification)) then begin
      if (SetInSet2(APUr.ServerClassification,RCSr.Classification)==false) then begin
        res = false;
        failuref = false;
      end;
    end;
    
    if (nonblank(APUr.NodeClassification)) then begin
      if (CNr.Code!=RCSr.Controller) then begin
        CNr.Code = RCSr.Controller;
        ReadFirstMain(CNr,1,true);
      end;
      if (SetInSet2(APUr.NodeClassification,CNr.Classification)==false) then begin
        res = false;
        failuref = false;
      end;
    end;
    if (APUr.IgnoreHalcust!=0 and RCSr.HalcustPresentFlag!=0) then begin
      res = false;
      failuref = false;
    end;
    if (APUr.IgnoreHalpatch!=0 and RCSr.HalpatchPresentFlag!=0) then begin
      res = false;
      failuref = false;
    end;
  end;
  
  if (res and IsServerExcludedFromPlannedUpdate(APUr,RCSr)) then begin
    res = false;
    failuref = false;
  end;
  
  if (res) then begin
    switch (RCSr.WantedStatus) begin
      case kWantedStatusStop:
      case kWantedStatusForceStop:
      case kWantedStatusRun:
      case kWantedStatusOnDemand:
      case kWantedStatusUpdateVersion:
      otherwise
        failuref = true;
        res = false;
    end;
    
    if (RCSr.CloneFlag!=kSystemTypeNormal) then begin // we haven't learnt how to update clone systems yet
      res = false;
      failuref = true;
    end;
    
    if (RCSr.CurrentStatus==kStatusConfigInError) then begin
      res = false;
      failuref = true;
    end;
  end;

LPlannedUpdateShouldTreatServer:;
  PlannedUpdateShouldTreatServer = res;
  return;
end;

function LongInt UpdatePlannedUpdateStatus(var record ASPPlannedUpdatesVc APUr,var LongInt total_cnt,var LongInt failed_cnt,var UUID first_ongoing)
begin
  UUID blank_uuid;
  record RemoteCloudServerVc RCSr;
  Boolean testf,failuref,foundf;
  Longint res;

  first_ongoing = APUr.CurrentServer;
  res = 0;
  failed_cnt = 0;
  total_cnt = 0;
  foundf = true;
  RCSr.UUID = first_ongoing;
  while (LoopMain(RCSr,1,foundf)) begin
    if (!foundf) then begin goto LUpdatePlannedUpdateStatus; end;

    testf = PlannedUpdateShouldTreatServer(APUr,RCSr,failuref);
    if (failuref) then begin
      AddFailedServerToPlannedUpdateIfNeeded(RCSr,APUr);
      qupdating.SetServerIsInPlannedUpdateFlag(RCSr.UUID,0);
      qupdating.SetServerRetainRecordDatesFlag(RCSr.UUID,0);
      failed_cnt = failed_cnt + 1;
    end;
    if (testf) then begin
      if (RCSr.CurrentStatus!=kStatusConfigInError) then begin
        if ((RCSr.HansaVersion!=APUr.ToHansaVersion) or (RCSr.WantedStatus==kWantedStatusUpdateVersion)) then begin
          if ((RCSr.IsInPlannedUpdateFlag!=0) and (RCSr.WantedStatus==kWantedStatusUpdateVersion)) then begin
            if (res==0) then begin
              first_ongoing = RCSr.UUID;
            end;
            res = res + 1;
          end;
          total_cnt = total_cnt + 1;
        end else begin
          if (RCSr.IsInPlannedUpdateFlag!=0) then begin
            if (RCSr.HansaVersion==APUr.ToHansaVersion) then begin
              qupdating.SetServerIsInPlannedUpdateFlag(RCSr.UUID,0);
              qupdating.SetServerRetainRecordDatesFlag(RCSr.UUID,0);
            end;
          end;
        end;
      end else begin
        if (RCSr.IsInPlannedUpdateFlag!=0) then begin
          qupdating.SetServerIsInPlannedUpdateFlag(RCSr.UUID,0);
          qupdating.SetServerRetainRecordDatesFlag(RCSr.UUID,0);
        end;
      end;
    end else begin
      if (RCSr.IsInPlannedUpdateFlag!=0) then begin
        RCSr.HansaVersion = RCSr.OldHansaVersion;
        testf = PlannedUpdateShouldTreatServer(APUr,RCSr,failuref);
        if (testf) then begin
          qupdating.SetServerIsInPlannedUpdateFlag(RCSr.UUID,0);
          qupdating.SetServerRetainRecordDatesFlag(RCSr.UUID,0);
        end;
      end;
    end;
  end;
  
LUpdatePlannedUpdateStatus:;
  UpdatePlannedUpdateStatus = res;
  return;
end;

procedure TreatOnePlannedUpdate(record ASPPlannedUpdatesVc APUr)
begin
  Boolean nextf,testf,failuref;
  record RemoteCloudServerVc RCSr,RCS2r;
  UUID blank_uuid,first_ongoing;
  record ASPPlannedUpdatesVc APU2r;
  LongInt ongoing_cnt,failed_cnt,total_cnt;

  if (ShouldTreatPlannedUpdate(APUr)==false) then begin
    goto LTreatOnePlannedUpdate;
  end;
  
  ongoing_cnt = UpdatePlannedUpdateStatus(APUr,total_cnt,failed_cnt,first_ongoing);
  RecordCopy(APU2r,APUr);
  APU2r.NumServersLeft = total_cnt;
  if (ongoing_cnt>0) then begin
    if (!BlankUUID(first_ongoing)) then begin
      APU2r.CurrentServer = first_ongoing;
      RCS2r.UUID = APU2r.CurrentServer;
      ReadFirstMain(RCS2r,1,true);
      APU2r.CurrentServerName = RCSName(RCS2r);
    end;
  end;

  if (ongoing_cnt<APU2r.MaxConcurrent) then begin
    RCSr.UUID = APU2r.CurrentServer;
    nextf = true;
    while (LoopMain(RCSr,1,nextf)) begin
      testf = PlannedUpdateShouldTreatServer(APU2r,RCSr,failuref);
      if (failuref) then begin
        AddFailedServerToPlannedUpdateIfNeeded(RCSr,APU2r);
      end;
      if (testf) then begin
        if (nextf==true) then begin
          nextf = StartOnePlannedUpdateIfNeeded(APU2r,RCSr,ongoing_cnt);
        end;
      end;
    end;

    if (APU2r.NumServersLeft==0) then begin
      APU2r.CurrentServer = blank_uuid;
      APU2r.CurrentServerName = "";
      APU2r.Completed = 1;
    end;
    APU2r.NumFailed = CountFailedServersInPlannedUpdate(APU2r);
    if (APU2r.NumTotal==-1) then begin
      APU2r.NumTotal = total_cnt;
    end;

    qupdating.UpdatePlanedUpdateRec(APU2r);
  end;

LTreatOnePlannedUpdate:;
  return;
end;

global
procedure TreatPlannedUpdates(string args)
begin
  record ASPPlannedUpdatesVc APUr;
  Boolean foundf;

  foundf = true;
  APUr.StartDate = CurrentDate;
  APUr.StartTime = CurrentTime;
  while (LoopBackKey("Completed",APUr,4,foundf)) begin
    if (APUr.Closed!=0) then begin foundf = false; end;
    if (APUr.Completed!=0) then begin foundf = false; end;
    if (foundf) then begin
      TreatOnePlannedUpdate(APUr);
    end;
  end;
  return;
end;

/* To use emergency node update, put the following 2 procedures
   in "emergencyupdate-halpatch/emergency_node_update.hal" on the
   Cloud Controller and use the "ASP>Cloud Nodes>Update Node to Version>Emergency halpatch update"
   function. This will cause the Cloud Node to restart with halpatch/emergency_node_update.hal in place
   and then initiate a call to EmergencyNodeUpdate(). You might want to include an empty stub for
   HttpAsyncDownloadHACallback() in the halpatch to avoid handling of versions downloaded on the node.
*/
global
procedure EmergencyNodeUpdate()
begin
  string 255 server,path;
  LongInt port;

  server = "downloads.hansaworld.com";
  port = 80;
  path = "/downloads/cloud_packages/STDERP_8.5-2019-03-26-0331-ASP.ha";
  
  LogText(0,"*** Cloud Node is initiating emergency node update ***");
  DeleteFolder("emergencyupdate");
  HttpAsyncDownloadHA(server,port,path,120,"emergencyupdate","EmergencyNodeUpdateDownloadHACallback");

  return;
end;

global
procedure EmergencyNodeUpdateDownloadHACallback(Boolean successf,LongInt httpres,Boolean timeout,string indir)
begin
  string 255 new_exename;

  LogText(0,"EmergencyNodeUpdateDownloadHACallback successf=" & successf & ", indir=" & indir);
  if (successf) then begin
    // Normal update
    //UpdateToVersionInFolder2(indir & "/newver",false,false);
    
    // Update by replacing the EXE only, avoiding any copy operations (only using moves)
    switch (ProgramPlatform) begin
      case kPlatformUnknown:    new_exename = "hansa-debug-optimized-server64";
      case kPlatformMac:        new_exename = "hansa-macosx-optimized-server";
      case kPlatformWindows32:  new_exename = "hansa-windows-optimized-server.exe";
      case kPlatformWindows64:  new_exename = "hansa-windows-optimized-server64.exe";
      case kPlatformLinux32:    new_exename = "hansa-debug-optimized-server";
      case kPlatformLinux64:    new_exename = "hansa-debug-optimized-server64";
      case kPlatformLinuxArm64: new_exename = "hansa-debug-optimized-serverarm64";
      otherwise
        new_exename = "hansa-debug-optimized-server64";
    end;

    Delete_file(CurExeName & ".emergencyupdate.old");
    RenameFile(CurExeName,CurExeName & ".emergencyupdate.old");
    RenameFile("emergencyupdate/newver/" & new_exename,CurExeName);
  end;
  
  DeleteFolder("halpatch"); // important
  
  QuitApplication(0,false);
  return;
end;


global
procedure DoOneEmergencyNodeUpdateThroughHalpatch(string cncode,Boolean skiphalpatchuploadf)
begin
  LongInt filecnt,i,fsz,pos,blocklen;
  string 255 url,halpatchpath,loc_halpatchpath,fpath,fname,remotefname;
  record CloudNodeVc CNr;
  area a_part;
  Integer stat;
  Integer retries;
  record RcVc RepSpec,ResRepSpec;
  Boolean scriptres;

  loc_halpatchpath = "emergencyupdate-halpatch";
  halpatchpath = "halpatch";
  CNr.Code = cncode;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    SetCloudControllerStatus(kJobStatusError,"Emergency node update skipped for node '" & cncode & "', node not found");
    LogText(0,"Emergency node update skipped for node '" & cncode & "', node not found");
    goto LDoOneEmergencyNodeUpdateThroughHalpatch;
  end;
  
  if (CNr.ReachableFlag==0) then begin
    SetCloudControllerStatus(kJobStatusError,"Emergency node update skipped for node '" & cncode & "', node unreachable");
    LogText(0,"Emergency node update skipped for node '" & cncode & "', node unreachable");
    goto LDoOneEmergencyNodeUpdateThroughHalpatch;
  end;
  
  url = NodeURL(CNr);
  if (blank(url)) then begin
    SetCloudControllerStatus(kJobStatusError,"Emergency node update skipped for node '" & cncode & "', node address not found");
    LogText(0,"Emergency node update skipped for node '" & cncode & "', node address not found");
    goto LDoOneEmergencyNodeUpdateThroughHalpatch;
  end;

  if (skiphalpatchuploadf) then begin
    stat = CallService(url).EmergencyNodeUpdate();
    if (TreatServiceError(stat,url,"EmergencyNodeUpdate")==false) then begin
      SetCloudControllerStatus(kJobStatusError,"Emergency node update: node '" & cncode & "', called emergency update function");
      LogText(0,"Emergency node update: node '" & cncode & "', called emergency update function");
      goto LDoOneEmergencyNodeUpdateThroughHalpatch;
    end;
  end;

  retries = 0;
  /* Here is a clever way to create empty files on all platforms. This code was written in
     a situation where the nodes was running an EXE that couldn't run any code that called
     F4Copy() without crashing, hence the trickery. This solution makes the call to
     ReceiveFilePart on the node work, because it will assume the file already exists and
     just write to it. We couldn't use ReceiveFilePart the way it was intended because then
     it would have created a temporary file and eventually made a call to CopyFile when
     finishing the file transfer... this way we don't need to call the Finish function, and
     thus we avoid the FileCopy operation.
  */
  LineTextPut2(RepSpec,LineTextCnt2(RepSpec),"mkdir " & halpatchpath & chr(10) & chr(13));
  LineTextPut2(RepSpec,LineTextCnt2(RepSpec),".>" & halpatchpath & "/emergency_node_update.hal" & chr(10) & chr(13));

LDoOneEmergencyNodeUpdateThroughHalpatch_RetryMkdir:;
  stat = CallService(url).RunScriptOnHost(CNr,RepSpec,ResRepSpec,scriptres);
  if (TreatServiceError(stat,url,"RunScriptOnHost")) then begin
    SetCloudControllerStatus(kJobStatusError,"Emergency node update: node '" & cncode & "', failed to create halpatch folder, retrying");
    LogText(0,"Emergency node update: node '" & cncode & "', failed to create halpatch folder, retrying");
    retries = retries + 1;
    Sleep(5);
    goto LDoOneEmergencyNodeUpdateThroughHalpatch_RetryMkdir;
  end;

  filecnt = CountFilesInDir(loc_halpatchpath);
  for (i = 0; i<filecnt; i = i + 1) begin
    fname = GetFileNameInDir(loc_halpatchpath,i);
    fpath = loc_halpatchpath & "/" & fname;
    if (FileExists(fpath)==false) then begin
      SetCloudControllerStatus(kJobStatusError,"Emergency node update: skipping halpatch subfolder " & fname);
      LogText(0,"Emergency node update: skipping halpatch subfolder " & fname);
    end else begin
      remotefname = halpatchpath & "/" & fname;
      fsz = FileSize(fpath);
      pos = 0;
      while (pos<fsz) begin
        blocklen = MIN(fsz - pos,5000000);
        LoadFileToArea(fpath,pos,blocklen,a_part);
        retries = 0;

LDoOneEmergencyNodeUpdateThroughHalpatch_Retry:
        stat = CallService(url).ReceiveFilePart(remotefname,fname,"",a_part);
        if (TreatServiceError(stat,url,"ReceiveFilePart")) then begin
          SetCloudControllerStatus(kJobStatusError,"Emergency node update: node '" & cncode & "', failed to send part " & i & ", retrying");
          LogText(0,"Emergency node update: node '" & cncode & "', failed to send part " & i & ", retrying");
          retries = retries + 1;
          Sleep(5);
          goto LDoOneEmergencyNodeUpdateThroughHalpatch_Retry;
        end else begin
          pos = pos + blocklen;
        end;
      end;
      /*
      if (pos>=fsz) then begin
        retries = 0;
LDoOneEmergencyNodeUpdateThroughHalpatch_RetryFinish:
        stat = CallService(url).FinishSendFileToLocalCloudServer(remotefname,fpath,false);
        if (TreatServiceError(stat,url,"FinishSendFileToLocalCloudServer")) then begin
          SetCloudControllerStatus(kJobStatusError,"Emergency node update: node '" & cncode & "', failed to finish transfer, retrying");
          LogText(0,"Emergency node update: node '" & cncode & "', failed to finish transfer, retrying");
          retries = retries + 1;
          Sleep(5);
          goto LDoOneEmergencyNodeUpdateThroughHalpatch_RetryFinish;
        end;
      end;
      */
    end;
  end;

  retries = 0;
LDoOneEmergencyNodeUpdateThroughHalpatch_RetryRestart:;
  stat = CallService(url).RestartCloudNodeOnNode();
  if (TreatServiceError(stat,url,"RestartCloudNodeOnNode")) then begin
    SetCloudControllerStatus(kJobStatusError,"Emergency node update: node '" & cncode & "', failed to restart, retrying");
    LogText(0,"Emergency node update: node '" & cncode & "', failed to restart, retrying");
    retries = retries + 1;
    Sleep(5);
    if (retries<2) then begin // if we failed to restart it 5 times, we'll try to initiate node update anyway
      goto LDoOneEmergencyNodeUpdateThroughHalpatch_RetryRestart;
    end;
  end;
  
  Sleep(30);

  retries = 0;
LDoOneEmergencyNodeUpdateThroughHalpatch_RetryUpdate:;
  stat = CallService(url).EmergencyNodeUpdate();
  if (TreatServiceError(stat,url,"EmergencyNodeUpdate")) then begin
    SetCloudControllerStatus(kJobStatusError,"Emergency node update: node '" & cncode & "', failed to call emergency update function, retrying...");
    LogText(0,"Emergency node update: node '" & cncode & "', failed to call emergency update function, retrying...");
    retries = retries + 1;
    Sleep(5);
    if (retries<2) then begin // if we fail 5 times, we'll try to initiate node update anyway
      goto LDoOneEmergencyNodeUpdateThroughHalpatch_RetryUpdate;
    end;
  end;

LDoOneEmergencyNodeUpdateThroughHalpatch:;
  return;
end;

global
procedure EmergencyNodeUpdateThroughHalpatch(array string cncode_arr,Boolean skiphalpatchuploadf)
begin
  LongInt l,filecnt;
  string 255 loc_halpatchpath;
  
  loc_halpatchpath = "emergencyupdate-halpatch";
  if (DirExists(loc_halpatchpath)==false) then begin
    SetCloudControllerStatus(kJobStatusError,"Emergency node update through halpatch can't start, " & loc_halpatchpath & " missing on Cloud Controller");
    LogText(0,"Emergency node update through halpatch can't start, " & loc_halpatchpath & " missing on Cloud Controller");
    goto LEmergencyNodeUpdateThroughHalpatch;
  end;
  
  filecnt = CountFilesInDir(loc_halpatchpath);
  if (filecnt<=0) then begin
    SetCloudControllerStatus(kJobStatusError,"Emergency node update through halpatch can't start, " & loc_halpatchpath & " is empty on Cloud Controller");
    LogText(0,"Emergency node update through halpatch can't start, " & loc_halpatchpath & " is empty on Cloud Controller");
    goto LEmergencyNodeUpdateThroughHalpatch;
  end;

  for (l = 0; l<cncode_arr.length; l = l + 1) begin
    SetCloudControllerStatus(kJobStatusRunning,"Starting emergency node update on node '" & cncode_arr[l] & "'...");
    LogText(0,"Starting emergency node update on node '" & cncode_arr[l] & "'...");
    DoOneEmergencyNodeUpdateThroughHalpatch(cncode_arr[l],skiphalpatchuploadf);
    SetCloudControllerStatus(kJobStatusFinished,"Finished emergency node update on node '" & cncode_arr[l] & "'");
    LogText(0,"Finished emergency node update on node '" & cncode_arr[l] & "'");
  end;
LEmergencyNodeUpdateThroughHalpatch:;
  return;
end;


