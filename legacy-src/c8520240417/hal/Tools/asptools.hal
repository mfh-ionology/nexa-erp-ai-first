  LCSr.SSLPrivKeyPassword = RCSr.SSLPrivKeyPassword;

  CopyRCSRowsToLCS(RCSr,LCSr);
  return;
end;

function string 255 LCSAsteriskControllerKey(record LocalCloudServerVc LCSr)
begin
  string 255 key;
  Integer i,rwcnt;
  row LocalCloudServerVc LCSrw;

  rwcnt = MatRowCnt(LCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(LCSr,i,LCSrw);
    if (LCSrw.Item==kManagedServerItemAsteriskControllerKey and LCSrw.Disabled==0) then begin
      key = LCSrw.Data;
      goto LLCSAsteriskControllerKey;
    end;
  end;

LLCSAsteriskControllerKey:;
  LCSAsteriskControllerKey = key;
  return;
end;

function string 255 LCSAsteriskControllerAddr(record LocalCloudServerVc LCSr)
begin
  string 255 addr;
  Integer i,rwcnt;
  row LocalCloudServerVc LCSrw;

  rwcnt = MatRowCnt(LCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(LCSr,i,LCSrw);
    if (LCSrw.Item==kManagedServerItemAsteriskControllerKey and LCSrw.Disabled==0) then begin
      addr = LCSrw.Desc;
      goto LLCSAsteriskControllerAddr;
    end;
  end;

LLCSAsteriskControllerAddr:;
  LCSAsteriskControllerAddr = addr;
  return;
end;

procedure UnsetLCSAsteriskControllerKey(var record LocalCloudServerVc LCSr)
begin
  UUID res;
  Integer i,rwcnt;
  row LocalCloudServerVc LCSrw;

  rwcnt = MatRowCnt(LCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(LCSr,i,LCSrw);
    if (LCSrw.Item==kManagedServerItemAsteriskControllerKey and LCSrw.Disabled==0) then begin
      LCSrw.Disabled = 1;
      MatRowPut(LCSr,i,LCSrw);
      goto LUnsetLCSAsteriskControllerKey;
    end;
  end;

LUnsetLCSAsteriskControllerKey:;
  return;
end;

function string 255 RCSAsteriskControllerKey(record RemoteCloudServerVc RCSr)
begin
  string 255 key;
  Integer i,rwcnt;
  row RemoteCloudServerVc RCSrw;

  rwcnt = MatRowCnt(RCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(RCSr,i,RCSrw);
    if (RCSrw.Item==kManagedServerItemAsteriskControllerKey and RCSrw.Disabled==0) then begin
      key = RCSrw.Data;
      goto LRCSAsteriskControllerKey;
    end;
  end;

LRCSAsteriskControllerKey:;
  RCSAsteriskControllerKey = key;
  return;
end;

procedure SetRCSAsteriskControllerKeyAndAddr(var record RemoteCloudServerVc RCSr,string key,string addr)
begin
  UUID res;
  Integer i,rwcnt;
  row RemoteCloudServerVc RCSrw;
  LongInt rown;

  rwcnt = MatRowCnt(RCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(RCSr,i,RCSrw);
    if (RCSrw.Item==kManagedServerItemAsteriskControllerKey and RCSrw.Disabled==0) then begin
      rown = i;
      goto LSetRCSAsteriskControllerKeyAndAddr_set;
    end;
  end;

LSetRCSAsteriskControllerKeyAndAddr_set:;
  if (rown<0) then begin rown = MatRowCnt(RCSr); end;
  ClearRow(RCSr,RCSrw,1);
  RCSrw.Item = kManagedServerItemAsteriskControllerKey;
  RCSrw.Data = key;
  RCSrw.Desc = addr;
  MatRowPut(RCSr,rown,RCSrw);

  return;
end;

global
function string 255 NodeURL(record CloudNodeVc CNr)
begin
  string 255 res;
  record CloudSettingsBlock CSb;

  BlockLoad(CSb);

  if (CNr.PollingFlag!=0) then begin
    res = "#" & HMACSHA1String(CSb.APIKey,CNr.Code) & ":" & CNr.Code;
  end else begin
    if ((CNr.SSLPort>0) and nonblank(CNr.HostName)) then begin
      res = CNr.HostName & ":" & CNr.SSLPort;
    end;
  end;
  
  NodeURL = res;
  return;
end;

global
function string 255 ReadNodeURL(var record CloudNodeVc CNr)
begin
  string 255 res;

  if (ReadFirstMain(CNr,1,true)) then begin
    if (CNr.Closed==0) then begin // We don't talk to closed CN:s
      res = NodeURL(CNr);
    end;
  end;

  ReadNodeURL = res;
  return;
end;

global
function string 255 RcsNodeURL(record RemoteCloudServerVc RCSr)
begin
  record CloudNodeVc CNr;
  string 255 res;

  CNr.Code = RCSr.Controller;
  
  if (ReadFirstMain(CNr,1,true)) then begin
    if (CNr.Closed==0) then begin // We don't talk to closed CN:s
      res = NodeURL(CNr);
    end;
  end;

  RcsNodeURL = res;
  return;
end;

global
function string 255 ServersFolder()
begin
  record CloudSettingsBlock CSb;
  string 255 res;
  
  BlockLoad(CSb);
  
  if (CSb.ServersFolder<>"") then begin
    res = CSb.ServersFolder;
    if (right(res,1)<>"/") then begin
      res = res & "/";
    end;
  end else begin
    res = "/Servers/";
  end;
  
  ServersFolder = res;
  return;
end;

global
function string 255 VersionsFolder()
begin
  record CloudSettingsBlock CSb;
  string 255 res,tstr;
  
  BlockLoad(CSb);
  
  if (CSb.VersionsFolder<>"") then begin
    res = CSb.VersionsFolder;
    if (right(res,1)<>"/") then begin
      res = res & "/";
    end;
  end else begin
    res = ServersFolder & "/Versions/";
  end;
  
  if ((left(res,1)!="/") and (left(res,1)!="\\") and (mid(res,1,2)!=":\\")) then begin
    tstr = ProgramFolder & "/" & res;
    res = tstr;
  end;

  VersionsFolder = res;
  return;
end;

global
function Boolean GetVersion(string vercode,var record HansaVersionVc HVr)
begin
  Boolean res;

  if (blank(vercode)) then begin goto LGetVersion; end;

  HVr.Code = vercode;
  if (ReadFirstMain(HVr,1,true)==false) then begin goto LGetVersion; end;

  if (CheckVersion(HVr)==true) then begin
    res = true;
    goto LGetVersion;
  end;
  
  if (HVr.CurrentState==kHansaVersionStateError) then begin // *possibly* this one should be in CheckVersion()
    LogText(0,"GetVersion(\"" & HVr.Code & "\") failed, version is in error state");
    goto LGetVersion;
  end;

  // The following must *not* be in CheckVersion()
  if (HVr.CurrentState==kHansaVersionStateNotDownloaded) then begin
    if (IsDownloadingVersion(vercode)==false and
        ShouldDownloadVersion(vercode)==false and
        HVr.CurrentState!=kHansaVersionStateInstalling and
        HVr.CurrentState!=kHansaVersionStateUpdating) then begin
      LogText(0,"GetVersion(\"" & vercode & "\") failed, version is not being downloaded");
    end;
    goto LGetVersion;
  end;

  if (HVr.CurrentState==kHansaVersionStateInstalling) then begin goto LGetVersion; end;
  if (HVr.CurrentState==kHansaVersionStateUpdating) then begin goto LGetVersion; end;

  if (IsDownloadingVersion(vercode)==false and
      ShouldDownloadVersion(vercode)==false and
      HVr.CurrentState!=kHansaVersionStateInstalling and
      HVr.CurrentState!=kHansaVersionStateUpdating) then begin
    LogText2(0,"GetVersion(\"" & vercode & "\") failed, CheckVersion failed",kVerbosityDebugDetailed);
    goto LGetVersion;
  end;

LGetVersion:;
  GetVersion = res;
  return;
end;

global
procedure GetHansaVersionAtCN(var record HansaVersionVc HVr,var Boolean canbeupdatedf)
begin
  record HansaVersionVc HV2r;

  canbeupdatedf = false;
  RecordCopy(HV2r,HVr);

  if (ReadFirstMain(HVr,1,true)) then begin
    if ((HV2r.Name==HVr.Name) and
        (HV2r.Version==HVr.Version) and
        (HV2r.SubVersion==HVr.SubVersion) and
        (HV2r.RunningBuild==HVr.RunningBuild) and
        (HV2r.ProgramType==HVr.ProgramType) and
        (HV2r.ProductCode==HVr.ProductCode)) then begin
      canbeupdatedf = true;
    end;
  end;
end;

global
function string 255 DatabaseName(LongInt progtype)
begin
  string 255 res;
  
  switch (progtype) begin
    case typHansaRaama:         res = "RAAMA.HDB";
    case typFirstOffice:        res = "1OFFICE.HDB";
    case typFirstOfficePro:     res = "1OFFICE.HDB";
    case typFirstOfficeSmall:   res = "1OFFICE.HDB";
    case typFirstOfficeASP:     res = "1OFFICE.HDB";
    case typOffice2:            res = "OFFICE2.HDB";
    case typOffice2TB:          res = "OFFICE2.HDB";
    case typFirstContact:       res = "1CONTACT.HDB";
    case typOffLine:            res = "OffLine.HDB";
    otherwise                   res = "HANSA.HDB";
  end;
  
  DatabaseName = res;
  return;
end;

