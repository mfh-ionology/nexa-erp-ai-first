  LogText(0,"CheckHansaVersionsFull no. versions: " & CountRecords("HansaVersionVc"));
  DownloadNewVersionsForCx(true,true);

  //SemaphorePost("DownloadVersions");
  return;
end;

global
updating procedure PeriodicASPEventsCleanup(string args)
begin
  record ASPEventsVc AEr;
  date td;
  Boolean foundf;
  Integer months;
  LongInt cnt,maxcnt;
  Date blankd;
  record CloudSettingsBlock CSb;
  
  BlockLoad(CSb);
  maxcnt = CSb.PeriodicRecordDeleteMax;
  if (maxcnt<0) then begin
    maxcnt = 50;
  end;

  if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LPeriodicASPEventsCleanup; end;

  months = 12;
  cnt = 0;
  td = AddMonth(CurrentDate,-months);
  AEr.TransDate = blankd;
  foundf = true;

  DBHold;
  while (LoopKey("TransDate",AEr,1,foundf)) begin
    if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin
      DBFlush;
      goto LPeriodicASPEventsCleanup;
    end;
    if (cnt>=maxcnt) begin
      DBFlush;
      goto LPeriodicASPEventsCleanup;
    end;
    if (AEr.TransDate>td) then begin foundf = false; end;
    if (foundf) then begin
      RecordDelete(AEr);
      StepBack(AEr);
      cnt = cnt + 1;
    end;
  end;
  DBFlush;

LPeriodicASPEventsCleanup:;
  if (cnt>0) then begin
    LogText(0,"Deleted " & cnt & " ASP events older than " & months & " months");
  end;
  return;
end;

global
updating procedure PeriodicNodeStatsCleanup(string args)
begin
  record CloudMachineStatsVc CMSr;
  date td;
  Boolean foundf;
  Integer months;
  LongInt cnt;
  Date blankd;

  if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LPeriodicNodeStatsCleanup; end;

  LogText(0,"Cleaning cloud node statistics");

  months = 3;
  cnt = 0;
  td = AddMonth(CurrentDate,-months);
  CMSr.Date = blankd;
  foundf = true;

  LogText(0,"Deleting node statistics older than " & months & " months");
  DBHold;
  while (LoopKey("Date",CMSr,1,foundf)) begin
    if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin
      DBFlush;
      goto LPeriodicNodeStatsCleanup;
    end;
    if (CMSr.Date>td) then begin foundf = false; end;
    if (foundf) then begin
      RecordDelete(CMSr);
      StepBack(CMSr);
      cnt = cnt + 1;
    end;
  end;
  DBFlush;

  LogText(0,"Finished, deleted " & cnt & " cloud node statistics records");

LPeriodicNodeStatsCleanup:;
  return;
end;

global
updating procedure DoRemoveNodesStats(Boolean allf)
begin
  record CloudMachineStatsVc CMSr;
  record CloudNodeVc CNr;
  Boolean deletef;
  LongInt i;

  if (allf) then begin
    LogText(0,"Deleting all node statistics");
  end else begin
    LogText(0,"Deleting node statistics for closed and deleted nodes");
  end;

  DBHold;
  i = 0;
  while (LoopMain(CMSr,1,true)) begin
    deletef = true;

    if (allf==false) then begin
      CNr.Code = CMSr.ServerCode;
      if (ReadFirstMain(CNr,1,true)) then begin
        if (CNr.Closed==0) then begin deletef = false; end;
      end;
    end;

    if (deletef==true) then begin
      RecordDelete(CMSr);
      StepBack(CMSr);
      i = i + 1;
    end;
  end;
  DBFlush;

  LogText(0,"Done, " & i & " node statistics records deleted");

  return;
end;

global
updating procedure StartRemoveNodesStats(Boolean allf)
begin
  queued.DoRemoveNodesStats(allf);
  return;
end;

global
updating procedure DoDownloadVersion(record HansaVersionVc HVr,Boolean updatef)
begin
  transaction Boolean update_after_download;
  transaction string 255 version_to_download;
  record HansaVersionVc HV2r;
  record HansaVersionVc OldHV2r;

  version_to_download = HVr.Code;
  update_after_download = updatef;

  HV2r.Code = HVr.Code;
  if (ReadFirstMain(HV2r,1,true)==true) then begin
    if (HV2r.CurrentState==kHansaVersionStateUnavailable and
        HVr.AdditionalPlatform!=kPlatformLinux64 and
        ProgramPlatform!=HVr.AdditionalPlatform) then begin
      goto LDoDownloadVersion;
    end;
    RecordCopy(OldHV2r,HV2r);
    HV2r.ForceReplaceVersionf = HVr.ForceReplaceVersionf;
    HV2r.AdditionalPlatform = HVr.AdditionalPlatform;
    RecordUpdate(OldHV2r,HV2r,true);
  end;
  
  SetShouldDownloadVersion(version_to_download,true);
  if (IsDownloadingVersion(version_to_download) or IsDownloadingVersion("AllVersionsTag")) then begin
    LogText2(0,"Skipping downloading of " & version_to_download & " because a download of that version already is in progress",kVerbosityDebugDetailed);
    LogText2(0,"IsDownloadingVersion(version_to_download)=" & IsDownloadingVersion(version_to_download),kVerbosityDebugDetailed);
    LogText2(0,"IsDownloadingVersion(""AllVersionsTag"")=" & IsDownloadingVersion("AllVersionsTag"),kVerbosityDebugDetailed);
    goto LDoDownloadVersion;
  end;
  
  if (updatef) then begin
    SetCloudControllerStatus(kJobStatusRunning,"Downloading version " & HVr.Code & " for Cloud Controller update");
  end;
  
  DownloadNewVersionsForCx(true,false);

LDoDownloadVersion:;
  return;
end;

global
updating procedure DoUpdateServersOnVersion(string vercode,LongInt hvut)
begin
  record HansaVersionVc HVr;
  record HansaVersionVc OldHVr;

  HVr.Code = vercode;
  if (ReadFirstMain(HVr,1,true)==true) then begin
    RecordCopy(OldHVr,HVr);
    HVr.ForceReplaceVersionf = 1;
    RecordUpdate(OldHVr,HVr,true);
    DoDownloadVersion(HVr,false);
  end;
  return;
end;

global
updating procedure UpdateServersOnVersion(string vercode,LongInt hvut)
begin
  record RemoteCloudServerVc RCSr,OldRCSr;
  record HansaVersionVc HVr;
  record CloudNodeVc CNr;
  array string 255 cnarr;
  LongInt i,j;
  Boolean testf;
  string 255 url;
  LongInt stat;
  Boolean scfailf;

  HVr.Code = vercode;
  if (ReadFirstMain(HVr,1,true)) then begin
    i = 0;
    while (LoopMain(RCSr,0,true)) begin
      if (RCSr.Closed==0) then begin
        if ((RCSr.HansaVersion==HVr.Code) or (RCSr.NewHansaVersion==HVr.Code)) then begin
          if (RCSr.WantedStatus==kWantedStatusRun) then begin
            RecordCopy(OldRCSr,RCSr);
            RCSr.WantedStatus = kWantedStatusStopAndRefresh;
            RecordUpdate(OldRCSr,RCSr,true);
          end;
          j = 0;
          testf = false;
          for (j = 0; j<cnarr.length; j = j + 1) begin
            if (cnarr[i]==RCSr.Controller) then begin
              testf = true;
            end;
          end;
          if (testf==false) then begin
            cnarr[i] = RCSr.Controller;
            i = i + 1;
          end;
        end;
      end;
    end;
  end;

  if (i>0) then begin
    LogText(0,"Attempting to refresh all cloud servers on version " & vercode);
  end;

  for (i = 0; i <cnarr.length; i = i + 1) begin
    CNr.Code = cnarr[i];
    url = ReadNodeURL(CNr);
    stat = CallService(url).DoUpdateServersOnVersion(vercode,hvut);
    scfailf = TreatServiceError(stat,url,"DoUpdateServersOnVersion");
    queued.SaveCloudNodeReachable(CNr.Code,!scfailf);
    if (scfailf) then begin
      LogText(0,"Failed to update servers on version on CN " & CNr.Code);
      goto LUpdateServersOnVersion;
    end;
  end;

LUpdateServersOnVersion:;
end;

global
procedure DownloadVersion(record HansaVersionVc HVr)
begin
  queued.DoDownloadVersion(HVr,false);
  return;
end;

procedure DeleteCoreFiles()
begin
  Boolean res;
  string 255 filename;
  Integer cnt,i,j;

  if (WindowsMode) then begin goto LDeleteCoreFiles; end;

  cnt = CountFilesInDir(".");
  for (i = cnt; i>0; i = i - 1) begin
    filename = GetFileNameInDir(".",i-1);
    if ((left(filename,5)=="core.") or (left(filename,5)=="core-")) then begin
      Delete_File(filename);
      j = j + 1;
    end;
  end;

  if (j>0) then begin
    LogText(0,"Deleted " & j & " core files");
  end;

LDeleteCoreFiles:;
  return;
end;

function Boolean IsServerSpaceCriticallyLow(var Boolean loggedf)
begin
  LongInt freespace,totalspace;
  Boolean res;
  
  if (DirExists("/Servers")) then begin
    freespace = GetDiskSpace("/Servers",totalspace); // TBD: other server folder locations. This will work for all that we are hosting ourselves though.
  end else begin
    freespace = GetDiskSpace("/",totalspace); // TBD: other server folder locations. This will work for all that we are hosting ourselves though.
  end;
  
  if (freespace!=-1) then begin
    if (freespace<10000) then begin // 10G, we're being aggressive
      res = true;
      if (loggedf==false) then begin
        LogText(0,"*** Available space in /Servers is critically low (below 10G): " & freespace & "M ***");
        loggedf = true;
      end;
    end;
  end else begin
    LogText(0,"ERROR: Failed to get free disk space for folder /Servers, return value of GetDiskSpace() was " & freespace);
  end;
  
  IsServerSpaceCriticallyLow = res;
  return;
end;

procedure DeleteOldverFolders()
begin
  Boolean res,criticalf,loggedf;
  string 255 foldername;
  Integer cnt,idx,j;

  if (WindowsMode) then begin goto LDeleteOldverFolders; end;
  
  criticalf = IsServerSpaceCriticallyLow(loggedf);
  if (!criticalf) then begin goto LDeleteOldverFolders; end;
  
  LogText2(0,"*** Starting to clean old autoupdate folders ***",kVerbosityDebug);

  cnt = CountDirectoriesInDir(".");
  for (idx = cnt; idx>0; idx = idx - 1) begin
    foldername = GetDirectoryNameInDir(".",idx-1);
    if (left(foldername,7)=="oldver.") then begin
      DeleteFolder(foldername);
      j = j + 1;
    end;
  end;
  
  criticalf = IsServerSpaceCriticallyLow(loggedf);
  if (!criticalf) then begin goto LDeleteOldverFolders; end;

  cnt = CountDirectoriesInDir(".");
  for (idx = cnt; idx>0; idx = idx - 1) begin
    foldername = GetDirectoryNameInDir(".",idx-1);
    if (left(foldername,6)=="oldver") then begin
      DeleteFolder(foldername);
      j = j + 1;
    end;
  end;

LDeleteOldverFolders:;
  if (j>0) then begin
    LogText(0,"Deleted " & j & " old autoupdate folders");
  end;
  LogText2(0,"*** Finished cleaning old autoupdate folders ***",kVerbosityDebug);
  return;
end;

updating procedure FixupNodeLogs()
begin
  Boolean res;
  string 255 filename;
  Integer cnt,i;

  if (WindowsMode) then begin goto LFixupNodeLogs; end;
  if (DirExists("node_logs")) then begin goto LFixupNodeLogs; end;
  
  CreateFolder("node_logs");
  
  cnt = CountFilesInDir(".");
  for (i = cnt; i>0; i = i - 1) begin
    filename = GetFileNameInDir(".",i-1);
    if ((left(filename,5)=="node_") and (right(filename,4)==".log")) then begin
      MoveFile(filename,".","node_logs");
    end;
  end;

LFixupNodeLogs:;
  return;
end;

global
updating procedure DoUpdateToVersionQueued(record HansaVersionVc HV2r)
begin
  Boolean downloadf,waitf;
  LongInt new_version_build,dbver;
  record HansaVersionVc HVr;

  HVr.Code = HV2r.Code;
  if (ReadFirstMain(HVr,1,true)==false) then begin
    LogText(0,"DoUpdateToVersionQueued failed, version doesn't exist: " & HV2r.Code);
    goto LDoUpdateToVersionQueued;
  end;

  downloadf = false;
  waitf = false;

  switch (HVr.CurrentState) begin
    case kHansaVersionStateUnknown:         waitf = true;
    case kHansaVersionStateNotDownloaded:   downloadf = true;
    case kHansaVersionStateOld:             downloadf = true;
    case kHansaVersionStateUpdating:        goto LDoUpdateToVersionQueued;
    case kHansaVersionStateInstalling:      goto LDoUpdateToVersionQueued;
  end;

  if (waitf==true) then begin
    LogText(0,"DoUpdateToVersionQueued waitf==true");
    queued.DoUpdateToVersionQueued(HVr);
    goto LDoUpdateToVersionQueued;
  end;

  if (downloadf==true) then begin
    HVr.ForceReplaceVersionf = 1;
    DoDownloadVersion(HVr,true);
    goto LDoUpdateToVersionQueued;
  end;

  if (CheckVersion(HVr)==true) then begin
    new_version_build = (HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild;
    dbver = (HVr.Version * 100) + HVr.SubVersion;
//    if (new_version_build>VersionBuild) then begin
      SetCloudControllerStatus(kJobStatusRunning,"Starting Cloud Controller update to version " & HVr.Code);
      LogText(0,"Starting update to version " & HVr.Code);
//      Delete_File("EnRetryNodeUpdate"); // what is this for? it breaks the automated process of restarting failed updates
      PauseASPIdleTasks;
      DeleteCoreFiles;
      DeleteOldverFolders;
      if (IsCloudNode or (new_version_build==85550411) or (new_version_build==85550412)) then begin // always rebuild cloud node hdb, it's small anyway
        UpdateToVersionInFolder2(HVr.ProgramFolder,false,true);
      end else begin
        if (dbver!=kProtocolVersion) then begin
          UpdateToVersionInFolder2(HVr.ProgramFolder,false,true);
        end else begin
          UpdateToVersionInFolder2(HVr.ProgramFolder,false,false);
        end;
      end;
//    end else begin
//      SetCloudControllerStatus(kJobStatusWarning,"Cloud Controller update cancelled, no new version is available (latest version is " & new_version_build & ", running version is " & VersionBuild);
//      LogText(0,"Skipping update to " & HVr.Code & " because version " & VersionBuild & ">=" & new_version_build);
//      Delete_File("EnRetryNodeUpdate");
//      SetGlobalBoolean("ASPIdleTasksStopped",false);
//    end;
  end else begin
    LogText(0,"Failed to update to version " & HVr.Code);
    if (IsDownloadingVersion(HVr.Code)==false) then begin
      SetShouldDownloadVersion(HVr.Code,true);
      threadasync.CheckHansaVersionsQuick("");
    end;
  end;

LDoUpdateToVersionQueued:;
  SetGlobalBoolean("ASPIdleTasksStopped",false);
  return;
end;

global
updating procedure DoUpdateToVersion(record HansaVersionVc HVr)
begin
  record HansaVersionVc HV2r;
  Boolean canbeupdatedf;
  record CloudSettingsBlock CSb;
  Date sd;
  Time st;
  Integer update_timeout_hrs;

  update_timeout_hrs = 4;
  if (IsCloudController) then begin
    update_timeout_hrs = 20;
  end;
  
  BlockLoad(CSb);
  RecordCopy(HV2r,HVr);
  GetHansaVersionAtCN(HV2r,canbeupdatedf);
  if (canbeupdatedf) then begin
    CSb.HansaVersion = HVr.Code; //??
    CSb.NewHansaVersion = "";
    BlockStore(CSb);
    LogText(0,"Requesting update to version " & HVr.Code);
    queued.DoUpdateToVersionQueued(HVr);
  end else begin
    LogText(0,"Requesting download of version " & HVr.Code & " for update");
    CSb.NewHansaVersion = HVr.Code;
    BlockStore(CSb);
    HVr.ForceReplaceVersionf = 1;
    DoDownloadVersion(HVr,true);
  end;

  if (TaskExists("RetryUpdateNodeToVersion")==false) then begin
    Delete_File("EnRetryNodeUpdate");
    WriteStringToFile(HVr.Code,"EnRetryNodeUpdate",0);

    sd = CurrentDate;
    st = AddMinutes(CurrentTime,60*update_timeout_hrs);
    if (st<CurrentTime) then begin sd = AddDay(sd,1); end;

    LogText(0,"*** Scheduled restart to retry update to version " & HVr.Code & " in " & update_timeout_hrs & " hours ***");
    //RemoveTask("RetryUpdateNodeToVersion");
    NewTimedTask("RetryUpdateNodeToVersion","RetryUpdateNodeToVersion","RetryUpdateNodeToVersionTask",HVr.Code,sd,st,"","");
  end;

LDoUpdateToVersion:;
  return;
end;

global
updating procedure RetryUpdateNodeToVersionTask(string arg)
begin
  Date sd;
  Time st;

  if (blank(arg)) then begin
    LogText(0,"ERROR: RetryUpdateNodeToVersionTask called with blank argument");
    goto LRetryUpdateNodeToVersionTask;
  end;

//  if (IsDownloadingVersion(arg)) then begin
//    sd = CurrentDate;
//    st = AddMinutes(CurrentTime,30);
//    if (st<CurrentTime) then begin sd = AddDay(sd,1); end;
//    NewTimedTask("RetryUpdateNodeToVersion","RetryUpdateNodeToVersion","RetryUpdateNodeToVersionTask",arg,sd,st,"","");
//    goto LRetryUpdateNodeToVersionTask;
//  end;

  LogText(0,"*** Update not completed, restarting and retrying update to version " & arg & " ***");
  QuitApplication(0,false);

LRetryUpdateNodeToVersionTask:;
  return;
end;

procedure RetryNodeUpdate()
begin
  string 255 tstr;
  record HansaVersionVc HVr;
  LongInt new_version_build;
  LongInt cur_version_build;

  if (FileExists("EnRetryNodeUpdate")) then begin
    tstr = Trim(ReadStringFromFile("EnRetryNodeUpdate"));
    Delete_File("EnRetryNodeUpdate");
    HVr.Code = tstr;
    if (ReadFirstMain(HVr,1,true)!=true) then begin
      HVr.Code = tstr;
    end else begin
      cur_version_build = (kProtocolVersion * 10000) + RunningBuild;
      new_version_build = (HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild;
      if (cur_version_build==new_version_build) then begin
        LogText(0,"The system was updated to version " & tstr);
        goto LRetryNodeUpdate;
      end;
    end;
    LogText(0,"Attempting version update to " & tstr);
    queued.DoUpdateToVersion(HVr);
  end;
  
LRetryNodeUpdate:;
  return;
end;

global
procedure UpdateToVersion(record HansaVersionVc HVr)
begin
  queued.DoUpdateToVersion(HVr);
  return;
end;

global
updating procedure UpdateToVersion_WTF(record HansaVersionVc HVr)
begin
  queued.UpdateToVersion(HVr);
  return;
end;

global
updating procedure SetCloudNodeState(string cncode,Boolean fastcheckf,Boolean reachablef,Integer state)
begin
  record CloudNodeVc CNr;
  record CloudNodeVc OldCNr;
  Integer fastcheck,reachable;

  if (fastcheckf) then begin
    fastcheck = 1;
  end;
  if (reachablef) then begin
    reachable = 1;
  end;

  CNr.Code = cncode;
  if (ReadFirstMain(CNr,1,true)) then begin
    RecordCopy(OldCNr,CNr);
    if (state!=kCloudNodeStateUnknown) then begin
      CNr.CurrentState = state;
    end;
    CNr.FastCheckFlag = fastcheck;
    CNr.ReachableFlag = reachable;
    RecordUpdate(OldCNr,CNr,true);
  end;
end;

global
procedure UpdateNodeToNewVersion(record CloudNodeVc CNr)
begin
  string 255 url;
  LongInt stat;
  record HansaVersionVc HVr;
  Boolean retval;
  string 255 archive;
  LongInt new_version_build;
  Boolean scfailf;

  HVr.Code = CNr.NewHansaVersion;
  url = NodeURL(CNr);

  if (ReadFirstMain(HVr,1,true)==false) then begin
    LogText(0,"Failed to update CN " & CNr.Code & " to version " & HVr.Code & ", because the version doesn't exist");
    goto LUpdateNodeToNewVersion;
  end;

  if (ReadFirstMain(CNr,1,true)) then begin end;

  new_version_build = (HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild;
  LogText(0,"Updating CN " & CNr.Code & " to version " & HVr.Code & " build " & new_version_build);
  stat = CallService(url).UpdateToVersion(HVr);
  scfailf = TreatServiceError(stat,url,"UpdateToVersion");
  qupdating.SaveCloudNodeReachable(CNr.Code,!scfailf);
  if (scfailf) then begin
    LogText(0,"Failed to update CN " & CNr.Code & " to version " & HVr.Code");
    goto LUpdateNodeToNewVersion;
  end;

LUpdateNodeToNewVersion:;
  return;
end;

global
updating procedure DownloadVersionOnAllNodes(record HansaVersionVc HVr)
begin
  record CloudNodeVc CNr;
  string 255 url;
  LongInt stat;
  record HansaVersionVc HV2r;
  record HansaVersionVc OldHV2r;
  Boolean scfailf;

  while (LoopMain(CNr,1,true)) begin
    if (CNr.Closed==0) then begin
      url = NodeURL(CNr);
      stat = CallService(url).DownloadVersion(HVr);
      scfailf = TreatServiceError(stat,url,"DownloadVersion");
      queued.SaveCloudNodeReachable(CNr.Code,!scfailf);
      if (scfailf) then begin
        LogText(0,"Failed to make CN " & CNr.Code & " download version " & HVr.Code");
        goto LDownloadVersionOnAllNodes;
      end;
    end;
  end;

  HV2r.Code = HVr.Code;
  if (ReadFirstMain(HV2r,1,true)==true) then begin
    RecordCopy(OldHV2r,HV2r);
    HV2r.ForceReplaceVersionf = 0;
    RecordUpdate(OldHV2r,HV2r,true);
  end;

LDownloadVersionOnAllNodes:;
  return;
end;

global
updating procedure UpdateAllNodesToVersion(record HansaVersionVc HVr)
begin
  record CloudNodeVc CNr;
  record CloudNodeVc OldCNr;
  record CloudSettingsBlock CSb;
  LongInt new_version_build;

  new_version_build = (HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild;
  LogText(0,"Updating all CN:s to " & HVr.Code & " (" & new_version_build & ")");
  while (LoopMain(CNr,1,true)) begin
    if ((CNr.Closed==0) and (CloudNodeStatus(CNr)!=kCloudNodeStatusUnreachable)) then begin
      RecordCopy(OldCNr,CNr);
      if (new_version_build>CNr.VersionBuild) then begin
        CNr.NewHansaVersion = HVr.Code;
        CNr.FastCheckFlag = 1;
        CNr.CurrentState = kCloudNodeStateUpdating;
        CNr.LastUpdateFailedFlag = 0;
        RecordUpdate(OldCNr,CNr,true);
        threadasync.UpdateNodeToNewVersion(CNr);
      end else begin
        LogText(0,"Skipping updating CN " & CNr.Code & " to " & HVr.Code & " because CN version " & CNr.VersionBuild & ">=" & new_version_build);
      end;
    end else begin
      if (CNr.Closed==0) then begin
        LogText(0,"Skipping updating CN " & CNr.Code & " to " & HVr.Code & " because CN is unreachable");
      end;
    end;
  end;

  BlockLoad(CSb);
  CSb.UpdateNodesFlag = 0;
  BlockStore(CSb);

  return;
end;

global
updating procedure UpdateCloudToVersion(record HansaVersionVc HVr)
begin
  record CloudSettingsBlock CSb;

  BlockLoad(CSb);
  CSb.UpdateNodesFlag = 1;
  BlockStore(CSb);
  queued.DoUpdateToVersion(HVr);

  return;
end;

global
procedure UpdateWantedStatusOnServers(array uuid csarr,Integer wanted_status)
begin
  Integer i;
  record RemoteCloudServerVc RCSr;

  for (i = 0; i<csarr.length; i = i + 1) begin
    RCSr.UUID = csarr[i];
    qupdating.UpdateRCSWantedStatus(RCSr,wanted_status);
  end;
  return;
end;

global
procedure ASPRefreshIPCC(string args)
begin
  record CloudNodeVc CNr,CN2r;
  Boolean foundf;

  CNr.Closed = 0;
  CNr.CurrentState = kCloudNodeStateGeneralFailure;
  foundf = true;
  while (LoopKey("State",CNr,2,foundf)) begin
    if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LASPRefreshIPCC; end;
    if (foundf) then begin
      if (CNr.Closed==0) then begin
        EC2RefreshIP(CNr);
      end;
    end;
  end;

  UpdateClientBrowsesIfNeeded("CloudNodeVc");

LASPRefreshIPCC:;
  return;
end;

global
procedure FastCheckCN(string args)
begin
  record CloudMachineStatsVc CMSr;
  record CloudNodeVc CNr;
  Boolean foundf;
  LongInt stat;
  Boolean testf;
  string 255 url;
  Boolean scfailf;
  LongInt minssinceseen;
  LongInt minssincechecked;
  Boolean skipabsentf;

  skipabsentf = true;
  if (args=="notseenforlong") then begin
    skipabsentf = false;
  end;

  CNr.FastCheckFlag = 1;
  foundf = true;
  while (LoopKey("FastCheckFlag",CNr,1,foundf)) begin
    if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LFastCheckCN; end;
    if (CNr.FastCheckFlag!=1) then begin foundf = false; end;
    testf = foundf;
    if (foundf) then begin
      if (nonblankdate(CNr.LastSeenDate)) then begin
        minssinceseen = DateTimeDiff(CurrentDate,CurrentTime,CNr.LastSeenDate,CNr.LastSeenTime);
      end else begin
        minssinceseen = -1;
      end;
      if (nonblankdate(CNr.LastCheckDate)) then begin
        minssincechecked = DateTimeDiff(CurrentDate,CurrentTime,CNr.LastCheckDate,CNr.LastCheckTime);
      end else begin
        minssincechecked = -1;
      end;
    end;

    if (testf and CNr.CurrentState==kCloudNodeStateStopping) then begin testf = false; end;
    if (testf and CNr.CurrentState==kCloudNodeStateStopped) then begin testf = false; end;
    if (testf and CNr.CurrentState==kCloudNodeStateTerminating) then begin testf = false; end;

    if (testf and blankdate(CNr.LastSeenDate)) then begin
      if (blankdate(CNr.CreatedDate) or DateTimeDiff(CurrentDate,CurrentTime,CNr.CreatedDate,CNr.CreatedTime)>=1440) then begin
        if (minssincechecked<=1440) then begin // We give nodes 24 hours to show up, then we check once per day
          testf = false;
        end;
      end;
    end;

    if (testf and nonblankdate(CNr.LastSeenDate) and minssinceseen>=5) then begin
      if (nonblankdate(CNr.LastCheckDate) and minssincechecked<=5) then begin
        testf = false;
      end;
    end;
    if (testf and nonblankdate(CNr.LastSeenDate) and minssinceseen>=10) then begin
      if (nonblankdate(CNr.LastCheckDate) and minssincechecked<=10) then begin
        testf = false;
      end;
    end;
    if (testf and nonblankdate(CNr.LastSeenDate) and minssinceseen>=20) then begin
      if (nonblankdate(CNr.LastCheckDate) and minssincechecked<=20) then begin
        testf = false;
      end;
    end;
    if (testf and nonblankdate(CNr.LastSeenDate) and minssinceseen>=60) then begin
      if (nonblankdate(CNr.LastCheckDate) and minssincechecked<=60) then begin
        testf = false;
      end;
    end;
    if (testf and nonblankdate(CNr.LastSeenDate) and minssinceseen>=720) then begin
      if (nonblankdate(CNr.LastCheckDate) and minssincechecked<=720) then begin
        testf = false;
      end;
    end;
    if (testf and nonblankdate(CNr.LastSeenDate) and minssinceseen>=1440) then begin
      if (nonblankdate(CNr.LastCheckDate) and minssincechecked<=1440) then begin
        testf = false;
      end;
    end;

    if (skipabsentf and minssinceseen>10) then begin
      testf = false;
    end;

    if (!skipabsentf and minssinceseen<=10) then begin
      testf = false;
    end;
/*
    if (blankdate(CNr.LastSeenDate) or minssinceseen>=30) then begin
      if (blankdate(CNr.LastCheckDate) or (minssincechecked<=30) or (CNr.CurrentState==kCloudNodeStateModifying)) then begin
        EC2RefreshIP(CNr);
      end;
    end else begin
      if (nonblankdate(CNr.LastSeenDate)) then begin
        if (CNr.CurrentState==kCloudNodeStateStarting or CNr.CurrentState==kCloudNodeStateModifying) then begin
          EC2RefreshIP(CNr);
        end;
      end;
    end;
*/
    if (testf) then begin
      url = NodeURL(CNr);
      if (nonblank(url)) then begin
        stat = CallService(url).GetCloudNodeStats(CMSr);
        scfailf = TreatServiceError(stat,url,"GetCloudNodeStats");
        qupdating.SaveCloudNodeReachable(CNr.Code,!scfailf);
        if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LFastCheckCN; end;
        qupdating.SaveCloudNodeStats(CNr,CMSr,scfailf);
        if (minssinceseen>15) then begin
          LogText(0,"Syncing RCSs with node " & CNr.Code & " because it wasn't seen for " & minssinceseen & " minutes");
          threadasync.SyncRCSDataWithOneCN(CNr,true,false);
        end;
      end;
    end;
  end;

  UpdateClientBrowsesIfNeeded("CloudNodeVc");

LFastCheckCN:;
  return;
end;

global
procedure FastCheckSyncOneCN(record CloudNodeVc CNr)
begin
  array record LocalCloudServerVc lcsarr;
  array record RemoteCloudServerVc rcsarr;
  record LocalCloudServerVc LCSr;
  record RemoteCloudServerVc RCSr;
  string 255 url;
  LongInt stat,i;
  Boolean foundf,testf;
  Boolean scfailf;
  Integer fastcheckflag;

  RCSr.FastCheckFlag = 1;
  RCSr.Controller = CNr.Code;
  foundf = true;
  while (LoopKey("FastCheckFlag",RCSr,2,foundf)) begin
    if (RCSr.FastCheckFlag!=1) then begin foundf = false; end;
    if (RCSr.Controller!=CNr.Code) then begin foundf = false; end;
    testf = foundf;
    if (testf) then begin
      fastcheckflag = GetFastCheckFlag(RCSr.Controller,RCSr.WantedStatus,RCSr.WantedStatus,RCSr.WantedSubStatus,RCSr.CurrentStatus,RCSr.Closed);
      if (fastcheckflag==0) then begin
        qupdating.UpdateRCSFastCheckFlag(RCSr,0);
      end else begin
        rcsarr[rcsarr.length] = RCSr;
      end;
    end;
  end;

  ResetLoop(RCSr);
  RecordClear(RCSr);
  RCSr.NewController = CNr.Code;
  foundf = true;
  while (LoopKey("NewController",RCSr,1,foundf)) begin
    if (RCSr.NewController!=CNr.Code) then begin foundf = false; end;
    testf = foundf;
    if (testf and (RCSr.WantedStatus!=kWantedStatusCreateServer) and
                  (RCSr.WantedStatus!=kWantedStatusCreateStartedServer) and
                  (RCSr.WantedStatus!=kWantedStatusLaunchReserveSystem) and
                  (RCSr.WantedStatus!=kWantedStatusLaunchUpdateSystem) and
                  (RCSr.WantedStatus!=kWantedStatusLaunchTestSystem)) then begin
      testf = false;
    end;
    if (testf) then begin
//LogText(0,"FastCheckSyncOneCN: 3 sending " & RCSName(RCSr) & " with wanted status " & WantedStatusName(RCSr.WantedStatus) & ", current status " & StatusName(RCSr.CurrentStatus) & ", FastCheckFlag=" & RCSr.FastCheckFlag);
      RCSr.FastCheckFlag = GetFastCheckFlag(RCSr.Controller,RCSr.WantedStatus,RCSr.WantedStatus,RCSr.WantedSubStatus,RCSr.CurrentStatus,RCSr.Closed);
//LogText(0,"FastCheckSyncOneCN: 4 sending " & RCSName(RCSr) & " with wanted status " & WantedStatusName(RCSr.WantedStatus) & ", current status " & StatusName(RCSr.CurrentStatus) & ", FastCheckFlag=" & RCSr.FastCheckFlag);
      fastcheckflag = GetFastCheckFlag(RCSr.Controller,RCSr.WantedStatus,RCSr.WantedStatus,RCSr.WantedSubStatus,RCSr.CurrentStatus,RCSr.Closed);
      if (fastcheckflag==0) then begin
        qupdating.UpdateRCSFastCheckFlag(RCSr,0);
      end else begin
        rcsarr[rcsarr.length] = RCSr;
      end;
    end;
  end;

  if (rcsarr.length>0) then begin
    //LogText(0,"[Fast] Synchronizing " & rcsarr.length & " CC cloud server records with node " & CNr.Code);
    url = NodeURL(CNr);
    stat = CallService(url).FastSyncLCSDataAtCN_WTF(rcsarr,lcsarr);
    if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LFastCheckSyncOneCN; end;
    scfailf = TreatServiceError(stat,url,"FastSyncLCSDataAtCN");
    queued.SaveCloudNodeReachable(CNr.Code,!scfailf);
    if (scfailf) then begin
      LogText(0,"Failed to [fast] synchronize " & rcsarr.length & " CC cloud server records with node " & CNr.Code);
      goto LFastCheckSyncOneCN;
    end;

    if (lcsarr.length>0) then begin
      LogText2(0,"[Fast] Synchronizing " & rcsarr.length & " CC and " & lcsarr.length & " CN cloud server records with node " & CNr.Code,kVerbosityDebug);
//LogText(0,"FastCheckSyncOneCN calling SaveNewAndUpdatedRCSs");
/*
for (i=0;i<lcsarr.length;i = i + 1) begin
LCSr = lcsarr[i];
LogText(0,"FastCheckSyncOneCN calling qupdating.SaveNewAndUpdatedRCSs(LCSr.WantedStatus=" & WantedStatusName(LCSr.WantedStatus) & ", LCSr.CurrentStatus=" & StatusName(LCSr.CurrentStatus) & ")");
end;
*/
      if (CNr.VersionBuild<85290293) then begin
        qupdating.SaveNewAndUpdatedRCSs(CNr,lcsarr);
      end;
    end;
  end;

LFastCheckSyncOneCN:;
  return;
end;

global
procedure FastCheckRCS(string args)
begin
  record CloudNodeVc CNr;
  record RemoteCloudServerVc RCSr;
  array record CloudNodeVc cnarr;
  Boolean foundf,skipf,testf;
  string 255 last_controller,controller;
  LongInt i;

  if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LFastCheckRCS; end;

  i = 0;
  RCSr.FastCheckFlag = 1;
  foundf = true;
  while (LoopKey("FastCheckFlag",RCSr,1,foundf)) begin
    if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LFastCheckRCS; end;
    if (RCSr.FastCheckFlag!=1) then begin foundf = false; end;
    if (blank(RCSr.Controller) and blank(RCSr.NewController)) then begin foundf = false; end;
    testf = foundf;
    if (testf and nonblank(RCSr.Controller)) then begin
      CNr.Code = RCSr.Controller;
      if (ReadFirstMain(CNr,1,true)) then begin
        if (CNr.ReachableFlag<>1) then begin testf = false; end;
      end;
    end;
    if (testf and blank(RCSr.Controller)) then begin
      if (blank(RCSr.NewController)) then begin
        testf = false;
      end;
    end;
    if (testf) then begin
      controller = RCSr.Controller;
      if (blank(controller)) then begin controller = RCSr.NewController; end;
      if ((controller!=last_controller) or blank(last_controller)) then begin
        CNr.Code = controller;
        if (ReadFirstMain(CNr,1,true)) then begin
          cnarr[i] = CNr;
          i = i + 1;
          skipf = false;
          switch (CNr.CurrentState) begin
            case kCloudNodeStateUnknown: skipf = true;
            case kCloudNodeStateNormal: skipf = false;
            case kCloudNodeStateUpdating: skipf = false;
            case kCloudNodeStateGeneralFailure: skipf = false;
            case kCloudNodeStateUpdateFailure: skipf = false;
            case kCloudNodeStateDifferentVersion: skipf = false;
            case kCloudNodeStateCreating: skipf = true;
            case kCloudNodeStateStopping: skipf = true;
            case kCloudNodeStateStopped: skipf = true;
            case kCloudNodeStateStarting: skipf = true;
            case kCloudNodeStateTerminating: skipf = true;
            case kCloudNodeStateMoving: skipf = true;
            case kCloudNodeStateModifying: skipf = true;
          end;
          if (CNr.ReachableFlag==0) then begin skipf = true; end;
          if (RCSr.CurrentStatus==kStatusConfigInError and RCSr.WantedStatus==kWantedStatusRun) then begin skipf = true; end;
          if (RCSr.WantedStatus==kWantedStatusManual) then begin skipf = true; end;
          if (skipf==false) then begin
            FastCheckSyncOneCN(CNr);
            last_controller = controller;
          end;
        end else begin
          LogText(0,"FastCheckRCS() Node " & CNr.Code & " used by RCSr " & RCSr.Name & ", " & RCSr.UUID & " doesn't exist");
        end;
      end;
    end;
  end;

  UpdateClientBrowsesIfNeeded("LocalCloudServerVc");
  UpdateClientBrowsesIfNeeded("RemoteCloudServerVc");
  UpdateClientBrowsesIfNeeded("CloudNodeVc");

LFastCheckRCS:;
  return;
end;

global
updating procedure ResetVersionsRegister()
begin
  record HansaVersionVc HVr,OldHVr;

//TODO: Each version that is in "Deprecated" should be deleted and deleted from disk if no LCSr or RCSr are found that use them in Version or New Version fields
  while (LoopMain(HVr,0,true)) begin
    if (HVr.CurrentState==kHansaVersionStateUnavailable) then begin
      //LogText(0,"Deleting unavailable version " & HVr.Code & " on reset of version register");
      RecordDelete(HVr);
      StepBack(HVr);
    end else begin
      if ((HVr.CurrentState==kHansaVersionStateInstalling) or (HVr.CurrentState==kHansaVersionStateUpdating)) then begin
        RecordCopy(OldHVr,HVr);
        //LogText(0,"ResetVersionsRegister(" & HVr.Code & ") " & StateName(HVr.CurrentState) & " -> " & StateName(kHansaVersionStateNotDownloaded));
        HVr.CurrentState = kHansaVersionStateNotDownloaded;
        RecordUpdate(OldHVr,HVr,false);
      end;
    end;
  end;
end;

global
function Boolean RunMultilineOutCommand(string command,var area atmp)
begin
  Boolean res;
  string 255 script,tmpfile,outfile,errfile,sucfile,scriptfile,bsfile;
  LongInt endtick,starttick;

  starttick = GetCurTick;

  AddLineToArea(command,atmp);
  scriptfile = CreateTempFile("script",".sh");
  WriteAreaToFile(atmp,scriptfile,0);
  SetAreaZeroSize(atmp);

  tmpfile = CreateTempFile("script",".out");
  outfile = tmpfile & ".out";
  errfile = tmpfile & ".err";
  sucfile = tmpfile & ".suc";

  bsfile = CreateTempFile("scriptstarter",".sh");
  AddLineToArea("#!/bin/bash",atmp);
  AddLineToArea("bash " & scriptfile & " >" & outfile & " && touch " & sucfile & " || touch " & errfile,atmp);
  WriteAreaToFile(atmp,bsfile,0);

  script = "bash " & bsfile;
  RunShellScript(script);
  Delete_File(bsfile);
  Delete_File(scriptfile);

  if (FileExists(sucfile)) then begin
    Delete_File(sucfile);
    res = true;
  end else begin
    if (FileExists(errfile)) then begin
      Delete_File(errfile);
    end;
  end;

  SetAreaZeroSize(atmp);
  AddFileToArea(outfile,atmp,false);
  Delete_File(outfile);
  Delete_File(tmpfile);

  if (ThisIsMainThread) then begin
    endtick = GetCurTick;
    if ((endtick-starttick)>=1000) then begin
      LogText(0,"SLOW SCRIPT " & endtick-starttick & "ms: " & command);
    end;
  end;

  RunMultilineOutCommand = res;
end;

global
function Boolean RunOneLineOutCommand(string command,var string output)
begin
  Boolean res;
  LongInt lcnt;
  area atmp;

  res = RunMultilineOutCommand(command,atmp);

  output = "";
  if (res==true) then begin
    lcnt = CountLinesInArea(atmp);
    if (lcnt>0) then begin
      output = Trim(GetLineFromArea(atmp,0));
    end;
  end;

  RunOneLineOutCommand = res;
end;

global
function Integer RunScriptInBackground(string lockfile,area a_script,area a_script_data)
begin
  Integer res; // 0 = error, 1 = started, 2 = already running
  string 255 donefile,datafile;
  string 255 scriptfile,bootstrap_script;
  LongInt cnt;
  LongInt lpid;
  area a_tmp;

  datafile = lockfile & "Data";
  donefile = lockfile & "Completed";

  if (FileExists(lockfile)) then begin
    lpid = ReadLongFromFile(lockfile);
    if (PidIsRunning(lpid)) then begin
      res = 2;
      goto LRunScriptInBackground; // Operation already in progress, only 1 at the time allowed
    end else begin
      if (lpid>=1) then begin
        Delete_File(lockfile);
        if (FileExists(donefile)) then begin
          Delete_File(donefile);
          Delete_File(datafile);
        end else begin
          // fatal error: not running, not done...
        end;
      end else begin
        // pending start...
      end;
    end;
  end;

  scriptfile = CreateTempFile("bootstrap_script",".sh");

  AddLineToArea("trap \"rm -f $0\" EXIT",a_tmp);
  AddAreaToArea(a_script,a_tmp);
  WriteAreaToFile(a_tmp,scriptfile,0);

  if (GetAreaLength(a_script_data)>0) then begin
    AddLineToArea("",a_script_data);
    WriteAreaToFile(a_script_data,datafile,0);
  end;

  bootstrap_script = "touch " & lockfile & "; chmod a+x " & scriptfile & "; bash -c '( echo -n $$ >>" & lockfile & " ; ";
  bootstrap_script = bootstrap_script & "./" & scriptfile & " ; ";
  bootstrap_script = bootstrap_script & "touch " & donefile & " ; )' &";
  RunShellScript(bootstrap_script);

  cnt = 0;

LRunScriptInBackground_Wait:;
  cnt = cnt + 1;
  lpid = ReadLongFromFile(lockfile);
  if (lpid>=1) then begin
    res = 1;
    goto LRunScriptInBackground;
  end;
  if (cnt>10000000) then begin
    LogText(0,"FATAL Script didn't start properly");
    goto LRunScriptInBackground;
  end;
  goto LRunScriptInBackground_Wait;

LRunScriptInBackground:;
  RunScriptInBackground = res;
  return;
end;

global
function string 255 GetArchiveDownloadURL(record ASPArchiveVc AAr)
begin
  record CloudNodeVc CNr;
  record HostingConfigurationVc HCr;
  string 255 res,tempaccesskeyid,tempaccesskey,sessiontoken,server,inpath,path;

  if (!ReadFirstMain(AAr,1,true)) then begin
    LogText(0,"Can't generate download link for archived file because the archive record doesn't exist (" & AAr.UUID & ")");
    goto LGetArchiveDownloadURL;
  end;
  if ((AAr.State==kArchiveFileStateLocal) or (AAr.State==kArchiveFileStateUploadingToLongTerm)) then begin
    // TODO: Kristaps, generate direct download link to .bz2 file here
    goto LGetArchiveDownloadURL;
  end;
  if (AAr.State==kArchiveFileStatePendingArchiving) then begin
    // TODO: Kristaps, generate direct download link to .TXT file here
    goto LGetArchiveDownloadURL;
  end;

  if ((AAr.State==kArchiveFileStateLocalAndLongTerm) or (AAr.State==kArchiveFileStateLongTerm)) then begin
    if (blank(AAr.AmazonRegion)) then begin // TODO: add support for old-style backups that are in hansaworld-cloudarchive bucket
      LogText(0,"Can't generate download link for archived file because the region isn't set (" & AAr.UUID & ")");
      goto LGetArchiveDownloadURL;
    end;
    if (blank(AAr.Controller)) then begin // TODO: add bucket and hosting config to AAr record and use this as fallback
      LogText(0,"Can't generate download link for archived file because the node isn't set (" & AAr.UUID & ")");
      goto LGetArchiveDownloadURL;
    end;
    CNr.Code = AAr.Controller;
    if (!ReadFirstMain(CNr,1,true)) then begin // TODO: fallback on region if node is missing, and use bucket stored on AAr record
      LogText(0,"Can't generate download link for archived file because the node doesn't exist (" & AAr.UUID & ")");
      goto LGetArchiveDownloadURL;
    end;
    HCr.SerNr = CNr.HostingConfig;
    if (!ReadFirstMain(HCr,1,true)) then begin
      LogText(0,"Can't generate download link for archived file because the node's hosting configuration doesn't exist (" & AAr.UUID & ")");
      goto LGetArchiveDownloadURL;
    end;
    if (blank(HCr.AmazonAccessKeyID) or blank(HCr.AmazonSecretAccessKey)) then begin
      LogText(0,"Can't generate download link for archived file because the node's hosting configuration doesn't have credentials (" & AAr.UUID & ")");
      goto LGetArchiveDownloadURL;
    end;

    server = HCr.AmazonCloudArchiveBucket & ".s3." & AAr.AmazonRegion & ".amazonaws.com";

    inpath = "/" & AAr.ServerUUID & "/" & AAr.UUID & "/" & AAr.FileName;
    GetAmazonSessionToken(AAr.AmazonRegion,HCr.AmazonAccessKeyID,HCr.AmazonSecretAccessKey,tempaccesskeyid,tempaccesskey,sessiontoken);
    path = SignAmazonRequestPath(server,inpath,"UNSIGNED-PAYLOAD",AAr.AmazonRegion,"s3",tempaccesskeyid,tempaccesskey,sessiontoken);
    res = "https://" & server & path;
  end;

LGetArchiveDownloadURL:;
  GetArchiveDownloadURL = res;
  return;
end;

global
procedure MakeCurrentVersionDownloadableArchive(record HansaVersionVc HVr)
begin
  record CloudSettingsBlock CSb;
  string 255 path,fn;

  BlockLoad(CSb);
  path = CSb.VersionsFolder;
  if (right(CSb.VersionsFolder,1)!="/") then begin
    path = path & "/";
  end;
  path = path & CSb.HansaVersion;
  fn =  CSb.HansaVersion & ".zip";
  if (DirExists(path)) then begin
    if (FileExists(path & "/" & fn)==false) then begin
      //create the archive
      RunShellScript("cd " & path & " && zip -r3 -qq " & fn & " ./* &");
    end;
  end;

  return;
end;

global
updating procedure UpdateSingleNodeToVersion(record CloudNodeVc CNr,string newver,var Boolean skippedf)
begin
  record CloudNodeVc OldCNr;

  skippedf = true;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    LogText(0,"Error: Attempted to update non-existing node '" & CNr.Code & "' to version " & newver);
    goto LUpdateSingleNodeToVersion;
  end;

  if (CNr.ReachableFlag==0) then begin
    goto LUpdateSingleNodeToVersion;
  end;

  skippedf = false;
  LogText(0,"Updating node " & CNr.Code & " to version " & newver);
  SetCloudControllerStatus(kJobStatusRunning,"Updating node " & CNr.Code & " to version " & newver);

  RecordCopy(OldCNr,CNr);
  CNr.NewHansaVersion = newver;
  CNr.FastCheckFlag = 1;
  CNr.CurrentState = kCloudNodeStateUpdating;
  CNr.UpdatingFlag = 1;
  CNr.LastUpdateFailedFlag = 0;
  RecordUpdate(OldCNr,CNr,true);
  threadasync.UpdateNodeToNewVersion(CNr);

LUpdateSingleNodeToVersion:;
  return;
end;

global
updating procedure ResetNodeUpdatingStates()
begin
  record CloudNodeVc CNr,OldCNr;
  LongInt lcnt;

  lcnt = 0;
  while (LoopMain(CNr,1,true)) begin
    if (CNr.Closed==0) then begin
      RecordCopy(OldCNr,CNr);
      CNr.UpdatingFlag = 0;
      lcnt = lcnt + 1;
      RecordUpdate(OldCNr,CNr,true);
    end;
  end;
  if (lcnt>0) then begin
    LogText(0,lcnt & " nodes will be requested to update to the current Cloud Node version");
  end;
  return;
end;

global
procedure UpdateNodesTask(string args)
begin
  record CloudSettingsBlock CSb;
  record CloudNodeVc CNr;
  LongInt lastseenlimit,nodeslimit,slowintervalmins,intervalmins;
  LongInt succesful_updates;
  Boolean loggedf,skippedf;

  BlockLoad(CSb);
  if (CSb.UpdateLastSeenInMins<=0) then begin
    lastseenlimit = 1440;
  end else begin
    lastseenlimit = CSb.UpdateLastSeenInMins;
  end;
  if (CSb.NodeUpdateSlowIntervalMins<=0) then begin
    slowintervalmins = 5;
  end else begin
    slowintervalmins = CSb.NodeUpdateSlowIntervalMins;
  end;
  if (CSb.NodeUpdateIntervalMins<0) then begin
    intervalmins = 1;
  end else begin
    intervalmins = CSb.NodeUpdateIntervalMins;
  end;
  if (CSb.NodesToUpdateSlowly<=0) then begin
    nodeslimit = 5;
  end else begin
    nodeslimit = CSb.NodesToUpdateSlowly;
  end;
  
  succesful_updates = 0;
  while (LoopMain(CNr,1,true)) begin
    if (CSb.AbortUpdateFlag!=0) then begin
      goto LUpdateNodesTask_Next;
    end;
    if (CNr.Closed==0) then begin
      if (CNr.VersionBuild!=VersionBuild and CNr.UpdatingFlag==0) then begin
        if (loggedf==false) then begin
          LogText(0,"*** Updating cloud nodes seen in the past " & lastseenlimit & " minutes to " & CSb.HansaVersion & " ***");
          loggedf = true;
        end;
      end;
      if (CNr.CurrentState==kCloudNodeStateNormal and CNr.VersionBuild==VersionBuild) then begin
        succesful_updates = succesful_updates + 1;
      end;
    end;
  end;

  RecordClear(CNr);
  ResetLoop(CNr);
  while (LoopMain(CNr,1,true)) begin
    if (CSb.AbortUpdateFlag!=0) then begin
      goto LUpdateNodesTask_Next;
    end;
    if (CNr.Closed==0) then begin
      if (CNr.VersionBuild!=VersionBuild and CNr.UpdatingFlag==0) then begin
        if (nonblankdate(CNr.LastSeenDate) and DateTimeDiff(CurrentDate,CurrentTime,CNr.LastSeenDate,CNr.LastSeenTime)<=lastseenlimit) then begin
          qupdating.UpdateSingleNodeToVersion(CNr,CSb.HansaVersion,skippedf);
          if (skippedf==false) then begin
            if (succesful_updates<nodeslimit) then begin
              LogText(0,"Waiting " & slowintervalmins & " minutes before continuing updating nodes, node limit is " & nodeslimit);
              goto LUpdateNodesTask_Next;
            end;
            LogText(0,"Waiting " & intervalmins & " minutes before continuing updating nodes");
            Sleep(intervalmins*60); //## ugly, should be done with the task...
          end;
        end else begin
          if (nonblankdate(CNr.LastSeenDate)) then begin
            LogText(0,"Update of node " & CNr.Code & " skipped (lastseen=" & DateTimeDiff(CurrentDate,CurrentTime,CNr.LastSeenDate,CNr.LastSeenTime) & ">lastseenlimit=" & lastseenlimit & ")");
          end else begin
            LogText(0,"Update of node " & CNr.Code & " skipped (node never seen)");
          end;
        end;
//      end else begin
//        if (CNr.UpdatingFlag==0) then begin
//          LogText(0,"Update of node " & CNr.Code & " skipped (node build=" & CNr.VersionBuild & ", VersionBuild=" & VersionBuild & ")");
//        end;
      end;
    end;
  end;

  qupdating.ResetNodeUpdatingStates;

LUpdateNodesTask_Next:;
  return;
end;

global
updating procedure UpdateLastProcCheckForServer(record LocalCloudServerVc LCSr)
begin
  record LocalCloudServerVc OldLCSr;

  if (ReadFirstMain(LCSr,1,true)==false) then begin goto LUpdateLastProcCheckForServer; end;

  RecordCopy(OldLCSr,LCSr);
  LCSr.LastProcCheckDate = CurrentDate;
  LCSr.LastProcCheckTime = CurrentTime;
  if (ComparePosts(OldLCSr,LCSr)==false) then begin
    RecordUpdate(OldLCSr,LCSr,true);
  end;

LUpdateLastProcCheckForServer:;
  return;
end;

procedure RecoverPidForServer(record LocalCloudServerVc LCSr) // this is an expensive function, should not run on the main thread
begin
  string 255 pid_file;
  Boolean pidfile_existsf,pid_is_runningf;
  Longint svpid;

  if (ThisIsMainThread) then begin goto LRecoverPidForServer; end;

  qupdating.UpdateLastProcCheckForServer(LCSr);

  pid_file = PidFile(LCSr);
  if (blank(pid_file)) then begin goto LRecoverPidForServer; end;

  pidfile_existsf = FileExists(pid_file);
  if (pidfile_existsf) then begin
    svpid = ReadLongFromFile(pid_file);
    pid_is_runningf = PidIsRunning(svpid);
  end;

  if (pid_is_runningf==false) then begin
    RecoverPidFile(LCSr,pid_file,pid_is_runningf,pidfile_existsf,svpid);
  end;

LRecoverPidForServer:;
  return;
end;

global
procedure CheckAndRecoverLSCPidFileTask(string args)
begin
  Boolean pidfile_existsf,pid_is_runningf,foundf,testf;
  record LocalCloudServerVc LCSr;
  Integer cnt;
  Date td;
  Time tt;

  LCSr.FastCheckFlag = 1;
  foundf = true;
  while (LoopKey("FastCheckFlag",LCSr,1,foundf)) begin
    if (LCSr.FastCheckFlag==0) then begin foundf = false; end;
    testf = foundf;
    if (LCSr.Closed!=0) then begin testf = false; end;
    if (testf) then begin
      RecoverPidForServer(LCSr); // maybe too often?
    end;
  end;

  RecordClear(LCSr);
  ResetLoop(LCSr);
  while (LoopMain(LCSr,1,true)) begin
    testf = true;
    if (testf and LCSr.Closed!=0) then begin testf = false; end;
    if (testf and blankdate(LCSr.LastStartDate)) then begin testf = false; end;
    if (testf and !blankdate(LCSr.LastStartDate)) then begin
      testf = IsMinutesPastTime(LCSr.LastProcCheckDate,LCSr.LastProcCheckTime,LCSr.LastStartDate,LCSr.LastStartTime,10);
    end;
    if (testf) then begin
      testf = IsMinutesPastCurrentTime(LCSr.LastProcCheckDate,LCSr.LastProcCheckTime,10);
    end;
    if (testf) then begin
      cnt = cnt + 1;
      RecoverPidForServer(LCSr);
      if (cnt>100) then begin goto LCheckAndRecoverLSCPidFileTask; end; // not sure if this is enough
    end;
  end;

LCheckAndRecoverLSCPidFileTask:;
  return;
end;

global
procedure ResetLocalServerErrorStatusTask(string args)
begin
  record LocalCloudServerVc LCSr;
  Boolean testf;
  Integer cnt;
  
  while (LoopMain(LCSr,1,true)) begin
    if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LResetLocalServerErrorStatusTask; end;
    testf = true;
    if (testf and LCSr.Closed!=0) then begin testf = false; end;
    if (testf and LCSr.CurrentStatus!=kStatusConfigInError) then begin testf = false; end;
    if (testf) then begin
      if (LCSr.WantedStatus!=kWantedStatusOnDemand and
          LCSr.WantedStatus!=kWantedStatusStop and
          LCSr.WantedStatus!=kWantedStatusImportBackupAndRun and
          LCSr.WantedStatus!=kWantedStatusStopAndRefresh and
          LCSr.WantedStatus!=kWantedStatusForceStop) then
      begin
        testf = false;
      end;
    end;
    if (testf and LocalCloudServerSeenInDays(LCSr,1)) then begin testf = false; end;
    if (testf) then begin
      qupdating.ClearLocalCloudServerErrorStatus(LCSr);
      cnt = cnt + 1;
    end;
  end;
  
  if (cnt>0) then begin
    LogText(0,"Cleared error status on " & cnt & " servers");
  end;
  
LResetLocalServerErrorStatusTask:;
  return;
end;

function Boolean IsChildSystemServerItem(Integer rcsrwitem)
begin
  Boolean res;
  
  res = true;
  switch (rcsrwitem) begin
    case kManagedServerItemSlaveSystem:
    case kManagedServerItemSystemCopy:
    case kManagedServerItemReserveSystem:
    case kManagedServerItemTestSystem:
    case kManagedServerItemUpdateSystem:
    otherwise
      res = false;
  end;
  
  IsChildSystemServerItem = res;
  return;
end;

global
updating procedure RemoveMotherSystemFromAllChildSystems(record RemoteCloudServerVc RCSr)
begin
  row RemoteCloudServerVc RCSrw;
  record RemoteCloudServerVc OldRCSr,RCS2r,OldRCS2r;
  LongInt rwcnt,rwn;
  
  RecordCopy(OldRCSr,RCSr);
  rwcnt = MatRowCnt(RCSr);
  for (rwn = rwcnt; rwn>0; rwn = rwn - 1) begin
    MatRowGet(RCSr,rwn-1,RCSrw);
    if (IsChildSystemServerItem(RCSrw.Item)) then begin
      if (nonblank(RCSrw.ItemName)) then begin
        RCS2r.UUID = StringToUUID(RCSrw.ItemName);
        if (!BlankUUID(RCS2r.UUID)) then begin
          if (ReadFirstMain(RCS2r,1,true)) then begin
            RecordCopy(OldRCS2r,RCS2r);
            RemoveManagedServerItemByName(RCS2r,RCSr.UUID);
            if (ComparePosts(OldRCS2r,RCS2r)==false) then begin
              RecordUpdate(OldRCS2r,RCS2r,true);
            end;
          end;
        end;
      end;
      MatRowDelete(RCSr,rwn-1);
    end;
  end;
  if (ComparePosts(OldRCSr,RCSr)==false) then begin
    RecordUpdate(OldRCSr,RCSr,true);
  end;
  return;
end;

global
updating procedure RemoveAllMissingChildSystems(record RemoteCloudServerVc RCSr)
begin
  row RemoteCloudServerVc RCSrw;
  record RemoteCloudServerVc OldRCSr,RCS2r,OldRCS2r;
  LongInt rwcnt,rwn;
  Boolean removef;
  
  RecordCopy(OldRCSr,RCSr);
  rwcnt = MatRowCnt(RCSr);
  for (rwn = rwcnt; rwn>0; rwn = rwn - 1) begin
    removef = false;
    MatRowGet(RCSr,rwn-1,RCSrw);
    if (IsChildSystemServerItem(RCSrw.Item)) then begin
      if (nonblank(RCSrw.ItemName)) then begin
        RCS2r.UUID = StringToUUID(RCSrw.ItemName);
        if (!BlankUUID(RCS2r.UUID)) then begin
          if (ReadFirstMain(RCS2r,1,true)) then begin
            if (RCS2r.Closed!=0) then begin removef = true; end;
          end else begin
            removef = true;
          end;
        end else begin
          removef = true;
        end;
      end else begin
        removef = true;
      end;
      if (removef) then begin
        MatRowDelete(RCSr,rwn-1);
      end;
    end;
  end;
  
  if (ComparePosts(OldRCSr,RCSr)==false) then begin
    RecordUpdate(OldRCSr,RCSr,true);
  end;
  
  return;
end;

global
procedure ResetRemoteServerErrorStatusTask(string args)
begin
  record RemoteCloudServerVc RCSr,RCS2r;
  row RemoteCloudServerVc RCSrw;
  LongInt rwcnt,rwn;
  record CloudNodeVc CNr;
  string 255 controller;
  Boolean testf;
  Integer cnt;
  
  while (LoopMain(RCSr,0,true)) begin
    if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LResetRemoteServerErrorStatusTask; end;
    if (QuitingApplication==true) then begin goto LResetRemoteServerErrorStatusTask; end;
    
    if (RCSr.Closed!=0) then begin
      qupdating.RemoveMotherSystemFromAllChildSystems(RCSr);
      goto LResetRemoteServerErrorStatusTask_next;
    end;

    qupdating.RemoveAllMissingChildSystems(RCSr);
    
    if (blank(RCSr.Controller) and blank(RCSr.NewController)) then begin
      if (RemoteCloudServerSeenInDays(RCSr,2)==false) then begin
        qupdating.DoCloseRemoteCloudServer(RCSr);
        goto LResetRemoteServerErrorStatusTask_next;
      end;
    end;
    
    controller = RCSr.Controller;
    if (blank(controller)) then begin controller = RCSr.NewController; end;
    CNr.Code = controller;
    if (ReadFirstMain(CNr,1,true)==false) then begin
      qupdating.DoCloseRemoteCloudServer(RCSr);
      goto LResetRemoteServerErrorStatusTask_next;
    end else begin
      if (CNr.Closed!=0) then begin
        qupdating.DoCloseRemoteCloudServer(RCSr);
        goto LResetRemoteServerErrorStatusTask_next;
      end;
      if (CloudNodeSeenInDays(CNr,90)==false) then begin
        qupdating.DoCloseRemoteCloudServer(RCSr);
        goto LResetRemoteServerErrorStatusTask_next;
      end;
    end;
    
    testf = true;
    if (testf and RCSr.CurrentStatus!=kStatusConfigInError) then begin testf = false; end;
    if (testf) then begin
      switch (RCSr.WantedStatus) begin
        case kWantedStatusStop:                     testf = false;
        case kWantedStatusRun:
        case kWantedStatusOnDemand:                 testf = false;
        case kWantedStatusMaintenence:
        case kWantedStatusManual:                   testf = false;
        case kWantedStatusImportBackup:
        case kWantedStatusUpdateVersion:
        case kWantedStatusCreateServer:
        case kWantedStatusMoveServer:               testf = false;
        case kWantedStatusRestart:
        case kWantedStatusExportDatabase:
        case kWantedStatusExportRegister:
        case kWantedStatusCreateStartedServer:
        case kWantedStatusImportBackupAndRun:
        case kWantedStatusLaunchReserveSystem:
        case kWantedStatusExportCompany:
        case kWantedStatusLaunchTestSystem:
        case kWantedStatusLaunchUpdateSystem:
        case kWantedStatusResetToBackup:
        case kWantedStatusRunUnjournaled:
        case kWantedStatusChangeVersion:            testf = false;
        case kWantedStatusForceStop:                testf = false;
        case kWantedStatusContinousUpdateVersion:
        case kWantedStatusRebuildDatabase:
        case kWantedStatusStopAndRefresh:           testf = false;
        case kWantedStatusClearRegister:
      end;
    end;
    if (testf and RemoteCloudServerSeenInDays(RCSr,2)) then begin testf = false; end;
    if (testf) then begin
      qupdating.StopRemoteCloudServer(RCSr,false);
      cnt = cnt + 1;
      goto LResetRemoteServerErrorStatusTask_next;
    end;
    
    switch (RCSr.WantedStatus) begin
      case kWantedStatusImportBackupAndRun:
        if (RCSr.CurrentStatus==kStatusCreated) then begin
          if (RemoteCloudServerSeenInDays(RCSr,2)==false) then begin
            qupdating.DoCloseRemoteCloudServer(RCSr);
            goto LResetRemoteServerErrorStatusTask_next;
          end;
        end;
      case kWantedStatusCreateStartedServer:
        if (RCSr.CurrentStatus==kStatusCreating) then begin
          if (RemoteCloudServerSeenInDays(RCSr,2)==false) then begin
            qupdating.DoCloseRemoteCloudServer(RCSr);
            goto LResetRemoteServerErrorStatusTask_next;
          end;
        end;
    end;
LResetRemoteServerErrorStatusTask_next:;
  end;
    
  if (cnt>0) then begin
    LogText(0,"Automatically stopped " & cnt & " servers that was in error state for more than one day");
  end;
  
LResetRemoteServerErrorStatusTask:;
  return;
end;

global
procedure CleanupRCSRecordsTask(string args)
begin
  record RemoteCloudServerVc RCSr;
  array UUID servers_to_refresh;

  while (LoopMain(RCSr,1,true)) begin
    if (RCSr.Closed==0) then begin
      switch (RCSr.CurrentStatus) begin
        case kStatusNone:
          servers_to_refresh[servers_to_refresh.length] = RCSr.UUID;

/* we need better data to figure out when we last saw a RCS
        case kStatusNodeUnreachable:
          if (RemoteCloudServerSeenInDays(RCSr,90)==false) then begin
          end;
*/
      end;
    end;
  end;

  if (servers_to_refresh.length>0) then begin
    RefreshStatusOfRemoteCloudServers(servers_to_refresh);
  end;

  return;
end;

function Boolean UseLocalWatchdogs()
begin
  record CloudSettingsBlock CSb;
  Boolean res;

  BlockLoad(CSb);
  res = CSb.LocalWatchpoints==1;

  UseLocalWatchdogs = res;
  return;
end;

procedure UpdateCorehandler()
begin
  string 255 corehandlerfile;
  area ar;

  switch (ProgramPlatform) begin
    case kPlatformLinux32:
    case kPlatformLinux64:
    case kPlatformLinuxArm64:
    otherwise
      goto LUpdateCorehandler;
  end;

  corehandlerfile = "/usr/local/bin/corehandler";
  if (FileExists(corehandlerfile)==false) then begin
    goto LUpdateCorehandler;
  end;

  AddLineToArea("#!/bin/bash",ar);
  AddLineToArea("dir=$(readlink -f /proc/$2/cwd)",ar);
  AddLineToArea("ls -lh /proc/$(cat \"${dir}/hansa.pid\")/fd >\"${dir}/core.$2-fds\"",ar);
  AddLineToArea("cat /proc/$(cat \"${dir}/hansa.pid\")/maps >\"${dir}/core.$2-maps\"",ar);
  AddLineToArea("cp -f \"${dir}/hansa.log\" \"${dir}/core.$2-hansa.log\" &>/dev/null",ar);
  AddLineToArea("cp -f \"${dir}/hal.hob\" \"${dir}/core.$2-hal.hob\" &>/dev/null",ar);
  AddLineToArea("dd bs=65536 of=\"${dir}/core.$2\"",ar);
  WriteAreaToFile(ar,corehandlerfile,0);

LUpdateCorehandler:;
  return;
end;

global
procedure ASPCleanVersionsTask(string args)
begin
  LongInt pos;
  LongInt filecnt;
  string 255 foldername;
  LongInt i,j;
  record HansaVersionVc HVr;
  Boolean keepf;
  
  i = 0;
  j = 0;
  filecnt = CountDirectoriesInDir(VersionsFolder);

  for (pos = 0; pos<filecnt; pos = pos + 1) begin
    if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LASPCleanVersionsTask; end;

    foldername = GetDirectoryNameInDir(VersionsFolder,pos);
    if (nonblank(trim(foldername)) and (foldername!=".") and (foldername!="..") and right(foldername,9)!=".download") then begin
      keepf = false;
      HVr.Code = foldername;
      if (ReadFirstMain(HVr,1,true)) then begin
        if ((HVr.CurrentState==kHansaVersionStateInstalling) or
            (HVr.CurrentState==kHansaVersionStateUpdating)) then begin
          keepf = true;
        end;
      end;
      if (qupdating.IsVersionInUse(foldername)==false and
          !ShouldDownloadVersion(foldername) and
          !IsDownloadingVersion(foldername) and
          !keepf) then begin
        LogText(0,"Removing unused version folder " & VersionsFolder & foldername);
        j = j + 1;
        DeleteFolder(VersionsFolder & foldername);
        i = i + 1;
      end else begin
        LogText2(0,"Keeping version folder " & VersionsFolder & foldername,kVerbosityDebugDetailed);
      end;
    end;
  end;

  if (j>0) then begin
    LogText(0,"Removed " & j & " version folders");
  end;

LASPCleanVersionsTask:;
  return;
end;

function LongInt CleanLCSFilesInterval()
begin
  CleanLCSFilesInterval = 5;
  return;
end;

procedure CleanFilesOnOneLCS(record LocalCloudServerVc LCSr,var Boolean loggedf)
begin
  string 255 path,fname,lcs_path;
  LongInt cnt,idx;
  date cdt,fdt;
  time ctm,ftm;
  Boolean foundf;
  Integer days_to_keep,max_days_to_keep;
  Boolean criticalf,forcef;
  
  lcs_path = LCSr.DataFolder;
  if (blank(lcs_path)) then begin goto LCleanFilesOnOneLCS; end;
  if (DirExists(lcs_path)==false) then begin goto LCleanFilesOnOneLCS; end;
  
  criticalf = IsServerSpaceCriticallyLow(loggedf);
  days_to_keep = 30;
  max_days_to_keep = days_to_keep;
  
  cdt = CurrentDate;
  ctm = CurrentTime;
  
  if (criticalf) then begin
    path = lcs_path & "/downloadupdateclients";
    if (DirExists(path)) then begin
      DeleteFolder(path);
      criticalf = IsServerSpaceCriticallyLow(loggedf);
      LogText(0,"Clean local cloud server files: deleted " & path & ", criticalf is now " & criticalf);
    end;
  end;

  path = lcs_path;
  cnt = CountFilesInDir(path);
  for (idx = cnt; idx>0; idx = idx - 1) begin
    fname = GetFileNameInDir(path,idx-1);
    //LogText(0,"DEBUG 1 Candidate " & path & "/" & fname & ", criticalf=" & criticalf);
    if (right(fname,4)==".zip") then begin
      if (criticalf) then begin
        if (FileChangedDate(path & "/" & fname,fdt,ftm)==true) then begin
          if (DateDiff(cdt,fdt)>=90) then begin
            Delete_File(path & "/" & fname);
            criticalf = IsServerSpaceCriticallyLow(loggedf);
            LogText(0,"Clean local cloud server files: deleted " & path & "/" & fname & ", criticalf is now " & criticalf);
          end;
        end;
      end;
    end;
    if (right(fname,4)==".log") then begin
      if (criticalf) then begin
        if (FileSize2(path & "/" & fname)>314572800) then begin // 300Mb
          Delete_File(path & "/" & fname);
          criticalf = IsServerSpaceCriticallyLow(loggedf);
          LogText(0,"Clean local cloud server files: deleted " & path & "/" & fname & ", criticalf is now " & criticalf);
          if (!criticalf) then begin days_to_keep = max_days_to_keep; end;
        end;
      end;
    end;
    if (left(fname,5)=="core.") then begin
      if (FileChangedDate(path & "/" & fname,fdt,ftm)==true) then begin
        if (criticalf or (DateDiff(cdt,fdt)>=days_to_keep)) then begin
          Delete_File(path & "/" & fname);
          criticalf = IsServerSpaceCriticallyLow(loggedf);
          LogText(0,"Clean local cloud server files: deleted " & path & "/" & fname & ", criticalf is now " & criticalf);
          if (!criticalf) then begin days_to_keep = max_days_to_keep; end;
        end;
      end;
    end;
    if ((len(fname)>10) and (left(fname,9)=="HANSA.HDB")) then begin // note len; intentionally not matching the actual live HDB
      if (FileChangedDate(path & "/" & fname,fdt,ftm)==true) then begin
        if (criticalf or (DateDiff(cdt,fdt)>=max_days_to_keep)) then begin // always keep HDB copies max days
          Delete_File(path & "/" & fname);
          criticalf = IsServerSpaceCriticallyLow(loggedf);
          LogText(0,"Clean local cloud server files: deleted " & path & "/" & fname & ", criticalf is now " & criticalf);
          if (!criticalf) then begin days_to_keep = max_days_to_keep; end;
        end;
      end;
    end;
    if (left(fname,13)=="RawDataEn.TXT") then begin
      if (FileChangedDate(path & "/" & fname,fdt,ftm)==true) then begin
        if (criticalf or (DateDiff(cdt,fdt)>=days_to_keep)) then begin
          Delete_File(path & "/" & fname);
          criticalf = IsServerSpaceCriticallyLow(loggedf);
          LogText(0,"Clean local cloud server files: deleted " & path & "/" & fname & ", criticalf is now " & criticalf);
          if (!criticalf) then begin days_to_keep = max_days_to_keep; end;
        end;
      end;
    end;
  end;
  
  if (criticalf) then begin days_to_keep = 10; end;
  if (LCSr.CloudBackupPlan==kCloudBackupPlanLevel4) then begin
    path =  lcs_path & "/Backup";
    if (DirExists(path)) then begin
      cnt = CountFilesInDir(path);
      for (idx = cnt; idx>0; idx = idx - 1) begin
        foundf = false;
        fname = GetFileNameInDir(path,idx-1);
        if (left(fname,2)=="TB") then begin foundf = true; end;
        if (right(fname,4)==".bz2") then begin foundf = true; end;
        if (right(fname,4)==".zip") then begin foundf = true; end;
        if (right(fname,4)==".tar") then begin foundf = true; end;
        if (right(fname,4)==".tgz") then begin foundf = true; end;
        if (right(fname,7)==".tar.gz") then begin foundf = true; end;
        if (fname=="TB.TXT") then begin foundf = false; end;
        if (foundf) then begin
          //LogText(0,"DEBUG 2 Candidate " & path & "/" & fname & ", criticalf=" & criticalf);
          if (FileChangedDate(path & "/" & fname,fdt,ftm)==true) then begin
            if (DateDiff(cdt,fdt)>=days_to_keep) then begin
              //LogText(0,"DEBUG 2 deleting");
              Delete_File(path & "/" & fname);
              criticalf = IsServerSpaceCriticallyLow(loggedf);
              LogText(0,"Clean local cloud server files: deleted " & path & "/" & fname & ", criticalf is now " & criticalf);
              if (!criticalf) then begin days_to_keep = max_days_to_keep; end;
            end;
          end;
        end;
      end;
    end;
  end;
  
  path = lcs_path;
  cnt = CountDirectoriesInDir(path);
  for (idx = cnt; idx>0; idx = idx - 1) begin
    fname = GetDirectoryNameInDir(path,idx-1);
    if (left(fname,6)=="oldver") then begin
//      LogText(0,"DEBUG 3 Candidate " & path & "/" & fname & ", criticalf=" & criticalf & ", fdt=" & DateToString(fdt,"YYYY-MM-DD") & ", cdt=" & DateToString(cdt,"YYYY-MM-DD") & ", days_to_keep=" & days_to_keep);
      if (FileChangedDate(path & "/" & fname,fdt,ftm)==true) then begin
        if (criticalf and DateDiff(cdt,fdt)>=days_to_keep) then begin
//          LogText(0,"DEBUG 3 deleting " & path & "/" & fname);
          DeleteFolder(path & "/" & fname);
          criticalf = IsServerSpaceCriticallyLow(loggedf);
          if (!criticalf) then begin days_to_keep = max_days_to_keep; end;
        end;
      end;
    end;
    if (fname=="wsreplies") then begin
      if (criticalf) then begin
        DeleteFolder(path & "/" & fname);
        criticalf = IsServerSpaceCriticallyLow(loggedf);
        if (!criticalf) then begin days_to_keep = max_days_to_keep; end;
      end;
    end;
  end;
  
  if (criticalf) then begin days_to_keep = 10; end;
  path =  lcs_path & "/Asterisk/var/log/asterisk";
  if (DirExists(path)) then begin
    cnt = CountFilesInDir(path);
    for (idx = cnt; idx>0; idx = idx - 1) begin
      forcef = false;
      foundf = false;
      fname = GetFileNameInDir(path,idx-1);
      if (left(fname,9)=="messages.") then begin foundf = true; end;
      if (foundf) then begin
        //LogText(0,"DEBUG 2 Candidate " & path & "/" & fname & ", criticalf=" & criticalf);
        if (FileSize2(path & "/" & fname)>1048576000) then begin // 1G
          forcef = true;
        end;
        if (forcef or (FileChangedDate(path & "/" & fname,fdt,ftm)==true)) then begin
          if (forcef or (DateDiff(cdt,fdt)>=days_to_keep)) then begin
            //LogText(0,"DEBUG 2 deleting");
            Delete_File(path & "/" & fname);
            criticalf = IsServerSpaceCriticallyLow(loggedf);
            LogText(0,"Clean local cloud server files: deleted " & path & "/" & fname & ", criticalf is now " & criticalf);
            if (!criticalf) then begin days_to_keep = max_days_to_keep; end;
          end;
        end;
      end;
    end;
  end;

LCleanFilesOnOneLCS:;
  return;
end;

procedure DeleteFileIfExists(string fname)
begin
  if (FileExists(fname)) then begin
    Delete_File(fname);
  end;
  return;
end;

procedure DeleteFolderIfExists(string path)
begin
  if (DirExists(path)) then begin
    DeleteFolder(path);
  end;
  return;
end;

/*** THIS FUNCTION IS CALLED FROM C - DO NOT CHANGE THE PARAMETERS ***/
global
procedure CleanVersionsFolders()
begin
  string 255 path,fname,vername;
  LongInt cnt,idx;
  date cdt,fdt;
  time ctm,ftm;
  Boolean foundf,criticalf,loggedf;

  path = VersionsFolder;
  if (blank(path)) then begin goto LCleanVersionsFolders; end;
  if (DirExists(path)==false) then begin goto LCleanVersionsFolders; end;
  if (FileExists(ProgramFolder & "/" & "EnNewNodeExe")) then begin goto LCleanVersionsFolders; end;

  LogText2(0,"*** Starting to clean version files ***",kVerbosityDebug);

  criticalf = IsServerSpaceCriticallyLow(loggedf);

  cdt = CurrentDate;
  ctm = CurrentTime;
  
  DeleteFileIfExists("hansa-debug-optimized-slavearm64");
  DeleteFileIfExists("hansa-debug-serverarm64");
  DeleteFileIfExists("hansa-debug-slavearm64");
  
  switch (ProgramPlatform) begin
    case kPlatformWindows32:
      DeleteFolderIfExists("ps-x64");
    case kPlatformWindows64:
      DeleteFolderIfExists("ps-x86");
    otherwise
      DeleteFolderIfExists("ps-x64");
      DeleteFolderIfExists("ps-x86");
  end;

  cnt = CountDirectoriesInDir(path);
  for (idx = cnt; idx>0; idx = idx - 1) begin
    fname = GetDirectoryNameInDir(path,idx-1);
    if (right(fname,9)==".download" or right(fname,10)==".tmpupdate") then begin
      vername = fname;
      if (right(fname,9)==".download") then begin vername = left(fname,len(fname)-9); end;
      if (right(fname,10)==".tmpupdate") then begin vername = left(fname,len(fname)-10); end;
      if (FileChangedDate(path & "/" & fname,fdt,ftm)==true) then begin
        if ((DateDiff(cdt,fdt)>=3) or (!IsDownloadingVersion(vername) and !ShouldDownloadVersion(vername))) then begin
          DeleteFolder(path & "/" & fname);
          criticalf = IsServerSpaceCriticallyLow(loggedf);
          LogText2(0,"Clean version files: deleted " & path & "/" & fname & ", criticalf is now " & criticalf,kVerbosityDebug);
        end;
      end;
    end else begin
      switch (ProgramPlatform) begin
        case kPlatformWindows32:
          DeleteFolderIfExists(path & "/" & fname & "/ps-x64");
        case kPlatformWindows64:
          DeleteFolderIfExists(path & "/" & fname & "/ps-x86");
        otherwise
          DeleteFolderIfExists(path & "/" & fname & "/ps-x64");
