function Val MIN(Val a,Val b)
begin
  if (a<b) then begin
    MIN = a;
  end else begin
    MIN = b;
  end;
  return;
end;

function Val MAX(Val a,Val b)
begin
  if (a>b) then begin
    MAX = a;
  end else begin
    MAX = b;
  end;
  return;
end;

