function Boolean ShouldRetryAmazonAPICall(string desc,Boolean call_res,string call_msg,record NodeRebuildVc NRr,var LongInt num_retries)
begin
  Boolean res;
  
  if (call_res) then begin
    num_retries = -1;
    goto LShouldRetryAmazonAPICall;
  end;
  
  qupdating.AddLineToNodeRebuildLog(NRr,desc);
  if (nonblank(call_msg)) then begin
    qupdating.AddLineToNodeRebuildLog(NRr,"Error:");
    qupdating.AddLineToNodeRebuildLog(NRr,call_msg);
  end;

  if (InString(call_msg,"ERROR: Communications error while calling")==0) then begin
    num_retries = -1;
    goto LShouldRetryAmazonAPICall;
  end;

  if (num_retries<0) then begin num_retries = 0; end;
  num_retries = num_retries + 1;
  
  if (num_retries>10) then begin
    qupdating.AddLineToNodeRebuildLog(NRr,"Error: Call failed after 10 attempts, giving up...");
    goto LShouldRetryAmazonAPICall;
  end;
  
  qupdating.AddLineToNodeRebuildLog(NRr,"Attempting AWS call again in 10s...");
  Sleep(10);
  res = true;
  
LShouldRetryAmazonAPICall:;
  ShouldRetryAmazonAPICall = res;
  return;
end;

global
updating function Boolean RebuildOneNode_PrepareAction(record CloudNodeActionQueueVc CNAQr,var record NodeRebuildVc NRr)
begin
  Boolean res;
  
  NRr.SerNr = CNAQr.LongParam1;
  if (ReadFirstMain(NRr,1,true)==false) then begin
    RemoveOneCloudNodeAction(CNAQr.SerNr);
    goto LRebuildOneNode_PrepareAction;
  end;
  
  if (NRr.PausedFlag!=0) then begin
    goto LRebuildOneNode_PrepareAction;
  end;
  
  if (NRr.DoneFlag!=0) then begin
    RemoveOneCloudNodeAction(CNAQr.SerNr);
    AddLineToNodeRebuildLog(NRr,"The node " & NRr.Controller & " was skipped because the node rebuild operation was marked as done");
    goto LRebuildOneNode_PrepareAction;
  end;
  
  res = true;

LRebuildOneNode_PrepareAction:;
  RebuildOneNode_PrepareAction = res;
  return;
end;

global
updating function Boolean RebuildOneNode_GetCloudNode(var record CloudNodeVc CNr,record NodeRebuildVc NRr,record CloudNodeActionQueueVc CNAQr)
begin
  Boolean res;
  
  CNr.Code = NRr.Controller;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"The node " & NRr.Controller & " disappeared");
    goto LRebuildOneNode_GetCloudNode;
  end;
  
  res = true;
  
LRebuildOneNode_GetCloudNode:;
  RebuildOneNode_GetCloudNode = res;
  return;
end;

global
updating function Boolean RebuildOneNode_GetCloudNodeAndHostingConfig(var record CloudNodeVc CNr,var record HostingConfigurationVc HCr,
                                                                      record NodeRebuildVc NRr,record CloudNodeActionQueueVc CNAQr)
begin
  Boolean res;
  
  if (!RebuildOneNode_GetCloudNode(CNr,NRr,CNAQr)) then begin
    goto LRebuildOneNode_GetCloudNodeAndHostingConfig;
  end;
  
  HCr.SerNr = CNr.HostingConfig;
  if (ReadFirstMain(HCr,1,true)==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"Invalid hosting configuration specified on node: " & HCr.SerNr);
    goto LRebuildOneNode_GetCloudNodeAndHostingConfig;
  end;
  
  res = true;

LRebuildOneNode_GetCloudNodeAndHostingConfig:;
  RebuildOneNode_GetCloudNodeAndHostingConfig = res;
  return;
end;

function string 255 VolumeArrToVolumesToMoveString(record EC2InstanceVc EC2Ir,array record EBSVolumeVc volume_arr)
begin
  string 255 res;
  Integer idx;
  record EBSVolumeVc EBSVr;
  
  for (idx = 0; idx<volume_arr.length; idx = idx + 1) begin
    EBSVr = volume_arr[idx];
    if (EBSVr.Device!=EC2Ir.RootDeviceName) then begin
      if (nonblank(res)) then begin res = res & ","; end;
      res = res & EBSVr.VolumeId & ":" & EBSVr.Device;
    end;
  end;
    
  VolumeArrToVolumesToMoveString = res;
  return;
end;

procedure VolumesToMoveStringToVolumeArr(string volumes_to_move,var array record EBSVolumeVc volume_arr)
begin
  LongInt pos,pos2;
  string 255 volume_to_move,volume_id,device_name;
  record EBSVolumeVc EBSVr;
  
  ClearArray(volume_arr);
  while (GetNextSubstring(volumes_to_move,pos,",",volume_to_move)) begin
    pos2 = -1;
    GetNextSubstring(volume_to_move,pos2,":",volume_id);
    GetNextSubstring(volume_to_move,pos2,":",device_name);
    EBSVr.VolumeId = volume_id;
    EBSVr.Device = device_name;
    volume_arr[volume_arr.length] = EBSVr;
  end;
  
  return;
end;

procedure StartRebuildOneNode(record CloudNodeActionQueueVc CNAQr)
begin
  record NodeRebuildVc NRr;
  uuid blank_uuid;
  time blank_tm;
  Boolean res;
  string 255 msg,vpc_id,subnet_id,group_id,volumes_to_move;
  record EC2InstanceVc EC2Ir,NewEC2Ir;
  record EC2AddressVc EC2Ar;
  record EC2AMIVc EC2AMIr;
  record EBSVolumeVc EBSVr;
  record CloudNodeVc CNr;
  record HostingConfigurationVc HCr;
  array record EC2SecurityGroupRuleVc EC2SGRr_arr;
  array record EBSVolumeVc volume_arr;
  LongInt aws_retries;
  Integer idx;
  
  if (!qupdating.RebuildOneNode_PrepareAction(CNAQr,NRr)) then begin
    goto LStartRebuildOneNode;
  end;
  
  if (!qupdating.RebuildOneNode_GetCloudNodeAndHostingConfig(CNr,HCr,NRr,CNAQr)) then begin
    goto LStartRebuildOneNode;
  end;

LStartRebuildOneNode_retry_getinstance:;
  res = GetEC2InstanceFromNode(NRr.Controller,"",EC2Ir,EC2Ar,msg);
  if (ShouldRetryAmazonAPICall("Couldn't get the instance information from AWS",res,msg,NRr,aws_retries)) then begin goto LStartRebuildOneNode_retry_getinstance; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LStartRebuildOneNode;
  end;
  
  qupdating.SetNodeRebuildRecInstanceId(NRr.SerNr,EC2Ir.InstanceId);
  
  if (nonblank(NRr.NewInstanceType)) then begin
LStartRebuildOneNode_retry_getvolumes:;
    res = ListEBSVolumesForInstance(EC2Ir,true,HCr.AmazonRegion,HCr.AmazonAccessKeyID,HCr.AmazonSecretAccessKey,volume_arr,msg);
    if (ShouldRetryAmazonAPICall("Couldn't get the instance volume information from AWS",res,msg,NRr,aws_retries)) then begin goto LStartRebuildOneNode_retry_getvolumes; end;
    if (res==false) then begin
      qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
      goto LStartRebuildOneNode;
    end;

    volumes_to_move = VolumeArrToVolumesToMoveString(EC2Ir,volume_arr);
    if (blank(volumes_to_move)) then begin
      qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"The node " & NRr.Controller & " was skipped because the node doesn't have any non-root volumes");
      goto LStartRebuildOneNode;
    end;
    qupdating.SetNodeRebuildRecVolumesToMove(NRr.SerNr,volumes_to_move);
  end;

LStartRebuildOneNode_retry_getvpc:;
  res = GetEC2ClassicVPCForNode(NRr.Controller,vpc_id,subnet_id,msg);
  if (ShouldRetryAmazonAPICall("Couldn't determine the VPC and subnet to use for the rebuild",res,msg,NRr,aws_retries)) then begin goto LStartRebuildOneNode_retry_getvpc; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LStartRebuildOneNode;
  end;

  if (nonblank(vpc_id)) then begin
    qupdating.SetNodeRebuildRecDestVPCId(NRr.SerNr,vpc_id,subnet_id,EC2Ir.MainSecurityGroupId);
  end;

  if (blank(EC2Ir.VPCId)) then begin
    qupdating.SetNodeRebuildRecFromEC2ClassicFlag(NRr.SerNr,1);
  end;
  
  if (nonblank(EC2Ar.PublicIP)) then begin
    qupdating.SetNodeRebuildRecElasticIP(NRr.SerNr,EC2Ar.PublicIP,EC2Ar.AllocationId);
  end;

  if (qupdating.ReadFirstNodeRebuildRec(NRr)==false) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    goto LStartRebuildOneNode;
  end;

  if (res and NRr.FromEC2ClassicFlag!=0) then begin
LStartRebuildOneNode_retry_getsgrules:;
    res = GetEC2SecurityGroupRulesForNode(NRr.Controller,EC2SGRr_arr,msg);
    if (ShouldRetryAmazonAPICall("Couldn't get the security group rules for the old instance",res,msg,NRr,aws_retries)) then begin goto LStartRebuildOneNode_retry_getsgrules; end;
    if (res==false) then begin
      qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
      goto LStartRebuildOneNode;
    end;
    
LStartRebuildOneNode_retry_createsg:;
    res = CreateEC2SecurityGroupForNode(NRr.Controller,EC2SGRr_arr,NRr.DestVPCId,NRr.DestSubnetId,group_id,msg);
    if (ShouldRetryAmazonAPICall("Couldn't create the new security group",res,msg,NRr,aws_retries)) then begin goto LStartRebuildOneNode_retry_createsg; end;
    if (res==false) then begin
      qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
      goto LStartRebuildOneNode;
    end else begin
      qupdating.SetNodeRebuildRecDestVPCId(NRr.SerNr,NRr.DestVPCId,NRr.DestSubnetId,group_id);
    end;
  end;

  if (blank(NRr.NewInstanceType)) then begin
LStartRebuildOneNode_retry_createpfami:;
    res = CreateEC2AMIFromNode(NRr.Controller,true,EC2AMIr,msg);
    if (ShouldRetryAmazonAPICall("Couldn't create the preflight image",res,msg,NRr,aws_retries)) then begin goto LStartRebuildOneNode_retry_createpfami; end;
    if (res==false) then begin
      qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
      goto LStartRebuildOneNode;
    end;

    qupdating.SetNodeRebuildRecPreflightAMIId(NRr.SerNr,EC2AMIr.ImageId);
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionRebuildNodePreflight,blank_uuid,0,NRr.SerNr,blank_tm,blank_tm);
    qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Creating preflight AMI " & EC2AMIr.ImageId);
  end else begin
    group_id = NRr.DestSecGroupId;
    if (blank(group_id)) then begin
      group_id = EC2Ir.MainSecurityGroupId;
    end;
LStartRebuildOneNode_retry_launchinst:;
    qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Launching new EC2 instance of type " & NRr.NewInstanceType);
    res = LaunchEC2InstanceForNodeFromAMI(NRr.Controller,"",NRr.NewInstanceType,group_id,NRr.DestSubnetId,NewEC2Ir,msg);
    if (ShouldRetryAmazonAPICall("Couldn't launch the new instance",res,msg,NRr,aws_retries)) then begin goto LStartRebuildOneNode_retry_launchinst; end;
    if (res==false) then begin
      qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
      goto LStartRebuildOneNode;
    end;

    qupdating.SetNodeRebuildRecNewInstanceId(NRr.SerNr,NewEC2Ir.InstanceId);
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionRebuildNodePrepareVersions,blank_uuid,0,NRr.SerNr,blank_tm,blank_tm);
    qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Waiting for cloud node " & CNr.Code & " to prepare versions");
  end;

LStartRebuildOneNode:;
  return;
end;
procedure PrepareVersionsRebuildOneNode(record CloudNodeActionQueueVc CNAQr)
begin
  record NodeRebuildVc NRr;
  uuid blank_uuid;
  time blank_tm;
  Boolean res,scfailf;
  string 255 url;
  record EC2InstanceTypeVc EC2ITr;
  record CloudNodeVc CNr;
  record HostingConfigurationVc HCr;
  Integer platform,cnt,stat;
  
  if (!qupdating.RebuildOneNode_PrepareAction(CNAQr,NRr)) then begin
    goto LPrepareVersionsRebuildOneNode;
  end;
  
  if (!qupdating.RebuildOneNode_GetCloudNodeAndHostingConfig(CNr,HCr,NRr,CNAQr)) then begin
    goto LPrepareVersionsRebuildOneNode;
  end;

  EC2ITr.InstanceType = NRr.NewInstanceType;
  EC2ITr.Region = HCr.AmazonRegion;
  if (ReadFirstMain(EC2ITr,2,true)==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"Invalid instance type: " & NRr.NewInstanceType & " (in region: " & HCr.AmazonRegion & ")");
    goto LPrepareVersionsRebuildOneNode;
  end;
  
  switch (ArchitectureFromEC2InstanceType(EC2ITr)) begin
    case "arm64":   platform = kPlatformLinuxArm64;
    case "x86_64":  platform = kPlatformLinux64;
    otherwise
  end;

  url = NodeURL(CNr);
  if (blank(url)) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"Invalid node URL: " & url);
    goto LPrepareVersionsRebuildOneNode;
  end;

  stat = CallService(url).SetupVersionsForPlatform(platform,cnt);
  scfailf = TreatServiceError(stat,url,"SetupVersionsForPlatform");
  queued.SaveCloudNodeReachable(CNr.Code,!scfailf);
  if (scfailf) then begin
    if (stat==kCallServiceCommError) then begin
      qupdating.AddLineToNodeRebuildLog(NRr,"Failed calling node " & CNr.Code & ", retrying...");
    end else begin
      qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"Failed calling node " & CNr.Code & ", stat=" & stat & ", giving up");
      goto LPrepareVersionsRebuildOneNode;
    end;
    goto LPrepareVersionsRebuildOneNode;
  end;

  if (cnt>0) then begin
    qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Waiting for cloud node " & CNr.Code & " to prepare " & cnt & " versions");
    goto LPrepareVersionsRebuildOneNode;
  end;
  
  qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
  qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionRebuildNodeStopHost,blank_uuid,0,NRr.SerNr,blank_tm,blank_tm);
  qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Waiting for new EC2 instance " & NRr.NewInstanceId & " of type " & NRr.NewInstanceType & " to come online");

LPrepareVersionsRebuildOneNode:;
  return;
end;

procedure StopHostRebuildOneNode(record CloudNodeActionQueueVc CNAQr)
begin
  record NodeRebuildVc NRr;
  uuid blank_uuid;
  time blank_tm;
  Boolean res;
  string 255 msg;
  record CloudNodeVc CNr;
  record HostingConfigurationVc HCr;
  record EC2AMIVc EC2AMIr;
  record EC2InstanceVc EC2Ir,NewEC2Ir;
  record EC2AddressVc EC2Ar;
  LongInt aws_retries;

  if (!qupdating.RebuildOneNode_PrepareAction(CNAQr,NRr)) then begin
    goto LStopHostRebuildOneNode;
  end;

LStopHostRebuildOneNode_retry_getnewinst:;
  res = GetEC2InstanceFromNode(NRr.Controller,NRr.NewInstanceId,NewEC2Ir,EC2Ar,msg);
  if (ShouldRetryAmazonAPICall("Couldn't get the instance description for the new instance " & NRr.NewInstanceId,res,msg,NRr,aws_retries)) then begin goto LStopHostRebuildOneNode_retry_getnewinst; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LStopHostRebuildOneNode;
  end;

  if (NewEC2Ir.State!="running") then begin goto LStopHostRebuildOneNode; end;
  
  qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Stopping EC2 instance " & NRr.InstanceId);
  qupdating.SetCloudNodeState(NRr.Controller,true,false,kCloudNodeStateModifying);

LStopHostRebuildOneNode_retry_getinst:;
  res = GetEC2InstanceFromNode(NRr.Controller,NRr.InstanceId,EC2Ir,EC2Ar,msg);
  if (ShouldRetryAmazonAPICall("Couldn't get the instance description for the new instance " & NRr.InstanceId,res,msg,NRr,aws_retries)) then begin goto LStopHostRebuildOneNode_retry_getinst; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LStopHostRebuildOneNode;
  end;

  if (!qupdating.RebuildOneNode_GetCloudNodeAndHostingConfig(CNr,HCr,NRr,CNAQr)) then begin
    goto LStopHostRebuildOneNode;
  end;

LStopHostRebuildOneNode_retry_stopinstance:;
  res = StopEC2Instance(HCr,EC2Ir,false,msg);
  if (ShouldRetryAmazonAPICall("Couldn't stop the old instance",res,msg,NRr,aws_retries)) then begin goto LStopHostRebuildOneNode_retry_stopinstance; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LStopHostRebuildOneNode;
  end;

  qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
  qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionRebuildNodeDetachDisks,blank_uuid,0,NRr.SerNr,blank_tm,blank_tm);

LStopHostRebuildOneNode:;
  return;
end;

procedure DetachDisksRebuildOneNode(record CloudNodeActionQueueVc CNAQr)
begin
  record NodeRebuildVc NRr;
  uuid blank_uuid;
  time blank_tm;
  Boolean res;
  string 255 msg;
  record CloudNodeVc CNr;
  record HostingConfigurationVc HCr;
  record EC2InstanceVc EC2Ir,NewEC2Ir;
  record EC2AddressVc EC2Ar;
  record EBSVolumeVc EBSVr;
  LongInt aws_retries;
  array record EBSVolumeVc volume_arr;
  Integer idx;

  if (!qupdating.RebuildOneNode_PrepareAction(CNAQr,NRr)) then begin
    goto LDetachDisksRebuildOneNode;
  end;

LDetachDisksRebuildOneNode_retry_getinst:;
  res = GetEC2InstanceFromNode(NRr.Controller,NRr.InstanceId,EC2Ir,EC2Ar,msg);
  if (ShouldRetryAmazonAPICall("Couldn't get the instance description for the new instance " & NRr.InstanceId,res,msg,NRr,aws_retries)) then begin goto LDetachDisksRebuildOneNode_retry_getinst; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LDetachDisksRebuildOneNode;
  end;
  
  if (EC2Ir.State!="stopped") then begin goto LDetachDisksRebuildOneNode; end;
  
  qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Detaching disks from EC2 instance " & EC2Ir.InstanceId);

LDetachDisksRebuildOneNode_retry_getnewinst:;
  res = GetEC2InstanceFromNode(NRr.Controller,NRr.NewInstanceId,NewEC2Ir,EC2Ar,msg);
  if (ShouldRetryAmazonAPICall("Couldn't get the instance description for the new instance " & NRr.NewInstanceId,res,msg,NRr,aws_retries)) then begin goto LDetachDisksRebuildOneNode_retry_getnewinst; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LDetachDisksRebuildOneNode;
  end;

  if (!qupdating.RebuildOneNode_GetCloudNodeAndHostingConfig(CNr,HCr,NRr,CNAQr)) then begin
    goto LDetachDisksRebuildOneNode;
  end;

  VolumesToMoveStringToVolumeArr(NRr.VolumesToMove,volume_arr);
  for (idx = 0; idx<volume_arr.length; idx = idx + 1) begin
    EBSVr = volume_arr[idx];
LDetachDisksRebuildOneNode_retry_detachvolume:;
    res = DetachEBSVolume(EBSVr,false,HCr.AmazonRegion,HCr.AmazonAccessKeyID,HCr.AmazonSecretAccessKey,msg);
    if (ShouldRetryAmazonAPICall("Couldn't detach the volume " & EBSVr.VolumeId & " from instance " & NRr.InstanceId,res,msg,NRr,aws_retries)) then begin goto LDetachDisksRebuildOneNode_retry_detachvolume; end;
    if (res==false) then begin
      qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
      goto LDetachDisksRebuildOneNode;
    end;
  end;

  qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
  qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionRebuildNodeReassignIP,blank_uuid,0,NRr.SerNr,blank_tm,blank_tm);

LDetachDisksRebuildOneNode:;
  return;
end;

procedure ReassignIPRebuildOneNode(record CloudNodeActionQueueVc CNAQr)
begin
  record NodeRebuildVc NRr;
  uuid blank_uuid;
  time blank_tm;
  Boolean res;
  string 255 msg;
  record CloudNodeVc CNr;
  record HostingConfigurationVc HCr;
  record EC2InstanceVc NewEC2Ir;
  record EC2AddressVc EC2Ar;
  LongInt aws_retries;
  
  if (!qupdating.RebuildOneNode_PrepareAction(CNAQr,NRr)) then begin
    goto LReassignIPRebuildOneNode;
  end;

  if (!qupdating.RebuildOneNode_GetCloudNodeAndHostingConfig(CNr,HCr,NRr,CNAQr)) then begin
    goto LReassignIPRebuildOneNode;
  end;

  if (nonblank(NRr.ElasticIP)) then begin
    qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Assigning elastic ip " & NRr.ElasticIP & " to new instance " & NRr.NewInstanceId);
    
LReassignIPRebuildOneNode_retry_assip:;
    res = AssociateAddressToNode(NRr.Controller,NRr.NewInstanceId,NRr.EIPAllocationId,msg);
    if (ShouldRetryAmazonAPICall("Couldn't associate the elastic IP to the instance",res,msg,NRr,aws_retries)) then begin goto LReassignIPRebuildOneNode_retry_assip; end;
    if (res==false) then begin
      qupdating.SetNodeRebuildRecFailedFlag(NRr.SerNr,1);
      goto LReassignIPRebuildOneNode;
    end;
    
LReassignIPRebuildOneNode_retry_getinst2:;
    res = GetEC2InstanceFromNode(NRr.Controller,NRr.NewInstanceId,NewEC2Ir,EC2Ar,msg);
    if (ShouldRetryAmazonAPICall("Couldn't get the instance description for instance " & NRr.NewInstanceId,res,msg,NRr,aws_retries)) then begin goto LReassignIPRebuildOneNode_retry_getinst2; end;
    if (res==false) then begin
      qupdating.SetNodeRebuildRecFailedFlag(NRr.SerNr,1);
      goto LReassignIPRebuildOneNode;
    end;
  end;

  qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
  qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionRebuildNodeAttachDisks,blank_uuid,0,NRr.SerNr,blank_tm,blank_tm);

LReassignIPRebuildOneNode:;
  return;
end;

procedure AttachDisksRebuildOneNode(record CloudNodeActionQueueVc CNAQr)
begin
  record NodeRebuildVc NRr;
  uuid blank_uuid;
  time blank_tm;
  Boolean res;
  string 255 msg;
  record CloudNodeVc CNr;
  record HostingConfigurationVc HCr;
  record EC2InstanceVc NewEC2Ir;
  record EC2AddressVc EC2Ar;
  record EBSVolumeVc EBSVr;
  LongInt aws_retries;
  Boolean detachingf;
  array record EBSVolumeVc volume_arr;
  Integer idx;
  
  if (!qupdating.RebuildOneNode_PrepareAction(CNAQr,NRr)) then begin
    goto LAttachDisksRebuildOneNode;
  end;

  if (!qupdating.RebuildOneNode_GetCloudNodeAndHostingConfig(CNr,HCr,NRr,CNAQr)) then begin
    goto LAttachDisksRebuildOneNode;
  end;

  VolumesToMoveStringToVolumeArr(NRr.VolumesToMove,volume_arr);
  res = GetEBSVolumes(volume_arr,HCr.AmazonRegion,HCr.AmazonAccessKeyID,HCr.AmazonSecretAccessKey,msg);
  if (ShouldRetryAmazonAPICall("Couldn't attach volumes to the new instance " & NRr.NewInstanceId & ", because the volume states couldn't be read",res,msg,NRr,aws_retries)) then begin goto LAttachDisksRebuildOneNode_retry_attachvolume; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LAttachDisksRebuildOneNode;
  end;

  for (idx = 0; idx<volume_arr.length; idx = idx + 1) begin
    EBSVr = volume_arr[idx];
    if (EBSVr.Status=="detaching") then begin
      detachingf = true;
    end else begin
      if (EBSVr.Status!="available") then begin
        qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"Invalid status of volume " & EBSVr.VolumeId & ": " & EBSVr.Status);
        goto LAttachDisksRebuildOneNode;
      end;
    end;
  end;
  
  if (detachingf) then begin goto LAttachDisksRebuildOneNode; end;

  qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Attaching disks from EC2 instance " & NRr.NewInstanceId);

LAttachDisksRebuildOneNode_retry_getnewinst:;
  res = GetEC2InstanceFromNode(NRr.Controller,NRr.NewInstanceId,NewEC2Ir,EC2Ar,msg);
  if (ShouldRetryAmazonAPICall("Couldn't get the instance description for the new instance " & NRr.NewInstanceId,res,msg,NRr,aws_retries)) then begin goto LAttachDisksRebuildOneNode_retry_getnewinst; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LAttachDisksRebuildOneNode;
  end;

  VolumesToMoveStringToVolumeArr(NRr.VolumesToMove,volume_arr);
  for (idx = 0; idx<volume_arr.length; idx = idx + 1) begin
    EBSVr = volume_arr[idx];
LAttachDisksRebuildOneNode_retry_attachvolume:;
    res = AttachEBSVolume(EBSVr,NewEC2Ir,HCr.AmazonRegion,HCr.AmazonAccessKeyID,HCr.AmazonSecretAccessKey,msg);
    if (ShouldRetryAmazonAPICall("Couldn't attach the volume " & EBSVr.VolumeId & " to instance " & NRr.NewInstanceId,res,msg,NRr,aws_retries)) then begin goto LAttachDisksRebuildOneNode_retry_attachvolume; end;
    if (res==false) then begin
      qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
      goto LAttachDisksRebuildOneNode;
    end;
  end;

  qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
  qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionRebuildNodeCleanup,blank_uuid,0,NRr.SerNr,blank_tm,blank_tm);
  qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Waiting for node " & NRr.Controller & " to come online");

LAttachDisksRebuildOneNode:;
  return;
end;

procedure PreflightRebuildOneNode(record CloudNodeActionQueueVc CNAQr)
begin
  record NodeRebuildVc NRr;
  uuid blank_uuid;
  time blank_tm;
  Boolean res;
  string 255 msg;
  record CloudNodeVc CNr;
  record HostingConfigurationVc HCr;
  record EC2AMIVc EC2AMIr;
  record EC2InstanceVc EC2Ir;
  record EC2AddressVc EC2Ar;
  LongInt aws_retries;

  if (!qupdating.RebuildOneNode_PrepareAction(CNAQr,NRr)) then begin
    goto LPreflightRebuildOneNode;
  end;
  
LPreflightRebuildOneNode_retry_getami:;
  res = GetEC2AMIForNode(NRr.Controller,NRr.PreflightAMIId,EC2AMIr,msg);
  if (ShouldRetryAmazonAPICall("Couldn't get the preflight image information for " & NRr.PreflightAMIId,res,msg,NRr,aws_retries)) then begin goto LPreflightRebuildOneNode_retry_getami; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LPreflightRebuildOneNode;
  end;

  switch (EC2AMIr.ImageState) begin
    case "pending": goto LPreflightRebuildOneNode; //TODO really should schedule the task into the future instead of checking every second
    case "available":
    otherwise
      qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"The AMI " & NRr.PreflightAMIId & " could not be created, AMI state is " & EC2AMIr.ImageState);
      goto LPreflightRebuildOneNode;
  end;

LPreflightRebuildOneNode_retry_getinstance:;
  res = GetEC2InstanceFromNode(NRr.Controller,"",EC2Ir,EC2Ar,msg);
  if (ShouldRetryAmazonAPICall("Couldn't get the instance information from AWS",res,msg,NRr,aws_retries)) then begin goto LPreflightRebuildOneNode_retry_getinstance; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LPreflightRebuildOneNode;
  end;
  
  if (!qupdating.RebuildOneNode_GetCloudNodeAndHostingConfig(CNr,HCr,NRr,CNAQr)) then begin
    goto LPreflightRebuildOneNode;
  end;

  qupdating.SetCloudNodeState(NRr.Controller,false,false,kCloudNodeStateModifying);
  
LPreflightRebuildOneNode_retry_stopinstance:;
  res = StopEC2Instance(HCr,EC2Ir,false,msg);
  if (ShouldRetryAmazonAPICall("Couldn't stop the old instance",res,msg,NRr,aws_retries)) then begin goto LPreflightRebuildOneNode_retry_stopinstance; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LPreflightRebuildOneNode;
  end;
  
  qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
  qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionRebuildNodeCreateAMI,blank_uuid,0,NRr.SerNr,blank_tm,blank_tm);
  qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Stopping instance " & NRr.InstanceId);

LPreflightRebuildOneNode:;
  return;
end;

procedure CreateAMIRebuildOneNode(record CloudNodeActionQueueVc CNAQr)
begin
  record NodeRebuildVc NRr;
  uuid blank_uuid;
  time blank_tm;
  Boolean res;
  string 255 msg;
  record EC2AMIVc EC2AMIr;
  record EC2InstanceVc EC2Ir;
  record EC2AddressVc EC2Ar;
  LongInt aws_retries;

  if (!qupdating.RebuildOneNode_PrepareAction(CNAQr,NRr)) then begin
    goto LCreateAMIRebuildOneNode;
  end;

LPreflightRebuildOneNode_retry_getinstance2:;
  res = GetEC2InstanceFromNode(NRr.Controller,"",EC2Ir,EC2Ar,msg);
  if (ShouldRetryAmazonAPICall("Couldn't get the old instance description",res,msg,NRr,aws_retries)) then begin goto LPreflightRebuildOneNode_retry_getinstance2; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LCreateAMIRebuildOneNode;
  end;

  if (EC2Ir.State!="stopped") then begin goto LCreateAMIRebuildOneNode; end;

LPreflightRebuildOneNode_retry_createami:;
  res = CreateEC2AMIFromNode(NRr.Controller,false,EC2AMIr,msg);
  if (ShouldRetryAmazonAPICall("Couldn't create the new image",res,msg,NRr,aws_retries)) then begin goto LPreflightRebuildOneNode_retry_createami; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LCreateAMIRebuildOneNode;
  end;

  qupdating.SetNodeRebuildRecAMIId(NRr.SerNr,EC2AMIr.ImageId);
  qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
  qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionRebuildNodeRestore,blank_uuid,0,NRr.SerNr,blank_tm,blank_tm);
  qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Creating AMI " & EC2AMIr.ImageId);

LCreateAMIRebuildOneNode:;
  return;
end;

procedure RestoreAMIRebuildOneNode(record CloudNodeActionQueueVc CNAQr)
begin
  record NodeRebuildVc NRr;
  uuid blank_uuid;
  time blank_tm;
  Boolean res;
  string 255 msg,new_instance_type,sg_id;
  record EC2AMIVc EC2AMIr;
  record EC2InstanceVc EC2Ir;
  record EC2AddressVc EC2Ar;
  LongInt aws_retries;

  if (!qupdating.RebuildOneNode_PrepareAction(CNAQr,NRr)) then begin
    goto LRestoreAMIRebuildOneNode;
  end;

LRestoreAMIRebuildOneNode_retry_getinstance:;
  res = GetEC2InstanceFromNode(NRr.Controller,"",EC2Ir,EC2Ar,msg);
  if (ShouldRetryAmazonAPICall("Couldn't get the instance information",res,msg,NRr,aws_retries)) then begin goto LRestoreAMIRebuildOneNode_retry_getinstance; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LRestoreAMIRebuildOneNode;
  end;

LRestoreAMIRebuildOneNode_retry_getami:;
  res = GetEC2AMIForNode(NRr.Controller,NRr.AMIId,EC2AMIr,msg);
  if (ShouldRetryAmazonAPICall("Couldn't get the new image's description " & NRr.AMIId,res,msg,NRr,aws_retries)) then begin goto LRestoreAMIRebuildOneNode_retry_getami; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LRestoreAMIRebuildOneNode;
  end;

  switch (EC2AMIr.ImageState) begin
    case "pending": goto LRestoreAMIRebuildOneNode; //TODO really should schedule the task into the future instead of checking every second
    case "available":
    otherwise
      qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"The AMI " & NRr.AMIId & " could not be created, AMI state is " & EC2AMIr.ImageState);
      goto LRestoreAMIRebuildOneNode;
  end;

LRestoreAMIRebuildOneNode_retry_launchinst:;
  new_instance_type = EC2Ir.Type;
//  if (nonblank(NRr.NewInstanceType)) then begin
//    new_instance_type = NRr.NewInstanceType;
//  end;
  sg_id = NRr.DestSecGroupId;
  if (blank(sg_id)) then begin
    sg_id = EC2Ir.MainSecurityGroupId;
  end;
  res = LaunchEC2InstanceForNodeFromAMI(NRr.Controller,NRr.AMIId,new_instance_type,sg_id,NRr.DestSubnetId,EC2Ir,msg);
  if (ShouldRetryAmazonAPICall("Couldn't launch the new instance from the AMI " & NRr.AMIId,res,msg,NRr,aws_retries)) then begin goto LRestoreAMIRebuildOneNode_retry_launchinst; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LRestoreAMIRebuildOneNode;
  end;
  
  qupdating.SetNodeRebuildRecNewInstanceId(NRr.SerNr,EC2Ir.InstanceId);
  qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);

  if ((NRr.FromEC2ClassicFlag!=0) and nonblank(NRr.ElasticIP)) then begin
    qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionRebuildNodeMigrateIP,blank_uuid,0,NRr.SerNr,blank_tm,blank_tm);
  end else begin
    qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionRebuildNodeCleanup,blank_uuid,0,NRr.SerNr,blank_tm,blank_tm);
  end;

  qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Creating new host for node " & NRr.Controller & " with AMI " & NRr.AMIId);

LRestoreAMIRebuildOneNode:;
  return;
end;

procedure MigrateIPRebuildOneNode(record CloudNodeActionQueueVc CNAQr)
begin
  record NodeRebuildVc NRr;
  uuid blank_uuid;
  time blank_tm;
  Boolean res;
  string 255 msg;
  record EC2AMIVc EC2AMIr;
  record EC2InstanceVc EC2Ir;
  record EC2AddressVc EC2Ar;
  LongInt aws_retries;

  if (!qupdating.RebuildOneNode_PrepareAction(CNAQr,NRr)) then begin
    goto LMigrateIPRebuildOneNode;
  end;
  
LMigrateIPRebuildOneNode_retry_getinst:;
  res = GetEC2InstanceFromNode(NRr.Controller,NRr.NewInstanceId,EC2Ir,EC2Ar,msg);
  if (ShouldRetryAmazonAPICall("Couldn't get the instance description for the new instance " & NRr.NewInstanceId,res,msg,NRr,aws_retries)) then begin goto LMigrateIPRebuildOneNode_retry_getinst; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LMigrateIPRebuildOneNode;
  end;

  if (EC2Ir.State!="running") then begin goto LMigrateIPRebuildOneNode; end;

LMigrateIPRebuildOneNode_retry_moveip:;
  res = MoveAddressToVPCForNode(NRr.Controller,NRr.ElasticIP,EC2Ar,msg);
  if (ShouldRetryAmazonAPICall("Couldn't move the elastic IP to the VPC",res,msg,NRr,aws_retries)) then begin goto LMigrateIPRebuildOneNode_retry_moveip; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LMigrateIPRebuildOneNode;
  end;
  
  qupdating.SetNodeRebuildRecElasticIP(NRr.SerNr,NRr.ElasticIP,EC2Ar.AllocationId);
  
  qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
  qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionRebuildNodeCleanup,blank_uuid,0,NRr.SerNr,blank_tm,blank_tm);
  qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Cleaning up");

LMigrateIPRebuildOneNode:;
  return;
end;

procedure CleanupRebuildOneNode(record CloudNodeActionQueueVc CNAQr)
begin
  record NodeRebuildVc NRr;
  uuid blank_uuid;
  time blank_tm,planned_tm;
  date planned_dt;
  Boolean res,skip_terminatef,delay_cleanupf;
  string 255 msg,tstr;
  record EC2AMIVc EC2AMIr;
  record EC2InstanceVc EC2Ir,NewEC2Ir;
  record EC2AddressVc EC2Ar;
  record CloudNodeVc CNr;
  record HostingConfigurationVc HCr;
  array record EBSSnapshotVc snapshot_arr,preflight_snapshot_arr;
  record EBSSnapshotVc EBSSr;
  LongInt idx;
  LongInt aws_retries;

  if (!qupdating.RebuildOneNode_PrepareAction(CNAQr,NRr)) then begin
    goto LCleanupRebuildOneNode;
  end;
  
  if (blankdate(CNAQr.PlannedDate)) then begin
    delay_cleanupf = true;
  end;
  
LCleanupRebuildOneNode_retry_getoldinst:;
  res = GetEC2InstanceFromNode(NRr.Controller,NRr.InstanceId,EC2Ir,EC2Ar,msg);
  if (ShouldRetryAmazonAPICall("Couldn't get the instance description for the old instance " & NRr.InstanceId,res,msg,NRr,aws_retries)) then begin goto LCleanupRebuildOneNode_retry_getoldinst; end;
  if (res==false) then begin
    qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
    goto LCleanupRebuildOneNode;
  end;

  if (delay_cleanupf==true) then begin
LCleanupRebuildOneNode_retry_getinst:;
    res = GetEC2InstanceFromNode(NRr.Controller,NRr.NewInstanceId,NewEC2Ir,EC2Ar,msg);
    if (ShouldRetryAmazonAPICall("Couldn't get the instance description for the new instance " & NRr.NewInstanceId,res,msg,NRr,aws_retries)) then begin goto LCleanupRebuildOneNode_retry_getinst; end;
    if (res==false) then begin
      qupdating.RebuildOneNode_CancelActionAndFail(CNAQr,NRr,"");
      goto LCleanupRebuildOneNode;
    end;
  end;

  if (!qupdating.RebuildOneNode_GetCloudNodeAndHostingConfig(CNr,HCr,NRr,CNAQr)) then begin
    goto LCleanupRebuildOneNode;
  end;
  
  if (delay_cleanupf==true) then begin
    if (CNr.CurrentState==kCloudNodeStateModifying) then begin
      qupdating.SetCloudNodeState(NRr.Controller,true,false,kCloudNodeStateStarting);
      qupdating.DoCheckCloudNode(CNr,false);
    end;

    if (NewEC2Ir.State!="running") then begin goto LCleanupRebuildOneNode; end;

    if (blank(NRr.NewInstanceType) and nonblank(NRr.ElasticIP)) then begin
LCleanupRebuildOneNode_retry_assip:;
      res = AssociateAddressToNode(NRr.Controller,NRr.NewInstanceId,NRr.EIPAllocationId,msg);
      if (ShouldRetryAmazonAPICall("Couldn't associate the elastic IP to the instance",res,msg,NRr,aws_retries)) then begin goto LCleanupRebuildOneNode_retry_assip; end;
      if (res==false) then begin
        qupdating.SetNodeRebuildRecFailedFlag(NRr.SerNr,1);
        skip_terminatef = true;
      end;
LCleanupRebuildOneNode_retry_getinst2:;
      res = GetEC2InstanceFromNode(NRr.Controller,NRr.NewInstanceId,NewEC2Ir,EC2Ar,msg);
      if (ShouldRetryAmazonAPICall("Couldn't get the instance description for instance " & NRr.NewInstanceId,res,msg,NRr,aws_retries)) then begin goto LCleanupRebuildOneNode_retry_getinst2; end;
      if (res==false) then begin
        qupdating.SetNodeRebuildRecFailedFlag(NRr.SerNr,1);
        skip_terminatef = true;
      end;
    end;

    qupdating.SetCloudNodeState(NRr.Controller,false,true,kCloudNodeStateNormal);
    qupdating.UpdateCloudNodeInstanceInfo(CNr,NewEC2Ir,EC2Ar);
    
    planned_tm = CurrentTime;
    planned_dt = AddDay(CurrentDate,7);
    tstr = "Node is ready - cleanup scheduled for " & DateToString(planned_dt,"YYYY-MM-DD") & " ";
    tstr = tstr & TimeToString(planned_tm,"HH",false) & ":" & TimeToString(planned_tm,"MM",false);
    tstr = tstr & ", revert is possible";
    
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,tstr);
    qupdating.QueueOnePlannedCloudNodeAction(-1,CNAQr.MotherAction,CNAQr.Action,CNAQr.UUIDParam1,
                                             CNAQr.IntParam1,CNAQr.LongParam1,blank_tm,blank_tm,planned_dt,planned_tm);
    goto LCleanupRebuildOneNode;
  end;

  qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Cleaning up");

  if (nonblank(NRr.PreflightAMIId)) then begin
    if (ListEBSSnapshotsForAMI(NRr.Controller,NRr.PreflightAMIId,preflight_snapshot_arr,msg)==false) then begin
      if (nonblank(msg)) then begin
        qupdating.AddLineToNodeRebuildLog(NRr,"Error:");
        qupdating.AddLineToNodeRebuildLog(NRr,msg);
        skip_terminatef = true;
      end;
    end;
  end;

  if (nonblank(NRr.AMIId)) then begin
    if (ListEBSSnapshotsForAMI(NRr.Controller,NRr.AMIId,snapshot_arr,msg)) then begin
      if (nonblank(msg)) then begin
        qupdating.AddLineToNodeRebuildLog(NRr,"Error:");
        qupdating.AddLineToNodeRebuildLog(NRr,msg);
        skip_terminatef = true;
      end;
    end;
  end;

  if (nonblank(NRr.PreflightAMIId)) then begin
    DeleteEC2AMIForNode(NRr.Controller,NRr.PreflightAMIId,msg);
    if (nonblank(msg)) then begin
      qupdating.AddLineToNodeRebuildLog(NRr,"Error:");
      qupdating.AddLineToNodeRebuildLog(NRr,msg);
      skip_terminatef = true;
    end;
  end;
  
  if (nonblank(NRr.AMIId)) then begin
    DeleteEC2AMIForNode(NRr.Controller,NRr.AMIId,msg);
    if (nonblank(msg)) then begin
      qupdating.AddLineToNodeRebuildLog(NRr,"Error:");
      qupdating.AddLineToNodeRebuildLog(NRr,msg);
      skip_terminatef = true;
    end;
  end;

  for (idx = 0; idx<preflight_snapshot_arr.length; idx = idx + 1) begin
    EBSSr = preflight_snapshot_arr[idx];
    DeleteEBSSnapshotForNode(NRr.Controller,EBSSr.SnapshotId,msg);
    if (nonblank(msg)) then begin
      qupdating.AddLineToNodeRebuildLog(NRr,"Error:");
      qupdating.AddLineToNodeRebuildLog(NRr,msg);
      skip_terminatef = true;
    end;
  end;
  
  for (idx = 0; idx<snapshot_arr.length; idx = idx + 1) begin
    EBSSr = snapshot_arr[idx];
    DeleteEBSSnapshotForNode(NRr.Controller,EBSSr.SnapshotId,msg);
    if (nonblank(msg)) then begin
      qupdating.AddLineToNodeRebuildLog(NRr,"Error:");
      qupdating.AddLineToNodeRebuildLog(NRr,msg);
      skip_terminatef = true;
    end;
  end;

  if (!skip_terminatef) then begin
LCleanupRebuildOneNode_retry_terminateinst:;
    res = TerminateEC2InstanceAndResources(HCr.AmazonRegion,HCr.AmazonAccessKeyID,HCr.AmazonSecretAccessKey,EC2Ir,true,false,msg);
    if (ShouldRetryAmazonAPICall("Couldn't terminate the old instance " & EC2Ir.InstanceId,res,msg,NRr,aws_retries)) then begin goto LCleanupRebuildOneNode_retry_terminateinst; end;
    if (res==false) then begin
      qupdating.SetNodeRebuildRecFailedFlag(NRr.SerNr,1);
      if (nonblank(msg)) then begin
        qupdating.AddLineToNodeRebuildLog(NRr,"Error:");
        qupdating.AddLineToNodeRebuildLog(NRr,msg);
      end;
      qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Node ready - cleanup failed to terminate the old instance");
    end else begin
      qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"All operations completed successfully");
    end;
  end else begin
    qupdating.SetNodeRebuildRecCurrentStatus(NRr.SerNr,"Node ready - cleanup failed");
  end;

  qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
  qupdating.SetNodeRebuildRecDoneFlag(NRr.SerNr,1);

LCleanupRebuildOneNode:;
  return;
end;

procedure StartMoveOneServerToOtherNode(record CloudNodeActionQueueVc CNAQr)
begin
  record RemoteCloudServerVc RCSr,RCS2r;
  record ServerMoveVc SMr;
  record CloudNodeVc CNr;
  string 255 url;
  Integer stat;

  SMr.SerNr = CNAQr.LongParam1;
  if (qupdating.ReadFirstServerMoveRec(SMr)==false) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    goto LStartMoveOneServerToOtherNode;
  end;

  if (SMr.PausedFlag!=0) then begin goto LStartMoveOneServerToOtherNode; end; // Note: We'll process the End and Finish events even if we're paused

  if (SMr.PendingServerCount>1) then begin // only move two servers at a time
    goto LStartMoveOneServerToOtherNode;
  end;

  if (BlankUUID(CNAQr.UUIDParam1)) begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveFailedCount(SMr);
    qupdating.AddLineToServerMoveLog(SMr,"A server with blank UUID was skipped");
    goto LStartMoveOneServerToOtherNode;
  end;

  RCSr.UUID = CNAQr.UUIDParam1;
  if (qupdating.GetRCSOnMainThread(RCSr)==false) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveFailedCount(SMr);
    qupdating.AddLineToServerMoveLog(SMr,"The server with UUID " & CNAQr.UUIDParam1 & " was skipped because the record doesn't exist");
    goto LStartMoveOneServerToOtherNode;
  end;
  
  if (SMr.DoneFlag!=0) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveFailedCount(SMr);
    qupdating.AddLineToServerMoveLog(SMr,"The server " & RCSName(RCSr) & " was skipped because the server move operation was marked as done");
    goto LStartMoveOneServerToOtherNode;
  end;
  
  if (RCSr.Closed!=0) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveClosedCount(SMr);
    qupdating.UpdateRCSController(RCSr,SMr.ToController);
    goto LStartMoveOneServerToOtherNode;
  end;

  url = RcsNodeURL(RCSr);
  if (blank(url)) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveFailedCount(SMr);
    qupdating.AddLineToServerMoveLog(SMr,"The server " & RCSName(RCSr) & " was skipped because the cloud node address is invalid");
    goto LStartMoveOneServerToOtherNode;
  end;

  if (blank(trim(RCSr.DataFolder))) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveFailedCount(SMr);
    qupdating.AddLineToServerMoveLog(SMr,"The server " & RCSName(RCSr) & " was skipped because it has blank data folder path");
    goto LStartMoveOneServerToOtherNode;
  end;

  CNr.Code = RCSr.Controller;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveFailedCount(SMr);
    qupdating.AddLineToServerMoveLog(SMr,"The server " & RCSName(RCSr) & " was skipped because the cloud node record doesn't exist");
    goto LStartMoveOneServerToOtherNode;
  end;
  
  if (CloudNodeStatus(CNr)!=kCloudNodeStatusReachable) then begin goto LStartMoveOneServerToOtherNode; end;

  if (HasChildSystemInSubfolder(RCSr)) then begin
    qupdating.FixupMoveOfChildSystemsInSubfolder(SMr,RCSr);
    goto LStartMoveOneServerToOtherNode; // We delay the move until all child systems in the same folder have been moved
  end;

  if (IsChildSystemOfClosedSystem(RCSr)) then begin
    qupdating.DoCloseRemoteCloudServer(RCSr);
    stat = CallService(url).ForceDeleteLCS(RCSr.UUID);
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveClosedCount(SMr);
    goto LStartMoveOneServerToOtherNode;
  end;

  if (IsChildSystemInSubfolder(RCSr)) then begin
    if ((RCSr.CurrentStatus!=kStatusStopped) and (RCSr.CurrentStatus!=kStatusConfigInError)) then begin
      qupdating.SetServerRetainRecordDatesFlag(RCSr.UUID,1);
      if (IsMinutesPastTime(CNAQr.QueuedDate,CNAQr.QueuedTime,CurrentDate,CurrentTime,30)) then begin
        // We gave the server 30 minutes to stop, let's give up
        qupdating.ForceStopRemoteCloudServer(RCSr);
      end else begin
        qupdating.StopRemoteCloudServer(RCSr,false);
      end;
      goto LStartMoveOneServerToOtherNode;
    end;

    stat = CallService(url).ForceDeleteLCS(RCSr.UUID);
    if (TreatServiceError(stat,url,"ForceDeleteLCS")) then begin goto LStartMoveOneServerToOtherNode; end;
    
    qupdating.UpdateRCSController(RCSr,SMr.ToController);
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveCompletedCount(SMr);
    goto LStartMoveOneServerToOtherNode;
  end;

  qupdating.UpdateRCSNextWantedStatus(RCSr,RCSr.WantedStatus);
  qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
  qupdating.IncreaseServerMovePendingCount(SMr);
  qupdating.QueueOneServerForArchiving(RCSr.UUID,1);
  qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionEndMoveServer,RCSr.UUID,0,SMr.SerNr,CNAQr.BlockedStartTime,CNAQr.BlockedEndTime);

LStartMoveOneServerToOtherNode:;
  return;
end;

procedure EndMoveOneServerToOtherNode(record CloudNodeActionQueueVc CNAQr)
begin
  record RemoteCloudServerVc RCSr;
  string 255 url;
  Integer stat;
  record ServerMoveVc SMr;
  record CloudNodeVc CNr;
  Boolean res;

  SMr.SerNr = CNAQr.LongParam1;
  if (qupdating.ReadFirstServerMoveRec(SMr)==false) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    goto LEndMoveOneServerToOtherNode;
  end;

  if (BlankUUID(CNAQr.UUIDParam1)) begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveFailedCount(SMr);
    qupdating.DecreaseServerMovePendingCount(SMr);
    qupdating.AddLineToServerMoveLog(SMr,"A server with blank UUID failed to be moved");
    goto LEndMoveOneServerToOtherNode;
  end;

  RCSr.UUID = CNAQr.UUIDParam1;
  if (qupdating.GetRCSOnMainThread(RCSr)==false) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveFailedCount(SMr);
    qupdating.DecreaseServerMovePendingCount(SMr);
    qupdating.AddLineToServerMoveLog(SMr,"The server with UUID " & CNAQr.UUIDParam1 & " failed to be moved because the record doesn't exist");
    goto LEndMoveOneServerToOtherNode;
  end;

  if (SMr.DoneFlag!=0) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveFailedCount(SMr);
    qupdating.DecreaseServerMovePendingCount(SMr);
    qupdating.AddLineToServerMoveLog(SMr,"The server " & RCSName(RCSr) & " failed to be moved because the server move operation was marked as done");
    goto LEndMoveOneServerToOtherNode;
  end;

  CNr.Code = SMr.ToController;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveFailedCount(SMr);
    qupdating.DecreaseServerMovePendingCount(SMr);
    qupdating.AddLineToServerMoveLog(SMr,"The server " & RCSName(RCSr) & " failed to be moved because the cloud node record doesn't exist");
    goto LEndMoveOneServerToOtherNode;
  end;
  
  url = NodeURL(CNr);
  if (blank(url)) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveFailedCount(SMr);
    qupdating.DecreaseServerMovePendingCount(SMr);
    qupdating.AddLineToServerMoveLog(SMr,"The server " & RCSName(RCSr) & " failed to be moved because the cloud node address is invalid");
    goto LEndMoveOneServerToOtherNode;
  end;

  if (RCSr.ArchivedFlag==0) then begin goto LEndMoveOneServerToOtherNode; end;

  if (CloudNodeStatus(CNr)!=kCloudNodeStatusReachable) then begin goto LEndMoveOneServerToOtherNode; end;

  if (CNAQr.IntParam1>0) then begin
    // Special function (temporary) to re-restore all servers on the To-node from the 2nd latest server archive (or Nth - zero based where zero is latest)
    if (SMr.PendingServerCount>1) then begin // only restore two servers at a time
      goto LEndMoveOneServerToOtherNode;
    end;
  end;
  qupdating.UpdateRCSController(RCSr,CNr.Code);
  stat = CallService(url).RestoreArchivedServerOnNode(RCSr,CNAQr.IntParam1,res);
  if (TreatServiceError(stat,url,"RestoreArchivedServerOnNode")) then begin
    qupdating.QueueOneCloudNodeAction(CNAQr.SerNr,CNAQr.MotherAction,CNAQr.Action,CNAQr.UUIDParam1,CNAQr.IntParam1,CNAQr.LongParam1,CNAQr.BlockedStartTime,CNAQr.BlockedEndTime);
    goto LEndMoveOneServerToOtherNode;
  end else begin
    if (CNAQr.IntParam1>0) then begin
      // Special function (temporary) to re-restore all servers on the To-node from the 2nd latest server archive (or Nth - zero based where zero is latest)
      qupdating.IncreaseServerMovePendingCount(SMr);
    end;
  end;

  qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
  qupdating.QueueOneCloudNodeAction(-1,-1,kCloudActionFinishMoveServer,CNAQr.UUIDParam1,CNAQr.IntParam1,SMr.SerNr,CNAQr.BlockedStartTime,CNAQr.BlockedEndTime);
  if (CNAQr.IntParam1==0) then begin
    // Special function (temporary) to re-restore all servers on the To-node from the 2nd latest server archive (or Nth - zero based where zero is latest)
    qupdating.DecreaseServerMovePendingCount(SMr);
  end;
  
LEndMoveOneServerToOtherNode:;
  return;
end;

procedure FinishMoveOneServerToOtherNode(record CloudNodeActionQueueVc CNAQr)
begin
  record RemoteCloudServerVc RCSr;
  record ServerMoveVc SMr;
  Integer wanted_status;
  record CloudNodeVc CNr;
  string 255 url,errtext;
  Integer stat;
  Boolean res;

  SMr.SerNr = CNAQr.LongParam1;
  if (qupdating.ReadFirstServerMoveRec(SMr)==false) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    goto LFinishMoveOneServerToOtherNode;
  end;

  if (BlankUUID(CNAQr.UUIDParam1)) begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveFailedCount(SMr);
    qupdating.AddLineToServerMoveLog(SMr,"A server with blank UUID failed to be restored");
    goto LFinishMoveOneServerToOtherNode;
  end;

  RCSr.UUID = CNAQr.UUIDParam1;
  if (qupdating.GetRCSOnMainThread(RCSr)==false) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveFailedCount(SMr);
    qupdating.AddLineToServerMoveLog(SMr,"The server with UUID " & CNAQr.UUIDParam1 & " failed to be restored because the record doesn't exist");
    goto LFinishMoveOneServerToOtherNode;
  end;

  if (SMr.DoneFlag!=0) then begin
    qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
    qupdating.IncreaseServerMoveFailedCount(SMr);
    qupdating.AddLineToServerMoveLog(SMr,"The server " & RCSName(RCSr) & " failed to be restored because the server move operation was marked as done");
    goto LFinishMoveOneServerToOtherNode;
  end;

  if (RCSr.ArchivedFlag!=0) then begin
    if (IsMinutesPastTime(CurrentDate,CurrentTime,CNAQr.QueuedDate,CNAQr.QueuedTime,30)) then begin
//LogText(0,"DEBUG 1 " & DateToString(CNAQr.QueuedDate,"YYYY-MM-DD") & " " & TimeToString(CNAQr.QueuedTime,"HHMM",false) & ", " & DateToString(CurrentDate,"YYYY-MM-DD") & " " & TimeToString(CurrentTime,"HHMM",false));
      CNr.Code = SMr.ToController;
      if (ReadFirstMain(CNr,1,true)==false) then begin
        qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
        qupdating.IncreaseServerMoveFailedCount(SMr);
        qupdating.AddLineToServerMoveLog(SMr,"The server " & RCSName(RCSr) & " failed to be restored because the cloud node record doesn't exist");
        goto LFinishMoveOneServerToOtherNode;
      end;

      url = NodeURL(CNr);
      if (blank(url)) then begin
        qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
        qupdating.IncreaseServerMoveFailedCount(SMr);
        qupdating.AddLineToServerMoveLog(SMr,"The server " & RCSName(RCSr) & " failed to be restored because the cloud node address is invalid");
        goto LFinishMoveOneServerToOtherNode;
      end;

      stat = CallService(url).RestoreArchivedServerOnNode(RCSr,CNAQr.IntParam1,res);
      if (TreatServiceError2(stat,url,"RestoreArchivedServerOnNode",errtext)) then begin
        if (CNAQr.IntParam1>0) then begin
          // Special function (temporary) to re-restore all servers on the To-node from the 2nd latest server archive (or Nth - zero based where zero is latest)
          qupdating.IncreaseServerMovePendingCount(SMr);
        end;
        qupdating.AddLineToServerMoveLog(SMr,"Attempt " & CNAQr.RetryCount+1 & " to restore the server '" & RCSName(RCSr) & "' failed, because the node '" & CNr.Code & "' couldn't be contacted, error was '" & errtext & "'");
      end;
      if (res==false) then begin
        qupdating.AddLineToServerMoveLog(SMr,"Attempt " & CNAQr.RetryCount+1 & " to restore the server '" & RCSName(RCSr) & "' failed, because the node '" & CNr.Code & "' couldn't contact the server archive service");
      end;
      qupdating.QueueOneCloudNodeAction(CNAQr.SerNr,CNAQr.MotherAction,CNAQr.Action,CNAQr.UUIDParam1,CNAQr.IntParam1,CNAQr.LongParam1,CNAQr.BlockedStartTime,CNAQr.BlockedEndTime);
//    end else begin
//LogText(0,"DEBUG 2 " & DateToString(CNAQr.QueuedDate,"YYYY-MM-DD") & " " & TimeToString(CNAQr.QueuedTime,"HHMM",false) & ", " & DateToString(CurrentDate,"YYYY-MM-DD") & " " & TimeToString(CurrentTime,"HHMM",false));
    end;
    if (CNAQr.IntParam1>0) then begin
      // Special function (temporary) to re-restore all servers on the To-node from the 2nd latest server archive (or Nth - zero based where zero is latest)
      qupdating.DecreaseServerMovePendingCount(SMr);
    end;
    goto LFinishMoveOneServerToOtherNode;
  end;

  qupdating.RemoveOneCloudNodeAction(CNAQr.SerNr);
  if (CNAQr.IntParam1>0) then begin
    // Special function (temporary) to re-restore all servers on the To-node from the 2nd latest server archive (or Nth - zero based where zero is latest)
    qupdating.DecreaseServerMovePendingCount(SMr);
  end;
  qupdating.IncreaseServerMoveCompletedCount(SMr);
  
  qupdating.UpdateRCSController(RCSr,SMr.ToController);
  qupdating.UpdateRCSNewController(RCSr,SMr.FromController);
  wanted_status = RCSr.NextWantedStatus;
  qupdating.UpdateRCSNextWantedStatus(RCSr,kWantedStatusStop);
  if (IsChildSystem(RCSr)==false) then begin
    qupdating.UpdateRCSWantedStatus(RCSr,wanted_status);
  end;

/* TODO
   • Check diskspace before attempting to archive
   • Factor out tests
   • Make "Server Move" report that checks what will work/will not work, did work/did not work, move status
*/

LFinishMoveOneServerToOtherNode:;
  return;
end;

function Boolean ServerMustBeStopped(record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  
  switch (RCSr.CurrentStatus) begin
    case kStatusRunning: res = true;
    case kStatusStopping: res = true; //hmmm
    case kStatusStarting: res = true;
    case kStatusImportingBackup: res = true;
    case kStatusUpdatingVersion: res = true;
    case kStatusMoving: res = true;
    case kStatusCreated: res = true;
    case kStatusCreating: res = true;
    case kStatusMaintenance: res = true; //hmmm
    case kStatusExportingDatabase: res = true;
    case kStatusExportedDatabase: res = true;
    case kStatusImportedBackup: res = true;
    case kStatusExportingRegister: res = true;
    case kStatusExportedRegister: res = true;
    case kStatusExportingCompany: res = true;
    case kStatusExportedCompany: res = true;
    case kStatusRunningTest: res = true;
    case kStatusRunningReserve: res = true;
    case kStatusRunningPreparingTest: res = true;
    case kStatusRunningUpdate: res = true;
    case kStatusRunningPreparingUpdate: res = true;
    case kStatusRunningPendingStop: res = true;
    case kStatusRunningPreparingReserve: res = true;
    case kStatusRebuildingDatabase: res = true;
    case kStatusClearingRegister: res = true;
    otherwise
  end;
  
  ServerMustBeStopped = res;
  return;
end;

function Boolean ShouldStartThisServerMove(record CloudNodeActionQueueVc CNAQr,Boolean check_rest_of_queuef)
begin
  Boolean res;
  record RemoteCloudServerVc RCSr;
  record CloudNodeActionQueueVc CNAQ2r;

  res = true;
  RCSr.UUID = CNAQr.UUIDParam1;
  if (ReadFirstMain(RCSr,1,true)==false) then begin goto LShouldStartThisServerMove; end;

  if (ServerMustBeStopped(RCSr)) then begin
    res = false;
  end;

  if (res==false) then begin
    if (NonBlankTime(CNAQr.BlockedStartTime) and NonBlankTime(CNAQr.BlockedEndTime)) then begin
      if ((CurrentTime<CNAQr.BlockedStartTime) or (CurrentTime>CNAQr.BlockedEndTime)) then begin
        res = true;
      end;
    end;
  end;
  
  // TODO: number of connected users, etc...
  
  if (check_rest_of_queuef==false) then begin
    goto LShouldStartThisServerMove;
  end;
  
  if (res==false) then begin
    CNAQ2r.SerNr = CNAQr.SerNr + 1;
    while (LoopKey("QueuedDate",CNAQ2r,0,true) and (QuitingApplication==false) and (GetGlobalBoolean("ASPIdleTasksStopped")==false)) begin
      if (CNAQ2r.Action==kCloudActionStartMoveServer) then begin
        if (ShouldStartThisServerMove(CNAQ2r,false)) then begin
          goto LShouldStartThisServerMove;
        end;
      end;
    end;
  end;

  if (res==false) then begin
    if (NonBlankTime(CNAQr.BlockedStartTime) and NonBlankTime(CNAQr.BlockedEndTime)) then begin
      if ((CurrentTime<CNAQr.BlockedStartTime) or (CurrentTime>CNAQr.BlockedEndTime)) then begin
        res = true;
      end;
    end else begin
      res = true;
    end;
  end;

LShouldStartThisServerMove:;
  ShouldStartThisServerMove = res;
  return;
end;

procedure TreatCloudNodeCloudActionQueueItem(var record CloudNodeActionQueueVc CNAQr)
begin
  if (IsCloudNode==false) then begin goto LTreatCloudNodeCloudActionQueueItem; end;
  
  switch (CNAQr.Action) begin
    case kCloudActionServerArchivingCompleted:
      NotifyControllerOfArchivedServer(CNAQr.SerNr,CNAQr.UUIDParam1,CNAQr.IntParam1,CNAQr.LongParam1);
  end;

LTreatCloudNodeCloudActionQueueItem:;
  return;
end;

procedure TreatCloudControllerCloudActionQueueItem(var record CloudNodeActionQueueVc CNAQr)
begin
  if (IsCloudController==false) then begin goto LTreatCloudControllerCloudActionQueueItem; end;
  
  switch (CNAQr.Action) begin
    case kCloudActionStartMoveServer:
        if (ShouldStartThisServerMove(CNAQr,true)) then begin
          StartMoveOneServerToOtherNode(CNAQr);
        end;
    case kCloudActionEndMoveServer:
        EndMoveOneServerToOtherNode(CNAQr);
    case kCloudActionFinishMoveServer:
        FinishMoveOneServerToOtherNode(CNAQr);
    case kCloudActionBeginRebuildNode:
        StartRebuildOneNode(CNAQr);
    case kCloudActionRebuildNodePrepareVersions:
        PrepareVersionsRebuildOneNode(CNAQr);
    case kCloudActionRebuildNodeStopHost:
        StopHostRebuildOneNode(CNAQr);
    case kCloudActionRebuildNodeDetachDisks:
        DetachDisksRebuildOneNode(CNAQr);
    case kCloudActionRebuildNodeReassignIP:
        ReassignIPRebuildOneNode(CNAQr);
    case kCloudActionRebuildNodeAttachDisks:
        AttachDisksRebuildOneNode(CNAQr);
    case kCloudActionRebuildNodePreflight:
        PreflightRebuildOneNode(CNAQr);
    case kCloudActionRebuildNodeCreateAMI:
        CreateAMIRebuildOneNode(CNAQr);
    case kCloudActionRebuildNodeRestore:
        RestoreAMIRebuildOneNode(CNAQr);
    case kCloudActionRebuildNodeMigrateIP:
        MigrateIPRebuildOneNode(CNAQr);
    case kCloudActionRebuildNodeCleanup:
        CleanupRebuildOneNode(CNAQr);
  end;

LTreatCloudControllerCloudActionQueueItem:;
  return;
end;

global
procedure TreatCloudActionQueueTask(string arg)
begin
  record CloudNodeActionQueueVc CNAQr;

  while (LoopKey("QueuedDate",CNAQr,0,true) and (QuitingApplication==false) and (GetGlobalBoolean("ASPIdleTasksStopped")==false)) begin
    if (CNAQr.PendingActionCount!=0) then begin goto LTreatCloudActionQueueTask_skip; end;
    if (nonblankdate(CNAQr.PlannedDate)) then begin
      if (CurrentDate<=CNAQr.PlannedDate) then begin
        if ((CurrentDate!=CNAQr.PlannedDate) or (CurrentTime<CNAQr.PlannedTime)) then begin
          goto LTreatCloudActionQueueTask_skip;
        end;
      end;
    end;
    TreatCloudNodeCloudActionQueueItem(CNAQr);
    TreatCloudControllerCloudActionQueueItem(CNAQr);
//    switch (CNAQr.Action) begin // for things that should be done regardless of internal server type
//    end;
LTreatCloudActionQueueTask_skip:;
  end;

LTreatCloudActionQueueTask:;
  return;
end;

global
updating procedure ClearRemoteCloudServerRegister(array uuid recarr,string vcname)
begin
  record RemoteCloudServerVc RCSr;
  record RemoteCloudServerVc OldRCSr;
  string 255 tstr;
  Boolean testf;
  LongInt idx;

  for (idx = 0; idx<recarr.length; idx = idx + 1) begin
    RCSr.UUID = recarr[idx];
    if (ReadFirstMain(RCSr,1,true)) then begin
      testf = true;
      if (RCSr.Closed!=0) then begin testf = false; end;
      if (RCSr.CurrentStatus==kStatusConfigInError) then begin testf = false; end;
      if (testf) then begin
        RecordCopy(OldRCSr,RCSr);
        if ((RCSr.WantedStatus==kWantedStatusRun) or (RCSr.WantedStatus==kWantedStatusStop)) then begin
          RCSr.NextWantedStatus = RCSr.WantedStatus;
        end else begin
          RCSr.NextWantedStatus = kWantedStatusStop;
        end;
        RCSr.WantedStatus = kWantedStatusClearRegister;
        RCSr.WantedSubStatus = kWantedSubStatusNone;
        RCSr.WantedStatusParams = vcname;
        RecordUpdate(OldRCSr,RCSr,true);
      end;
    end;
  end;
  
  return;
end;

procedure AsteriskDefaultDB(record CUVc CUr,string key,LongInt portno,var area a_setuptb)
begin
  record ProgramStatusBlock PSb;
  record ClientFormatBlock CFb;
  record ModuleBlock Modr;
  record CompaniesBlock Cb;
  row CompaniesBlock Crw;
  record InternetEnablerBlock IEb;
  record LocalAsteriskBlock LAb;
  area a_tmp;
  string 255 tmpfile;

  RecordNew(Cb);
  Crw.CompCode = "1";
  Crw.CompName = CUr.Name;
  Crw.ShortName = CUr.Code;
  MatRowPut(Cb,0,Crw);
  AddBlockToArea(Cb,a_tmp);

  RecordNew(IEb);
  IEb.CustomerCode = CUr.Code;
  AddBlockToArea(IEb,a_tmp);

  RecordNew(PSb);
  PSb.ProgramName = "Asterisk Controller";
  PSb.ServerFlag = 1;
//  PSb.ServerPort = 1601;
//  PSb.httpPort = 8080;
  PSb.httpsPort = portno;
  PSb.UseHttps = 1;
  PSb.SSLCertFile = "cert.crt";
  PSb.SSLPrivKeyFile = "privkey.pem";
  PSb.WebSessionTimeout = -1;
  AddBlockToArea(PSb,a_tmp);

  RecordNew(CFb);
  CFb.dateOrder = m4_ymd;
  CFb.leadZday = 1;
  CFb.leadZmonth = 1;
  CFb.century = 1;
  CFb.dateSep = "-";
  CFb.decimalPt = ".";
  CFb.thousSep = ",";
  CFb.Usef = 0;
  CFb.thousSepf = 1;
  AddBlockToArea(CFb,a_tmp);

  RecordNew(Modr);
  Modr.NumberOfUsers = 999;
  Modr.Mailboxes = 999;
  Modr.MultiIntServEnabler = 1;
  Modr.BrowseFiltering = 1;
  Modr.UpdWebWhileRep = 1;
  Modr.ReportParaType = kReportParallelityMultiThread;
  Modr.MultiClientImport = 1;
  Modr.ReportSlots = 2;        // default is 2
  Modr.WebRequestThreads = 3;  // default is 3
  Modr.HTTPThreads = 0;        // default is 0, max is 20
  Modr.ServerEnabler = 1;
  AddBlockToArea(Modr,a_tmp);

  RecordNew(LAb);
  LAb.RemoteAsteriskFlag = 1; // new asterisk controller solution
  LAb.AsteriskControllerKey = key;
  LAb.AsteriskControllerFlag = 0; // different solution, not used for this
  AddBlockToArea(LAb,a_tmp);

  tmpfile = CreateTempFile("setuptb",".ha");
  WriteAreaToFile(a_tmp,tmpfile,0);
  BeginArchiveToArea(a_setuptb);
  AddArchiveFile("TBSETUP.TXT",tmpfile);
  EndArchive;

  return;
end;

global
updating procedure StoreNewAsteriskControllerKeyForRCS(UUID rcsid,string key,string addr)
begin
  record RemoteCloudServerVc OldRCSr,RCSr;
  RCSr.UUID = rcsid;
  
  if (ReadFirstMain(RCSr,1,true)) then begin
    RecordCopy(OldRCSr,RCSr);
    SetRCSAsteriskControllerKeyAndAddr(RCSr,key,addr);
    RecordUpdate(OldRCSr,RCSr,true);
    RCSr.RcsSeqNr = -1;
    threadasync.SyncOneRCS(RCSr,true,true,"10");
  end;

  return;
end;


global
procedure InstallTelephonyForServer(uuid rcsid,string cncode,var LongInt https_port,var Integer res_code,var string res_msg)
begin
  uuid serverid;
  record CloudNodeVc CNr;
  record HansaVersionVc HVr;
  record CUVc CUr;
  record RemoteCloudServerVc RCSr;
  area a_setuptb;
  string 255 vcode,key,acaddr,url;
  LongInt port,http_port;
  Integer stat;

  vcode = "STDERP_8.5-2020-07-07-2962"; //TODO: Use current release version set on Standard Install
  https_port = 5070;

  if (blank(cncode)) then begin
    res_code = 1;
    res_msg = "Cloud Node is blank";
    goto LInstallTelephonyForServer;
  end;
  
  CNr.Code = cncode;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    res_code = 2;
    res_msg = "Cloud Node " & cncode & " not found";
    goto LInstallTelephonyForServer;
  end;
  
  HVr.Code = vcode;
  //if (GetVersion(vcode,HVr)==false) then begin // only on nodes, and only if the version is already downloaded...
  if (ReadFirstMain(HVr,1,true)==false) then begin
    res_code = 3;
    res_msg = "Version " & vcode & " not found";
    goto LInstallTelephonyForServer;
  end;

  RCSr.UUID = rcsid;
  if (ReadFirstMain(RCSr,1,true)==false) then begin
    res_code = 4;
    res_msg = "Cloud Server with id '" & serverid & "' not found";
    goto LInstallTelephonyForServer;
  end;
  
  if (right(RCSr.Name,12)==" - Telephony") then begin
    res_code = 5;
    res_msg = "Telephony can't be configured for this server (server name can't end with '- Telephony')";
    goto LInstallTelephonyForServer;
  end;
  
  https_port = FindUnusedPortOnCC(CNr.Code,https_port,50000);
//  FindUnusedPortsOnCC(CNr.Code,port,http_port,https_port); // Checking on CC to prevent conflict with unsynced RCSr:s
//  url = NodeURL(CNr);
//  stat = CallService(url).FindUnusedPorts(port,http_port,https_port); // Checking on CN to ensure port is available on the machine
  // Shouldn't be a problem if the node didn't respond, likelyhood of error is very low
  
  CUr.Code = RCSr.HMCUCode;
  if (blank(CUr.Code)) then begin
    CUr.Code = RCSr.CUCode;
  end;
  CUr.Name = RCSr.Name & " - Telephony";

  key = RCSAsteriskControllerKey(RCSr);
  if (blank(key)) then begin
    key = GeneratePassword2(21);
    acaddr = CNr.HostName;
    queued.StoreNewAsteriskControllerKeyForRCS(RCSr.UUID,key,acaddr & ":" & https_port);
  end;
  AsteriskDefaultDB(CUr,key,https_port,a_setuptb);

  serverid = MakeUUID;
  threadasync.CreateServerThread(serverid,CNr,HVr,CUr,a_setuptb,"",false,https_port,false,true);
  
  res_code = 0;
  res_msg = "Started installation of Telephony on '" & cncode & "', server name '" & CUr.Name & "', port " & https_port;

LInstallTelephonyForServer:;
  return;
end;

