global
procedure DownloadBackupForLCS(uuid server_uuid,string tburl)
begin
  string 255 host,path,tbfile,tbtmpfile;
  record LocalCloudServerVc LCSr;
  LongInt portno;
  Boolean sslf;
  
  if (blank(tburl)) then begin goto LDownloadBackupForLCS; end;
  LCSr.UUID = server_uuid;
  if (ReadFirstMain(LCSr,1,true)==false) then begin
    LogText(0,"DownloadBackupForLCS couldn't read LCS record"); //TODO update server activity log with error info
    goto LDownloadBackupForLCS;
  end;
  
  tbfile = LCSr.DataFolder & "/TBSETUP.TXT";
  tbtmpfile = tbfile & ".downloading";
  Delete_file(tbfile);
  Delete_file(tbtmpfile);

  GetHostAndPathFromUrl(tburl,host,portno,path,sslf);
  HttpAsyncDownload(host,portno,sslf,path,30,tbtmpfile,"DownloadBackupForLCSCallback");
  
LDownloadBackupForLCS:;
  return;
end;

global
procedure DownloadBackupForLCSCallback(Boolean successf,LongInt httpres,Boolean timeout,string tbtmpfile)
begin
  Integer res;
  string 255 tbfile;

  if (timeout==true) then begin
    LogText(0,"DownloadBackupForLCSCallback timed out httpres=" & httpres); //TODO update server activity log with error info
    goto LDownloadBackupForLCSCallback;
  end;

  switch (httpres) begin
    case kHttpStatusNotFound:
      LogText(0,"DownloadBackupForLCSCallback failed (httpres=404 not found)"); //TODO update server activity log with error info
      goto LDownloadBackupForLCSCallback;
    case kHttpStatusOK:
    otherwise
      LogText(0,"DownloadBackupForLCSCallback failed (httpres=" & httpres & ")"); //TODO update server activity log with error info
      goto LDownloadBackupForLCSCallback;
  end;

  if (successf==false) then begin
    LogText(0,"DownloadBackupForLCSCallback failed");
    goto LDownloadBackupForLCSCallback;
  end;
  
  tbfile = left(tbtmpfile,len(tbtmpfile)-12);
  Delete_file(tbfile);
  RenameFile(tbtmpfile,tbfile);

LDownloadBackupForLCSCallback:;
  Delete_file(tbtmpfile);
  return;
end;

function string 255 UpdateItemDataRow(record RemoteCloudServerVc MotherRCSr,string in_itemdata)
begin
  record CloudNodeVc CNr;
  LongInt pos;
  string 255 res,tstr;

  res = in_itemdata;
  CNr.Code = MotherRCSr.Controller;
  if (ReadFirstMain(CNr,1,true)==false) then begin goto LUpdateItemDataRow; end;
  
  res = "";
  GetNextSubstring(in_itemdata,pos,",",tstr); // ec2-user@13.51.235.56
  res = CNr.AdminUser & "@" & CNr.HostName;
  GetNextSubstring(in_itemdata,pos,",",tstr); // 1200
  res = res & ",";
  res = res & MotherRCSr.Port;
  GetNextSubstring(in_itemdata,pos,",",tstr); // zMejnomvBo9vn7
  res = res & ",";
  res = res & tstr;
  GetNextSubstring(in_itemdata,pos,",",tstr); // 0
  res = res & ",";
  res = res & tstr;
  GetNextSubstring(in_itemdata,pos,",",tstr); // /Servers/lvg220713-1
  res = res & ",";
  res = res & MotherRCSr.DataFolder;
  GetNextSubstring(in_itemdata,pos,",",tstr); // 0
  res = res & ",";
  res = res & tstr;
  GetNextSubstring(in_itemdata,pos,",",tstr); // 3
  res = res & ",";
  res = res & tstr;
  GetNextSubstring(in_itemdata,pos,",",tstr); // 3
  res = res & ",";
  res = res & tstr;
  GetNextSubstring(in_itemdata,pos,",",tstr); // -1
  res = res & ",";
  res = res & tstr;

LUpdateItemDataRow:;
  UpdateItemDataRow = res;
  return;
end;

global
updating procedure ActivateRestoredServerOnCC(UUID server_uuid,string in_data_folder)
begin
  record RemoteCloudServerVc OldRCSr,RCSr,RCS2r,OldRCS2r;
  row RemoteCloudServerVc RCSrw,RCS2rw;
  string 255 lockstr;
  LongInt rwcnt,rwn,rwcnt2,rwn2,off;
  string 255 tstr,data_folder;
  record CloudNodeActionQueueVc CNAQr;
  
  data_folder = in_data_folder;
  
  RCSr.UUID = server_uuid;
  if (ReadFirstMain(RCSr,1,true)==false) then begin end; // TODO error handling

  if (blank(data_folder)) then begin
    data_folder = RCSr.DataFolder;
  end;
  
  if (blank(data_folder)) then begin
    data_folder = "/Servers/Auto/" & RCSr.UUID; // Should never happen
  end;

  rwcnt = MatRowCnt(RCSr);
  for (rwn = 0; rwn<rwcnt; rwn = rwn + 1) begin
    MatRowGet(RCSr,rwn,RCSrw);
    if (((RCSrw.Item==kManagedServerItemReserveSystem) or
        (RCSrw.Item==kManagedServerItemTestSystem) or
        (RCSrw.Item==kManagedServerItemUpdateSystem)) and (RCSrw.Disabled==0)) then begin
      RCS2r.UUID = StringToUUID(RCSrw.ItemName);
      if (ReadFirstMain(RCS2r,1,true)) then begin
//LogText(0,"DEBUG 3 RCSr.Controller=" & RCSr.Controller & ", RCS2r.Controller=" & RCS2r.Controller);
        if (RCS2r.Controller==RCSr.Controller) then begin
          tstr = RCSr.DataFolder;
          if (Right(tstr,1)!="/") then begin tstr = tstr & "/"; end;
//LogText(0,"DEBUG 1 tstr=" & tstr & ", len(tstr)=" & len(tstr) & ", Left(RCS2r.DataFolder,len(tstr))=" & Left(RCS2r.DataFolder,len(tstr)));
          if (Left(RCS2r.DataFolder,len(tstr))==tstr) then begin
            off = len(tstr);
            RecordCopy(OldRCS2r,RCS2r);
            RCS2r.RetainRecordDatesFlag = 0;
            tstr = data_folder;
            if (Right(tstr,1)!="/") then begin tstr = tstr & "/"; end;
//LogText(0,"DEBUG 2 tstr=" & tstr & ", off=" & off & ", len(RCS2r.DataFolder)=" & len(RCS2r.DataFolder) & ", RCS2r.DataFolder=" & RCS2r.DataFolder);
            RCS2r.DataFolder = tstr & right(RCS2r.DataFolder,len(RCS2r.DataFolder)-off);
            rwcnt2 = MatRowCnt(RCS2r);
            for (rwn2 = 0; rwn2<rwcnt2; rwn2 = rwn2 + 1) begin
              MatRowGet(RCS2r,rwn2,RCS2rw);
              if ((RCS2rw.Item==kManagedServerItemMotherSystem) and (RCS2rw.Disabled==0)) then begin
                RCS2rw.Data = UpdateItemDataRow(RCSr,RCS2rw.Data);
                MatRowPut(RCS2r,rwn2,RCS2rw);
              end;
            end;
            RecordUpdate(OldRCS2r,RCS2r,true);
          end;
        end;
      end;
    end;
  end;

  RecordCopy(OldRCSr,RCSr);
  RCSr.ArchivedFlag = 0;
  RCSr.RestoredDate = CurrentDate;
  RCSr.RestoredTime = CurrentTime;
  RCSr.ShouldCloseFlag = 0;
  RCSr.Closed = 0;
  RCSr.ClosedOnNodeFlag = 0;
  RCSr.DataFolder = data_folder;
  RCSr.WantedStatus = kWantedStatusStop;
  RCSr.CurrentStatus = kStatusStopped;
  RCSr.WantedSubStatus = kWantedSubStatusNone;
  RCSr.CurrentSubStatus = kSubStatusNone;
  RCSr.PublicHostName = "";
  //RCSr.OnDemandFlag = 1;
  RCSr.RetainRecordDatesFlag = 0;
  RecordUpdate(OldRCSr,RCSr,true);
  RCSr.RcsSeqNr = -1;
  threadasync.SyncOneRCS(RCSr,true,true,"11");
  
  lockstr = server_uuid & "_RESTORING";
  SetGlobalBoolean(lockstr,false);

  return;
end;

global
procedure CallActivateRestoredServerOnCC(UUID server_uuid,string data_folder)
begin
  record CloudSettingsBlock CSb;
  string 255 url;
  LongInt stat;
  
  BlockLoad(CSb);

LCallActivateRestoredServerOnCC_again:;
  url = Trim(CSb.CCAddr) & ":" & CSb.CCHTTPSPort;
  stat = CallService(url).ActivateRestoredServerOnCC(server_uuid,data_folder);
  if (stat!=kCallServiceOK) then begin
    Sleep(10);
    LogText(0,"Failed calling the Cloud Controller on url " & url & ", retrying...");
    goto LCallActivateRestoredServerOnCC_again;
  end;

  return;
end;

global
updating procedure ActivateRestoredServerOnNode(uuid server_uuid,string data_folder)
begin
  if (BlankUUID(server_uuid)) then begin goto LActivateRestoredServerOnNode; end;

  threadasync.CallActivateRestoredServerOnCC(server_uuid,data_folder);

LActivateRestoredServerOnNode:;
  return;
end;

global
procedure DownloadArchivedServerOnNodeCallback(Boolean successf,LongInt httpres,Boolean timeout,string indir)
begin
  Integer res;
  string 255 tbfile,lockstr;
  uuid server_uuid;
  
  server_uuid = StringToUUID(BaseName(indir));
  lockstr = server_uuid & "_RESTORING_ON_NODE";

  if (timeout==true) then begin
    LogText(0,"DownloadBackupForLCSCallback timed out httpres=" & httpres); //TODO update server activity log with error info
    goto LDownloadArchivedServerOnNodeCallback;
  end;

  switch (httpres) begin
    case kHttpStatusNotFound:
      LogText(0,"DownloadArchivedServerOnNodeCallback failed (httpres=404 not found)"); //TODO update server activity log with error info
      goto LDownloadArchivedServerOnNodeCallback;
    case kHttpStatusOK:
    otherwise
      LogText(0,"DownloadArchivedServerOnNodeCallback failed (httpres=" & httpres & ")"); //TODO update server activity log with error info
      goto LDownloadArchivedServerOnNodeCallback;
  end;

  if (successf==false) then begin
    LogText(0,"DownloadArchivedServerOnNodeCallback failed");
    goto LDownloadArchivedServerOnNodeCallback;
  end;

  queued.ActivateRestoredServerOnNode(StringToUUID(BaseName(indir)),indir);

LDownloadArchivedServerOnNodeCallback:;
  SetGlobalBoolean(lockstr,false);
  return;
end;

global
procedure RestoreArchivedServerOnNode(record RemoteCloudServerVc RCSr,Integer skip_archives_cnt,var Boolean successf)
begin
  string 255 haurl,lockstr,tstr;
  Integer stat,idx;
  record CloudSettingsBlock CSb;

  BlockLoad(CSb);
  stat = CallCloudPartner("SERVER_ARCHIVE",CSb.HostingPartner).GetServerArchiveDownloadURL2(
            RCSr.UUID,skip_archives_cnt,haurl,false); // false until we fix DoHttpRequest4 to support SSL
  if (stat!=kCallServiceOK) then begin
    LogText(0,"Error: calling server archive, failed with status=" & stat);
    goto LRestoreArchivedServerOnNode;
  end;

  if (blank(haurl)) then begin
    for (idx = 0; idx<255; idx = idx + 1) begin
      tstr = StringFromSet(614,idx);
      if (nonblank(tstr)) begin
        if (idx!=CSb.HostingPartner) then begin
          stat = CallCloudPartner("SERVER_ARCHIVE",idx).GetServerArchiveDownloadURL2(
                    RCSr.UUID,skip_archives_cnt,haurl,false); // false until we fix DoHttpRequest4 to support SSL
          if (nonblank(haurl)) then begin goto LRestoreArchivedServerOnNode_found; end;
        end;
      end;
    end;
    goto LRestoreArchivedServerOnNode;
  end;
  
LRestoreArchivedServerOnNode_found:;
  lockstr = RCSr.UUID & "_RESTORING_ON_NODE";
  if (GetGlobalBoolean(lockstr)) then begin
    successf = true;
    goto LRestoreArchivedServerOnNode;
  end;

  successf = DownloadArchivedServerOnNode(RCSr.UUID,haurl);
  SetGlobalBoolean(lockstr,successf);

LRestoreArchivedServerOnNode:;
  return;
end;

function Boolean RestoreArchivedServer(record RemoteCloudServerVc RCSr,string cncode)
begin
  Boolean res;
  string 255 url,lockstr,cnurl;
  Integer stat;
  record CloudNodeVc CNr;
  Boolean testf,autoassign_nodef;
  record HansaVersionVc HVr;
  LongInt version_build;

  if (RCSr.ArchivedFlag==0) then begin goto LRestoreArchivedServer; end;

  lockstr = RCSr.UUID & "_RESTORING";
  if (GetGlobalBoolean(lockstr)) then begin
    res = true;
    goto LRestoreArchivedServer;
  end;

  if (blank(RCSr.HansaVersion)) then begin
    goto LRestoreArchivedServer; // Not supported
  end;
  
  if (nonblank(RCSr.HansaVersion)) then begin
    HVr.Code = RCSr.HansaVersion;
    if (ReadFirstMain(HVr,1,true)==false) then begin
      goto LRestoreArchivedServer; // We don't know how to do this yet, but we should teach the system to update it to a newer version
    end;
    version_build = (HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild;
  end;

  autoassign_nodef = true;
  if (nonblank(cncode)) then begin
    CNr.Code = cncode;
    if (ReadFirstMain(CNr,1,true)) then begin
      if (CNr.Closed==0) then begin
        autoassign_nodef = false;
        if (CNr.Platform==kPlatformLinuxArm64) then begin
          if ((version_build>0) and (version_build<85350335)) then begin
            autoassign_nodef = true;
          end;
        end;
        testf = true;
      end;
    end;
  end;
  
  if (ServerIsStandardServer(RCSr)) then begin
    if (autoassign_nodef) then begin
      testf = AssignNodeForNewAutoServer("<archived server>","<n/a>",CNr,false,HVr);
      if (testf==false) then begin
        goto LRestoreArchivedServer;
      end;
    end else begin
      cnurl = NodeURL(CNr);
    end;
  end else begin
    if (autoassign_nodef) then begin
      cnurl = RcsNodeURL(RCSr);
    end else begin
      cnurl = NodeURL(CNr);
    end;
      
    if (nonblank(cnurl) and autoassign_nodef) then begin
      CNr.Code = RCSr.Controller;
      testf = ReadFirstMain(CNr,1,true);
    end;
    if (testf==false) then begin
      testf = AssignNodeForNewAutoServer("<archived server>","<n/a>",CNr,false,HVr);
      if (testf==false) then begin
        LogText(0,"ERROR: Failed to assign node for server " & RCSName(RCSr));
        goto LRestoreArchivedServer;
      end;
    end;
  end;
  
  qupdating.UpdateRCSController(RCSr,CNr.Code);
  
  url = RcsNodeURL(RCSr);
  if (blank(url)) then begin
    goto LRestoreArchivedServer;
  end;
  
  stat = CallService(url).RestoreArchivedServerOnNode(RCSr,0,res);
  if (TreatServiceError(stat,url,"RestoreArchivedServerOnNode")) then begin
    SetCloudControllerStatus(kJobStatusError,"Failed restoring archived server '" & RCSName(RCSr) & "', couldn't contact node '" & RCSr.Controller & "'");
    LogText(0,"Failed restoring archived server '" & RCSName(RCSr) & "', couldn't contact node '" & RCSr.Controller & "'");
  end;

  if (res==true) then begin
    SetGlobalBoolean(lockstr,true);
  end;
  
LRestoreArchivedServer:;
  RestoreArchivedServer = res;
  return;
end;

global
procedure RestoreRemoteCloudServers(array uuid recarr,string cncode,var string msg)
begin
  Integer i;
  Boolean res;
  record RemoteCloudServerVc RCSr;
  record CloudNodeVc CNr;
  record HansaVersionVc HVr;
  LongInt version_build;

  CNr.Code = cncode;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    msg = "The selected node could not be found (was it deleted?).";
    goto LRestoreRemoteCloudServers;
  end;

  if (CNr.Platform==kPlatformLinuxArm64) then begin
    for (i = 0; i<recarr.length; i = i + 1) begin
      RCSr.UUID = recarr[i];
      if (ReadFirstMain(RCSr,1,true)) then begin
        if (nonblank(RCSr.HansaVersion)) then begin
          RecordClear(HVr);
          HVr.Code = RCSr.HansaVersion;
          if (ReadFirstMain(HVr,1,true)) then begin
            version_build = (HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild;
            if (version_build<85350335) then begin
              msg = RCSName(RCSr) & " can't be restored on the cloud node " & cncode & ", because it is using a version that is incompatible with the CPU architecture of the node";
              goto LRestoreRemoteCloudServers;
            end;
          end;
        end;
      end;
    end;
  end;

  for (i = 0; i<recarr.length; i = i + 1) begin
    RCSr.UUID = recarr[i];
    if (ReadFirstMain(RCSr,1,true)) then begin
      res = RestoreArchivedServer(RCSr,cncode);
    end;
  end;

LRestoreRemoteCloudServers:;
  return;
end;

