global
updating procedure StoreASPActionLog(Integer actiontype,Date atd,Time atm,UUID serverid,string controller,string usercode,string stdid,string param,string ipaddr)
begin
  record ASPActionLogVc AALr;
  Date td;
  Time tm;
  
  UTCTimeToDate(CurrentUnixUTCTime,td,tm);    //we always override
  RecordNew(AALr);
  AALr.UUID = MakeUUID;
  AALr.TransDate = td;
  AALr.TransTime = tm;
  AALr.ServerUUID = serverid;
  AALr.Controller = controller;
  AALr.UserCode = usercode;
  AALr.StandardID = stdid;
  AALr.ActionType = actiontype;
  AALr.Parameter = param;
  AALr.IPAddress = ipaddr;
  RecordStore(AALr,false);

  return;
end;

