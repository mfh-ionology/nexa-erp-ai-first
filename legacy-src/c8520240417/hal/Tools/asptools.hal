global
updating procedure CNResetAllFastCheckFlags()
begin
  record LocalCloudServerVc OldLCSr,LCSr;
  Boolean foundf,testf;
  LongInt cnt;

  cnt = 0;
  DBHold;
  foundf = true;
  while (LoopMain(LCSr,0,foundf)) begin
    testf = foundf;
    if (LCSr.FastCheckFlag==0) then begin testf = false; end;
    if (testf) then begin
      RecordCopy(OldLCSr,LCSr);
      LCSr.FastCheckFlag = 0;
      RecordUpdate(OldLCSr,LCSr,true);
      cnt = cnt + 1;
    end;
  end;
  DBFlush;
  if (cnt>0) then begin
    LogText(0,"Reset observation state on " & cnt & " servers");
  end;
  return;
end;

global
updating procedure ResetLCSRecords()
begin
  record LocalCloudServerVc OldLCSr,LCSr;
  Boolean foundf,testf;
  LongInt cnt;

  cnt = 0;
  DBHold;
  foundf = true;
  while (LoopMain(LCSr,0,foundf)) begin
    testf = foundf;
    if (LCSr.BlockStartupOnNodeFlag==0) then begin testf = false; end;
    if (testf) then begin
      RecordCopy(OldLCSr,LCSr);
      LCSr.BlockStartupOnNodeFlag = 0;
      if (ComparePosts(OldLCSr,LCSr)==false) then begin
        RecordUpdate(OldLCSr,LCSr,true);
        cnt = cnt + 1;
      end;
    end;
  end;
  DBFlush;
  
  if (cnt>0) then begin
    LogText(0,"Did reset of states on " & cnt & " servers");
  end;
  return;
end;

global
updating procedure CCResetAllFastCheckFlags()
begin
  record RemoteCloudServerVc OldRCSr,RCSr,RCS2r;
  Boolean foundf,testf;
  LongInt cnt;

  cnt = 0;
  DBHold;
  foundf = true;
  while (LoopMain(RCSr,0,foundf)) begin
    testf = foundf;
    if (RCSr.FastCheckFlag==0) then begin testf = false; end;
    if (testf) then begin
      RecordCopy(RCS2r,RCSr);
      RCSr.FastCheckFlag = GetFastCheckFlag(RCSr.Controller,RCS2r.WantedStatus,RCSr.WantedStatus,RCSr.WantedSubStatus,RCSr.CurrentStatus,RCSr.Closed);
      if (RCSr.FastCheckFlag!=RCS2r.FastCheckFlag) then begin
        RecordUpdate(RCS2r,RCSr,true);
        cnt = cnt + 1;
      end;
    end;
  end;
  DBFlush;
  if (cnt>0) then begin
    LogText(0,"Reset observation state on " & cnt & " servers");
  end;
  return;
end;

global
updating function UpdateRCSFastCheckFlag(record RemoteCloudServerVc RCSr,Integer fastcheckflag)
begin
  record RemoteCloudServerVc OldRCSr;

  if (ReadFirstMain(RCSr,1,true)) then begin
    RecordCopy(OldRCSr,RCSr);
    RCSr.FastCheckFlag = fastcheckflag;
    if (ComparePosts(OldRCSr,RCSr)==false) then begin
      RecordUpdate(OldRCSr,RCSr,true);
    end;
  end;
  return;
end;

global
updating function UpdateLCSFastCheckFlag(record LocalCloudServerVc LCSr,Integer fastcheckflag)
begin
  record LocalCloudServerVc OldLCSr;

  if (ReadFirstMain(LCSr,1,true)) then begin
    RecordCopy(OldLCSr,LCSr);
    LCSr.FastCheckFlag = fastcheckflag;
    if (ComparePosts(OldLCSr,LCSr)==false) then begin
      RecordUpdate(OldLCSr,LCSr,true);
    end;
  end;
  return;
end;

function Boolean ShouldSyncRCS(record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  record CloudNodeVc CNr;
  
  CNr.Code = RCSr.Controller;
  if (blank(ReadNodeURL(CNr))) then begin goto LShouldSyncRCS; end;
  if (CNr.ReachableFlag==0) then begin goto LShouldSyncRCS; end;

  if (RCSr.CurrentStatus==kStatusNone) then begin res = true; end;
  
  if (res) then begin goto LShouldSyncRCS; end;
  
  switch (RCSr.WantedStatus) begin
    case kWantedStatusStop:
    case kWantedStatusRun:
    case kWantedStatusOnDemand:
    case kWantedStatusMaintenence:
    case kWantedStatusManual:
    case kWantedStatusImportBackup:
      if (RCSr.CurrentStatus!=kStatusImportingBackup) then begin res = true; end;
    case kWantedStatusUpdateVersion:
      if (RCSr.CurrentStatus!=kStatusUpdatingVersion) then begin res = true; end;
    case kWantedStatusCreateServer:
      if (RCSr.CurrentStatus!=kStatusCreating and RCSr.CurrentStatus!=kStatusCreated) then begin res = true; end;
    case kWantedStatusMoveServer:
      if (RCSr.CurrentStatus!=kStatusMoving) then begin res = true; end;
    case kWantedStatusRestart:
      if (RCSr.CurrentStatus!=kStatusStopping and RCSr.CurrentStatus!=kStatusStopped) then begin res = true; end;
    case kWantedStatusExportDatabase:
      if (RCSr.CurrentStatus!=kStatusExportingRegister and RCSr.CurrentStatus!=kStatusExportedRegister) then begin res = true; end;
    case kWantedStatusExportRegister:
      if (RCSr.CurrentStatus!=kStatusExportingRegister and RCSr.CurrentStatus!=kStatusExportedRegister) then begin res = true; end;
    case kWantedStatusCreateStartedServer:
      if (RCSr.CurrentStatus!=kStatusCreating and RCSr.CurrentStatus!=kStatusCreated) then begin res = true; end;
    case kWantedStatusImportBackupAndRun:
      if (RCSr.CurrentStatus!=kStatusImportingBackup and RCSr.CurrentStatus!=kStatusImportedBackup) then begin res = true; end;
    case kWantedStatusLaunchReserveSystem:
    case kWantedStatusExportCompany:
      if (RCSr.CurrentStatus!=kStatusExportingCompany and RCSr.CurrentStatus!=kStatusExportedCompany) then begin res = true; end;
    case kWantedStatusLaunchTestSystem:
    case kWantedStatusLaunchUpdateSystem:
    case kWantedStatusResetToBackup:
      if (RCSr.CurrentStatus!=kStatusImportingBackup and RCSr.CurrentStatus!=kStatusImportedBackup) then begin res = true; end;
    case kWantedStatusRunUnjournaled:
    case kWantedStatusChangeVersion:
    case kWantedStatusForceStop:
      if (RCSr.CurrentStatus!=kStatusStopping and RCSr.CurrentStatus!=kStatusStopped) then begin res = true; end;
    case kWantedStatusContinousUpdateVersion:
    case kWantedStatusRebuildDatabase:
      if (RCSr.CurrentStatus!=kStatusRebuildingDatabase) then begin res = true; end;
    case kWantedStatusStopAndRefresh:
    case kWantedStatusClearRegister:
      if (RCSr.CurrentStatus!=kStatusClearingRegister) then begin res = true; end;
  end;
  
LShouldSyncRCS:;
  ShouldSyncRCS = res;
  return;
end;

global
procedure ASPFastPollServersTask(string arg)
begin
  record LocalCloudServerVc LCSr,LCS2r;
  record RemoteCloudServerVc RCSr,RCS2r;
  Boolean foundf;
  LongInt i;
  Integer trycount,fastcheckflag;
  array record LocalCloudServerVc lcsarr;
  Boolean ccsyncf,doccsyncf;
  LongInt cnt;

  cnt = 0;
//LASPFastPollServersTask_Again:;
  if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LASPFastPollServersTask; end;


  if (IsCloudController==false) then begin
    ClearArray(lcsarr);
    ccsyncf = false;
    LCSr.FastCheckFlag = 1;
    foundf = true;
    while (LoopKey("FastCheckFlag",LCSr,1,foundf)) begin
      if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LASPFastPollServersTask; end;
      if (QuitingApplication==true) then begin goto LASPFastPollServersTask; end;
      if (LCSr.FastCheckFlag==0) then begin foundf = false; end;
      if (foundf) then begin
        fastcheckflag = GetFastCheckFlag("#CLOUDNODE#",LCSr.WantedStatus,LCSr.WantedStatus,LCSr.WantedSubStatus,LCSr.CurrentStatus,LCSr.Closed);
        if (fastcheckflag==0) then begin
          qupdating.UpdateLCSFastCheckFlag(LCSr,0);
        end else begin
          RecordCopy(LCS2r,LCSr);
          qupdating.DoPollOneLCS(LCS2r,ccsyncf);
          if (ccsyncf) then begin
            lcsarr[lcsarr.length] = LCS2r;
            doccsyncf = true;
          end;
        end;
      end;
    end;

    CallServerStatusesChanged(lcsarr,doccsyncf);
  end;

  RCSr.FastCheckFlag = 1;
  foundf = true;
  while (LoopKey("FastCheckFlag",RCSr,1,foundf)) begin
    if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LASPFastPollServersTask; end;
    if (QuitingApplication==true) then begin goto LASPFastPollServersTask; end;
    if (RCSr.FastCheckFlag==0) then begin foundf = false; end;
    if (foundf) then begin
      fastcheckflag = GetFastCheckFlag(RCSr.Controller,RCSr.WantedStatus,RCSr.WantedStatus,RCSr.WantedSubStatus,RCSr.CurrentStatus,RCSr.Closed);
      if (fastcheckflag==0) then begin
        qupdating.UpdateRCSFastCheckFlag(RCSr,0);
      end else begin
        RecordCopy(RCS2r,RCSr);
        if (((RCSr.CurrentStatus==kStatusUpdatingVersion) or (RCSr.CurrentStatus==kStatusRebuildingDatabase)) and
            (RCSr.WantedStatus!=kWantedStatusStop) and
            (RCSr.WantedStatus!=kWantedStatusStopAndRefresh) and
            (RCSr.WantedStatus!=kWantedStatusForceStop) and
            (RCSr.WantedStatus!=kWantedStatusRestart)) then begin
          qupdating.UpdateServerWantedSubStatus(RCS2r,cnt);
        end else begin
          if (RCSr.WantedStatus==kWantedStatusUpdateVersion) then begin
            qupdating.UpdateServerWantedSubStatus(RCS2r,cnt);
          end;
        end;
        if (ServerStatusesShouldChange(RCS2r)) then begin
          qupdating.UpdateServerWantedStatus(RCS2r,cnt);
        end;
      end;
      if (ShouldSyncRCS(RCSr)) then begin
        qupdating.SyncOneRCS(RCSr,true,true,"12");
      end;
    end;
  end;

  if (IsCloudController) then begin
    UpdateClientBrowsesIfNeeded("RemoteCloudServerVc");
  end;

LASPFastPollServersTask:;
  return;
end;

global
procedure ASPPollServersTask(string arg)
begin
  record LocalCloudServerVc LCSr,LCS2r;
  record RemoteCloudServerVc RCSr,RCS2r;
  LongInt i;
  Boolean ccsyncf,doccsyncf;
  array record LocalCloudServerVc lcsarr;
  LongInt starttick,calls1,calls2,cnt;

  if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LASPPollServersTask; end;

  cnt = 0; calls1 = 0; calls2 = 0;
  if (IsCloudController==false) then begin
    i = 0;
    while (LoopMain(LCSr,0,true)) begin
      if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LASPPollServersTask; end;
      if (LCSr.FastCheckFlag==0 and LCSr.Closed==0) then begin
        i = i + 1;
        RecordCopy(LCS2r,LCSr);
        qupdating.DoPollOneLCS(LCS2r,ccsyncf);
        if (ccsyncf) then begin
          lcsarr[lcsarr.length] = LCS2r;
          doccsyncf = true;
        end;
      end;
    end;
    CallServerStatusesChanged(lcsarr,doccsyncf);
  end;

  starttick = GetCurTick;

  while (LoopMain(RCSr,0,true)) begin
    if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LASPPollServersTask; end;
    if (RCSr.Closed==0) then begin
      RecordCopy(RCS2r,RCSr);
      if (((RCSr.CurrentStatus==kStatusUpdatingVersion) or (RCSr.CurrentStatus==kStatusRebuildingDatabase)) and
          (RCSr.WantedStatus!=kWantedStatusStop) and
          (RCSr.WantedStatus!=kWantedStatusStopAndRefresh) and
          (RCSr.WantedStatus!=kWantedStatusForceStop)) then begin
        qupdating.UpdateServerWantedSubStatus(RCS2r,cnt);
        calls1 = calls1 + 1;
      end;
      if (ServerStatusesShouldChange(RCS2r)) then begin
        qupdating.UpdateServerWantedStatus(RCS2r,cnt);
        calls2 = calls2 + 1;
      end;
    end;
  end;

  if ((GetCurTick - starttick)>10 and (calls2+calls1+cnt)>0) then begin
    LogText2(0,"ASPPollServersTask loop ticks: " & GetCurTick - starttick & ", " & calls2 & " status calls, " & calls1 & " substatus calls, " & cnt & " updated RCS records",kVerbosityDebugDetailed);
  end;

  if (IsCloudController) then begin
    UpdateClientBrowsesIfNeeded("RemoteCloudServerVc");
  end;

LASPPollServersTask:;
  return;
end;

global
function LongInt FindUnusedPortOnCC2(string controller,LongInt firstport,LongInt lastport,Boolean ignorercsf,uuid rcsuuid)
begin
  record RemoteCloudServerVc RCSr;
  LongInt res;

  res = firstport - 1;

LFindUnusedPortOnCC2_Again:;
  res = res + 1;

  if (res>lastport) then begin
    res = -1;
    goto LFindUnusedPortOnCC2;
  end;

  RCSr.Controller = controller;
  RCSr.Port = res;
  if (ReadFirstKey("Port",RCSr,2,true)) then begin
    if (ignorercsf==false or (rcsuuid!=RCSr.UUID)) then begin goto LFindUnusedPortOnCC2_Again; end;
  end;

  RCSr.Controller = controller;
  RCSr.HTTPPort = res;
  if (ReadFirstKey("HTTPPort",RCSr,2,true)) then begin
    if (ignorercsf==false or (rcsuuid!=RCSr.UUID)) then begin goto LFindUnusedPortOnCC2_Again; end;
  end;

  RCSr.Controller = controller;
  RCSr.HTTPSPort = res;
  if (ReadFirstKey("HTTPSPort",RCSr,2,true)) then begin
    if (ignorercsf==false or (rcsuuid!=RCSr.UUID)) then begin goto LFindUnusedPortOnCC2_Again; end;
  end;

  RCSr.Controller = controller;
  RCSr.MaintPort = res;
  if (ReadFirstKey("MaintPort",RCSr,2,true)) then begin
    if (ignorercsf==false or (rcsuuid!=RCSr.UUID)) then begin goto LFindUnusedPortOnCC2_Again; end;
  end;

LFindUnusedPortOnCC2:;
  FindUnusedPortOnCC2 = res;
  return;
end;

global
function LongInt FindUnusedPortOnCC(string controller,LongInt firstport,LongInt lastport)
begin
  uuid uuidt;
  FindUnusedPortOnCC = FindUnusedPortOnCC2(controller,firstport,lastport,false,uuidt);
  return;
end;

global
procedure FindUnusedPortsOnCC(string controller,var LongInt port,var LongInt httpport,var LongInt httpsport)
begin
  LongInt firstport,lastport;

  firstport = 10000;
  lastport = 50000;

  port = FindUnusedPortOnCC(controller,firstport,lastport);
  if (port==-1) then begin goto LFindUnusedPortsOnCC; end;

  httpport = FindUnusedPortOnCC(controller,port+1,lastport);
  if (httpport==-1) then begin goto LFindUnusedPortsOnCC; end;

  httpsport = FindUnusedPortOnCC(controller,httpport+1,lastport);
  if (httpsport==-1) then begin goto LFindUnusedPortsOnCC; end;

LFindUnusedPortsOnCC:;
  return;
end;

global
updating procedure ReceiveVersion(string remotearchive,record HansaVersionVc HVr)
begin
  record HansaVersionVc OldHVr;
  string 255 infolder;
  string 255 tmpfolder;

  if (FileExists(remotearchive)) then begin
    LogText(0,"Extracting version " & HVr.Code & " to " & VersionsFolder & HVr.Code);
  end else begin
    LogText(0,"Failed to extract version " & HVr.Code & " because the archive file " & remotearchive & " doesn't exist");
    goto LReceiveVersion;
  end;

  tmpfolder = "tmp/" & HVr.Code;
  DeleteFolder(tmpfolder);
  CreateFolderHierarchy(tmpfolder);
  RestoreArchive(tmpfolder,remotearchive);
  OldHVr.Code = HVr.Code;
  HVr.ProgramFolder = VersionsFolder & HVr.Code;

  DeleteFolder(HVr.ProgramFolder);
  if (DirExists(HVr.ProgramFolder)) then begin
    LogText(0,"Failed to delete folder " & HVr.ProgramFolder);
    goto LReceiveVersion;
  end;
  CopyFolder(tmpfolder,HVr.ProgramFolder);
  if (DirExists(HVr.ProgramFolder)==false) then begin
    LogText(0,"Failed to copy folder " & tmpfolder & " to " & HVr.ProgramFolder);
    goto LReceiveVersion;
  end;
  DeleteFolder(tmpfolder);

  if (ReadFirstMain(OldHVr,1,true)) then begin
    RecordUpdate(OldHVr,HVr,true);
  end else begin
    RecordInsert(HVr,false);
  end;

  LogText(0,"Version " & HVr.Code & " successfully extracted to folder " & HVr.ProgramFolder);

LReceiveVersion:;
end;

global
procedure ReceiveFilePart(var string remotefname,string prefix,string suffix,area part)
begin
  if (remotefname=="") then begin
    remotefname = CreateTempFile(prefix,suffix);
    LogText(0,"Inbound file transfer of " & prefix & suffix & " starting, writing to temporary file " & remotefname);
  end;
  
  AppendAreaToFile(remotefname,part);
end;

updating function Boolean SendVersionToNode(record HansaVersionVc HVr,string archive,record CloudNodeVc CNr)
begin
  LongInt stat,pos,blocklen;
  Val fsz;
  string 255 url,remotearchive;
  area part;
  Boolean res;
  Boolean scfailf;

  LogText(0,"Sending version " & HVr.Code & " in folder " & HVr.ProgramFolder & " to node " & CNr.Code);
  url = NodeURL(CNr);
  
  fsz = FileSize2(archive);
  pos = 0;
  
  while (pos<fsz) begin
    blocklen = MIN(fsz - pos,5000000); // 5MB at a time...
    LoadFileToArea(archive,pos,blocklen,part);
    
    stat = CallService(url).ReceiveFilePart(remotearchive,"version",".ha",part);
    scfailf = TreatServiceError(stat,url,"ReceiveFilePart");
    queued.SaveCloudNodeReachable(CNr.Code,!scfailf);
    if (scfailf) then begin
      goto LSendVersionToNode;
    end;
    
    pos = pos + blocklen;
  end;
  LogText(0,"Version " & HVr.Code & " successfully sent to node " & CNr.Code);

  stat = CallService(url).ReceiveVersion(remotearchive,HVr);
  if (stat!=kCallServiceCommError) then begin
    if (TreatServiceError(stat,url,"ReceiveVersion")) then begin
      goto LSendVersionToNode;
    end;
  end;
  LogText(0,"Version " & HVr.Code & " successfully unpacked on node " & CNr.Code);

res = true;

LSendVersionToNode:;
  if (res==false) then begin
    LogText(0,"Version " & HVr.Code & " could not be sent to node " & CNr.Code);
  end;
  SendVersionToNode = true;
  return;
end;

updating function Boolean SendVersionToNodeIfNeeded(record CloudNodeVc CNr,record HansaVersionVc HVr)
begin
  string 255 url,archive;
  Boolean canbeupdatedf;
  LongInt stat;
  LongInt retries;
  record HansaVersionVc HV2r;

  RecordCopy(HV2r,HVr);
  url = NodeURL(CNr);

  stat = CallService(url).GetHansaVersionAtCN(HV2r,canbeupdatedf);
  TreatServiceError(stat,url,"GetHansaVersionAtCN");

  if (canbeupdatedf==false) then begin
    LogText(0,"Creating version archive for " & HVr.Code & " to send to " & CNr.Code);
    archive = CreateTempFile("version",".ha");
    BeginArchiveToFile(archive);
    AddArchiveDir(".",HVr.ProgramFolder); // BaseName(HVr.ProgramFolder)
    EndArchive;
    SendVersionToNode(HVr,archive,CNr);
    Delete_File(archive);
  end;

LRetryGetHansaVersionAtCN:;
  RecordCopy(HV2r,HVr);
  stat = CallService(url).GetHansaVersionAtCN(HV2r,canbeupdatedf);
  if (stat==kCallServiceCommError) then begin
    if (retries<15) then begin
      Sleep(5);
      retries = retries + 1;
      goto LRetryGetHansaVersionAtCN;
    end;
  end else begin
    TreatServiceError(stat,url,"GetHansaVersionAtCN");
  end;

  if (canbeupdatedf==false) then begin
    StopAlert("Version " & HVr.Code & " does not exist on node " & CNr.Code & " and failed to be pushed");
  end;

  SendVersionToNodeIfNeeded = canbeupdatedf;
end;

function Boolean OnDemandServerNeedsStarting(record RemoteCloudServerVc RCSr)
begin
  Boolean res;

  if (RCSr.OnDemandFlag==0) then begin goto LOnDemandServerNeedsStarting; end;
  
  if ((RCSr.CurrentStatus!=kStatusRunning) and
      (RCSr.CurrentStatus!=kStatusRunningPendingStop)) then begin
    if ((RCSr.WantedStatus==kWantedStatusOnDemand) or (RCSr.WantedStatus==kWantedStatusStop) or (RCSr.WantedStatus==kWantedStatusStopAndRefresh) or (RCSr.WantedStatus==kWantedStatusForceStop)) then begin
      res = true;
    end;
  end;
  
LOnDemandServerNeedsStarting:;
  OnDemandServerNeedsStarting = res;
  return;
end;

global
updating function DoStartOnDemandServer(record RemoteCloudServerVc RCSr)
begin
  record RemoteCloudServerVc OldRCSr;

  if (OnDemandServerNeedsStarting(RCSr)) then begin
    ReadFirstMain(RCSr,1,true);
    RecordCopy(OldRCSr,RCSr);
    RCSr.WantedStatus = kWantedStatusRun;
    RecordUpdate(OldRCSr,RCSr,true);
    RCSr.RcsSeqNr = -1;
    threadasync.SyncOneRCS(RCSr,true,true,"4");
  end;
  return;
end;

global
updating function UpdateRCSWantedStatus(record RemoteCloudServerVc RCSr,Integer status)
begin
  record RemoteCloudServerVc OldRCSr;

  if (ReadFirstMain(RCSr,1,true)) then begin
    RecordCopy(OldRCSr,RCSr);
    RCSr.WantedStatus = status;
    if (ComparePosts(OldRCSr,RCSr)==false) then begin
      RecordUpdate(OldRCSr,RCSr,true);
    end;
    SyncOneRCS(RCSr,true,true,"9");
  end;
  return;
end;

global
updating function UpdateRCSStatus(record RemoteCloudServerVc RCSr,Integer status)
begin
  record RemoteCloudServerVc OldRCSr;

  if (ReadFirstMain(RCSr,1,true)) then begin
    RecordCopy(OldRCSr,RCSr);
    RCSr.CurrentStatus = status;
    if (ComparePosts(OldRCSr,RCSr)==false) then begin
      RecordUpdate(OldRCSr,RCSr,true);
    end;
  end;
end;

global
function Boolean FindLocalServerAddrAndPort(string serverid,var string addr,var LongInt port)
begin
  Boolean res;
  record LocalCloudServerVc LCSr;
  
  res = false;  
  port = -1;
  addr = "";
  
  LCSr.UUID = StringToUUID(serverid);
  if (ReadFirstMain(LCSr,1,true)==false) then begin
    LogText(0,"FindLocalServerAddrAndPort(\"" & serverid & "\") failed, record not found");
    goto LFindLocalServerAddrAndPort;
  end;
  
  port = LCSr.Port;
  addr = ServerIPAddress; //returns 0.0.0.0 when processing cloud service request
  LogText(0,"ServerIPAddress: " & ServerIPAddress);
  res = true;
  
LFindLocalServerAddrAndPort:;
  FindLocalServerAddrAndPort = res;
  return;
end;

global
procedure CallServerStatusesChangedQ(array record LocalCloudServerVc lcsarr,Boolean ccsyncf)
begin
  threadasync.CallServerStatusesChanged(lcsarr,ccsyncf);
  return;
end;

global
updating procedure AsyncPollOneLCS(record LocalCloudServerVc LCSr)
begin
  array record LocalCloudServerVc lcsarr;
  Boolean ccsyncf,doccsyncf;

  if (ReadFirstMain(LCSr,1,true)) begin
    DoPollOneLCS(LCSr,ccsyncf);

    if (ccsyncf) then begin
      lcsarr[lcsarr.length] = LCSr;
      doccsyncf = true;
      queued.CallServerStatusesChangedQ(lcsarr,doccsyncf);
    end;
  end;

  return;
end;

function Integer SubStatusOrder(Integer SubStatus)
begin
  Integer res;

  res = 0;

  switch (SubStatus) begin
    case kWantedSubStatusBeforeExport:                     res = 1;
    case kWantedSubStatusSetCrontabBeforeUpdate:           res = 2;
    case kWantedSubStatusDBCopyBeforeUpdate:               res = 3;
    case kWantedSubStatusSystemCopyBeforeUpdate:           res = 4;
    case kWantedSubStatusStopSlaveSystems:                 res = 5;
    case kWantedSubStatusStopForExport:                    res = 6;
    case kWantedSubStatusStartSystemCopiesBeforeExport:    res = 7;
    case kWantedSubStatusSystemCopyDuringUpdate:           res = 8;
    case kWantedSubStatusStartSystemCopiesDuringUpdate:    res = 9;
    case kWantedSubStatusExport:                           res = 10;
    case kWantedSubStatusAfterExport:                      res = 11;
    case kWantedSubStatusImport:                           res = 12;
    case kWantedSubStatusAfterImport:                      res = 13;
    case kWantedSubStatusStopSystemCopiesDuringUpdate:     res = 14;
    case kWantedSubStatusSetCrontabAfterUpdate:            res = 15;

    // not sorted properly yet
    case kWantedSubStatusFinishUpdate:                     res = 0;
    case kWantedSubStatusCreatingUpdateSystem:             res = 0;
    case kWantedSubStatusUpdateSystemReady:                res = 0;
    case kWantedSubStatusFinishContinousUpdate:            res = 0;
    case kWantedSubStatusCancelContinousUpdate:            res = 0;
  end;

  SubStatusOrder = res;
end;

function Boolean UpdateLCSAllowed(record LocalCloudServerVc OldLCSr,record LocalCloudServerVc LCSr) // LCSr is the RCSr from CC
begin
  Boolean res;

  if (OldLCSr.RcsSeqNr>LCSr.RcsSeqNr) then begin
    if (LCSr.RcsSeqNr==-1) then begin
      res = true;
    end else begin
      res = false;
    end;
  end else begin
    res = true;
  end;

  /*
  switch (LCSr.WantedStatus) begin
    case kWantedStatusImportBackup:
      if (SubStatusOrder(OldLCSr.WantedSubStatus)>SubStatusOrder(LCSr.WantedSubStatus)) then begin
        res = false;
      end;
      if (OldLCSr.WantedStatus!=LCSr.WantedStatus) then begin
        if (SubStatusOrder(LCSr.WantedSubStatus)>SubStatusOrder(kWantedSubStatusStopForExport)) then begin
          res = false;
        end;
      end;
    case kWantedStatusUpdateVersion:
      if (SubStatusOrder(OldLCSr.WantedSubStatus)>SubStatusOrder(LCSr.WantedSubStatus)) then begin
        res = false;
      end;
      if (OldLCSr.WantedStatus!=LCSr.WantedStatus) then begin
        if (SubStatusOrder(LCSr.WantedSubStatus)>SubStatusOrder(kWantedSubStatusStopForExport)) then begin
          res = false;
        end;
      end;
    case kWantedStatusRebuildDatabase:
      if (SubStatusOrder(OldLCSr.WantedSubStatus)>SubStatusOrder(LCSr.WantedSubStatus)) then begin
        res = false;
      end;
      if (OldLCSr.WantedStatus!=LCSr.WantedStatus) then begin
        if (SubStatusOrder(LCSr.WantedSubStatus)>SubStatusOrder(kWantedSubStatusStopForExport)) then begin
          res = false;
        end;
      end;
  end;
  */

  if (res==false) then begin
    LogText(0,"UpdateLCSAllowed() blocking update of server record '" & LCSName(LCSr) & "' (new wanted status '" & WantedStatusName(LCSr.WantedStatus) & "', old wanted substatus '" & WantedSubStatusName(OldLCSr.WantedSubStatus) & "', new wanted substatus'" & WantedSubStatusName(LCSr.WantedSubStatus) & "'");
  end;

  UpdateLCSAllowed = res;
  return;
end;

global
updating procedure UpdateRCSController(var record RemoteCloudServerVc RCSr,string cncode)
begin
  record RemoteCloudServerVc OldRCSr;

  if (ReadFirstMain(RCSr,1,true)) then begin
    RecordCopy(OldRCSr,RCSr);
    RCSr.Controller = cncode;
    if (ComparePosts(OldRCSr,RCSr)==false) then begin
      RecordUpdate(OldRCSr,RCSr,true);
    end;
  end;
  if (ReadFirstMain(RCSr,1,true)) then begin end;
  return;
end;

global
updating procedure UpdateRCSNewController(var record RemoteCloudServerVc RCSr,string cncode)
begin
  record RemoteCloudServerVc OldRCSr;

  if (ReadFirstMain(RCSr,1,true)) then begin
    RecordCopy(OldRCSr,RCSr);
    RCSr.NewController = cncode;
    if (ComparePosts(OldRCSr,RCSr)==false) then begin
      RecordUpdate(OldRCSr,RCSr,true);
    end;
  end;
  if (ReadFirstMain(RCSr,1,true)) then begin end;
  return;
end;

function Boolean NodeIsBeingMoved(string cncode)
begin
  Boolean res,foundf;
  record ServerMoveVc SMr;
  
  foundf = true;
  while (LoopKey("DoneFlag",SMr,1,foundf)) begin
    if (SMr.DoneFlag!=0) then begin foundf = false; end;
    if (foundf) then begin
      if (SMr.FromController==cncode) then begin
        res = true;
        goto LNodeIsBeingMoved;
      end;
    end;
  end;
  
LNodeIsBeingMoved:;
  NodeIsBeingMoved = res;
  return;
end;

global
updating procedure UpdateRCSControllerIfMatch(var record RemoteCloudServerVc RCSr,string match_cncode,string new_cncode)
begin
  record RemoteCloudServerVc OldRCSr;

  if (ReadFirstMain(RCSr,1,true)) then begin
    if (RCSr.Controller==match_cncode) then begin
      if (!NodeIsBeingMoved(match_cncode)) then begin
        RecordCopy(OldRCSr,RCSr);
        RCSr.Controller = new_cncode;
        RCSr.CurrentStatus = kStatusNone;
        RCSr.StatusText = "Node " & match_cncode & " rejected this server because the data folder was missing";
        RCSr.FastCheckFlag = 0;
        if (ComparePosts(OldRCSr,RCSr)==false) then begin
          RecordUpdate(OldRCSr,RCSr,true);
        end;
      end;
    end;
  end;
  if (ReadFirstMain(RCSr,1,true)) then begin end;
  return;
end;

global
procedure ClearRCSControllerOnCC(array uuid clear_node_on_cc_arr) // Can be deleted after 2022-08-01
begin
  LongInt idx;
  record RemoteCloudServerVc RCSr;
  
  for (idx = 0; idx<clear_node_on_cc_arr.length; idx = idx + 1) begin
    RCSr.UUID = clear_node_on_cc_arr[idx];
    qupdating.UpdateRCSController(RCSr,"");
  end;
  
  return;
end;

global
procedure ClearRCSControllerOnCC2(string cncode,array uuid clear_node_on_cc_arr)
begin
  LongInt idx;
  record RemoteCloudServerVc RCSr;
  
  for (idx = 0; idx<clear_node_on_cc_arr.length; idx = idx + 1) begin
    RCSr.UUID = clear_node_on_cc_arr[idx];
    qupdating.UpdateRCSControllerIfMatch(RCSr,cncode,"");
  end;
  
  return;
  return;
end;

global
procedure CallClearRCSControllerOnCC(array uuid clear_node_on_cc_arr)
begin
  record CloudSettingsBlock CSb;
  string 255 cncode,url;
  LongInt stat;

  BlockLoad(CSb);

LCallClearRCSControllerOnCC_again:;
  cncode = CSb.NodeCode;
  if (nonblank(CSb.CCAddr) and (CSb.CCHTTPSPort>0)) then begin
    url = Trim(CSb.CCAddr) & ":" & CSb.CCHTTPSPort;
    stat = CallService(url).ClearRCSControllerOnCC2(cncode,clear_node_on_cc_arr);
    if (stat!=kCallServiceOK) then begin
      Sleep(10);
      goto LCallClearRCSControllerOnCC_again;
    end;
  end;

  return;
end;

global
updating procedure SaveNewAndUpdatedLCSs(array record RemoteCloudServerVc rcsarr)
begin
  record LocalCloudServerVc LCSr;
  record LocalCloudServerVc OldLCSr;
  record RemoteCloudServerVc RCSr;
  record HansaVersionVc HVr;
  Integer i;
  Boolean ccsyncf,doccsyncf;
  array record LocalCloudServerVc lcsarr;
  array uuid clear_node_on_cc_arr;
  LongInt starttick,process_time;
  record CloudSettingsBlock CSb;

  BlockLoad(CSb);

  starttick = GetCurTick;
  for (i = 0; i<rcsarr.length; i = i + 1) begin
    RCSr = rcsarr[i];
    RecordClear(LCSr);
    ResetLoop(LCSr);
    LCSr.UUID = RCSr.UUID;
    if (ReadFirstMain(LCSr,1,true)) then begin
      if (blank(RCSr.Controller) or (RCSr.Controller==CSb.NodeCode)) then begin
        if (LCSr.MovedAwayFlag==0) then begin
          if ((RCSr.WantedStatus!=kWantedStatusCreateServer) and
              (RCSr.WantedStatus!=kWantedStatusMoveServer) and
              (RCSr.WantedStatus!=kWantedStatusCreateStartedServer)) then begin
            if (DirExists(RCSr.DataFolder)==false) then begin
              LogText(0,"SaveNewAndUpdatedLCSs is deleting local cloud server record for " & RCSName(RCSr) & " because it doesn't belong to node " & CSb.NodeCode & ", (the data " & RCSr.DataFolder & " folder doesn't exist)");
              RecordDelete(LCSr);
              goto LSaveNewAndUpdatedLCSs_next;
            end;
          end;
          RecordCopy(OldLCSr,LCSr);
          CopyRCSControlledDataToLCS(RCSr,LCSr);
          LCSr.ClosedOnNodeFlag = LCSr.Closed;
          if (UpdateLCSAllowed(OldLCSr,LCSr)) then begin
            if (ComparePosts(OldLCSr,LCSr)==false) then begin
              LogText2(0,"SaveNewAndUpdatedLCSs: storing " & LCSr.UUID & " with wanted status " & WantedStatusName(LCSr.WantedStatus) & ", current status " & StatusName(LCSr.CurrentStatus) & ", FastCheckFlag=" & LCSr.FastCheckFlag & ", RCSr.FastCheckFlag=" & RCSr.FastCheckFlag,kVerbosityDebugDetailed);
              RecordUpdate(OldLCSr,LCSr,true);
            end else begin
              LogText2(0,"SaveNewAndUpdatedLCSs: No changes to " & RCSName(RCSr) & ", skipping",kVerbosityDebugDetailed);
            end;
            LCSr.UUID = RCSr.UUID;
            queued.AsyncPollOneLCS(LCSr);
          end else begin
            LogText2(0,"SaveNewAndUpdatedLCSs() UpdateLCSAllowed prevented update of " & RCSName(RCSr),kVerbosityDebug);
          end;
        end else begin
          goto LSaveNewAndUpdatedLCSs_next;
        end;
      end else begin
        if (LCSr.MovedAwayFlag==0) then begin
          LogText(0,"SaveNewAndUpdatedLCSs is deleting local cloud server record for " & RCSName(RCSr) & " because it doesn't belong to node " & CSb.NodeCode & ", (it actually belongs to " & RCSr.Controller & ")");
          RecordDelete(LCSr);
          goto LSaveNewAndUpdatedLCSs_next;
        end;
      end;
    end else begin
      if (blank(RCSr.Controller) or (RCSr.Controller==CSb.NodeCode)) then begin
        if ((RCSr.WantedStatus!=kWantedStatusCreateServer) and
            (RCSr.WantedStatus!=kWantedStatusCreateStartedServer) and
            (RCSr.WantedStatus!=kWantedStatusLaunchReserveSystem) and
            (RCSr.WantedStatus!=kWantedStatusLaunchTestSystem) and
            (RCSr.WantedStatus!=kWantedStatusLaunchUpdateSystem) and
            (RCSr.WantedStatus!=kWantedStatusMoveServer)) then begin
          if (DirExists(RCSr.DataFolder)==false) then begin
            LogText(0,"SaveNewAndUpdatedLCSs is skipping " & RCSName(RCSr) & " because it doesn't belong to node " & CSb.NodeCode & ", (the data folder " & RCSr.DataFolder & " doesn't exist)");
//            if (RCSr.Closed!=0) then begin //LVG231013 I am not sure why I at one point thought the CC should keep insisting that the record belongs to a CN that is clearly refusing it, I am disabling it now
              if (RCSr.ArchivedFlag==0) then begin
                clear_node_on_cc_arr[clear_node_on_cc_arr.length] = RCSr.UUID;
              end;
              goto LSaveNewAndUpdatedLCSs_next;
//            end;
            goto LSaveNewAndUpdatedLCSs_next;
          end;
        end;
        RecordClear(LCSr);
        CopyRCSDataToLCS(RCSr,LCSr);
        LCSr.UUID = RCSr.UUID;
        LCSr.ClosedOnNodeFlag = LCSr.Closed;
  //      LogText(0,"Inserting LCS " & LCSName(LCSr) & " with wanted status " & LCSr.WantedStatus);
        RecordInsert(LCSr,false);
        LCSr.UUID = RCSr.UUID;
        queued.AsyncPollOneLCS(LCSr);
      end else begin
        LogText(0,"SaveNewAndUpdatedLCSs is skipping " & RCSName(RCSr) & " because it doesn't belong to node " & CSb.NodeCode & ", (it actually belongs to " & RCSr.Controller & ")");
        goto LSaveNewAndUpdatedLCSs_next;
      end;
    end;

    if (nonblank(LCSr.HansaVersion) and (LCSr.Closed==0) and (LCSr.MovedAwayFlag==0)) then begin
      if (GetVersion(LCSr.HansaVersion,HVr)==false) then begin
        HVr.Code = LCSr.HansaVersion;
        DoDownloadVersion(HVr,false);
      end;
    end;
    if (nonblank(LCSr.NewHansaVersion) and (LCSr.Closed==0) and (LCSr.MovedAwayFlag==0)) then begin
      if (GetVersion(LCSr.NewHansaVersion,HVr)==false) then begin
        HVr.Code = LCSr.NewHansaVersion;
        DoDownloadVersion(HVr,false);
      end;
    end;
    if (nonblank(LCSr.OldHansaVersion) and (LCSr.Closed==0) and (LCSr.MovedAwayFlag==0)) then begin
      if (IsDevelopmentVersion(LCSr.OldHansaVersion)==false) then begin
        if (GetVersion(LCSr.OldHansaVersion,HVr)==false) then begin
          HVr.Code = LCSr.OldHansaVersion;
          DoDownloadVersion(HVr,false);
        end;
      end;
    end;
    
LSaveNewAndUpdatedLCSs_next:;
  end;
  process_time = GetCurTick - starttick;
  if (process_time>100) then begin
    LogText(0,"SaveNewAndUpdatedLCSs took " & process_time & "ms to process " & rcsarr.length & " records");
  end;
  
  if (clear_node_on_cc_arr.length>0) then begin
    threadasync.CallClearRCSControllerOnCC(clear_node_on_cc_arr);
  end;
  return;
end;

global
procedure SyncRCSsAtCN(array record RemoteCloudServerVc rcsarr)
begin
  Integer i;
  array record RemoteCloudServerVc rcsarr2;
  record LocalCloudServerVc CurLCSr,NewLCSr;
  record RemoteCloudServerVc RCSr;

  for (i = 0; i<rcsarr.length; i = i + 1) begin
    RCSr = rcsarr[i];
    CurLCSr.UUID = RCSr.UUID;
    if (ReadFirstMain(CurLCSr,1,true)) then begin
      if (CurLCSr.MovedAwayFlag==0) then begin
        RecordCopy(NewLCSr,CurLCSr);
        CopyRCSControlledDataToLCS(RCSr,NewLCSr);
        NewLCSr.ClosedOnNodeFlag = NewLCSr.Closed;
        if (ComparePosts(NewLCSr,CurLCSr)==false) then begin
          rcsarr2[rcsarr2.length] = RCSr;
        end;
      end;
    end else begin
      rcsarr2[rcsarr2.length] = RCSr;
    end;
  end;
  
  LogText2(0,"SyncRCSsAtCN got " & rcsarr.length & " and found " & rcsarr2.length & " that needs updating",kVerbosityDebugDetailed);
  
  if (rcsarr2.length>0) then begin 
    LogText(0,"SyncRCSsAtCN updating " & rcsarr2.length & " records from controller");
    queued.SaveNewAndUpdatedLCSs(rcsarr2);
  end;
  
LSyncRCSsAtCN:;
  return;
end;

global
procedure RCSArrToLCSArr(array record RemoteCloudServerVc rcsarr,var array record LocalCloudServerVc lcsarr)
begin
  LongInt i;
  record LocalCloudServerVc LCSr;
  record RemoteCloudServerVc RCSr;

  for (i=0;i<rcsarr.length;i=i+1) begin
    RCSr = rcsarr[i];
    LCSr.UUID = RCSr.UUID;
    if (ReadFirstMain(LCSr,1,true)) then begin
      lcsarr[lcsarr.length] = LCSr;
    end;
  end;

  return;
end;

global
procedure SyncRCSsAtCN3(array record RemoteCloudServerVc rcsarr,string intendedcncode,var array record LocalCloudServerVc lcsarr)
begin
  Integer i;
  array record RemoteCloudServerVc rcsarr2;
  record LocalCloudServerVc CurLCSr,NewLCSr;
  record RemoteCloudServerVc RCSr;
  record CloudSettingsBlock CSb;

  BlockLoad(CSb);

  for (i = 0; i<rcsarr.length; i = i + 1) begin
    RCSr = rcsarr[i];
    CurLCSr.UUID = RCSr.UUID;
    if (ReadFirstMain(CurLCSr,1,true)) then begin
      if (CurLCSr.MovedAwayFlag==0) then begin
        RecordCopy(NewLCSr,CurLCSr);
        CopyRCSControlledDataToLCS(RCSr,NewLCSr);
        NewLCSr.ClosedOnNodeFlag = NewLCSr.Closed;
        if (ComparePosts(NewLCSr,CurLCSr)==false) then begin
          rcsarr2[rcsarr2.length] = RCSr;
        end;
      end;
    end else begin
      rcsarr2[rcsarr2.length] = RCSr;
    end;
  end;
  
  LogText2(0,"SyncRCSsAtCN got " & rcsarr.length & " and found " & rcsarr2.length & " that needs updating, intended for node " & intendedcncode,kVerbosityDebugDetailed);
  
  if (rcsarr2.length>0) then begin 
    if (rcsarr2.length==1) then begin
      RCSr = rcsarr2[0];
      LogText2(0,"Syncronizing CC cloud server '" & RCSName(RCSr) & "' from controller, wantedstatus=" & WantedStatusName(RCSr.WantedStatus) & ", wantedsubstatus=" & WantedSubStatusName(RCSr.WantedSubStatus) & ", Controller=" & RCSr.Controller & ", CSb.NodeCode=" & CSb.NodeCode,kVerbosityDebugDetailed);
    end else begin
      LogText2(0,"SyncRCSsAtCN updating " & rcsarr2.length & " records from controller, intended for node " & intendedcncode,kVerbosityDebugDetailed);
    end;
    qupdating.SaveNewAndUpdatedLCSs(rcsarr2);
    qupdating.RCSArrToLCSArr(rcsarr2,lcsarr);
  end;
  
LSyncRCSsAtCN:;
  return;
end;

global
procedure SyncRCSsAtCN2(array record RemoteCloudServerVc rcsarr,string intendedcncode)
begin
  array record LocalCloudServerVc lcsarr;
  SyncRCSsAtCN3(rcsarr,intendedcncode,lcsarr);
  return;
end;

global
updating procedure GetOneLCS(var record LocalCloudServerVc LCSr,var Boolean foundf)
begin
  foundf = ReadFirstMain(LCSr,1,true);
//LogText(0,"GetOneLCS status=" & StatusName(LCSr.CurrentStatus));
  return;
end;

global
function Boolean FindServerAddrAndPort(string serverid,var string addr,var LongInt port,var Integer status)
begin
  Boolean res,testf,foundf;
  record RemoteCloudServerVc RCSr;
  record LocalCloudServerVc LCSr;
  record CloudNodeVc CNr;
  string 255 cnurl;
  array record RemoteCloudServerVc rcsarr;
  LongInt stat,starttick,serverstatus;
  Boolean scfailf;
  UUID server_uuid;
  
  server_uuid = StringToUUID(serverid);

  starttick = GetCurTick;

  status = 2; // not found
  res = false;
  port = -1;
  addr = "";

  if ((GetGlobalBoolean("ASPIdleTasksStopped")==true) or (QuitingApplication==true)) then begin
    status = 1; // try again if uuid in client is non-blank
    port = 30000; // so old clients don't give up
    addr = "0.0.0.0";  // so old clients don't give up
    goto LFindServerAddrAndPort;
  end;

LFindServerAddrAndPort_Again:;
  RCSr.UUID = server_uuid;
  if (ReadFirstMain(RCSr,1,true)==false) then begin
    //
    // TODO call the server archive service to see if this one was archived on a different controller
    //
    RCSr.UUID = server_uuid;
    if (qupdating.GetRCSOnMainThread(RCSr)==false) then begin
      LogText(0,"FindServerAddrAndPort(\"" & server_uuid & "\") failed, record not found");
      qupdating.StoreASPEvent(kASPEventTypeFindServerError,"FindServerAddrAndPort failed, record not found","",server_uuid,"");
      if (!BlankUUID(server_uuid)) then begin
        status = 1; // try again if uuid in client is non-blank
        port = 30000; // so old clients don't give up
        addr = "0.0.0.0";  // so old clients don't give up
      end;
    end else begin
      LogText(0,"FindServerAddrAndPort(\"" & server_uuid & "\") failed, RCS exists on main thread but not on processing thread");
      status = 1;
    end;
    goto LFindServerAddrAndPort;
  end;

  if (!BlankUUID(RCSr.ReplacedBy)) then begin
    server_uuid = RCSr.ReplacedBy;
    goto LFindServerAddrAndPort_Again;
  end;
  
  if (RCSr.ArchivedFlag!=0) then begin
    if (RestoreArchivedServer(RCSr,"")) then begin
      status = 1;
      goto LFindServerAddrAndPort;
    end;
  end;

  CNr.Code = RCSr.Controller;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    LogText(0,"FindServerAddrAndPort(\"" & server_uuid & "\") failed, node record " & CNr.Code & " not found");
    qupdating.StoreASPEvent(kASPEventTypeFindServerError,"FindServerAddrAndPort failed, node record not found","",server_uuid,RCSr.Controller);
    goto LFindServerAddrAndPort;
  end;

  port = RCSr.Port;
  addr = CNr.HostName;
  res = true;
  cnurl = ReadNodeUrl(CNr);

  if (OnDemandServerNeedsStarting(RCSr)) then begin
    queued.DoStartOnDemandServer(RCSr);
    status = 1; // try again
    goto LFindServerAddrAndPort;
  end;

  while ((GetCurTick-starttick)<(4 * kTicksPerSecond)) begin
    LCSr.UUID = RCSr.UUID;
    if (HostIsReachable(cnurl,1)) then begin
      stat = CallService(cnurl).GetOneLCS(LCSr,foundf);
      scfailf = TreatServiceError(stat,cnurl,"GetOneLCS");
      queued.SaveCloudNodeReachable(CNr.Code,!scfailf);
    end else begin
      LogText(0,"FindServerAddrAndPort " & cnurl & " is not reachable");
      scfailf = true;
    end;

    if (scfailf) then begin
      LogText(0,"Failed to get status for " & LCSr.UUID & " from node " & CNr.Code);
      qupdating.StoreASPEvent(kASPEventTypeFindServerError,"FindServerAddrAndPort failed, node not responding (2)","",RCSr.UUID,CNr.Code);
      status = 1; // try again
      goto LFindServerAddrAndPort;
    end;
    serverstatus = LCSr.CurrentStatus;

    switch (serverstatus) begin
      case kStatusRunningPendingStop:
        status = 0; // should be ok
        goto LFindServerAddrAndPort;
      case kStatusRunning:
        if (TestServerNotResponding(addr,port)) then begin
          LogText(0,"FindServerAddrAndPort(\"" & server_uuid & "\") got running but not yet responding, addr=" & addr & ", port=" & port);
          MilliSleep(200);
          status = 1; // starting up...
        end else begin
          status = 0; // good to go
          goto LFindServerAddrAndPort;
        end;
      otherwise
        status = 1; // starting up...
        LCSr.UUID = RCSr.UUID;
        stat = CallService(cnurl).GetOneLCS(LCSr,foundf);
        scfailf = TreatServiceError(stat,cnurl,"GetOneLCS");
        queued.SaveCloudNodeReachable(CNr.Code,!scfailf);
        if (scfailf) then begin
          LogText(0,"Failed to get status for " & LCSr.UUID & " from node " & CNr.Code);
          qupdating.StoreASPEvent(kASPEventTypeFindServerError,"FindServerAddrAndPort failed, node not responding (3)","",RCSr.UUID,CNr.Code);
          status = 1; // try again
          goto LFindServerAddrAndPort;
        end;
        if (serverstatus<>LCSr.CurrentStatus) then begin
          LogText(0,"FindServerAddrAndPort(\"" & server_uuid & "\") change status from " & StatusName(serverstatus) & " to " & StatusName(LCSr.CurrentStatus));
          serverstatus = LCSr.CurrentStatus;
          queued.UpdateRCSStatus(RCSr,serverstatus);
        end else begin
          LogText(0,"FindServerAddrAndPort(\"" & server_uuid & "\") sleep 200ms, status " & StatusName(serverstatus));
          MilliSleep(200);
        end;
    end;
  end;

LFindServerAddrAndPort:;
  LogText(0,"FindServerAddrAndPort(\"" & server_uuid & "\") got addr=" & addr & ", port=" & port & ", status=" & status);
  FindServerAddrAndPort = res;
  
  return;
end;

global
procedure FindServerAddrAndPortService(string serverid,var string addr,var LongInt port,var Integer status,var Boolean res)
begin
  res = FindServerAddrAndPort(serverid,addr,port,status);
  return;
end;

global
procedure FindServersWithId(string ident,Boolean testallf,var array record RemoteCloudServerVc RCSarr)
begin
  LongInt cnt;
  Boolean emailf;
  record CUVc CUr,mainCUr;
  record ContactRelVc ContactRelr;
  record RemoteCloudServerVc RCSr;
  record RemoteCloudServerVc RCS2r;
  record RemoteCloudServerVc RCS3r;
  record RemoteCloudServerVc RCS4r;
  record RemoteCloudServerVc RCS5r;
  Boolean foundf,found2f,found3f;

  ClearArray(RCSarr);

  if (blank(ident)) then begin
    LogText(0,"Warning: FindServersWithId called with blank identification");
    goto LFindServersWithId;
  end else begin
    LogText(0,"FindServersWithId called with identification """ & ident & """");
  end;

  emailf = CheckEmailStr(ident);

  cnt = 0;
  if (emailf==false) then begin
    LogText2(0,"FindServersWithId: CheckEmailStr==false",kVerbosityDebugDetailed);
    foundf = true;
    RCSr.CUCode = ident;
    while (LoopKey("CUCode",RCSr,1,foundf)) begin
      if (RCSr.CUCode!=ident) then begin foundf = false; end;
      if (foundf) then begin
        LogText2(0,"FindServersWithId: Ident recognized as customer for server " & RCSName(RCSr),kVerbosityDebugDetailed);
        RCSarr[RCSarr.length] = RCSr;
        cnt = cnt + 1;
      end;
    end;
    if (cnt==0) then begin
      LogText2(0,"FindServersWithId: Found no servers with ident used as a customer code",kVerbosityDebugDetailed);
    end;
  end;
  if (testallf==false and cnt>0) then begin goto LFindServersWithId; end;

  cnt = 0;
  if (emailf) then begin
    foundf = true;
    CUr.eMail = ident;
    while (LoopKey("eMail",CUr,1,foundf)) begin
      if (CUr.eMail!=ident) then begin foundf = false; end;
      if (foundf) then begin
        found2f = true;
        ResetLoop(RCS2r);
        RCS2r.CUCode = CUr.Code;
        while (LoopKey("CUCode",RCS2r,1,found2f)) begin
          if (RCS2r.CUCode!=CUr.Code) then begin found2f = false; end;
          if (found2f) then begin
            LogText2(0,"FindServersWithId: Ident recognized as e-mail address for server " & RCS2r.Name,kVerbosityDebugDetailed);
            RCSarr[RCSarr.length] = RCS2r;
            cnt = cnt + 1;
          end else begin
            ResetLoop(ContactRelr);
            ContactRelr.ContactCode = CUr.Code;
            if (ReadFirstKey("ContactCode",ContactRelr,1,true)) then begin
              mainCUr.Code = ContactRelr.CustCode;
              if (ReadFirstMain(mainCUr,1,true)) then begin
                found3f = true;
                ResetLoop(RCS3r);
                RCS3r.CUCode = mainCUr.Code;
                while (LoopKey("CUCode",RCS3r,1,found3f)) begin
                  if (RCS3r.CUCode!=mainCUr.Code) then begin found3f = false; end;
                  if (found3f) then begin
                    LogText2(0,"FindServersWithId: Ident recognized as e-mail (2) address for server " & RCS3r.Name,kVerbosityDebugDetailed);
                    RCSarr[RCSarr.length] = RCS3r;
                    cnt = cnt + 1;
                  end;
                end;
              end;
            end;
          end;
        end;
      end;
    end;
  end;
  if (cnt==0) then begin
    LogText2(0,"FindServersWithId: Found no servers with ident used an e-mail address",kVerbosityDebugDetailed);
  end;
  if (testallf==false and cnt>0) then begin goto LFindServersWithId; end;

  cnt = 0;
  foundf = true;
  RecordClear(CUr);
  ResetLoop(CUr);
  CUr.VATNr = ident;
  foundf = ReadFirstKey("VATNr",CUr,1,true);
  if (foundf) then begin
    LogText2(0,"FindServersWithId: Ident recognized as VAT nr with ident " & ident,kVerbosityDebugDetailed);
    found2f = true;
    RCS4r.CUCode = CUr.Code;
    while (LoopKey("CUCode",RCS4r,1,found2f)) begin
      if (RCS4r.CUCode!=CUr.Code) then begin found2f = false; end;
      if (found2f) then begin
        LogText2(0,"FindServersWithId: Ident recognized as VAT nr for server " & RCS4r.Name,kVerbosityDebugDetailed);
        RCSarr[RCSarr.length] = RCS4r;
        cnt = cnt + 1;
      end;
    end;
  end;
  if (cnt==0) then begin
    LogText2(0,"FindServersWithId: Found no servers with ident used as VAT nr.",kVerbosityDebugDetailed);
  end;
  if (testallf==false and cnt>0) then begin goto LFindServersWithId; end;

  cnt = 0;
  foundf = true;
  RecordClear(CUr);
  ResetLoop(CUr);
  CUr.RegNr1 = ident;
  foundf = ReadFirstKey("RegNr1",CUr,1,true);
  if (foundf) then begin
    LogText2(0,"FindServersWithId: Ident recognized as Reg nr with ident " & ident,kVerbosityDebugDetailed);
    found2f = true;
    ResetLoop(RCS2r);
    RCS2r.CUCode = CUr.Code;
    while (LoopKey("CUCode",RCS2r,1,found2f)) begin
      if (RCS2r.CUCode!=CUr.Code) then begin found2f = false; end;
      if (found2f) then begin
        LogText2(0,"FindServersWithId: Ident recognized as Reg nr for server " & RCS2r.Name,kVerbosityDebugDetailed);
        RCSarr[RCSarr.length] = RCS2r;
        cnt = cnt + 1;
      end;
    end;
  end;
  if (cnt==0) then begin
    LogText2(0,"FindServersWithId: Found no servers with ident used as Reg nr.",kVerbosityDebugDetailed);
  end;
  if (testallf==false and cnt>0) then begin goto LFindServersWithId; end;

/*
  cnt = 0;
  foundf = true;
  RecordClear(CUr);
  ResetLoop(CUr);
  CUr.RegNr2 = ident;
  foundf = ReadFirstKey("RegNr2",CUr,1,true);
  if (foundf) then begin
    LogText2(0,"FindServersWithId: Ident recognized as Reg nr 2 with ident " & ident,kVerbosityDebugDetailed);
    found2f = true;
    ResetLoop(RCS2r);
    RCS2r.CUCode = CUr.Code;
    while (LoopKey("CUCode",RCS2r,1,found2f)) begin
      if (RCS2r.CUCode!=CUr.Code) then begin found2f = false; end;
      if (found2f) then begin
        LogText2(0,"FindServersWithId: Ident recognized as Reg nr 2 for server " & RCS2r.Name,kVerbosityDebugDetailed);
        RCSarr[RCSarr.length] = RCS2r;
        cnt = cnt + 1;
      end;
    end;
  end;
  if (cnt==0) then begin
    LogText2(0,"FindServersWithId: Found no servers with ident used as Reg nr. 2",kVerbosityDebugDetailed);
  end;
  if (testallf==false and cnt>0) then begin goto LFindServersWithId; end;
*/

  cnt = 0;
  RecordClear(RCSr);
  ResetLoop(RCSr);
  RCSr.UUID = StringToUUID(ident);
  if (ReadFirstMain(RCSr,1,true)) begin
    LogText2(0,"FindServersWithId: Ident recognized as UUID for server " & RCSName(RCSr),kVerbosityDebugDetailed);
    RCSarr[RCSarr.length] = RCSr;
    cnt = cnt + 1;
  end;
  if (cnt==0) then begin
    LogText2(0,"FindServersWithId: Found no servers with ident used as UUID",kVerbosityDebugDetailed);
  end;
  if (testallf==false and cnt>0) then begin goto LFindServersWithId; end;

  cnt = 0;
  foundf = true;
  RecordClear(CUr);
  ResetLoop(CUr);
  CUr.Name = ident;
//  foundf = ReadFirstKey("Name",CUr,1,true);
//  if (foundf) then begin
  foundf = true;
  while (LoopKey("Name",CUr,1,foundf)) begin
    if (left(CUr.Name,len(ident))!=ident) then begin
      foundf = false;
    end else begin
      LogText2(0,"FindServersWithId: Ident recognized as Name with ident " & ident,kVerbosityDebugDetailed);
      found2f = true;
      ResetLoop(RCS2r);
      RCS2r.CUCode = CUr.Code;
      while (LoopKey("CUCode",RCS2r,1,found2f)) begin
        if (RCS2r.CUCode!=CUr.Code) then begin found2f = false; end;
        if (found2f) then begin
          LogText2(0,"FindServersWithId: Ident recognized as Name for server " & RCS2r.Name,kVerbosityDebugDetailed);
          RCSarr[RCSarr.length] = RCS2r;
          cnt = cnt + 1;
        end;
      end;
    end;
  end;
  if (cnt==0) then begin
    LogText2(0,"FindServersWithId: Found no servers with ident used as Name",kVerbosityDebugDetailed);
  end;
  if (testallf==false and cnt>0) then begin goto LFindServersWithId; end;

LFindServersWithId:;
  return;
end;

global
procedure FindServersWithId_Extended(string ident,Boolean testallf,var array record RemoteCloudServerVc RCSarr)
begin
  record RemoteCloudServerVc RCSr;

  if (len(ident)>=4) then begin
    while (LoopMain(RCSr,1,true)) begin
      if (InString(RCSr.Name,ident)>0) then begin
        LogText2(0,"FindServersWithId_Extended: Ident recognized as customer for server " & RCSName(RCSr),kVerbosityDebugDetailed);
        RCSarr[RCSarr.length] = RCSr;
      end;
    end;
  end;

  if (testallf or RCSarr.length==0) then begin
    FindServersWithId(ident,testallf,RCSarr);
  end;

  return;
end;

global
function Boolean FindServerAddrAndPortWithId2(string ident,var string addr,var LongInt port,var Integer status,var string name,var uuid serverid,var string curstatus,var string cursubstatus,var string buildno)
begin
  Boolean res,dummy;
  record RemoteCloudServerVc RCSr;
  record CloudNodeVc CNr;
  array record RemoteCloudServerVc RCSarr;
  record HansaVersionVc HVr;

  status = 2; // not found
  res = false;
  port = -1;
  addr = "";

  if (blank(ident)) then begin
    status = 1; // comm err, should be own status but to be compatible with older 8.0:s we'll pretend that the server is starting, which will cause a retry
    LogText(0,"FindServerAddrAndPortWithId2 called with blank identification");
    goto LFindServerAddrAndPortWithId;
  end;

  FindServersWithId(ident,false,RCSarr);

  if (RCSarr.length>0) then begin
    RCSr = RCSarr[0]; // only first hit for now
    if (RCSr.ArchivedFlag!=1) then begin
      CNr.Code = RCSr.Controller;
      if (ReadFirstMain(CNr,1,true)==false) then begin
        LogText(0,"FindServerAddrAndPortWithId2(\"" & ident & "\") failed, node record " & CNr.Code & " not found");
        qupdating.StoreASPEvent(kASPEventTypeFindServerError,"FindServerAddrAndPort failed, node record not found","",RCSr.UUID,RCSr.Controller);
        goto LFindServerAddrAndPortWithId;
      end;
    end;

    port = RCSr.Port;
    addr = CNr.HostName;
    name = RCSr.Name;
    serverid = RCSr.UUID;
    HVr.Code = RCSr.HansaVersion;
    if (ReadFirstMain(HVr,1,true)) then begin
      buildno = ValToString(((HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild),M4Val,"",".",1);
    end;
    LogText(0,"FindServerAddrAndPortWithId2(\"" & ident & "\") got addr=" & addr & ", port=" & port);
    res = true;

    if (OnDemandServerNeedsStarting(RCSr)) then begin
      queued.DoStartOnDemandServer(RCSr);
      status = 1; // try again
      goto LFindServerAddrAndPortWithId;
    end;

    switch (RCSr.CurrentStatus) begin
      case kStatusRunningPendingStop:
        status = 0; // should be ok
      case kStatusRunning:
        status = 0; // good to go
      otherwise
        status = 1; // starting up...
        curstatus = RCSr.CurrentStatus;//for upgrade from webpage we need to get the actual task that server is performing
        cursubstatus = RCSr.CurrentSubStatus;
    end;
  end;

LFindServerAddrAndPortWithId:;
  FindServerAddrAndPortWithId2 = res;
  LogText2(0,"FindServerAddrAndPortWithId2(\"" & ident & "\") got addr=" & addr & ", port=" & port & ", res=" & res & ", status=" & status,kVerbosityDebug);
  return;
end;

global
function Boolean FindServerAddrAndPortWithId(string ident,var string addr,var LongInt port,var Integer status,var string name,var uuid serverid)
begin
  string 255 curstatus,cursubstatus,buildno;
  Boolean res;

  res = FindServerAddrAndPortWithId2(ident,addr,port,status,name,serverid,curstatus,cursubstatus,buildno);

  FindServerAddrAndPortWithId = res;
  return;
end;

global
function Boolean FindCloudServerAddr(record RemoteCloudServerVc RCSr,var string addr)
begin
  Boolean res;
  record CloudNodeVc CNr;

  res = false;
  addr = "";

  if (blank(RCSr.PublicHostName)) then begin
    CNr.Code = RCSr.Controller;
    if (ReadFirstMain(CNr,1,true)==false) then begin
      goto LFindCloudServerAddr;
    end;
    //Possibly CallService().FindLocalServerAddrAndPort()
    addr = CNr.HostName;
  end else begin
    addr = RCSr.PublicHostName;
  end;

  res = true;

LFindCloudServerAddr:;
  FindCloudServerAddr = res;

  return;
end;

global
updating procedure CreateRemoteServer(uuid serverid,record CloudNodeVc CNr,record HansaVersionVc HVr,record CUVc CUr,var string errorstr,var LongInt port,var LongInt http_port,var LongInt https_port,string country_localizations,Boolean ondemandf,Boolean findportsf,string backuppath,string backuptime,Boolean withcertsf)
begin
  record RemoteCloudServerVc RCSr,RCS2r;
  row RemoteCloudServerVc RCSrw;
  string 255 datafolder;
  Integer btime;
  LongInt stat;
  Boolean scfailf;
  string 255 url;

  if (findportsf) then begin
    FindUnusedPortsOnCC(CNr.Code,port,http_port,https_port); // Checking on CC to prevent conflict with unsynced RCSr:s
    url = NodeURL(CNr);
    stat = CallService(url).FindUnusedPorts(port,http_port,https_port); // Checking on CN to ensure port is available on the machine
    scfailf = TreatServiceError(stat,url,"FindUnusedPorts");
    queued.SaveCloudNodeReachable(CNr.Code,!scfailf);
  end;
  // TODO: handle errors

  datafolder = ServersFolder & "Auto/" & serverid;
  if (nonblank(CUr.Code)) then begin
    RCSr.ServerName = "hansa-autoserver-" & CUr.Code;
  end else begin
    RCSr.ServerName = "hansa-autoserver";
  end;
  RCSr.UUID = serverid;
  RCSr.CUCode = CUr.Code;
  RCSr.HMCUCode = CUr.Code;
  RCSr.Classification = CUr.Classification;
  RCSr.Name = CUr.Name;//Not here
  RCSr.HansaVersion = HVr.Code;
  RCSr.DataFolder = datafolder;
  RCSr.Port = port;
  RCSr.HTTPPort = http_port;
  RCSr.HTTPSPort = https_port;
  RCSr.CurrentStatus = kStatusCreating;
  RCSr.UUIDLock = 1;
  RCSr.Controller = CNr.Code;
  RCSr.NewController = CNr.Code;
  RCSr.LogLevel = 2;
  RCSr.HalcustUpdateRule = 3;
  RCSr.HalpatchUpdateRule = 3;
  RCSr.CountryLocalizations = country_localizations;
  if (ondemandf) then begin
    RCSr.OnDemandFlag = 1;
    RCSr.BackupOnStopFlag = 1;
    btime = Random(1,24);
    RCSr.BackupTime = right("0" & btime-1 & ":00",5);
    RCSr.BackupFolder = "Backup";
  end else begin
    RCSr.BackupTime = backuptime;
    RCSr.BackupFolder = backuppath;
  end;
  RCSr.WantedStatus = kWantedStatusCreateStartedServer;
  
  if (withcertsf) then begin
    RCSr.SSLCertFlag = 1;
  end;
  
  if (nonblank(CUr.Comment1)) then begin // contains the App Store receipt hash, see HTSCloudControllerSetupServerV1
    RCSrw.Item = kManagedServerItemEnabler;
    RCSrw.ItemName = "EnAppleInAppPurchase";
    RCSrw.When = kManagedServerWhenRunningNormally;
    RCSrw.Disabled = 0;
    MatRowPut(RCSr,MatRowCnt(RCSr),RCSrw);
  end;

  if (RecordInsert(RCSr,false)==false) then begin
    errorstr = "failed to save server record";
    LogText(0,"CreateRemoteServer error: " & errorstr);
  end;

  return;
end;

global
