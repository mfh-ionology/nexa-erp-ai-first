function string 2 CRLF()
begin
  CRLF = chr(13) & chr(10);
  return;
end;

function string 255 LogTimeStamp()
begin
  LogTimeStamp = DateToString(CurrentDate,"YYYY-MM-DD") & " " & TimeToString(CurrentTime,"HH",false) & ":" & TimeToString(CurrentTime,"MM",false);
  return;
end;

global
updating procedure AddLineToServerMoveLog(record ServerMoveVc SMr,string textstr)
begin
  record RLinkVc RLr;
  record NotepadVc NPr;
  Integer notenr;
  area a_text;

  AddTextToArea(LogTimeStamp & " " & textstr & CRLF,a_text);
  
  notenr = 1;
  while (ReadRecordLink(SMr,notenr,NPr,RLr)) begin
    if (RLr.Comment=="Server Move Log") then begin goto LAddLineToServerMoveLog_add; end;
    notenr = notenr + 1;
  end;
  
  RecordNew(NPr);
  NPr.SerNr = NextSerNr("NotepadVc",CurrentDate,-1,false,"");
  AddAreaToTextField(a_text,NPr);
  if (RecordStore(NPr,false)) then begin
    CreateRecordLink(SMr,CurrentCompany,NPr,CurrentCompany);
    if (ReadRecordLink(SMr,notenr,NPr,RLr)) then begin
    RLr.Comment = "Server Move Log";
      if (RecordStore(RLr,true)) then begin end;
    end;
  end;
  goto LAddLineToServerMoveLog;

LAddLineToServerMoveLog_add:;
  AddAreaToTextField(a_text,NPr);
  if (RecordStore(NPr,true)) then begin end;
  
LAddLineToServerMoveLog:;
  return;
end;

global
