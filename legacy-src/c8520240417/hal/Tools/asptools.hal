global
function LongInt ReadLongFromFile(string filename)
begin
  LongInt res;
  area a;

  ReadLongFromFile = StringToLongInt(ReadStringFromFile(filename));
  
  return;
end;

procedure RecoverPidFile(record LocalCloudServerVc LCSr,string pidfilename,var Boolean pid_is_runningf,var Boolean pidfile_existsf,var LongInt svpid)
begin
  LongInt lsvpid;

  if (GetPidIfExeUsesFile(HDBFile2(LCSr),ServerExe(LCSr),lsvpid)) then begin
    if (PidIsRunning(lsvpid)) then begin
      Delete_File(pidfilename);
      WriteStringToFile(lsvpid,pidfilename,0);
      svpid = lsvpid;
      pid_is_runningf = true;
      pidfile_existsf = true;
    end else begin
      svpid = -1;
    end;
  end;

  return;
end;

global
function LongInt ServerPid(record LocalCloudServerVc LCSr)
begin
  string 255 pidfilename;
  Boolean pidfile_existsf,pid_is_runningf;
  LongInt svpid;

  pidfilename = PidFile(LCSr);
  pidfile_existsf = FileExists(pidfilename);

  if (pidfile_existsf) then begin
    svpid = ReadLongFromFile(pidfilename);
    pid_is_runningf = PidIsRunning(svpid);
  end;

/* This is way to expensive if run on the main thread
  if (pid_is_runningf==false) then begin
    RecoverPidFile(LCSr,pidfilename,pid_is_runningf,pidfile_existsf,svpid);
  end;
*/
  if (pid_is_runningf) then begin
    ServerPid = svpid;
  end else begin
    ServerPid = -1;
  end;
  return;
end;

procedure DebugTrace(string text)
begin
  LogText(0,text);
end;

procedure UpdateLCSEnablers(record LocalCloudServerVc LCSr,Integer when)
begin
  row LocalCloudServerVc LCSrw;
  Integer i,rwcnt;
  string 255 filename;
  area a;
  
  rwcnt = MatRowCnt(LCSr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(LCSr,i,LCSrw);
    if (LCSrw.Item==kManagedServerItemEnabler) then begin
      filename = LCSr.DataFolder & "/" & LCSrw.ItemName;
      Delete_File(filename);
      if (((LCSrw.When==when) or (LCSrw.When==kManagedServerWhenAlways)) and LCSrw.Disabled==0) then begin
        if (blank(LCSrw.Data)) then begin
          CreateFile(filename);
          CloseFile;
        end else begin
          SetAreaZeroSize(a);
          AddTextToArea(LCSrw.Data,a);
          WriteAreaToFile(a,filename,0);
        end;
      end;
    end;
  end;

  return;
end;

function Boolean RCSShouldStartInMaintenance(record RemoteCloudServerVc RCSr,Integer when)
begin
  row RemoteCloudServerVc RCSrw;
  Integer i,rwcnt;
  Boolean res;

  rwcnt = MatRowCnt(RCSr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(RCSr,i,RCSrw);
    if ((RCSrw.Item==kManagedServerItemStartMaintenance) and (RCSrw.Disabled==0) and
        (RCSrw.When==when)) then begin
      res = true;
    end;
  end;

  RCSShouldStartInMaintenance = res;
  return;
end;

function Boolean RCSShouldTreatSlaveSystems(record RemoteCloudServerVc RCSr,Integer when)
begin
  row RemoteCloudServerVc RCSrw;
  Integer i,rwcnt;
  Boolean res;

  rwcnt = MatRowCnt(RCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(RCSr,i,RCSrw);
    if (RCSrw.Item==kManagedServerItemSlaveSystem) then begin
      if ((RCSrw.When==kManagedServerWhenRunningNormally) and (when==kManagedServerWhenUpdateBegins) and RCSrw.Disabled==0) then begin
        res = true;
      end;
    end;
  end;

  RCSShouldTreatSlaveSystems = res;
  return;
end;

function Boolean RCSShouldTreatCrontab(record RemoteCloudServerVc RCSr,Integer when)
begin
  row RemoteCloudServerVc RCSrw;
  Integer i,rwcnt;
  Boolean res;

  rwcnt = MatRowCnt(RCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(RCSr,i,RCSrw);
    if (RCSrw.Item==kManagedServerItemCrontabEntry) then begin
      if ((RCSrw.When==kManagedServerWhenUpdating) and ((when==kManagedServerWhenUpdateBegins) or (when==kManagedServerWhenUpdateEnds))) then begin
        res = true;
      end;
    end;
  end;

  RCSShouldTreatCrontab = res;
  return;
end;

function Boolean RCSShouldTreatSystemCopy(record RemoteCloudServerVc RCSr,Integer when)
begin
  record RemoteCloudServerVc RCS2r;
  row RemoteCloudServerVc RCSrw;
  Integer i,rwcnt;
  Boolean res;

  rwcnt = MatRowCnt(RCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(RCSr,i,RCSrw);
    if (RCSrw.Item==kManagedServerItemSystemCopy) then begin
      if (((RCSrw.When==when) or ((RCSrw.When==kManagedServerWhenUpdating) and (when==kManagedServerWhenUpdateBegins)) or
        ((RCSrw.When==kManagedServerWhenUpdateBegins) and (when==kManagedServerWhenUpdateExports))) and (RCSrw.Disabled==0)) then begin
        RCS2r.UUID = StringToUUID(RCSrw.ItemName);
        if (ReadFirstMain(RCS2r,1,true)) then begin
          if (RCS2r.Closed==0) then begin res = true; end;
        end;
      end;
    end;
  end;

  RCSShouldTreatSystemCopy = res;
  return;
end;

global
procedure PublishHansaMailLivePackagesAtCN(record HansaVersionVc HVr)
begin
  string 255 shfile;
  area a_script;
  LongInt rbuild;

  rbuild = (HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild;

  LogText2(0,"PublishHansaMailLivePackagesAtCN()",kVerbosityDebugDetailed);

  AddLineToArea("#!/bin/bash",a_script);
  AddLineToArea("cd /Translations",a_script);
  AddLineToArea("vfolder=$(dirname $(grep -l \".\\.. ....-..-.. HansaMail\" c990*/.folderalias) 2>/dev/null)",a_script);
  AddLineToArea("if ( [ \"${vfolder}\" != \"\" ] ) then",a_script);
  AddLineToArea("p_cntry=great-britain",a_script);
  AddLineToArea("p_prod=HansaMail",a_script);
  AddLineToArea("p_prodlc=hansamail",a_script);
  AddLineToArea("running_build=" & rbuild,a_script);
  AddLineToArea("p_ccode=gbr",a_script);
  AddLineToArea("/Translations/_svr_publish_packages /Translations/${vfolder} \"(Apr 25 14:59:40 2016) ${p_cntry}/SpecificProducts/${p_prod}/Packages/${p_prodlc}.${p_cntry}.android.client.${running_build}.live.apk\" false false false false",a_script);
  AddLineToArea("/Translations/_svr_publish_packages /Translations/${vfolder} \"(Apr 25 21:25:52 2016) ${p_cntry}/SpecificProducts/${p_prod}/Packages/${p_prodlc}.${p_cntry}.macosx.client.${running_build}.live.dmg\" false false false false",a_script);
  AddLineToArea("/Translations/_svr_publish_packages /Translations/${vfolder} \"(Apr 25 21:26:40 2016) ${p_cntry}/SpecificProducts/${p_prod}/Packages/${p_prodlc}.${p_cntry}.windowsnet.client.${running_build}.live.msi\" false false false false",a_script);
  AddLineToArea("/Translations/_svr_publish_packages /Translations/${vfolder} \"(Apr 25 21:27:00 2016) ${p_cntry}/SpecificProducts/${p_prod}/Packages/${p_prodlc}.${p_cntry}.ios-999999999.client.${running_build}.live.ipa\" false false false false",a_script);
  AddLineToArea("fi",a_script);

  shfile = CreateTempFile("PHML-Script",".sh");
  WriteAreaToFile(a_script,shfile,0);
  RunShellScript("bash " & shfile);
  Delete_File(shfile);
  return;
end;

global
procedure PublishHansaMailLivePackages(record LocalCloudServerVc LCSr)
begin
  string 255 url;
  LongInt stat;
  record HansaVersionVc HVr;

  HVr.Code = LCSr.HansaVersion;
  if (ReadFirstMain(HVr,1,true)==true) then begin
    url = "hmt.hansaworld.com:499";
    LogText2(0,"PublishHansaMailLivePackages() calling PublishHansaMailLivePackagesAtCN on " & url,kVerbosityDebugDetailed);
    stat = CallService(url).PublishHansaMailLivePackagesAtCN(HVr);
    if (TreatServiceError(stat,url,"PublishHansaMailLivePackagesAtCN")) then begin
      LogText(0,"ERROR: Failed to publish HansaMail Live packages");
    end;
  end;

  return;
end;

global
function string 255 DetermineNextName(string fname,Boolean folderf,Boolean with_datef)
begin
  string 255 nextname;
  string 255 tstr;
  Integer idx;
  Boolean testf;


  if (with_datef) then begin
    nextname = fname & "-" & DateToString(CurrentDate,"YYYYMMDD");
  end else begin
    nextname = fname;
  end;
  tstr = nextname;

LDetermineNextName_Again:;
  if (folderf) then begin
    testf = DirExists(tstr);
  end else begin
    testf = FileExists(tstr);
  end;
  if (testf) then begin
    idx = idx + 1;
    tstr = nextname & "-" & idx;
    goto LDetermineNextName_Again;
  end;

  DetermineNextName = tstr;
  return;
end;

function string 255 CanonicalWorkDir(string workdir)
begin
  string 255 res;

  if ((left(workdir,1)!="/") and (left(workdir,1)!="\\") and (mid(workdir,1,2)!=":\\")) then begin
    res = ProgramFolder & "/" & workdir;
  end else begin
    res = workdir;
  end;

  CanonicalWorkDir = res;
  return;
end;

procedure RenameBlockingFolder(string folder)
begin
  string 255 tstr;

  if (DirExists(folder)) then begin
    tstr = DetermineNextName(folder,false,true);
    RenameFile(folder,tstr);
  end;
end;

global
updating procedure ChangeVersionOnLocalCloudServer(UUID server_uuid,string new_vercode)
begin
  record LocalCloudServerVc OldLCSr,LCSr;
  record HansaVersionVc HV1r,HV2r;
  Boolean renamedbf;
  string 255 workdir,bkfldr,tstr,dbpath,dbfile;

  LCSr.UUID = server_uuid;
  if (ReadFirstMain(LCSr,1,true)==false) then begin
    LogText(0,"ChangeVersionOnLocalCloudServer(\"" & server_uuid & "\") failed, record not found");
  end else begin
    HV1r.Code = LCSr.HansaVersion;
    ReadFirstMain(HV1r,1,true);
    HV2r.Code = new_vercode;
    ReadFirstMain(HV2r,1,true);
    if (HV1r.Version!=HV2r.Version or HV1r.SubVersion!=HV2r.SubVersion) then begin
      switch (LCSr.CloneFlag) begin
        case 1: renamedbf = true;
        case 2:
        case 3:
        otherwise
      end;
    end;

    if (renamedbf) then begin
      dbpath = HDBFile(LCSr,HV1r);
      if (FileExists(dbpath)) then begin
        workdir = CanonicalWorkDir(LCSr.DataFolder);
        dbfile = BaseName(dbpath);
        bkfldr = workdir & "/oldver." & LCSr.HansaVersion;  //## should have timestamp
        CreateFolderHierarchy(bkfldr & "/");
        RenameBlockingFolder(bkfldr & "/" & dbfile);
        MoveFile(dbfile,DirName(dbpath),bkfldr);
      end;
    end;

    RecordCopy(OldLCSr,LCSr);
    LCSr.OldHansaVersion = LCSr.HansaVersion;
    LCSr.HansaVersion = new_vercode;
    RecordUpdate(OldLCSr,LCSr,true);
//    if (LCSr.Name=="HansaMail Live") then begin
//      PublishHansaMailLivePackages(LCSr);
//    end;
  end;
  return;
end;

global
updating procedure StartCloningAtCN(record LocalCloudServerVc LCSr,string passw,area a_ec2_key)
begin
  string 255 enpath;

  if (ReadFirstMain(LCSr,1,true)) then begin
//    Delete_File(LCSr.DataFolder & "/clone-attach-k.dat");
//    if (GetAreaLength(a_ec2_key)>0) then begin
//      WriteAreaToFile(a_ec2_key,LCSr.DataFolder & "/clone-attach-k.dat",0);
//    end;
    enpath = EnablerActionsFolder(LCSr) & "/";
    CreateFolderHierarchy(enpath);
    Delete_File(enpath & ".EnStartCloning");
    WriteStringToFile(passw,enpath & ".EnStartCloning",0);
    RenameFile(enpath & ".EnStartCloning",enpath & "EnStartCloning");
  end else begin
    LogText(0,"Failed to start cloning on cloud server " & LCSr.UUID);
  end;
  return;
end;

global
updating procedure AddCloningKeyAtCN(string datafolder,area a_ec2_key)
begin
  CreateFolderHierarchy(datafolder & "/");
  Delete_File(datafolder & "/clone-attach-k.dat");
  if (GetAreaLength(a_ec2_key)>0) then begin
    WriteAreaToFile(a_ec2_key,datafolder & "/clone-attach-k.dat",0);
  end;
  return;
end;

updating procedure StartCloning(record RemoteCloudServerVc RCSr,string passw,record RemoteCloudServerVc RCS2r)
begin
  string 255 url;
  LongInt stat;
  record LocalCloudServerVc LCSr;
  record HostingConfigurationVc HCr;
  record CloudNodeVc CNr;
  record Attach2Vc AT2r;
  LongInt blocklen;
  area a_ec2_key;
  Boolean scfailf;

  url = RcsNodeURL(RCSr);
  if (nonblank(url)) then begin
    CNr.Code = RCSr.Controller;
    ReadFirstMain(CNr,1,true);
    HCr.SerNr = CNr.HostingConfig;
    if (!ReadFirstMain(HCr,1,true)) then begin
      LogText(0,"Cloning of attachments and other files will be disabled for server " & RCSName(RCSr) & " on node " & CNr.Code & " because the hosting configuration " & CNr.HostingConfig & " is missing");
    end else begin
      if (GetKeyForHostingConfiguration(HCr,AT2r)==false) then begin
        LogText(0,"Cloning of attachments and other files will be disabled because the hosting configuration with SerNr=" & HCr.SerNr & ", " & CNr.HostingConfig & " (" & CNr.HostingConfigComment & ") have no key uploaded");
      end else begin
        blocklen = AttachFileSize(AT2r);
        SetAreaZeroSize(a_ec2_key);
        LoadAttachFilePartToArea(AT2r,0,blocklen,a_ec2_key);
      end;
    end;
    LCSr.UUID = RCSr.UUID;
    LogText(0,"Starting cloning of remote cloud server " & RCSName(RCSr));
    stat = CallService(url).StartCloningAtCN(LCSr,passw,a_ec2_key);
    scfailf = TreatServiceError(stat,url,"StartCloningAtCN");
    queued.SaveCloudNodeReachable(RCSr.Controller,!scfailf);
    if (scfailf) then begin
      LogText(0,"Failed to start cloning of remote cloud server " & RCSName(RCSr));
    end;

    url = RcsNodeURL(RCS2r);
    if (nonblank(url)) then begin
      LogText(0,"Adding key for cloning to remote cloud server " & RCS2r.Name);
      stat = CallService(url).AddCloningKeyAtCN(RCS2r.DataFolder,a_ec2_key);
      scfailf = TreatServiceError(stat,url,"AddCloningKeyAtCN");
      queued.SaveCloudNodeReachable(RCS2r.Controller,!scfailf);
      if (scfailf) then begin
        LogText(0,"Failed add key for cloning to remote cloud server " & RCS2r.Name);
      end;
    end else begin
      LogText(0,"(Node URL missing) Failed add key for cloning to remote cloud server " & RCS2r.Name);
    end;
  end else begin
    LogText(0,"Failed to start cloning of remote cloud server " & RCSName(RCSr) & ", because the node " & RCSr.Controller & " have no address");
  end;
  return;
end;

function LongInt FindUnusedPort(LongInt firstport,LongInt lastport)
begin
  record LocalCloudServerVc LCSr;
  LongInt res;
  
  res = firstport - 1;
  
LFindUnusedPort_Again:;
  res = res + 1;

  if (res>lastport) then begin
    res = -1;
    goto LFindUnusedPort;
  end;

  LCSr.Port = res;
  if (ReadFirstKey("Port",LCSr,1,true)) then begin goto LFindUnusedPort_Again; end;

  LCSr.HTTPPort = res;
  if (ReadFirstKey("HTTPPort",LCSr,1,true)) then begin goto LFindUnusedPort_Again; end;

  LCSr.HTTPSPort = res;
  if (ReadFirstKey("HTTPSPort",LCSr,1,true)) then begin goto LFindUnusedPort_Again; end;

  LCSr.MaintPort = res;
  if (ReadFirstKey("MaintPort",LCSr,1,true)) then begin goto LFindUnusedPort_Again; end;

  if (TCPPortAvailable(res,"")==false) then begin goto LFindUnusedPort_Again; end;

LFindUnusedPort:;
  FindUnusedPort = res;
  return;
end;
  
global
procedure FindUnusedPorts(var LongInt port,var LongInt httpport,var LongInt httpsport)
begin
  LongInt lastport;
  if (port==-1) then begin
    port = 10000;
  end;
  lastport = 50000;

  port = FindUnusedPort(port,lastport);
  if (port==-1) then begin goto LFindUnusedPorts; end;
  httpport = FindUnusedPort(port+1,lastport);
  if (httpport==-1) then begin goto LFindUnusedPorts; end;
  httpsport = FindUnusedPort(httpport+1,lastport);
  if (httpsport==-1) then begin goto LFindUnusedPorts; end;
  
LFindUnusedPorts:;
  return; 
end;

function
string 255 FindCloudNodeAddress(string code,Boolean withuserf)
begin
  record CloudNodeVc CNr;
  
  FindCloudNodeAddress = "";
  CNr.Code = code;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    LogText(0,"FindCloudNodeAddress(\"" & code & "\") failed, record not found");
    goto LFindCloudNodeAddress;
  end;
  if (withuserf) then begin
    FindCloudNodeAddress = CNr.AdminUser & "@" & CNr.HostName;
  end else begin
    FindCloudNodeAddress = CNr.HostName;
  end;
  
LFindCloudNodeAddress:;
  return;
end;

global
updating function Boolean DoChangeVersionOnRemoteCloudServer(record RemoteCloudServerVc RCSr,string new_vercode)
begin
  Boolean res,testf;
  string 255 url;
  LongInt stat;
  record CloudNodeVc CNr;
  row RemoteCloudServerVc RCSrw;
  record RemoteCloudServerVc RCS2r,OldRCS2r;
  Integer rwcnt,i;
  Boolean scfailf;

  if (ReadFirstMain(RCSr,1,true)==false) then begin
    LogText(0,"ERROR DoChangeVersionOnRemoteCloudServer RCSr.Name=" & RCSName(RCSr) & ", RCSr.UUID=" & RCSr.UUID & " not found!");
    goto LDoChangeVersionOnRemoteCloudServer;
  end;

  rwcnt = MatRowCnt(RCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(RCSr,i,RCSrw);
    testf = false;
//    if (RCSrw.Item==kManagedServerItemSystemCopy) then begin testf = true; end;
//    if (RCSrw.Item==kManagedServerItemSlaveSystem) then begin testf = true; end;
    if (RCSrw.Item==kManagedServerItemReserveSystem) then begin testf = true; end;
    if (RCSrw.Item==kManagedServerItemTestSystem) then begin testf = true; end;
    //if (RCSrw.Item==kManagedServerItemUpdateSystem) then begin testf = true; end;
    if (RCSrw.Item==kManagedServerItemSlaveSystem) then begin testf = true; end;
    if (RCSrw.Disabled!=0) then begin testf = false; end;
    if (testf==true) then begin
      RCS2r.UUID = StringToUUID(RCSrw.ItemName);
      if (ReadFirstMain(RCS2r,1,true)) then begin
        if ((RCS2r.Closed==0) and (RCS2r.HansaVersion==RCSr.HansaVersion)) then begin
          CNr.Code = RCS2r.Controller;
          url = ReadNodeURL(CNr);

          if (RCSrw.Item==kManagedServerItemSlaveSystem) then begin
            RecordCopy(OldRCS2r,RCS2r);
            RCS2r.NewHansaVersion = new_vercode;
            RecordUpdate(OldRCS2r,RCS2r,true);
            UpdateRemoteCloudServer(RCS2r);
          end else begin
            stat = CallService(url).ChangeVersionOnLocalCloudServer(RCS2r.UUID,new_vercode);
            scfailf = TreatServiceError(stat,url,"ChangeVersionOnLocalCloudServer");
            queued.SaveCloudNodeReachable(CNr.Code,!scfailf);
            if (scfailf) then begin
              LogText(0,"Failed to change version to " & new_vercode & " on " & RCSName(RCS2r));
            end;
          end;
        end else begin
          LogText(0,"Not changing version on " & RCSName(RCS2r) & " because it is either closed on not on the same version as the mother system");
        end;
      end;
    end;
  end;

  CNr.Code = RCSr.Controller;
  url = ReadNodeURL(CNr);

  stat = CallService(url).ChangeVersionOnLocalCloudServer(RCSr.UUID,new_vercode);
  scfailf = TreatServiceError(stat,url,"ChangeVersionOnLocalCloudServer");
  queued.SaveCloudNodeReachable(RCSr.Controller,!scfailf);
  if (scfailf) then begin
    LogText(0,"Failed to change version to " & new_vercode & " on " & RCSName(RCSr));
    goto LDoChangeVersionOnRemoteCloudServer;
  end;

  if (ReadFirstMain(RCSr,1,true)) then begin
    RCSr.RcsSeqNr = -1;
    threadasync.SyncOneRCS(RCSr,true,true,"1");
  end;
  res = true;

LDoChangeVersionOnRemoteCloudServer:;
  DoChangeVersionOnRemoteCloudServer = res;
  return;
end;

function Boolean ChangeManagedServerItem(var record RemoteCloudServerVc RCSr,Integer item_type,string item_name,string new_value)
begin
  row RemoteCloudServerVc RCSrw;
  Integer i,rwcnt;
  Boolean res;

  rwcnt = MatRowCnt(RCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(RCSr,i,RCSrw);
    if (RCSrw.Item==item_type) then begin
      if (RCSrw.ItemName==item_name) then begin
        RCSrw.Data = new_value;
        MatRowPut(RCSr,i,RCSrw);
        res = true;
      end;
    end;
  end;
  return;
end;

global
procedure RemoveManagedServerItemByName(var record RemoteCloudServerVc RCSr,string item_name)
begin
  row RemoteCloudServerVc RCSrw;
  Integer rwcnt;
  LongInt idx;

  rwcnt = MatRowCnt(RCSr);
  if (rwcnt>0) then begin
    for (idx = rwcnt-1; idx>=0; idx = idx - 1) begin
      MatRowGet(RCSr,idx,RCSrw);
      if (RCSrw.ItemName==item_name) then begin
        MatRowDelete(RCSr,idx);
      end;
    end;
  end;
  
  return;
end;


global
updating procedure DoLaunchRemoteCloudServerSystem3(var record RemoteCloudServerVc RCSr,string rcsname,string rcsdir,string rcscontroller,string rcsversion,Boolean copyattachf,Boolean copyfilesf,LongInt dbcachesz,Integer system_type,var string msg,var UUID newserverid)
begin
  record CloudNodeVc CNr;
  record RemoteCloudServerVc RCS2r;
  row RemoteCloudServerVc RCSrw,RCS2rw,RCS3rw;
  string 255 passw,cloneflags,url;
  Integer i,rwcnt,stat;
  Boolean newpasswf;
  Boolean scfailf;

  if (blank(rcsname)) then begin
    msg = "Name may not be blank.";
    goto LDoLaunchRemoteCloudServerSystem3;
  end;
  if (RCSr.Name==rcsname) then begin
    msg = "The system name must be different from the mother systems name.";
    goto LDoLaunchRemoteCloudServerSystem3;
  end;

  if (blank(rcsdir)) then begin
    msg = "Folder may not be blank.";
    goto LDoLaunchRemoteCloudServerSystem3;
  end;

/* had to disable this for on-premise servers
  if (left(rcsdir,9)!="/Servers/" and mid(rcsdir,2,9)!="\\Servers\\" and left(rcsdir,8)!="Servers/") then begin
    msg = "Folder must be in Servers subfolder.";
    goto LDoLaunchRemoteCloudServerSystem3;
  end;
*/
  if (RCSr.DataFolder==rcsdir and RCSr.Controller==rcscontroller) then begin//was RCSr.Name==rcsdir a bug???
    msg = "The system folder must be different from the mother systems folder when launching it on the same node.";
    goto LDoLaunchRemoteCloudServerSystem3;
  end;

  if ((RCSr.CurrentStatus!=kStatusStopped) and
      (RCSr.CurrentStatus!=kStatusRunning)) then begin
    msg = "The cloud server must be stopped or running when launching this system.";
    goto LDoLaunchRemoteCloudServerSystem3;
  end;

  CNr.Code = rcscontroller;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    msg = "The cloud node " & rcscontroller & " does not exist.";
    goto LDoLaunchRemoteCloudServerSystem3;
  end;

// TODO: Change datafolder if node is different from master system node
  RecordCopy(RCS2r,RCSr);

  newpasswf = true;
  rwcnt = MatRowCnt(RCS2r);
  for (i = rwcnt-1; i>=0; i = i - 1) begin
    MatRowGet(RCS2r,i,RCS3rw);
    if ((RCS3rw.Item==kManagedServerItemTestSystem) or (RCS3rw.Item==kManagedServerItemReserveSystem) or (RCS3rw.Item==kManagedServerItemUpdateSystem)) then begin
      passw = RCS3rw.Data;
      newpasswf = false;
      MatRowDelete(RCS2r,i);
    end else begin
      if (RCS3rw.Item==kManagedServerItemSlaveSystem) then begin
        RCS3rw.Disabled = 1;
        MatRowPut(RCS2r,i,RCS3rw);
      end;
    end;
  end;

  url = NodeURL(CNr);
  stat = CallService(url).FindUnusedPorts(RCS2r.Port,RCS2r.HTTPPort,RCS2r.HTTPSPort);
  scfailf = TreatServiceError(stat,url,"FindUnusedPorts");
  queued.SaveCloudNodeReachable(CNr.Code,!scfailf);
  if (scfailf) then begin
    LogText(0,"Failed reading unused ports on node " & CNr.Code);
  end;

  RCS2r.UUID = MakeUUID;
  RCS2r.CreatedDate = CurrentDate;
  RCS2r.CreatedTime = CurrentTime;
  RCS2r.Controller = CNr.Code;
  RCS2r.NewController = CNr.Code;
  RCS2r.PublicHostName = CNr.HostName;

  switch (system_type) begin
    case kSystemTypeTest:
      RCS2r.HansaVersion = rcsversion;
      RCS2r.WantedStatus = kWantedStatusLaunchTestSystem;
      RCS2r.Name = rcsname;
      RCS2r.DataFolder = rcsdir;
      RCS2r.CloneFlag = kSystemTypeTest;
      RCS2r.ServerName = RCS2r.ServerName & "-test";
      ChangeManagedServerItem(RCS2r,kManagedServerItemEnabler,"EnPKGT","test");
    case kSystemTypeReserve:
      RCS2r.HansaVersion = RCSr.HansaVersion;
      RCS2r.WantedStatus = kWantedStatusLaunchReserveSystem;
      RCS2r.Name = rcsname;
      RCS2r.DataFolder = rcsdir;
      RCS2r.CloneFlag = kSystemTypeReserve;
      RCS2r.ServerName = RCS2r.ServerName & "-reserve";
    case kSystemTypeUpdate:
      RCS2r.HansaVersion = rcsversion;
      RCS2r.WantedStatus = kWantedStatusLaunchUpdateSystem;
      RCS2r.Name = rcsname;
      RCS2r.DataFolder = rcsdir;
      RCS2r.CloneFlag = kSystemTypeUpdate;
      RCS2r.ServerName = RCS2r.ServerName & "-update";
  end;
  RCS2r.CurrentStatus = kStatusCreating;
  RCS2rw.Item = kManagedServerItemMotherSystem;
  RCS2rw.ItemName = RCSr.UUID;
  RCS2rw.Desc = RCSr.Name;
  if (newpasswf==true) then begin
    passw = GeneratePassword2(15);
  end;
  RCS2rw.Data = FindCloudNodeAddress(RCSr.Controller,true) & "," & RCSr.Port & "," & passw & "," & copyattachf & "," & RCSr.DataFolder & "," & copyfilesf & "," & RCSr.HalcustUpdateRule & "," & RCSr.HalpatchUpdateRule & "," & dbcachesz;

  RCS2rw.When = kManagedServerWhenRunningNormally;
  RCS2rw.Disabled = 0;
  MatRowPut(RCS2r,MatRowCnt(RCS2r),RCS2rw);

  switch (system_type) begin
    case kSystemTypeReserve: RCSrw.Item = kManagedServerItemReserveSystem;
    case kSystemTypeTest: RCSrw.Item = kManagedServerItemTestSystem;
    case kSystemTypeUpdate: RCSrw.Item = kManagedServerItemUpdateSystem;
  end;
  RCSrw.ItemName = RCS2r.UUID;
  RCSrw.Desc = RCS2r.Name;
  RCSrw.Data = passw;
  RCSrw.When = kManagedServerWhenRunningNormally;
  RCSrw.Disabled = 0;

  MatRowPut(RCSr,MatRowCnt(RCSr),RCSrw);
  StartCloning(RCSr,passw,RCS2r);

  RecordInsert(RCS2r,false);
  newserverid = RCS2r.UUID;

LDoLaunchRemoteCloudServerSystem3:;
  return;
end;

global
function UUID MotherSystemUUID(record RemoteCloudServerVc RCSr)
begin
  UUID res;
  Integer i,rwcnt;
  row RemoteCloudServerVc RCSrw;

  rwcnt = MatRowCnt(RCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(RCSr,i,RCSrw);
    if (RCSrw.Item==kManagedServerItemMotherSystem and RCSrw.Disabled==0) then begin
      res = StringToUUID(RCSrw.ItemName);
      goto LMotherSystemUUID;
    end;
  end;

LMotherSystemUUID:;
  MotherSystemUUID = res;
  return;
end;

function Boolean SystemHaveCloneSystem(record RemoteCloudServerVc RCSr,Integer system_type)
begin
  Boolean res;
  Integer i,rwcnt,item_type;
  row RemoteCloudServerVc RCSrw;

  switch (system_type) begin
    case kSystemTypeReserve: item_type = kManagedServerItemReserveSystem;
    case kSystemTypeTest: item_type = kManagedServerItemTestSystem;
    case kSystemTypeUpdate: item_type = kManagedServerItemUpdateSystem;
  end;

  rwcnt = MatRowCnt(RCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(RCSr,i,RCSrw);
    if (RCSrw.Item==item_type and RCSrw.Disabled==0) then begin
      res = true;
      goto LSystemHaveCloneSystem;
    end;
  end;

LSystemHaveCloneSystem:;
  SystemHaveCloneSystem = res;
  return;
end;

function Boolean IsAllClonesStopped(record RemoteCloudServerVc RCSr)
begin
  Boolean res,testf;
  record RemoteCloudServerVc RCS2r;
  row RemoteCloudServerVc RCSrw;
  Integer i,rwcnt;

  res = true;
  rwcnt = MatRowCnt(RCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(RCSr,i,RCSrw);
    testf = false;
    if (RCSrw.Item==kManagedServerItemReserveSystem) then begin testf = true; end;
    if (RCSrw.Item==kManagedServerItemTestSystem) then begin testf = true; end;
    if (RCSrw.Item==kManagedServerItemUpdateSystem) then begin testf = true; end;
    if (RCSrw.Disabled!=0) then begin testf = false; end;
    if (testf==true) then begin
      RCS2r.UUID = StringToUUID(RCSrw.ItemName);
      if (ReadFirstMain(RCS2r,1,true)) then begin
        if (RCS2r.Closed==0) then begin
          if (RCS2r.CurrentStatus!=kStatusStopped) then begin
            res = false;
            goto LIsAllClonesStopped;
          end;
        end;
      end;
    end;
  end;

LIsAllClonesStopped:;
  IsAllClonesStopped = res;
  return;
end;

function Boolean FirstCloneSystemOfTypeAtCN(record LocalCloudServerVc LCSr,Integer system_type,var record LocalCloudServerVc LCScr)
begin
  Boolean res;
  Integer i,rwcnt,item_type;
  row LocalCloudServerVc LCSrw;

  switch (system_type) begin
    case kSystemTypeReserve: item_type = kManagedServerItemReserveSystem;
    case kSystemTypeTest: item_type = kManagedServerItemTestSystem;
    case kSystemTypeUpdate: item_type = kManagedServerItemUpdateSystem;
  end;

  rwcnt = MatRowCnt(LCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(LCSr,i,LCSrw);
    if (LCSrw.Item==item_type and LCSrw.Disabled==0) then begin
      LCScr.UUID = StringToUUID(LCSrw.ItemName);
      if (ReadFirstMain(LCScr,1, true)) then begin
        res = true;
      end;
      goto LFirstCloneSystemOfTypeAtCN;
    end;
  end;

LFirstCloneSystemOfTypeAtCN:;
  FirstCloneSystemOfTypeAtCN = res;
  return;
end;

global
function Boolean FirstCloneSystemOfType(record RemoteCloudServerVc RCSr,Integer system_type,var record LocalCloudServerVc RCScr)
begin
  Boolean res;
  Integer i,rwcnt,item_type;
  row RemoteCloudServerVc RCSrw;

  switch (system_type) begin
    case kSystemTypeReserve: item_type = kManagedServerItemReserveSystem;
    case kSystemTypeTest: item_type = kManagedServerItemTestSystem;
    case kSystemTypeUpdate: item_type = kManagedServerItemUpdateSystem;
  end;

  rwcnt = MatRowCnt(RCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(RCSr,i,RCSrw);
    if (RCSrw.Item==item_type and RCSrw.Disabled==0) then begin
      RCScr.UUID = StringToUUID(RCSrw.ItemName);
      if (ReadFirstMain(RCScr,1, true)) then begin
        res = true;
      end;
      goto LFirstCloneSystemOfType;
    end;
  end;

LFirstCloneSystemOfType:;
  FirstCloneSystemOfType = res;
  return;
end;

global
updating procedure SetLocalCloudServerSubStatus(record LocalCloudServerVc LCSr,LongInt substatus)
begin
  record LocalCloudServerVc OldLCSr;

  if (ReadFirstMain(LCSr,1,true)) then begin
    RecordCopy(OldLCSr,LCSr);
    LCSr.CurrentSubStatus = substatus;
    RecordUpdate(OldLCSr,LCSr,true);
  end;
  return;
end;

global
procedure ServerStatusesChanged(array record LocalCloudServerVc lcsarr,string cncode)
begin
  record CloudNodeVc CNr;
  record LocalCloudServerVc LCSr;
  LCSr = lcsarr[0];

  if (GetGlobalBoolean("ASPIdleTasksStopped")==true) then begin goto LServerStatusesChanged; end;
  if (QuitingApplication==true) then begin goto LServerStatusesChanged; end;
  
  if (nonblank(cncode)) then begin
    CNr.Code = cncode;
    if (ReadFirstMain(CNr,1,true)==false) then begin goto LServerStatusesChanged; end;

    LogText(0,"[SuperFast] Saving " & lcsarr.length & " updated LCSs for node " & cncode & ", status=" & StatusName(LCSr.CurrentStatus));
//LogText(0,"ServerStatusesChanged calling SaveNewAndUpdatedRCSs");
    if (lcsarr.length>0) then begin
      qupdating.SaveNewAndUpdatedRCSs(CNr,lcsarr);
    end;
    queued.SaveCloudNodeReachable(cncode,true);
  end else begin
    LogText(0,"ERROR: ServerStatusesChanged got blank node!");
  end;

LServerStatusesChanged:;
  return;
end;

global
procedure CallServerStatusesChanged(array record LocalCloudServerVc lcsarr,Boolean ccsyncf)
begin
  record CloudSettingsBlock CSb;
  string 255 cncode,url;
  LongInt stat;

//LogText(0,"CallServerStatusesChanged: ccsyncf=" & ccsyncf & ", lcsarr.length=" & lcsarr.length);

  if (ccsyncf and !IsCloudController) then begin
    BlockLoad(CSb);
    cncode = CSb.NodeCode;
    if (nonblank(CSb.CCAddr) and (CSb.CCHTTPSPort>0) and nonblank(CSb.NodeCode) and (lcsarr.length>0)) then begin
      url = Trim(CSb.CCAddr) & ":" & CSb.CCHTTPSPort;
      stat = CallService(url).ServerStatusesChanged(lcsarr,cncode);
    end;
  end;

  return;
end;

global
updating procedure ClearLocalCloudServerErrorStatus(record LocalCloudServerVc LCSr)
begin
  record LocalCloudServerVc OldLCSr;

  if (ReadFirstMain(LCSr,1,true)) then begin
    RecordCopy(OldLCSr,LCSr);
    if (LCSr.CurrentStatus==kStatusConfigInError) then begin
      LCSr.CurrentStatus = kStatusStopped;
      LCSr.FastCheckFlag = 0;
      LCSr.StatusText = DateToString(CurrentDate,"YYYY-MM-DD") & ": Error state was automatically cleared";
      LCSr.MyStandardStatusCode = 10000;
      LCSr.MyStandardStatusStr = DateToString(CurrentDate,"YYYY-MM-DD");
      RecordUpdate(OldLCSr,LCSr,false); // No RActions; we do not want the stopped date to be updated
    end;
  end;
  
  return;
end;

global
updating procedure SetLocalCloudServerErrorStatus(record LocalCloudServerVc LCSr,LongInt statuscode,string statustext,string statusstr)
begin
  record LocalCloudServerVc OldLCSr;
  array record LocalCloudServerVc lcsarr;
    
  if (ReadFirstMain(LCSr,1,true)) then begin
    RecordCopy(OldLCSr,LCSr);
    LCSr.CurrentStatus = kStatusConfigInError;
    LCSr.FastCheckFlag = 1;
    LCSr.StatusText = statustext;
    LCSr.MyStandardStatusCode = statuscode;
    LCSr.MyStandardStatusStr = statusstr;
    RecordUpdate(OldLCSr,LCSr,false); // No RActions; we do not want the stopped date to be updated
    lcsarr[lcsarr.length] = LCSr;
    threadasync.CallServerStatusesChanged(lcsarr,true);
  end;
  
  return;
end;

global
updating function Longint GetLocalCloudServerSubStatus(record LocalCloudServerVc LCSr)
begin
  Longint res;

  if (ReadFirstMain(LCSr,1,true)) then begin
    res = LCSr.CurrentSubStatus;
  end;

  GetLocalCloudServerSubStatus = res;
  return;
end;

global
procedure DoFinishContinousUpdateAtCN(uuid server_uuid)
begin
  record LocalCloudServerVc LCSr,LCScur;
  record HansaVersionVc HVr,HVcur;
  string 255 dbpath,workdir,dbfile,bkfldr,tstr,cudbpath,jpath,gwpath;

  LCSr.UUID = server_uuid;
  if (ReadFirstMain(LCSr,1,true)==false) then begin
    LogText(0,"DoFinishContinousUpdateAtCN couldn't read LCS record");
    goto LDoFinishContinousUpdateAtCN;
  end;

  HVr.Code = LCSr.HansaVersion;
  if (ReadFirstMain(HVr,1,true)==false) then begin
    LogText(0,"DoFinishContinousUpdateAtCN couldn't read version record " & HVr.Code);
    goto LDoFinishContinousUpdateAtCN;
  end;

  if (qupdating.GetLocalCloudServerSubStatus(LCSr)==kSubStatusSwitchToUpdateSystemDB) then begin
    LogText(0,"DoFinishContinousUpdateAtCN server already switching. Skipping request");
    goto LDoFinishContinousUpdateAtCN;
  end;

  if (FirstCloneSystemOfTypeAtCN(LCSr,kSystemTypeUpdate,LCScur)==false) then begin
    LogText(0,"DoFinishContinousUpdateAtCN LCS " & LCSName(LCSr) & " didn't have any update sytem");
    goto LDoFinishContinousUpdateAtCN;
  end;

  HVcur.Code = LCScur.HansaVersion;
  if (ReadFirstMain(HVcur,1,true)==false) then begin
    LogText(0,"DoFinishContinousUpdateAtCN couldn't read version record " & HVcur.Code);
    goto LDoFinishContinousUpdateAtCN;
  end;

  qupdating.SetLocalCloudServerSubStatus(LCSr,kSubStatusSwitchToUpdateSystemDB);

  dbpath = HDBFile(LCSr,HVr);
  if (FileExists(dbpath)) then begin
    workdir = CanonicalWorkDir(LCSr.DataFolder);
    dbfile = BaseName(dbpath);
    bkfldr = workdir & "/oldver." & LCSr.HansaVersion;  //## should have timestamp
    CreateFolderHierarchy(bkfldr & "/");
    RenameBlockingFolder(bkfldr & "/" & dbfile);
    MoveFile(dbfile,DirName(dbpath),bkfldr);
  end;

  jpath = JournalFolder(LCSr);
  if (DirExists(jpath)) then begin
    workdir = CanonicalWorkDir(LCSr.DataFolder);
    bkfldr = workdir & "/oldver." & LCSr.HansaVersion;  //## should have timestamp
    CreateFolderHierarchy(bkfldr & "/");
    RenameBlockingFolder(bkfldr & "/journal");
    MoveFile("journal",DirName(jpath),bkfldr);
  end;

  gwpath = GatewayFolder(LCSr);
  if (DirExists(gwpath)) then begin
    workdir = CanonicalWorkDir(LCSr.DataFolder);
    bkfldr = workdir & "/oldver." & LCSr.HansaVersion;  //## should have timestamp
    CreateFolderHierarchy(bkfldr & "/");
    RenameBlockingFolder(bkfldr & "/EmailGateway");
    MoveFile("EmailGateway",DirName(gwpath),bkfldr);
  end;

  cudbpath = HDBFile(LCScur,HVcur);
  if (FileExists(cudbpath)) then begin
    MoveFile(dbfile,DirName(cudbpath),DirName(dbpath));
  end;

  qupdating.SetLocalCloudServerSubStatus(LCSr,kSubStatusCleanupAfterContinousUpdate);

LDoFinishContinousUpdateAtCN:;
  return;
end;

global
procedure FinishContinousUpdateAtCN(uuid server_uuid)
begin
  threadasync.DoFinishContinousUpdateAtCN(server_uuid);
  return;
end;

global
procedure FinishContinousUpdate(record RemoteCloudServerVc RCSr)
begin
  string 255 url;
  LongInt stat;
  Boolean scfailf;
  Integer retries;

  url = RcsNodeURL(RCSr);
  if (blank(url)) then begin goto LFinishContinousUpdate; end;
  
LFinishContinousUpdate_again:;
  stat = CallService(url).FinishContinousUpdateAtCN(RCSr.UUID);
  scfailf = TreatServiceError(stat,url,"FinishContinousUpdateAtCN");
  queued.SaveCloudNodeReachable(RCSr.Controller,!scfailf);
  if (scfailf) then begin
    retries = retries + 1;
    if (retries>20) then begin
      LogText(0,"Failed finishing continous update of " & RCSName(RCSr));
      goto LFinishContinousUpdate;
    end;
    Sleep(1);
    LogText(0,"Failed finishing continous update of " & RCSName(RCSr) & ", retrying (" & retries & "/20)...");
    goto LFinishContinousUpdate_again;
  end;

LFinishContinousUpdate:;
  return;
end;

updating
procedure RemoveFirstCloneSystemOfType(var record RemoteCloudServerVc RCSr,Integer system_type)
begin
  Integer i,rwcnt,item_type;
  record RemoteCloudServerVc OldRCSr;
  row RemoteCloudServerVc RCSrw;

  if (ReadFirstMain(RCSr,1,true)==false) then begin goto LRemoveFirstCloneSystemOfType; end;

  RecordCopy(OldRCSr,RCSr);

  switch (system_type) begin
    case kSystemTypeReserve: item_type = kManagedServerItemReserveSystem;
    case kSystemTypeTest: item_type = kManagedServerItemTestSystem;
    case kSystemTypeUpdate: item_type = kManagedServerItemUpdateSystem;
  end;

  rwcnt = MatRowCnt(RCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(RCSr,i,RCSrw);
    if (RCSrw.Item==item_type and RCSrw.Disabled==0) then begin
      MatRowDelete(RCSr,i);
      goto LRemoveFirstCloneSystemOfType;
    end;
  end;

  RecordUpdate(OldRCSr,RCSr,true);

LRemoveFirstCloneSystemOfType:;
  return;
end;

global
procedure DoRemoveLCSatCN(string datafolder)
begin
  if (nonblank(datafolder)) then begin
    DeleteFolder(datafolder);
  end;
  return;
end;

global
updating procedure CleanupAfterContinousUpdateAtCN(uuid server_uuid,uuid lcscuid)
begin
  record LocalCloudServerVc LCSr,LCScur,OldLCSr;

  LCScur.UUID = lcscuid;
  if (ReadFirstMain(LCScur,1,true)) then begin
    LCSr.UUID = server_uuid;
    if (ReadFirstMain(LCSr,1,true)) then begin
      RecordCopy(OldLCSr,LCSr);
      LCSr.OldHansaVersion = LCSr.HansaVersion;
      LCSr.HansaVersion = LCSr.NewHansaVersion;
      LCSr.NewHansaVersion = "";
      RecordUpdate(OldLCSr,LCSr,true);
    end;
    threadasync.DoRemoveLCSatCN(LCScur.DataFolder);
    RecordDelete(LCScur);
  end;
  return;
end;

updating procedure CleanupAfterContinousUpdate(var record RemoteCloudServerVc RCSr)
begin
  record RemoteCloudServerVc RCScur,OldRCScur;
  string 255 url;
  LongInt stat;
  Boolean scfailf;

  if (FirstCloneSystemOfType(RCSr,kSystemTypeUpdate,RCScur)==false) then begin goto LCleanupAfterContinousUpdate; end;
  
  url = RcsNodeURL(RCScur);

  if (ReadFirstMain(RCScur,1,true)==false) then begin goto LCleanupAfterContinousUpdate; end;
  RecordCopy(OldRCScur,RCScur);
  RCScur.Closed = 1;
  RecordUpdate(OldRCScur,RCScur,true);

  if (blank(url)) then begin goto LCleanupAfterContinousUpdate; end;

  stat = CallService(url).CleanupAfterContinousUpdateAtCN(RCSr.UUID,RCScur.UUID);
  scfailf = TreatServiceError(stat,url,"CleanupAfterContinousUpdateAtCN");
  queued.SaveCloudNodeReachable(RCScur.Controller,!scfailf);
  if (scfailf) then begin
    LogText(0,"Failed to cleanup after continous update of cloud server " & RCSName(RCScur) & " on node " & RCScur.Controller);
    goto LCleanupAfterContinousUpdate;
  end;

  RemoveManagedServerItemByName(RCSr,RCScur.UUID);
//  RemoveFirstCloneSystemOfType(RCSr,kSystemTypeUpdate);
//  if (ReadFirstMain(RCScur,1,true)) then begin
//    RecordDelete(RCScur);
//  end;

LCleanupAfterContinousUpdate:;
  return;
end;

updating procedure StartContinousUpdateIfNeeded(record RemoteCloudServerVc RCSr)
begin
  LongInt when;
  Boolean startf;
  string 255 msg;
  uuid newserverid;

  if (RCSr.WantedStatus!=kWantedStatusContinousUpdateVersion) then begin goto LStartContinousUpdateIfNeeded; end;

  switch (RCSr.WantedSubStatus) begin
    case kWantedSubStatusCancelContinousUpdate:
      StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
      if (IsAllClonesStopped(RCSr)) then begin
        CleanupAfterContinousUpdate(RCSr);
        RCSr.WantedStatus = kWantedStatusRun;
        RCSr.WantedSubStatus = kWantedSubStatusNone;
      end;
      goto LStartContinousUpdateIfNeeded;
  end;

  switch (RCSr.CurrentStatus) begin
    case kStatusRunning: startf = true;
  end;

  if (startf) then begin
    if (SystemHaveCloneSystem(RCSr,kSystemTypeUpdate)) then begin goto LStartContinousUpdateIfNeeded; end;

    DoLaunchRemoteCloudServerSystem3(RCSr,RCSr.Name & " (update)",RCSr.DataFolder & "/" & "update",RCSr.Controller,
                                       RCSr.NewHansaVersion,false,false,0/*dbcace, should be configurable*/,kSystemTypeUpdate,msg,newserverid);
  end;

LStartContinousUpdateIfNeeded:;
  return;
end;

function Boolean ServerStatusesShouldChange(record RemoteCloudServerVc RCSr)
begin
  Boolean res;
  record RemoteCloudServerVc RCS2r;

  switch (RCSr.CurrentStatus) begin
    case kStatusRunningPreparingTest:
    case kStatusRunningTest:
    case kStatusRunningReserve:
    case kStatusRunningPreparingReserve:
    case kStatusRunningPendingStop:

    case kStatusRunningPreparingUpdate:
      RCS2r.UUID = MotherSystemUUID(RCSr);
      if (ReadFirstMain(RCS2r,1,true)) then begin
        if ((RCS2r.WantedStatus==kWantedStatusContinousUpdateVersion) and
            (RCS2r.WantedSubStatus==kWantedSubStatusNone) and
            (RCS2r.CurrentStatus==kStatusRunning) and
            (RCS2r.CurrentSubStatus==kSubStatusNone)) then begin
          res = true;
        end;
      end;
    case kStatusRunningUpdate:
      RCS2r.UUID = MotherSystemUUID(RCSr);
      if (ReadFirstMain(RCS2r,1,true)) then begin
        if ((RCS2r.WantedStatus==kWantedStatusContinousUpdateVersion) and
            (RCS2r.WantedSubStatus==kWantedSubStatusCreatingUpdateSystem) and
            (RCS2r.CurrentStatus==kStatusRunning) and
            (RCS2r.CurrentSubStatus==kSubStatusCreatingUpdateSystem)) then begin
          res = true;
        end;
      end;

    case kStatusCreated:
      res = true;
    case kStatusRunning:
      if (RCSr.WantedStatus==kWantedStatusRunUnjournaled) begin
        res = true;
      end;
      if ((RCSr.OnDemandFlag==1) and ((RCSr.WantedStatus==kWantedStatusImportBackupAndRun) or
                                      (RCSr.WantedStatus==kWantedStatusRun) or
                                      (RCSr.WantedStatus==kWantedStatusRunUnjournaled))) then begin
        res = true;
      end else begin
        if (RCSr.WantedStatus==kWantedStatusImportBackupAndRun) then begin
          res = true;
        end;
      end;

      if (RCSr.WantedStatus==kWantedStatusContinousUpdateVersion) then begin
        res = true;
      end;

    case kStatusStopped:
      switch (RCSr.WantedStatus) begin
        case kWantedStatusUpdateVersion:
          switch (RCSr.WantedSubStatus) begin
            case kWantedSubStatusStopForExport:
              switch (RCSr.CurrentSubStatus) begin
                case kSubStatusDBMissing: res = true;
                otherwise
              end;
          end;
        case kWantedStatusContinousUpdateVersion:
          switch (RCSr.WantedSubStatus) begin
            case kWantedSubStatusFinishContinousUpdate:
              switch (RCSr.CurrentSubStatus) begin
                case kSubStatusStopForContinousUpdate:        res = true;
                case kSubStatusSwitchToUpdateSystemDB:        res = true;
                case kSubStatusCleanupAfterContinousUpdate:   res = true;
                otherwise
                  res = true;
              end;
            case kWantedSubStatusCancelContinousUpdate:
              res = true;
          end;
        case kWantedStatusChangeVersion:
          res = true;
        case kWantedStatusRestart:
          res = true;
        case kWantedStatusStop:
          res = true;
        case kWantedStatusStopAndRefresh:
          res = true;
        case kWantedStatusForceStop:
          res = true;
      end;
    case kStatusExportedDatabase:
      res = true;
    case kStatusExportedRegister:
      res = true;
    case kStatusExportedCompany:
      res = true;
    case kStatusImportedBackup:
      res = true;
  end;

  ServerStatusesShouldChange = res;
  return;
end;

global
updating procedure UpdateServerWantedStatus(var record RemoteCloudServerVc RCSr,var LongInt cnt)
begin
  LongInt old_wantedstatus;
  record RemoteCloudServerVc OldRCSr,RCS2r,OldRCS2r;
  Boolean startf;

  if (ReadFirstMain(RCSr,1,true)==false) then begin
    LogText(0,"ERROR UpdateServerWantedStatus RCSr.Name=" & RCSName(RCSr) & ", RCSr.UUID=" & RCSr.UUID & " not found!");
    goto LUpdateServerWantedStatus;
  end;
  RecordCopy(OldRCSr,RCSr);

  old_wantedstatus = RCSr.WantedStatus;
  
  switch (RCSr.CurrentStatus) begin
    case kStatusRunningPreparingTest:
    case kStatusRunningTest:
    case kStatusRunningReserve:
    case kStatusRunningPreparingReserve:
    case kStatusRunningPendingStop:

    case kStatusRunningPreparingUpdate:
      RCS2r.UUID = MotherSystemUUID(RCSr);
      if (ReadFirstMain(RCS2r,1,true)) then begin
        if ((RCS2r.WantedStatus==kWantedStatusContinousUpdateVersion) and
            (RCS2r.WantedSubStatus==kWantedSubStatusNone) and
            (RCS2r.CurrentStatus==kStatusRunning) and
            (RCS2r.CurrentSubStatus==kSubStatusNone)) then begin
          RecordCopy(OldRCS2r,RCS2r);
          RCS2r.WantedSubStatus = kWantedSubStatusCreatingUpdateSystem;
          RecordUpdate(OldRCS2r,RCS2r,true);
        end;
      end;
    case kStatusRunningUpdate:
      RCS2r.UUID = MotherSystemUUID(RCSr);
      if (ReadFirstMain(RCS2r,1,true)) then begin
        if ((RCS2r.WantedStatus==kWantedStatusContinousUpdateVersion) and
            (RCS2r.WantedSubStatus==kWantedSubStatusCreatingUpdateSystem) and
            (RCS2r.CurrentStatus==kStatusRunning) and
            (RCS2r.CurrentSubStatus==kSubStatusCreatingUpdateSystem)) then begin
          RecordCopy(OldRCS2r,RCS2r);
          RCS2r.WantedSubStatus = kWantedSubStatusUpdateSystemReady;
          RecordUpdate(OldRCS2r,RCS2r,true);
        end;
      end;

    case kStatusCreated:
      switch (old_wantedstatus) begin
        case kWantedStatusCreateServer:         RCSr.WantedStatus = kWantedStatusStop; startf = false;
        case kWantedStatusCreateStartedServer:  RCSr.WantedStatus = kWantedStatusImportBackupAndRun;  startf = true;
        case kWantedStatusLaunchReserveSystem:  RCSr.WantedStatus = kWantedStatusRun; startf = true;
        case kWantedStatusLaunchUpdateSystem:   RCSr.WantedStatus = kWantedStatusRun; startf = true;
        case kWantedStatusLaunchTestSystem:     RCSr.WantedStatus = kWantedStatusRun; startf = true;
      end;
      StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,startf,true);
    case kStatusRunning:
      if (old_wantedstatus==kWantedStatusRunUnjournaled) begin
        RCSr.WantedStatus = kWantedStatusRun;
      end;
      if ((RCSr.OnDemandFlag==1) and ((old_wantedstatus==kWantedStatusImportBackupAndRun) or
                                      (old_wantedstatus==kWantedStatusRun) or
                                      (old_wantedstatus==kWantedStatusRunUnjournaled))) then begin
        RCSr.WantedStatus = kWantedStatusOnDemand;
        StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,true,true);
      end else begin
        if (old_wantedstatus==kWantedStatusImportBackupAndRun) then begin
          RCSr.WantedStatus = kWantedStatusRun;
          StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,true,true);
        end;
      end;

      StartContinousUpdateIfNeeded(RCSr);
    case kStatusStopped:
      switch (old_wantedstatus) begin
        case kWantedStatusUpdateVersion:
          switch (RCSr.WantedSubStatus) begin
            case kWantedSubStatusStopForExport:
              switch (RCSr.CurrentSubStatus) begin
                case kSubStatusDBMissing:
                  RCSr.WantedStatus = kWantedStatusStop;
                  RCSr.WantedSubStatus = kWantedSubStatusNone;
                  if (ComparePosts(OldRCSr,RCSr)==false) then begin
                    RecordUpdate(OldRCSr,RCSr,true);
                    cnt = cnt + 1;
                  end;
                  RecordCopy(OldRCSr,RCSr);
                  DoChangeVersionOnRemoteCloudServer(RCSr,RCSr.NewHansaVersion);
                otherwise
              end;
          end;

        case kWantedStatusContinousUpdateVersion:
          switch (RCSr.WantedSubStatus) begin
            case kWantedSubStatusFinishContinousUpdate:
              switch (RCSr.CurrentSubStatus) begin
                case kSubStatusSwitchToUpdateSystemDB:
                case kSubStatusCleanupAfterContinousUpdate:
                  if (IsAllClonesStopped(RCSr)) then begin
                    CleanupAfterContinousUpdate(RCSr);
                    RCSr.WantedStatus = kWantedStatusRun;
                  end;
                otherwise
                  StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
                  if (IsAllClonesStopped(RCSr)) then begin
                    RCSr.CurrentSubStatus = kSubStatusSwitchToUpdateSystemDB;
                    threadasync.FinishContinousUpdate(RCSr);
                  end;
              end;
            case kWantedSubStatusCancelContinousUpdate:
              StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
              if (IsAllClonesStopped(RCSr)) then begin
                CleanupAfterContinousUpdate(RCSr);
                RCSr.WantedStatus = kWantedStatusRun;
              end;
          end;
        case kWantedStatusChangeVersion:
          if (DoChangeVersionOnRemoteCloudServer(RCSr,RCSr.NewHansaVersion)) then begin
            if (RCSr.OnDemandFlag==0) then begin
              RCSr.WantedStatus = kWantedStatusRun;
              StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,true,true);
            end else begin
              if (RCSr.WantedStatus!=kWantedStatusOnDemand) then begin
                RCSr.WantedStatus = kWantedStatusOnDemand;
                StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
              end;
            end;
          end;
        case kWantedStatusRestart:
          if (RCSr.OnDemandFlag==0) then begin
            RCSr.WantedStatus = kWantedStatusRun;
            StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,true,true);
          end else begin
            if (RCSr.WantedStatus!=kWantedStatusOnDemand) then begin
              RCSr.WantedStatus = kWantedStatusOnDemand;
              StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
            end;
          end;
        case kWantedStatusStop:
          if (RCSr.OnDemandFlag==1) then begin
            if (RCSr.WantedStatus!=kWantedStatusOnDemand) then begin
              RCSr.WantedStatus = kWantedStatusOnDemand;
              StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
            end;
          end;
        case kWantedStatusStopAndRefresh:
          if (RCSr.OnDemandFlag==1) then begin
            if (RCSr.WantedStatus!=kWantedStatusOnDemand) then begin
              RCSr.WantedStatus = kWantedStatusOnDemand;
              StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
            end;
          end;
        case kWantedStatusForceStop:
          if (RCSr.OnDemandFlag==1) then begin
            if (RCSr.WantedStatus!=kWantedStatusOnDemand) then begin
              RCSr.WantedStatus = kWantedStatusOnDemand;
              StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
            end;
          end;
      end;
    case kStatusExportedDatabase:
      if (RCSr.OnDemandFlag==0) then begin
        RCSr.WantedStatus = kWantedStatusStop;
        StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
      end else begin
        if (RCSr.WantedStatus!=kWantedStatusOnDemand) then begin
          RCSr.WantedStatus = kWantedStatusOnDemand;
          StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
        end;
      end;
    case kStatusExportedRegister:
      if (RCSr.OnDemandFlag==0) then begin
        RCSr.WantedStatus = kWantedStatusStop;
        StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
      end else begin
        if (RCSr.WantedStatus!=kWantedStatusOnDemand) then begin
          RCSr.WantedStatus = kWantedStatusOnDemand;
          StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
        end;
      end;
    case kStatusExportedCompany:
      if (RCSr.OnDemandFlag==0) then begin
        RCSr.WantedStatus = kWantedStatusStop;
        StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
      end else begin
        if (RCSr.WantedStatus!=kWantedStatusOnDemand) then begin
          RCSr.WantedStatus = kWantedStatusOnDemand;
          StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
        end;
      end;
    case kStatusImportedBackup:
      switch (old_wantedstatus) begin
        case kWantedStatusImportBackupAndRun:
          RCSr.WantedStatus = kWantedStatusRun;
          StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,true,true);
        case kWantedStatusRun:
          if (RCSr.OnDemandFlag==0) then begin
            RCSr.WantedStatus = kWantedStatusRun;
            StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,true,true);
          end else begin
            if (RCSr.WantedStatus!=kWantedStatusOnDemand) then begin
              RCSr.WantedStatus = kWantedStatusOnDemand;
              StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
            end;
          end;
        otherwise
          if (RCSr.OnDemandFlag==0) then begin
            RCSr.WantedStatus = kWantedStatusStop;
            StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
          end else begin
            if (RCSr.WantedStatus!=kWantedStatusOnDemand) then begin
              RCSr.WantedStatus = kWantedStatusOnDemand;
              StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
            end;
          end;
      end;
    case kStatusClearingRegister:
      if (RCSr.CurrentSubStatus==kSubStatusClearingRegisterCompleted) then begin
        RCSr.WantedStatus = RCSr.NextWantedStatus;
        RCSr.WantedSubStatus = kWantedSubStatusNone;
        RCSr.WantedStatusParams = "";
        RCSr.NextWantedStatus = kWantedStatusStop;
      end;
  end;

  if (old_wantedstatus!=RCSr.WantedStatus) then begin
    LogText(0,"UpdateServerWantedStatus: WantedStatus for " & RCSr.UUID & " changed from " & WantedStatusName(old_wantedstatus) & " to " & WantedStatusName(RCSr.WantedStatus) & ", CurrentStatus=" & StatusName(OldRCSr.CurrentStatus) & ", WantedSubStatus=" & WantedSubStatusName(OldRCSr.WantedSubStatus) & ", CurrentSubStatus=" & SubStatusName(OldRCSr.CurrentSubStatus));
  end;

  if (ComparePosts(OldRCSr,RCSr)==false) then begin
    RecordUpdate(OldRCSr,RCSr,true);
    cnt = cnt + 1;
  end;

LUpdateServerWantedStatus:;
  return;
end;

global
procedure SetRemoteCloudServerSubStatus(record RemoteCloudServerVc RCSr,LongInt substatus)
begin
  string 255 url;
  LongInt stat;
  record LocalCloudServerVc LCSr;
  Boolean scfailf;

  url = RcsNodeURL(RCSr);
  if (blank(url)) then begin goto LSetRemoteCloudServerSubStatus; end;

  LCSr.UUID = RCSr.UUID;
  stat = CallService(url).SetLocalCloudServerSubStatus(LCSr,substatus);
  scfailf = TreatServiceError(stat,url,"SetLocalCloudServerSubStatus");
  queued.SaveCloudNodeReachable(RCSr.Controller,!scfailf);
  if (scfailf) then begin
    LogText(0,"Failed to set substatus on remote cloud server " & RCSName(RCSr));
    goto LSetRemoteCloudServerSubStatus;
  end;

LSetRemoteCloudServerSubStatus:;
  return;
end;

global
updating procedure StartRemoteCloudServer(record RemoteCloudServerVc RCSr,Boolean maintf)
begin
  record RemoteCloudServerVc OldRCSr;
  record CloudNodeVc CNr;
  Boolean testf;

  testf = true;
  if (RCSr.Closed!=0) then begin testf = false; end;
  if (RCSr.CurrentStatus!=kStatusStopped) then begin testf = false; end;
  if (testf) then begin
    RecordCopy(OldRCSr,RCSr);
    if (maintf==true) then begin
      RCSr.WantedStatus = kWantedStatusMaintenence;
    end else begin
      RCSr.WantedStatus = kWantedStatusRun;
      StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,true,true);
    end;
    RecordUpdate(OldRCSr,RCSr,true);
    CNr.Code = RCSr.Controller;
    RCSr.RcsSeqNr = -1;
    threadasync.SyncOneRCS(RCSr,true,true,"2");
    SetCloudControllerStatus(kJobStatusRunning,"Starting server " & RCSName(RCSr));
  end else begin
    SetCloudControllerStatus(kJobStatusWarning,"Ignoring start command for server " & RCSName(RCSr));
  end;
  return;
end;

global
updating procedure ClearQuickRestarts(var record LocalCloudServerVc LCSr)
begin
  record LocalCloudServerVc OldLCSr;

  if (ReadFirstMain(LCSr,1,true)) then begin
    RecordCopy(OldLCSr,LCSr);
    LCSr.QuickRestarts = 0;
    RecordUpdate(OldLCSr,LCSr,true);
    UpdateClientBrowsesIfNeeded("LocalCloudServerVc");
  end;

  return;
end;

global
procedure DoClearQuickRestartsOnNode(uuid serverid)
begin
  record LocalCloudServerVc LCSr;

  LCSr.UUID = serverid;
  if (ReadFirstMain(LCSr,1,true)) then begin
    qupdating.ClearQuickRestarts(LCSr);
  end;
end;

global
procedure ClearQuickRestartsOnNode(record RemoteCloudServerVc RCSr)
begin
  string 255 url;
  LongInt stat;
  Boolean scfailf;

  url = RcsNodeURL(RCSr);
  stat = CallService(url).DoClearQuickRestartsOnNode(RCSr.UUID);
  scfailf = TreatServiceError(stat,url,"ClearQuickRestartsOnNode");
  queued.SaveCloudNodeReachable(RCSr.Controller,!scfailf);
  if (scfailf) then begin end;
  return;
end;

function Boolean IsDateOlderThanDays(date dt,Integer days)
begin
  Boolean res;
  date tdt;

  if (blankdate(dt)) then begin // Important!
    res = true;
    goto LIsDateOlderThanDays;
  end;

  tdt = AddDay(CurrentDate,-days);
  if (dt<tdt) then begin res = true; end;

LIsDateOlderThanDays:;
  IsDateOlderThanDays = res;
  return;
end;

global
function Boolean CloudNodeSeenInDays(record CloudNodeVc CNr,Integer days)
begin
  Boolean res;

  if (IsDateOlderThanDays(CNr.CreatedDate,days)==false) then begin res = true; end;
  if (IsDateOlderThanDays(CNr.LastSeenDate,days)==false) then begin res = true; end;

  CloudNodeSeenInDays = res;
  return;
end;

function Boolean RemoteCloudServerSeenInDays(record RemoteCloudServerVc RCSr,Integer days)
begin
  Boolean res;

  if (IsDateOlderThanDays(RCSr.CreatedDate,days)==false) then begin res = true; end;
  if (IsDateOlderThanDays(RCSr.LastStartDate,days)==false) then begin res = true; end;
  if (IsDateOlderThanDays(RCSr.LastStopDate,days)==false) then begin res = true; end;

  RemoteCloudServerSeenInDays = res;
  return;
end;

function Boolean CertCheckHistoryCheckedInDays(record CertCheckHistVc CCHr,Integer days)
begin
  Boolean res;

  if (IsDateOlderThanDays(CCHr.LastChecked,days)==false) then begin res = true; end;

  CertCheckHistoryCheckedInDays = res;
  return;
end;

function Boolean LocalCloudServerSeenInDays(record LocalCloudServerVc LCSr,Integer days)
begin
  Boolean res;

  if (IsDateOlderThanDays(LCSr.CreatedDate,days)==false) then begin res = true; end;
  if (IsDateOlderThanDays(LCSr.LastStartDate,days)==false) then begin res = true; end;
  if (IsDateOlderThanDays(LCSr.LastStopDate,days)==false) then begin res = true; end;

  LocalCloudServerSeenInDays = res;
  return;
end;

global
updating procedure StopRemoteCloudServer(record RemoteCloudServerVc RCSr,Boolean forcef)
begin
  record RemoteCloudServerVc OldRCSr;
  Boolean testf;
  record CloudNodeVc CNr;

  testf = true;
  if (RCSr.Closed<>0) then begin testf = false; end;
  if (testf) then begin
    RecordCopy(OldRCSr,RCSr);
    if (forcef) then begin
      RCSr.WantedStatus = kWantedStatusForceStop;
    end else begin
      RCSr.WantedStatus = kWantedStatusStop;
    end;
    RCSr.WantedSubStatus = kWantedSubStatusNone;
    RecordUpdate(OldRCSr,RCSr,true);
    StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,false,true);
    CNr.Code = RCSr.Controller;
    if (ReadFirstMain(CNr,1,true)==false) then begin
      ReadFirstMain(RCSr,1,true);
      RecordCopy(OldRCSr,RCSr);
      RCSr.CurrentStatus = kStatusStopped;
      RecordUpdate(OldRCSr,RCSr,true);
    end else begin
      if (CNr.ReachableFlag==0 and CloudNodeSeenInDays(CNr,2)==false) then begin
        ReadFirstMain(RCSr,1,true);
        RecordCopy(OldRCSr,RCSr);
        RCSr.CurrentStatus = kStatusStopped;
        RecordUpdate(OldRCSr,RCSr,true);
      end else begin
        RCSr.RcsSeqNr = -1;
        threadasync.SyncOneRCS(RCSr,true,true,"3");
        threadasync.ClearQuickRestartsOnNode(RCSr);
      end;
    end;
    SetCloudControllerStatus(kJobStatusRunning,"Stopping cloud server " & RCSName(RCSr));
  end else begin
    SetCloudControllerStatus(kJobStatusWarning,"Ignoring stop command for server " & RCSName(RCSr));
  end;
  return;
end;

global
updating procedure StartStopSystemCopies(var record RemoteCloudServerVc RCSr,LongInt when,Boolean startf,Boolean slavesystemsf)
begin
  record RemoteCloudServerVc RCS2r;
  record RemoteCloudServerVc OldRCS2r;
  row RemoteCloudServerVc RCSrw;
  Integer i,rwcnt;
  Boolean all_donef;
  Boolean testf,test2f;

  all_donef = true;
  rwcnt = MatRowCnt(RCSr);
  for (i = 0; i<rwcnt; i = i + 1) begin
    MatRowGet(RCSr,i,RCSrw);
    testf = false;
    if ((RCSrw.Item==kManagedServerItemSystemCopy) and (slavesystemsf==false)) then begin testf = true; end;
    if ((RCSrw.Item==kManagedServerItemSlaveSystem) and (slavesystemsf==true)) then begin testf = true; end;
    if ((RCSrw.Item==kManagedServerItemMotherSystem) and (RCSr.CloneFlag!=kSystemTypeNormal) and (RCSr.CurrentStatus==kStatusCreated) and (startf==true)) then begin testf = true; end;
    if ((RCSrw.Item==kManagedServerItemReserveSystem) and (slavesystemsf==true)) then begin testf = true; end;
    if ((RCSrw.Item==kManagedServerItemTestSystem) and (slavesystemsf==true)) then begin testf = true; end;
    if ((RCSrw.Item==kManagedServerItemUpdateSystem) and (slavesystemsf==true)) then begin testf = true; end;
    if (testf==true) then begin
      test2f = false;
      if ((slavesystemsf==false)) then begin
        if (RCSrw.When==when) then begin test2f = true; end;
        if ((RCSrw.When==kManagedServerWhenUpdateBegins) and (when==kManagedServerWhenUpdateExports)) then begin test2f = true; end;
      end else begin
        if ((RCSrw.When==kManagedServerWhenRunningNormally) and
            ((when==kManagedServerWhenUpdating) or (when==kManagedServerWhenRunningNormally))) then begin test2f = true; end;
      end;
      if (RCSrw.Disabled!=0) then begin test2f = false; end;
      if (test2f) then begin
        RCS2r.UUID = StringToUUID(RCSrw.ItemName);
        if (ReadFirstMain(RCS2r,1,true)) then begin
          if ((RCS2r.Closed==0) and ((RCSrw.Item==kManagedServerItemMotherSystem) and (RCS2r.CloneFlag!=kSystemTypeNormal)) or
              (RCSrw.Item!=kManagedServerItemMotherSystem)) then begin
            if (startf==true) then begin
              if ((RCS2r.WantedStatus!=kWantedStatusRun) and (RCS2r.WantedStatus!=kWantedStatusRunUnjournaled)) then begin
                if ((RCS2r.CloneFlag==kSystemTypeNormal) and (RCSr.HansaVersion!=RCS2r.HansaVersion)) then begin
                  RecordCopy(OldRCS2r,RCS2r);
                  RCS2r.NewHansaVersion = RCSr.HansaVersion;
                  RecordUpdate(OldRCS2r,RCS2r,true);
                  UpdateRemoteCloudServer(RCS2r);
                end else begin
                  StartRemoteCloudServer(RCS2r,false);
                end;
                all_donef = false;
              end else begin
                if ((RCS2r.CurrentStatus!=kStatusRunning) and
                    (RCS2r.CurrentStatus!=kStatusRunningPreparingUpdate) and
                    (RCS2r.CurrentStatus!=kStatusRunningUpdate) and
                    (RCS2r.CurrentStatus!=kStatusRunningPreparingTest) and
                    (RCS2r.CurrentStatus!=kStatusRunningTest) and
                    (RCS2r.CurrentStatus!=kStatusRunningReserve) and
                    (RCS2r.CurrentStatus!=kStatusRunningPreparingReserve) and
                    (RCS2r.CurrentStatus!=kStatusRunningPendingStop)) then begin
                  all_donef = false;
                end;
              end;
            end else begin
              if ((RCSrw.When!=kManagedServerWhenUpdating) or (slavesystemsf==true)) then begin // ugly, but OR should keep runnung
                if ((RCS2r.WantedStatus!=kWantedStatusStop) and (RCS2r.WantedStatus!=kWantedStatusForceStop) and (RCS2r.WantedStatus!=kWantedStatusStopAndRefresh)) then begin
                  if (RCS2r.CurrentStatus!=kStatusRunningTest) then begin
                    StopRemoteCloudServer(RCS2r,false);
                  end;
                  all_donef = false;
                end else begin
                  if (RCS2r.CurrentStatus!=kStatusStopped) then begin
                    all_donef = false;
                  end;
                end;
              end;
            end;
          end;
        end;
      end;
    end;
  end;

  if (all_donef) then begin
    if (startf) then begin
      if (slavesystemsf==false) then begin
        if (RCSr.CurrentSubStatus==kSubStatusStartingSystemCopiesBeforeExport) then begin
          SetRemoteCloudServerSubStatus(RCSr,kSubStatusStartingSystemCopiesBeforeExportCompleted);
        end else begin
          SetRemoteCloudServerSubStatus(RCSr,kSubStatusStartingSystemCopiesDuringUpdateCompleted);
        end;
      end;
    end else begin
      if (slavesystemsf==false) then begin
        SetRemoteCloudServerSubStatus(RCSr,kSubStatusStoppingSystemCopiesDuringUpdateCompleted);
      end else begin
        if (RCSr.CurrentSubStatus==kSubStatusStoppingSlaveSystems) then begin
          SetRemoteCloudServerSubStatus(RCSr,kSubStatusStoppingSlaveSystemsCompleted);
        end;
      end;
    end;
  end;
end;

global
updating procedure UpdateServerWantedSubStatus(var record RemoteCloudServerVc RCSr,var LongInt cnt)
begin
  LongInt old_status;
  LongInt old_wantedstatus;
  LongInt old_substatus;
  LongInt old_wantedsubstatus;
  record RemoteCloudServerVc OldRCSr;
  record CloudNodeVc CNr;
  Boolean skipf;

  if (ReadFirstMain(RCSr,1,true)==false) then begin
    LogText(0,"ERROR UpdateServerWantedSubStatus RCSr.Name=" & RCSName(RCSr) & ", RCSr.UUID=" & RCSr.UUID & " not found!");
    goto LUpdateServerWantedSubStatus;
  end;

  skipf = true;
  if (((RCSr.CurrentStatus==kStatusUpdatingVersion) or (RCSr.CurrentStatus==kStatusRebuildingDatabase)) and
      (RCSr.WantedStatus!=kWantedStatusStop) and
      (RCSr.WantedStatus!=kWantedStatusOnDemand) and
      (RCSr.WantedStatus!=kWantedStatusStopAndRefresh) and
      (RCSr.WantedStatus!=kWantedStatusForceStop) and
      (RCSr.WantedStatus!=kWantedStatusRestart)) then begin
    skipf = false;
  end else begin
    if (RCSr.WantedStatus==kWantedStatusUpdateVersion) then begin
      skipf = false;
    end;
  end;
  
  if (skipf) then begin goto LUpdateServerWantedSubStatus; end;

  RecordCopy(OldRCSr,RCSr);
  old_status = RCSr.CurrentStatus;
  old_wantedstatus = RCSr.WantedStatus;
  old_substatus = RCSr.CurrentSubStatus;
  old_wantedsubstatus = RCSr.WantedSubStatus;

  switch (RCSr.CurrentSubStatus) begin
    case kSubStatusNone:
//      LogText(0,"DEBUG 4 " & RCSName(RCSr) & ", wantedstatus==" & WantedStatusName(RCSr.WantedStatus) & ", wantedsubstatus==" & WantedSubStatusName(RCSr.WantedSubStatus) & ", currentstatus==" & StatusName(RCSr.CurrentStatus));
    case kSubStatusBeforeExport:
      if (RCSShouldTreatCrontab(RCSr,kManagedServerWhenUpdateBegins)) then begin
        RCSr.WantedSubStatus = kWantedSubStatusSetCrontabBeforeUpdate;
      end else begin
        if (RCSShouldTreatSystemCopy(RCSr,kManagedServerWhenUpdateBegins)) then begin
          RCSr.WantedSubStatus = kWantedSubStatusDBCopyBeforeUpdate;
        end else begin
          if (RCSShouldTreatSlaveSystems(RCSr,kManagedServerWhenUpdateBegins)) then begin
            RCSr.WantedSubStatus = kWantedSubStatusStopSlaveSystems;
          end else begin
            RCSr.WantedSubStatus = kWantedSubStatusStopForExport;
          end;
        end;
      end;
    case kSubStatusSetCrontabBeforeUpdateCompleted:
      if (RCSShouldTreatSystemCopy(RCSr,kManagedServerWhenUpdateBegins)) then begin
        RCSr.WantedSubStatus = kWantedSubStatusDBCopyBeforeUpdate;
      end else begin
        if (RCSShouldTreatSlaveSystems(RCSr,kManagedServerWhenUpdateBegins)) then begin
          RCSr.WantedSubStatus = kWantedSubStatusStopSlaveSystems;
        end else begin
          RCSr.WantedSubStatus = kWantedSubStatusStopForExport;
        end;
      end;
    case kSubStatusDBCopyBeforeUpdateCompleted:
      if (RCSShouldTreatSystemCopy(RCSr,kManagedServerWhenUpdateBegins)) then begin
        RCSr.WantedSubStatus = kWantedSubStatusSystemCopyBeforeUpdate;
      end else begin
        if (RCSShouldTreatSlaveSystems(RCSr,kManagedServerWhenUpdateBegins)) then begin
          RCSr.WantedSubStatus = kWantedSubStatusStopSlaveSystems;
        end else begin
          RCSr.WantedSubStatus = kWantedSubStatusStopForExport;
        end;
      end;
    case kSubStatusSystemCopyBeforeUpdateCompleted:
      if (RCSShouldTreatSlaveSystems(RCSr,kManagedServerWhenUpdateBegins)) then begin
        RCSr.WantedSubStatus = kWantedSubStatusStopSlaveSystems;
      end else begin
        RCSr.WantedSubStatus = kWantedSubStatusStopForExport;
      end;
    case kSubStatusStoppingSlaveSystemsCompleted:
      RCSr.WantedSubStatus = kWantedSubStatusStopForExport;
    case kSubStatusStopForExportCompleted:
      if (RCSShouldTreatSystemCopy(RCSr,kManagedServerWhenUpdateExports)) then begin
        RCSr.WantedSubStatus = kWantedSubStatusStartSystemCopiesBeforeExport;
      end else begin
        if (RCSShouldTreatSystemCopy(RCSr,kManagedServerWhenUpdating)) then begin
          RCSr.WantedSubStatus = kWantedSubStatusSystemCopyDuringUpdate;
        end else begin
          RCSr.WantedSubStatus = kWantedSubStatusExport;
        end;
      end;
    case kSubStatusStartingSystemCopiesBeforeExportCompleted:
      if (RCSShouldTreatSystemCopy(RCSr,kManagedServerWhenUpdating)) then begin
        RCSr.WantedSubStatus = kWantedSubStatusSystemCopyDuringUpdate;
      end else begin
        RCSr.WantedSubStatus = kWantedSubStatusExport;
      end;
    case kSubStatusSystemCopyDuringUpdateCompleted:
      RCSr.WantedSubStatus = kWantedSubStatusStartSystemCopiesDuringUpdate;
    case kSubStatusStartingSystemCopiesDuringUpdateCompleted:
      RCSr.WantedSubStatus = kWantedSubStatusExport;
    case kSubStatusExportingCompleted:
      RCSr.WantedSubStatus = kWantedSubStatusAfterExport;
    case kSubStatusAfterExport:
      RCSr.WantedSubStatus = kWantedSubStatusImport;
    case kSubStatusImportingCompleted:
      RCSr.WantedSubStatus = kWantedSubStatusAfterImport;
    case kSubStatusAfterImport:
      RCSr.HalcustUpdateRule = kHalUpdateRuleNotTested; // One-off setting
      RCSr.HalpatchUpdateRule = kHalUpdateRuleNotTested; // One-off setting
      if (RCSShouldTreatSystemCopy(RCSr,kManagedServerWhenUpdateBegins)) then begin
        RCSr.WantedSubStatus = kWantedSubStatusStopSystemCopiesDuringUpdate;
      end else begin
        if (RCSShouldTreatCrontab(RCsr,kManagedServerWhenUpdateEnds)) then begin
          RCSr.WantedSubStatus = kWantedSubStatusSetCrontabAfterUpdate;
        end else begin
          RCSr.WantedSubStatus = kWantedSubStatusNone;
          if (RCSr.IsInPlannedUpdateFlag!=0) then begin
            RCSr.WantedStatus = RCSr.NextWantedStatus;
          end else begin
            if (RCSShouldStartInMaintenance(RCSr,kManagedServerWhenUpdateEnds)) then begin
              RCSr.WantedStatus = kWantedStatusMaintenence;
            end else begin
              RCSr.WantedStatus = kWantedStatusRun;
            end;
          end;
        end;
      end;

    case kSubStatusStoppingSystemCopiesDuringUpdateCompleted:
      if (RCSShouldTreatCrontab(RCsr,kManagedServerWhenUpdateEnds)) then begin
        RCSr.WantedSubStatus = kWantedSubStatusSetCrontabAfterUpdate;
      end else begin
        RCSr.WantedSubStatus = kWantedSubStatusNone;
        RCSr.WantedStatus = kWantedStatusRun;
        if (RCSShouldStartInMaintenance(RCSr,kManagedServerWhenUpdateEnds)) then begin
          RCSr.WantedStatus = kWantedStatusMaintenence;
        end else begin
          RCSr.WantedStatus = kWantedStatusRun;
        end;
      end;
    case kSubStatusSetCrontabAfterUpdateCompleted:
      RCSr.WantedSubStatus = kWantedSubStatusNone;
      RCSr.WantedStatus = kWantedStatusRun;
      if (RCSShouldStartInMaintenance(RCSr,kManagedServerWhenUpdateEnds)) then begin
        RCSr.WantedStatus = kWantedStatusMaintenence;
      end else begin
        RCSr.WantedStatus = kWantedStatusRun;
      end;
  end;

  if ((RCSr.WantedStatus==kWantedStatusRun) or (RCSr.WantedStatus==kWantedStatusRunUnjournaled)) then begin
    StartStopSystemCopies(RCSr,kManagedServerWhenRunningNormally,true,true);
  end;

  switch (RCSr.CurrentSubStatus) begin
    case kSubStatusStartingSystemCopiesBeforeExport:  StartStopSystemCopies(RCSr,kManagedServerWhenUpdateExports,true,false);
    case kSubStatusStartingSystemCopiesDuringUpdate:  StartStopSystemCopies(RCSr,kManagedServerWhenUpdating,true,false); // must fix + rcsshouldstart...
    case kSubStatusStoppingSystemCopiesDuringUpdate:  StartStopSystemCopies(RCSr,kManagedServerWhenUpdating,false,false);
    case kSubStatusStoppingSlaveSystems:              StartStopSystemCopies(RCSr,kManagedServerWhenUpdating,false,true);
  end;

  if (old_status!=RCSr.CurrentStatus) then begin
    LogText(0,"UpdateServerWantedSubStatus: CurrentStatus for " & RCSr.UUID & " changed from " & StatusName(old_status) & " to " & StatusName(RCSr.CurrentStatus));
  end;
  if (old_wantedstatus!=RCSr.WantedStatus) then begin
    LogText(0,"UpdateServerWantedSubStatus: WantedStatus for " & RCSr.UUID & " changed from " & WantedStatusName(old_wantedstatus) & " to " & WantedStatusName(RCSr.WantedStatus));
  end;
  if (old_substatus!=RCSr.CurrentSubStatus) then begin
    LogText(0,"UpdateServerWantedSubStatus: CurrentSubStatus for " & RCSr.UUID & " changed from " & SubStatusName(old_substatus) & " to " & SubStatusName(RCSr.CurrentSubStatus));
  end;
  if (old_wantedsubstatus!=RCSr.WantedSubStatus) then begin
    LogText(0,"UpdateServerWantedSubStatus: WantedSubStatus for " & RCSr.UUID & " changed from " & WantedSubStatusName(old_wantedsubstatus) & " to " & WantedSubStatusName(RCSr.WantedSubStatus));
  end;

  if (ComparePosts(OldRCSr,RCSr)==false) then begin
    RecordUpdate(OldRCSr,RCSr,true);
    cnt = cnt + 1;
  end;
LUpdateServerWantedSubStatus:;
  return;
end;

global
updating procedure CheckSystemArchitecture()
begin
  string 255 script;
  record CloudSettingsBlock CSb;

  if (WindowsMode) then begin
    script = "cmd /c \"if defined PROCESSOR_ARCHITECTURE (if defined PROCESSOR_ARCHITEW6432 (echo >En64BitOS) else ";
    script = script & "(if \"%PROCESSOR_ARCHITECTURE%\" == \"x86\" (set dummy=) else (echo >En64BitOS))) else ";
    script = script & "(if \"%PROCESSOR_ARCHITECTURE%\" == \"x86\" (set dummy=) else (echo >En64BitOS))\"";
  end else begin
    script = "bash -c '( ";
    script = script & "if ( [ $(getconf LONG_BIT) -eq 64 ] ) ; then touch En64BitOS ; else rm -f En64BitOS ; fi ;";
    script = script & " )' ";
  end;
  RunShellScript(script);

  BlockLoad(CSb);
  if (FileExists("En64BitOS")) then begin
    SetGlobalBoolean("En64BitOS",true);
    if (CSb.Is64BitFlag<=1) then begin
      CSb.Is64BitFlag = 2;
      BlockStore(CSb);
    end;
  end else begin
    SetGlobalBoolean("En64BitOS",false);
    if (CSb.Is64BitFlag!=1) then begin
      CSb.Is64BitFlag = 1;
      BlockStore(CSb);
    end;
  end;
  return;
end;

global
procedure GetCloudSettingsBlock(var record CloudSettingsBlock CSb)
begin
  BlockLoad(CSb);
  return;
end;

function string 255 LinuxVersionExe(record HansaVersionVc HVr,record LocalCloudServerVc LCSr)
begin
  string 255 res,tstr,progfolder;
  record CloudSettingsBlock CSb;

  BlockLoad(CSb);
  if (CSb.Is64BitFlag==0) then begin
    qupdating.CheckSystemArchitecture;
    qupdating.GetCloudSettingsBlock(CSb); // Not sure if this is needed or if threads have a older copy
  end;

  progfolder = HVr.ProgramFolder;
  if (blank(progfolder) and nonblank(HVr.Code)) then begin
    progfolder = ProgramFolder & "/" VersionsFolder & "/" & HVr.Code;
  end;

  switch (LCSr.ExecutableType) begin
    case kExecutableTypeOptimizedDebug:       res = progfolder & "/hansa-debug-optimized-server";
    case kExecutableTypeDebug:                res = progfolder & "/hansa-debug-server";
    case kExecutableTypeSlave:                res = progfolder & "/hansa-slave";
    case kExecutableTypeSlaveDebug:           res = progfolder & "/hansa-debug-slave";
    case kExecutableTypeSlaveOptimizedDebug:  res = progfolder & "/hansa-debug-optimized-slave";
    otherwise
      LogText(0,"LinuxVersionExe() - Invalid executable type: " & LCSr.ExecutableType);
  end;

  if (ProgramPlatform==kPlatformLinuxArm64) then begin
    res = res & "arm";
  end;


  if ((CSb.Is64BitFlag==2) and nonblank(res)) then begin
    res = res & "64";
  end;

  if (left(res,1)!="/") then begin
    tstr = progfolder & "/" & res;
    res = tstr;
  end;

  if ((HVr.Version>0) and (HVr.Version<72)) then begin
    if (FileExists(res)==false) then begin
      res = progfolder & "/" & "hansa-server";
    end;
    if (FileExists(res)==false) then begin
      res = progfolder & "/" & "hansa-debug-server";
    end;
  end;

  LinuxVersionExe = res;
  return;
end;

function string 255 WindowsVersionExe(record HansaVersionVc HVr,record LocalCloudServerVc LCSr)
begin
  string 255 res,tstr,progfolder;

  progfolder = HVr.ProgramFolder;
  if (blank(progfolder) and nonblank(HVr.Code)) then begin
    progfolder = ProgramFolder & "/" VersionsFolder & "/" & HVr.Code;
  end;

  switch (LCSr.ExecutableType) begin
    case kExecutableTypeOptimizedDebug:       res = progfolder & "/hansa-windows-optimized-server";
    case kExecutableTypeDebug:                res = progfolder & "/hansa-windows-optimized-server";
    case kExecutableTypeSlave:                res = progfolder & "/hansa-windows-optimized-slave";
    case kExecutableTypeSlaveDebug:           res = progfolder & "/hansa-windows-optimized-slave";
    case kExecutableTypeSlaveOptimizedDebug:  res = progfolder & "/hansa-windows-optimized-slave";
    otherwise
      LogText(0,"WindowsVersionExe() - Invalid executable type: " & LCSr.ExecutableType);
  end;

  if (GetGlobalBoolean("En64BitOS") and nonblank(res)) then begin
    res = res & "64";
  end;

  res = res & ".exe";

  if (mid(res,1,1)!=":") then begin
    tstr = ProgramFolder & "\\" & res;
    res = tstr;
  end;

  WindowsVersionExe = res;
  return;
end;

function string 255 MacOSXVersionExe(record HansaVersionVc HVr,record LocalCloudServerVc LCSr)
begin
  string 255 res,tstr,progfolder;

  progfolder = HVr.ProgramFolder;
  if (blank(progfolder) and nonblank(HVr.Code)) then begin
    progfolder = ProgramFolder & "/" VersionsFolder & "/" & HVr.Code;
  end;

  switch (LCSr.ExecutableType) begin
    case kExecutableTypeOptimizedDebug:       res = progfolder & "/hansa-macosx-optimized-server";
    case kExecutableTypeDebug:                res = progfolder & "/hansa-macosx-optimized-server";
    case kExecutableTypeSlave:                res = progfolder & "/hansa-macosx-optimized-slave";
    case kExecutableTypeSlaveDebug:           res = progfolder & "/hansa-macosx-optimized-slave";
    case kExecutableTypeSlaveOptimizedDebug:  res = progfolder & "/hansa-macosx-optimized-slave";
    otherwise
      LogText(0,"MacOSXVersionExe() - Invalid executable type: " & LCSr.ExecutableType);
  end;

  if (left(res,1)!="/") then begin
    tstr = ProgramFolder & "/" & res;
    res = tstr;
  end;

  MacOSXVersionExe = res;
  return;
end;

function string 255 VersionExe(record HansaVersionVc HVr,record LocalCloudServerVc LCSr,Boolean forceverf)
begin
  string 255 res,tstr;

  if (blank(LCSr.HansaVersion) and !forceverf) then begin // Use process name as EXE name, EXE and HOBs from workdir
    res = LCSr.DataFolder & "/" & LCSr.ServerName;
    if ((left(res,1)!="/") and (left(res,1)!="\\") and (mid(res,1,2)!=":\\")) then begin
      tstr = ProgramFolder & "/" & res;
      res = tstr;
    end;
  end else begin
    switch (ProgramPlatform) begin
      case kPlatformUnknown:    res = LinuxVersionExe(HVr,LCSr);
      case kPlatformMac:        res = MacOSXVersionExe(HVr,LCSr);
      case kPlatformWindows32:  res = WindowsVersionExe(HVr,LCSr);
      case kPlatformWindows64:  res = WindowsVersionExe(HVr,LCSr);
      case kPlatformLinux32:    res = LinuxVersionExe(HVr,LCSr);
      case kPlatformLinux64:    res = LinuxVersionExe(HVr,LCSr);
      case kPlatformLinuxArm64: res = LinuxVersionExe(HVr,LCSr);
      otherwise
        res = LinuxVersionExe(HVr,LCSr);
    end;
  end;

  VersionExe = res;
  return;
end;

function string 255 ServerExe(record LocalCloudServerVc LCSr)
begin
  record HansaVersionVc HVr;

  GetVersion(LCSr.HansaVersion,HVr);
  ServerExe = VersionExe(HVr,LCSr,false);
end;

function Boolean LastLogLineEquals(string logfile,string logstr)
begin
  Boolean testf;
  string 255 tstr;
  LongInt fsz,pos,blocklen;
  area part;

  if (FileExists(logfile)) then begin
    fsz = FileSize(logfile);
    blocklen = MIN(len(logstr)+2,fsz);
    pos = 0;
    if (fsz>blocklen) then begin
      pos = fsz - blocklen;
    end;
    LoadFileToArea(logfile,pos,blocklen,part);
    tstr = Trim(GetStringFromArea(part,0,blocklen));
    if (tstr==logstr) then begin
      testf = true;
    end;
  end;

  LastLogLineEquals = testf;
  return;
end;

function Boolean IsCloneFinished(record LocalCloudServerVc LCSr)
begin
  IsCloneFinished = LastLogLineEquals(LCSr.DataFolder & "/cloning.log","finished with cloning");
  return;
end;

function Boolean IsCloneUpToDate(record LocalCloudServerVc LCSr)
begin
  IsCloneUpToDate = LastLogLineEquals(LCSr.DataFolder & "/cloning.log","up to date");
  return;
end;

global
updating procedure CallConfigHostFirewall(string cncode,string tcp_ports,string udp_ports,Integer op,var Integer res,var string msg)
begin
  res = ConfigHostFirewall(cncode,tcp_ports,udp_ports,op,msg);
end;

global
procedure OpenFirewallPortsOnLCS(area a_ports)
begin
  record CloudSettingsBlock CSb;
  string 255 tcp_ports,udp_ports,cncode,url,msg;
  LongInt stat;
  Integer res;

  tcp_ports = GetLineFromArea(a_ports,0);
  udp_ports = GetLineFromArea(a_ports,1);

  BlockLoad(CSb);
  cncode = CSb.NodeCode;
  url = Trim(CSb.CCAddr) & ":" & CSb.CCHTTPSPort;
  stat = CallService(url).CallConfigHostFirewall(cncode,tcp_ports,udp_ports,0,res,msg);
  if (res!=0) then begin
    LogText(0,"Failed opening Firewall ports (code=" & res & "): " & msg);
  end;
end;

procedure CreateEnablerActionsForServerIfNeeded(var record LocalCloudServerVc LCSr)
begin
  string 255 enfile,tstr;
  
  if (LCSr.CurrentStatus==kStatusRunning) then begin
    if (nonblank(LCSAsteriskControllerKey(LCSr))) then begin
      enfile = EnablerActionsFolder(LCSr) & "/EnInitAsteriskController";
      if (FileExists(enfile)==false) then begin
        CreateFolderHierarchy(EnablerActionsFolder(LCSr) & "/");
        tstr = LCSAsteriskControllerKey(LCSr);
        tstr = tstr & ":" & LCSAsteriskControllerAddr(LCSr);
        WriteStringToFile(tstr,enfile,0);
        UnsetLCSAsteriskControllerKey(LCSr);
      end;
    end;
  end;
  return;
end;

procedure GenerateSSLCertificatesForServerIfNeeded(var record LocalCloudServerVc LCSr)
begin
  area a_cert,a_privkey;
  string 255 certfile,privkeyfile,errmsg;
  
  if (LCSr.SSLCertFlag==0) then begin goto LGenerateSSLCertificatesForServerIfNeeded; end;
  if (blank(LCSr.DataFolder)==true) then begin goto LGenerateSSLCertificatesForServerIfNeeded; end;
  if (DirExists(LCSr.DataFolder)==false) then begin goto LGenerateSSLCertificatesForServerIfNeeded; end;
  
  certfile = LCSr.DataFolder & "/cert.crt";
  privkeyfile = LCSr.DataFolder & "/privkey.pem";
  if (FileExists(certfile) and FileExists(privkeyfile)) then begin goto LGenerateSSLCertificatesForServerIfNeeded; end;
 
  Delete_File(certfile);
  Delete_File(privkeyfile);
  GenerateCertificates(PublicHostName,a_cert,a_privkey,errmsg);
  if (nonblank(errmsg)) then begin
    LogText(0,"ERROR: " & errmsg);
    goto LGenerateSSLCertificatesForServerIfNeeded;
  end;
  
  WriteAreaToFile(a_cert,certfile,0);
  WriteAreaToFile(a_privkey,privkeyfile,0);
  
LGenerateSSLCertificatesForServerIfNeeded:;
  return;
end;

procedure HandleEnablerActionsOnServer(record LocalCloudServerVc LCSr)
begin
  string 255 enfile;
  area a_enfile;

  enfile = EnablerActionsFolder(LCSr) & "/EnOpenFirewallPorts";
  if (FileExists(enfile)) then begin
    LoadFileToArea(enfile,0,FileSize2(enfile),a_enfile);
    Delete_File(enfile);
    ThreadAsync.OpenFirewallPortsOnLCS(a_enfile);
  end;
end;

function string 255 VersionHOB(record HansaVersionVc HVr,record LocalCloudServerVc LCSr,Boolean forceverf)
begin
  string 255 res,tstr,progfolder;

  progfolder = HVr.ProgramFolder;
  if (blank(progfolder) and nonblank(HVr.Code)) then begin
    progfolder = ProgramFolder & "/" VersionsFolder & "/" & HVr.Code;
  end;

  if (blank(LCSr.HansaVersion) and !forceverf) then begin // Use process name as EXE name, EXE and HOBs from workdir
    res = LCSr.DataFolder & "/hob/";
  end else begin
    res = progfolder & "/hob/";
  end;

  if ((left(res,1)!="/") and (left(res,1)!="\\") and (mid(res,1,2)!=":\\")) then begin
    tstr = ProgramFolder & "/" & res;
    res = tstr;
  end;

  VersionHOB = res;
end;

function Boolean IsMinutesPastTime(date frdt,time frtm,date dt,time tm,Integer mins)
begin
  Boolean res;
  time tm2;

  if (BlankDate(frdt) or BlankDate(dt)) then begin
    res = true;
    goto LIsMinutesPastTime;
  end;

  tm2 = AddMinutes(tm,mins);
  if (AddDay(dt,1)==frdt) then begin
    if (tm2<tm) then begin
      if (tm2<frtm) then begin
        res = true;
      end;
    end else begin
      res = true;
    end;
  end else begin
    if (dt!=frdt) then begin
      res = true;
    end else begin
      if (tm2>tm) then begin
        if (tm2<frtm) then begin
          res = true;
        end;
      end;
    end;
  end;
  
LIsMinutesPastTime:;
  IsMinutesPastTime = res;
  return;
end;

function Boolean IsMinutesPastCurrentTime(date dt,time tm,Integer mins)
begin
  IsMinutesPastCurrentTime = IsMinutesPastTime(CurrentDate,CurrentTime,dt,tm,mins);
  return;
end;

function Boolean IsLocalServerSlaveSystem(record LocalCloudServerVc LCSr)
begin
  Boolean res;
  
  switch (LCSr.ExecutableType) begin
    case kExecutableTypeSlave:                res = true;
    case kExecutableTypeSlaveDebug:           res = true;
    case kExecutableTypeSlaveOptimizedDebug:  res = true;
    otherwise
  end;
  IsLocalServerSlaveSystem = res;
  return;
end;

function Boolean IsLocalServerCloneSystem(record LocalCloudServerVc LCSr)
begin
  Boolean res;
  
  switch (LCSr.CloneFlag) begin
    case kSystemTypeNormal:
    otherwise
      res = true;
  end;
  
  IsLocalServerCloneSystem = res;
  return;
end;

updating procedure UpdateServerStatus(var record LocalCloudServerVc LCSr,var record HansaVersionVc HVr)
begin
  LongInt svpid,newport;
  record LocalCloudServerVc OldLCSr;
  string 255 dbname,errmsg,hallogfile,oldhallogfile,vercode;
  Boolean hal_logfilef,hdb_existsf,hdb_lockedf,ok_versionf,pidfile_existsf,pid_is_runningf;
  Boolean ok_exef,ok_datafolderf;
  Boolean tcp_port_avail,http_port_avail,https_port_avail;
  Boolean slavesystemf,clonesystemf;
  string 255 tstr,port_conflicts,exefil,hobflr;
  record CloudSettingsBlock CSb;
  record HansaVersionVc HV2r;
  val tval,foldersz;
  ULong64 min_diskfree;
  LongInt freespace,totalspace;

  vercode = HVr.Code;
  RecordCopy(OldLCSr,LCSr);

  if (LCSr.CurrentStatus==kStatusMoving) then begin
    if (LCSr.WantedStatus==kWantedStatusStop) then begin
      LCSr.CurrentStatus = kStatusStopped;
    end;
    goto LUpdateServerStatus;
  end;
  
  if (LCSr.WantedStatus==kWantedStatusMoveServer) then begin
    LCSr.CurrentSubStatus = kSubStatusNone;
    if (LCSr.CurrentStatus!=kStatusStopped) then begin
      LCSr.CurrentStatus = kStatusConfigInError;
      LCSr.StatusText = "Server must be stopped";
      LCSr.MyStandardStatusCode = 10001;
      LCSr.MyStandardStatusStr = "";
      goto LUpdateServerStatus;
    end;
    LCSr.CurrentStatus = kStatusMoving;
    goto LUpdateServerStatus;
  end;
  
  if (LCSr.CurrentStatus==kStatusConfigInError) then begin
    if (LCSr.MyStandardStatusCode==10046) then begin
      foldersz = GetFolderSize(LCSr.DataFolder);
      freespace = GetDiskSpace("tmp",totalspace);
      min_diskfree = foldersz;
      min_diskfree = min_diskfree/1024/1024;
      min_diskfree = min_diskfree + (2*1024); // 2Gb margin
      if (freespace<min_diskfree) then begin
        goto LUpdateServerStatus; // Server archiving in progress, but disk is full
      end;
      LCSr.StatusText = "";
      LCSr.MyStandardStatusCode = -1;
      LCSr.MyStandardStatusStr = "";
    end;
  end;

  slavesystemf = IsLocalServerSlaveSystem(LCSr);
  clonesystemf = IsLocalServerCloneSystem(LCSr);

  if (blank(LCSr.DataFolder)) then begin
    LCSr.CurrentStatus = kStatusConfigInError;
    LCSr.CurrentSubStatus = kSubStatusNone;
    LCSr.StatusText = "No data folder specified";
    LCSr.MyStandardStatusCode = 10002;
    LCSr.MyStandardStatusStr = "";
    goto LUpdateServerStatus;
  end;
  
  ok_versionf = GetVersion(LCSr.HansaVersion,HVr);
  if (ok_versionf==false) then begin
    RecordClear(HVr);
    HVr.Code = vercode;
  end;
  exefil = ServerExe(LCSr);
  hobflr = VersionHOB(HVr,LCSr,false);

  if ((clonesystemf==false) and (slavesystemf==false) and (blank(LCSr.Port) or (LCSr.Port==0))) then begin
    LCSr.CurrentStatus = kStatusConfigInError;
    LCSr.CurrentSubStatus = kSubStatusNone;
    LCSr.StatusText = "No port specified";
    LCSr.MyStandardStatusCode = 10003;
    LCSr.MyStandardStatusStr = "";
    goto LUpdateServerStatus;
  end;

  ok_datafolderf = DirExists(LCSr.DataFolder);
  
  hallogfile = LCSr.DataFolder & "/hal.log";
  oldhallogfile = hallogfile & ".old";
  hal_logfilef = FileExists(hallogfile);
  if (hal_logfilef and LCSr.CurrentStatus==kStatusConfigInError and
      ((LCSr.WantedStatus==kWantedStatusStop) or (LCSr.WantedStatus==kWantedStatusStopAndRefresh) or (LCSr.WantedStatus==kWantedStatusForceStop) or (LCSr.WantedStatus==kWantedStatusRestart))) then begin
    Delete_File(oldhallogfile);
    RenameFile(hallogfile,oldhallogfile);
    hal_logfilef = false;
  end;

  if (blank(LCSr.HansaVersion)) then begin
    ok_versionf = true; // Use process name as EXE name, EXE and HOBs from workdir
  end else begin
    if (ok_versionf==false) then begin
      if (HVr.CurrentState==kHansaVersionStateNotDownloaded) then begin
        if (IsDownloadingVersion(HVr.Code)==false or ShouldDownloadVersion(HVr.Code)==false) then begin
          DoDownloadVersion(HVr,false);
        end;
        goto LUpdateServerStatus;
      end;
      
      BlockLoad(CSb);
      HVr.Code = LCSr.HansaVersion;
      RecordCopy(HV2r,HVr);
      if (ReadFirstMain(HV2r,1,true)==false) then begin
        if (DirExists(CSb.VersionsFolder & "/" & HVr.Code)) then begin
          if (!FileExists(VersionExe(HVr,LCSr,false))) then begin
            LogText(0,"UpdateServerStatus " & LCSName(LCSr) & " version record for " & HVr.Code & " is missing, folder exists but with missing exe or hob, looking for " & VersionExe(HVr,LCSr,false));
            LCSr.CurrentStatus = kStatusConfigInError;
            LCSr.CurrentSubStatus = kSubStatusNone;
            LCSr.StatusText = "Version record for " & HVr.Code & " is missing, folder exists but with missing exe or hob";
            LCSr.MyStandardStatusCode = 10004;
            LCSr.MyStandardStatusStr = "";
            goto LUpdateServerStatus;
          end else begin
            ok_versionf = true;
          end;
        end else begin
          if (LCSr.CurrentStatus==kStatusStopped) then begin
            if (IsDownloadingVersion(HVr.Code) or ShouldDownloadVersion(HVr.Code)) then begin
              // Allow node to download the version
              goto LUpdateServerStatus;
            end;
          end;
          if (!IsDownloadingVersion(HVr.Code) and !ShouldDownloadVersion(HVr.Code) and (HVr.CurrentState!=kHansaVersionStateInstalling) and (HVr.CurrentState!=kHansaVersionStateUpdating)) then begin
            if (IsDevelopmentVersion(LCSr.HansaVersion)) then begin
              LogText(0,"UpdateServerStatus " & LCSName(LCSr) & " version record for " & HVr.Code & " is missing, closing it...");
              LCSr.CurrentStatus = kStatusStopped;
              LCSr.CurrentSubStatus = kSubStatusNone;
              LCSr.ShouldCloseFlag = 1;
              LCSr.Closed = 1;
              goto LUpdateServerStatus;
            end else begin
              LogText(0,"UpdateServerStatus " & LCSName(LCSr) & " version record for " & HVr.Code & " is missing");
              LCSr.CurrentStatus = kStatusConfigInError;
              LCSr.CurrentSubStatus = kSubStatusNone;
              LCSr.StatusText = "Version record for " & HVr.Code & " is missing";
              LCSr.MyStandardStatusCode = 10005;
              LCSr.MyStandardStatusStr = HVr.Code;
              if (blank(LCSr.MyStandardStatusStr)) then begin LCSr.MyStandardStatusStr = "(blank)"; end;
              goto LUpdateServerStatus;
            end;
          end;
        end;
      end;
    end else begin
      if (LCSr.CurrentStatus==kStatusUpdatingVersion) then begin
        switch (LCSr.CurrentSubStatus) begin
          case kSubStatusImportingCompleted:
          case kSubStatusImporting:
          otherwise
            switch (LCSr.WantedStatus) begin
              case kWantedStatusStop:
              case kWantedStatusOnDemand:
              otherwise
                if (GetVersion(LCSr.NewHansaVersion,HV2r)==false) then begin
                  LCSr.StatusText = "Version not yet available at node (" & HV2r.DownloadProgress & ")";
                  LCSr.MyStandardStatusCode = 10041;
                  LCSr.MyStandardStatusStr = HV2r.DownloadProgress;
                  if (blank(LCSr.MyStandardStatusStr)) then begin LCSr.MyStandardStatusStr = "0"; end;
                  goto LUpdateServerStatus;
                end;
            end;
        end;
      end;
    end;
  end;

  dbname = HDBFile(LCSr,HVr);

  hdb_existsf = FileExists(dbname);
  if (hdb_existsf) then begin
    hdb_lockedf = FileIsLocked(dbname);
  end;

  pidfile_existsf = FileExists(PidFile(LCSr));
  if (pidfile_existsf) then begin
    svpid = ReadLongFromFile(PidFile(LCSr));
    pid_is_runningf = PidIsRunning(svpid);
  end;

  if (hdb_lockedf and pid_is_runningf==false) then begin
    hdb_lockedf = FileIsLocked(dbname);
  end;

  if (hdb_existsf) then begin
    tval = FileSize2(dbname);
    if (tval<0) then begin
      LCSr.HDBSize = 0;
    end else begin
      LCSr.HDBSize = tval;
    end;
  end else begin
    LCSr.HDBSize = 0;
  end;

  if ((LCSr.CurrentStatus!=kStatusUpdatingVersion) and
      (LCSr.CurrentStatus!=kStatusRebuildingDatabase) and
      (LCSr.CurrentStatus!=kStatusExportingDatabase) and
      (LCSr.CurrentStatus!=kStatusExportingRegister) and
      (LCSr.CurrentStatus!=kStatusExportingCompany)) then begin
    tcp_port_avail = true;
    http_port_avail = true;
    https_port_avail = true;
    if ((clonesystemf==false) and (slavesystemf==false)) then begin
      if (LCSr.Port>0) then begin
        if (TCPPortAvailable(LCSr.Port,LCSr.BindIP)==false) then begin
          tcp_port_avail = false;
          port_conflicts = LCSr.Port;
        end;
      end else begin
        tcp_port_avail = false;
      end;
      if (LCSr.HTTPPort>0) then begin
        if (TCPPortAvailable(LCSr.HTTPPort,LCSr.BindIP)==false) then begin
          http_port_avail = false;
          if (nonblank(port_conflicts)) then begin port_conflicts = port_conflicts & ", "; end;
          port_conflicts = port_conflicts & LCSr.HTTPPort;
        end;
      end;
      if (LCSr.HTTPSPort>0) then begin
        if (TCPPortAvailable(LCSr.HTTPSPort,LCSr.BindIP)==false) then begin
          https_port_avail = false;
          if (nonblank(port_conflicts)) then begin port_conflicts = port_conflicts & ", "; end;
          port_conflicts = port_conflicts & LCSr.HTTPSPort;
        end;
      end;
    end;
  end;

  if ((LCSr.WantedStatus==kWantedStatusCreateServer) or
      (LCSr.WantedStatus==kWantedStatusCreateStartedServer) or
      (LCSr.WantedStatus==kWantedStatusLaunchReserveSystem) or
      (LCSr.WantedStatus==kWantedStatusLaunchUpdateSystem) or
      (LCSr.WantedStatus==kWantedStatusLaunchTestSystem)) then begin
    if (ok_versionf==false) then begin
      ReadFirstMain(HVr,1,true);
      LCSr.CurrentStatus = kStatusCreating;
      LCSr.StatusText = "Version not yet available at node (" & HVr.DownloadProgress & ")";
      LCSr.MyStandardStatusCode = 10006;
      LCSr.MyStandardStatusStr = HVr.DownloadProgress;
      if (blank(LCSr.MyStandardStatusStr)) then begin LCSr.MyStandardStatusStr = "0"; end;
      goto LUpdateServerStatus;
    end;
    if (ok_datafolderf==false) then begin
      LCSr.CurrentStatus = kStatusCreating;
      LCSr.StatusText = "Data folder missing";
      LCSr.MyStandardStatusCode = 10007;
      LCSr.MyStandardStatusStr = "";
      goto LUpdateServerStatus;
    end;
    LCSr.CurrentStatus = kStatusCreated;
    LCSr.StatusText = "";
    LCSr.MyStandardStatusCode = -1;
    LCSr.MyStandardStatusStr = "";
    goto LUpdateServerStatus;
  end else begin
    if (ok_datafolderf==false) then begin
      if (LCSr.ArchivedFlag==0) then begin
        LCSr.CurrentStatus = kStatusConfigInError;
        LCSr.CurrentSubStatus = kSubStatusNone;
        LCSr.StatusText = "Data folder is gone";
        LCSr.MyStandardStatusCode = 10008;
        LCSr.MyStandardStatusStr = "";
      end;
      goto LUpdateServerStatus;
    end;
  end;

  if (ok_versionf==false) then begin
    if (blank(HVr.Code) or
       (IsDownloadingVersion(HVr.Code)==false and ShouldDownloadVersion(HVr.Code)==false and HVr.CurrentState!=kHansaVersionStateInstalling and HVr.CurrentState!=kHansaVersionStateUpdating)) then begin
      LogText(0,"UpdateServerStatus: Version missing (" & LCSr.UUID & ") state=" & StateName(HVr.CurrentState) & ", shoulddownload=" & ShouldDownloadVersion(HVr.Code) & ", isdownloading=" & IsDownloadingVersion(HVr.Code));
      if ((LCSr.WantedStatus!=kWantedStatusStop) and
          (LCSr.WantedStatus!=kWantedStatusStopAndRefresh) and
          (LCSr.WantedStatus!=kWantedStatusForceStop) and
          (LCSr.WantedStatus!=kWantedStatusRestart) and
          (LCSr.WantedStatus!=kWantedStatusOnDemand)) then begin
        LCSr.StatusText = "Version missing and not yet being downloaded";
        LCSr.MyStandardStatusCode = 10009;
        LCSr.MyStandardStatusStr = "";
      end else begin
        if (LCSr.CurrentStatus==kStatusStarting) then begin
          LCSr.CurrentStatus = kStatusStopped;
        end;
      end;
    end else begin
      ReadFirstMain(HVr,1,true);
      LCSr.StatusText = "Version not yet available at node (" & HVr.DownloadProgress & ")";
      LCSr.MyStandardStatusCode = 10010;
      LCSr.MyStandardStatusStr = HVr.DownloadProgress;
      if (blank(LCSr.MyStandardStatusStr)) then begin LCSr.MyStandardStatusStr = "0"; end;
    end;
    goto LUpdateServerStatus; // This is probably incorrect, should be higher up
  end;

  tstr = VersionExe(HVr,LCSr,false);
  if (FileExists(tstr)==false) then begin
    if (nonblank(HVr.Code) and
        IsDownloadingVersion(HVr.Code)==false and
        ShouldDownloadVersion(HVr.Code)==false and
        HVr.CurrentState!=kHansaVersionStateInstalling and
        HVr.CurrentState!=kHansaVersionStateUpdating) then begin
      LogText2(0,"UpdateServerStatus: Version EXE missing (" & LCSr.UUID & ")",kVerbosityDebugDetailed);
      errmsg = "Version EXE missing: ";
      if (nonblank(tstr)) then begin
        errmsg = errmsg & tstr;
      end else begin
        errmsg = errmsg & "unknown type";
      end;
//      LCSr.CurrentStatus = kStatusConfigInError;
//      LCSr.CurrentSubStatus = kSubStatusNone;
      LCSr.StatusText = errmsg;
      LCSr.MyStandardStatusCode = 10011;
    end else begin
      errmsg = "Version " & HVr.Code & " is being downloaded";
      LCSr.StatusText = errmsg;
      LCSr.MyStandardStatusCode = 10012;
      LCSr.MyStandardStatusStr = HVr.Code;
      if (blank(LCSr.MyStandardStatusStr)) then begin LCSr.MyStandardStatusStr = "(blank)"; end;
    end;
    goto LUpdateServerStatus;
  end else begin
    if (LCSr.MyStandardStatusCode==10011) then begin // "Version EXE missing: "
      if (LCSr.CurrentStatus==kStatusConfigInError) then begin
        LCSr.CurrentStatus = kStatusStopped;
      end else begin
        LCSr.StatusText = "";
        LCSr.MyStandardStatusCode = -1;
        LCSr.MyStandardStatusStr = "";
      end;
    end;
  end;

  if (hal_logfilef) then begin
    LogText(0,"UpdateServerStatus: Fatal halcust/halpatch errors (" & LCSr.UUID & ")");
    LCSr.CurrentStatus = kStatusConfigInError;
    LCSr.CurrentSubStatus = kSubStatusNone;
    LCSr.StatusText = "Fatal halcust/halpatch errors";
    LCSr.MyStandardStatusCode = 10015;
    LCSr.MyStandardStatusStr = "";
    goto LUpdateServerStatus;
  end;

  if ((LCSr.CurrentStatus==kStatusUpdatingVersion) or (LCSr.CurrentStatus==kStatusRebuildingDatabase)) then begin
    switch (LCSr.WantedSubStatus) begin
/*
      case kWantedSubStatusImport:
        if (LCSr.CurrentStatus==kStatusImporting) then begin
          if (!pid_is_runningf and !hdb_lockedf and hdb_existsf) then begin
            LCSr.CurrentSubStatus = kSubStatusImportingCompleted;
            goto LUpdateServerStatus;
          end;
        end;
*/
      case kWantedSubStatusExport:
        if (LCSr.CurrentSubStatus==kSubStatusExporting) then begin
          if (!pid_is_runningf and !hdb_lockedf and hdb_existsf) then begin
            if (pidfile_existsf) then begin
              LCSr.CurrentStatus = kStatusConfigInError;
              LCSr.CurrentSubStatus = kSubStatusNone;
              LCSr.StatusText = "Server encountered errors during export";
              LCSr.MyStandardStatusCode = 10044;
              LCSr.MyStandardStatusStr = "";
              goto LUpdateServerStatus;
            end else begin
              if (!FileExists(LCSr.DataFolder & "/" & "LCSUPDATE.TXT")) then begin
                LCSr.QuickRestarts = LCSr.QuickRestarts + 1;
                if (LCSr.QuickRestarts>120) then begin
                  LCSr.CurrentStatus = kStatusConfigInError;
                  LCSr.CurrentSubStatus = kSubStatusNone;
                  LCSr.StatusText = "Server failed exporting database";
                  LCSr.MyStandardStatusCode = 10045;
                  LCSr.MyStandardStatusStr = "";
                end;
                goto LUpdateServerStatus;
              end;
            end;
          end;
        end;
      case kWantedSubStatusStopForExport:
        if (pid_is_runningf) then begin
          LCSr.CurrentSubStatus = kSubStatusStopForExport;
          goto LUpdateServerStatus;
        end;
        if (hdb_lockedf) then begin
          LCSr.CurrentStatus = kStatusConfigInError;
          LCSr.CurrentSubStatus = kSubStatusNone;
          LCSr.StatusText = "Server HDB is locked but process is not running";
          LCSr.MyStandardStatusCode = 10016;
          LCSr.MyStandardStatusStr = "";
          goto LUpdateServerStatus;
        end else begin
          LCSr.CurrentSubStatus = kSubStatusStopForExportCompleted;
          goto LUpdateServerStatus;
        end;
      case kWantedSubStatusNone:
        if ((LCSr.CurrentSubStatus==kSubStatusAfterImport) or
            (LCSr.CurrentSubStatus==kSubStatusStoppingSystemCopiesDuringUpdateCompleted) or
            (LCSr.CurrentSubStatus==kSubStatusSetCrontabAfterUpdateCompleted) or
            (LCSr.CurrentSubStatus==kSubStatusDBCopyBeforeUpdateCompleted)) then begin  //must be wrong
          if (pid_is_runningf or (hdb_existsf==false and (LCSr.CloneFlag==kSystemTypeNormal)) or hdb_lockedf) then begin
            LCSr.StatusText = "Waiting for server to stop after import";
            LCSr.MyStandardStatusCode = 10017;
            LCSr.MyStandardStatusStr = "";
            goto LUpdateServerStatus; // we are waiting for the server to stop after the import
          end else begin
            LCSr.CurrentStatus = kStatusStopped;
            LCSr.CurrentSubStatus = kSubStatusNone;
          end;
        end;
    end;
    goto LUpdateServerStatus;
  end;

  if (LCSr.CurrentStatus==kStatusConfigInError) then begin
    if ((LCSr.WantedStatus==kWantedStatusUpdateVersion) or
        (LCSr.WantedStatus==kWantedStatusRebuildDatabase) or
        (LCSr.WantedStatus==kWantedStatusClearRegister)) then begin
      goto LUpdateServerStatus;
    end;
  end;

  if ((hdb_existsf==false) and (LCSr.CloneFlag==kSystemTypeNormal)) then begin
    if (LCSr.WantedStatus==kWantedStatusUpdateVersion) then begin
      LCSr.CurrentStatus = kStatusStopped;
      LCSr.CurrentSubStatus = kSubStatusDBMissing;
      goto LUpdateServerStatus;
    end;
    if ((LCSr.WantedStatus==kWantedStatusRebuildDatabase) or
        (LCSr.WantedStatus==kWantedStatusClearRegister)) then begin
      LCSr.CurrentStatus = kStatusConfigInError;
      LCSr.CurrentSubStatus = kSubStatusNone;
      LCSr.StatusText = "HDB missing, operation cancelled";
      LCSr.MyStandardStatusCode = 10018;
      LCSr.MyStandardStatusStr = "";
      goto LUpdateServerStatus;
    end;
  end;

  if ((hdb_lockedf==false) and (pid_is_runningf==false)) then begin //XX
    if ((LCSr.WantedStatus!=kWantedStatusOnDemand) and
        (LCSr.WantedStatus!=kWantedStatusStop) and
        (LCSr.WantedStatus!=kWantedStatusStopAndRefresh) and
        (LCSr.WantedStatus!=kWantedStatusForceStop) and
        (LCSr.WantedStatus!=kWantedStatusImportBackup) and
        (LCSr.WantedStatus!=kWantedStatusExportDatabase) and
        (LCSr.WantedStatus!=kWantedStatusImportBackupAndRun) and
        (LCSr.WantedStatus!=kWantedStatusExportCompany) and
        (LCSr.WantedStatus!=kWantedStatusResetToBackup) and
        (LCSr.WantedStatus!=kWantedStatusExportRegister)) then begin
      if ((LCSr.CurrentStatus!=kStatusUpdatingVersion) and
          (LCSr.CurrentStatus!=kStatusRebuildingDatabase) and
          (LCSr.CurrentStatus!=kStatusRebuildingDatabase) and
          (LCSr.CurrentStatus!=kStatusImportingBackup) and
          (LCSr.CurrentStatus!=kStatusImportedBackup) and
          (LCSr.CurrentStatus!=kStatusExportingDatabase) and
          (LCSr.CurrentStatus!=kStatusExportedDatabase) and
          (LCSr.CurrentStatus!=kStatusExportingRegister) and
          (LCSr.CurrentStatus!=kStatusExportedRegister) and
          (LCSr.CurrentStatus!=kStatusExportingCompany) and
          (LCSr.CurrentStatus!=kStatusExportedCompany) and
          (LCSr.CurrentStatus!=kStatusStopped) and
          (LCSr.CurrentStatus!=kStatusConfigInError)) then begin
        if (blankdate(LCSr.LastStartDate) or (DateTimeDiffInSeconds(LCSr.LastStartDate,LCSr.LastStartTime,CurrentDate,CurrentTime)>8)) then begin
          LCSr.QuickRestarts = LCSr.QuickRestarts + 1;
          LCSr.CurrentStatus = kStatusStopped;
        end;
      end;

      if (clonesystemf or slavesystemf) then begin
        if (LCSr.QuickRestarts>120) then begin
          LCSr.CurrentStatus = kStatusConfigInError;
          LCSr.CurrentSubStatus = kSubStatusNone;
          LCSr.StatusText = "Server stopped within 5 minutes more than 120 times, check mother system";
          LCSr.MyStandardStatusCode = 10019;
          LCSr.MyStandardStatusStr = "";
          goto LUpdateServerStatus;
        end;
      end else begin
        if (LCSr.QuickRestarts>5) then begin
          if (IsMinutesPastTime(LCSr.LastStopDate,LCSr.LastStopTime,CurrentDate,CurrentTime,60)==true) then begin
            LogText(0,"UpdateServerStatus: Server " & LCSName(LCSr) & " stopped more than 5 times within 5 minutes, attempting restart");
            LCSr.CurrentStatus = kStatusStopped;
            LCSr.CurrentSubStatus = kSubStatusNone;
            LCSr.QuickRestarts = 0;
            LCSr.StatusText = "Server stopped within 5 minutes more than 5 times, attempting restart";
            LCSr.MyStandardStatusCode = 10020;
            LCSr.MyStandardStatusStr = "";
          end else begin
            LogText(0,"UpdateServerStatus: Server " & LCSName(LCSr) & " stopped more than 5 times within 5 minutes");
            LCSr.CurrentStatus = kStatusConfigInError;
            LCSr.CurrentSubStatus = kSubStatusNone;
            LCSr.StatusText = "Server stopped within 5 minutes more than 5 times";
            LCSr.MyStandardStatusCode = 10021;
            LCSr.MyStandardStatusStr = "";
          end;
          goto LUpdateServerStatus;
        end;
      end;
      if (LCSr.CurrentStatus==kStatusStopped) then begin
        if (LCSr.WantedStatus==kWantedStatusClearRegister) then begin
          LCSr.CurrentStatus = kStatusClearingRegister;
          if (LCSr.CurrentSubStatus==kSubStatusClearingRegister) then begin
            LCSr.CurrentSubStatus = kSubStatusClearingRegisterCompleted;
          end else begin
            LCSr.CurrentSubStatus = kSubStatusStopForClearRegisterCompleted;
          end;
        end;
        if (LCSr.WantedSubStatus==kWantedSubStatusStopForExport) then begin
          switch (LCSr.WantedStatus) begin
            case kWantedStatusUpdateVersion:
              LCSr.CurrentStatus = kStatusUpdatingVersion;
              LCSr.CurrentSubStatus = kSubStatusStopForExportCompleted;
            case kWantedStatusRebuildDatabase:
              LCSr.CurrentStatus = kStatusRebuildingDatabase;
              LCSr.CurrentSubStatus = kSubStatusStopForExportCompleted;
          end;
        end;
        goto LUpdateServerStatus;
      end;
    end;

    if (LCSr.CurrentStatus==kStatusStarting) then begin
      if (hdb_existsf) then begin // Unless we were creating the db and succeeded
        // This is required because the server might be in starting state, but finished by the time we get here
        switch (LCSr.WantedStatus) begin
          case kWantedStatusImportBackup:       LCSr.CurrentStatus = kStatusImportingBackup;    goto LUpdateServerStatus;
          case kWantedStatusImportBackupAndRun: LCSr.CurrentStatus = kStatusImportingBackup;    goto LUpdateServerStatus;
          case kWantedStatusResetToBackup:      LCSr.CurrentStatus = kStatusImportingBackup;    goto LUpdateServerStatus;
        end;
      end;
      switch (LCSr.WantedStatus) begin
        case kWantedStatusStop:               LCSr.CurrentStatus = kStatusExportingCompany;   goto LUpdateServerStatus;
        case kWantedStatusExportCompany:      LCSr.CurrentStatus = kStatusExportingCompany;   goto LUpdateServerStatus;
        case kWantedStatusExportRegister:     LCSr.CurrentStatus = kStatusExportingRegister;  goto LUpdateServerStatus;
        case kWantedStatusExportDatabase:     LCSr.CurrentStatus = kStatusExportingDatabase;  goto LUpdateServerStatus;
        
        case kWantedStatusOnDemand:           LCSr.CurrentStatus = kStatusStopped;  goto LUpdateServerStatus;
        case kWantedStatusStop:               LCSr.CurrentStatus = kStatusStopped;  goto LUpdateServerStatus;
        case kWantedStatusStopAndRefresh:     LCSr.CurrentStatus = kStatusStopped;  goto LUpdateServerStatus;
        case kWantedStatusForceStop:          LCSr.CurrentStatus = kStatusStopped;  goto LUpdateServerStatus;

        case kWantedStatusClearRegister:
          LCSr.CurrentStatus = kStatusClearingRegister;
          LCSr.CurrentSubStatus = kSubStatusClearingRegister;
          goto LUpdateServerStatus;
      end;

      if (nonblankdate(LCSr.LastStartDate) and (DateTimeDiffInSeconds(CurrentDate,CurrentTime,LCSr.LastStartDate,LCSr.LastStartTime)<10)) then begin //XX
        goto LUpdateServerStatus;
      end;
    end;
    
    if (LCSr.WantedStatus==kWantedStatusUpdateVersion) then begin
      if (slavesystemf) then begin
        LCSr.CurrentStatus = kStatusConfigInError;
        LCSr.CurrentSubStatus = kSubStatusNone;
        LCSr.StatusText = "Version update requires the server to be running";
        LCSr.MyStandardStatusCode = 10022;
        LCSr.MyStandardStatusStr = "";
      end else begin // check kStatusConfigInError?
        LCSr.CurrentStatus = kStatusUpdatingVersion;
        LCSr.CurrentSubStatus = kSubStatusBeforeExport;
      end;
      LCSr.QuickRestarts = 0;
      goto LUpdateServerStatus;
    end;

    if (LCSr.WantedStatus==kWantedStatusRebuildDatabase) then begin
      LCSr.CurrentStatus = kStatusRebuildingDatabase;
      LCSr.CurrentSubStatus = kSubStatusBeforeExport;
      LCSr.QuickRestarts = 0;
      goto LUpdateServerStatus;
    end;
    
    if (LCSr.WantedStatus==kWantedStatusClearRegister) then begin
      LCSr.CurrentStatus = kStatusClearingRegister;
      if (LCSr.CurrentSubStatus==kSubStatusClearingRegister) then begin
        LCSr.CurrentSubStatus = kSubStatusClearingRegisterCompleted;
      end else begin
        LCSr.CurrentSubStatus = kSubStatusStopForClearRegister;
      end;
      LCSr.QuickRestarts = 0;
      goto LUpdateServerStatus;
    end;

    if ((LCSr.WantedStatus!=kWantedStatusExportDatabase) and
        (LCSr.WantedStatus!=kWantedStatusImportBackup) and
        (LCSr.WantedStatus!=kWantedStatusExportRegister) and
        (LCSr.WantedStatus!=kWantedStatusExportCompany) and
        (LCSr.WantedStatus!=kWantedStatusImportBackupAndRun) and
        (LCSr.WantedStatus!=kWantedStatusResetToBackup) and
        (LCSr.CurrentStatus!=kStatusConfigInError)) then begin
      if ((tcp_port_avail==false) and (clonesystemf==false) and (slavesystemf==false) and (LCSr.Port>0)) then begin
        LCSr.CurrentStatus = kStatusConfigInError;
        LCSr.CurrentSubStatus = kSubStatusNone;
        LCSr.StatusText = "Client port not available";
        LCSr.MyStandardStatusCode = 10023;
        LCSr.MyStandardStatusStr = "";
        goto LUpdateServerStatus;
      end;

      if ((clonesystemf==false) and (slavesystemf==false)) then begin
        if (http_port_avail==false) then begin
          LCSr.CurrentStatus = kStatusConfigInError;
          LCSr.CurrentSubStatus = kSubStatusNone;
          LCSr.StatusText = "HTTP port not available";
          LCSr.MyStandardStatusCode = 10024;
          LCSr.MyStandardStatusStr = "";
          goto LUpdateServerStatus;
        end;
    
        if (https_port_avail==false) then begin
          LCSr.CurrentStatus = kStatusConfigInError;
          LCSr.CurrentSubStatus = kSubStatusNone;
          LCSr.StatusText = "HTTPS port not available";
          LCSr.MyStandardStatusCode = 10025;
          LCSr.MyStandardStatusStr = "";
          goto LUpdateServerStatus;
        end;
      end;
    end;

    switch (LCSr.WantedStatus) begin
      case kWantedStatusExportCompany:
        if (LCSr.CurrentStatus==kStatusExportingCompany) then begin
          LCSr.CurrentStatus = kStatusExportedCompany;
        end;
      case kWantedStatusExportCompany:
        if (LCSr.CurrentStatus==kStatusExportingCompany) then begin
          LCSr.CurrentStatus = kStatusExportedCompany;
        end;
      case kWantedStatusExportRegister:
        if (LCSr.CurrentStatus==kStatusExportingRegister) then begin
          LCSr.CurrentStatus = kStatusExportedRegister;
        end;
      case kWantedStatusExportDatabase:
        if (LCSr.CurrentStatus==kStatusExportingDatabase) then begin
          LCSr.CurrentStatus = kStatusExportedDatabase;
        end;
      case kWantedStatusImportBackup:
        if (LCSr.CurrentStatus==kStatusImportingBackup) then begin
          LCSr.CurrentStatus = kStatusImportedBackup;
        end;
      case kWantedStatusImportBackupAndRun:
        if (LCSr.CurrentStatus==kStatusImportingBackup) then begin
          LCSr.CurrentStatus = kStatusImportedBackup;
        end;
      case kWantedStatusResetToBackup:
        if (LCSr.CurrentStatus==kStatusImportingBackup) then begin
          LCSr.CurrentStatus = kStatusImportedBackup;
        end;
      otherwise
        if (LCSr.CurrentStatus!=kStatusConfigInError) then begin
          LCSr.CurrentStatus = kStatusStopped;
        end;
    end;
    if (LCSr.CurrentStatus!=kStatusConfigInError) then begin
      LCSr.CurrentSubStatus = kSubStatusNone;
      LCSr.StatusText = "";
      LCSr.MyStandardStatusCode = -1;
      LCSr.MyStandardStatusStr = "";
    end;
    goto LUpdateServerStatus;
  end;
  
  if (pidfile_existsf==false and
     (LCSr.CurrentStatus!=kStatusUpdatingVersion) and
     (LCSr.CurrentStatus!=kStatusExportingDatabase) and
     (LCSr.CurrentStatus!=kStatusExportingCompany) and
     (LCSr.CurrentStatus!=kStatusExportingRegister) and
     (LCSr.CurrentStatus!=kStatusImportingBackup) and
     (LCSr.CurrentStatus!=kStatusStopped) and
     (LCSr.CurrentStatus!=kStatusStarting) and
     (LCSr.CurrentStatus!=kStatusConfigInError)) then begin
    LogText(0,"UpdateServerStatus: pidfile missing (" & LCSr.UUID & ")");
    LCSr.CurrentStatus = kStatusConfigInError;
    LCSr.CurrentSubStatus = kSubStatusNone;
    LCSr.StatusText = "Pidfile missing";
    LCSr.MyStandardStatusCode = 10026;
    LCSr.MyStandardStatusStr = "";
    goto LUpdateServerStatus;
  end;
  
  if ((pid_is_runningf==false) and (hdb_lockedf==true)) then begin
    switch (LCSr.CurrentStatus) begin
      case kStatusConfigInError:
      case kStatusStarting:
      otherwise
        LogText(0,"UpdateServerStatus: pid missing, but HDB locked");
        LCSr.CurrentStatus = kStatusConfigInError;
        LCSr.CurrentSubStatus = kSubStatusNone;
        LCSr.StatusText = "Process ID missing, but HDB locked";
        LCSr.MyStandardStatusCode = 10027;
        LCSr.MyStandardStatusStr = "";
    end;
    goto LUpdateServerStatus;
  end else begin
    if (LCSr.CurrentStatus==kStatusImportingBackup) then begin
      goto LUpdateServerStatus;
    end;
    if (LCSr.CurrentStatus==kStatusExportingDatabase) then begin
      goto LUpdateServerStatus;
    end;
    if (LCSr.CurrentStatus==kStatusExportingCompany) then begin
      goto LUpdateServerStatus;
    end;
    if (LCSr.CurrentStatus==kStatusExportingRegister) then begin
      goto LUpdateServerStatus;
    end;
  end;

  if ((pid_is_runningf==false) and (LCSr.CurrentStatus==kStatusConfigInError)) then begin
    //if (blank(LCSr.StatusText)) then begin
    if (LCSr.MyStandardStatusCode==-1) then begin
      if (IsMinutesPastCurrentTime(LCSr.LastStopDate,LCSr.LastStopTime,60)==true) then begin
        LCSr.CurrentStatus = kStatusStopped;
        LCSr.CurrentSubStatus = kSubStatusNone;
        LCSr.QuickRestarts = 0;
        LCSr.StatusText = "Server in error state for unknown reason, attempting restart";
        LCSr.MyStandardStatusCode = 10028;
        LCSr.MyStandardStatusStr = "";
      end;
    end;
    goto LUpdateServerStatus;
  end;

  switch (LCSr.WantedStatus) begin
    case kWantedStatusUpdateVersion:
      if (LCSr.CurrentStatus!=kStatusConfigInError) then begin
        LCSr.CurrentStatus = kStatusUpdatingVersion;
        LCSr.CurrentSubStatus = kSubStatusBeforeExport;
        LCSr.QuickRestarts = 0;
      end;
    case kWantedStatusRebuildDatabase:
      if (LCSr.CurrentStatus!=kStatusConfigInError) then begin
        LCSr.CurrentStatus = kStatusRebuildingDatabase;
        LCSr.CurrentSubStatus = kSubStatusBeforeExport;
        LCSr.QuickRestarts = 0;
      end;
    case kWantedStatusClearRegister:
      if (LCSr.CurrentStatus!=kStatusConfigInError) then begin
        LCSr.CurrentStatus = kStatusClearingRegister;
        LCSr.CurrentSubStatus = kSubStatusStopForClearRegister;
        LCSr.QuickRestarts = 0;
      end;
/**/
    case kWantedStatusMaintenence:
      LCSr.CurrentStatus = kStatusMaintenance;
    otherwise
      switch (LCSr.CloneFlag) begin
        case kSystemTypeReserve:
          if (IsCloneUpToDate(LCSr)==true) then begin
            LCSr.CurrentStatus = kStatusRunningReserve;
          end else begin
            LCSr.CurrentStatus = kStatusRunningPreparingReserve;
          end;
        case kSystemTypeTest:
          if (IsCloneFinished(LCSr)==true) then begin
            LCSr.CurrentStatus = kStatusRunningTest;
          end else begin
            LCSr.CurrentStatus = kStatusRunningPreparingTest;
          end;
        case kSystemTypeUpdate:
          if (IsCloneUpToDate(LCSr)==true) then begin
            LCSr.CurrentStatus = kStatusRunningUpdate;
          end else begin
            LCSr.CurrentStatus = kStatusRunningPreparingUpdate;
          end;
        otherwise
          if (DirExists(JournalFolder(LCSr))==true) then begin
            LCSr.JournalPresentFlag = 1;
          end else begin
            LCSr.JournalPresentFlag = 0;
          end;
          if (DirExists(HalcustFolder(LCSr))==true) then begin
            LCSr.HalcustPresentFlag = 1;
          end else begin
            LCSr.HalcustPresentFlag = 0;
          end;
          if (DirExists(HalpatchFolder(LCSr))==true) then begin
            LCSr.HalpatchPresentFlag = 1;
          end else begin
            LCSr.HalpatchPresentFlag = 0;
          end;
          if (DirExists(AsteriskFolder(LCSr))==true) then begin
            LCSr.AsteriskFlag = 1;
          end else begin
            LCSr.AsteriskFlag = 0;
          end;
          switch (LCSr.WantedStatus) begin
            case kWantedStatusImportBackup:       LCSr.CurrentStatus = kStatusImportingBackup;
            case kWantedStatusImportBackupAndRun: LCSr.CurrentStatus = kStatusImportingBackup;
            case kWantedStatusResetToBackup:      LCSr.CurrentStatus = kStatusImportingBackup;
            case kWantedStatusExportCompany:      LCSr.CurrentStatus = kStatusExportingCompany;
            case kWantedStatusExportRegister:     LCSr.CurrentStatus = kStatusExportingRegister;
            case kWantedStatusExportDatabase:     LCSr.CurrentStatus = kStatusExportingDatabase;
            case kWantedStatusClearRegister:      LCSr.CurrentStatus = kStatusClearingRegister; LCSr.CurrentSubStatus = kSubStatusClearingRegister;
            otherwise
              LCSr.CurrentStatus = kStatusRunning;
          end;
      end;
      if (FileExists(IntentionalStopFile(LCSr))) then begin
        LCSr.CurrentStatus = kStatusRunningPendingStop;
      end;
      LCSr.CurrentSubStatus = kSubStatusNone;
  end;
  if (DateTimeDiff(CurrentDate,CurrentTime,LCSr.LastStartDate,LCSr.LastStartTime)>=2) then begin
    LCSr.QuickRestarts = 0;
  end;

LUpdateServerStatus:;
  if (((LCSr.CurrentStatus==kStatusConfigInError) or
      (LCSr.CurrentStatus==kStatusImportingBackup) or
      (LCSr.CurrentStatus==kStatusExportingCompany) or
      (LCSr.CurrentStatus==kStatusExportingRegister) or
      (LCSr.CurrentStatus==kStatusExportingDatabase) or
      (LCSr.CurrentStatus==kStatusCreated) or
      (LCSr.CurrentStatus==kStatusUpdatingVersion) or
      (LCSr.CurrentStatus==kStatusRebuildingDatabase)) and
      ((LCSr.WantedStatus==kWantedStatusStop) or (LCSr.WantedStatus==kWantedStatusStopAndRefresh) or (LCSr.WantedStatus==kWantedStatusForceStop) or (LCSr.WantedStatus==kWantedStatusRestart))) then begin
    if (hdb_lockedf==true) then begin
      LCSr.StatusText = "HDB locked, waiting for operation to complete";
      LCSr.MyStandardStatusCode = 10029;
    end else begin
      if (!(LCSr.WantedStatus==kWantedStatusRun and LCSr.CurrentStatus==kStatusStarting) and !(LCSr.MyStandardStatusCode==10046)) then begin
        LCSr.StatusText = "";
        LCSr.MyStandardStatusCode = -1;
        LCSr.MyStandardStatusStr = "";
        LCSr.CurrentStatus = kStatusStopped;
        LCSr.CurrentSubStatus = kSubStatusNone;
      end;
    end;
  end;
  
  if (OldLCSr.CurrentStatus!=LCSr.CurrentStatus) then begin
    if (LCSr.CurrentStatus==kStatusStopped) then begin
      if (OldLCSr.CurrentStatus!=kStatusConfigInError) then begin
        if (LCSr.RetainRecordDatesFlag==0) then begin
          LCSr.LastStopDate = CurrentDate;
          LCSr.LastStopTime = CurrentTime;
        end;
      end;
      LCSr.StopAttempts = 0;
    end;
  end;
  
  CreateEnablerActionsForServerIfNeeded(LCSr);
  GenerateSSLCertificatesForServerIfNeeded(LCSr);
  if (ComparePosts(OldLCSr,LCSr)==false) then begin
    RecordUpdate(OldLCSr,LCSr,true);
  end;
  HandleEnablerActionsOnServer(LCSr);

  return;
end;

procedure DoStopExternalProcess(LongInt pid,Boolean forcef)
begin
  if (forcef) then begin
    ForceStopExternalProcess(pid);
  end else begin
    StopExternalProcess(pid);
  end;

  return;
end;

procedure SetBackupOnStopForServer(record LocalCloudServerVc LCSr,Boolean forcef)
begin
  Boolean testf;
  string 255 backup_path;
  date dt;
  time tm;

  if (LCSr.BackupOnStopFlag==1) then begin testf = true; end;
  if (forcef) then begin testf = true; end;

  if (!testf) then begin goto LSetBackupOnStopForServer; end;
  
  if (forcef==false) then begin
    backup_path = LCSr.DataFolder & "/" & LCSr.BackupFolder & "/TB.TXT";
    if (FileExists(backup_path)) then begin
      if (FileChangedDate(backup_path,dt,tm)==true) then begin
        if (dt==CurrentDate) then begin testf = false; end;
      end;
    end;
    backup_path = LCSr.DataFolder & "/" & LCSr.BackupFolder & "/TB";
    backup_path = backup_path & DateToString(CurrentDate,"YYMMDD");
    backup_path = backup_path & ".TXT";
    if (FileExists(backup_path)) then begin testf = false; end;
  end;
  
  if (!testf) then begin goto LSetBackupOnStopForServer; end;

  CreateFolderHierarchy(EnablerActionsFolder(LCSr) & "/");
  CreateFile(EnablerActionsFolder(LCSr) & "/EnBackupOnStop");
  CloseFile;
  
LSetBackupOnStopForServer:;
  return;
end;

function Boolean IsLocalCloudServerCreatingTB(record LocalCloudServerVc LCSr)
begin
  Boolean res;
  string 255 temptbpath;
  date fdt;
  time ftm;

  if (blank(trim(LCSr.DataFolder))) then begin goto LIsLocalCloudServerCreatingTB; end;
  
  temptbpath = LCSr.DataFolder & "/" & LCSr.BackupFolder & "/.TB.TXT";
  if (FileExists(temptbpath)) then begin
    if (FileChangedDate(temptbpath,fdt,ftm)==true) then begin
      if (DateDiff(CurrentDate,fdt)<2) then begin
        res = true;
      end;
    end;
  end;

  
LIsLocalCloudServerCreatingTB:;
  IsLocalCloudServerCreatingTB = res;
  return;
end;

global
updating function Boolean TestIfPIDIsCorrect(LongInt pid,record LocalCloudServerVc LCSr)
begin
  Boolean res;
  string 255 pid_file,test_file;
  
  pid_file = PidFile(LCSr);
  if (FileExists(pid_file)) then begin
    test_file = Left(pid_file,len(pid_file)-3) & LCSr.UUID;
    WriteStringToFile("",test_file,0);
    if (FileExists("/proc/" & pid & "/cwd/" & BaseName(test_file))) then begin
      res = true;
    end;
    Delete_file(test_file);
  end;
  
  TestIfPIDIsCorrect = res;
  return;
end;

updating
procedure StopLocalCloudServer(var record LocalCloudServerVc LCSr,Boolean forcef)
begin
  LongInt pid;
  record LocalCloudServerVc OldLCSr;
  Boolean testf;
  
  pid = ReadLongFromFile(PidFile(LCSr));
  if (pid<=0) then begin goto LStopLocalCloudServer; end;

  if (PidIsRunning(pid)) then begin
    switch (ProgramPlatform) begin
      case kPlatformLinux32:    testf = qupdating.TestIfPIDIsCorrect(pid,LCSr);
      case kPlatformLinux64:    testf = qupdating.TestIfPIDIsCorrect(pid,LCSr);
      case kPlatformLinuxArm64: testf = qupdating.TestIfPIDIsCorrect(pid,LCSr);
      otherwise
        testf = true;
    end;
    
    if (testf) then begin
      DoStopExternalProcess(pid,forcef);
//      LogText(0,"DEBUG Stopping pid " & pid & ", forcef=" & forcef);
//      HalCallStack;
    end else begin
      LogText(0,"Warning: Deleting pid file " & PidFile(LCSr) & ", because the pid " & pid & " is for a different process");
      Delete_file(PidFile(LCSr));
    end;
  end;
  
  ReadFirstMain(LCSr,1,true);
  RecordCopy(OldLCSr,LCSr);

  if (LCSr.StopAttempts<=0) then begin
    LCSr.StopAttempts = 1;
  end else begin
    LCSr.StopAttempts = LCSr.StopAttempts + 1;
  end;
  
  RecordUpdate(OldLCSr,LCSr,true);
  
  if ((forcef==false) and (LCSr.StopAttempts>60)) then begin
    if (!IsLocalCloudServerCreatingTB(LCSr)) then begin
      DoStopExternalProcess(pid,true);
      if (PidIsRunning(pid)==false) then begin
        Delete_file(PidFile(LCSr));
      end;
    end;
  end;
  
LStopLocalCloudServer:;
  return;
end;

updating
procedure StopServerIfNeeded(var record LocalCloudServerVc LCSr,Boolean forcef)
begin
  switch (LCSr.CurrentStatus) begin
    case kStatusConfigInError:
    case kStatusStopped:
    case kStatusRunningPendingStop:
      SetBackupOnStopForServer(LCSr,false);
    case kStatusRunning:
      SetBackupOnStopForServer(LCSr,false);
      StopLocalCloudServer(LCSr,forcef);
    case kStatusStopping:
      if (forcef) then begin
        StopLocalCloudServer(LCSr,forcef);
      end;
    case kStatusStarting:
    otherwise
      StopLocalCloudServer(LCSr,forcef);
  end;
  return;
end;


procedure MoveServerIfNeeded(var record LocalCloudServerVc LCSr)
begin
  return;
end;

procedure CreateServerIfNeeded(var record LocalCloudServerVc LCSr)
begin
  switch (LCSr.CurrentStatus) begin
    case kStatusCreating:
      CreateFolderHierarchy(LCSr.DataFolder);
      if (blank(LCSr.HansaVersion) and nonblank(LCSr.NewHansaVersion)) then begin
        LCSr.HansaVersion = LCSr.NewHansaVersion;
      end;
  end;
  return;
end;

function Boolean ShouldStartDeprecatedVersion(record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  Boolean res;
  record CloudSettingsBlock CSb;

  BlockLoad(CSb);
  if (DirExists(CSb.VersionsFolder & "/" & HVr.Code)) then begin
      HVr.ProgramFolder = CSb.VersionsFolder & "/" & HVr.Code;
    if (!FileExists(VersionExe(HVr,LCSr,false)) or !DirExists(VersionHOB(HVr,LCSr,false))) then begin
      LogText(0,"DoStartServer " & LCSName(LCSr) & " can't start the server because version record is missing and no files exist in version folder " & HVr.Code);
    end else begin
      LogText(0,"DoStartServer " & LCSName(LCSr) & " allowed to start, though version record is missing");
      res = true;
    end;
  end else begin
    LogText(0,"DoStartServer " & LCSName(LCSr) & " can't start the server because version record is missing");
  end;

  ShouldStartDeprecatedVersion = res;
  return;
end;

updating procedure DoStartServer(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr,Integer when)
begin
  string 255 exefil;
  string 255 workdir;
  string 255 hobflr;
  string 255 arglist;
  LongInt procflags;
  record LocalCloudServerVc OldLCSr;
  Integer i,rwcnt;
  row LocalCloudServerVc LCSrw;
  LongInt pos,pos2,version_build;
  string 255 tstr,server,fldr,user;
  Boolean clonef,clonedonef,hdb_existsf;
  Integer idx;
  string 255 hdbbakname,dbname;
  record HansaVersionVc HV2r;
  LongInt rpe;
  Boolean updf;
  ULong64 min_diskfree;
  LongInt freespace,totalspace;
/*
  LongInt svpid;
  string 255 pidfilename;
  Boolean pidfile_existsf,pid_is_runningf;
*/

  if (ReadFirstMain(LCSr,1,true)==false) then begin
    LogText(0,"ERROR: LCSr with uuid " & LCSr.UUID & " not found in database!");
    goto LDoStartServer;
  end;
  
  RecordCopy(OldLCSr,LCSr);

  if (LCSr.BlockStartupOnNodeFlag!=0) then begin
    goto LDoStartServer;
  end;

  if (nonblank(LCSr.HansaVersion)) then begin
    RecordCopy(HV2r,HVr);
    if (ReadFirstMain(HV2r,1,true)==false) then begin
      if (ShouldStartDeprecatedVersion(LCSr,HVr)==false) then begin
        goto LDoStartServer;
      end;
    end else begin
      if (CheckVersion(HVr)==false) then begin
        if (HVr.CurrentState==kHansaVersionStateNotDownloaded or
            HVr.CurrentState==kHansaVersionStateInstalling or
            HVr.CurrentState==kHansaVersionStateUpdating or
            ShouldDownloadVersion(HVr.Code) or
            IsDownloadingVersion(HVr.Code)) then begin
          if (HVr.CurrentState==kHansaVersionStateDeprecated) then begin
            if (ShouldStartDeprecatedVersion(LCSr,HVr)==false) then begin
              goto LDoStartServer;
            end;
            LogText(0,"Version " & HVr.Code & " is in state " & StringFromSet(574,HVr.CurrentState));
          end else begin
            goto LDoStartServer;
          end;
        end;
      end;
    end;
  end;

  procflags = 0;
  exefil = VersionExe(HVr,LCSr,false);
  hobflr = VersionHOB(HVr,LCSr,false);
  workdir = LCSr.DataFolder;
  
  dbname = HDBFile(LCSr,HVr);
  hdb_existsf = FileExists(dbname);
  if (hdb_existsf) then begin
/* This is way too expensive on the main thread, can take seconds
    pidfilename = PidFile(LCSr);
    pidfile_existsf = FileExists(pidfilename);
    if (pidfile_existsf) then begin
      svpid = ReadLongFromFile(pidfilename);
      pid_is_runningf = PidIsRunning(svpid);
    end;

    if (pid_is_runningf==false) then begin
      RecoverPidFile(LCSr,pidfilename,pid_is_runningf,pidfile_existsf,svpid);
    end;
    if (pid_is_runningf) then begin
      LogText2(0,"DoStartServer: Skipping start of '" & LCSName(LCSr) & "' because it is already running",kVerbosityDebug);
      goto LDoStartServer;
    end;
*/
    if (FileIsLocked(dbname)) then begin
      LogText2(0,"DoStartServer: Skipping start of '" & LCSName(LCSr) & "' because HDB is locked",kVerbosityDebug);
      goto LDoStartServer;
    end;
  end;

  updf = true;
  
/* Not a bad idea, but better to have a proper data recovery feature built. This method confuse customers too much ::lvg220721
  if (FileExists(workdir & "/RawDataEn.TXT")) then begin
    LCSr.CurrentStatus = kStatusConfigInError;
    LCSr.CurrentSubStatus = kSubStatusNone;
    LCSr.StatusText = "System startup disabled because RawDataEn.TXT was found";
    LCSr.MyStandardStatusCode = 10030;
    LCSr.MyStandardStatusStr = "";
    goto LDoStartServer;
  end;

  if (FileExists(workdir & "/rawdata.txt")) then begin
    LCSr.CurrentStatus = kStatusConfigInError;
    LCSr.CurrentSubStatus = kSubStatusNone;
    LCSr.StatusText = "System startup disabled because rawdata.txt was found";
    LCSr.MyStandardStatusCode = 10031;
    LCSr.MyStandardStatusStr = "";
    goto LDoStartServer;
  end;
*/
  if (DirExists(workdir)==false) then begin
    LCSr.CurrentStatus = kStatusConfigInError;
    LCSr.CurrentSubStatus = kSubStatusNone;
    LCSr.StatusText = "System startup disabled because the work directory wasn't found";
    LCSr.MyStandardStatusCode = 10032;
    LCSr.MyStandardStatusStr = "";
    goto LDoStartServer;
  end;

  // /Versions/54071217/HW/hansa-server --workdir /Servers/TEST --hobfolder /Versions/54071217/HW/hob/
  
  arglist = "--workdir \"" & workdir & "\"";
  arglist = arglist &  " --hobfolder \"" & hobflr & "\"";
  
  if ((HVr.Version>=81) and DirExists(workdir & "/halcust")==false and DirExists(workdir & "/halpatch")==false) then begin
    arglist = arglist &  " --ignore-linkcheck";
  end;

  if ((LCSr.WantedStatus!=kWantedStatusImportBackup) and
      (LCSr.WantedStatus!=kWantedStatusImportBackupAndRun) and
      (LCSr.WantedStatus!=kWantedStatusResetToBackup)) then begin
    if (LCSr.DisableHobcheck>0) then begin
      arglist = arglist &  " --disable-hobcheck";
    end;

    if (LCSr.WantedStatus==kWantedStatusMaintenence) then begin
      if (LCSr.MaintPort>0) then begin
        arglist = arglist & " --port " & LCSr.MaintPort;
      end;
    end else begin
      if (LCSr.Port>0) then begin
        arglist = arglist & " --port " & LCSr.Port;
      end;
    end;
    if (LCSr.HTTPPort>0) then begin
      arglist = arglist & " --httpport=" & LCSr.HTTPPort;
    end;
    
    if (LCSr.HTTPSPort>0) then begin
      arglist = arglist & " --httpsport=" & LCSr.HTTPSPort;
    end;
    
    version_build = (HVr.Version * 1000000) + (HVr.SubVersion * 10000) + HVr.RunningBuild;
    if ((LCSr.UUIDLock>0) or (version_build>=85330100)) then begin
      arglist = arglist & " --server-uuid=" & LCSr.UUID;
    end;
    
    if (LCSr.MassiveCacheMB>0) then begin
      arglist = arglist & " --db-cache=" & LCSr.MassiveCacheMB & "M";
    end;

    if (nonblank(LCSr.BackupFolder)) then begin
      arglist = arglist & " --timed-backup-dir=" & LCSr.BackupFolder;
    end;

    if (nonblank(LCSr.BackupTime)) then begin
      arglist = arglist & " --timed-backup-time=" & LCSr.BackupTime;
    end;

    if (nonblank(LCSr.PublicHostName)) then begin
      arglist = arglist & " --public-host-name=" & LCSr.PublicHostName;
    end;

    if ((LCSr.WebClientStartPort>0) and (LCSr.WebClientEndPort>0)) then begin
      arglist = arglist & " --webclientportrange " & LCSr.WebClientStartPort & " " & LCSr.WebClientEndPort;
    end;

    switch (LCSr.LogLevel) begin
      case 0: arglist = arglist & " --verbosity=debug-detailed";
      case 1: arglist = arglist & " --verbosity=debug";
      case 2: arglist = arglist & " --verbosity=verbose";
      case 3: arglist = arglist & " --verbosity=silent";
      otherwise
    end;
    
    switch (LCSr.AllowRunProgram)  begin
      case kRunProgramDefault:
      case kRunProgramAllowed:
      case kRunProgramForbidden: arglist = arglist & " --no-run-program";
    end;

    if (LCSr.ExtraParameters<>"") then begin
      arglist = arglist & " " & LCSr.ExtraParameters;
    end;

    rwcnt = MatRowCnt(LCSr);
    for (i=0;i<rwcnt;i=i+1) begin
      MatRowGet(LCSr,i,LCSrw);
      if ((LCSrw.Item==kManagedServerItemParameters) and (LCSrw.Disabled==0) and
          ((LCSrw.When==when) or (LCSrw.When==kManagedServerWhenAlways) or
          ((LCSr.CloneFlag!=kSystemTypeNormal) and (LCSrw.When==kManagedServerWhenUpdateImports) and !IsCloneFinished(LCSr)))) then begin
        arglist = arglist & " " & LCSrw.Data & " ";
      end;
      if (((LCSrw.Item==kManagedServerItemReserveSystem) or (LCSrw.Item==kManagedServerItemTestSystem) or (LCSrw.Item==kManagedServerItemUpdateSystem)) and
          (LCSrw.Disabled==0) and (clonef==false) and ((LCSrw.When==when) or (LCSrw.When==kManagedServerWhenAlways))) then begin
        clonef = true;
        arglist = arglist & " --enable-cloning " & LCSrw.Data & " ";
      end;
      if ((LCSrw.Item==kManagedServerItemMotherSystem) and (LCSrw.Disabled==0) and (LCSr.CloneFlag!=kSystemTypeNormal) and
          ((LCSrw.When==when) or (LCSrw.When==kManagedServerWhenAlways))) then begin
        pos = 0;
        clonedonef = IsCloneFinished(LCSr);

        if ((LCSr.CloneFlag==kSystemTypeReserve) or (LCSr.CloneFlag==kSystemTypeUpdate)) then begin
          arglist = arglist & " --clone ";
        end;

        if (LCSr.CloneFlag==kSystemTypeTest) then begin
          if (clonedonef==true) then begin goto LDoStartServer_SkipClone; end;

//          tstr = DetermineNextName(HDBFile(LCSr,HVr),false,true);
//          RenameFile(HDBFile(LCSr,HVr),tstr); // Maybe not only for test systems?
//          tstr = DetermineNextName(LCSr.DataFolder & "/cloning.log",false,true);
//          RenameFile(LCSr.DataFolder & "/cloning.log",tstr); // Maybe not only for test systems?

          arglist = arglist & " --finish-clone-when-up-to-date --clone ";
        end;
        GetNextSubstring(LCSrw.Data,pos,",",tstr);
        GetNextSubstring(tstr,pos2,"@",user);
        GetNextSubstring(tstr,pos2,"@",server);
        if (blank(server)) then begin
          server = user;
          user = "";
        end else begin
          user = user & "@";
        end;
        arglist = arglist & server & " ";
        GetNextSubstring(LCSrw.Data,pos,",",tstr);
        arglist = arglist & tstr & " ";
        GetNextSubstring(LCSrw.Data,pos,",",tstr);
        arglist = arglist & tstr & " ";
        GetNextSubstring(LCSrw.Data,pos,",",tstr);
        if (tstr!="0" and nonblank(tstr)) then begin
          GetNextSubstring(LCSrw.Data,pos,",",fldr);
          arglist = arglist & " --clone-attach " & user & server & " " & fldr & " ";
        end else begin
          GetNextSubstring(LCSrw.Data,pos,",",fldr); // Not used
        end;
        GetNextSubstring(LCSrw.Data,pos,",",tstr);
        if (tstr!="0" and nonblank(tstr)) then begin
          arglist = arglist & " --clone-other-files ";
        end;
        GetNextSubstring(LCSrw.Data,pos,",",tstr);
        if (tstr!="3" and nonblank(tstr)) then begin
          arglist = arglist & " --clone-halcust " & user & server & " " & fldr & " ";
          if (tstr=="1") then begin
            arglist = arglist & " --clone-halcust-folder=" & "newver." & LCSr.HansaVersion & "/halcust/ ";
          end;
        end;
        GetNextSubstring(LCSrw.Data,pos,",",tstr);
        if (tstr!="3" and nonblank(tstr)) then begin
          if (tstr=="1") then begin
            arglist = arglist & " --clone-halpatch-folder=" & "newver." & LCSr.HansaVersion & "/halpatch/ ";
          end;
        end;
        GetNextSubstring(LCSrw.Data,pos,",",tstr);
        if (tstr!="0" and tstr!="-1" and nonblank(tstr)) then begin
          arglist = arglist & " --db-cache=" & tstr & "M";
        end;
      end;
    end;

    if (LCSr.CloneFlag==kSystemTypeNormal) then begin
      arglist = arglist & " --stop-cloning ";
    end;
    
    if (LCSr.WantedStatus==kWantedStatusClearRegister) then begin
      if (LCSr.CurrentSubStatus==kSubStatusStopForClearRegisterCompleted) then begin
        if (LCSr.Port>0) then begin
          arglist = arglist & " --port " & LCSr.Port;
        end;
        arglist = arglist & " --i-know-this-is-dangerous --drop-register=" & LCSr.WantedStatusParams;
      end;
    end;

LDoStartServer_SkipClone:;
    if (when==kManagedServerWhenExportingDatabase) then begin
      arglist = arglist & " --backup ";
    end;

    if (LCSr.CoreDump<>0) then begin
      procflags = procflags + kExtProcDumpCore;
    end;
  end;
  
  //arglist = arglist & " --with-controller";

  if ((LCSr.WantedStatus==kWantedStatusImportBackup) or
      (LCSr.WantedStatus==kWantedStatusImportBackupAndRun) or
      (LCSr.WantedStatus==kWantedStatusResetToBackup)) then begin

    if (FileExists(LCSr.DataFolder & "/TBSETUP.TXT")==false) then begin
      LCSr.StatusText = "Waiting for download of backup";
      LCSr.MyStandardStatusCode = 10033;
      LCSr.MyStandardStatusStr = "";
      goto LDoStartServer;
    end;

    if (LCSr.MassiveCacheMB>0) then begin
      arglist = arglist & " --db-cache=" & LCSr.MassiveCacheMB & "M";
    end;

    rwcnt = MatRowCnt(LCSr);
    for (i=0;i<rwcnt;i=i+1) begin
      MatRowGet(LCSr,i,LCSrw);
      if ((LCSrw.Item==kManagedServerItemParameters) and (LCSrw.Disabled==0) and
          ((LCSrw.When==when) or (LCSrw.When==kManagedServerWhenAlways))) then begin
        arglist = arglist & " " & LCSrw.Data & " ";
      end;
    end;

    switch (LCSr.LogLevel) begin
      case 0: arglist = arglist & " --verbosity=debug-detailed";
      case 1: arglist = arglist & " --verbosity=debug";
      case 2: arglist = arglist & " --verbosity=verbose";
      case 3: arglist = arglist & " --verbosity=silent";
      otherwise
    end;
    arglist = arglist & " --exit-after-import TBSETUP.TXT ";
  end;
  
  UpdateLCSEnablers(LCSr,when);

  if ((when==kManagedServerWhenExportingCompany) or
      (when==kManagedServerWhenExportingRegister) or
      (when==kManagedServerWhenUpdateImports)) then begin
    arglist = arglist & " " & LCSr.WantedStatusParams;
  end;

  if (LCSr.WantedStatus==kWantedStatusResetToBackup) then begin
    freespace = GetDiskSpace(LCSr.DataFolder,totalspace);
    min_diskfree = FileSize2(HDBFile(LCSr,HVr));
    min_diskfree = min_diskfree/1024/1024;
    min_diskfree = min_diskfree + (2*1024); // 2Gb margin
    if (freespace<min_diskfree) then begin
      LCSr.StatusText = "Not enough free space to start import, need at least an extra " & FileSizeToString(((min_diskfree-freespace)*1024*1024));
      LCSr.MyStandardStatusCode = 10034;
      LCSr.MyStandardStatusStr = FileSizeToString(((min_diskfree-freespace)*1024*1024));
      goto LDoStartServer;
    end;

    tstr = DetermineNextName(HDBFile(LCSr,HVr),false,true);
    LogText2(0,"Renaming " & HDBFile(LCSr,HVr) & " to " & tstr,kVerbosityDebugDetailed);
    RenameFile(HDBFile(LCSr,HVr),tstr);
    tstr = DetermineNextName(JournalFolder(LCSr),true,true);
    LogText2(0,"Renaming " & JournalFolder(LCSr) & " to " & tstr,kVerbosityDebugDetailed);
    MoveFile("/",JournalFolder(LCSr),tstr);
  end;

  if (LCSr.WantedStatus==kWantedStatusRunUnjournaled) then begin
    arglist = arglist & " --stop-journaling --i-know-this-is-dangerous";
  end;

  LogText2(0,"DoStartServer(): Starting " & exefil & " " & arglist & " ::: in folder " & workdir,kVerbosityDebug);
  rpe = StartExternalProcessAsUser(exefil,arglist,workdir,LCSr.ServerName,procflags,LCSr.OSUser);
  if (rpe==kRunProgramErrorOutOfMemory) then begin
    LogText(0,"FATAL: Restarting node because it has run out of memory");
    QuitApplication(0,false);
    goto LDoStartServer;
  end;

  if (LCSr.RetainRecordDatesFlag==0) then begin
    LCSr.LastStartTime = CurrentTime;
    LCSr.LastStartDate = CurrentDate;
  end;

  if (LCSr.CurrentStatus!=kStatusUpdatingVersion and
      LCSr.CurrentStatus!=kStatusRebuildingDatabase) then begin
    LCSr.CurrentStatus = kStatusStarting;
    goto LDoStartServer;
  end;

LDoStartServer:;
  if (updf) then begin
    if (ComparePosts(OldLCSr,LCSr)==false) then begin
      RecordUpdate(OldLCSr,LCSr,true);
    end;
  end;

  return;
end;

updating procedure DoStopLCS(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  LongInt svpid;
  string 255 pidfilename;
  Boolean pidfile_existsf,pid_is_runningf;

  pidfilename = PidFile(LCSr);
  pidfile_existsf = FileExists(pidfilename);

  if (pidfile_existsf) then begin
    svpid = ReadLongFromFile(pidfilename);
    pid_is_runningf = PidIsRunning(svpid);
  end;
/* This is way too expensive on the main thread, can take seconds
  if (pid_is_runningf==false) then begin
    RecoverPidFile(LCSr,pidfilename,pid_is_runningf,pidfile_existsf,svpid); // blocks main thread for too long
  end;
*/
  if (pid_is_runningf) then begin
    StopExternalProcess(ReadLongFromFile(pidfilename));
  end;
  return;
end;

function string 255 GetDatabaseStatus(string workdir)
begin
  string 255 res;

//  while (IncreaseVmLong("importing",1)==false) begin
//    MilliSleep(200);
//  end;
//  OpenFile(workdir & "/DatabaseStatus.txt");
//  stattext = ImportField;
//  CloseFile;
//  ChangeVmLong("importing",-1);

  res = ReadStringFromFile(workdir & "/DatabaseStatus.txt");
  GetDatabaseStatus = res;
  return;
end;

updating procedure DoUpdateBeforeExportIfNeeded(var record LocalCloudServerVc LCSr)
begin
  string 255 stattext,workdir;

  if (LCSr.DBStatusUpdateType==kDBStatusUpdateAutomatic) then begin
    workdir = LCSr.DataFolder;
    if (FileExists(workdir & "/DatabaseStatus.txt")) then begin
      stattext = GetDatabaseStatus(workdir);
      LCSr.DBStatusBeforeUpdate = stattext;
    end;
  end;

  return;
end;

updating procedure DoUpdateExportIfNeeded(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  string 255 exefil,workdir,hobflr;
  string 255 arglist,tstr;
  LongInt procflags;
  string 255 tbname,bktbname,bkfldr;
  Integer i,rwcnt;
  row LocalCloudServerVc LCSrw;
  string 255 pid_file;
  LongInt lpid;
  Boolean foundf,backupfoundf;
  ULong64 min_diskfree;
  LongInt freespace,totalspace;
  date pid_dt;
  time pid_tm;

  if (LCSr.CurrentSubStatus==kSubStatusExportingCompleted) then begin
    goto LDoUpdateExportIfNeeded;
  end;

  switch (LCSr.CurrentStatus) begin
    case kStatusUpdatingVersion:    tbname = "LCSUPDATE.TXT";
    case kStatusRebuildingDatabase: tbname = "LCSEXPIMP.TXT";
  end;

  if (LCSr.CurrentSubStatus==kSubStatusExporting) then begin
    backupfoundf = FileExists(LCSr.DataFolder & "/" & tbname);
    foundf = ReadFirstMain(HVr,1,true);
    if (foundf and (HVr.Version>0) and (HVr.Version<72)) then begin
      if (!backupfoundf and (HVr.Version>0) and (HVr.Version<71)) then begin
        tstr = "/TB";
        tstr = tstr & DateToString(CurrentDate,"YYMMDD");
        tstr = tstr & ".TXT";
        backupfoundf = FileExists(LCSr.DataFolder & tstr);
        if (!backupfoundf) then begin
          tstr = "/Backup/TB";
          tstr = tstr & DateToString(CurrentDate,"YYMMDD");
          tstr = tstr & ".TXT";
          backupfoundf = FileExists(LCSr.DataFolder & tstr);
        end;
      end;
    end else begin
      if (foundf==false) then begin
        HVr.Code = LCSr.HansaVersion;
      end;
    end;

    //## move to own function, check progress exported during backup instead
    if (backupfoundf==true) then begin
      pid_file = PidFile(LCSr);
      if (FileExists(pid_file)==false) then begin
        if (nonblank(tstr)) then begin
          CopyFile(LCSr.DataFolder & tstr,LCSr.DataFolder & "/" & tbname);
        end;
        LCSr.CurrentSubStatus = kSubStatusExportingCompleted;
      end else begin
        lpid = ReadLongFromFile(pid_file);
        if (PidIsRunning(lpid)==false) then begin
// Check core files, check if export was successful
          if (nonblank(tstr)) then begin
            CopyFile(tstr,LCSr.DataFolder & "/" & tbname);
          end;
          Delete_File(pid_file);
          if (LCSr.ExecutableType==kExecutableTypeSlave or LCSr.ExecutableType==kExecutableTypeSlaveDebug or LCSr.ExecutableType==kExecutableTypeSlaveOptimizedDebug) then begin // ugly, need to fix slave deleting pidfile on exit
            LCSr.CurrentSubStatus = kSubStatusExportingCompleted;
          end else begin
            LCSr.CurrentStatus = kStatusConfigInError;
            LCSr.CurrentSubStatus = kSubStatusNone;
            LCSr.StatusText = "Export failed, check log";
            LCSr.MyStandardStatusCode = 10035;
            LCSr.MyStandardStatusStr = "";
          end;
        end;
      end;
      goto LDoUpdateExportIfNeeded;
    end else begin
      pid_file = PidFile(LCSr);
      if (FileExists(pid_file)) then begin
        lpid = ReadLongFromFile(pid_file);
        if (PidIsRunning(lpid)) then begin
          if (FileChangedDate(pid_file,pid_dt,pid_tm)) then begin
            if (IsMinutesPastCurrentTime(pid_dt,pid_tm,21)) then begin
              ForceStopExternalProcess(lpid);
              Delete_file(pid_file);
            end;
            if (IsMinutesPastCurrentTime(pid_dt,pid_tm,20)) then begin // rebuilding index on startup can take a really long time...
              StopExternalProcess(lpid);
              LCSr.CurrentStatus = kStatusConfigInError;
              LCSr.CurrentSubStatus = kSubStatusNone;
              LCSr.StatusText = "Export failed, check log";
              LCSr.MyStandardStatusCode = 10042;
              LCSr.MyStandardStatusStr = "";
            end;
          end;
          goto LDoUpdateExportIfNeeded;
        end;
      end;
    end;
    
    if (DateTimeDiffInSeconds(LCSr.LastStartDate,LCSr.LastStartTime,CurrentDate,CurrentTime)<10) then begin
      goto LDoUpdateExportIfNeeded;
    end;
    
    LogText(0,"DoUpdateExportIfNeeded() retrying to start command server '" & LCSName(LCSr) & "'");
  end;
  
  procflags = 0;
  exefil = VersionExe(HVr,LCSr,false);
  hobflr = VersionHOB(HVr,LCSr,false);
  workdir = LCSr.DataFolder;
  if ((left(workdir,1)!="/") and (left(workdir,1)!="\\") and (mid(workdir,1,2)!=":\\")) then begin
    workdir = ProgramFolder & "/" & workdir;
  end;

  switch (LCSr.CurrentStatus) begin
    case kStatusUpdatingVersion:
      bkfldr = workdir & "/oldver." & LCSr.HansaVersion;  //## should have timestamp
      tbname = workdir & "/LCSUPDATE.TXT";
      bktbname = bkfldr & "/LCSUPDATE.TXT";
      CreateFolderHierarchy(bkfldr & "/");
      Delete_File(bktbname);
      RenameFile(tbname,bktbname);
    case kStatusRebuildingDatabase:
      tbname = workdir & "/LCSEXPIMP.TXT";
      if (FileExists(tbname)) then begin
        bktbname = DetermineNextName(tbname,false,true);
        RenameFile(tbname,bktbname);
      end;
  end;
  
  freespace = GetDiskSpace(LCSr.DataFolder,totalspace);
  min_diskfree = FileSize2(HDBFile(LCSr,HVr));
  min_diskfree = min_diskfree/1024/1024;
  min_diskfree = min_diskfree + (2*1024); // 2Gb margin
  if (freespace<min_diskfree) then begin
    LCSr.StatusText = "Not enough free space to start export, need at least an extra " & FileSizeToString(((min_diskfree-freespace)*1024*1024));
    LCSr.MyStandardStatusCode = 10036;
    LCSr.MyStandardStatusStr = FileSizeToString(((min_diskfree-freespace)*1024*1024));
    goto LDoUpdateExportIfNeeded;
  end;

  arglist = "--workdir \"" & workdir & "\"";
  arglist = arglist &  " --hobfolder \"" & hobflr & "\"";
  arglist = arglist &  " --disable-sip";
  arglist = arglist &  " --backup ";
  arglist = arglist &  " --backup-file=\"" & tbname & "\"";
  if ((HVr.Version<54) and (left(HVr.Code,3)=="HW_")) then begin
    // Override for old versions that doesn't work well with exe/hob in other folder than HDB
    CopyFile(exefil,LCSr.DataFolder & "/" & BaseName(exefil));
    CreateFolderHierarchy(LCSr.DataFolder & "/hob/");
    CopyFolder(hobflr,LCSr.DataFolder & "/hob/");
    exefil = LCSr.DataFolder & "/" & BaseName(exefil);
    arglist = "--workdir \"" & workdir & "\"";
    arglist = arglist &  " --backup ";
    arglist = arglist &  " --backup-file=\"" & tbname & "\"";
  end;

  switch (LCSr.LogLevel) begin
    case 0: arglist = arglist & " --verbosity=debug-detailed";
    case 1: arglist = arglist & " --verbosity=debug";
    case 2: arglist = arglist & " --verbosity=verbose";
    case 3: arglist = arglist & " --verbosity=silent";
    otherwise
  end;

  if (LCSr.CurrentStatus==kStatusUpdatingVersion) then begin
    rwcnt = MatRowCnt(LCSr);
    for (i=0;i<rwcnt;i=i+1) begin
      MatRowGet(LCSr,i,LCSrw);
      if ((LCSrw.Item==kManagedServerItemParameters) and (LCSrw.Disabled==0) and
          (LCSrw.When==kManagedServerWhenUpdateExports)) then begin
        arglist = arglist & " " & LCSrw.Data & " ";
      end;
    end;
    UpdateLCSEnablers(LCSr,kManagedServerWhenUpdateExports);
  end;
  
  if (LCSr.CoreDump<>0) then begin
    procflags = procflags + kExtProcDumpCore;
  end;

  LogText2(0,"DoUpdateExportIfNeeded() trying to start server '" & LCSName(LCSr) & "' with command '" & exefil & "' with arguments '" & arglist & "'",kVerbosityDebugDetailed);
  StartExternalProcessAsUser(exefil,arglist,workdir,LCSr.ServerName,procflags,LCSr.OSUser);
  
  LCSr.CurrentSubStatus = kSubStatusExporting;
  if (LCSr.RetainRecordDatesFlag==0) then begin
    LCSr.LastStartTime = CurrentTime;
    LCSr.LastStartDate = CurrentDate;
  end;
  
LDoUpdateExportIfNeeded:;
  return;
end;

updating procedure DoUpdateAfterExportIfNeeded(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  string 255 curname,bakname,newname,workdir,bkfldr,newfldr;
  record InternetEnablerBlock IEb;
  record CYBlock CYb;
  Boolean foundf,oldwrwi;
  
  if (LCSr.CurrentSubStatus==kSubStatusAfterExport) then begin
    goto LDoUpdateAfterExportIfNeeded;
  end;

  workdir = LCSr.DataFolder;

  bkfldr = workdir & "/oldver." & LCSr.HansaVersion;  //## should have timestamp
  newfldr = workdir & "/newver." & LCSr.NewHansaVersion;
  curname = HDBFile2(LCSr);//workdir & "/" & DatabaseName(HVr.ProgramType);
  bakname = bkfldr & "/" & DatabaseName(HVr.ProgramType);

  CreateFolderHierarchy(bkfldr & "/");
  Delete_File(bakname);
  RenameFile(curname,bakname);

  curname = workdir & "/webclient";
  bakname = bkfldr & "/webclient";
  DeleteFolder(bakname);
  RenameFile(curname,bakname);

  curname = workdir & "/hob";
  bakname = bkfldr & "/hob";
  DeleteFolder(bakname);
  RenameFile(curname,bakname);

  curname = workdir & "/updateclients";
  bakname = bkfldr & "/updateclients";
  DeleteFolder(bakname);
  RenameFile(curname,bakname);

  curname = workdir & "/journal";
  bakname = bkfldr & "/journal";
  DeleteFolder(bakname);
  RenameFile(curname,bakname);

  curname = workdir & "/EmailGateway";
  bakname = bkfldr & "/EmailGateway";
  DeleteFolder(bakname);
  RenameFile(curname,bakname);

  curname = workdir & "/halcust";
  bakname = bkfldr & "/halcust";
  newname = newfldr & "/halcust";
  switch (LCSr.HalcustUpdateRule) begin
    case kHalUpdateRuleUseUpdated:
      if (DirExists(bakname)) then begin
        DeleteFolder(bakname);
      end;
      RenameFile(curname,bakname);

      if (DirExists(newname)) then begin
        CopyFolder(newname,curname);
      end else begin
        //error? or pre-checks only?
      end;
    case kHalUpdateRuleDoNotUse:
      if (DirExists(bakname)) then begin
        DeleteFolder(bakname);
      end;
      RenameFile(curname,bakname);
  end;
  
  curname = workdir & "/halpatch";
  bakname = bkfldr & "/halpatch";
  newname = newfldr & "/halpatch";
  switch (LCSr.HalpatchUpdateRule) begin
    case kHalUpdateRuleUseUpdated:
      if (DirExists(bakname)) then begin
        DeleteFolder(bakname);
      end;
      RenameFile(curname,bakname);
      if (DirExists(newname)) then begin
        CopyFolder(newname,curname);
      end else begin
        //error? or pre-checks only?
      end;
    case kHalUpdateRuleDoNotUse:
      if (DirExists(bakname)) then begin
        DeleteFolder(bakname);
      end;
      RenameFile(curname,bakname);
  end;

  if (LCSr.MigrationFlag==1) then begin
    if (FileExists(workdir & "/TBSETUP.TXT")) then begin
      while (IncreaseVmLong("importing",1)==false) begin
        MilliSleep(200);
      end;
      oldwrwi = SetWebRequestsWhileImporting(true);
      ReadCompanyInfoBlocksFromTB(workdir & "/TBSETUP.TXT",IEb,CYb);
      SetWebRequestsWhileImporting(oldwrwi);
      ChangeVmLong("importing",-1);
      foundf = true;
    end else begin
      if (FileExists(workdir & "/LCSUPDATE.TXT")) then begin
        while (IncreaseVmLong("importing",1)==false) begin
          MilliSleep(200);
        end;
        oldwrwi = SetWebRequestsWhileImporting(true);
        ReadCompanyInfoBlocksFromTB(workdir & "/LCSUPDATE.TXT",IEb,CYb);
        SetWebRequestsWhileImporting(oldwrwi);
        ChangeVmLong("importing",-1);
        foundf = true;
      end;
    end;
    if (foundf) then begin
      LCSr.CUCode = IEb.CustomerCode;
      LCSr.Contract = IEb.Contract;
      LCSr.Name = CYb.CompName;
      LCSr.OrgNr = CYb.OrgNr;
      LCSr.VATNr = CYb.VATNr;
      LCSr.OrgNr2 = CYb.OrgNr2;
      LCSr.HMCUCode = IEb.CustomerCode;
      LCSr.HMRegInCountry = IEb.RegInCountry;
      if (LCSr.ServerName=="hansa-migratedserver" and nonblank(LCSr.CUCode)) then begin
        LCSr.ServerName = "hansa-migratedserver-" & LCSr.CUCode;
      end;
      LCSr.MigrationFlag = 0;
    end;
  end;

  LCSr.CurrentSubStatus = kSubStatusAfterExport;

LDoUpdateAfterExportIfNeeded:;
  return;
end;


updating procedure DoRebuildDatabaseAfterExportIfNeeded(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  string 255 curname,bakname;

  if (LCSr.CurrentSubStatus==kSubStatusAfterExport) then begin
    goto LDoRebuildDatabaseAfterExportIfNeeded;
  end;

  curname = HDBFile2(LCSr);
  bakname = DetermineNextName(curname,false,true);
  RenameFile(curname,bakname);

  LCSr.CurrentSubStatus = kSubStatusAfterExport;

LDoRebuildDatabaseAfterExportIfNeeded:;
  return;
end;

updating procedure DoUpdateImportIfNeeded(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  string 255 exefil,workdir,hobflr;
  string 255 arglist,dbname;
  LongInt procflags,svpid;
  record HansaVersionVc HV2r;
  Integer i,rwcnt;
  row LocalCloudServerVc LCSrw;
  string 255 tbname,faildbname;
  Boolean hdb_existsf,hdb_lockedf,pidfile_existsf,pid_is_runningf;
  date db_dt,tb_dt;
  time db_tm,tb_tm;
  val tb_fsz,db_fsz;
  
  if (LCSr.CurrentSubStatus==kSubStatusImportingCompleted) then begin
    goto LDoUpdateImportIfNeeded;
  end;
  switch (LCSr.CurrentStatus) begin
    case kStatusUpdatingVersion: tbname = "LCSUPDATE.TXT";
    case kStatusRebuildingDatabase: tbname = "LCSEXPIMP.TXT";
  end;
  if (LCSr.CurrentSubStatus==kSubStatusImporting) then begin
    //## move to own function, check progress exported during backup instead
    if (FileExists(LCSr.DataFolder & "/" & tbname)==true) then begin
      GetVersion(LCSr.HansaVersion,HV2r)
      dbname = HDBFile(LCSr,HV2r);
      hdb_existsf = FileExists(dbname);
      if (hdb_existsf) then begin
        hdb_lockedf = FileIsLocked(dbname);
      end;
      pidfile_existsf = FileExists(PidFile(LCSr));
      if (pidfile_existsf) then begin
        svpid = ReadLongFromFile(PidFile(LCSr));
        pid_is_runningf = PidIsRunning(svpid);
      end;

      if (pidfile_existsf==false) then begin
        LCSr.CurrentSubStatus = kSubStatusImportingCompleted;
      end else begin
        if (hdb_existsf and !hdb_lockedf) then begin
          if (FileChangedDate(dbname,db_dt,db_tm) and FileChangedDate(LCSr.DataFolder & "/" & tbname,tb_dt,tb_tm)) then begin
            if (DateTimeDiff(tb_dt,tb_tm,db_dt,db_tm)<=0) then begin
              // Sanity check
              tb_fsz = FileSize2(LCSr.DataFolder & "/" & tbname);
              db_fsz = FileSize2(dbname);
              if (tb_fsz>db_fsz) then begin
                faildbname = "HANSA.HDB.TBIMPFAILED-" & DateToString(CurrentDate,"YYYYMMDD");
                if (FileExists(faildbname)) then begin
                  // Fail permanently
                end else begin
                  RenameFile(dbname,faildbname);
                  goto LDoUpdateImportIfNeeded_import;
                end;
              end;
              LCSr.CurrentSubStatus = kSubStatusImportingCompleted;
            end else begin
              // The TB is newer than the HDB, we could move the HDB away and retry
              faildbname = "HANSA.HDB.TBIMPFAILED-" & DateToString(CurrentDate,"YYYYMMDD");
              if (FileExists(faildbname)) then begin
                // Fail permanently
              end else begin
                RenameFile(dbname,faildbname);
                goto LDoUpdateImportIfNeeded_import;
              end;
            end;
          end;
        end;
      end;
    end;
    goto LDoUpdateImportIfNeeded;
  end;
  
LDoUpdateImportIfNeeded_import:;
  switch (LCSr.CurrentStatus) begin
    case kStatusUpdatingVersion:
      if (GetVersion(LCSr.NewHansaVersion,HV2r)==false) then begin
        goto LDoUpdateImportIfNeeded;
      end;
    case kStatusRebuildingDatabase:
      RecordCopy(HV2r,HVr);
  end;

  procflags = 0;
  switch (LCSr.CurrentStatus) begin
    case kStatusRebuildingDatabase:
      exefil = VersionExe(HV2r,LCSr,false);
      hobflr = VersionHOB(HV2r,LCSr,false);
    otherwise
      exefil = VersionExe(HV2r,LCSr,true);
      hobflr = VersionHOB(HV2r,LCSr,true);
  end;

  workdir = LCSr.DataFolder;
  
  arglist = "--workdir \"" & workdir & "\"";
  arglist = arglist & " --hobfolder \"" & hobflr & "\"";
  arglist = arglist & " --exit-after-import";
  arglist = arglist & " --disable-sip";

  if (LCSr.CurrentStatus==kStatusUpdatingVersion) then begin
    rwcnt = MatRowCnt(LCSr);
    for (i=0;i<rwcnt;i=i+1) begin
      MatRowGet(LCSr,i,LCSrw);
      if ((LCSrw.Item==kManagedServerItemParameters) and (LCSrw.Disabled==0) and
          (LCSrw.When==kManagedServerWhenUpdateImports)) then begin
        arglist = arglist & " " & LCSrw.Data & " ";
      end;
    end;
  end;

  if (LCSr.CoreDump<>0) then begin
    procflags = procflags + kExtProcDumpCore;
  end;

  arglist = arglist & " " & LCSr.WantedStatusParams;
  arglist = arglist & " " & tbname;

  if (LCSr.CurrentStatus==kStatusUpdatingVersion) then begin
    UpdateLCSEnablers(LCSr,kManagedServerWhenUpdateImports);
  end;
  StartExternalProcessAsUser(exefil,arglist,workdir,LCSr.ServerName,procflags,LCSr.OSUser);
  
  LCSr.CurrentSubStatus = kSubStatusImporting;
  if (LCSr.RetainRecordDatesFlag==0) then begin
    LCSr.LastStartTime = CurrentTime;
    LCSr.LastStartDate = CurrentDate;
  end;
  
LDoUpdateImportIfNeeded:;
  return;
end;

updating procedure DoUpdateAfterImportIfNeeded(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  string 255 curname,bakname,newname,workdir,bkfldr,newfldr;
  record HansaVersionVc HV2r;

  if (LCSr.CurrentSubStatus==kSubStatusAfterImport) then begin
    goto LDoUpdateAfterImportIfNeeded;
  end;

  if (LCSr.CurrentStatus==kStatusUpdatingVersion) then begin
    if (GetVersion(LCSr.NewHansaVersion,HV2r)==false) then begin
      goto LDoUpdateAfterImportIfNeeded;
    end;

    workdir = LCSr.DataFolder;
    bkfldr = workdir & "/oldver." & LCSr.HansaVersion;  //## should have timestamp
    newfldr = workdir & "/newver." & LCSr.NewHansaVersion;
    curname = workdir & "/updateclients";
    bakname = bkfldr & "/updateclients";
    newname = newfldr & "/updateclients";

    CreateFolderHierarchy(bkfldr & "/");
    if (DirExists(bakname)) then begin
      DeleteFolder(bakname);
    end;
    RenameFile(curname,bakname);
    if (DirExists(newname)) then begin
      CopyFolder(newname,curname);
    end;

    LCSr.OldHansaVersion = LCSr.HansaVersion;
    LCSr.HansaVersion = LCSr.NewHansaVersion;
    LCSr.NewHansaVersion = "";
  end;
    
  LCSr.CurrentSubStatus = kSubStatusAfterImport;

  //Set Database Status if needed
  if (LCSr.DBStatusUpdateType==kDBStatusUpdateAutomatic and nonblank(LCSr.DBStatusBeforeUpdate)) then begin
    CreateFolderHierarchy(EnablerActionsFolder(LCSr) & "/");
    WriteStringToFile(LCSr.DBStatusBeforeUpdate,EnablerActionsFolder(LCSr) & "/EnSetDBStatus",kDBStatusUnknown);
  end;

LDoUpdateAfterImportIfNeeded:;
  return;
end;


updating procedure DoUpdateSystemCopyIfNeeded(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr,LongInt when)
begin
  Integer i,rwcnt;
  record LocalCloudServerVc OldLCS2r;
  record LocalCloudServerVc LCS2r;
  row LocalCloudServerVc LCSrw;
  string 255 script,hdbcopyscript,rmscript,syncscript;
  string 255 lockfile,donefile,dbname;
  LongInt lpid;
  Boolean foundf,completedf;

  dbname = DatabaseName(HVr.ProgramType);

  if (LCSr.CurrentSubStatus==kSubStatusSystemCopyBeforeUpdateCompleted) then begin
    goto LDoUpdateAfterSystemCopyIfNeeded;
  end;
  if (LCSr.CurrentSubStatus==kSubStatusSystemCopyDuringUpdateCompleted) then begin
    goto LDoUpdateAfterSystemCopyIfNeeded;
  end;

  completedf = true;

  switch (when) begin
    case kManagedServerWhenUpdateBegins:  lockfile = LCSr.DataFolder & "/CCSystemCopyUB";
    case kManagedServerWhenUpdating:      lockfile = LCSr.DataFolder & "/CCSystemCopyU";
  end;
  donefile = lockfile & "Completed";

  if (FileExists(lockfile)) then begin
    lpid = ReadLongFromFile(lockfile);
    if (PidIsRunning(lpid)) then begin
      completedf = false;
      goto LDoUpdateAfterSystemCopyIfNeeded;
    end else begin
      Delete_File(lockfile);
      if (FileExists(donefile)) then begin
        Delete_File(donefile);
        switch (when) begin
          case kManagedServerWhenUpdateBegins:  LCSr.CurrentSubStatus = kSubStatusSystemCopyBeforeUpdateCompleted;
          case kManagedServerWhenUpdating:      LCSr.CurrentSubStatus = kSubStatusSystemCopyDuringUpdateCompleted;
        end;
      end else begin
        if (lpid>=1) then begin
          LCSr.CurrentStatus = kStatusConfigInError;
          LCSr.CurrentSubStatus = kSubStatusNone;
          LCSr.StatusText = "System copy before update failed";
          LCSr.MyStandardStatusCode = 10037;
          LCSr.MyStandardStatusStr = "";
          completedf = false;
        end;
      end;
      goto LDoUpdateAfterSystemCopyIfNeeded;
    end;
  end;

  if (FileExists(donefile)) then begin Delete_File(donefile); end;

  script = "touch " & lockfile & "; ionice -c 3 bash -c '( echo -n $$ >>" & lockfile & ";";

  rwcnt = MatRowCnt(LCSr);
  for (i=0;i<rwcnt;i=i+1) begin
    foundf = false;
    MatRowGet(LCSr,i,LCSrw);
    if ((LCSrw.Item==kManagedServerItemSystemCopy) and (LCSrw.Disabled==0)) then begin
      LCS2r.UUID = StringToUUID(LCSrw.ItemName);
      if (ReadFirstMain(LCS2r,1,true)) then begin foundf = true; end;
    end;

    if (foundf==false) then begin goto LDoUpdateAfterSystemCopyIfNeeded_Next; end;

    rmscript = "";
    syncscript = "";
    hdbcopyscript = "";

    if (when==kManagedServerWhenUpdateBegins) then begin
      syncscript = "rsync -avx --delete";
      syncscript = syncscript & " --exclude=\"LCSUPDATE*\" ";
      syncscript = syncscript & " --exclude=\"*.HDB*\" ";
      syncscript = syncscript & " --exclude=\"core*\" ";
      syncscript = syncscript & " --exclude=\"Attach\" ";
      syncscript = syncscript & " --exclude=\"Backup\" ";
      syncscript = syncscript & " --exclude=\"tmp\" ";
      syncscript = syncscript & " --exclude=\"*.pid\" ";
      syncscript = syncscript & " --exclude=\"*.log*\" ";
      syncscript = syncscript & " --exclude=\"*.tmp*\" ";
      syncscript = syncscript & " --exclude=\"journal*\" ";
      syncscript = syncscript & " --exclude=\"old_logs\" ";
      syncscript = syncscript & " --exclude=\"HM20??????\" ";
      syncscript = syncscript & " --exclude=\"EnablerActions\" ";
      syncscript = syncscript & " --exclude=\"TB*TXT*\" ";
      syncscript = syncscript & " --exclude=\"webclients\" ";
      syncscript = syncscript & " --exclude=\"hob*\" ";
      syncscript = syncscript & " --exclude=\"CC*\" ";
      syncscript = syncscript & " --exclude=\"oldver*\" ";
      syncscript = syncscript & " --exclude=\"newver*\" ";
      syncscript = syncscript & " --exclude=\"HREXPORTS*\" ";
      syncscript = syncscript & " --exclude=\"TRADEBOOKS*\" ";
      syncscript = syncscript & " --exclude=\"halcust?*\" ";
      syncscript = syncscript & " --exclude=\"halpatch?*\" ";
      syncscript = syncscript & " --exclude=\"hansa-*\" ";
      syncscript = syncscript & " --exclude=\"nohup.out*\" ";
      syncscript = syncscript & " --exclude=\"*.zip*\" ";
      syncscript = syncscript & " --exclude=\"*.tgz*\" ";
      syncscript = syncscript & " --exclude=\"*.gz\" ";
      syncscript = syncscript & " --exclude=\"downloadupdateclients*\" ";
      syncscript = syncscript & " --exclude=\"amain*\" ";
      syncscript = syncscript & " --exclude=\"appcatalog*\" ";
      syncscript = syncscript & " --exclude=\"webclient?*\" ";
      syncscript = syncscript & " --exclude=\"BI\" ";
      syncscript = syncscript & LCSr.DataFolder & "/ ";
      syncscript = syncscript & LCS2r.DataFolder & "/ ";
      syncscript = syncscript & ";";
      switch (LCSrw.When) begin
        case kManagedServerWhenUpdateBegins:
          rmscript = "rm -rf ";
          rmscript = rmscript & LCS2r.DataFolder & "/*.log ";
          rmscript = rmscript & LCS2r.DataFolder & "/downloadupdateclients ";
          rmscript = rmscript & LCS2r.DataFolder & "/journal ";
          rmscript = rmscript & LCS2r.DataFolder & "/webclients ";
          rmscript = rmscript & ";";
          hdbcopyscript = "mv -f " & LCSr.DataFolder & "/" & dbname & ".COPY " & LCS2r.DataFolder & "/" & dbname & " ;";
        case kManagedServerWhenUpdating:
          rmscript = "rm -rf ";
          rmscript = rmscript & LCS2r.DataFolder & "/" & dbname & ".OLD ";
          rmscript = rmscript & LCS2r.DataFolder & "/journal.old ";
          rmscript = rmscript & LCS2r.DataFolder & "/*.log ";
          rmscript = rmscript & LCS2r.DataFolder & "/downloadupdateclients ";
          rmscript = rmscript & LCS2r.DataFolder & "/webclients ";
          rmscript = rmscript & ";";
          rmscript = rmscript & "mv -f " & LCS2r.DataFolder & "/" & dbname & " " & LCS2r.DataFolder & "/" & dbname & ".OLD ;";
          rmscript = rmscript & "mv -f " & LCS2r.DataFolder & "/journal " & LCS2r.DataFolder & "/journal.old ;";
      end;

      RecordCopy(OldLCS2r,LCS2r);
      LCS2r.HansaVersion = LCSr.HansaVersion;
      RecordUpdate(OldLCS2r,LCS2r,true);
    end;

    if (when==kManagedServerWhenUpdating) then begin
      switch (LCSrw.When) begin
        case kManagedServerWhenUpdateBegins:
        case kManagedServerWhenUpdating:
          hdbcopyscript = "cp -f " & LCSr.DataFolder & "/" & dbname & " " & LCS2r.DataFolder & "/" & dbname & " ;";
      end;

      RecordCopy(OldLCS2r,LCS2r);
      LCS2r.HansaVersion = LCSr.HansaVersion;
      RecordUpdate(OldLCS2r,LCS2r,true);
    end;

    if (when==kManagedServerWhenUpdateEnds) then begin
      RecordCopy(OldLCS2r,LCS2r);
      LCS2r.OldHansaVersion = LCS2r.HansaVersion;
      LCS2r.HansaVersion = LCSr.NewHansaVersion;
      RecordUpdate(OldLCS2r,LCS2r,true);
    end;

    if (nonblank(rmscript) or nonblank(syncscript) or nonblank(hdbcopyscript)) then begin
      completedf = false;
    end;

    script = script & rmscript;
    script = script & syncscript;
    script = script & hdbcopyscript;

LDoUpdateAfterSystemCopyIfNeeded_Next:;
  end;

  script = script & "touch " & donefile & ";";
  script = script & " )' &";

  if (completedf==false) then begin
    RunShellScript(script);
    if (FileExists(lockfile)) then begin
      switch (when) begin
        case kManagedServerWhenUpdateBegins:  LCSr.CurrentSubStatus = kSubStatusSystemCopyBeforeUpdate;
        case kManagedServerWhenUpdating:      LCSr.CurrentSubStatus = kSubStatusSystemCopyDuringUpdate;
      end;
    end else begin
      LogText(0,"System Copy script failed to start");
      LCSr.CurrentStatus = kStatusConfigInError;
      LCSr.CurrentSubStatus = kSubStatusNone;
      LCSr.StatusText = "System copy script failed to start";
      LCSr.MyStandardStatusCode = 10038;
      LCSr.MyStandardStatusStr = "";
    end;
  end else begin
    switch (when) begin
      case kManagedServerWhenUpdateBegins:  LCSr.CurrentSubStatus = kSubStatusSystemCopyBeforeUpdateCompleted;
      case kManagedServerWhenUpdating:      LCSr.CurrentSubStatus = kSubStatusSystemCopyDuringUpdateCompleted;
    end;
  end;
LDoUpdateAfterSystemCopyIfNeeded:;
  return;
end;

updating procedure DoUpdateSetCrontabIfNeeded(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr,LongInt when)
begin
  Integer i,rwcnt;
  row LocalCloudServerVc LCSrw;
  string 255 script;
  string 255 lockfile,donefile;
  LongInt lpid;
  Boolean completedf,enablef;

  if (LCSr.CurrentSubStatus==kSubStatusSetCrontabBeforeUpdateCompleted) then begin
    goto LDoUpdateSetCrontabIfNeeded;
  end;
  if (LCSr.CurrentSubStatus==kSubStatusSetCrontabAfterUpdateCompleted) then begin
    goto LDoUpdateSetCrontabIfNeeded;
  end;

  completedf = true;

  switch (when) begin
    case kManagedServerWhenUpdateBegins: lockfile = LCSr.DataFolder & "/CCSetCrontabUB";
    case kManagedServerWhenUpdateEnds:   lockfile = LCSr.DataFolder & "/CCSetCrontabUE";
  end;
  donefile = lockfile & "Completed";

  if (FileExists(lockfile)) then begin
    lpid = ReadLongFromFile(lockfile);
    if (PidIsRunning(lpid)) then begin
      goto LDoUpdateSetCrontabIfNeeded;
    end else begin
      Delete_File(lockfile);
      if (FileExists(donefile)) then begin
        Delete_File(donefile);
        switch (when) begin
          case kManagedServerWhenUpdateBegins:  LCSr.CurrentSubStatus = kSubStatusSetCrontabBeforeUpdateCompleted;
          case kManagedServerWhenUpdateEnds:    LCSr.CurrentSubStatus = kSubStatusSetCrontabAfterUpdateCompleted;
        end;
      end else begin
        if (lpid>=1) then begin
          LCSr.CurrentStatus = kStatusConfigInError;
          LCSr.CurrentSubStatus = kSubStatusNone;
          LCSr.StatusText = "Set crontab failed";
          LCSr.MyStandardStatusCode = 10039;
          LCSr.MyStandardStatusStr = "";
        end;
      end;
      goto LDoUpdateSetCrontabIfNeeded;
    end;
  end;

  if (FileExists(donefile)) then begin Delete_File(donefile); end;

  script = "touch " & lockfile & "; bash -c '( echo -n $$ >>" & lockfile & ";";
  script = script & "crontab -l |sed \"";

  rwcnt = MatRowCnt(LCSr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(LCSr,i,LCSrw);
    if ((LCSrw.Item==kManagedServerItemCrontabEntry) and (nonblank(LCSrw.Data)) and
        (LCSrw.When==kManagedServerWhenUpdating)) then begin
      enablef = false;
      if (when==kManagedServerWhenUpdateEnds) then begin enablef = true; end;
      if (((LCSrw.Disabled==0) and (enablef==false)) or
          ((LCSrw.Disabled!=0) and (enablef==true))) then begin
        script = script & "s/^#CCDISABLED#\\(.*\\/" & LCSrw.Data & "\\)/\\1/ ;";
      end else begin
        script = script & "s/^#CCDISABLED#\\(.*\\/" & LCSrw.Data & "\\)/\\1/ ;";
        script = script & "s/\\(.*\\/" & LCSrw.Data & "\\)/#CCDISABLED#\\1/ ;";
      end;
      completedf = false;
    end;
  end;

  script = script & "\" |crontab - ;";
  script = script & "touch " & donefile & ";";
  script = script & " )' &";

  if (completedf==false) then begin
    RunShellScript(script);
    if (FileExists(lockfile)) then begin
      switch (when) begin
        case kManagedServerWhenUpdateBegins:  LCSr.CurrentSubStatus = kSubStatusSetCrontabBeforeUpdate;
        case kManagedServerWhenUpdateEnds:    LCSr.CurrentSubStatus = kSubStatusSetCrontabAfterUpdate;
      end;
    end else begin
      LogText(0,"Crontab script failed to start");
      LCSr.CurrentStatus = kStatusConfigInError;
      LCSr.CurrentSubStatus = kSubStatusNone;
      LCSr.StatusText = "Crontab script failed to start";
      LCSr.MyStandardStatusCode = 10040;
      LCSr.MyStandardStatusStr = "";
    end;
  end else begin
    switch (when) begin
      case kManagedServerWhenUpdateBegins:  LCSr.CurrentSubStatus = kSubStatusSetCrontabBeforeUpdateCompleted;
      case kManagedServerWhenUpdateEnds:    LCSr.CurrentSubStatus = kSubStatusSetCrontabAfterUpdateCompleted;
    end;
  end;

LDoUpdateSetCrontabIfNeeded:;
  return;
end;


updating procedure DoUpdateDBCopyBeforeUpdateIfNeeded(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  string 255 dbname,dbcopyname;

  if (LCSr.CurrentSubStatus==kSubStatusDBCopyBeforeUpdateCompleted) then begin
    goto LDoUpdateDBCopyBeforeUpdateIfNeeded;
  end;

  if (LCSr.CurrentSubStatus==kSubStatusDBCopyBeforeUpdate) then begin
    if (FileExists(EnablerActionsFolder(LCSr) & "/EnDoDBCopy")==false) then begin
      LCSr.CurrentSubStatus = kSubStatusDBCopyBeforeUpdateCompleted;
    end;
    goto LDoUpdateDBCopyBeforeUpdateIfNeeded;
  end;

  if (LCSr.CurrentSubStatus!=kSubStatusDBCopyBeforeUpdate) then begin
    dbname = DatabaseName(HVr.ProgramType);
    dbcopyname = dbname & ".COPY";
    if (FileExists(dbcopyname)==false) then begin
      CreateFolderHierarchy(EnablerActionsFolder(LCSr) & "/");
      CreateFile(EnablerActionsFolder(LCSr) & "/EnDoDBCopy");
      CloseFile;
      LCSr.CurrentSubStatus = kSubStatusDBCopyBeforeUpdate;
    end else begin
      LCSr.CurrentSubStatus = kSubStatusDBCopyBeforeUpdateCompleted;
    end;
  end;

LDoUpdateDBCopyBeforeUpdateIfNeeded:;
  return;
end;


updating procedure DoCloudServerVersionUpdate(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  record LocalCloudServerVc OldLCSr;

  RecordCopy(OldLCSr,LCSr);

  switch (LCSr.CurrentSubStatus) begin
    case kSubStatusBeforeExport:
      DoUpdateBeforeExportIfNeeded(LCSr);
  end;

  switch (LCSr.WantedSubStatus) begin
    case kWantedSubStatusBeforeExport:
      //nothing
    case kWantedSubStatusSetCrontabBeforeUpdate:
      DoUpdateSetCrontabIfNeeded(LCSr,HVr,kManagedServerWhenUpdateBegins);
    case kWantedSubStatusDBCopyBeforeUpdate:
      DoUpdateDBCopyBeforeUpdateIfNeeded(LCSr,HVr);
    case kWantedSubStatusSystemCopyBeforeUpdate:
      DoUpdateSystemCopyIfNeeded(LCSr,HVr,kManagedServerWhenUpdateBegins);
    case kWantedSubStatusStopForExport:
      DoStopLCS(LCSr,HVr);
    case kWantedSubStatusStopSlaveSystems:
      if (LCSr.CurrentSubStatus!=kSubStatusStoppingSlaveSystemsCompleted) then begin
        LCSr.CurrentSubStatus = kSubStatusStoppingSlaveSystems;
      end;
    case kWantedSubStatusStartSystemCopiesBeforeExport:
      if (LCSr.CurrentSubStatus!=kSubStatusStartingSystemCopiesBeforeExportCompleted) then begin
        LCSr.CurrentSubStatus = kSubStatusStartingSystemCopiesBeforeExport;
      end;
    case kWantedSubStatusSystemCopyDuringUpdate:
      DoUpdateSystemCopyIfNeeded(LCSr,HVr,kManagedServerWhenUpdating);
    case kWantedSubStatusStartSystemCopiesDuringUpdate:
      if (LCSr.CurrentSubStatus!=kSubStatusStartingSystemCopiesDuringUpdateCompleted) then begin
        LCSr.CurrentSubStatus = kSubStatusStartingSystemCopiesDuringUpdate;
      end;
    case kWantedSubStatusExport:
      DoUpdateExportIfNeeded(LCSr,HVr);
    case kWantedSubStatusAfterExport:
      DoUpdateAfterExportIfNeeded(LCSr,HVr);
    case kWantedSubStatusImport:
      DoUpdateImportIfNeeded(LCSr,HVr);
    case kWantedSubStatusAfterImport:
      DoUpdateAfterImportIfNeeded(LCSr,HVr);
    case kWantedSubStatusStopSystemCopiesDuringUpdate:
      if (LCSr.CurrentSubStatus!=kSubStatusStoppingSystemCopiesDuringUpdateCompleted) then begin
        LCSr.CurrentSubStatus = kSubStatusStoppingSystemCopiesDuringUpdate;
      end;
    case kWantedSubStatusSetCrontabAfterUpdate:
      DoUpdateSetCrontabIfNeeded(LCSr,HVr,kManagedServerWhenUpdateEnds);
  end;

  if (ComparePosts(OldLCSr,LCSr)==false) then begin
    RecordUpdate(OldLCSr,LCSr,true);
  end;

  return;
end;

updating procedure DoCloudServerRebuildDatabase(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  record LocalCloudServerVc OldLCSr;

  RecordCopy(OldLCSr,LCSr);

  switch (LCSr.CurrentSubStatus) begin
    case kSubStatusBeforeExport:
      DoUpdateBeforeExportIfNeeded(LCSr);
  end;

  switch (LCSr.WantedSubStatus) begin
    case kWantedSubStatusBeforeExport:
    case kWantedSubStatusStopForExport:
      DoStopLCS(LCSr,HVr);
    case kWantedSubStatusStopSlaveSystems:
      if (LCSr.CurrentSubStatus!=kSubStatusStoppingSlaveSystemsCompleted) then begin
        LCSr.CurrentSubStatus = kSubStatusStoppingSlaveSystems;
      end;
    case kWantedSubStatusExport:
      DoUpdateExportIfNeeded(LCSr,HVr);
    case kWantedSubStatusAfterExport:
      DoRebuildDatabaseAfterExportIfNeeded(LCSr,HVr);
    case kWantedSubStatusImport:
      DoUpdateImportIfNeeded(LCSr,HVr);
    case kWantedSubStatusAfterImport:
      DoUpdateAfterImportIfNeeded(LCSr,HVr);
  end;

  if (ComparePosts(OldLCSr,LCSr)==false) then begin
    RecordUpdate(OldLCSr,LCSr,true);
  end;

  return;
end;

updating procedure DoCloudServerClearRegister(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  record LocalCloudServerVc OldLCSr;

  RecordCopy(OldLCSr,LCSr);

  switch (LCSr.CurrentSubStatus) begin
    case kSubStatusStopForClearRegister:
      DoStopLCS(LCSr,HVr);
    case kSubStatusStopForClearRegisterCompleted:
      if (nonblank(LCSr.WantedStatusParams)) then begin
        DoStartServer(LCSr,HVr,kManagedServerWhenAlways);
      end;
  end;

  if (ComparePosts(OldLCSr,LCSr)==false) then begin
    RecordUpdate(OldLCSr,LCSr,true);
  end;

  return;
end;

updating procedure StartServerIfNeeded(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  LongInt when;
/* This code make no sense at all, I suspect I commited it my mistake ::lvg240215
  LongInt lpid;
  string 255 pid_file;
  date pid_dt;
  time pid_tm;
*/

  switch (LCSr.CurrentStatus) begin
    case kStatusConfigInError:
      // nothing
    case kStatusCreated:
      when = kManagedServerWhenRunningNormally;
      if (LCSr.WantedStatus==kWantedStatusImportBackup) then begin
        when = kManagedServerWhenRunningNormally; // TODO: add option for importing
      end;
      if (LCSr.WantedStatus==kWantedStatusImportBackupAndRun) then begin
        when = kManagedServerWhenRunningNormally; // TODO: add option for importing
      end;
      if (LCSr.WantedStatus==kWantedStatusResetToBackup) then begin
        when = kManagedServerWhenRunningNormally; // TODO: add option for importing
      end;
      DoStartServer(LCSr,HVr,when);
    case kStatusStopped:
      when = kManagedServerWhenRunningNormally;
      if (LCSr.WantedStatus==kWantedStatusExportDatabase) then begin
        when = kManagedServerWhenExportingDatabase;
      end;
      if (LCSr.WantedStatus==kWantedStatusExportCompany) then begin
        when = kManagedServerWhenExportingCompany;
      end;
      if (LCSr.WantedStatus==kWantedStatusExportRegister) then begin
        when = kManagedServerWhenExportingRegister;
      end;
      DoStartServer(LCSr,HVr,when);
    case kStatusRunning:
      // nothing
    case kStatusStopping:
      StopAlert("Should check if force stop needed to speed up start");
      // if too many force stops have been made, place "config in error"
    case kStatusStarting:
    case kStatusImportingBackup:
      // nothing
    case kStatusMaintenance:
      // nothing
    case kStatusRunningPendingStop:
      // nothing
/* This code make no sense at all, I suspect I commited it my mistake ::lvg240215
    case kStatusExportingDatabase:
      pid_file = PidFile(LCSr);
      if (FileExists(pid_file)) then begin
        lpid = ReadLongFromFile(pid_file);
        if (PidIsRunning(lpid)) then begin
          if (FileChangedDate(pid_file,pid_dt,pid_tm)) then begin
            if (IsMinutesPastCurrentTime(pid_dt,pid_tm,21)) then begin
              ForceStopExternalProcess(lpid);
              Delete_file(pid_file);
            end;
            if (IsMinutesPastCurrentTime(pid_dt,pid_tm,20)) then begin // rebuilding index on startup can take a really long time...
              StopExternalProcess(lpid);
              LCSr.CurrentStatus = kStatusConfigInError;
              LCSr.CurrentSubStatus = kSubStatusNone;
              LCSr.StatusText = "Export during update failed, check log";
              LCSr.MyStandardStatusCode = 10043;
              LCSr.MyStandardStatusStr = "";
            end;
          end;
        end;
      end;
*/
  end;
  return;
end;

updating procedure UpdateVersionIfNeeded(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  switch (LCSr.CurrentStatus) begin
    case kStatusConfigInError:
    case kStatusStopped:
    case kStatusRunning:
    case kStatusStopping:
    case kStatusStarting:
    case kStatusImportingBackup:
    case kStatusUpdatingVersion:
      DoCloudServerVersionUpdate(LCSr,HVr);
    case kStatusMaintenance:
    case kStatusRunningPendingStop:
  end;

  return;
end;

updating procedure RebuildDatabaseIfNeeded(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  switch (LCSr.CurrentStatus) begin
    case kStatusConfigInError:
    case kStatusStopped:
    case kStatusRunning:
    case kStatusStopping:
    case kStatusStarting:
    case kStatusImportingBackup:
    case kStatusRebuildingDatabase:
      DoCloudServerRebuildDatabase(LCSr,HVr);
    case kStatusMaintenance:
    case kStatusRunningPendingStop:
  end;

  return;
end;

updating procedure ClearRegisterIfNeeded(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  switch (LCSr.CurrentStatus) begin
    case kStatusConfigInError:
    case kStatusStopped:
    case kStatusRunning:
    case kStatusStopping:
    case kStatusStarting:
    case kStatusImportingBackup:
    case kStatusRebuildingDatabase:
    case kStatusClearingRegister:
      DoCloudServerClearRegister(LCSr,HVr);
    case kStatusMaintenance:
    case kStatusRunningPendingStop:
  end;

  return;
end;

updating procedure ContinousUpdateVersionIfNeeded(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  record LocalCloudServerVc OldLCSr;

  LogText2(0,"ContinousUpdateVersionIfNeeded LCSr.WantedStatus=" & WantedStatusName(LCSr.WantedStatus) & ", LCSr.WantedSubStatus=" & LCSr.WantedSubStatus & ", LCSr.CurrentSubStatus=" & LCSr.CurrentSubStatus,kVerbosityDebugDetailed);
  switch (LCSr.WantedSubStatus) begin
    case kWantedSubStatusFinishContinousUpdate:
      switch (LCSr.CurrentStatus) begin
        case kStatusRunning:
          if (LCSr.CurrentSubStatus!=kSubStatusStopForContinousUpdate) then begin
            ReadFirstMain(LCSr,1,true);
            RecordCopy(OldLCSr,LCSr);
            LCSr.CurrentSubStatus = kSubStatusStopForContinousUpdate;
            RecordUpdate(OldLCSr,LCSr,true);
            StopServerIfNeeded(LCSr,false);
          end;
        case kStatusStopped:
          if ((LCSr.CurrentSubStatus!=kSubStatusStopForContinousUpdate) and
              (LCSr.CurrentSubStatus!=kSubStatusSwitchToUpdateSystemDB) and
              (LCSr.CurrentSubStatus!=kSubStatusCleanupAfterContinousUpdate) and
              (LCSr.WantedSubStatus!=kWantedSubStatusFinishContinousUpdate) and
              (LCSr.WantedSubStatus!=kWantedSubStatusCancelContinousUpdate)) then begin
            StartServerIfNeeded(LCSr,HVr);
          end;
      end;
  end;

  return;
end;

global
updating procedure ImportKnownSessions(string known_sessions,var array string usrarr,var array string datearr,var array string timearr,var array string evtarr,var array string argarr)
begin
  Boolean moref;
  Boolean oldwrwi;
  Integer obv;

  obv = SetBackupVerbosity(kBackupVerbositySilent);
  oldwrwi = SetWebRequestsWhileImporting(true);
  while (IncreaseVmLong("importing",1)==false) begin
    MilliSleep(200);
  end;
  OpenFile(known_sessions);
  moref = !TestEOF;
  while (moref) begin
    usrarr[usrarr.length] = ImportField;
    datearr[datearr.length] = ImportField;
    timearr[timearr.length] = ImportField;
    evtarr[evtarr.length] = ImportField;
    argarr[argarr.length] = ImportField;
    moref = NextImportLine(true);
  end;
  CloseFile;
  SetWebRequestsWhileImporting(oldwrwi);
  ResetBackupVerbosity(obv);
  ChangeVmLong("importing",-1);
  return;
end;

function Boolean IsMinutesBeforeCurrentTime(date dt,time tm,Integer mins)
begin
  IsMinutesBeforeCurrentTime = IsMinutesPastTime(dt,tm,CurrentDate,CurrentTime,mins);
  return;
end;

global
procedure ActiveServerUsers(record LocalCloudServerVc LCSr,Boolean keepstartupf,var LongInt res)
begin
  LongInt l,lcnt;
  string 255 known_sessions,tstr;
  date last_entry_date;
  time last_entry_time,t2;
  array string 255 userarr,userarr2;
  Integer i;
  Boolean foundf;
  string 255 pidfilename;
  Boolean pidfile_existsf,pid_is_runningf;
  LongInt svpid;
  Boolean useconnectionsf;
  array string 255 usrarr,datearr,timearr,evtarr,argarr,tagsarr;
  vector Boolean foundusersvec,foundconnectionsvec;

  //LogText(0,"ActiveServerUsers: " & LCSr.UUID & " keepstartupf=" & keepstartupf);
  res = 0;
  if (ReadFirstMain(LCSr,1,true)==false) then begin
    goto LActiveServerUsers;
  end;

  if ((LCSr.CurrentStatus!=kStatusRunning) and
      (LCSr.CurrentStatus!=kStatusMaintenance) and
      (LCSr.CurrentStatus!=kStatusRunningPendingStop) and
      (LCSr.CurrentStatus!=kStatusRunningTest) and
      (LCSr.CurrentStatus!=kStatusConfigInError)) then begin
    goto LActiveServerUsers;
  end;

  pidfilename = PidFile(LCSr);
  pidfile_existsf = FileExists(pidfilename);

  if (pidfile_existsf) then begin
    svpid = ReadLongFromFile(pidfilename);
    if (svpid>0) then begin
      pid_is_runningf = PidIsRunning(svpid);
    end;
  end;

  if (pid_is_runningf==false) then begin
    LogText(0,"ActiveServerUsers: ERROR " & LCSr.UUID & " isn't running");
    goto LActiveServerUsers;
  end;

  known_sessions = LCSr.DataFolder & "/known_sessions.dat";

  if (FileExists(known_sessions)==false) then begin
    if (keepstartupf) then begin
      //LogText(0,"ActiveServerUsers: " & LCSr.UUID & " being allowed to start up");
      res = 1; // Let it start once
    end;
    goto LActiveServerUsers;
  end;

  qupdating.ImportKnownSessions(known_sessions,usrarr,datearr,timearr,evtarr,argarr);

  lcnt = usrarr.length;
  if (lcnt<=0) then begin
    if (keepstartupf) then begin
      //LogText(0,"ActiveServerUsers: " & LCSr.UUID & " being allowed to start up");
      res = 1; // Let it start once
    end;
    goto LActiveServerUsers;
  end;
  
  last_entry_date = DateFromString(datearr[lcnt-1],"YYYY-MM-DD");
  last_entry_time = StringToTime(timearr[lcnt-1]);
  t2 = AddMinutes(last_entry_time,5);
  
  if (DateTimeDiff(last_entry_date,last_entry_time,LCSr.LastStartDate,LCSr.LastStartTime)<=0) then begin
    //if (IsMinutesBeforeCurrentTime(LCSr.LastStartDate,LCSr.LastStartTime,300)==false) then begin // why 300 minutes?? lvg210723
    if (IsMinutesPastTime(CurrentDate,CurrentTime,LCSr.LastStartDate,LCSr.LastStartTime,5)==false) then begin
      if (keepstartupf) then begin
        //LogText(0,"ActiveServerUsers: " & LCSr.UUID & " being allowed to start up");
        res = 1; // Let it start once
      end;
      goto LActiveServerUsers;
    end;
  end;

  if (lcnt==1) then begin
    if (IsMinutesPastCurrentTime(last_entry_date,last_entry_time,5)==false) then begin
      if (keepstartupf) then begin
//        LogText(0,"ActiveServerUsers: " & LCSr.UUID & " is idle, waiting " & 5-DateTimeDiff(CurrentDate,CurrentTime,last_entry_date,last_entry_time) & " minutes for a connection");
        res = 1; // Give it 5 minutes to the first connection
      end;
    end;
    goto LActiveServerUsers;
  end;

  if (AddDay(last_entry_date,3)<CurrentDate) then begin
    if (keepstartupf) then begin
      LogText(0,"ActiveServerUsers: " & LCSr.UUID & " got no connections since " & last_entry_date & ", stopping server");
      res = 0; // Stopping after 2-3 days even if there are active users
      goto LActiveServerUsers;
    end;
  end;

  //LogText(0,"ActiveServerUsers: " & LCSr.UUID & " have " & lcnt & " entries in known_sessions.dat");
  for (l=0;l<lcnt;l=l+1) begin
    tstr = evtarr[l];
    //LogText(0,"ActiveServerUsers: " & LCSr.UUID & " evtarr[" & l & "]==" & evtarr[l] & ", argarr[" & l & "]==" & argarr[l]);
    switch (tstr) begin
      case "startup":
      case "login":
        if (useconnectionsf==false) then begin
          tstr = usrarr[l];
          if (foundusersvec[tstr]==false) then begin
            foundusersvec[tstr] = true;
            res = res + 1;
          end;
        end;
      case "logout":
        if (useconnectionsf==false) then begin
          tstr = usrarr[l];
          if (foundusersvec[tstr]==true) then begin
            foundusersvec[tstr] = false;
            res = res - 1;
          end;
        end;
      case "connect":
        tstr = argarr[l];
        if (nonblank(tstr)) then begin
          useconnectionsf = true;
          if (foundconnectionsvec[tstr]==false) then begin
            foundconnectionsvec[tstr] = true;
            res = res + 1;
            //LogText(0,"ActiveServerUsers: " & LCSr.UUID & " got connect (" & res & ")");
          end;
        end;
      case "disconnect":
        tstr = argarr[l];
        if (nonblank(tstr)) then begin
          useconnectionsf = true;
          if (foundconnectionsvec[tstr]==true) then begin
            res = res - 1;
            foundconnectionsvec[tstr] = false;
            //LogText(0,"ActiveServerUsers: " & LCSr.UUID & " got disconnect (" & res & ")");
          end;
        end else begin
          LogText(0,"ActiveServerUsers: " & LCSr.UUID & " ERROR got disconnect with blank argument");
        end;
    end;
  end;

  if (res<0) then begin
    LogText(0,"ActiveServerUsers: " & LCSr.UUID & "ERROR counted to less than zero connections on server");
    res = 0;
  end;

  if (res==0) then begin
    if (!IsMinutesPastCurrentTime(last_entry_date,last_entry_time,5)) then begin
      if (keepstartupf) then begin
        LogText(0,"ActiveServerUsers: " & LCSr.UUID & " waiting 5 minutes for next connection (last was " & last_entry_date & " " & last_entry_time & ")");
        res = 1; // Give it 5 minutes to the next connection
      end;
    end else begin
      LogText(0,"ActiveServerUsers: " & LCSr.UUID & " no active connections for more than 5 minutes, stopping");
    end;
  end else begin
    LogText2(0,"ActiveServerUsers: " & LCSr.UUID & " has " & res & " active connections",kVerbosityDebugDetailed);
  end;

LActiveServerUsers:;
  if (res<0) then begin
    res = 0;
  end;
  return;
end;

global
procedure LastServerActivityDate(record LocalCloudServerVc LCSr,var Date res)
begin
  string 255 known_sessions,tstr;
  array string 255 userarr,userarr2;
  array string 255 usrarr,datearr,timearr,evtarr,argarr,tagsarr;
  Integer lcnt;

  res = "";//set date to blank;
  if (ReadFirstMain(LCSr,1,true)==false) then begin
    goto LLastServerActivityDate;
  end;

  known_sessions = LCSr.DataFolder & "/known_sessions.dat";

  if (FileExists(known_sessions)==false) then begin
    goto LLastServerActivityDate;
  end;

  qupdating.ImportKnownSessions(known_sessions,usrarr,datearr,timearr,evtarr,argarr);

  lcnt = usrarr.length;
  res = DateFromString(datearr[lcnt-1],"YYYY-MM-DD");

LLastServerActivityDate:;
  return;
end;

global
procedure LastServerListActivityDate(array record RemoteCloudServerVc aRCSr,var array Date Actarr)
begin
  Integer lcnt,i;
  record LocalCloudServerVc LCSr;
  record RemoteCloudServerVc RCSr;
  Date res;

  for (i=0;i<aRCSr.length;i=i+1) begin
    RCSr = aRCSr[i];
    LCSr.UUID = RCSr.UUID;
    LastServerActivityDate(LCSr,res);
    Actarr[i] = res;
  end;

  return;
end;

global
function Date GetLastServerActivityDate(record RemoteCloudServerVc RCSr)
begin
  string 255 url;
  record LocalCloudServerVc LCSr;
  Integer stat;
  Date res;
  Boolean scfailf;

  url = RcsNodeURL(RCSr);

  LCSr.UUID = RCSr.UUID;
  stat = CallService(url).LastServerActivityDate(LCSr,res);
  scfailf = TreatServiceError(stat,url,"LastServerActivityDate");
  queued.SaveCloudNodeReachable(RCSr.Controller,!scfailf);

  GetLastServerActivityDate = res;
  return;
end;

global
procedure GetLastServerListActivityDate(array record RemoteCloudServerVc aRCSr,var array Date Actarr)
begin
  string 255 url;
  Integer stat;
  record RemoteCloudServerVc RCSr;
  Boolean scfailf;

  if (aRCSr.length>0) then begin
    RCSr = aRCSr[0];
    url = RcsNodeURL(RCSr);
    stat = CallService(url).LastServerListActivityDate(aRCSr,Actarr);
    scfailf = TreatServiceError(stat,url,"LastServerListActivityDate");
    queued.SaveCloudNodeReachable(RCSr.Controller,!scfailf);
  end;

  return;
end;

global
procedure RemoteCloudServersData(array record RemoteCloudServerVc aRCSr,var array Date Actarr,var array val aRCSDBSize,var array Integer aRCShals)
begin
  Integer lcnt,i;
  record LocalCloudServerVc LCSr;
  record RemoteCloudServerVc RCSr;
  Date res;

  for (i=0;i<aRCSr.length;i=i+1) begin
    RCSr = aRCSr[i];
    LCSr.UUID = RCSr.UUID;
    LastServerActivityDate(LCSr,res);
    Actarr[i] = res;
    aRCSDBSize[i] = FileSize2(HDBFile2(LCSr));
    aRCShals[i] = 0;
    if (DirExists(LCSr.DataFolder & "/" & "halcust") or DirExists(LCSr.DataFolder & "/" & "halpatch")) then begin
      aRCShals[i] = 1;
    end;
  end;

  return;
end;

global
procedure GetRemoteCloudServersData(array record RemoteCloudServerVc aRCSr,var array Date Actarr,var array val aRCSDBSize,var array Integer aRCShals)
begin
  string 255 url;
  Integer stat;
  record RemoteCloudServerVc RCSr;
  Boolean scfailf;

  if (aRCSr.length>0) then begin
    RCSr = aRCSr[0];
    url = RcsNodeURL(RCSr);
    stat = CallService(url).RemoteCloudServersData(aRCSr,Actarr,aRCSDBSize,aRCShals);
    scfailf = TreatServiceError(stat,url,"LastServerListActivityDate");
    queued.SaveCloudNodeReachable(RCSr.Controller,!scfailf);
  end;

  return;
end;

updating procedure StopServerIfIdle(var record LocalCloudServerVc LCSr,record HansaVersionVc HVr)
begin
  LongInt l;

  switch (LCSr.CurrentStatus) begin
    case kStatusStopped:
      if (FileExists(ServerExpectRestartFile(LCSr))) then begin
        StartServerIfNeeded(LCSr,HVr);
      end;
    case kStatusRunningPendingStop:
      ActiveServerUsers(LCSr,true,l);
      if (l<=0) then begin
        SetBackupOnStopForServer(LCSr,false);
      end;
      StopLocalCloudServer(LCSr,false);
    case kStatusRunning:
      ActiveServerUsers(LCSr,true,l);
      if (l<=0) then begin
        //LogText(0,"Stopping LCSr.Name=" & LCSName(LCSr) & " because nobody is logged in");
        SetBackupOnStopForServer(LCSr,false);
        StopLocalCloudServer(LCSr,false);
      end;
    case kStatusStopping:
      // StopAlert("Should check if force stop needed");
      // if too many force stops have been made, place "config in error"
    case kStatusStarting:
      // StopAlert("Should check if force stop needed");
      // if too many force stops have been made, place "config in error"
      // should wait a bit to begin with to let it start normally first
    case kStatusImportingBackup:
      // StopAlert("Should check if force stop needed");
      // if too many force stops have been made, place "config in error"
    case kStatusMaintenance:
  end;
  return;
end;

