  end;
  goto LAddLineToNodeRebuildLog;

LAddLineToNodeRebuildLog_add:;
  AddAreaToTextField(a_text,NPr);
  if (RecordStore(NPr,true)) then begin end;
  
LAddLineToNodeRebuildLog:;
  return;
end;

function string 255 GetCertSubField(string field,string subfieldname)
begin
  LongInt i,pos,prefixlen;
  array string 255 subfields;
  string 255 prefix,res;
  
  SplitString(field,"/",subfields);
  
  prefix = subfieldname & "=";
  prefixlen = len(prefix);
  
  for (i=0;i<subfields.length;i=i+1) begin
    if (left(subfields[i],prefixlen)==prefix) then begin
      res = right(subfields[i],len(subfields[i]) - prefixlen);
    end;
  end;
  
  GetCertSubField = res;
end;

