external procedure JSONNotStringPut(var string,string,string);
external procedure JSONNotStringAdd(var string,string,string);
external procedure JSONStringStart(var string);
external procedure JSONStringMemberStart(var string,string);
external procedure JSONStringMemberEnd(var string);
external procedure JSONStringEnd(var string);
external procedure EmSzmalAuthCodesm;
external function val StringToValue(string,Integer,string,string);
external procedure emSzmalGetAccountsListDsm;
external function Boolean ParseHTTPHeader(area,string,var Integer,var string,var string);
external procedure LogAreaToFile(string,area);
external procedure EmSzmalAuthCode2sm;
external function Boolean GetBankAccPMRow(record PMBlock,string,string,var row PMBlock);
external updating procedure CreateReceipt(record SRBlock,string,record BankTRVc,boolean);
external function Boolean FindStringInString(string,string);
external function string 255 StripCharacter(string,string);
remote procedure ClientDisplayErrorMessage(string,LongInt,string);

procedure JSONStringPut(var string js,string argument,string value)
begin
    js = js & """" & argument & """: ";
    js = js & """" & value & """";
  return;
end;

procedure JSONStringAdd(var string js,string argument,string value)
begin
    JSONStringPut(js,argument,value);
    js = js & ",";
  return;
end;

