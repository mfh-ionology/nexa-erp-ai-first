global
function string 255 emSzmalHost()
begin
  string 255 res;

  res =  "web.emszmal.pl";

  emSzmalHost = res;
  return;
end;

global
updating procedure EmSzmalStoreSessionDetails(record EmSzmalBlock EmSzmalBl)
begin
  BlockStore(EmSzmalBl);
  return;
end;

function Date ParseDate(string datetime)
begin
  Date res;
  string 255 d,year,month,day;
  LongInt pos;

  d = Left(datetime,10);
  GetNextSubstring(d,pos,"-",year);
  GetNextSubstring(d,pos,"-",month);
  GetNextSubstring(d,pos,"-",day);
  res.year = StringToInt(year);
  res.month = StringToInt(month);
  res.day = StringToInt(day);

  ParseDate = res;
  return;
end;

procedure emSzmalDestroySession()
begin
  string 255 res,jsr,sessionid;
  Area a_req,a_reply;
  json js;
  record EmSzmalBlock EmSzmalBl;

  BlockLoad(EmSzmalBl);

  JSONStringStart(jsr); 
  JSONStringAdd(jsr,"SessionId",EmSzmalBl.SessionId);
  JSONStringMemberStart(jsr,"License");
  jsr = jsr & "{";
  JSONStringAdd(jsr,"APIId",EmSzmalBl.ApiId);
  JSONStringPut(jsr,"APIKey",EmSzmalBl.ApiKey); 
  JSONStringMemberEnd(jsr);  
  JSONStringEnd(jsr);
  AddTextToArea(jsr,a_req);
  SetWebHeaders("Cookie:SessionId=" & EmSzmalBl.SessionId);
  if (SendWebRequest(emSzmalHost,443,-1,true,"POST","api/Common/SayBye","","",false,a_req,a_reply,60)) then begin
    EmSzmalBl.SessionId = "";
    EmSzmalBl.SessionCreatedDate = "";
    EmSzmalBl.SessionCreatedTime = "";
    EmSzmalBl.AccountNumber = "";
    qupdating.EmSzmalStoreSessionDetails(EmSzmalBl);
  end;

  return;
end;


function string 255 GetFullName(string description,string paydetails,string accountnr)
begin
  string 255 res,newlineinfo,name;
  LongInt pos;

  pos = 0;
  while (GetNextSubstring(description,pos,chr(10),newlineinfo)) begin
    name = StripCharacter(newlineinfo,chr(13));
    if (paydetails!=name) and (accountnr!=name) then begin
      res = res &  name;
    end; 
  end;
  GetFullName = res;
  return;
end;

global
updating procedure emSzmalGetAccountHistoryReply(Area a_reply,Area replyheader,Boolean timedout)
begin
  json js,js2;
  Integer i;
  string 255 key,sum,ref,accountnr,type,description,amount;
  string 255 tstr,partneraccountnr,paydetails;
  record BankTRVc BankTRr,oBTRr;
  record EmSzmalBlock EmSzmalBl;
  Boolean found,successf;
  area a_req,amyreply;
  record CYBlock CYb;
  record PMBlock PMb;
  row PMBlock PMbrw;
  record SRBlock SRb;

  BlockLoad(PMb);
  BlockLoad(CYb);
  BlockLoad(SRb);
  BlockLoad(EmSzmalBl);
 

  LogAreaToFile("reply.txt",a_reply);//leave for testing
  js2 = ParseJSONArea(a_req);
  if (JSONNodeExists(js2,"Data/AccountNumber")) then begin
    accountnr = JSONGet(js2,"Data/AccountNumber");
  end;
  if (blank(accountnr)) then begin
    GetBankAccPMRow(PMb,"",EmSzmalBl.AccountNumber,PMbrw);
  end else begin
    GetBankAccPMRow(PMb,"",accountnr,PMbrw);
  end;
  js = ParseJSONArea(a_reply);
  if (GetAreaLength(a_reply)>=0) then begin
    if (JSONNodeExists(js,"Error")) then begin
      Messagebox(0,JSONGet(js,"Error/Message"));
      goto LemSzmalGetAccountHistoryReply;
    end;
    i = 0;
    while (JSONNodeExists(js,"Transactions/" & "[" & i & "]/TransactionRefNumber")) begin
      key = "Transactions/" & "[" & i & "]";
      sum = JSONGet(js,key & "/TransactionAmount");
      ref = JSONGet(js,key & "/TransactionRefNumber");
      type = JSONGet(js,key & "/TransactionType");
      RecordClear(BankTRr);
      BankTRr.Reference = ref;
      if (ReadFirstKey("Reference",BankTRr,1,true)==false) then begin
        RecordNew(BankTRr);
        BankTRr.TRNumber = JSONGet(js,key & "/TransactionRefNumber");
        BankTRr.Reference = ref & " " & type;
        BankTRr.TransDate = ParseDate(JSONGet(js,key & "/TransactionBookingDate"));
        amount = StripCharacter(sum,"-");
        //BankTRr.Sum = StringToVal(amount,M4Val);
        BankTRr.Sum = StringToValue(amount,M4Val,"",".");
        tstr = JSONGet(js,key & "/TransactionPaymentDetails");
        description = JSONGet(js,key & "/TransactionDescription");
        paydetails = JSONGet(js,key & "/TransactionPaymentDetails");
        partneraccountnr = JSONGet(js,key & "/TransactionPartnerAccountNo");
        BankTRr.CurncyCode = "PLN" ;
        switch (Left(sum,1)) begin
          case "-":
            BankTRr.PayName = CYb.CompName;
            BankTRr.PayTransDate = "";
            if (nonblank(accountnr)) then begin
              BankTRr.PayBankAcc = accountnr;
            end else begin
              BankTRr.PayBankAcc = EmSzmalBl.AccountNumber;
            end;
            BankTRr.TypeRef = "D";
            BankTRr.RcpTransDate = ParseDate(JSONGet(js,key & "/TransactionOperationDate"));
            BankTRr.RcpName = GetFullName(description,paydetails,partneraccountnr);
            if (nonblank(tstr)) then begin
              BankTRr.RcpReference = tstr;
              BankTRr.Comment = tstr;
            end else begin
              BankTRr.Comment = JSONGet(js,key & "/TransactionDescription");
            end;
            BankTRr.RcpBankAcc = StripNonDigits(JSONGet(js,key & "/TransactionPartnerAccountNo"));
          otherwise
            BankTRr.RcpName = CYb.CompName;
            BankTRr.RcpTransDate = "";
            if (nonblank(accountnr)) then begin
              BankTRr.RcpBankAcc = accountnr;
            end else begin
              BankTRr.RcpBankAcc = EmSzmalBl.AccountNumber;
            end;
            BankTRr.TypeRef = "C";
            BankTRr.PayTransDate = ParseDate(JSONGet(js,key & "/TransactionOperationDate"));
            BankTRr.PayName = GetFullName(description,paydetails,partneraccountnr);
            if (nonblank(tstr)) then begin
              BankTRr.PayReference = tstr;
              BankTRr.Comment = tstr;
            end else begin
              BankTRr.Comment = JSONGet(js,key & "/TransactionDescription");
            end;
            BankTRr.PayBankAcc = StripNonDigits(JSONGet(js,key & "/TransactionPartnerAccountNo"));  
          end;

          oBTRr.TRNumber = BankTRr.TRNumber;
          if (ReadFirstKey("TRNumber",oBTRr,1,true)==false) then begin
            BankTRr.SerNr = NextSerNr("BankTRVc",BankTRr.TransDate,-1,false,"");
            if (BankTRr.SerNr>0) then begin
              RecordStore(BankTRr,false);
              if (nonblank(BankTRr.Comment)) then begin
                if (FindStringInString(BankTRr.Comment,"/VAT/")) then begin
                  CreateReceipt(SRb,PMbrw.Code,BankTRr,true);
                end;
              end;
            end;
          end;
      end;
      i = i + 1;
      successf = true;
    end;
  end else begin
    ClientDisplayErrorMessage("",0,USetStr(42974));
  end;
  if (successf) then begin
    if (ServerMode) then begin
      AllClientsRemoteAsync.ClientDisplayErrorMessage("",0,USetStr(15092));
    end else begin
      ClientDisplayErrorMessage("",0,USetStr(15092));
    end;
  end;
  emSzmalDestroySession;
  
LemSzmalGetAccountHistoryReply:;
  return;
end;

global
procedure emSzmalGetAccountHistory(record RcVc RepSpec,integer bankrecon)
begin
  string 255 jsr,providernumber;
  Area a_req,a_reply;
  json js;
  record EmSzmalBlock EmSzmalBl;

  BlockLoad(EmSzmalBl);
  JSONStringStart(jsr); 
  JSONStringAdd(jsr,"SessionId",EmSzmalBl.SessionId);
  GetProviderId(RepSpec.f4,providernumber);
  JSONNotStringAdd(jsr,"ProviderId",providernumber);
  JSONStringAdd(jsr,"ProviderConfiguration","");
  JSONStringMemberStart(jsr,"Authentication");
  jsr = jsr & "{";
  JSONStringAdd(jsr,"UserLogin",RepSpec.f2);
  JSONStringAdd(jsr,"UserPassword",RepSpec.f3);
  JSONStringAdd(jsr,"UserContext",RepSpec.f5);
  JSONStringPut(jsr,"TokenValue","");
  JSONStringMemberEnd(jsr); 
  jsr = jsr & ","; 
  JSONStringMemberStart(jsr,"License");
  jsr = jsr & "{";
  JSONStringAdd(jsr,"APIId",EmSzmalBl.ApiId);
  JSONStringPut(jsr,"APIKey",EmSzmalBl.ApiKey); 
  JSONStringMemberEnd(jsr);  
  jsr = jsr & ",";
  JSONStringMemberStart(jsr,"Data");
  jsr = jsr & "{";
  JSONStringAdd(jsr,"AccountNumber",RepSpec.f1);
  JSONStringAdd(jsr,"DateSince",DateToString(RepSpec.sStartDate,"YYYY-MM-DD"));
  JSONStringPut(jsr,"DateTo",DateToString(RepSpec.sEndDate,"YYYY-MM-DD"));
  JSONStringMemberEnd(jsr);
  JSONStringEnd(jsr);

  AddTextToArea(jsr,a_req);

  SetWebHeaders("Cookie:SessionId=" & EmSzmalBl.SessionId);
  EmSzmalBl.AccountNumber = RepSpec.f1;
  qupdating.EmSzmalStoreSessionDetails(EmSzmalBl);
  SendAsyncWebRequest(emSzmalHost,443,-1,true,"POST","/api/Accounts/GetAccountHistory","application/json","",a_req,"emSzmalGetAccountHistoryReply",500);

  if (bankrecon==0) then begin
    if (RepSpec.flags[0]==0) then begin
      EmSzmalAuthCodesm;
    end;
  end else begin
    if (RepSpec.flags[0]==0) then begin
      EmSzmalAuthCode2sm;
    end;
  end;

  //LogAreaToFile("historyreq" & ".txt",a_req);

  return;
end;

global
function boolean emSzmalDoSecondPhaseAuthenticationData(string authcode,string login,string password,string provider,string usercontext)
begin
  string 255 jsr,providernumber;
  Area a_req,a_reply;
  json js;
  Boolean res;
  record EmSzmalBlock EmSzmalBl;

  BlockLoad(EmSzmalBl);
  JSONStringStart(jsr); 
  JSONStringAdd(jsr,"SessionId",EmSzmalBl.SessionId); 
  GetProviderId(provider,providernumber);
  JSONNotStringAdd(jsr,"ProviderId",providernumber);
  JSONStringAdd(jsr,"ProviderConfiguration","");
  JSONStringMemberStart(jsr,"Authentication");
  jsr = jsr & "{";
  JSONStringAdd(jsr,"UserLogin",login);
  JSONStringAdd(jsr,"UserPassword",password);
  JSONStringAdd(jsr,"UserContext",usercontext);
  JSONStringPut(jsr,"TokenValue","");
  JSONStringMemberEnd(jsr);  
  jsr = jsr & ",";
  JSONStringMemberStart(jsr,"License");
  jsr = jsr & "{";
  JSONStringAdd(jsr,"APIId",EmSzmalBl.ApiId);
  JSONStringPut(jsr,"APIKey",EmSzmalBl.ApiKey);
  JSONStringMemberEnd(jsr);  
  jsr = jsr & ",";
  JSONStringPut(jsr,"AuthenticationCode",authcode);
  JSONStringEnd(jsr);
  AddTextToArea(jsr,a_req);
  SetWebHeaders("Cookie:SessionId=" & EmSzmalBl.SessionId);
  res = SendWebRequest(emSzmalHost,443,-1,true,"POST","/api/SessionManager/DoSecondPhaseAuthentication","","",false,a_req,a_reply,60);
  // LogAreaToFile("DOSECONDAUTHreply" & ".txt",a_reply);
  // LogAreaToFile("DOSECONDAUTHreq" & ".txt",a_req);
  if (res) then begin 
  end else begin
    ClientDisplayErrorMessage("",0,USetStr(42975));
  end;
  emSzmalDoSecondPhaseAuthenticationData = res;
  return;
end;

global
procedure emSzmalGetAccountsListReply(Area a_reply,Area replyheader,Boolean timedout)
begin
  json js;
  Integer i,l;
  string 255 key,accountnr,currency,accountfunds,accounbal;
  record EmSzmalBlock EmSzmalBl;
  array string 255 aaccountnr,acurrency,aaccounbal,aaccountfunds;
  string 255 tstr;
  integer rw;

  //LogAreaToFile("emSzmalGetAccountsListReply" & ".txt",a_reply);
  
  StartReportJob(USetStr(42971));
  EndHeader;

  SetRepCol(2,250);
  SetRepCol(3,350);
  SetRepCol(1,450);

  StartFormat(15);
  OutString(0,0,USetStr(42967),false);
  OutString(2,0,USetStr(42969),false);
  OutString(3,0,USetStr(42970),false);
  OutString(1,0,USetStr(42968),false);
  EndFormat;
  Gray_Divider(0,1);

 //AddFileToArea("emsszmal/text.txt",a_reply,false);
 //LogAreaToFile("emsszmal/_emSzmalGetAccountsListReply_reply" & ".txt",a_reply);
  
  BlockLoad(EmSzmalBl);
  js = ParseJSONArea(a_reply);
  if (JSONNodeExists(js,"Accounts")) then begin
    while (JSONNodeExists(js,"Accounts/" & "[" & i & "]")) begin
      key = "Accounts/" & "[" & i & "]";
      aaccountnr[i] = JSONGet(js,key & "/AccountNumber");
      acurrency[i] = JSONGet(js,key & "/AccountCurrency");
      aaccountfunds[i] =JSONGet(js,key & "/AccountAvailableFunds");
      aaccounbal[i] = JSONGet(js,key & "/AccountBalance");
      i = i + 1;
    end;
  end else begin
    if (JSONNodeExists(js,"Error")) then begin
      ClientDisplayErrorMessage("",0,JSONGet(js,"Error/Message"));
    end;
  end;
  for (l=0;l<i;l=l+1) begin 
    StartFormat(15);
    OutString(0,0,aaccountnr[l],false);
    OutString(2,0,aaccountfunds[l],false);
    OutString(3,0,aaccounbal[l],false);
    OutString(1,0,acurrency[l],false);
    EndFormat;
  end;
  emSzmalDestroySession;
  EndJob;
  return;
end;

global
procedure emSzmalGetAccountsList(record BankVc Bankr)
begin
  string 255 jsr;
  Area a_req;
  json js;
  record EmSzmalBlock EmSzmalBl;
  string 255 providernumber;
  record RcVc RepSpec;

  BlockLoad(EmSzmalBl);
  JSONStringStart(jsr); 
  JSONStringAdd(jsr,"SessionId",EmSzmalBl.SessionId);
  GetProviderId(Bankr.emSzmalBankProvider,providernumber);
  JSONNotStringAdd(jsr,"ProviderId",providernumber);
  JSONStringAdd(jsr,"ProviderConfiguration","");
  JSONStringMemberStart(jsr,"Authentication");
  jsr = jsr & "{";
  JSONStringAdd(jsr,"UserLogin",Bankr.emSzmalBankLogin);
  JSONStringAdd(jsr,"UserPassword",Bankr.emSzmalBankPassword);
  JSONStringAdd(jsr,"UserContext",Bankr.emSzmalBankUserContext);
  JSONStringPut(jsr,"TokenValue","");
  JSONStringMemberEnd(jsr);  
  jsr = jsr & ",";
  JSONStringMemberStart(jsr,"License");
  jsr = jsr & "{";
  JSONStringAdd(jsr,"APIId",EmSzmalBl.ApiId);
  JSONStringPut(jsr,"APIKey",EmSzmalBl.ApiKey); 
  JSONStringMemberEnd(jsr);  
  JSONStringEnd(jsr);
  AddTextToArea(jsr,a_req);

  SetWebHeaders("Cookie:SessionId=" & EmSzmalBl.SessionId);
  //LogAreaToFile("emSzmalGetAccountsList_request" & ".txt",a_req);
  SendAsyncWebRequest(emSzmalHost,443,-1,true,"POST","/api/Accounts/GetAccountsList","application/json","",a_req,"emSzmalGetAccountsListReply",600);
  
  if (Bankr.SkipSms==0) then begin
    EmSzmalAuthCodesm;
  end;
  
  return;
end;


global
procedure DoEmSzmalStartSessionRemote(Integer sessiontype)
begin
  string 255 jsr;
  Area a_req,a_reply;
  json js;
  string 255 sessionid;
  record EmSzmalBlock EmSzmalBl;
  Boolean res;

  BlockLoad(EmSzmalBl);
  if (blank(EmSzmalBl.ApiId)) then begin  ClientDisplayErrorMessage("",0,USetStr(42960)); goto LDoEmSzmalStartSessionRemote; end;
  if (blank(EmSzmalBl.ApiKey)) then begin ClientDisplayErrorMessage("",0,USetStr(42961)); goto LDoEmSzmalStartSessionRemote; end;

  JSONStringStart(jsr); 
  JSONStringMemberStart(jsr,"License");
  jsr = jsr & "{";
  JSONStringAdd(jsr,"APIId",EmSzmalBl.ApiId);
  JSONStringPut(jsr,"APIKey",EmSzmalBl.ApiKey); 
  JSONStringMemberEnd(jsr);  
  JSONStringEnd(jsr);
  AddTextToArea(jsr,a_req);
  //LogAreaToFile("emsszmal/_HistoryemSzmalSayHello_request" & ".txt",a_req);
  res = SendWebRequest(emSzmalHost,443,-1,true,"POST","/api/Common/SayHello","application/json","",false,a_req,a_reply,20);
  //LogAreaToFile("emsszmal/_HistoryemSzmalSayHello_reply" & ".txt",a_reply);
  if (res) then begin
    js = ParseJSONArea(a_reply);
    if nonblank(JSONGet(js,"SessionId")) then begin
      sessionid = JSONGet(js,"SessionId"); 
      EmSzmalBl.SessionId = sessionid;
      EmSzmalBl.SessionCreatedDate = CurrentDate;
      EmSzmalBl.SessionCreatedTime = CurrentTime;
      qupdating.EmSzmalStoreSessionDetails(EmSzmalBl);
      if (sessiontype==1) then begin
        emSzmalGetAccountsListDsm;
      end;
    end else begin
      if (JSONNodeExists(js,"Error")) then begin
        ClientDisplayErrorMessage("",0,JSONGet(js,"Error/Message"));
      end;
    end;
  end;
LDoEmSzmalStartSessionRemote:;
  return;
end;

