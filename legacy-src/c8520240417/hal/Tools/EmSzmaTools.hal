global
function Longint EmSzmalHistoryAccRecon(string accountnr,string period)
begin
  Integer wn,nwn;
  record RcVc RepSpec;
  record BankVc Bankr;
  record EmSzmalBlock EmSzmalBl;
  Boolean testf,TrHs;
  LongInt res;

  res = 0;
  DoEmSzmalStartSessionRemote(0);
  BlockLoad(EmSzmalBl);
  if (nonblank(EmSzmalBl.SessionId)) then begin
    TrHs = true;
    while (LoopMain(Bankr,1,TrHs)) begin
      testf = false;
      if (Bankr.Nr2 == accountnr) then begin
         testf = true;
         TrHs = false;
      end;
    end;
    if (testf) then begin
      if (blank(Bankr.emSzmalBankLogin)) then begin
        res = 42965;
        goto LEmSzmalHistoryAccRecon;
      end;
      if (blank(Bankr.emSzmalBankPassword)) then begin
        res = 42964;
        goto LEmSzmalHistoryAccRecon;
      end;
      if (blank(Bankr.emSzmalBankProvider)) then begin
        res = 42963;
        goto LEmSzmalHistoryAccRecon;
      end;
      RepSpec.f1 = Bankr.Nr2;
      RepSpec.f2 = Bankr.emSzmalBankLogin;
      RepSpec.f3 = Bankr.emSzmalBankPassword;
      RepSpec.f4 = Bankr.emSzmalBankProvider;
      RepSpec.sStartDate = Left(period,10);
      RepSpec.sEndDate = Right(period,10);
      RepSpec.flags[0] = Bankr.SkipSms;
      RepSpec.f5 = Bankr.emSzmalBankUserContext;
      emSzmalGetAccountHistory(RepSpec,1);
    end;
  end;

LEmSzmalHistoryAccRecon:;
  EmSzmalHistoryAccRecon = res;
  return;
end;