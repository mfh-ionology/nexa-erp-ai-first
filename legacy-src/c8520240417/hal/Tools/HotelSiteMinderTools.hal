    gSiteMinderRequestUUID = uid;
    SendAsyncWebRequest(SMb.Host,443,-1,true,"POST","/pmsxchangev2/services/" & SMb.HotelID,"text/xml; charset=""utf-8""","pmsxchange/HotelAvailNotifRQ",req,"SendRatesToSiteMinderReply",30);
  end;
LSetRatesAtSiteMinder2:;
  return;
end;
  
