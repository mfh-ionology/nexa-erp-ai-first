function string 10 TimeToString(time t)
begin
  string 10 res;
  
  if (t.hour<10) then begin res = res & "0"; end;
  res = res & t.hour & ":";
  if (t.minute<10) then begin res = res & "0"; end;
  res = res & t.minute & ":";
  if (t.second<10) then begin res = res & "0"; end;
  res = res & t.second;
  
  TimeToString = res;
  return;
end;

function string 5 TimeOffset(val gmtoffset)
begin
  string 255 res; 
  Time t;
  
  if (gmtoffset>=0) then begin
    res = "+";
  end else begin
    res = "-";
  end;
  
  t = ValToTime(gmtoffset);
  res = res & Left(t,5);
  
  TimeOffset = res;
  return;
end;

procedure AddXmlTagWithAttr(string tag,string attributes,string value,var Area a)
begin
  
  AddTextToArea("<",a);
  AddTextToArea(tag,a);
  if (nonblank(attributes)) then begin
    AddTextToArea(" " & attributes,a);  
  end;
  AddTextToArea(">",a);  
  if (nonblank(value)) then begin
    AddTextToArea(URLEncode(value),a);
  end;
  if (Right(attributes,1)!="/") then begin
    AddTextToArea("</",a);
    AddTextToArea(tag,a);
    AddTextToArea(">",a);
  end;
  return;
end;

procedure AddXmlTag(string tag,string value,var Area a)
begin
    
  AddTextToArea("<",a);
  AddTextToArea(tag,a);
  AddTextToArea(">",a);  
  AddTextToArea(URLEncode(value),a);
  AddTextToArea("</",a);
  AddTextToArea(tag,a);
  AddTextToArea(">",a);
  return;
end;

procedure OpenXmlTagWithAttr(string tag,string attributes,var Area a)
begin
  
  AddTextToArea("<" & tag,a);
  if (nonblank(attributes)) then begin
    AddTextToArea(" " & attributes,a);  
  end;
  AddTextToArea(">",a);  
  return;
end;

procedure OpenXmlTag(string tag,var Area a)
begin
  OpenXmlTagWithAttr(tag,"",a);
  return;
end;

procedure CloseXmlTag(string tag,var Area a)
begin
  AddTextToArea("</" & tag & ">",a);
  return;
end;

procedure AddSecurityHeader(record SiteMinderBlock SMb,var Area req)
begin
  OpenXmlTag("soap:Header",req);
  OpenXmlTagWithAttr("wsse:Security","soap:mustUnderstand=""1"" xmlns:wsse=""http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd""",req);
  OpenXmlTag("wsse:UsernameToken",req);
  AddXmlTag("wsse:Username",SMb.Username,req);//StandardERPTest
  AddXmlTagWithAttr("wsse:Password","Type=""http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-username-token-profile-1.0#PasswordText""",SMb.Password,req);//8pnc1iX197924NpA38R9WOJD
  CloseXmlTag("wsse:UsernameToken",req);
  CloseXmlTag("wsse:Security",req);
  CloseXmlTag("soap:Header",req);
  return;
end;

procedure AddReuqestor(record SiteMinderBlock SMb,var Area req)
begin
  AddTextToArea("<POS>" ,req);
  AddTextToArea("<Source>" ,req);  
  AddTextToArea("<RequestorID Type=""" & "22" & """" & " ID=""" & SMb.HotelID & """/>" ,req);//STANDARDERP
  AddTextToArea("</Source>" ,req);
  AddTextToArea("</POS>" ,req);
  return;
end;

updating procedure LogSiteMinderUUID(string uid,Integer action,string soapmsg,Integer status,string errstr)
begin
  record SiteMinderUUIDLogVc SMUUIDLr;
  
  RecordNew(SMUUIDLr);
  SMUUIDLr.RequestUUID = StringToUUID(uid);
  SMUUIDLr.Action = action;
  SMUUIDLr.Message = soapmsg;
  SMUUIDLr.Status = status;
  SMUUIDLr.Comment = errstr;

  SMUUIDLr.TransDate = CurrentDate;
  SMUUIDLr.TransTime = CurrentTime;
  SMUUIDLr.SerNr = NextSerNr("SiteMinderUUIDLogVc",SMUUIDLr.TransDate,-1,false,"");
  if (SMUUIDLr.SerNr>0) then begin
    RecordStore(SMUUIDLr,false);
    switch (status) begin
      case kSOAPReplyError:
        if (ServerMode) then begin
          AllClientsRemoteAsync.ClientDisplayErrorMessage("",0,SMUUIDLr.RequestUUID  & " " & SMUUIDLr.Comment);
        end else begin
          ClientDisplayErrorMessage("",0,SMUUIDLr.RequestUUID  & " " & SMUUIDLr.Comment);
        end;
      case kSOAPReplyTimeOut:
        if (ServerMode) then begin
          AllClientsRemoteAsync.ClientDisplayErrorMessage("",0,SMUUIDLr.RequestUUID  & " " & SMUUIDLr.Comment);
        end else begin
          ClientDisplayErrorMessage("",0,SMUUIDLr.RequestUUID  & " " & SMUUIDLr.Comment);
        end;
    end;
  end;
  return;
end;

global
updating procedure RetriveSiteMinderReservations()
begin
  record SiteMinderBlock SMb;
  Area req;
  Area reply;
  string 255 timestamp;
  LongInt fsz;
  UUID uid;
  transaction string 255 gSiteMinderRequestUUID;
       
  BlockLoad(SMb);
  if (SMb.Enable!=0 and nonblank(SMb.HotelCode)) then begin
    AddTextToArea("<?xml version=""1.0"" encoding=""UTF-8""?>",req);
    OpenXmlTagWithAttr("soap:Envelope","xmlns:soap=""http://schemas.xmlsoap.org/soap/envelope/""",req);

    AddSecurityHeader(SMb,req);
    AddTextToArea("<soap:Body>" ,req);

    timestamp = DateToString(CurrentDate,"YYYY-MM-DD") & "T" & TimeToString(CurrentTime) & TimeOffset(SMb.GMTOffset);
    uid = MakeUUID;
    OpenXmlTagWithAttr("OTA_ReadRQ","xmlns=""http://www.opentravel.org/OTA/2003/05"" Version=""1.0"" TimeStamp=""" & timestamp & """ EchoToken=""" & uid & """",req);

    AddReuqestor(SMb,req);

    OpenXmlTag("ReadRequests",req);
    OpenXmlTagWithAttr("HotelReadRequest","HotelCode=""" & SMb.HotelCode & """",req);//StandardERP608
    AddTextToArea("<SelectionCriteria SelectionType=""" & "Undelivered" & """" & " />" ,req);
    CloseXmlTag("HotelReadRequest",req);
    CloseXmlTag("ReadRequests",req);
    CloseXmlTag("OTA_ReadRQ",req);

    AddTextToArea("</soap:Body>" ,req);
    AddTextToArea("</soap:Envelope>" ,req);



    if (SMb.LogCommunication!=0) then begin
      LogAreaToFile(ProgramFolder & "/SiteMinder/" & "_siteminder_retrive_res_req.xml",req);
    end;

//cmtpi.siteminder.com
//STANDARDERP
LogText(0,"RetriveSiteMinderReservations");
    LogSiteMinderUUID(uid,kSOAPActionRequest,"ReadRQ",kSOAPReplyNone,"");
    gSiteMinderRequestUUID = uid;
    SendAsyncWebRequest(SMb.Host,443,-1,true,"POST","/pmsxchangev2/services/" & SMb.HotelID,"text/xml; charset=""utf-8""","pmsxchange/ReadRQ",req,"RetriveSiteMinderReservationsReply",30);
//    fsz = FileSize("_siteminder_retrive_res_reply.xml");//debug Code
//    LoadFileToArea("_siteminder_retrive_res_reply.xml",0,fsz,reply);
//    AddReservations(SMb,reply);//debug code

  end;
  return;
end;

function Boolean SetRoomTypeRateAtSiteMinder(record SiteMinderBlock SMb,record AgentRoomVc ARr,var Area req)
begin
  Boolean res;
  Date sd,ed;
  record JobVc Jobr;    
  record ResVc Resr;
  record ResTypeVc RTr;
  record JobPriceVc JPr;
  row JobPriceVc JPrw;
  Integer i,rwcnt; 
  LongInt pos;
  string 255 tstr;
  string 255 resusages,resusage;
  record INVc INr;
  record BaseCurBlock BCb;
  vector val vrates;
  vector string 255 vratesitem;
  Array string 255 aday;

  Resr.Code = ARr.ResCode;
  if (ReadFirstMain(Resr,1,true)) then begin
    BlockLoad(BCb);
    RTr.Code = Resr.Type;
    ReadFirstMain(RTr,1,true);
    
    sd = ARr.StartDate;
    if (blankdate(sd) or sd<CurrentDate) then begin sd = CurrentDate; end;
    ed = ARr.EndDate;
    if (blankdate(ed) or ed<CurrentDate) then begin ed = CurrentDate; end;
    ed = AddDay(ed,1);

    resusages = ARr.ResUsage;
    if (blank(resusages)) then begin
      resusages = SMb.ResUsages;
    end;
    pos = 0;
    GetNextSubstring(resusages,pos,",",resusage);
    while (nonblank(resusage)) begin
      RecordNew(Jobr);
      Jobr.ResCode = Resr.Code;
      JobPasteResCode(Jobr,"");
    
      Jobr.TransDate = sd;
      JobPasteTransDate(Jobr);
      Jobr.EndDate = ed;
      Jobr.NrOfDays = DateDiff(Jobr.EndDate,Jobr.TransDate);
      Jobr.Persons = RTr.MaxPersons;
      tstr = Jobr.ResUsage;
      Jobr.ResUsage = resusage;
      if (Jobr.ResUsage!=tstr) then begin
        JobPasteResUsage(Jobr,tstr);
      end;
      if (JobToJobPrices(Jobr,Jobr.Type,JPr)) then begin
        AddTextToArea("<StatusApplicationControl InvTypeCode=""" & Jobr.Type & """" & " RatePlanCode=""" & Jobr.ResUsage & """/>",req);  
        OpenXmlTag("Rates",req);
      
        rwcnt = MatRowCnt(JPr);
        if (rwcnt==0) then begin
          MessageBox(39180," " & ARr.ResCode);
        end;
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(JPr,i,JPrw);
          if (nonblankdate(JPrw.StayDay)) then begin
            res = true;
            vrates[GetDateId(JPrw.StayDay)] = JPrw.Price;
            vratesitem[GetDateId(JPrw.StayDay)] = JPrw.ArtCode;
          end;
        end;
        Jobr.EndDate = AddDay(Jobr.EndDate,-1);

        GetVectorTags(vrates,aday);
        SortStringArray(aday);
        for (i=0;i<aday.length;i=i+1) begin
          AddTextToArea("<Rate" & " CurrencyCode=""" & BCb.BaseCur1 & """ Start=""" & DateToString(Jobr.TransDate,"YYYY-MM-DD") & """ End=""" & DateToString(Jobr.EndDate,"YYYY-MM-DD") & """ ",req);
          switch (aday[i]) begin
            case "1":
              AddTextToArea("Mon=""1"" Tue=""0"" Weds=""0"" Thur=""0"" Fri=""0"" Sat=""0"" Sun=""0""",req);  
            case "2":
              AddTextToArea("Mon=""0"" Tue=""1"" Weds=""0"" Thur=""0"" Fri=""0"" Sat=""0"" Sun=""0""",req);  
            case "3":
              AddTextToArea("Mon=""0"" Tue=""0"" Weds=""1"" Thur=""0"" Fri=""0"" Sat=""0"" Sun=""0""",req);  
            case "4":
              AddTextToArea("Mon=""0"" Tue=""0"" Weds=""0"" Thur=""1"" Fri=""0"" Sat=""0"" Sun=""0""",req);  
            case "5":
              AddTextToArea("Mon=""0"" Tue=""0"" Weds=""0"" Thur=""0"" Fri=""1"" Sat=""0"" Sun=""0""",req);  
            case "6":
              AddTextToArea("Mon=""0"" Tue=""0"" Weds=""0"" Thur=""0"" Fri=""0"" Sat=""1"" Sun=""0""",req);  
            case "7":
              AddTextToArea("Mon=""0"" Tue=""0"" Weds=""0"" Thur=""0"" Fri=""0"" Sat=""0"" Sun=""1""",req);  
          end;
          AddTextToArea(">",req);  
          OpenXmlTag("BaseByGuestAmts",req);
          AddTextToArea("<BaseByGuestAmt AmountAfterTax=""" & ValToString(vrates[aday[i]],M4Val,"",".",0) & """/>",req);      
          CloseXmlTag("BaseByGuestAmts",req);
/*          
          if (ReadFirstItem(vratesitem[aday[i]],INr,true,false)) then begin
            OpenXmlTag("RateDescription",req);
            AddXmlTag("Text",INr.Name,req);
            CloseXmlTag("RateDescription",req);
          end;
*/          
          CloseXmlTag("Rate",req);
        end;

        CloseXmlTag("Rates",req);
      end;
      GetNextSubstring(resusages,pos,",",resusage);
    end;
  end;
    
  SetRoomTypeRateAtSiteMinder = res;
  return;
end;

global
updating procedure SendRatesToSiteMinder(record AgentRoomVc ARr)
begin
  Area req;
  string 255 timestamp;
  Integer i;
  Boolean sendf;
  record SiteMinderBlock SMb;
  UUID uid;
  transaction string 255 gSiteMinderRequestUUID;

  if (ARr.Closed!=0) then begin
    goto LSendRatesToSiteMinder;
  end;
  BlockLoad(SMb);
  AddTextToArea("<?xml version=""1.0"" encoding=""UTF-8""?>",req);
  OpenXmlTagWithAttr("soap:Envelope","xmlns:soap=""http://schemas.xmlsoap.org/soap/envelope/""",req);

  AddSecurityHeader(SMb,req);
  AddTextToArea("<soap:Body>" ,req);
  
  timestamp = DateToString(CurrentDate,"YYYY-MM-DD") & "T" & TimeToString(CurrentTime) & TimeOffset(SMb.GMTOffset);
  uid = MakeUUID;
  OpenXmlTagWithAttr("OTA_HotelRateAmountNotifRQ","xmlns=""http://www.opentravel.org/OTA/2003/05"" Version=""1.0"" TimeStamp=""" & timestamp & """ EchoToken=""" & uid & """",req);
  AddReuqestor(SMb,req);

  OpenXmlTagWithAttr("RateAmountMessages","HotelCode=""" & SMb.HotelCode & """",req);
  OpenXmlTag("RateAmountMessage",req);

  sendf = SetRoomTypeRateAtSiteMinder(SMb,ARr,req);

  CloseXmlTag("RateAmountMessage",req);
  CloseXmlTag("RateAmountMessages",req);
  CloseXmlTag("OTA_HotelRateAmountNotifRQ",req);

  AddTextToArea("</soap:Body>" ,req);
  AddTextToArea("</soap:Envelope>" ,req);

  if (SMb.LogCommunication) then begin
    LogAreaToFile(ProgramFolder & "/SiteMinder/" & "_siteminder_setrates_req.xml",req);
  end;
  if (sendf) then begin
    LogSiteMinderUUID(uid,kSOAPActionRequest,"HotelRateAmountNotifRQ",kSOAPReplyNone,"");
    gSiteMinderRequestUUID = uid;
    SendAsyncWebRequest(SMb.Host,443,-1,true,"POST","/pmsxchangev2/services/" & SMb.HotelID,"text/xml; charset=""utf-8""","pmsxchange/HotelRateAmountNotifRQ",req,"SendRatesToSiteMinderReply",30);
  end;
LSendRatesToSiteMinder:;  
  return;
end;

procedure AddRoomTypeToSiteMinderRates(record SiteMinderBlock SMb,record AgentRoomVc ARr,string resusageonly,var Area req)
begin
  Date sd,ed;
  Date rsd,red;
  record JobVc Jobr;    
  record ResVc Resr;
  record ResTypeVc RTr;
  record JobPriceVc JPr;
  row JobPriceVc JPrw;
  LongInt pos;
  Integer i,rwcnt; 
  string 255 tstr,artcode;
  string 255 resusages,resusage;
  record INVc INr;
  record BaseCurBlock BCb;
  val prevprice,price;
  string 255 weekdays;
  vector val vrates;
  vector string 255 vratesitem;
  Array string 255 aday;

  Resr.Code = ARr.ResCode;
  if (ReadFirstMain(Resr,1,true)) then begin    
    BlockLoad(BCb);
    RTr.Code = Resr.Type;
    ReadFirstMain(RTr,1,true);
    
    sd = ARr.StartDate;
    if (blankdate(sd) or sd<CurrentDate) then begin sd = CurrentDate; end;
    ed = ARr.EndDate;
    if (blankdate(ed) or ed<CurrentDate) then begin ed = CurrentDate; end;
    ed = AddDay(ed,1);
    
    resusages = ARr.ResUsage;
    if (blank(resusages)) then begin
      resusages = SMb.ResUsages;
    end;
    if (nonblank(resusageonly)) then begin
      if (SetInSet(resusageonly,resusages)) then begin
        resusages = resusageonly;
      end else begin
        resusages = "";
      end;
    end;
    pos = 0;
    GetNextSubstring(resusages,pos,",",resusage);
    while (nonblank(resusage)) begin    
      RecordNew(Jobr);
      Jobr.ResCode = Resr.Code;
      JobPasteResCode(Jobr,"");
      Jobr.CUCode = ARr.CUCode;
      PasteCUCodeToJob2(Jobr,-1,false);    
      Jobr.TransDate = sd;
      JobPasteTransDate(Jobr);
      Jobr.EndDate = ed;
      Jobr.NrOfDays = DateDiff(Jobr.EndDate,Jobr.TransDate);
      Jobr.Persons = RTr.MaxPersons;
      tstr = Jobr.ResUsage;
      Jobr.ResUsage = resusage;
      if (Jobr.ResUsage!=tstr) then begin
        JobPasteResUsage(Jobr,tstr);
      end;
      if (JobToJobPrices(Jobr,Jobr.Type,JPr)) then begin
        rwcnt = MatRowCnt(JPr);
        if (rwcnt==0) then begin
          MessageBox(39180," " & resusage);
          goto LSKIPRate;
        end;
        OpenXmlTag("RateAmountMessage",req);
        AddTextToArea("<StatusApplicationControl InvTypeCode=""" & Jobr.Type & """" & " RatePlanCode=""" & Jobr.ResUsage & """/>",req);  
        OpenXmlTag("Rates",req);

        rsd = Jobr.TransDate;
        red = AddDay(Jobr.EndDate,-1);
        prevprice = blankval;
        ClearVector(vrates);
        vrates[1] = blankval; vrates[2] = blankval; vrates[3] = blankval; vrates[4] = blankval; vrates[5] = blankval; vrates[6] = blankval; vrates[7] = blankval;
        
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(JPr,i,JPrw);
          if (prevprice==JPrw.Price or blank(prevprice)) then begin
            vrates[GetDateId(JPrw.StayDay)] = JPrw.Price;
            vratesitem[GetDateId(JPrw.StayDay)] = JPrw.ArtCode;
          end else begin
            GetVectorTags(vrates,aday);
            if (aday.length>0) then begin
              AddTextToArea("<Rate" & " CurrencyCode=""" & BCb.BaseCur1 & """ Start=""" & DateToString(rsd,"YYYY-MM-DD") & """ End=""" & DateToString(red,"YYYY-MM-DD") & """ ",req);
              price = blankval;
              weekdays = "";
              artcode = "";
                      
              weekdays = "Mon=""";
              if (blank(vrates[1])) then begin
                weekdays = weekdays & "0"" ";
              end else begin
                weekdays = weekdays & "1"" ";
                price = vrates[1];
                artcode = vratesitem[1];
              end;
              weekdays = weekdays & "Tue=""";
              if (blank(vrates[2])) then begin
                weekdays = weekdays & "0"" ";
              end else begin
                weekdays = weekdays & "1"" ";
                price = vrates[2];
                artcode = vratesitem[2];
              end;
              weekdays = weekdays & "Weds=""";
              if (blank(vrates[3])) then begin
                weekdays = weekdays & "0"" ";
              end else begin
                weekdays = weekdays & "1"" ";
                price = vrates[3];
                artcode = vratesitem[3];
              end;
              weekdays = weekdays & "Thur=""";
              if (blank(vrates[4])) then begin
                weekdays = weekdays & "0"" ";
              end else begin
                weekdays = weekdays & "1"" ";
                price = vrates[4];
                artcode = vratesitem[4];
              end;
              weekdays = weekdays & "Fri=""";
              if (blank(vrates[5])) then begin
                weekdays = weekdays & "0"" ";
              end else begin
                weekdays = weekdays & "1"" ";
                price = vrates[5];
                artcode = vratesitem[5];
              end;
              weekdays = weekdays & "Sat=""";
              if (blank(vrates[6])) then begin
                weekdays = weekdays & "0"" ";
              end else begin
                weekdays = weekdays & "1"" ";
                price = vrates[6];
                artcode = vratesitem[6];
              end;
              weekdays = weekdays & "Sun=""";
              if (blank(vrates[7])) then begin
                weekdays = weekdays & "0""";
              end else begin
                weekdays = weekdays & "1""";
                price = vrates[7];
                artcode = vratesitem[7];
              end;
        
              AddTextToArea(weekdays,req);  
              AddTextToArea(">",req);  
              OpenXmlTag("BaseByGuestAmts",req);
              AddTextToArea("<BaseByGuestAmt AmountAfterTax=""" & ValToString(price,M4Val,"",".",0) & """/>",req);      
              CloseXmlTag("BaseByGuestAmts",req);
/*              
              if (ReadFirstItem(artcode,INr,true,false)) then begin
                OpenXmlTag("RateDescription",req);
                AddXmlTag("Text",INr.Name,req);
                CloseXmlTag("RateDescription",req);
              end;
*/              
              CloseXmlTag("Rate",req);
            end;
            rsd = JPrw.StayDay;
            red = rsd;
            ClearVector(vrates);
            vrates[1] = blankval; vrates[2] = blankval; vrates[3] = blankval; vrates[4] = blankval; vrates[5] = blankval; vrates[6] = blankval; vrates[7] = blankval;
            vrates[GetDateId(JPrw.StayDay)] = JPrw.Price;
            vratesitem[GetDateId(JPrw.StayDay)] = JPrw.ArtCode;
          end;
          prevprice = JPrw.Price;
          red = JPrw.StayDay;
        end;

        GetVectorTags(vrates,aday);
        if (aday.length>0) then begin
          AddTextToArea("<Rate" & " CurrencyCode=""" & BCb.BaseCur1 & """ Start=""" & DateToString(rsd,"YYYY-MM-DD") & """ End=""" & DateToString(red,"YYYY-MM-DD") & """ ",req);
        
          price = blankval;
          weekdays = "";
          artcode = "";
        
          weekdays = "Mon=""";
          if (blank(vrates[1])) then begin
            weekdays = weekdays & "0"" ";
          end else begin
            weekdays = weekdays & "1"" ";
            price = vrates[1];
            artcode = vratesitem[1];
          end;
          weekdays = weekdays & "Tue=""";
          if (blank(vrates[2])) then begin
            weekdays = weekdays & "0"" ";
          end else begin
            weekdays = weekdays & "1"" ";
            price = vrates[2];
            artcode = vratesitem[2];
          end;
          weekdays = weekdays & "Weds=""";
          if (blank(vrates[3])) then begin
            weekdays = weekdays & "0"" ";
          end else begin
            weekdays = weekdays & "1"" ";
            price = vrates[3];
            artcode = vratesitem[3];
          end;
          weekdays = weekdays & "Thur=""";
          if (blank(vrates[4])) then begin
            weekdays = weekdays & "0"" ";
          end else begin
            weekdays = weekdays & "1"" ";
            price = vrates[4];
            artcode = vratesitem[4];
          end;
          weekdays = weekdays & "Fri=""";
          if (blank(vrates[5])) then begin
            weekdays = weekdays & "0"" ";
          end else begin
            weekdays = weekdays & "1"" ";
            price = vrates[5];
            artcode = vratesitem[5];
          end;
          weekdays = weekdays & "Sat=""";
          if (blank(vrates[6])) then begin
            weekdays = weekdays & "0"" ";
          end else begin
            weekdays = weekdays & "1"" ";
            price = vrates[6];
            artcode = vratesitem[6];
          end;
          weekdays = weekdays & "Sun=""";
          if (blank(vrates[7])) then begin
            weekdays = weekdays & "0""";
          end else begin
            weekdays = weekdays & "1""";
            price = vrates[7];
            artcode = vratesitem[7];
          end;
        
          AddTextToArea(weekdays,req);  
          AddTextToArea(">",req);  
          OpenXmlTag("BaseByGuestAmts",req);
          AddTextToArea("<BaseByGuestAmt AmountAfterTax=""" & ValToString(price,M4Val,"",".",0) & """/>",req);      
          CloseXmlTag("BaseByGuestAmts",req);
/*          
          if (ReadFirstItem(artcode,INr,true,false)) then begin
            OpenXmlTag("RateDescription",req);
            AddXmlTag("Text",INr.Name,req);
            CloseXmlTag("RateDescription",req);
          end;
*/          
          CloseXmlTag("Rate",req);
        end;


        CloseXmlTag("Rates",req);
        CloseXmlTag("RateAmountMessage",req);
LSKIPRate:;      
      end;
      GetNextSubstring(resusages,pos,",",resusage);
    end;    
  end;
  return;
end;

updating procedure SetRatesAtSiteMinder2(LongInt quenr,string type,string resusage,Date startdate,Date enddate)
begin
  Integer i;
  record SiteMinderBlock SMb;
  Area req;
