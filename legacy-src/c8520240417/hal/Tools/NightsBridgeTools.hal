procedure NightsBridgeLog(string filename,string type,area a)
begin
  record NightsBrigdeBlock NBb;
  string 255 fname;

  BlockLoad(NBb);
  if (NBb.LogCommunication!=0) then begin
    fname = CreateTempFile("_NB-" & filename & "-" & type,".txt");  
    WriteAreaToFile(a,fname,0);
  end;
  return;
end;

global
procedure NBEnableRoomsReply(Area reply,Area replyheader,boolean timeout)
begin
  json js;
  string 255 tstr;
  longint result;
  
  result = 0;
  NightsBridgeLog("NBEnableRooms","reply",reply);
  WriteAreaToFile(reply,"NBEnableRoomsreply.txt",0);

  tstr = GetStringFromArea(reply,0,255);
  if (timeout) then begin
    LogText2(39172," NBEnableRooms",kVerbosityDebugDetailed);
  end else begin
    js = ParseJSONArea(reply);
    if (JSONNodeExists(js,"success")) then begin 
      if (JSONGet(js,"success")=="true") then begin
        result = 43340;
      end else begin
        result = 43341;
      end;
    end else begin
      result = 43342;
    end;
  end;
  AllClientsRemoteAsync.SendNightsBridgeStatusMessage(result);

end;

procedure AddRoomTypeToNightsBridgeAvailable(date sd2,date ed2,string rate2,string type2,integer qty2, var string jsr)
begin
  integer cnt;

  jsr = jsr & "{";
  JSONStringAdd(jsr,"roomtypeid",type2);
  JSONStringAdd(jsr,"startdate",DateToString(sd2,"YYYY-MM-DD"));
  JSONStringAdd(jsr,"enddate",DateToString(ed2,"YYYY-MM-DD"));
  JSONStringPut(jsr,"roomsfree",qty2);
  JSONStringEnd(jsr);
  return;
end;

procedure AddToArr(string rescode,date sd,date ed, string rate,string type,integer qty, array string arescode,array date asd,array date aed, array string arate,array string atype,array integer aqty, var Integer acnt)
begin
  Integer i;

  arescode[acnt] = rescode;
  asd[acnt] = sd;
  aed[acnt] = ed;
  arate[acnt] = rate;
  atype[acnt] = type;
  aqty[acnt] = qty;
  acnt = acnt + 1;
  
  return;
end;

procedure CreateArray( array string arescode,array date asd,array date aed, array string arate,  array string atype,  array integer aqty, integer acnt)
begin
  Integer i;
  record AgentRoomVc ARr;   
  record AgentRoomVc ptARr;   
  record ResVc Resr;
  record ResVc ptResr;
  Date td,td2,ed;
  Time tt;
  Boolean found,testf;
  LongInt nr;
  record HotelBlock Hotelb;
  val q;
  Boolean includezeroavailf;
  Integer ReduceAvail;
  string 255  rescode,type,rate;
  integer qty;

  BlockLoad(Hotelb);
  found = true;
  while (LoopMain(ARr,1,found)) begin
    if (found) then begin
      testf = true;
      if (ARr.Closed!=0) then begin testf = false; end;
      if (blankdate(ARr.StartDate)) then begin testf = false; end;
      if (blankdate(ARr.EndDate))   then begin testf = false; end;
      if (blank(ARr.ResCode))       then begin testf = false; end;
      if (blank(ARr.StdTypeID))     then begin testf = false; end;
      if (blank(ARr.StdRateID))     then begin testf = false; end;
      if (testf) then begin
        td = CurrentDate;
        if (blankdate(td))    then begin td = ARr.StartDate;end;
        if (td<ARr.StartDate) then begin td = ARr.StartDate; end;
        ed = ARr.EndDate;
        if (blankdate(ed))  then begin ed = ARr.EndDate; end;
        if (ed>ARr.EndDate) then begin ed = ARr.EndDate; end;
        if (td<CurrentDate) then begin td = CurrentDate; end;   
        while (td<=ed) begin
          td2 = td;
          nr = HotelReservationExists(ARr.ResCode,"",td2,Hotelb.CheckIn,AddDay(td2,1),Hotelb.CheckOut);
          if (nr<=0) then begin
            AddToArr(ARr.ResCode,td,td,ARr.StdRateID,ARr.StdTypeID,1,arescode,asd, aed, arate, atype, aqty, acnt);
          end else begin
            AddToArr(ARr.ResCode,td,td,ARr.StdRateID,ARr.StdTypeID,0,arescode, asd, aed,  arate, atype, aqty, acnt);
          end;
          td = AddDay(td,1);
        end;
      end;
    end;
  end;  
  return;
end;

procedure SortArrayByType(var array string arescode,var array date aed,var array string arate,var array string atype,var array integer aqty)
begin
  Integer i;
  Boolean swapped;
  integer taqty;
  string 255 tarate,tatype,tarescode;
  date tasd,taed;

  swapped = true;
  while (swapped) begin
    swapped = false;
    for (i=0;i<atype.length-1;i=i+1) begin
      if (atype[i]>atype[i+1]) then begin
        tarescode = arescode[i];
        tatype = atype[i];
        taed = aed[i];
        tarate = arate[i];
        tatype = atype[i];
        taqty = aqty[i];
    
        arescode[i] = arescode[i+1];
        atype[i] =  atype[i+1];
        aed[i] = aed[i+1];
        arate[i] = arate[i+1];
        atype[i] = atype[i+1];
        aqty[i] =  aqty[i+1];
   
 
        arescode[i+1] = tarescode;
        atype[i+1] = tatype;
        aed[i+1] = taed;
        arate[i+1] = tarate;
        atype[i+1] = tatype;
        aqty[i+1] =  taqty;

        swapped = true;
      end;
    end;
  end;
return;
end;

procedure SortArrayByDate(var array string arescode,var array date asd,var array date aed,var array string arate,var array string atype,var array integer aqty)
begin
  Boolean swapped;
  string 255 tstate,trescode,trate,ttype;
  date ted,tsd;
  integer tqty;
  Integer i;

  swapped = true;
  while (swapped) begin
    swapped = false;
    for (i=0;i<asd.length-1;i=i+1) begin
      if (asd[i]>asd[i+1]) then begin
        tsd = asd[i];
        trescode = arescode[i];
        ted = aed[i];
        trate = arate[i];
        tqty = aqty[i];
        ttype = atype[i];

        asd[i] =  asd[i+1];
        arescode[i] = arescode[i+1];
        aed[i] = aed[i+1];
        arate[i] = arate[i+1];
        aqty[i] = aqty[i+1];
        atype[i] = atype[i+1];

        asd[i+1] = tsd;
        arescode[i+1]= trescode;
        aed[i+1] = ted;
        arate[i+1] = trate;
        aqty[i+1] = tqty;
        atype[i+1] = ttype;

        swapped = true;
      end;
    end;
  end;
return;
end;

procedure AddtoArray(string rescode,date sd, string rate,string type,integer qty,array string arescode,array date asd,array string arate,array string atype,array integer aqty,var Integer acnt)
begin
  Integer i;

  arescode[acnt] = rescode;
  asd[acnt] = sd;
  arate[acnt] = rate;
  atype[acnt] = type;
  aqty[acnt] = qty;
  acnt = acnt + 1;
  
  return;
end;

global
procedure NBEnableRooms()
begin
  Integer i,cnt,j;
  Area req;
  string 255 jsr;
  record NightsBrigdeBlock NBb;
  array string 255 arescode;
  array date asd,asd2;
  array date aed,aed2;
  array string 255 atype,arate,atype2,arate2,arescode2;
  array integer aqty,aqty2;
  integer acnt,acnt2;
  date d1;

  BlockLoad(NBb);
  if (NBb.Enable==0) or (blank(NBb.LoginKey))  then begin
    goto LNBEnableRooms;
  end;

  CreateArray(arescode,asd,aed,arate,atype,aqty,acnt);
  SortArrayByDate(arescode,asd,aed,arate,atype,aqty);

  for (i=0;i<asd.length;i=i+1) begin
    SortArrayByType(arescode,aed,arate,atype,aqty);
    if (arate[i]==arate[i+1] and aed[i]==aed[i+1] and atype[i]==atype[i+1]) then begin
      AddtoArray(arescode[i],aed[i],arate[i],atype[i],aqty[i]+aqty[i+1],arescode2,aed2,arate2,atype2,aqty2,acnt2);
    end else begin
      if (i!=0) then begin
        if (aed[i]==aed[i-1]) then begin
          AddtoArray(arescode[i],aed[i],arate[i],atype[i],aqty[i]+aqty[i-1],arescode2,aed2,arate2,atype2,aqty2,acnt2);
        end else begin
          AddtoArray(arescode[i],aed[i],arate[i],atype[i],aqty[i],arescode2,aed2,arate2,atype2,aqty2,acnt2);
        end;
      end else begin
        AddtoArray(arescode[i],aed[i],arate[i],atype[i],aqty[i],arescode2,aed2,arate2,atype2,aqty2,acnt2);
      end;  
    end;
  end;

  SetAreaZeroSize(req);
  JSONStringStart(jsr); 
  JSONStringAdd(jsr,"messagename","InventoryUpdateRQ");
  JSONStringMemberStart(jsr,"credentials");
  jsr = jsr & "{";
  JSONStringPut(jsr,"loginkey",NBb.LoginKey);
  JSONStringMemberEnd(jsr);  
  jsr = jsr & ",";
  JSONStringMemberStart(jsr,"inventoryupdates");
  JSONStringArrayStart(jsr);
  d1=aed2[0];

  for (j=0;j<acnt2;j=j+1) begin
      if (atype2[j]==atype2[j+1]) and (arate2[j]==arate2[j+1]) and (aqty2[j]!=aqty2[j+1]) then begin
        AddRoomTypeToNightsBridgeAvailable(d1,aed2[j+1],arate2[j],atype2[j],aqty2[j],jsr);
        d1=aed2[j+1];
        if (j!=acnt2-1) then begin 
          jsr = jsr & ",";
        end; 
      end else begin
        if (atype2[j]!=atype2[j+1]) then begin
          AddRoomTypeToNightsBridgeAvailable(d1,aed2[j],arate2[j],atype2[j],aqty2[j],jsr);
          d1 = aed2[j+1];
          if (j!=acnt2-1) then begin 
            jsr = jsr & ",";
          end;
        end;
      end;
  end; 

  JSONStringArrayEnd(jsr);
  JSONStringEnd(jsr);
  AddTextToArea(jsr,req);

  SendAsyncWebRequest("nightsbridge.co.za",443,-1,true,"POST","/bridge/bridgeconnect","application/json","",req,"NBEnableRoomsReply",60);
  NightsBridgeLog("NBEnableRooms","req",req);

  WriteAreaToFile(req,"NBEnableRoomsreq.txt",0);
LNBEnableRooms:;
  return;
end;

