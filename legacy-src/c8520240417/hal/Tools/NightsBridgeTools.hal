updating function Boolean PasteReservationDetails(var record JobVc Jobr,json js,Integer type,Integer room)
begin
  Integer cnt;
  string 255 key,mainkey;
  record NightsBrigdeBlock NBb;
  record CCatVc CCatr;
  record AgentRoomVc AgentRoomr;
  record CUVc CUr;
  row JobVc Jobrw;
  string 255 timestr,fullname,cucode,phoneno,tstr;
  Time regtime;
  Boolean res,found,testf;
  record HotelBlock Hotelb;
 
  BlockLoad(Hotelb);
  BlockLoad(NBb);

  res = true;

  RecordNew(Jobr);
  mainkey = "booking";
  Jobr.CurncyCode =   JSONGet(js,"currencycode");
  if (type!=kReservationTypeGroup) then begin
    Jobr.TransDate =  DateFromString(Left(JSONGet(js,mainkey & "/arrivaldate"),10),"YYYY-MM-DD");
    Jobr.EndDate =    DateFromString(Left(JSONGet(js,mainkey & "/departuredate"),10),"YYYY-MM-DD");
  end;
  Jobr.RegDate =      DateFromString(Left(JSONGet(js,mainkey & "/bookingdate"),10),"YYYY-MM-DD");
  Jobr.BookDate =     Jobr.RegDate;
  Jobr.ConfDate =     Jobr.RegDate;
  Jobr.RefStr =       JSONGet(js,mainkey & "/bookingid");
  Jobr.ConfComment =  JSONGet(js,mainkey & "/notes");
  Jobr.NrOfDays =     JSONGet(js,mainkey & "/nights");
  Jobr.ResStatus =    NBb.ResStatus;
  Jobr.ResUsage =     "";
  Jobr.Objects =      "";
  JobVc_PasteCurncyCode(Jobr,""); 
  JobPasteType(Jobr,"");
  JobPasteResUsage(Jobr,"");
  timestr = Right(JSONGet(js,mainkey & "bookingdate"),5);
  regtime.hour = StringToInt(left(timestr,2));
  regtime.minute = StringToInt(right(timestr,2));  
  Jobr.RegTime =  regtime;

  key = mainkey & "source";
  Jobr.BookOrigin = StringToInt(JSONGet(js,key & "sourceid"));

  Jobr.ReservationType = type;

  if (type==kReservationTypeGroup) then begin
    key = mainkey & "/madeby";
  end else begin
    key = mainkey & "/roomtypes/[" & room & "]/guest";
  end;

  fullname = JSONGet(js,key & "/firstname") & " " & JSONGet(js,key & "/surname");
  if (CustomerWithNameExists("",fullname)==false) then begin
    RecordNew(CUr);
    CUr.Title = JSONGet(js,key & "/title");
    CUr.Name = fullname;
    CUr.eMail = JSONGet(js,key & "/email");
    phoneno = JSONGet(js,key & "/phoneno");
    GetNextCustNr(CUr.Code);
    StripSpace(phoneno,CUr.Phone);
    CUr.Phone = phoneno; 
    if (nonblank(CUr.Code)) then begin
      RecordStore(CUr,false);
    end;
  end else begin
    // cucode = FindCUCode(fullname,"");
    CUr.Name = fullname;
    if (ReadFirstKey("Name",CUr,1,true)) then begin end;
  end;
  Jobr.CUCode = CUr.Code;
  PasteCUCodeToJob2(Jobr,-1,false);

  if (blank(Jobr.LangCode)) then begin
    Jobr.LangCode = CUr.LangCode;
  end;
  Jobr.Newspapers = CUr.Newspaper;
  Jobrw.GuestCode = Jobr.CUCode;   
  Jobrw.CUName = CUr.Name;   
  Jobrw.PriceList = CUr.PLCode;
  if (blank(Jobrw.PriceList)) then begin
    CCatr.Code = CUr.CustCat;
    ReadFirstMain(CCatr,1,true);
    Jobrw.PriceList = CCatr.PLCode;
  end;
  Jobrw.CClass = FindHotelClassForClassTerms(CUr.Classification);
  MatRowPut(Jobr,MatRowCnt(Jobr),Jobrw);
  AgentRoomr.StdTypeID = JSONGet(js,mainkey & "/roomtypes/[" & room & "]/roomtypeid");
  AgentRoomr.StdRateID = JSONGet(js,mainkey & "/roomtypes/[" & room & "]/ratecode");  
  found = true;
  while LoopBackKey("StdTypeID",AgentRoomr,2,found) begin
    testf =  true;
    if (AgentRoomr.StdTypeID != JSONGet(js,mainkey & "/roomtypes/[" & room & "]/roomtypeid")) then begin testf = false; end;
    if (AgentRoomr.StdRateID != JSONGet(js,mainkey & "/roomtypes/[" & room & "]/ratecode")) then begin testf = false; end;
    if (testf) then begin
      if (HotelReservationExists(AgentRoomr.ResCode,AgentRoomr.StdTypeID,Jobr.TransDate,Hotelb.CheckIn,Jobr.EndDate,Hotelb.CheckOut)==-1) then begin
        Jobr.ResCode = AgentRoomr.ResCode;
        res = true;
        goto LSkip;
      end else begin
        res = false;
      end;
    end;  
  end;
LSkip:;
  Jobr.Source = AgentRoomr.CUCode;
  Jobr.SourceName = AgentRoomr.CUName;
  Jobr.PLPrice = StringToVal(JSONGet(js,mainkey & "/roomtypes/[" & room & "]/roomrate"),M4Val);
  Jobr.SerNr = NextSerNr("JobVc",Jobr.TransDate,-1,false,"");
LPasteReservationDetails:;
  PasteReservationDetails = res;
  return;
end;

updating function Boolean CreateSubReservation(json js,record JobVc Jobp,Integer room)
begin
  string 255 key,mainkey;
  record JobVc Jobr;
  Boolean res;

  mainkey = "booking";
  key = mainkey & "/roomtypes/[" & room & "]";

  res = PasteReservationDetails(Jobr,js,kReservationTypeNormal,room);
  Jobr.Mother = Jobp.SerNr;
  Jobr.Sum4 = StringToVal(JSONGet(js,key & "/stayrate"),M4Val);
  Jobr.Persons = StringToInt(JSONGet(js,key & "/adults"));
  Jobr.Children = StringToInt(JSONGet(js,key & "/child1")) + StringToInt(JSONGet(js,key & "/child2"));
  Jobr.Type = JSONGet(js,key & "/roomtypeid");

  if (res) then begin
    res = RecordStore(Jobr,true);
  end;

  CreateSubReservation = res;
  return;
end;

updating function Boolean CreateGroupReservation(json js,var record JobVc Jobr,Integer room)
begin
  Boolean res;

  if (PasteReservationDetails(Jobr,js,kReservationTypeGroup,room)) then begin
    res = RecordStore(Jobr,false);
  end;
  CreateGroupReservation = res;
  return;
end;

function Boolean ReservationExists(json js)
begin
  string 255 mainkey,key;
  record AgentRoomVc AgentRoomr;
  record HotelBlock Hotelb;
  Date transdate,departuredate;
  Boolean res,found,testf;
  Integer i;

  res = true;
  BlockLoad(Hotelb);

  mainkey = "booking";
  transdate = DateFromString(Left(JSONGet(js,mainkey & "/arrivaldate"),10),"YYYY-MM-DD");
  departuredate = DateFromString(Left(JSONGet(js,mainkey & "/departuredate"),10),"YYYY-MM-DD");
  key = mainkey & "/roomtypes/[" & i & "]";
  while (JSONNodeExists(js,key)) begin
    AgentRoomr.StdTypeID = JSONGet(js,key & "/roomtypeid");
    AgentRoomr.StdRateID = JSONGet(js,key & "/ratecode");
    found = true;
    while LoopBackKey("StdTypeID",AgentRoomr,2,found) begin
      testf =  true;
      if (AgentRoomr.StdTypeID != JSONGet(js,key & "/roomtypeid")) then begin testf = false; end;
      if (AgentRoomr.StdRateID != JSONGet(js,key & "/ratecode")) then begin testf = false; end;
      if (testf) then begin
        if (HotelReservationExists(AgentRoomr.ResCode,AgentRoomr.StdTypeID,transdate,Hotelb.CheckIn,departuredate,Hotelb.CheckOut)==-1) then begin
          res = false;
          goto LReservationExists;
        end;
      end;  
    end;
    i = i + 1;
    key = mainkey & "/roomtypes/[" & i & "]";
  end;
LReservationExists:;
  ReservationExists = res;
  return;
end;

global
updating function Boolean AddReservations(area abookrq)
begin  
  record JobVc Jobr;
  Boolean res;
  string 255 bookingId,tstr;
  Integer cnt,i;
  json js;

  res = false;
  
  js = ParseJSONArea(abookrq);
  tstr = GetStringFromArea(abookrq,0,255);
  bookingId = JSONGet(js,"bbid");
  if (blank(bookingId)) then begin goto LAddReservations; end;

  cnt = JSONCountChildren(js,"booking/roomtypes");
  if (cnt<=0) then begin goto LAddReservations; end;
  if (ReservationExists(js)) then begin goto LAddReservations; end;
  if (cnt>1) then begin
    res = CreateGroupReservation(js,Jobr,0); 
    for (i=0;i<cnt;i=i+1) begin
      res = CreateSubReservation(js,Jobr,i);
      if (res==false) then begin goto LAddReservations; end;
    end;
  end else begin
    res = CreateSubReservation(js,Jobr,0);
  end;
LAddReservations:;
  AddReservations = res;
  return;
end;

