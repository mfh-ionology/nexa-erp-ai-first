end;

global webpublic
procedure WebNightsBridgeBookingRQUrl()
begin
  Boolean res;
  area a;
  json jsr;
  record NightsBrigdeBlock NBb;
  string 255 loginkey;
  Integer oldcomp;
  record CompaniesBlock Compb;
  row CompaniesBlock Comprw;
  Integer i,rwcnt;

  oldcomp = CurrentCompany;  
  BlockLoad(Compb);

  WebGetPostData(a);
  if (GetAreaLength(a)>0) then begin
    jsr = ParseJSONArea(a);
    loginkey = JSONGet(jsr,"loginkey");

    rwcnt = MatRowCnt(Compb);
    for (i=0;i<rwcnt;i=i+1) begin
      MatRowGet(Compb,i,Comprw);
      if (blank(Comprw.TCPIP)) then begin
        if (SetCompanyCode(Comprw.CompCode,false)) then begin
          BlockLoad(NBb);
          if (NBb.LoginKey==loginkey) then begin
            res = NBRetrieveRes(a);
            i = rwcnt;
          end;
        end;
      end;
    end;
  end;

  if (res) then begin
    WebOutBegin;
    { "success": true
    }
    EndWebOut;
  end else begin

      WebOutBegin;
      {
      "success": false,
      "error":  "This establishment is already reserved"
      }
    EndWebOut;
  end;
  NBEnableRooms;

  return;
end;


global 
procedure NBRetrieveResBUTTON()
begin
  area req;
  Boolean res;

  AddFileToArea("WebNightsBrigdeBookingRQUrl.txt",req,false);
  res = NBRetrieveRes(req);
  return;
end;