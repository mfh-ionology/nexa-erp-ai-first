global
function string 255 AsteriskHomeDir(record PBXConnectionVc PBXCr,Boolean localf)
begin
  record LocalAsteriskBlock LAb;
  string 255 res;

  if (blank(PBXCr.RemoteConfigDir) or localf) then begin
    BlockLoad(LAb);
    res = LAb.LocalAsteriskDir;
  end else begin
    res = PBXCr.RemoteConfigDir;
  end;

  AsteriskHomeDir = res;
  return;
end;

global
function string 255 AsteriskConfigBaseDir(record PBXConnectionVc PBXCr,Boolean localf)
begin
  string 255 res;
  record LocalAsteriskBlock LAb;

  BlockLoad(LAb);

  if ((nonblank(LAb.LocalAsteriskDir) and (PublicHostName==PBXCr.PBXHostIP)) or localf) then begin
    res = AsteriskHomeDir(PBXCr,true);
  end else begin
    if (nonblank(PBXCr.AsteriskControllerKey)) then begin
      res = "tmp/RemoteAsteriskConfig-" & PBXCr.Code;
    end;
    if (blank(res)) then begin
      res = "tmp/AsteriskConfig-" & PBXCr.Code;
    end;
  end;
  AsteriskConfigBaseDir = res;
end;


function string 255 AsteriskLocalHomeDir()
begin
  record PBXConnectionVc PBXCr;
  AsteriskLocalHomeDir = AsteriskHomeDir(PBXCr,true);
end;

function string 255 AsteriskPidFile()
begin
  string 255 res;

  res = AsteriskLocalHomeDir & "/var/run/asterisk/asterisk.pid";
  //LogText(0,"AsteriskPidFile: " & res);

  AsteriskPidFile = res;
  return;
end;

function string 255 ReadStringFromFile(string filename)
begin
  string 255 res;
  area a;

  AddFileToArea(filename,a,false);
  res = Trim(GetStringFromArea(a,0,GetAreaLength(a)));
  ReadStringFromFile = res;

  return;
end;

function LongInt ReadLongFromFile(string filename)
begin
  LongInt res;
  area a;

  ReadLongFromFile = StringToLongInt(ReadStringFromFile(filename));

  return;
end;

global
function LongInt AsteriskPid()
begin
  LongInt res;
  LongInt lpid;
  string 255 pid_file;

  res = -1;
  pid_file = AsteriskPidFile();
  lpid = ReadLongFromFile(pid_file);

  if (PidIsRunning(lpid)) then begin
    res = lpid;
  end;
  AsteriskPid = res;
  return;
end;

procedure DetectAndFixDuplicateAsteriskProcs()
begin
  LongInt lpid,last_pid,proc_pid;
  string 255 tstr;
  
LDetectAndFixDuplicateAsteriskProcs_again:
  lpid = AsteriskPid;
  RunShellScriptGetStdout("ps x |grep asterisk_orig |grep -v -- -R |grep -v -- -RC |grep -v -- -CR|grep -v grep |grep -v -- " & lpid & " 2>/dev/null |awk '{print $1}'|tail -1",tstr);
  tstr = trim(tstr);
  proc_pid = StringToLongInt(tstr);
  if (proc_pid>0) then begin
    if (proc_pid!=last_pid) then begin
      LogText(0,"Stopping duplicate Asterisk process: " & proc_pid);
      StopExternalProcess(lpid); // If a duplicate is found, we kill the currently running process also, as it might be hung
      StopExternalProcess(proc_pid);
    end else begin
      LogText(0,"Forcefully stopping duplicate Asterisk process: " & proc_pid);
      ForceStopExternalProcess(lpid);
      ForceStopExternalProcess(proc_pid);
    end;
    last_pid = proc_pid;
    goto LDetectAndFixDuplicateAsteriskProcs_again;
  end;
  
  return;
end;

global
procedure StartAsteriskIfNeeded()
begin
  LongInt lpid;
  string 255 cmd,args;

  if (DirExists(AsteriskLocalHomeDir)==false) then begin
    if (GetGlobalBoolean("AsteriskRunningLogged")==false) then begin
      LogText(0,"ERROR: Can't start Asterisk because it is not installed");
      SetGlobalBoolean("AsteriskRunningLogged",true);
    end;
    goto LStartAsteriskIfNeeded;
  end;

  if (IncreaseVmLong("starting_asterisk",1)==false) then begin goto LStartAsteriskIfNeeded; end;

  lpid = AsteriskPid;

  if (lpid==-1 or PidIsRunning(lpid)==false) then begin
    goto LStartAsteriskIfNeeded;
    
    cmd = AsteriskLocalHomeDir & "/sbin/asterisk";
    args = "-C " & AsteriskLocalHomeDir & "/etc/asterisk/asterisk.conf";
    LogText(0,"Starting Asterisk with command " & cmd & " " & args);
    RunShellScript(cmd & " " & args);
    SetGlobalBoolean("AsteriskRunningLogged",false);
  end else begin
    if (GetGlobalBoolean("AsteriskRunningLogged")==false) then begin
      LogText(0,"Asterisk process running, pid:" & lpid);
      SetGlobalBoolean("AsteriskRunningLogged",true);
      DetectAndFixDuplicateAsteriskProcs;
    end;
  end;
  
  ChangeVmLong("starting_asterisk",-1);

LStartAsteriskIfNeeded:
  return;
end;

global
procedure ReloadAsteriskConfiguration()
begin
  LongInt lpid;
  string 255 cmd,args;

  lpid = AsteriskPid;
  if (lpid>0 and PidIsRunning(lpid)) then begin
    cmd = AsteriskLocalHomeDir & "/sbin/asterisk";
    args = "-RC " & AsteriskLocalHomeDir & "/etc/asterisk/asterisk.conf";
    args = args & " -x \"core restart when convenient\"";
    LogText(0,"Reloading Asterisk configuration with command " & cmd & " " & args);
    RunShellScript(cmd & " " & args);
  end;
  return;
end;

global
procedure ReloadAsteriskLoggerConfiguration()
begin
  LongInt lpid;
  string 255 cmd,args;

  lpid = AsteriskPid;
  if (lpid>0 and PidIsRunning(lpid)) then begin
    cmd = AsteriskLocalHomeDir & "/sbin/asterisk";
    args = "-RC " & AsteriskLocalHomeDir & "/etc/asterisk/asterisk.conf";
    args = args & " -x \"logger reload\"";
    RunShellScript(cmd & " " & args);
  end;
  return;
end;

global
procedure StopAsterisk()
begin
  LongInt lpid;

  lpid = AsteriskPid;
  if (lpid>0) then begin
    LogText(0,"Stopping Asterisk process " & lpid);
    DetectAndFixDuplicateAsteriskProcs;
    StopExternalProcess(lpid);
  end;
  return;
end;

