global
updating procedure CreateMusicOnHoldConf(record PBXConnectionVc PBXCr,Boolean localf)
begin
  area a_conf;
  string 255 conf_file;

  CreateFolderHierarchy(AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/");
  conf_file = AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/musiconhold.conf";
  AddLineToArea("[general]",a_conf);
  AddLineToArea("[default]",a_conf);
  AddLineToArea("mode=files",a_conf);
  AddLineToArea("directory=" & AsteriskHomeDir(PBXCr,localf) & "/var/lib/asterisk/moh",a_conf);
  AddLineToArea("[HW]",a_conf);
  AddLineToArea("mode=files",a_conf);
  AddLineToArea("directory=" & AsteriskHomeDir(PBXCr,localf) & "/var/lib/asterisk/sounds-moh",a_conf);
  WriteAreaToFile(a_conf,conf_file,0);
end;

global
updating procedure CreateRTPConf(record PBXConnectionVc PBXCr,Boolean localf)
begin
  area a_conf;
  string 255 conf_file;

  CreateFolderHierarchy(AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/");
  conf_file = AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/rtp.conf";
  AddLineToArea("[general]",a_conf);
  AddLineToArea("rtpstart=10000",a_conf);   //##
  AddLineToArea("rtpend=20000",a_conf);
  WriteAreaToFile(a_conf,conf_file,0);
end;

procedure DefineGenericQueue(area a_conf,record PBXQueueVc PBXQr)
begin
  AddLineToArea("[HWQUEUE" & PBXQr.Code & "]",a_conf);
  AddLineToArea("strategy=ringall",a_conf);
  //AddLineToArea("joinempty=unavailable,invalid,wrapup",a_conf);
  AddLineToArea("joinempty=paused,inuse,ringing,unavailable,invalid,wrapup",a_conf);
  //AddLineToArea("joinempty=yes",a_conf);
  AddLineToArea("musicclass=HW",a_conf);
  AddLineToArea("wrapuptime=10",a_conf);
  AddLineToArea("ringinuse=no",a_conf);
  //AddLineToArea("leavewhenempty=yes,wrapup",a_conf);
  AddLineToArea("leavewhenempty=paused,inuse,unavailable,invalid",a_conf);
  //AddLineToArea("leavewhenempty=no",a_conf);
  AddLineToArea("timeout=60",a_conf);
  AddLineToArea("setinterfacevar=yes",a_conf);
  AddLineToArea("setqueuevar=yes",a_conf);
  return;
end;

global
function Integer MaxAnnaConversations()
begin
  Integer res;
  // TODO: Setting should be in system>settings>configuration (moduleblock)
  res = 20;
  MaxAnnaConversations = res;
  return;
end;

global
function string 255 AnnaSIPUserName(record PBXConnectionVc PBXCr,Integer idx)
begin
  string 255 res;
  res = "HWANNA_" & PBXCr.Code & "_USER_" & right("0000" & idx + 1,5);
  AnnaSIPUserName = res;
  return;
end;

function string 255 AnnaQueueName(record PBXConnectionVc PBXCr)
begin
  string 255 res;
  res = "HWQUEUE-ANNA_" & PBXCr.Code;
  AnnaQueueName = res;
  return;
end;

procedure DefineAnnaQueue(area a_conf,record PBXConnectionVc PBXCr)
begin
  Integer idx;
  
  AddLineToArea("[" & AnnaQueueName(PBXCr) & "]",a_conf);
  AddLineToArea("strategy=rrmemory",a_conf);
  AddLineToArea("servicelevel=0",a_conf);
  AddLineToArea("joinempty=yes",a_conf);
  AddLineToArea("musicclass=HW",a_conf);
  AddLineToArea("wrapuptime=0",a_conf);
  AddLineToArea("autopause=no",a_conf);
  AddLineToArea("ringinuse=no",a_conf);
  AddLineToArea("leavewhenempty=no",a_conf);
  AddLineToArea("timeout=3",a_conf);
  AddLineToArea("retry=0",a_conf);
  AddLineToArea("setinterfacevar=yes",a_conf);
  AddLineToArea("setqueuevar=yes",a_conf);
  AddLineToArea("announce-frequency=0",a_conf);

  for (idx=0; idx<MaxAnnaConversations; idx = idx + 1) begin
    AddLineToArea("member => PJSIP/" & AnnaSIPUserName(PBXCr,idx),a_conf);
  end;
  
  return;
end;

global
function Boolean PBXConnectionSupportsAnna(record PBXConnectionVc PBXCr,var string password)
begin
  Boolean res;
  record SipTrunk2Vc STr;
  record PBXIVRTreeVc PBXIVRTreer;
  Integer idx,rwcnt;
  row PBXIVRTreeVc PBXIVRTreerw;
  Boolean testf,test2f,foundf,found2f;
  record PBXQueueVc PBXQr;
  
  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      ResetLoop(PBXQr);
      PBXQr.SipTrunk = STr.Code;
      found2f = true;
      while (LoopKey("SipTrunk",PBXQr,1,found2f)) begin
        if (PBXQr.SipTrunk!=STr.Code) then begin found2f = false; end;
        test2f = found2f;
        if (PBXQr.Closed!=0) then begin test2f = false; end;
        if (test2f==true) then begin
          if (PBXQr.DirectToAnnaFlag!=0 and nonblank(PBXQr.AnnaPassword)) then begin
            password = PBXQr.AnnaPassword;
            res = true;
            goto LPBXConnectionSupportsAnna;
          end;
        end;
      end;

      ResetLoop(PBXIVRTreer);
      PBXIVRTreer.SipTrunk = STr.Code;
      found2f = true;
      while (LoopKey("SipTrunk",PBXIVRTreer,1,found2f)) begin
        if (PBXIVRTreer.SipTrunk!=STr.Code) then begin found2f = false; end;
        test2f = found2f;
        if (PBXIVRTreer.Closed!=0) then begin test2f = false; end;
        if (test2f==true) then begin
          rwcnt = MatRowCnt(PBXIVRTreer);
          for (idx = 0; idx<rwcnt; idx = idx + 1) begin
            MatRowGet(PBXIVRTreer,idx,PBXIVRTreerw);
            if (PBXIVRTreerw.AnnaFlag!=0 and nonblank(PBXIVRTreerw.AnnaPassword)) then begin
              password = PBXIVRTreerw.AnnaPassword;
              res = true;
              goto LPBXConnectionSupportsAnna;
            end;
          end;
        end;
      end;
    end;
  end;
  
LPBXConnectionSupportsAnna:;
  PBXConnectionSupportsAnna = res;
  return;
end;

global
updating procedure CreateQueuesConf(record PBXConnectionVc PBXCr,Boolean localf)
begin
  area a_conf;
  string 255 conf_file,tstr;
  record PBXQueueVc PBXQr;
  record SipTrunk2Vc STr;
  Boolean testf,foundf,found2f,test2f;

  CreateFolderHierarchy(AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/");
  conf_file = AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/queues.conf";

  AddLineToArea("[general]",a_conf);
  AddLineToArea("persistentmembers=yes",a_conf);
  AddLineToArea("autofill=yes",a_conf);
  AddLineToArea("monitor-type=MixMonitor",a_conf);
  AddLineToArea("shared_lastcall=no",a_conf);

  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      ResetLoop(PBXQr);
      PBXQr.SipTrunk = STr.Code;
      found2f = true;
      while (LoopKey("SipTrunk",PBXQr,1,found2f)) begin
        if (PBXQr.SipTrunk!=STr.Code) then begin found2f = false; end;
        test2f = found2f;
        if (PBXQr.Closed!=0) then begin test2f = false; end;
        if (test2f==true) then begin
          if (PBXQr.DirectToAnnaFlag==0) then begin
            DefineGenericQueue(a_conf,PBXQr);
          end;
        end;
      end;
    end;
  end;

  if (PBXConnectionSupportsAnna(PBXCr,tstr)) then begin
    DefineAnnaQueue(a_conf,PBXCr);
  end;

  WriteAreaToFile(a_conf,conf_file,0);
  return;
end;

function string 255 DefaultSIPTrunk(record PBXConnectionVc PBXCr,string astusername)
begin
  string 255 res;
  record SipTrunk2Vc STr;
  record UserDefSipTrunkVc UDSTr;
  Boolean foundf,testf;

  UDSTr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopMain(UDSTr,1,foundf)) begin
    if (UDSTr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (blank(UDSTr.AstUserName)) then begin
      res = UDSTr.SipTrunk;
    end;
    if (UDSTr.AstUserName==astusername) then begin
      res = UDSTr.SipTrunk;
      goto LDefaultSIPTrunk;
    end;
  end;

  if (nonblank(res)) then begin goto LDefaultSIPTrunk; end;
  
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (STr.Type!=kAsteriskTrunkTypeOutbound) then begin testf = false; end;
    if (testf) then begin
      res = STr.Code;
      goto LDefaultSIPTrunk;
    end;
  end;
  
LDefaultSIPTrunk:;
  DefaultSIPTrunk = res;
  return;
end;

procedure AddOneUserToPJSIPConf(record PBXConnectionVc PBXCr,string UserName,string Password,string CallerIdName,string CallerIdNumber,area a_conf)
begin
  string 255 defsiptrunk;
  
  AddLineToArea("[" & UserName & "](HW_USERS)",a_conf);
  AddLineToArea("secret=" & Password,a_conf);
  //AddLineToArea("callerid=""" & CallerIdName & """ <" & CallerIdNumber & ">",a_conf);
  AddLineToArea("callerid=""" & CallerIdName & """ <" & UserName & ">",a_conf);

  AddLineToArea("[" & UserName & "](HW_USERS)",a_conf);
  AddLineToArea("type=endpoint",a_conf);
  AddLineToArea("auth=" & UserName,a_conf);
  AddLineToArea("aors=" & UserName,a_conf);
  //AddLineToArea("callerid=\"" & CallerIdName & "\" <" & CallerIdNumber & ">",a_conf);
  AddLineToArea("callerid=\"" & CallerIdName & "\" <" & UserName & ">",a_conf);
  AddLineToArea("context=HW_EXTENSIONS",a_conf);
  AddLineToArea("set_var=IAXVAR(HW_IAX_SOURCE)=HW_NOT_IAX",a_conf);

  defsiptrunk = DefaultSIPTrunk(PBXCr,UserName);
  if (nonblank(defsiptrunk)) then begin
    AddLineToArea("set_var=DIALCOUNTRY=HW_SIPTRUNK_" & defsiptrunk,a_conf);
  end;

  AddLineToArea("[" & UserName & "](HW_USERS_AORS)",a_conf);
  AddLineToArea("type=aor",a_conf);
  
  AddLineToArea("[" & UserName & "]",a_conf);
  AddLineToArea("type=auth",a_conf);
  AddLineToArea("auth_type=userpass",a_conf);
  AddLineToArea("password=" & Password,a_conf);
  AddLineToArea("username=" & UserName,a_conf);

  return;
end;

procedure AddOneUserToSIPConf(string UserName,string Password,string CallerIdName,string CallerIdNumber,area a_conf)
begin
  AddLineToArea("[" & UserName & "](HW_USERS)",a_conf);
  AddLineToArea("secret=" & Password,a_conf);
  //AddLineToArea("callerid=""" & CallerIdName & """ <" & CallerIdNumber & ">",a_conf);
  AddLineToArea("callerid=""" & CallerIdName & """ <" & UserName & ">",a_conf);
  return;
end;

procedure AddOneUserToConf(record PBXConnectionVc PBXCr,Boolean pjsipf,string UserName,string Password,string CallerIdName,string CallerIdNumber,area a_conf)
begin
  if (pjsipf) then begin
    AddOneUserToPJSIPConf(PBXCr,UserName,Password,CallerIdName,CallerIdNumber,a_conf);
  end else begin
    AddOneUserToSIPConf(UserName,Password,CallerIdName,CallerIdNumber,a_conf);
  end;
  return;
end;

procedure AddUsersToConf(record PBXConnectionVc PBXCr,Boolean pjsipf,area a_conf)
begin
  record AsteriskUser2Vc AsteriskUserr;
  record UserVc Userr;
  record GlobalUserVc GUserr;
  string 255 tstr,password;
  LongInt pos;
  Integer idx;
  Boolean testf;
  vector Boolean uservec;

  while (LoopMain(AsteriskUserr,1,true)) begin
    testf = false;
    if (AsteriskUserr.Closedf==0) then begin
      if (blank(AsteriskUserr.PBXConnection)) then begin testf = true; end;
      pos = 0;
      while (GetNextSubstring(AsteriskUserr.PBXConnection,pos,",",tstr)) begin
        if ((tstr==PBXCr.Code) or (PBXCr.AllUsersFlag!=0)) then begin
          if (IsValidPBXConnection(tstr)) then begin
            testf = true;
          end;
        end;
      end;
    end;
    if (testf) then begin
      if (uservec[AsteriskUserr.UserName]==false) then begin
        AddOneUserToConf(PBXCr,pjsipf,AsteriskUserr.UserName,AsteriskUserr.Password,AsteriskUserr.CallerIdName,AsteriskUserr.CallerIdNumber,a_conf);
        uservec[AsteriskUserr.UserName] = true;
      end;
    end;
  end;
  while (LoopMain(GUserr,1,true)) begin
    testf = false;
    if (GUserr.Closed==0) then begin
      if (blank(GUserr.AstPBXConnection)) then begin testf = true; end;
      pos = 0;
      while (GetNextSubstring(GUserr.AstPBXConnection,pos,",",tstr)) begin
        if ((tstr==PBXCr.Code) or (PBXCr.AllUsersFlag!=0)) then begin
          if (IsValidPBXConnection(tstr)) then begin
            testf = true;
          end;
        end;
      end;
    end;
    if (blank(GUserr.AstUserName)) then begin testf = false; end;
    if (testf) then begin
      if (uservec[GUserr.AstUserName]==false) then begin
        AddOneUserToConf(PBXCr,pjsipf,GUserr.AstUserName,GUserr.AstPassword,GUserr.Name,GUserr.AstCallerIdNumber,a_conf);
        uservec[GUserr.AstUserName] = true;
      end;
    end;
  end;
  while (LoopMain(Userr,1,true)) begin
    testf = false;
    if (Userr.Closed==0) then begin
      if (blank(Userr.AstPBXConnection)) then begin testf = true; end;
      pos = 0;
      while (GetNextSubstring(Userr.AstPBXConnection,pos,",",tstr)) begin
        if ((tstr==PBXCr.Code) or (PBXCr.AllUsersFlag!=0)) then begin
          if (IsValidPBXConnection(tstr)) then begin
            testf = true;
          end;
        end;
      end;
    end;
    if (blank(Userr.AstUserName)) then begin testf = false; end;
    if (testf) then begin
      if (uservec[Userr.AstUserName]==false) then begin
        AddOneUserToConf(PBXCr,pjsipf,Userr.AstUserName,Userr.AstPassword,Userr.Name,Userr.AstCallerIdNumber,a_conf);
        uservec[Userr.AstUserName] = true;
      end;
    end;
  end;

  if (PBXConnectionSupportsAnna(PBXCr,password)) then begin
    for (idx=0; idx<MaxAnnaConversations; idx = idx + 1) begin
      AddOneUserToConf(PBXCr,pjsipf,AnnaSIPUserName(PBXCr,idx),password,"Anna the Bot","",a_conf);
    end;
  end;

  return;
end;

global
updating procedure CreatePJSIPConf(record PBXConnectionVc PBXCr,Boolean localf)
begin
  area a_conf;
  string 255 conf_file,tstr,username;
  Boolean foundf,testf;
  record SipTrunk2Vc STr;
  row SipTrunk2Vc STrw;
  Integer i,rwcnt;
  LongInt pos;

  if (UseChanPJSIP(PBXCr)==false) then begin
    goto LCreatePJSIPConf;
  end;
  
  CreateFolderHierarchy(AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/");
  conf_file = AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/pjsip.conf";

  AddLineToArea("[global]",a_conf);
  AddLineToArea("type=global",a_conf);
  AddLineToArea("user_agent=Asterisk PBX 18 - StandardERP Configuration",a_conf);

  tstr = DefaultSIPTrunk(PBXCr,"");
  if (nonblank(tstr)) then begin
    AddLineToArea("default_outbound_endpoint=HW_SIPTRUNK_" & tstr,a_conf);
  end;
  
  AddLineToArea("[transport-udp]",a_conf);
  AddLineToArea("type=transport",a_conf);
  AddLineToArea("protocol=udp",a_conf);
  AddLineToArea("bind=0.0.0.0",a_conf);
  AddLineToArea("external_media_address=" & PBXCr.PBXHostIP,a_conf);
  AddLineToArea("external_signaling_address=" & PBXCr.PBXHostIP,a_conf);

  AddLineToArea("[transport-udp-ipv6]",a_conf);
  AddLineToArea("type=transport",a_conf);
  AddLineToArea("protocol=udp",a_conf);
  AddLineToArea("bind=::",a_conf);
  
  //AddLineToArea("[transport-tls]",a_conf);
  //AddLineToArea("type=transport",a_conf);
  //AddLineToArea("protocol=tls",a_conf);
  //AddLineToArea("bind=0.0.0.0",a_conf);
  //AddLineToArea("cert_file=...",a_conf);
  //AddLineToArea("priv_key_file=...",a_conf);
  //AddLineToArea("cipher=ADH-AES256-SHA,ADH-AES128-SHA",a_conf);
  //AddLineToArea("method=tlsv1",a_conf);

  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      AddLineToArea("[HW_SIPTRUNK_" & STr.Code & "]",a_conf);
      AddLineToArea("type=endpoint",a_conf);
      if (nonblank(STr.Proxy)) then begin
        AddLineToArea("outbound_proxy=sip:" & STr.Proxy & "\\;lr",a_conf);
      end;
      AddLineToArea("aors=HW_SIPTRUNK_" & STr.Code,a_conf);
      AddLineToArea("outbound_auth=HW_SIPTRUNK_" & STr.Code & "_AUTH",a_conf);
      AddLineToArea("context=HW_INBOUND",a_conf);
      AddLineToArea("transport=transport-udp",a_conf);
      if (blank(STr.FromUser)) then begin
        AddLineToArea("from_user=" & STr.Username,a_conf);
      end else begin
        AddLineToArea("from_user=" & STr.FromUser,a_conf);
      end;
      if (nonblank(STr.Domain)) then begin
        AddLineToArea("from_domain=" & Trim(STr.Domain),a_conf);
      end;
      //AddLineToArea("disallow=all",a_conf);
      AddLineToArea("allow=alaw",a_conf);
      AddLineToArea("allow=ulaw",a_conf);
      //AddLineToArea("allow=opus",a_conf);
      if (nonblank(STr.Domain)) then begin
        AddLineToArea("[HW_SIPTRUNK_" & STr.Code & "]",a_conf);
        AddLineToArea("type=aor",a_conf);
        if (nonblank(STr.Proxy)) then begin
          AddLineToArea("outbound_proxy=sip:" & STr.Proxy & "\\;lr",a_conf);
        end;
        AddLineToArea("contact=sip:" & STr.Domain,a_conf);
        AddLineToArea("qualify_frequency=120",a_conf);
      end;
      AddLineToArea("[HW_SIPTRUNK_" & STr.Code & "_AUTH]",a_conf);
      AddLineToArea("type=auth",a_conf);
      AddLineToArea("auth_type=userpass",a_conf);
      if (nonblank(STr.Username)) then begin
        AddLineToArea("username=" & STr.Username,a_conf);
      end else begin
        AddLineToArea("username=" & STr.FromUser,a_conf);
      end;
      AddLineToArea("password=" & STr.Password,a_conf);
      
      if (STr.Type==kAsteriskTrunkTypeOutbound) then begin
        rwcnt = MatRowCnt(STr);
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(STr,i,STrw);
          username = STrw.AuthUsername;
          if (blank(username)) then begin username = STrw.Username; end;
          if (nonblank(username)) then begin
            AddLineToArea("[HW_SIPTRUNK_" & STr.Code & "_REG_" & i & "_AUTH]",a_conf);
            AddLineToArea("type=auth",a_conf);
            AddLineToArea("auth_type=userpass",a_conf);
            AddLineToArea("username=" & username,a_conf);
            AddLineToArea("password=" & STrw.Password,a_conf);
          end;
          AddLineToArea("[HW_SIPTRUNK_" & STr.Code & "_REG_" & i & "]",a_conf);
          AddLineToArea("type=registration",a_conf);
          if (nonblank(STr.Proxy)) then begin
            AddLineToArea("outbound_proxy=sip:" & STr.Proxy & "\\;lr",a_conf);
          end;
          AddLineToArea("auth_rejection_permanent=no",a_conf);
          AddLineToArea("retry_interval=1",a_conf);
          AddLineToArea("forbidden_retry_interval=300",a_conf);
          AddLineToArea("max_retries=120",a_conf);

          AddLineToArea("transport=transport-udp",a_conf);
          if (nonblank(username)) then begin
            AddLineToArea("outbound_auth=HW_SIPTRUNK_" & STr.Code & "_REG_" & i & "_AUTH",a_conf);
          end else begin
            AddLineToArea("outbound_auth=HW_SIPTRUNK_" & STr.Code & "_AUTH",a_conf);
          end;
          AddLineToArea("server_uri=sip:" & STrw.Domain,a_conf);
          AddLineToArea("client_uri=sip:" & STrw.Username & "@" & STrw.Domain,a_conf);
          AddLineToArea("contact_user=" & STrw.Username,a_conf);
          AddLineToArea("[HW_SIPTRUNK_" & STr.Code & "_REG_" & i & "_AOR]",a_conf);
          AddLineToArea("type=aor",a_conf);
          if (nonblank(STr.Proxy)) then begin
            AddLineToArea("outbound_proxy=sip:" & STr.Proxy & "\\;lr",a_conf);
          end;
          AddLineToArea("contact=sip:" & STrw.Domain,a_conf);
          AddLineToArea("qualify_frequency=120",a_conf);
          AddLineToArea("[HW_SIPTRUNK_" & STr.Code & "_REG_" & i & "_ENDPOINT]",a_conf);
          AddLineToArea("type=endpoint",a_conf);
          if (nonblank(STr.Proxy)) then begin
            AddLineToArea("outbound_proxy=sip:" & STr.Proxy & "\\;lr",a_conf);
          end;
          AddLineToArea("transport=transport-udp",a_conf);
          AddLineToArea("context=HW_INBOUND",a_conf);
          AddLineToArea("disallow=all",a_conf);
          AddLineToArea("allow=alaw",a_conf);
          AddLineToArea("allow=ulaw",a_conf);
          if (nonblank(username)) then begin
            AddLineToArea("outbound_auth=HW_SIPTRUNK_" & STr.Code & "_REG_" & i & "_AUTH",a_conf);
          end else begin
            AddLineToArea("outbound_auth=HW_SIPTRUNK_" & STr.Code & "_AUTH",a_conf);
          end;
          AddLineToArea("aors=HW_SIPTRUNK_" & STr.Code & "_REG_" & i & "_AOR",a_conf);
          AddLineToArea("[HW_SIPTRUNK_" & STr.Code & "_REG_" & i & "_IDENTIFY]",a_conf);
          AddLineToArea("type=identify",a_conf);
          AddLineToArea("match=" & STrw.Domain,a_conf);
          AddLineToArea("endpoint=HW_SIPTRUNK_" & STr.Code & "_REG_" & i & "_ENDPOINT",a_conf);
        end;
      end;
      if (nonblank(STr.AllowedIPs)) then begin
        AddLineToArea("[HW_SIPTRUNK_" & STr.Code & "_IDENTIFY]",a_conf);
        AddLineToArea("type=identify",a_conf);
        AddLineToArea("endpoint=HW_SIPTRUNK_" & STr.Code,a_conf);
        pos = 0;
        while (GetNextSubstring(STr.AllowedIPs,pos,",",tstr)) begin
          AddLineToArea("match=" & tstr,a_conf);
        end;
      end;
    end;
  end;
  
  AddLineToArea("[HW_USERS]",a_conf);
  AddLineToArea("from_domain=" & PBXCr.PBXHostIP,a_conf);
  AddLineToArea("transport=transport-udp",a_conf);
  AddLineToArea("set_var=IAXVAR(HW_IAX_SOURCE)=HW_NOT_IAX",a_conf);
  //AddLineToArea("disallow=all",a_conf);
  AddLineToArea("allow=opus",a_conf);
  AddLineToArea("allow=alaw",a_conf);
  AddLineToArea("allow=ulaw",a_conf);
  AddLineToArea("direct_media=no",a_conf);
  AddLineToArea("rtp_symmetric=yes",a_conf);
  AddLineToArea("force_rport=yes",a_conf);
  AddLineToArea("rewrite_contact=yes",a_conf);
  AddLineToArea("ice_support=no",a_conf); // maybe we need this to be on - but if so, we should turn it off for the Anna users
  
  AddLineToArea("[HW_USERS_AORS]",a_conf);
  AddLineToArea("max_contacts=1",a_conf);
  AddLineToArea("remove_existing=yes",a_conf);
  AddLineToArea("qualify_frequency=120",a_conf);

  AddUsersToConf(PBXCr,true,a_conf);
  
  WriteAreaToFile(a_conf,conf_file,0);

LCreatePJSIPConf:;
  return;
end;

global
updating procedure CreateSIPConf(record PBXConnectionVc PBXCr,Boolean localf)
begin
  area a_conf;
  string 255 conf_file;
  record SipTrunk2Vc STr;
  row SipTrunk2Vc STrw;
  Boolean foundf,testf,test2f;
  Integer i,rwcnt;
  record AsteriskUser2Vc AsteriskUserr;
  record UserVc Userr;
  record GlobalUserVc GUserr;
  string 255 tstr;
  LongInt pos;
  vector Boolean uservec;

  if (UseChanSIP(PBXCr)==false) then begin
    goto LCreateSIPConf;
  end;
  
  CreateFolderHierarchy(AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/");
  conf_file = AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/sip.conf";
  AddLineToArea("[general]",a_conf);
  AddLineToArea("tos_sip=cs3",a_conf);
  AddLineToArea("tos_audio=ef",a_conf);
  AddLineToArea("tos_video=af41",a_conf);
  AddLineToArea("tos_text=af41",a_conf);
  AddLineToArea("context=HW_INBOUND",a_conf);
  AddLineToArea("srvlookup=yes",a_conf);
  AddLineToArea("defaultexpirey=300",a_conf);
  AddLineToArea("allowoverlap=yes",a_conf);
  AddLineToArea("dtmfmode=auto",a_conf);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  test2f = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (STr.Type!=kAsteriskTrunkTypeOutbound) then begin testf = false; end;
    if (testf) then begin
      if (STr.AllowGuestf) then begin test2f = false; end;
    end;
  end;
  if (test2f) then begin
    AddLineToArea("allowguest=no",a_conf);
  end;
  AddLineToArea("bindport=5060",a_conf);
  AddLineToArea("bindaddr=0.0.0.0",a_conf);
  AddLineToArea("externip=" & PBXCr.PBXHostIP,a_conf);
  AddLineToArea("realm=" & PBXCr.PBXHost,a_conf);
  AddLineToArea("localnet=127.0.0.1",a_conf);
  AddLineToArea("udpbindaddr=0.0.0.0",a_conf);
  AddLineToArea("tcpbindaddr=0.0.0.0",a_conf);
  AddLineToArea("tcpenable=yes",a_conf);
  AddLineToArea("videosupport=no",a_conf);
  AddLineToArea("directmedia=no",a_conf);
  AddLineToArea("autodomain=no",a_conf);
  AddLineToArea("allowexternaldomains=yes",a_conf);
  AddLineToArea("disallow=all",a_conf);
  //AddLineToArea("allow=ulaw",a_conf);
  //AddLineToArea("allow=gsm",a_conf);
  //AddLineToArea("allow=g729",a_conf);
  AddLineToArea("allow=opus",a_conf);
  AddLineToArea("allow=alaw",a_conf);
  AddLineToArea("mohinterpret=default",a_conf);
  AddLineToArea("mohsuggest=default",a_conf);
  AddLineToArea("musicclass=default",a_conf);
  AddLineToArea("callevents=yes",a_conf);
  AddLineToArea("authfailureevents=yes",a_conf);
  AddLineToArea("forwardloopdetected=yes",a_conf);
  AddLineToArea("notifyringing=no",a_conf);
  AddLineToArea("busylevel=2",a_conf);
  AddLineToArea("callcounter=yes",a_conf);
  AddLineToArea("alwaysauthreject=yes",a_conf);
  AddLineToArea("canreinvite=no",a_conf);
  AddLineToArea("nat=force_rport,comedia",a_conf);
  AddLineToArea("rtcachefriends=yes",a_conf);
  AddLineToArea("rtsavesysname=yes",a_conf);
  AddLineToArea("rtupdate=yes",a_conf);
  AddLineToArea("rtautoclear=yes",a_conf);
  //AddLineToArea("subscribecontext=hints",a_conf);

  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (STr.Type!=kAsteriskTrunkTypeOutbound) then begin testf = false; end;
    if (testf) then begin
      rwcnt = MatRowCnt(STr);
      for (i=0;i<rwcnt;i=i+1) begin
        MatRowGet(STr,i,STrw);
        tstr = "register => " & STrw.Username & ":" & STrw.Password;
        if (nonblank(STrw.AuthUsername)) then begin
          tstr = tstr & ":" & STrw.AuthUsername;
        end;
        tstr = tstr & "@" & STrw.Domain;
        if (nonblank(STrw.Extension)) then begin
          tstr = tstr & "/" & STrw.Extension;
        end;
        AddLineToArea(tstr,a_conf);
      end;
    end;
  end;

  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      if (nonblank(STr.TalkBotHost)) then begin
        AddLineToArea("[HW_TALKBOT_SIPTRUNK_" & STr.Code & "]",a_conf);
        AddLineToArea("context=HW_EXTENSIONS",a_conf);
        AddLineToArea("type=friend",a_conf);
        AddLineToArea("canreinvite=yes",a_conf);
        AddLineToArea("defaultuser=" & STr.TalkBotUser,a_conf);
        AddLineToArea("host=" & STr.TalkBotHost,a_conf);
        AddLineToArea("disallow=all",a_conf);
        AddLineToArea("allow=ulaw",a_conf);
        AddLineToArea("allow=opus",a_conf);
      end;
    end;

    if (STr.IAXf!=0) then begin testf = false; end; // Because this means it is an IAX trunk, not SIP
    
    if (testf) then begin
      AddLineToArea("[HW_SIPTRUNK_" & STr.Code & "]",a_conf);
      if (STr.Type==kAsteriskTrunkTypeOutbound) then begin
        AddLineToArea("type=peer",a_conf); // peer == outbound
      end else begin
        AddLineToArea("type=friend",a_conf); // friend == outbound + inbound
      end;
      AddLineToArea("context=HW_INBOUND ",a_conf);
      if (blank(STr.FromUser)) then begin
        AddLineToArea("defaultuser=" & STr.Username,a_conf);    // username,defaultuser, same thing, username for "fromdomain" and "secret"
        AddLineToArea("fromuser=" & STr.Username,a_conf);    // username,defaultuser, same thing, username for "fromdomain" and "secret"
      end else begin
        AddLineToArea("defaultuser=" & STr.Username,a_conf);
        AddLineToArea("fromuser=" & STr.FromUser,a_conf);
      end;
      AddLineToArea("secret=" & STr.Password,a_conf);         // secret, new name is remotesecret
      if (nonblank(STr.Domain)) then begin
        AddLineToArea("fromdomain=" & STr.Domain,a_conf);
      end;
      AddLineToArea("canreinvite=no ",a_conf);
      AddLineToArea("disallow=all ",a_conf); 
      AddLineToArea("allow=alaw ",a_conf);
      AddLineToArea("nat=force_rport,comedia",a_conf);
      if (nonblank(STr.Insecure)) then begin
        AddLineToArea("insecure=" & STr.Insecure,a_conf);
      end else begin
        AddLineToArea("insecure=port,invite",a_conf);
      end;
      if (nonblank(STr.Domain)) then begin
        AddLineToArea("realm=" & STr.Domain,a_conf);
      end;
      AddLineToArea("qualify=yes",a_conf);
      if (STr.AllowGuestf) then begin
        AddLineToArea("allowguest=yes",a_conf);
      end else begin
        AddLineToArea("allowguest=no",a_conf);
      end;
      if (nonblank(STr.AllowedIPs)) then begin
        AddLineToArea("deny=0.0.0.0/0.0.0.0",a_conf);
        pos = 0;
        while (GetNextSubstring(STr.AllowedIPs,pos,",",tstr)) begin
          AddLineToArea("permit=" & tstr,a_conf);
        end;
      end;

      if (nonblank(STr.Host)) then begin
        pos = 0;
        i = 0;
        while (GetNextSubstring(STr.Host,pos,",",tstr)) begin
          if (i>0) then begin
            AddLineToArea("[HW_SIPTRUNK_" & STr.Code & "-" & Right("0" & i,2) & "](HW_SIPTRUNK_" & STr.Code & ")",a_conf);
          end;
          AddLineToArea("host=" & tstr,a_conf);
          i = i + 1;
        end;
      end;

    end;
  end;

  AddLineToArea("[basic-options](!)",a_conf);
  AddLineToArea("type=friend",a_conf);
  AddLineToArea("host=dynamic",a_conf);
//  AddLineToArea("qualify=yes",a_conf);
  AddLineToArea("qualify=5000",a_conf); // default is 2s, we allow longer
  AddLineToArea("transport=udp",a_conf);
  AddLineToArea("callcounter=yes",a_conf);
  AddLineToArea("notifyringing=no",a_conf);
  AddLineToArea("busylevel=3",a_conf);
  AddLineToArea("[HW_USERS](!,basic-options)",a_conf);
  AddLineToArea("context=HW_EXTENSIONS",a_conf);
  AddLineToArea("setvar=IAXVAR(HW_IAX_SOURCE)=HW_NOT_IAX",a_conf);
  AddLineToArea("nat=force_rport,comedia",a_conf);
  //AddLineToArea("qualifyfreq=10",a_conf);

  AddUsersToConf(PBXCr,false,a_conf);

  WriteAreaToFile(a_conf,conf_file,0);
  
LCreateSIPConf:;
  return;
end;

function string 255 AstMonthName(Integer monthno)
begin
  string 255 res;
  switch (monthno) begin
    case 1:  res = "jan";
    case 2:  res = "feb";
    case 3:  res = "mar";
    case 4:  res = "apr";
    case 5:  res = "may";
    case 6:  res = "jun";
    case 7:  res = "jul";
    case 8:  res = "aug";
    case 9:  res = "sep";
    case 10: res = "oct";
    case 11: res = "nov";
    case 12: res = "dec";
  end;
  AstMonthName = res;
  return;
end;

updating procedure AddBankHolidays(string qcode,string company,area a_conf)
begin
  record CYBlock CYb;
  record BHollVc BHollr;
  Integer oldcomp,compno,i;
  Date d,dp;
  string 4 daystr;

  compno = StringToLongInt(company);
  oldcomp = CurrentCompany;
  dp = CurrentDate;
  if (company!="" and compno>-1) then begin
    SetCompany(compno,false);
  end;
  BlockLoad(CYb);
  RecordClear(BHollr);
  ResetLoop(BHollr);
  BHollr.CountryCode = CYb.CountryCode;
  if (ReadFirstMain(BHollr,1,true)) then begin
    for (i = 0;i<365;i=i+1) begin
      d = AddDay(dp,i);
      if (IsBankHoliday(BHollr,0,d)) then begin
        AddLineToArea(",GotoIfTime(*,*," & d.day & "," & AstMonthName(d.month) & "?" & qcode & ")",a_conf);
        AddTextToArea("same => n",a_conf);
      end;
    end;
  end;
  ResetCompany(oldcomp);
  return;
end;

function string 255 AnnaQueueContextName(record PBXConnectionVc PBXCr)
begin
  string 255 res;
  res = "HW_Q-ANNA_" & PBXCr.Code;
  AnnaQueueContextName = res;
  return;
end;

global
updating procedure CreateExtensionsConf(record PBXConnectionVc PBXCr,Boolean localf)
begin
  area a_conf;
  string 255 conf_file;
  record PBXQueueVc PBXQr;
  record SipTrunk2Vc STr,ST2r;
  record PBXConnectionVc PBXC2r;
  record AsteriskUser2Vc AsteriskUserr;
  record UserVc Userr;
  record GlobalUserVc GUserr;
  record PBXIVRTreeVc PBXIVRTreer,PBXIVRTree2r;
  row PBXIVRTreeVc PBXIVRTreerw;
  row SipTrunk2Vc STrw;
  Boolean foundf,testf,found2f,test2f,test3f,notfirstf;
  Integer i,rwcnt;
  LongInt pos;
  string 255 tstr,chanstr;
  vector Boolean stextvec;
  vector Boolean ivrqvec;

  if (UseChanPJSIP(PBXCr)) then begin
    chanstr = "PJSIP/"; // Maybe "Local/" would work for both?
  end else begin
    chanstr = "SIP/";
  end;

  CreateFolderHierarchy(AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/");
  conf_file = AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/extensions.conf";
  AddLineToArea("[general]",a_conf);
  AddLineToArea("static=yes",a_conf);
  AddLineToArea("writeprotect=yes",a_conf);
  AddLineToArea("autofallthrough=yes",a_conf);
  AddLineToArea("clearglobalvars=no",a_conf);
  AddLineToArea("priorityjumping=yes",a_conf);
  AddLineToArea("userscontext=hwusers",a_conf);
  AddLineToArea("[globals]",a_conf);

  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      if (STr.IAXf) then begin
        if (blank(STr.FromUser)) then begin
          AddLineToArea("HW_SIPTRUNKVAR_" & STr.Code & "=IAX2/" & STr.Username,a_conf);
        end else begin
          AddLineToArea("HW_SIPTRUNKVAR_" & STr.Code & "=IAX2/" & STr.FromUser,a_conf);
        end;
      end else begin
        //AddLineToArea("HW_SIPTRUNKVAR_" & STr.Code & "=" & chanstr & "HW_SIPTRUNK_" & STr.Code,a_conf);
        AddLineToArea("HW_SIPTRUNKVAR_" & STr.Code & "=HW_SIPTRUNK_" & STr.Code,a_conf);
      end;
    end;
  end;

  AddLineToArea("[HW_IAX_CTX]",a_conf);
  AddLineToArea("include => HW_BASICS",a_conf);
  AddLineToArea("include => HW_FUNCTIONS",a_conf);
  AddLineToArea("include => HW_TRUNK",a_conf);
  AddLineToArea("include => HW_QUEUE_MANAGEMENT",a_conf);
  AddLineToArea("[HansaWorld]",a_conf);
  AddLineToArea("include => HW_BASICS",a_conf);
  AddLineToArea("include => HW_IAX_CTX",a_conf);
  AddLineToArea("include => HW_PARKED_CALLS",a_conf);
  AddLineToArea("include => HW_QUEUE_MANAGEMENT",a_conf);
