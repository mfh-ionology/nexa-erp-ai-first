external function Integer IsBankHoliday(record BHollVc,Integer,Date);
external function string 255 PBXPublicSSHKeyName();
external function string 255 PBXPrivateSSHKeyName();
external function boolean IsNumeric(string);

enum begin
  kAsteriskBackgroundPlayback = 1,
  kAsteriskForegroundPlayback = 2
end;

function Boolean IsValidPBXConnection(string pbxcode)
begin
  record PBXConnectionVc PBXCr;
  Boolean res;

  PBXCr.Code = pbxcode;
  if (ReadFirstMain(PBXCr,1,true)) then begin
    if (PBXCr.Closed==0) then begin
      res = true;
    end;
  end;
  IsValidPBXConnection = res;
  return;
end;

function Boolean UseChanSIP(record PBXConnectionVc PBXCr)
begin
  record SipTrunk2Vc STr;
  Boolean foundf,testf,res;
  
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      if (STr.ChanSIPf!=0) then begin
        res = true;
        goto LUseChanSIP;
      end;
    end;
  end;
  
LUseChanSIP:;
  UseChanSIP = res;
  return;
end;

function Boolean UseChanPJSIP(record PBXConnectionVc PBXCr)
begin
  record SipTrunk2Vc STr;
  Boolean foundf,testf,res;
  
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      if (STr.ChanSIPf==0) then begin
        res = true;
        goto LUseChanPJSIP;
      end;
    end;
  end;
  
LUseChanPJSIP:;
  UseChanPJSIP = res;
  return;
end;

global
function string 255 AsteriskUser(record PBXConnectionVc PBXCr)
begin
  string 255 res;

  res = PBXCr.RemoteUser;
  if (blank(res)) then begin
    res = "asterisk";
  end;

  AsteriskUser = res;
  return;
end;

global
function Boolean SavePBXSSHKey(string keyname,string keyfile,record PBXConnectionVc PBXr)
begin
  Integer i;
  record Attach2Vc AT2r;
  record RLinkVc RLr;
  Boolean res;
  LongInt blocklen;
  area a_key;

  while (ReadRecordLink(PBXr,i,AT2r,RLr)) begin
    if (AT2r.FileName==keyname) then begin
      goto LSavePBXSSHKey_FoundKey;
    end;
    i = i + 1;
  end;
  goto LSavePBXSSHKey;

LSavePBXSSHKey_FoundKey:;
  res = true;
  blocklen = AttachFileSize(AT2r);
  LoadAttachFilePartToArea(AT2r,0,blocklen,a_key);
  WriteAreaToFile(a_key,keyfile,0);
  RunShellScript("chmod 600 """ & keyfile & """");

LSavePBXSSHKey:;
  SavePBXSSHKey = res;
  return;
end;

procedure AddLineToArea(string line,area req)
begin
  AddTextToArea(line,req);
  AddTextToArea(chr(10),req);
  return;
end;

global
function string 255 MakeTrailingSlash(string path)
begin
  string 255 res;
  if (right(path,1)=="/" or right(path,1)=="\\") then begin
    res = path;
  end else begin
    res = path & "/";
  end;
  MakeTrailingSlash = res;
  return;
end;

global
function string 255 SoundFileName(string queueName,Integer astevent)
begin
  string 255 res;
  
  res = "HW_PBXSound_" & queueName & "_";
  switch (astevent) begin
    case kAsteriskEventSoundWelcome:      res = res & "Welcome";
    case kAsteriskEventSoundLineClosed:   res = res & "LineClosed";
    case kAsteriskEventSoundQueueStart:   res = res & "QueueStart";
    case kAsteriskEventSoundIVRStart:     res = res & "IVRStart";
    case kAsteriskEventSoundLineBusy:     res = res & "LineBusy";
    case kAsteriskEventSoundMusicOnHold:  res = res & "MusicOnHold";
    case kAsteriskEventSoundIVRClosed:    res = res & "IVRClosed";
    otherwise
      res = "";
  end;
  
  SoundFileName = res;
end;

function Boolean SoundExistsForEvent(string code,Integer astevent)
begin
  record PBXSoundVc PBXSr;
  record Attach2Vc Attach2r;
  record RLinkVc RLr;
  Boolean res,foundf,testf;
  Integer filenr;
  string 255 soundfile;
  
  soundfile = SoundFileName(code,astevent);
  if (blank(soundfile)) then begin goto LSoundExistsForEvent; end;

  PBXSr.Queue = code;
  PBXSr.Event = astevent;
  foundf = true;
  while (LoopKey("QueueEvent",PBXSr,2,foundf)) begin
    if (PBXSr.Queue!=code) then begin foundf = false; end;
    if (PBXSr.Event!=astevent) then begin foundf = false; end;
    testf = foundf;
    if (PBXSr.Closed!=0) then begin testf = false; end;
    if (testf) then begin
      filenr = 1;
      while (ReadRecordLink(PBXSr,filenr,Attach2r,RLr)) begin
        if ((nonblank(Attach2r.FileName)) and (Attach2r.Uploading==0) and (Attach2r.FileSize>0)) then begin
          res = true;
          goto LSoundExistsForEvent;
        end;
      end;
    end;
  end;

LSoundExistsForEvent:;
  SoundExistsForEvent = res;
  return;
end;

function string 255 PlayAsteriskSound(string code,Integer astevent,Integer playbackmode)
begin
  string 255 res;
  
  if (SoundExistsForEvent(code,astevent)==false) then begin
    res = "NoOp(No sound defined for " & code & ", event " & StringFromSet(587,astevent) & ")";
    goto LPlayAsteriskSound;
  end;
  
  switch (playbackmode) begin
    case kAsteriskBackgroundPlayback: res = "Background(" & SoundFileName(code,astevent) & ")";
    case kAsteriskForegroundPlayback: res = "Playback(" & SoundFileName(code,astevent) & ")";
    otherwise
      res = "NoOp()";
  end;

LPlayAsteriskSound:;
  PlayAsteriskSound = res;
  return;
end;

            
global
procedure MoveFileInPlaceRemote(area afile,string path)
begin
  //Check sanity
  WriteAreaToFile(afile,path,0);
  return;
end;

global
procedure RemoveFolderInPlaceRemote(string path)
begin
  //Check sanity
  if (DirExists(path)) then begin
    DeleteFolder(path & ".old");
    RenameFile(path,path & ".old");
    CreateFolderHierarchy(MakeTrailingSlash(path));
  end;
  return;
end;

global
procedure MoveAsteriskDirInPlace(string servcode,string localdir)
begin
  record PBXConnectionVc PBXCr;
  Integer i,filecnt;
  area afile;
  string 255 args,remotepath,filename,keyfile;

  PBXCr.Code = servcode;
  if (ReadFirstMain(PBXCr,1,true)) then begin
    remotepath = MakeTrailingSlash(PBXCr.RemoteConfigDir) & "/etc/asterisk/";
    if (blank(remotepath)) then begin
      remotepath = "/Servers/Asterisk/etc/asterisk/";
    end;
    if (blank(PBXCr.AsteriskController)) then begin
      keyfile = CreateTempFile("asterisk-config-key-dir",".pem");
      if (SavePBXSSHKey(PBXPrivateSSHKeyName,keyfile,PBXCr)) then begin
        args = "-avz --remove-source-files --delete -e ""ssh -o UserKnownHostsFile=/dev/null -i " & keyfile & " -o ServerAliveInterval=60 -o StrictHostKeyChecking=no -o PasswordAuthentication=no"" --rsync-path=""sudo rsync"" --partial " & localdir & " " & AsteriskUser(PBXCr) & "@" & PBXCr.PBXHost & ":" & remotepath;
        RunShellScript("/usr/bin/rsync " & args);
//LogText(0,"/usr/bin/rsync " & args);
      end;
      Delete_File(keyfile);
    end else begin
      CallService2(PBXCr.AsteriskController,PBXCr.AsteriskControllerKey).RemoveFolderInPlaceRemote(MakeTrailingSlash(remotepath) & filename);
      filecnt = CountFilesInDir(localdir);
      for (i = 0; i<filecnt; i = i + 1) begin
        filename = GetFileNameInDir(localdir,i);
        AddFileToArea(MakeTrailingSlash(localdir) & filename,afile,false);
        CallService2(PBXCr.AsteriskController,PBXCr.AsteriskControllerKey).MoveFileInPlaceRemote(afile,MakeTrailingSlash(remotepath) & filename);
      end;
    end;
  end else begin
    LogText(0,"Asterisk server not found: " & servcode);
  end;
end;

global
procedure MoveAsteriskSoundDirInPlace(record PBXConnectionVc PBXCr,string localdir,string remotepath)
begin
  Integer i,filecnt;
  area afile;
  string 255 args,filename,keyfile;

  if (blank(PBXCr.AsteriskController)) then begin
    keyfile = CreateTempFile("asterisk-config-key-sounddir",".pem");
    if (SavePBXSSHKey(PBXPrivateSSHKeyName,keyfile,PBXCr)) then begin
      args = "-avz --remove-source-files --delete -e ""ssh -i " & keyfile & " -o UserKnownHostsFile=/dev/null -o ServerAliveInterval=60 -o StrictHostKeyChecking=no -o PasswordAuthentication=no"" --rsync-path=""sudo rsync"" --partial " & localdir & " " & AsteriskUser(PBXCr) & "@" & PBXCr.PBXHost & ":" & remotepath;
      RunShellScript("/usr/bin/rsync " & args);
//LogText(0,"/usr/bin/rsync " & args);
    end;
    Delete_File(keyfile);
  end else begin
    filecnt = CountFilesInDir(localdir);
    for (i = 0; i<filecnt; i = i + 1) begin
      filename = GetFileNameInDir(localdir,i);
      AddFileToArea(MakeTrailingSlash(localdir) & filename,afile,false);
      CallService2(PBXCr.AsteriskController,PBXCr.AsteriskControllerKey).MoveFileInPlaceRemote(afile,MakeTrailingSlash(remotepath) & filename);
    end;
  end;
end;

global
procedure MoveAsteriskFileInPlace(string servcode,string localfile,string remotefile)
begin
  area afile;
  record PBXConnectionVc PBXCr;
  string 255 args,remotepath,keyfile;

  PBXCr.Code = servcode;
  if (ReadFirstMain(PBXCr,1,true)) then begin
    remotepath = MakeTrailingSlash(PBXCr.RemoteConfigDir) & "/etc/asterisk/";
    if (blank(remotepath)) then begin
      remotepath = "/Servers/Asterisk/etc/asterisk/";
    end;
    if (blank(PBXCr.AsteriskController)) then begin
      keyfile = CreateTempFile("asterisk-config-key-file",".pem");
      if (SavePBXSSHKey(PBXPrivateSSHKeyName,keyfile,PBXCr)) then begin
        args = "-i " & keyfile & " " & localfile & " " & AsteriskUser(PBXCr) & "@" & PBXCr.PBXHost & ":" & remotepath & remotefile;
        RunShellScript("/usr/bin/scp " & args);
      end;
      Delete_File(keyfile);
    end else begin
      AddFileToArea(localfile,afile,false);
      CallService2(PBXCr.AsteriskController,PBXCr.AsteriskControllerKey).MoveFileInPlaceRemote(afile,remotepath & remotefile);
    end;
  end else begin
    LogText(0,"Asterisk server not found: " & servcode);
  end;
end;

global
procedure MoveAsteriskSoundFileInPlace(record PBXConnectionVc PBXCr,string localfile,string remotefile)
begin
  string 255 args,keyfile;

  keyfile = CreateTempFile("asterisk-config-key-sounds",".pem");
  if (SavePBXSSHKey(PBXPrivateSSHKeyName,keyfile,PBXCr)) then begin
    args = "-i " & keyfile & " " & localfile & " " & AsteriskUser(PBXCr) & "@" & PBXCr.PBXHost & ":" & remotefile;
    RunShellScript("/usr/bin/scp " & args);
  end;
  Delete_File(keyfile);
  return;
end;


