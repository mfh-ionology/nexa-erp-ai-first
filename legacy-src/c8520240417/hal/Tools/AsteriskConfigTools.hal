global
updating procedure CreateCodecsConf(record PBXConnectionVc PBXCr,Boolean localf)
begin
  area a_conf;
  string 255 conf_file;

  CreateFolderHierarchy(AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/");
  conf_file = AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/codecs.conf";
  /* Not compatible with opensource-opus
  AddLineToArea("[hw_opus]",a_conf);
  AddLineToArea("type=opus",a_conf);
  AddLineToArea("packet_loss=60",a_conf); // packet loss resistance percentage; 40 seems to give good results as well
  AddLineToArea("complexity=10",a_conf); // computational complexity, 0-10; lower gives worse audio quality
  AddLineToArea("max_bandwidth=full",a_conf); // narrow, medium, wide, super_wide, full; suprisingly effective to use full
  AddLineToArea("signal=voice",a_conf); // auto, voice, music; significant improvement for calls when using voice
  AddLineToArea("application=voip",a_conf); // voip, audio, low_delay
  AddLineToArea("max_playback_rate=32000",a_conf); // 8000-48000; 48000 gave poor results in conference calls
  AddLineToArea("bitrate=auto",a_conf); // 500-512000, auto, max
  AddLineToArea("cbr=no",a_conf); // constant bitrate: yes, no
  AddLineToArea("fec=yes",a_conf); // forward error correction: yes, no
  AddLineToArea("dtx=no",a_conf); // discontinuous transmission: yes, no
  */
  WriteAreaToFile(a_conf,conf_file,0);
  return;
end;


global
updating procedure CreateConfBridgeConf(record PBXConnectionVc PBXCr,Boolean localf)
begin
  area a_conf;
  string 255 conf_file;

  CreateFolderHierarchy(AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/");
  conf_file = AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/confbridge.conf";
  
  AddLineToArea("[default_user]",a_conf);
  AddLineToArea("type=user",a_conf);
  AddLineToArea("music_on_hold_when_empty=no",a_conf);
  AddLineToArea("quiet=yes",a_conf); // When enabled enter/leave prompts and user intros are not played.
  AddLineToArea("announce_user_count=no",a_conf);
  AddLineToArea("announce_user_count_all=no",a_conf);
  AddLineToArea("announce_only_user=no",a_conf);
  AddLineToArea("wait_marked=no",a_conf);
  AddLineToArea("end_marked=no",a_conf);
  AddLineToArea("announce_join_leave=no",a_conf);
  AddLineToArea("announce_join_leave_review=no",a_conf);
  AddLineToArea("dtmf_passthrough=no",a_conf);
  AddLineToArea("timeout=0",a_conf);
  AddLineToArea("text_messaging=no",a_conf);
  /*
    This option drops what Asterisk detects as silence from entering into the bridge. Enabling
    this option will drastically improve performance and help remove the buildup of background
    noise from the conference. Highly recommended for large conferences due to its performance
    enhancements.
  */
  AddLineToArea("dsp_drop_silence=yes",a_conf);
  /*
    Enabling this option places a jitterbuffer on the user's audio stream before audio mixing
    is performed.  This is highly recommended but will add a slight delay to the audio. This
    option is using the JITTERBUFFER dialplan function's default adaptive jitterbuffer. For a
    more fine tuned jitterbuffer, disable this option and use the JITTERBUFFER dialplan function
    on the user before entering the ConfBridge application.
  */
  AddLineToArea("jitterbuffer=yes",a_conf); // We have it in the dialplan instead //220111 - turned on, dialpan func seems missing on arm asterisk?
  /*
    Average magnitude threshold to determine talking. The minimum average magnitude per sample
    in a frame for the DSP to consider talking/noise present. A value below this level is
    considered silence. This value affects several operations and should not be changed unless
    the impact on call quality is fully understood. What this value affects internally:
    1. Audio is only mixed out of a user's incoming audio stream if talking is detected. If
       this value is set too high the user will hear himself talking.
    2. When talk detection AMI events are enabled, this value determines when talking has begun
       which results in an AMI event to fire. If this value is set too low AMI events may be falsely
       triggered by variants in room noise.
    3. The 'drop_silence' option depends on this value to determine when the user's audio should be
       mixed into the bridge after periods of silence. If this value is too high the user's speech
       will get discarded as they will be considered silent.
    Valid values are 1 through 2^15. By default this value is 160.
    ;dsp_talking_threshold=128
  */
  /*
    The number of milliseconds of silence necessary to declare talking stopped. The time in milliseconds
    of sound falling below the 'dsp_talking_threshold' option when a user is considered to stop talking.
    This value affects several operations and should not be changed unless the impact on call quality is
    fully understood. What this value affects internally:
    1. When talk detection AMI events are enabled, this value determines when the user has stopped talking
       after a period of talking. If this value is set too low AMI events indicating the user has stopped
       talking may get falsely sent out when the user briefly pauses during mid sentence.
    2. The 'drop_silence' option depends on this value to determine when the user's audio should begin to
       be dropped from the conference bridge after the user stops talking. If this value is set too low
       the user's audio stream may sound choppy to the other participants. This is caused by the user
       transitioning constantly from silence to talking during mid sentence.
    The best way to approach this option is to set it slightly above the maximum amount of milliseconds of
    silence a user may generate during natural speech.
    Valid values are 1 through 2^31. By default this value is 2500ms.
    ;dsp_silence_threshold=2000
  */
  /*
    This option sets whether or not notifications of when a user begins and ends talking should be sent out
    as events over AMI. By default this option is off.
    ;talk_detection_events=yes
  */
  AddLineToArea("talk_detection_events=yes",a_conf);
  /*
    Sets whether or not a denoise filter should be applied to the audio before mixing or not. Off by default.
    Requires func_speex to be built and installed. Do not confuse this option with drop_silence. Denoise is
    useful if there is a lot of background noise for a user as it attempts to remove the noise while preserving
    the speech. This option does NOT remove silence from being mixed into the conference and does come at the
    cost of a slight performance hit.
  */
  AddLineToArea("denoise=yes",a_conf); // In some tests, caused poor quality, possibly because too much CPU demand
  
  AddLineToArea("[default_bridge]",a_conf);
  AddLineToArea("type=bridge",a_conf);
  AddLineToArea("record_conference=no",a_conf);
  /*
    Sets the internal native sample rate the conference is mixed at. This is set to automatically
    adjust the sample rate to the best quality by default. Other values can be anything from
    8000-192000. If a sample rate is set that Asterisk does not support, the closest sample rate
    Asterisk does support to the one requested will be used.
    ;internal_sample_rate=48000
  */
  //AddLineToArea("internal_sample_rate=96000",a_conf);
  AddLineToArea("internal_sample_rate=48000",a_conf);
  /*
    Sets the maximum sample rate the conference is mixed at. This is set to no maximum by default.
    Values can be anything from 8000-192000.
    ;maximum_sample_rate=48000
  */
  //AddLineToArea("maximum_sample_rate=192000",a_conf);
  AddLineToArea("maximum_sample_rate=48000",a_conf);
  /*
    Sets the internal mixing interval in milliseconds for the bridge. This number reflects how tight
    or loose the mixing will be for the conference. In order to improve performance a larger mixing
    interval such as 40ms may be chosen. Using a larger mixing interval comes at the cost of introducing
    larger amounts of delay into the bridge. Valid values here are 10, 20, 40, or 80.  By default 20ms
    is used.
  */
  //AddLineToArea("mixing_interval=40",a_conf); // 40 does not work - breakups and horrible audio quality
  AddLineToArea("enable_events=no",a_conf);
  AddLineToArea("binaural_active=no",a_conf);
  WriteAreaToFile(a_conf,conf_file,0);
  return;
end;

global
updating procedure CreateDNSMgrConf(record PBXConnectionVc PBXCr,Boolean localf)
begin
  area a_conf;
