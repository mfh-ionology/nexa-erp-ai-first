  AddLineToArea("[HW_EXTENSIONS]",a_conf);
  AddLineToArea("include => HW_BASICS",a_conf);
  AddLineToArea("include => HW_FUNCTIONS",a_conf);
  AddLineToArea("include => HW_QUEUE_MANAGEMENT",a_conf);
  AddLineToArea("include => HW_TRUNK",a_conf);
  AddLineToArea("[HW_BASICS]",a_conf);
  AddLineToArea("exten => h,1,Hangup()",a_conf);
  
  AddLineToArea("[HW_FUNCTIONS]",a_conf);
  
  AddLineToArea("; Talkbot extensions",a_conf);
  AddLineToArea(";",a_conf);
  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (blank(STr.TalkBotExtension)) then begin testf = false; end;
    if (testf) then begin
      AddLineToArea("exten => _" & STr.TalkBotExtension & ",1,Dial(" & chanstr & "HW_TALKBOT_SIPTRUNK_" & STr.Code & ",60,TtKk)",a_conf);
    end;
  end;

  if (PBXCr.IAXf!=0) then begin
    AddLineToArea("; IAX routed extensions for menus",a_conf);
    AddLineToArea(";",a_conf);
    ResetLoop(PBXC2r);
    while (LoopMain(PBXC2r,1,true)) begin
      testf = true;
      if (PBXC2r.Closed!=0) then begin testf = false; end;
      if (IsAsteriskPbxType(PBXC2r.PBXType)==false) then begin testf = false; end;
      if (PBXC2r.Code==PBXCr.Code) then begin testf = false; end;
      if (PBXC2r.IAXf==0) then begin testf = false; end;
      if (blank(PBXC2r.PBXHostIP)) then begin testf = false; end;
      if (testf==true) then begin
        ResetLoop(STr);
        STr.PBXConnection = PBXC2r.Code;
        foundf = true;
        while (LoopKey("PBXConnection",STr,1,foundf)) begin
          if (STr.PBXConnection!=PBXC2r.Code) then begin foundf = false; end;
          test2f = foundf;
          if (STr.Closedf!=0) then begin test2f = false; end;
          if (test2f) then begin
            ResetLoop(PBXIVRTreer);
            PBXIVRTreer.SipTrunk = STr.Code;
            found2f = true;
            while (LoopKey("SipTrunk",PBXIVRTreer,1,found2f)) begin
              if (PBXIVRTreer.SipTrunk!=STr.Code) then begin found2f = false; end;
              test3f = found2f;
              if (PBXIVRTreer.Closed!=0) then begin test3f = false; end;
              if (test3f) begin
                AddLineToArea("exten => HW_IVR_" & PBXIVRTreer.Code & ",1,Answer()",a_conf);
                AddLineToArea("same => n,Dial(IAX2/HW_IAX_" & PBXC2r.Code & "/HW_IVR_" & PBXIVRTreer.Code & ",60,TtKk)",a_conf);
                AddLineToArea("same => n,Hangup()",a_conf);
              end;
            end;
          end;
        end;
      end;
    end;
  end;

  AddLineToArea("; Locally routed extensions for menus and queues",a_conf);
  AddLineToArea(";",a_conf);
  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      ResetLoop(PBXQr);
      PBXQr.SipTrunk = STr.Code;
      found2f = true;
      while (LoopKey("SipTrunk",PBXQr,1,found2f)) begin
        if (PBXQr.SipTrunk!=STr.Code) then begin found2f = false; end;
        test2f = found2f;
        if (PBXQr.Closed!=0) then begin test2f = false; end;
        if (PBXQr.Extension=="") then begin test2f = false; end;
        if (test2f==true) then begin
          pos = 0;
          while (GetNextSubstring(PBXQr.Extension,pos,",",tstr)) begin
            if (ivrqvec[tstr]==false) then begin
              AddLineToArea("exten => _" & tstr & ",1,Goto(HW_Q_" & PBXQr.Code & ",s,1)",a_conf);
              ivrqvec[tstr] = true;
            end;
          end;
        end;
      end;
      
      ResetLoop(PBXIVRTreer);
      PBXIVRTreer.SipTrunk = STr.Code;
      found2f = true;
      while (LoopKey("SipTrunk",PBXIVRTreer,1,found2f)) begin
        if (PBXIVRTreer.SipTrunk!=STr.Code) then begin found2f = false; end;
        test2f = found2f;
        if (PBXIVRTreer.Closed!=0) then begin test2f = false; end;
        if (test2f) begin
          AddLineToArea("exten => HW_IVR_" & PBXIVRTreer.Code & ",1,Goto(HW_IVR_" & PBXIVRTreer.Code & ",s,1)",a_conf);
        end;
        if (PBXIVRTreer.Extension=="") then begin test2f = false; end;
        if (test2f==true) then begin
          pos = 0;
          while (GetNextSubstring(PBXIVRTreer.Extension,pos,",",tstr)) begin
            if (ivrqvec[tstr]==false) then begin
              AddLineToArea("exten => _" & tstr & ",1,Goto(HW_IVR_" & PBXIVRTreer.Code & ",s,1)",a_conf);
              ivrqvec[tstr] = true;
            end;
          end;
        end;
      end;
    end;
  end;
  
  AddLineToArea("[HW_ADD_CALLEDEXT_HEADER]",a_conf);
  AddLineToArea("exten => s,1,Set(PJSIP_HEADER(add,X-StandardERP-CalledExten)=${ARG1})",a_conf);
  AddLineToArea("same => n,Return",a_conf);

  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      ResetLoop(PBXQr);
      PBXQr.SipTrunk = STr.Code;
      found2f = true;
      while (LoopKey("SipTrunk",PBXQr,1,found2f)) begin
        if (PBXQr.SipTrunk!=STr.Code) then begin found2f = false; end;
        test2f = found2f;
        if (PBXQr.Closed!=0) then begin test2f = false; end;
        if (blank(PBXQr.Code)) then begin test2f = false; end;
        if (test2f==true) then begin
          AddLineToArea("[HW_Q_" & PBXQr.Code & "]",a_conf);
          AddLineToArea("exten => s,1,Answer()",a_conf);
          AddLineToArea("same => n,Set(CALLERID(num-pres)=allowed)",a_conf);
          AddLineToArea("same => n,MSet(Q=" & PBXQr.Code & ",L=" & PBXQr.Code & ")",a_conf);
          AddLineToArea("same => n,Set(CALLERID(all)=""${Q} ${L}: ${CALLERID(num)}<${CALLERID(num)}>"")",a_conf);
          AddLineToArea("same => n,Ringing",a_conf);
          if (PBXQr.DirectToAnnaFlag==0) then begin
            AddLineToArea("same => n,UserEvent(Queue,Type: Reached,Code: " & PBXQr.Code & ",Caller: ${CALLERID(num)})",a_conf);
            AddLineToArea("same => n,GoTo(HW_OPENING_HOURS,s,HW_JUMP_Q_" & PBXQr.Code & ")",a_conf);
            AddLineToArea("same => n(HW_JUMP_ISOPEN),NoOp(" & PBXQr.Code & " is open)",a_conf);
            AddLineToArea("same => n,UserEvent(Queue,Type: Open,Code: " & PBXQr.Code & ",Caller: ${CALLERID(num)})",a_conf);
            AddLineToArea("same => n," & PlayAsteriskSound(PBXQr.Code,kAsteriskEventSoundQueueStart,kAsteriskForegroundPlayback),a_conf);
            AddLineToArea("same => n(HW_JUMP_BACKINQUEUE),Queue(HWQUEUE" & PBXQr.Code & ",Rtk,,,60,,,HW_AGENT_PICKUP,)",a_conf);
            AddLineToArea("same => n,Verbose(0,Queue exited with status ${QUEUESTATUS})",a_conf);
            AddLineToArea("same => n,ExecIf($[""${QUEUESTATUS}"" = ""JOINEMPTY""]?Goto(HW_JUMP_JOINEMPTY)",a_conf);
            AddLineToArea("same => n," & PlayAsteriskSound(PBXQr.Code,kAsteriskEventSoundLineBusy,kAsteriskForegroundPlayback),a_conf);
            AddLineToArea("same => n,Goto(HW_JUMP_BACKINQUEUE)",a_conf);
            AddLineToArea("same => n,Hangup()",a_conf);
            AddLineToArea("same => n(HW_JUMP_JOINEMPTY),NoOp()",a_conf);
            AddLineToArea("same => n," & PlayAsteriskSound(PBXQr.Code,kAsteriskEventSoundLineBusy,kAsteriskForegroundPlayback),a_conf);
            //AddLineToArea("same => n,GosubIf($[""${QUEUESTATUS}"" = ""JOINEMPTY""]?HW_QUEUE_FALLBACK_" & PBXQr.Code & ",s,1)",a_conf);
            AddLineToArea("same => n,MusicOnHold(HW,20)",a_conf);
            AddLineToArea("same => n,Goto(HW_JUMP_BACKINQUEUE)",a_conf);
          end else begin
            AddLineToArea("same => n(HW_JUMP_BACKINQUEUE),Queue(" & AnnaQueueName(PBXCr) & ",rtkb(HW_ADD_CALLEDEXT_HEADER^s^1(${INBOUND_EXTEN})),,,60,,,HW_AGENT_PICKUP,)",a_conf);
            AddLineToArea("same => n,ExecIf($[""${QUEUESTATUS}"" = ""TIMEOUT""]?Goto(HW_JUMP_TIMEOUT)",a_conf);
            AddLineToArea("same => n,Verbose(0,Queue exited with status ${QUEUESTATUS}, retrying)",a_conf);
            AddLineToArea("same => n,Goto(HW_JUMP_BACKINQUEUE)",a_conf);
            AddLineToArea("same => n(HW_JUMP_TIMEOUT)," & PlayAsteriskSound(PBXQr.Code,kAsteriskEventSoundLineBusy,kAsteriskForegroundPlayback),a_conf);
            AddLineToArea("same => n,Goto(HW_JUMP_BACKINQUEUE)",a_conf);
          end;
        end;
      end;
      ResetLoop(PBXIVRTreer);
      PBXIVRTreer.SipTrunk = STr.Code;
      found2f = true;
      while (LoopKey("SipTrunk",PBXIVRTreer,1,found2f)) begin
        if (PBXIVRTreer.SipTrunk!=STr.Code) then begin found2f = false; end;
        test2f = found2f;
        if (PBXIVRTreer.Closed!=0) then begin test2f = false; end;
        if (blank(PBXIVRTreer.Code)) then begin test2f = false; end;
        if (test2f==true) then begin
          AddLineToArea("[HW_IVR_" & PBXIVRTreer.Code & "]",a_conf);
          AddLineToArea("exten => s,1,Answer()",a_conf);
          AddLineToArea("same => n,Set(CALLERID(num-pres)=allowed)",a_conf);
          AddLineToArea("same => n,MSet(Q=" & PBXIVRTreer.Code & ",L=" & PBXIVRTreer.Code & ")",a_conf);
          AddLineToArea("same => n,Set(CALLERID(all)=""${Q} ${L}: ${CALLERID(num)}<${CALLERID(num)}>"")",a_conf);
          AddLineToArea("same => n,Ringing",a_conf);
          AddLineToArea("same => n,UserEvent(IVRTree,Type: Reached,Code: " & PBXIVRTreer.Code & ",Caller: ${CALLERID(num)})",a_conf);
          AddLineToArea("same => n,GoTo(HW_OPENING_HOURS,s,HW_JUMP_IVR_" & PBXIVRTreer.Code & ")",a_conf);
          AddLineToArea("same => n(HW_JUMP_ISOPEN),NoOp(" & PBXIVRTreer.Code & " is open)",a_conf);
          AddLineToArea("same => n,UserEvent(IVRTree,Type: Open,Code: " & PBXIVRTreer.Code & ",Caller: ${CALLERID(num)})",a_conf);
          AddLineToArea("same => n(HW_JUMP_IVRSTART)," & PlayAsteriskSound(PBXIVRTreer.Code,kAsteriskEventSoundIVRStart,kAsteriskBackgroundPlayback),a_conf);
          if (PBXIVRTreer.Interval>0) then begin
            AddLineToArea("same => n,WaitExten(" & PBXIVRTreer.Interval & ")",a_conf);
          end else begin
            AddLineToArea("same => n,WaitExten(10)",a_conf);
          end;
          AddLineToArea("same => n,GoTo(HW_JUMP_IVRSTART)",a_conf);
          rwcnt = MatRowCnt(PBXIVRTreer);
          for (i=0;i<rwcnt;i=i+1) begin
            MatRowGet(PBXIVRTreer,i,PBXIVRTreerw);
            if (PBXIVRTreerw.AnnaFlag!=0 and nonblank(PBXIVRTreerw.AnnaPassword)) then begin
              AddLineToArea("exten => " & PBXIVRTreerw.Number & ",1,Verbose(0,  [${UNIQUEID}] Caller selected """& PBXIVRTreerw.Number & """, continuing to Anna...)",a_conf);
              AddLineToArea("same => n,GoTo(" & AnnaQueueContextName(PBXCr) & ",s,1)",a_conf);
              AddLineToArea("same => n,Hangup())",a_conf);
            end else begin
              if (nonblank(PBXIVRTreerw.Queue)) then begin
                AddLineToArea("exten => " & PBXIVRTreerw.Number & ",1,Set(L=" & PBXIVRTreerw.Queue & ")",a_conf);
//                AddLineToArea("same => n,Verbose(0,  [${UNIQUEID}] Caller selected """& PBXIVRTreerw.Number & """, continuing to ${Q} ${L}...)",a_conf);
                ResetLoop(PBXQr);
                PBXQr.Code = PBXIVRTreerw.Queue;
                if (ReadFirstMain(PBXQr,1,true)) then begin
                  ResetLoop(ST2r);
                  ST2r.Code = PBXQr.SipTrunk;
                  if (ReadFirstMain(ST2r,1,true)) then begin
                    if (PBXCr.Code==ST2r.PBXConnection) then begin
                      AddLineToArea("same => n,GoTo(HW_Q_" & PBXIVRTreerw.Queue & ",s,1)",a_conf);
                    end else begin
                      AddLineToArea("same => n,Dial(IAX2/HW_IAX_" & ST2r.PBXConnection & "/HW_Q_" & PBXIVRTreerw.Queue & ",60,TtKk)",a_conf);
                      AddLineToArea("same => n,Hangup()",a_conf);
                    end;
                  end;
                end;
              end else begin
                AddLineToArea("exten => " & PBXIVRTreerw.Number & ",1,Set(L=" & PBXIVRTreerw.Menu & ")",a_conf);
//                AddLineToArea("same => n,Verbose(0,  [${UNIQUEID}] Caller selected """& PBXIVRTreerw.Number & """, continuing to ${Q} ${L}...)",a_conf);
                ResetLoop(PBXQr);
                PBXIVRTree2r.Code = PBXIVRTreerw.Menu;
                if (ReadFirstMain(PBXIVRTree2r,1,true)) then begin
                  ResetLoop(ST2r);
                  ST2r.Code = PBXIVRTree2r.SipTrunk;
                  if (ReadFirstMain(ST2r,1,true)) then begin
                    if (PBXCr.Code==ST2r.PBXConnection) then begin
                      AddLineToArea("same => n,GoTo(HW_IVR_" & PBXIVRTreerw.Menu & ",s,1)",a_conf);
                    end else begin
                      AddLineToArea("same => n,Dial(IAX2/HW_IAX_" & ST2r.PBXConnection & "/HW_IVR_" & PBXIVRTreerw.Menu & ",60,TtKk)",a_conf);
                      AddLineToArea("same => n,Hangup()",a_conf);
                    end;
                  end;
                end;
              end;
            end;
          end;
        end;
      end;
    end;
  end;
  
  if (PBXConnectionSupportsAnna(PBXCr,tstr)) then begin
    AddLineToArea("[" & AnnaQueueContextName(PBXCr) & "]",a_conf);
    AddLineToArea("exten => s,1,Answer()",a_conf);
    AddLineToArea("same => n,Ringing",a_conf);
    AddLineToArea("same => n(HW_JUMP_BACKINQUEUE),Queue(" & AnnaQueueName(PBXCr) & ",Rtk,,,60,,,HW_AGENT_PICKUP,)",a_conf);
    AddLineToArea("same => n,MusicOnHold(HW,20)",a_conf);
    AddLineToArea("same => n,Goto(HW_JUMP_BACKINQUEUE)",a_conf);
    AddLineToArea("same => n,Hangup()",a_conf);
  end;
  
  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      ResetLoop(PBXQr);
      PBXQr.SipTrunk = STr.Code;
      found2f = true;
      while (LoopKey("SipTrunk",PBXQr,1,found2f)) begin
        if (PBXQr.SipTrunk!=STr.Code) then begin found2f = false; end;
        test2f = found2f;
        if (PBXQr.Closed!=0) then begin test2f = false; end;
        if (test2f==true) then begin
          AddLineToArea("[HW_QUEUE_FALLBACK_" & PBXQr.Code & "]",a_conf);
          AddLineToArea("exten => s,1,NoOp()",a_conf);
          if (PBXQr.NoGeneralSIPFallback==0) then begin
            notfirstf = false;
            AsteriskUserr.SerNr = -1;
            ResetLoop(AsteriskUserr);
            while (LoopMain(AsteriskUserr,1,true)) begin
              test3f = false;
              if (AsteriskUserr.Closedf==0 and AsteriskUserr.ExcludeQueueFallbackf==0) then begin
                if (blank(AsteriskUserr.PBXConnection)) then begin test3f = true; end;
                pos = 0;
                while (GetNextSubstring(AsteriskUserr.PBXConnection,pos,",",tstr)) begin
                  if (tstr==STr.PBXConnection) then begin
                    if (IsValidPBXConnection(tstr)) then begin
                      test3f = true;
                    end;
                  end;
                end;
                if (test3f) then begin
                  if (notfirstf) then begin
                    AddTextToArea("&",a_conf);
                  end else begin
                    AddTextToArea("same => n,Dial(",a_conf);
                  end;
                  notfirstf = true;
                  AddTextToArea("" & chanstr & AsteriskUserr.UserName,a_conf);
                end;
              end;
            end;
            RecordClear(GUserr);
            ResetLoop(GUserr);
            while (LoopMain(GUserr,1,true)) begin
              test3f = false;
              if (GUserr.Closed==0 and GUserr.ExcludeQueueFallbackf==0) then begin
                if (blank(GUserr.AstPBXConnection)) then begin test3f = true; end;
                pos = 0;
                while (GetNextSubstring(GUserr.AstPBXConnection,pos,",",tstr)) begin
                  if (tstr==PBXCr.Code) then begin
                    if (IsValidPBXConnection(tstr)) then begin
                      test3f = true;
                    end;
                  end;
                end;
                if (blank(GUserr.AstUserName)) then begin
                  test3f = false;
                end;
                if (test3f) then begin
                  if (notfirstf) then begin
                    AddTextToArea("&",a_conf);
                  end else begin
                    AddTextToArea("same => n,Dial(",a_conf);
                  end;
                  notfirstf = true;
                  AddTextToArea("" & chanstr & GUserr.AstUserName,a_conf);
                end;
              end;
            end;
            RecordClear(Userr);
            ResetLoop(Userr);
            while (LoopMain(Userr,1,true)) begin
              test3f = false;
              if (Userr.Closed==0 and Userr.ExcludeQueueFallbackf==0) then begin
                if (blank(Userr.AstPBXConnection)) then begin test3f = true; end;
                pos = 0;
                while (GetNextSubstring(Userr.AstPBXConnection,pos,",",tstr)) begin
                  if (tstr==PBXCr.Code) then begin
                    if (IsValidPBXConnection(tstr)) then begin
                      test3f = true;
                    end;
                  end;
                end;
                if (blank(Userr.AstUserName)) then begin
                  test3f = false;
                end;
                if (test3f) then begin
                  if (notfirstf) then begin
                    AddTextToArea("&",a_conf);
                  end else begin
                    AddTextToArea("same => n,Dial(",a_conf);
                  end;
                  notfirstf = true;
                  AddTextToArea(chanstr & Userr.AstUserName,a_conf);
                end;
              end;
            end;
            if (notfirstf) then begin
              AddTextToArea(",60)" & chr(10),a_conf);
            end;
          end;
          if (nonblank(PBXQr.FallBackNumber)) then begin
            AddLineToArea("same => n,Goto(HW_TRUNK," & PBXQr.FallBackNumber & ",1)",a_conf);
          end;
          AddLineToArea("same => n,Return",a_conf);
        end;
      end;
    end;
  end;
  AddLineToArea("[HW_OPENING_HOURS]",a_conf);
  AddLineToArea("exten => s,1,NoOp()",a_conf); // Must have exten => ...
  
  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      ResetLoop(PBXQr);
      PBXQr.SipTrunk = STr.Code;
      found2f = true;
      while (LoopKey("SipTrunk",PBXQr,1,found2f)) begin
        if (PBXQr.SipTrunk!=STr.Code) then begin found2f = false; end;
        test2f = found2f;
        if (PBXQr.Closed!=0) then begin test2f = false; end;
        if (blank(PBXQr.Code)) then begin test2f = false; end;
        if (test2f==true) then begin
          //## Add days and timezone
          AddTextToArea("same => n(HW_JUMP_Q_" & PBXQr.Code & ")",a_conf);
          if (PBXQr.ExcludeBankHolidaysf) then begin
            AddBankHolidays("HW_JUMP_ISCLOSED_Q_" & PBXQr.Code,PBXQr.CRMCompany,a_conf);
          end;
          if (PBXQr.AlwaysClosedf==0) then begin
            if (blanktime(PBXQr.OpenTime) or blanktime(PBXQr.CloseTime)) then begin
              AddLineToArea(",GotoIfTime(*,*,*,*?HW_Q_" & PBXQr.Code & ",s,HW_JUMP_ISOPEN)",a_conf);
            end else begin
              AddLineToArea(",GotoIfTime(" & PBXQr.OpenTime & "-" & PBXQr.CloseTime & ",mon-fri,*,*?HW_Q_" & PBXQr.Code & ",s,HW_JUMP_ISOPEN)",a_conf);
              if (nonblanktime(PBXQr.OpenTime2) and nonblanktime(PBXQr.CloseTime2)) then begin
                AddLineToArea("same => n,GotoIfTime(" & PBXQr.OpenTime2 & "-" & PBXQr.CloseTime2 & ",mon-fri,*,*?HW_Q_" & PBXQr.Code & ",s,HW_JUMP_ISOPEN)",a_conf);
              end;
            end;
          end;
          AddLineToArea("same => n(HW_JUMP_ISCLOSED_Q_" & PBXQr.Code & "),Verbose(0,${Q} line is closed, playing ""office closed"" message and hanging up...)",a_conf);
          AddLineToArea("same => n," & PlayAsteriskSound(PBXQr.Code,kAsteriskEventSoundLineClosed,kAsteriskForegroundPlayback),a_conf);
          AddLineToArea("same => n,Hangup()",a_conf);
        end;
      end;
      ResetLoop(PBXIVRTreer);
      PBXIVRTreer.SipTrunk = STr.Code;
      found2f = true;
      while (LoopKey("SipTrunk",PBXIVRTreer,1,found2f)) begin
        if (PBXIVRTreer.SipTrunk!=STr.Code) then begin found2f = false; end;
        test2f = found2f;
        if (PBXIVRTreer.Closed!=0) then begin test2f = false; end;
        if (blank(PBXIVRTreer.Code)) then begin test2f = false; end;
        if (test2f==true) then begin
          AddTextToArea("same => n(HW_JUMP_IVR_" & PBXIVRTreer.Code & ")",a_conf);
          if (PBXIVRTreer.ExcludeBankHolidaysf) then begin
            AddBankHolidays("HW_JUMP_ISCLOSED_IVR_" & PBXIVRTreer.Code,PBXQr.CRMCompany,a_conf);
          end;
          if (PBXIVRTreer.AlwaysClosedf==0) then begin
            if (blanktime(PBXIVRTreer.OpenTime) or blanktime(PBXIVRTreer.CloseTime)) then begin
              AddLineToArea(",GotoIfTime(*,*,*,*?HW_IVR_" & PBXIVRTreer.Code & ",s,HW_JUMP_ISOPEN)",a_conf);
            end else begin
              AddLineToArea(",GotoIfTime(" & PBXIVRTreer.OpenTime & "-" & PBXIVRTreer.CloseTime & ",mon-fri,*,*?HW_IVR_" & PBXIVRTreer.Code & ",s,HW_JUMP_ISOPEN)",a_conf);
              if (nonblanktime(PBXIVRTreer.OpenTime2) and nonblanktime(PBXIVRTreer.CloseTime2)) then begin
                AddLineToArea("same => n,GotoIfTime(" & PBXIVRTreer.OpenTime2 & "-" & PBXIVRTreer.CloseTime2 & ",mon-fri,*,*?HW_IVR_" & PBXIVRTreer.Code & ",s,HW_JUMP_ISOPEN)",a_conf);
              end;
            end;
          end;
          AddLineToArea("same => n(HW_JUMP_ISCLOSED_IVR_" & PBXIVRTreer.Code & "),Verbose(0,${Q} line is closed, playing ""office closed"" message and hanging up...)",a_conf);
          AddLineToArea("same => n," & PlayAsteriskSound(PBXIVRTreer.Code,kAsteriskEventSoundLineClosed,kAsteriskForegroundPlayback),a_conf);
          AddLineToArea("same => n,Hangup()",a_conf);
        end;
      end;
    end;
  end;

  AddLineToArea("[HW_AGENT_PICKUP]",a_conf);
  AddLineToArea("exten => s,1,Verbose(0,Call from number ${CALLERID(num)} was answered by agent ${MEMBERNAME} in ${QUEUENAME} queue)",a_conf);
  //AddLineToArea("same => n,MixMonitor(,br(${UNIQUEID}-in.ogg)t(${UNIQUEID}-out.ogg)W(1))",a_conf);
  AddLineToArea("same => n,Return",a_conf);
  
  AddLineToArea("#include queuemanagement.conf",a_conf); //??
  AddLineToArea("#include trunks.conf",a_conf); //??

  AddLineToArea("[HW_INBOUND]",a_conf);

  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      rwcnt = MatRowCnt(STr);
      for (i=0;i<rwcnt;i=i+1) begin
        MatRowGet(STr,i,STrw);
        if (nonblank(STrw.Extension) and stextvec[STrw.Extension]==false) then begin
          stextvec[STrw.Extension] = true;
          if (STr.ChanSIPf==1) then begin
            AddLineToArea("exten => _" & STrw.Extension & ",1,Verbose(0,Setting up an inbound call [ CALLID: ${UNIQUEID} ] from [ ${CALLERID(num)} ] to [ ${EXTEN} ] on channel [ ${CHANNEL(peername)} ])",a_conf);
          end else begin
            AddLineToArea("exten => _" & STrw.Extension & ",1,Verbose(0,Setting up an inbound call [ CALLID: ${UNIQUEID} ] from [ ${CALLERID(num)} ] to [ ${EXTEN} ] on channel [ ${CHANNEL(endpoint)} ])",a_conf);
          end;
          AddLineToArea("same => n,Set(INBOUND_EXTEN=${EXTEN})",a_conf);
          AddLineToArea("same => n,Goto(HW_JUMP_TRUNK_" & STr.Code & ")",a_conf);
        end;
      end;
    end;
  end;
  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      ResetLoop(PBXQr);
      PBXQr.SipTrunk = STr.Code;
      found2f = true;
      while (LoopKey("SipTrunk",PBXQr,1,found2f)) begin
        if (PBXQr.SipTrunk!=STr.Code) then begin found2f = false; end;
        test2f = found2f;
        if (PBXQr.Closed!=0) then begin test2f = false; end;
        if (PBXQr.Extension=="") then begin test2f = false; end;
        if (test2f==true) then begin
          pos = 0;
          while (GetNextSubstring(PBXQr.Extension,pos,",",tstr)) begin
            if (stextvec[tstr]==false) then begin
              stextvec[tstr] = true;
              if (STr.ChanSIPf==1) then begin
                AddLineToArea("exten => _" & tstr & ",1,Verbose(0,Setting up an inbound call [ CALLID: ${UNIQUEID} ] from [ ${CALLERID(num)} ] to [ ${EXTEN} ] on channel [ ${CHANNEL(peername)} ])",a_conf);
              end else begin
                AddLineToArea("exten => _" & tstr & ",1,Verbose(0,Setting up an inbound call [ CALLID: ${UNIQUEID} ] from [ ${CALLERID(num)} ] to [ ${EXTEN} ] on channel [ ${CHANNEL(endpoint)} ])",a_conf);
              end;
              AddLineToArea("same => n,Goto(HW_JUMP_TRUNK_" & STr.Code & ")",a_conf);
            end;
          end;
        end;
      end;
      ResetLoop(PBXIVRTreer);
      PBXIVRTreer.SipTrunk = STr.Code;
      found2f = true;
      while (LoopKey("SipTrunk",PBXIVRTreer,1,found2f)) begin
        if (PBXIVRTreer.SipTrunk!=STr.Code) then begin found2f = false; end;
        test2f = found2f;
        if (PBXIVRTreer.Closed!=0) then begin test2f = false; end;
        if (PBXIVRTreer.Extension=="") then begin test2f = false; end;
        if (test2f==true) then begin
          pos = 0;
          while (GetNextSubstring(PBXIVRTreer.Extension,pos,",",tstr)) begin
            if (stextvec[tstr]==false) then begin
              stextvec[tstr] = true;
              if (STr.ChanSIPf==1) then begin
                AddLineToArea("exten => _" & tstr & ",1,Verbose(0,Setting up an inbound call [ CALLID: ${UNIQUEID} ] from [ ${CALLERID(num)} ] to [ ${EXTEN} ] on channel [ ${CHANNEL(peername)} ])",a_conf);
              end else begin
                AddLineToArea("exten => _" & tstr & ",1,Verbose(0,Setting up an inbound call [ CALLID: ${UNIQUEID} ] from [ ${CALLERID(num)} ] to [ ${EXTEN} ] on channel [ ${CHANNEL(endpoint)} ])",a_conf);
              end;
              AddLineToArea("same => n,Goto(HW_JUMP_TRUNK_" & STr.Code & ")",a_conf);
            end;
          end;
        end;
      end;
    end;
  end;
  AddLineToArea("exten => _X.,1,Verbose(0,Setting up an inbound call [ CALLID: ${UNIQUEID} ] from [ ${CALLERID(num)} ] to [ ${EXTEN} ])",a_conf);

  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      if (STr.ChanSIPf==1) then begin
        AddLineToArea("same => n,GotoIf($[""${CHANNEL(peername)}"" = ""HW_SIPTRUNK_" & STr.Code & """]?HW_JUMP_TRUNK_" & STr.Code & ")",a_conf);
      end else begin
        AddLineToArea("same => n,GotoIf($[""${CHANNEL(endpoint)}"" = ""HW_SIPTRUNK_" & STr.Code & """]?HW_JUMP_TRUNK_" & STr.Code & ")",a_conf);
      end;
    end;
  end;

  AddLineToArea("same => n,Goto(HW_JUMP_DENYCALL)",a_conf);

  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      if (nonblank(STr.TalkBotHost)) then begin
        AddLineToArea("same => n(HW_JUMP_TRUNK_" & STr.Code & "),Set(IAXVAR(HW_IAX_SOURCE)=HW_NOT_IAX)",a_conf);
        AddLineToArea("same => n,Answer",a_conf);
        AddLineToArea("same => n,Dial(" & chanstr & "HW_TALKBOT_SIPTRUNK_" & STr.Code & ",60,TtKk)",a_conf);
      end else begin
        AddLineToArea("same => n(HW_JUMP_TRUNK_" & STr.Code & "),Set(IAXVAR(HW_IAX_SOURCE)=HW_NOT_IAX)",a_conf);
        AddLineToArea("same => n,Goto(HW_FUNCTIONS,${EXTEN},1)",a_conf);
      end;
    end;
  end;

  AddLineToArea("same => n(HW_JUMP_DENYCALL),Verbose(0,Inbound call forbidden. Hanging up)",a_conf);
  AddLineToArea("same => n,Hangup()",a_conf);
  WriteAreaToFile(a_conf,conf_file,0);
  return;
end;

function Boolean AddOneUserToTrunksConf(string astusername,string pbxconnections,record PBXConnectionVc PBXCr,var area a_conf)
begin
  LongInt pos;
  string 255 pbxcode;
  Boolean res,testf;
  
  while (GetNextSubstring(pbxconnections,pos,",",pbxcode)) begin
    if (nonblank(pbxcode)) then begin
      if (pbxcode==PBXCr.Code) then begin
        if (IsValidPBXConnection(pbxcode)) then begin
          goto LAddOneUserToTrunksConf_addlocal;
        end;
      end;
    end;
  end;
  
  pos = -1;
  while (GetNextSubstring(pbxconnections,pos,",",pbxcode)) begin
    if (nonblank(pbxcode)) then begin
      if (pbxcode!=PBXCr.Code) then begin
        if (IsValidPBXConnection(pbxcode)) then begin
          goto LAddOneUserToTrunksConf_addiax; // possibly we could add all iax connections with priorities...
        end;
      end;
    end;
  end;
  goto LAddOneUserToTrunksConf;
  
LAddOneUserToTrunksConf_addiax:;
  AddLineToArea("exten => " & astusername & ",1,Exec(Dial(IAX2/HW_IAX_" & pbxcode & "/${EXTEN},60,TtKk))",a_conf);
  AddLineToArea("same => n,Hangup()",a_conf);
  res = true;
  goto LAddOneUserToTrunksConf;

LAddOneUserToTrunksConf_addlocal:;
  AddLineToArea("exten => " & astusername & ",1,Exec(Dial(PJSIP/${EXTEN},60,TtKk))",a_conf);
  AddLineToArea("same => n,Hangup()",a_conf);
  res = true;

LAddOneUserToTrunksConf:;
  AddOneUserToTrunksConf = res;
  return;
end;

procedure AddIAXRoutedUsersToTrunksConf(record PBXConnectionVc PBXCr,var area a_conf)
begin
  record AsteriskUser2Vc AsteriskUserr;
  record UserVc Userr;
  record GlobalUserVc GUserr;
  vector Boolean uservec;
  Boolean testf;

  while (LoopMain(AsteriskUserr,1,true)) begin
    testf = true;
    if (uservec[AsteriskUserr.UserName]==true) then begin testf = false; end;
    if (AsteriskUserr.Closedf<>0) then begin testf = false; end;
    if (testf) then begin
      testf = AddOneUserToTrunksConf(AsteriskUserr.UserName,AsteriskUserr.PBXConnection,PBXCr,a_conf);
      if (testf) then begin uservec[AsteriskUserr.UserName] = true; end;
    end;
  end;
  
  while (LoopMain(GUserr,1,true)) begin
    testf = true;
    if (uservec[GUserr.AstUserName]==true) then begin testf = false; end;
    if (GUserr.Closed<>0) then begin testf = false; end;
    if (testf) then begin
      testf = AddOneUserToTrunksConf(GUserr.AstUserName,GUserr.AstPBXConnection,PBXCr,a_conf);
      if (testf) then begin uservec[GUserr.AstUserName] = true; end;
    end;
  end;
  
  while (LoopMain(Userr,1,true)) begin
    testf = true;
    if (uservec[Userr.AstUserName]==true) then begin testf = false; end;
    if (Userr.Closed<>0) then begin testf = false; end;
    if (testf) then begin
      testf = AddOneUserToTrunksConf(Userr.AstUserName,Userr.AstPBXConnection,PBXCr,a_conf);
      if (testf) then begin uservec[Userr.AstUserName] = true; end;
    end;
  end;
  
  return;
end;

global
updating procedure CreateTrunksConf(record PBXConnectionVc PBXCr,Boolean localf)
begin
  area a_conf;
  string 255 conf_file;
  record SipTrunk2Vc STr;
  record PBXConnectionVc PBXC2r;
  boolean testf,foundf;
  string 255 defcallid,chanstr,defsiptrunk;
  Integer l;

  if (UseChanPJSIP(PBXCr)) then begin
    chanstr = "PJSIP/"; // Maybe "Local/" would work for both?
  end else begin
    chanstr = "SIP/";
  end;
  
  CreateFolderHierarchy(AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/");
  conf_file = AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/trunks.conf";

  AddLineToArea("[HW_TRUNK]",a_conf);
  
  defcallid = "";
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (STr.CountryCode!=PBXCr.CountryCode) then begin testf = false; end;
    if (testf) then begin
      defcallid = STr.DefaultCallerId;
    end;
  end;
  AddLineToArea("exten => _XX.,1,Set(DIALEXTEN=${FILTER(0-9,${EXTEN})})",a_conf);
  AddLineToArea("same => n,Gosub(groupgw,s,1)",a_conf);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  if (nonblank(defcallid)) then begin
    AddLineToArea("same => n,Set(CALLERID(num)=" & defcallid & ")",a_conf);
  end;
  AddLineToArea("same => n,ExecIf($[\"${DIALCOUNTRY:0:5}\" = \"IAX2/\"]?Dial(${DIALCOUNTRY}/${DIALEXTEN},60):Dial(" & chanstr & "${DIALEXTEN}@${DIALCOUNTRY},60))",a_conf);
  AddLineToArea("same => n,Hangup()",a_conf);
  AddLineToArea("exten => _00XX.,1,Set(DIALEXTEN=${FILTER(0-9,${EXTEN})})",a_conf);
  AddLineToArea("same => n,Gosub(groupgw,s,1)",a_conf);
  if (nonblank(defcallid)) then begin
    AddLineToArea("same => n,Set(CALLERID(num)=" & defcallid & ")",a_conf);
  end;
  AddLineToArea("same => n,ExecIf($[\"${DIALCOUNTRY:0:5}\" = \"IAX2/\"]?Dial(${DIALCOUNTRY}/${DIALEXTEN},60):Dial(" & chanstr & "${DIALEXTEN}@${DIALCOUNTRY},60))",a_conf);
  AddLineToArea("same => n,Hangup()",a_conf);
  
  AddLineToArea("exten => _+XX.,1,Set(DIALEXTEN=${FILTER(+0-9,${EXTEN})})",a_conf);
  AddLineToArea("same => n,Gosub(groupgw,s,1)",a_conf);
  if (nonblank(defcallid)) then begin
    AddLineToArea("same => n,Set(CALLERID(num)=" & defcallid & ")",a_conf);
  end;
  AddLineToArea("same => n,ExecIf($[\"${DIALCOUNTRY:0:5}\" = \"IAX2/\"]?Dial(${DIALCOUNTRY}/${DIALEXTEN},60):Dial(" & chanstr & "${DIALEXTEN}@${DIALCOUNTRY},60))",a_conf);
  AddLineToArea("same => n,Hangup()",a_conf);

  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (blank(STr.CountryCode)) then begin testf = false; end;
    if (testf) then begin
      l = len(STr.CountryCode);
      if (nonblank(STr.SkipDigit)) then begin
        AddLineToArea("exten => _" & STr.SkipDigit & "XX.,1,Set(DIALEXTEN=+" & STr.CountryCode & "${FILTER(0-9,${EXTEN:1})})",a_conf);
        AddLineToArea("same => n,Gosub(groupgw,s,1)",a_conf);
        AddLineToArea("same => n,Set(CALLERID(num)=" & STr.DefaultCallerId & ")",a_conf);
        AddLineToArea("same => n,ExecIf($[\"${DIALCOUNTRY:0:5}\" = \"IAX2/\"]?Dial(${DIALCOUNTRY}/${DIALEXTEN},60):Dial(" & chanstr & "${DIALEXTEN}@${HW_SIPTRUNKVAR_" & STr.Code & "},60))",a_conf);
        AddLineToArea("same => n,Hangup()",a_conf);
      end;
      if (STr.DialLocallyf) then begin
        AddLineToArea("exten => _+" & STr.CountryCode & "XX.,1,Set(DIALEXTEN=${FILTER(+0-9,${EXTEN:" & len("+" & STr.CountryCode) & "})})",a_conf);
        AddLineToArea("same => n,Gosub(groupgw,s,1)",a_conf);
        AddLineToArea("same => n,Set(CALLERID(num)=" & STr.DefaultCallerId & ")",a_conf);
        AddLineToArea("same => n,ExecIf($[\"${DIALCOUNTRY:0:5}\" = \"IAX2/\"]?Dial(${DIALCOUNTRY}/${DIALEXTEN},60):Dial(" & chanstr & "${DIALEXTEN}@${HW_SIPTRUNKVAR_" & STr.Code & "},60))",a_conf);
        AddLineToArea("same => n,Hangup()",a_conf);
      end;
    end;
  end;

  RecordClear(PBXC2r);
  ResetLoop(PBXC2r);
  while (LoopMain(PBXC2r,1,true)) begin
    testf = true;
    if (PBXC2r.Closed!=0) then begin testf = false; end;
    if (IsAsteriskPbxType(PBXC2r.PBXType)==false) then begin testf = false; end;
    if (PBXC2r.Code==PBXCr.Code) then begin testf = false; end;
    if (PBXC2r.IAXf==0) then begin testf = false; end;
    if (testf==true) then begin
      AddLineToArea("exten => _[+]" & PBXC2r.CountryCode & "XX.,1,Set(DIALEXTEN=+${FILTER(0-9,${EXTEN})})",a_conf);
      AddLineToArea("same => n,Gosub(groupgw,s,1)",a_conf);
      AddLineToArea("same => n,Dial(IAX2/HW_IAX_" & PBXC2r.Code & "/${DIALEXTEN},60)",a_conf);
      AddLineToArea("same => n,Hangup()",a_conf);
      AddLineToArea("exten => _00" & PBXC2r.CountryCode & "XX.,1,Set(DIALEXTEN=${FILTER(0-9,${EXTEN})})",a_conf);
      AddLineToArea("same => n,Gosub(groupgw,s,1)",a_conf);
      AddLineToArea("same => n,Dial(IAX2/HW_IAX_" & PBXC2r.Code & "/${DIALEXTEN},60)",a_conf);
      AddLineToArea("same => n,Hangup()",a_conf);
    end;
  end;
  
  AddIAXRoutedUsersToTrunksConf(PBXCr,a_conf);
  
  AddLineToArea("exten => _X.,1,Exec(Dial(PJSIP/${EXTEN},60,TtKk))",a_conf);
  AddLineToArea("same => n,Hangup()",a_conf);

  AddLineToArea("[groupgw]",a_conf);
  AddLineToArea("exten => s,1,Verbose(0,Setting up an outbound call by ${CALLERID(name)} to number: ${DIALEXTEN} \"[CALLID: ${UNIQUEID}\", IAXVAR(HW_IAX_SOURCE): \"${IAXVAR(HW_IAX_SOURCE)}\"])",a_conf);

  AddLineToArea("same => n,Set(DENOISE(tx)=on)",a_conf);
//  AddLineToArea("same => n,Set(AGC(rx)=-8000)",a_conf); // This doesn't work, external calls get voice muted entirely

  AddLineToArea("same => n,GoToIf($[""${IAXVAR(HW_IAX_SOURCE)}"" = """"]?HW_JUMP_INVALID_IAX)",a_conf);
//  AddLineToArea("same => n,MixMonitor(,br(${UNIQUEID}-in.ogg)t(${UNIQUEID}-out.ogg)W(1))",a_conf);
  AddLineToArea("same => n,GoToIf($[""${IAXVAR(HW_IAX_SOURCE)}"" = ""HW_NOT_IAX""]?HW_USERS,s,1)",a_conf);

  RecordClear(PBXC2r);
  ResetLoop(PBXC2r);
  while (LoopMain(PBXC2r,1,true)) begin
    testf = true;
    if (PBXC2r.Closed!=0) then begin testf = false; end;
    if (IsAsteriskPbxType(PBXC2r.PBXType)==false) then begin testf = false; end;
    if (PBXC2r.Code==PBXCr.Code) then begin testf = false; end;
    if (PBXC2r.IAXf==0) then begin testf = false; end;
    if (testf==true) then begin
      AddLineToArea("same => n,GoToIf($[""${IAXVAR(HW_IAX_SOURCE)}"" = ""HW_IAX_" & PBXC2r.Code & """]?HW_JUMP_IAX)",a_conf);
    end;
  end;

  AddLineToArea("same => n(HW_JUMP_INVALID_IAX),Verbose(0,This caller is not allowed to make outbound calls, hanging up...)",a_conf);
  AddLineToArea("same => n,Hangup()",a_conf);
  AddLineToArea("same => n(HW_JUMP_IAX),Verbose(0,Handling inbound call from ${DIALEXEN})",a_conf);
  AddLineToArea("same => n,Return",a_conf);

  AddLineToArea("[HW_USERS]",a_conf);
  defsiptrunk = "";
  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
//      AddLineToArea("exten => s,1,MSet(DIALCOUNTRY=${HW_SIPTRUNKVAR_" & STr.Code & "})",a_conf);
      defsiptrunk = STr.Code;
    end;
  end;

  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (STr.CountryCode!=PBXCr.CountryCode) then begin testf = false; end;
    if (testf) then begin
      defsiptrunk = STr.Code;
    end;
  end;

  if (blank(defsiptrunk)) then begin
    defsiptrunk = DefaultSIPTrunk(PBXCr,"");
  end;

  if (nonblank(defsiptrunk)) then begin
    AddLineToArea("exten => s,1,ExecIf($[\"${DIALCOUNTRY}\" = \"\"]?MSet(DIALCOUNTRY=${HW_SIPTRUNKVAR_" & defsiptrunk & "}))",a_conf);
  end;

  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  if (ReadFirstMain(STr,1,true)) begin
    if (STr.PBXConnection==PBXCr.Code) then begin
      if (STr.Closedf==0) then begin
        if (nonblank(STr.DefaultCallerId)) then begin
          AddLineToArea("same => n,Set(CALLERID(all)=""" & STr.Comment & """ <" & STr.DefaultCallerId & ">)",a_conf);
        end;
      end;
    end;
  end;
  
  AddLineToArea("same => n,Return",a_conf);

  WriteAreaToFile(a_conf,conf_file,0);
  return;
end;

global
updating procedure CreateQueueManagementConf(record PBXConnectionVc PBXCr,Boolean localf)
begin
  area a_conf;
  string 255 conf_file;
  record SipTrunk2Vc STr;
  record PBXQueueVc PBXQr;
  record PBXConnectionVc PBXC2r;
  boolean testf,foundf,test2f,test3f,found2f,firstf,found3f;

  CreateFolderHierarchy(AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/");
  conf_file = AsteriskConfigBaseDir(PBXCr,localf) & "/etc/asterisk/queuemanagement.conf";

  AddLineToArea("[HW_QUEUE_MANAGEMENT]",a_conf);

  if (PBXCr.IAXf!=0) then begin
    while (LoopMain(PBXC2r,1,true)) begin
      testf = true;
      if (PBXC2r.Closed!=0) then begin testf = false; end;
      if (IsAsteriskPbxType(PBXC2r.PBXType)==false) then begin testf = false; end;
      if (PBXC2r.Code==PBXCr.Code) then begin testf = false; end;
      if (PBXC2r.IAXf==0) then begin testf = false; end;
      if (blank(PBXC2r.PBXHostIP)) then begin testf = false; end;
      if (testf==true) then begin
        ResetLoop(STr);
        STr.PBXConnection = PBXC2r.Code;
        foundf = true;
        while (LoopKey("PBXConnection",STr,1,foundf)) begin
          if (STr.PBXConnection!=PBXC2r.Code) then begin foundf = false; end;
          test2f = foundf;
          if (STr.Closedf!=0) then begin test2f = false; end;
          if (test2f) then begin
            ResetLoop(PBXQr);
            PBXQr.SipTrunk = STr.Code;
            found2f = true;
            while (LoopKey("SipTrunk",PBXQr,1,found2f)) begin
              if (PBXQr.SipTrunk!=STr.Code) then begin found2f = false; end;
              test3f = found2f;
              if (PBXQr.Closed!=0) then begin test3f = false; end;
              if (test3f==true) then begin
                AddLineToArea("exten => HW_Q_" & PBXQr.Code & ",1,Answer()",a_conf);
                AddLineToArea("same => n,Ringing",a_conf);
                AddLineToArea("same => n,Dial(IAX2/HW_IAX_" & PBXC2r.Code & "/HW_Q_" & PBXQr.Code & ",60,TtKk)",a_conf);
                AddLineToArea("same => n,Hangup()",a_conf);
              end;
            end;
          end;
        end;
      end;
    end;
  end;

  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (testf) then begin
      ResetLoop(PBXQr);
      PBXQr.SipTrunk = STr.Code;
      found2f = true;
      while (LoopKey("SipTrunk",PBXQr,1,found2f)) begin
        if (PBXQr.SipTrunk!=STr.Code) then begin found2f = false; end;
        test2f = found2f;
        if (PBXQr.Closed!=0) then begin test2f = false; end;
        if (test2f==true) then begin
          AddLineToArea("exten => HW_Q_" & PBXQr.Code & ",1,Answer()",a_conf);
          AddLineToArea("same => n,GoTo(HW_Q_" & PBXQr.Code & ",s,1)",a_conf);
// We use AMI actions to add/remove queue members now, so this code is not needed - and it is buggy (can generate conflicts if many PBX connections/queues are defined)
//          AddLineToArea("exten => *" & STr.CountryCode & "*" & PBXQr.QueueID & "1,1,AddQueueMember(HWQUEUE" & PBXQr.Code & ",,,,${CALLERID(name)},)",a_conf);
//          AddLineToArea("same => n,Wait(1)",a_conf);
//          AddLineToArea("same => n,GoToIf($[""${AQMSTATUS}"" = ""ADDED""]?HW_QUEUEMEMBER_LOGGEDIN,s,1)",a_conf);
//          AddLineToArea("same => n,GoToIf($[""${AQMSTATUS}"" = ""MEMBERALREADY""]?HW_QUEUEMEMBER_ALREADYON,s,1)",a_conf);
//          AddLineToArea("same => n,Wait(1)",a_conf);
//          AddLineToArea("same => n,Hangup()",a_conf);
//          AddLineToArea("exten => *" & STr.CountryCode & "*" & PBXQr.QueueID & "0,1,RemoveQueueMember(HWQUEUE" & PBXQr.Code & ",)",a_conf);
//          AddLineToArea("same => n,Wait(1)",a_conf);
//          AddLineToArea("same => n,GoToIf($[""${RQMSTATUS}"" = ""REMOVED""]?HW_QUEUEMEMBER_LOGGEDOUT,s,1)",a_conf);
//          AddLineToArea("same => n,Wait(1)",a_conf);
//          AddLineToArea("same => n,Hangup()",a_conf);
        end;
      end;
    end;
  end;

  ResetLoop(STr);
  STr.PBXConnection = PBXCr.Code;
  foundf = true;
  while (LoopKey("PBXConnection",STr,1,foundf)) begin
    if (STr.PBXConnection!=PBXCr.Code) then begin foundf = false; end;
    testf = foundf;
    if (STr.Closedf!=0) then begin testf = false; end;
    if (blank(STr.CountryCode)) then begin testf = false; end;
    if (testf) then begin
      found3f = false;
      firstf = true;
      ResetLoop(PBXQr);
      PBXQr.SipTrunk = STr.Code;
      found2f = true;
      while (LoopKey("SipTrunk",PBXQr,1,found2f)) begin
        if (PBXQr.SipTrunk!=STr.Code) then begin found2f = false; end;
        test2f = found2f;
        if (PBXQr.Closed!=0) then begin test2f = false; end;
        if (test2f==true) then begin
          if (firstf) then begin
            firstf = false;
            found3f = true;
            AddLineToArea("exten => *" & STr.CountryCode & "*00,1,RemoveQueueMember(HWQUEUE" & PBXQr.Code & ",)",a_conf);
          end else begin
            AddLineToArea("same => n,RemoveQueueMember(HWQUEUE" & PBXQr.Code & ",)",a_conf);
          end;
        end;
      end;
      if (found3f) then begin
        AddLineToArea("same => n,GoTo(HW_QUEUEMEMBER_LOGGEDOUT,s,1)",a_conf);
      end;
    end;
  end;

  AddLineToArea("[HW_QUEUEMEMBER_LOGGEDIN]",a_conf);
  AddLineToArea("exten => s,1,Playback(agent-loginok)",a_conf);
  AddLineToArea("same => n,Wait(1)",a_conf);
  AddLineToArea("same => n,Hangup()",a_conf);

  AddLineToArea("[HW_QUEUEMEMBER_LOGGEDOUT]",a_conf);
  AddLineToArea("exten => s,1,Playback(silence/1&agent-loggedoff)",a_conf);
  AddLineToArea("same => n,Wait(1)",a_conf);
  AddLineToArea("same => n,Hangup()",a_conf);

  AddLineToArea("[HW_QUEUEMEMBER_ALREADYON]",a_conf);
  AddLineToArea("exten => s,1,Wait(1)",a_conf);
  AddLineToArea("same => n,Wait(1)",a_conf);
  AddLineToArea("same => n,Playback(silence/1&agent-alreadyon)",a_conf);
  AddLineToArea("same => n,Wait(1)",a_conf);
  AddLineToArea("same => n,Hangup()",a_conf);
  WriteAreaToFile(a_conf,conf_file,0);
  return;
end;

function Boolean ShouldCopySoundFileToPBX(record PBXConnectionVc PBXCr,record PBXSoundVc PBXSr,var string queue)
begin
  Boolean res;
  record PBXQueueVc PBXQr;
  record SipTrunk2Vc STr;
  record PBXIVRTreeVc PBXIVRTr;
  LongInt pos;
  
  res = true;
  if (blank(PBXSr.Queue)) then begin goto LShouldCopySoundFileToPBX; end;
  
  while (GetNextSubstring(PBXSr.Queue,pos,",",queue)) begin
    if ((PBXSr.Event==kAsteriskEventSoundQueueStart) or (PBXSr.Event==kAsteriskEventSoundLineClosed) or (PBXSr.Event==kAsteriskEventSoundLineBusy)) begin
      PBXQr.Code = queue;
      if (ReadFirstMain(PBXQr,1,true)) then begin
        STr.Code = PBXQr.SipTrunk;
        if (ReadFirstMain(STr,1,true)) then begin
          if (PBXCr.Code==STr.PBXConnection) then begin goto LShouldCopySoundFileToPBX; end;
        end;
      end;
    end;
    if ((PBXSr.Event==kAsteriskEventSoundIVRStart) or (PBXSr.Event==kAsteriskEventSoundIVRClosed)) begin
      PBXIVRTr.Code = queue;
      if (ReadFirstMain(PBXIVRTr,1,true)) then begin
        STr.Code = PBXIVRTr.SipTrunk;
        if (ReadFirstMain(STr,1,true)) then begin
          if (PBXCr.Code==STr.PBXConnection) then begin goto LShouldCopySoundFileToPBX; end;
        end;
      end;
    end;
  end;
  res = false;

LShouldCopySoundFileToPBX:;
  ShouldCopySoundFileToPBX = res;
  return;
end;

global
updating procedure GenerateSoundFiles(record PBXConnectionVc PBXCr,Boolean localf)
begin
  record PBXSoundVc PBXSr;
  record Attach2Vc Attach2r;
  record RLinkVc RLr;
  string 255 fname,queue;
  Area a;
  Integer filenr;
  LongInt filecnt,idx;
  string 255 sounddir,mohsounddir,filename;

  sounddir = AsteriskConfigBaseDir(PBXCr,localf) & "/var/lib/asterisk/sounds";
  CreateFolderHierarchy(sounddir & "/");
  filecnt = CountFilesInDir(sounddir);
  for (idx = filecnt; idx>0; idx = idx - 1) begin
    filename = GetFileNameInDir(sounddir,idx-1);
    if ((left(filename,12)=="HW_PBXSound_") or (left(filename,4)=="snd_")) then begin
      Delete_File(sounddir & "/" & filename);
    end;
  end;

  mohsounddir = AsteriskConfigBaseDir(PBXCr,localf) & "/var/lib/asterisk/sounds-moh";
  if (DirExists(mohsounddir)) then begin DeleteFolder(mohsounddir); end;
  CreateFolderHierarchy(mohsounddir & "/");
  while (LoopMain(PBXSr,1,true)) begin
    if (PBXSr.Closed==0) then begin
      filenr = 1;
      if (PBXSr.Event==kAsteriskEventSoundMusicOnHold) then begin
        fname = mohsounddir & "/";
        CreateFolderHierarchy(fname);
        while (ReadRecordLink(PBXSr,filenr,Attach2r,RLr)) begin
          if ((nonblank(Attach2r.FileName)) and (Attach2r.Uploading==0)) then begin
            fname = mohsounddir & "/" & Attach2r.FileName;
            SetAreaZeroSize(a);
            AddAttachFileToArea(Attach2r,a,false);
            Delete_File(fname);
            WriteAreaToFile(a,fname,0);
          end;
          filenr = filenr + 1;
        end;
      end else begin
        if (ShouldCopySoundFileToPBX(PBXCr,PBXSr,queue)==true) then begin
          if (nonblank(queue)) then begin
            fname = AsteriskConfigBaseDir(PBXCr,localf) & "/var/lib/asterisk/sounds/" & SoundFileName(queue,PBXSr.Event) & ".wav";
            while (ReadRecordLink(PBXSr,filenr,Attach2r,RLr)) begin
              if ((nonblank(Attach2r.FileName)) and (Attach2r.Uploading==0)) then begin
                SetAreaZeroSize(a);
                AddAttachFileToArea(Attach2r,a,false);
                Delete_File(fname);
                WriteAreaToFile(a,fname,0);
              end;
              filenr = filenr + 1;
            end;
          end;
        end;
      end;
    end;
  end;
  return;
end;

