  AddLineToArea("[general]",a_conf);
//  AddLineToArea("[@asterisk]",a_conf); //Only useful if there's a group "asterisk"
//  AddLineToArea("deny=all",a_conf);
//  AddLineToArea("permit=queue show *",a_conf);
  AddLineToArea("[root]",a_conf);
