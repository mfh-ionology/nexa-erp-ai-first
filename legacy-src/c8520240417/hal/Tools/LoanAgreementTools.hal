global
function Boolean LoanAgreementDchrsum(var record LoanAgreementVc LoanAgreementr,Integer rownr)
begin
  row LoanAgreementVc LoanAgreementrw;
  val s;
  Boolean res;
  record GeneralOptionBlock GenOptRec;

  BlockLoad(GenOptRec);
  res = false;
  MatRowGet(LoanAgreementr,rownr,LoanAgreementrw);
  CalcSum(LoanAgreementrw.Quant,LoanAgreementrw.Price,LoanAgreementrw.PriceFactor,LoanAgreementrw.vRebate,s,GenOptRec.UseDiscount);
  RoundRowSum(LoanAgreementr.CurncyCode,LoanAgreementr.PayDeal,"LoanAgreementVc",s);
  if (s!=LoanAgreementrw.Sum) then begin
    LoanAgreementrw.Sum = s;
    MatRowPut(LoanAgreementr,rownr,LoanAgreementrw);
    res = true;
  end;
  if (LoanAgreementrw.Price==0) then begin res = true; end;
  LoanAgreementDchrsum = res;
  return;
end;

global
procedure LoanAgreementSchedVc_PasteCustCode(var record LoanAgreementSchedVc LoanAgreementSchedr)
begin
  record CUVc CUr;

  CUr.Code = LoanAgreementSchedr.CustCode;
  if (ReadFirstMain(CUr,1,true)) then begin
    LoanAgreementSchedr.CustName = CUr.Name;
  end;

  return;
end;

global
procedure LoanAgreementDchsum(var record LoanAgreementVc LoanAgreementr,Integer rownr)
begin  
  row LoanAgreementVc LoanAgreementrw;

  if (rownr>=0) then begin
    MatRowGet(LoanAgreementr,rownr,LoanAgreementrw);
    SendArtStat(LoanAgreementrw.ArtCode,"","",0,0,0,LoanAgreementr.TransDate,0);
  end;
  return;
end;

global
procedure LoanAgreementSumup(var record LoanAgreementVc LoanAgreementr)
begin
  //TODO
  return;
end;

procedure LoanAgreementchsums(var record LoanAgreementVc LoanAgreementr,Integer rownr)
begin
  if (LoanAgreementDchrsum(LoanAgreementr,rownr)) then begin
    LoanAgreementDchsum(LoanAgreementr,rownr);
  end;
  LoanAgreementSumup(LoanAgreementr);
  return;
end;

global
procedure LoanAgreementVc_PasteCurncyCode(var record LoanAgreementVc LoanAgreementr)
begin
  val from,to1,to2,base1,base2;
  string 5 crncy;
 
  crncy = LoanAgreementr.CurncyCode;
  GetFullCurncyRate(crncy,LoanAgreementr.TransDate,from,to1,to2,base1,base2);
  LoanAgreementr.CurncyCode = crncy;
  LoanAgreementr.FrRate = from;
  LoanAgreementr.ToRateB1 = to1;
  LoanAgreementr.ToRateB2 = to2;
  LoanAgreementr.BaseRate1 = base1;
  LoanAgreementr.BaseRate2 = base2;
  LoanAgreementr.BaseTotalSum = MulRateToBase1(LoanAgreementr.CurncyCode,LoanAgreementr.TotalSum,from,to1,to2,base1,base2,DefaultCurRoundOff);
  return;
end;

global
function Boolean LoanAgreementVc_PasteArtCode(var record LoanAgreementVc LoanAgreementr,Integer rownr)
begin
  Boolean res;
  record INVc INr;
  row LoanAgreementVc LoanAgreementrw;
  val t,s,price,vreb,baseprice,temp,tax2prc,tax2reb;
  string 255 curitemname,salesacc,vatcode,tstr,tax2code,taxtemplatecode;
  Boolean calcprice;
  val UnitFactQuant,UnitFactPrice,Quant;
  Date resp;
  Boolean dummyf;
  val fr,to1,to2,br1,br2;
  string 10 curcode;
  Time blankt;

  MatRowGet(LoanAgreementr,rownr,LoanAgreementrw);
  if (LoanAgreementrw.Quant<=0) then begin
    LoanAgreementrw.Quant = 1;
  end;
  LoanAgreementrw.Price = BlankVal;
  LoanAgreementrw.Sum = BlankVal;
  curcode = LoanAgreementr.CurncyCode;
  GetFullCurncyRate(curcode,LoanAgreementr.TransDate,fr,to1,to2,br1,br2);
  if (GetItemPriceDiscount3(LoanAgreementrw.ArtCode,LoanAgreementrw.Quant,INr,LoanAgreementr.CurncyCode,
                            fr,to1,to2,br1,br2,
                            LoanAgreementr.LangCode,LoanAgreementr.CustCat,"",LoanAgreementr.RebCode,
                            price,curitemname,vreb,vatcode,baseprice,salesacc,
                            LoanAgreementr.ExportFlag,calcprice,resp,blankt,LoanAgreementr.CustCode,true,dummyf,LoanAgreementr.PayDeal,tax2code,tax2prc,"","",taxtemplatecode)) then begin
    if (vreb==0) then begin
      vreb = blankval;
    end;
    LoanAgreementrw.Price = price;
    LoanAgreementrw.Comment = curitemname;
    LoanAgreementrw.vRebate = vreb;
    LoanAgreementrw.ArtCode = INr.Code;
    LoanAgreementrw.PriceFactor = INr.PriceFactor;
    MatRowPut(LoanAgreementr,rownr,LoanAgreementrw);
    LoanAgreementchsums(LoanAgreementr,rownr);
    res = true;
  end;
  LoanAgreementVc_PasteArtCode = res;
  return;
end;

global
