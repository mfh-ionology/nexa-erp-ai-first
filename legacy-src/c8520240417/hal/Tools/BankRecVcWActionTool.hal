function Boolean IsTransactionRowReconciled(record TRVc TRr,string paymodeacc,val sum)
begin
  Boolean res;
  row TRVc TRrw;
  Integer i,rwcnt;
  val v;

  rwcnt = MatRowCnt(TRr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(TRr,i,TRrw);
    v = TRrw.DebVal - TRrw.CredVal;
    if (TRrw.AccNumber==paymodeacc and TRrw.Reconsf!=0 and TRrw.ovst==0 and sum==v) then begin
      res = true;
      i = rwcnt;
    end;
  end;
  IsTransactionRowReconciled = res;
  return;
end;


function Boolean FindMatchingPayment(Date sd,Date ed,record AccountReconDataVc ARDr,var row OPVc OPrw,var row PPVc PPrw,var record TRVc TRr,var row TRVc TRrw)
begin
  record MainVc Mainr;
  record OPVc OPr;
  record PPVc PPr;
  row TRVc TR2rw;
  Integer i,j,rwcnt;
  Boolean found,testf,res;
  transaction string 255 gAccRcn_vpmaccnr;
  val v;
  array Integer arownr;
  
  RecordClear(TRr);
  ClearRow(TRr,TRrw,1);
  if (nonblank(ARDr.FileName)) then begin
    switch (ARDr.FileName) begin
      case "OPVc":
        OPr.SerNr = ARDr.TransNr;
        if (ReadFirstMain(OPr,1,true)) then begin
          if (ARDr.TransRow>=0 and ARDr.TransRow<MatRowCnt(OPr)) then begin
            MatRowGet(OPr,ARDr.TransRow,OPrw);
            TRr.Number = OPr.SerNr;
            TRr.IntYc = OPYc;
            if (ReadFirstMain(TRr,2,true)) then begin
              res = true;
            end else begin
              res = OPr.OrderedFlag!=0 and OPr.DoneFlag==0;
            end;
          end;
        end;
      case "PPVc":
        PPr.SerNr = ARDr.TransNr;
        if (ReadFirstMain(PPr,1,true)) then begin
          if (ARDr.TransRow>=0 and ARDr.TransRow<MatRowCnt(PPr)) then begin
            MatRowGet(PPr,ARDr.TransRow,PPrw);
            TRr.Number = PPr.SerNr;
            TRr.IntYc = PPYc;
            if (ReadFirstMain(TRr,2,true)) then begin
              res = true;
            end;
          end;
        end;
      case "TRVc":
        TRr.Number = ARDr.TransNr;
        TRr.IntYc = ARDr.IntYc;
        if (ReadFirstMain(TRr,2,true)) then begin
          if (ARDr.TransRow>=0 and ARDr.TransRow<MatRowCnt(TRr)) then begin
            MatRowGet(TRr,ARDr.TransRow,TRrw);
            if (ARDr.Sum==TRr.DSum) or (ARDr.Sum==TRr.CSum) then begin
              TRrw.Comment = TRr.Comment;
              res = true;
            end;
          end;
        end;
      otherwise
    end;
    goto LFindMatchingPayment;
  end;

  ClearRow(OPr,OPrw,1);
  ClearRow(PPr,PPrw,1);
  ClearRow(TRr,TRrw,1);
  found = true;
  Mainr.AccNumber = gAccRcn_vpmaccnr;
  Mainr.TransDate = sd;
  while (LoopMain(Mainr,2,found)) begin
    if (Mainr.AccNumber!=gAccRcn_vpmaccnr) then begin found = false; end;
    if (DateInRange(Mainr.TransDate,sd,ed)==false) then begin found = false; end;
    if (found) then begin
      testf = true;
      if (Mainr.FileName!="TRVc") then begin testf = false; end;
      if (Mainr.IntYc!=OPYc and Mainr.IntYc!=PPYc and Mainr.IntYc>=IPYc) then begin
        testf = false;
      end;
      if (testf) then begin
        TRr.Number = Mainr.TransNr;
        TRr.IntYc = Mainr.IntYc;
        if (ReadFirstMain(TRr,2,true)==false) then begin
          testf = false;
        end;
      end;
      if (testf) then begin
        testf = IsTransactionRowReconciled(TRr,gAccRcn_vpmaccnr,-ARDr.Sum)==false;
      end;
      if (testf) then begin
        switch (Mainr.IntYc) begin
          case OPYc:
            if (DateInRange(Mainr.TransDate,AddDay(ARDr.TransDate,-1),AddDay(ARDr.TransDate,1))) then begin
              OPr.SerNr = Mainr.TransNr;
              if (ReadFirstMain(OPr,1,true)) then begin
                rwcnt = MatRowCnt(OPr);
                 for (i=0;i<rwcnt;i=i+1) begin
                  MatRowGet(OPr,i,OPrw);
                  testf = true;
  //                if (OPrw.BankVal==(-ARDr.Sum)) then begin
                  if (Left(ARDr.TypeRef,1)=="D") then begin
                    if (OPrw.BankVal!=ARDr.Sum) then begin testf = false; end;
                    if (nonblank(ARDr.ContactName)) then begin
                     // if (OPrw.Comment!=ARDr.ContactName) then begin testf = false; end;
                     if (FindStringInString(OPrw.Comment,ARDr.ContactName)==false) then begin testf = false; end;
                    end;
                    if (DateInRange(OPr.TransDate,AddDay(ARDr.TransDate,-1),AddDay(ARDr.TransDate,1))==false) then begin testf = false; end;
                    if (testf) then begin
                      ARDr.FileName = "OPVc";
                      ARDr.TransNr = Mainr.TransNr;
                      ARDr.TransRow = i;
                      ARDr.TransDate = Mainr.TransDate;
                      ARDr.IntYc = OPYc;
                      ARDr.ContactName = OPrw.Comment;
                      i = rwcnt;
                      res = true;
                      found = false;
                    end;
                  end;
                end;
              end;
            end;
          case PPYc:
            PPr.SerNr = Mainr.TransNr;
            if (ReadFirstMain(PPr,1,true)) then begin
              rwcnt = MatRowCnt(PPr);
               for (i=0;i<rwcnt;i=i+1) begin
                MatRowGet(PPr,i,PPrw);
                if (PPrw.PayVal==ARDr.Sum and Left(ARDr.TypeRef,1)=="D") then begin
                  ARDr.FileName = "PPVc";
                  ARDr.TransNr = Mainr.TransNr;
                  ARDr.TransRow = i;
                  ARDr.TransDate = Mainr.TransDate;
                  ARDr.CurncyCode = PPr.CurncyCode;
                  ARDr.IntYc = PPYc;
                  i = rwcnt;
                  res = true;
                  found = false;
                end;
              end;
            end;
          otherwise
            rwcnt = MatRowCnt(TRr);
            for (i=0;i<rwcnt;i=i+1) begin
              MatRowGet(TRr,i,TRrw);
              v = 0;
/*
              ClearArray(arownr);
              for (j=i+1;j<rwcnt;j=j+1) begin
                MatRowGet(TRr,j,TR2rw);
                if (TR2rw.AccNumber==gAccRcn_vpmaccnr and TR2rw.Reconsf==0 and TR2rw.ovst==0 and (Left(ARDr.TypeRef,1)=="D")) then begin
                  v = v + (TR2rw.DebVal - TR2rw.CredVal);
                  arownr[arownr.length] = j;
                end;
              end;
*/
              v = v + (TRrw.DebVal - TRrw.CredVal);
              if (TRrw.AccNumber==gAccRcn_vpmaccnr and TRrw.Reconsf==0 and TRrw.ovst==0 and (ARDr.Sum==-v and Left(ARDr.TypeRef,1)=="D")) then begin
                ARDr.FileName = "TRVc";
                ARDr.TransNr = Mainr.TransNr;
                ARDr.TransRow = i;
                ARDr.TransDate = Mainr.TransDate;
                ARDr.IntYc = Mainr.IntYc;
                res = true;
                i = rwcnt;
                found = false;
//                for (j=0;j<arownr.length) begin
//                  ARDr.FileName = "TRVc";
//                  ARDr.TransNr = Mainr.TransNr;
//                  ARDr.TransRow = arownr[j];
//                  ARDr.TransDate = Mainr.TransDate;
//                  ARDr.IntYc = Mainr.IntYc;
//                end;
              end;
            end;
        end;
      end;
    end;
  end;
  OPr.OrderedFlag = 1;
  OPr.DoneFlag = 0;
  found = true;
  while (LoopKey("OrderedFlag",OPr,2,found)) begin
    if (OPr.OrderedFlag!=1) then begin found = false; end;
    if (OPr.DoneFlag!=0) then begin found = false; end;
    if (OPr.Invalid!=0) then begin found = false; end;
    if (found) then begin
      testf = true;
      if (testf) then begin
        rwcnt = MatRowCnt(OPr);
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(OPr,i,OPrw);
          if (Left(ARDr.TypeRef,1)=="D") then begin
            testf = true;
            if (OPrw.BankVal!=ARDr.Sum) then begin testf = false; end;
            if (OPrw.ovst!=0) then begin testf = false; end;
            if (nonblank(ARDr.ContactName)) then begin
             // if (OPrw.Comment!=ARDr.ContactName) then begin testf = false; end;
             if (FindStringInString(OPrw.Comment,ARDr.ContactName)==false) then begin testf = false; end;
            end;
            if (testf) then begin
              ARDr.FileName = "OPVc";
              ARDr.TransNr = OPr.SerNr;
              ARDr.TransRow = i;
              ARDr.TransDate = OPr.TransDate;
              ARDr.IntYc = OPYc;
              i = rwcnt;
              res = true;
              found = false;
            end;
          end;
        end;
        if (res==false) then begin
          testf = true;
          if (OPr.CurPayVal!=ARDr.Sum) then begin testf = false; end;
          if (DateInRange(OPr.TransDate,AddDay(ARDr.TransDate,-1),AddDay(ARDr.TransDate,1))==false) then begin testf = false; end;
            if (testf) then begin
              ARDr.FileName = "OPVc";
              ARDr.TransNr = OPr.SerNr;
              ARDr.TransRow = 1;
              ARDr.TransDate = OPr.TransDate;
              ARDr.IntYc = OPYc;
              ARDr.CurncyCode = OPr.PayCurCode;
              res = true;
              found = false;
            end;
        end;
      end;
    end;
  end;

LFindMatchingPayment:;
  FindMatchingPayment = res;
  return;
end;

function val GetInvoiceBalance(LongInt ivnr,Integer rownr,val curval,var Boolean curbalf)
begin
  val res;
  record IPVc IPr;
  row IPVc IPrw;
  val chk;
  Boolean installmentf;

  curbalf = true;
  if (rownr=-1) then begin 
    res = 0;
    goto LGetInvoiceBalance;
  end;
  
  RecordNew(IPr);
  IPrw.InvoiceNr = ivnr;
  MatRowPut(IPr,rownr,IPrw);
  PasteInvIn2IPr(IPr,rownr,IPr.TransDate,chk,false,installmentf);
  MatRowGet(IPr,rownr,IPrw);

  res = IPrw.RecVal;
  if (res==blankval) then begin
    res = curval;
    curbalf = false;
  end;
  
LGetInvoiceBalance:;
  GetInvoiceBalance = res;
  return;
end;

function Boolean FindMatchingReceipt(Date sd,Date ed,var record AccountReconDataVc ARDr,var row IPVc IPrw,var record TRVc TRr,var row TRVc TRrw,record BankTRVc BankTRr,var Boolean curbalf)
begin
  record MainVc Mainr;
  record IPVc IPr;
  row IPVc tIPrw;
  Integer i,rwcnt;
  Boolean found,testf,res,checkf;
  transaction string 255 gAccRcn_vpmaccnr;
  val v;
    
  RecordNew(TRr);
  if (nonblank(ARDr.FileName)) then begin
    switch (ARDr.FileName) begin
      case "IPVc":
        IPr.SerNr = ARDr.TransNr;
        if (ReadFirstMain(IPr,1,true)) then begin
          if (ARDr.TransRow>=0 and ARDr.TransRow<MatRowCnt(IPr)) then begin
            MatRowGet(IPr,ARDr.TransRow,IPrw);
            IPrw.Comment = IPrw.InvoiceNr;
            res = true;
          end else begin
            if (ARDr.TransRow==-2) then begin
              IPrw.Comment = "";
              rwcnt = MatRowCnt(IPr);
              for (i=0;i<rwcnt;i=i+1) begin
                MatRowGet(IPr,i,tIPrw);
                IPrw.Comment = AddStringToStringList(IPrw.Comment,tIPrw.InvoiceNr);
              end;
              IPrw.CustName = ARDr.ContactName;
              res = true;
            end;
          end;
        end;
      case "TRVc":
        TRr.Number = ARDr.TransNr;
        TRr.IntYc = ARDr.IntYc;
        if (ReadFirstMain(TRr,2,true)) then begin
          if (ARDr.TransRow>=0 and ARDr.TransRow<MatRowCnt(TRr)) then begin
            MatRowGet(TRr,ARDr.TransRow,TRrw);
            if (ARDr.Sum==TRr.DSum) or (ARDr.Sum==TRr.CSum) then begin
              TRrw.Comment = TRr.Comment;
              res = true;
            end;
          end;
        end;
      otherwise
    end;
    goto LFindMatchingReceipt;
  end;
  ClearRow(IPr,IPrw,1);
  ClearRow(TRr,TRrw,1);
  found = true;
  Mainr.AccNumber = gAccRcn_vpmaccnr;
  Mainr.TransDate = sd;
  while (LoopMain(Mainr,2,found)) begin
    if (Mainr.AccNumber!=gAccRcn_vpmaccnr) then begin found = false; end;
    if (DateInRange(Mainr.TransDate,sd,ed)==false) then begin found = false; end;
    if (found) then begin
      testf = true;
      if (Mainr.FileName!="TRVc") then begin testf = false; end;
      if (Mainr.IntYc!=IPYc and Mainr.IntYc>=IVYc) then begin
        testf = false;
      end;
      if (testf) then begin
        TRr.Number = Mainr.TransNr;
        TRr.IntYc = Mainr.IntYc;
        if (ReadFirstMain(TRr,2,true)==false) then begin
          testf = false;
        end;
      end;
      if (testf) then begin
        testf = IsTransactionRowReconciled(TRr,gAccRcn_vpmaccnr,ARDr.Sum)==false;
      end;
      if (testf) then begin
        switch (Mainr.IntYc) begin
          case IPYc:
            IPr.SerNr = Mainr.TransNr;
            if (ReadFirstMain(IPr,1,true)) then begin 
              rwcnt = MatRowCnt(IPr);
              for (i=0;i<rwcnt;i=i+1) begin
                MatRowGet(IPr,i,IPrw);
                if (IPrw.BankVal==ARDr.Sum) then begin
                  ARDr.FileName = "IPVc";
                  ARDr.TransNr = Mainr.TransNr;
                  ARDr.TransRow = i;
                  ARDr.TransDate = Mainr.TransDate;
                  ARDr.IntYc = IPYc;
                  i = rwcnt;
                  res = true;
                  found = false;
                end;
              end;
              if (res==false) then begin
                if (IPr.CurPayVal==ARDr.Sum) then begin
                  ARDr.FileName = "IPVc";
                  ARDr.TransNr = Mainr.TransNr;
                  ARDr.TransRow = -2;
                  ARDr.TransDate = Mainr.TransDate;
                  ARDr.IntYc = IPYc;
                  ARDr.CurncyCode = IPr.PayCurCode;
                  res = true;
                  found = false;
                end;
              end;
            end;
          otherwise
            rwcnt = MatRowCnt(TRr);
            for (i=0;i<rwcnt;i=i+1) begin
              MatRowGet(TRr,i,TRrw);
              v = TRrw.DebVal - TRrw.CredVal;
              if (TRrw.AccNumber==gAccRcn_vpmaccnr and TRrw.Reconsf==0 and TRrw.ovst==0 /*and ARDr.Sum==v*/) then begin
                ARDr.FileName = "TRVc";
                ARDr.TransNr = Mainr.TransNr;
                ARDr.TransRow = i;
                ARDr.TransDate = Mainr.TransDate;
                ARDr.IntYc = Mainr.IntYc;
                res = true;
                i = rwcnt;
                found = false;
              end;
            end;
        end;
      end;
    end;
  end;
  found = true;
  IPr.OKFlag = 0;
  IPr.TransDate = sd;
  while (LoopKey("OKFlagTransDate",IPr,2,found)) begin
    if (IPr.OKFlag!=0) then begin found = false; end;
    if (DateInRange(IPr.TransDate,sd,ed)==false) then begin found = false; end;
    if (found) then begin
      testf = true;
      if (testf) then begin
        rwcnt = MatRowCnt(IPr);
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(IPr,i,IPrw);
          if (Left(ARDr.TypeRef,1)=="C") then begin
            testf = true;
            checkf = false;

            if ((IPrw.InvoiceNr!=StringToLongInt(BankTRr.Reference) or (IPrw.InvoiceNr==-1 and StringToLongInt(BankTRr.Reference)==-1))) then begin checkf = true; end;
            if ((nonblank(BankTRr.Reference) and nonblank(IPrw.rkRecNumber)) and (BankTRr.Reference!=IPrw.rkRecNumber)) then begin checkf = true; end;
            if (checkf) then begin
              if (IPrw.BankVal!=ARDr.Sum) then begin testf = false; end;
              if (nonblank(ARDr.ContactName)) then begin
                ARDr.ContactName = StripCharacter(ARDr.ContactName,"""");
                if ((UpperCase(IPrw.CustName))!=ARDr.ContactName) then begin testf = false; end;
              end;
            end;

            if (DateInRange(IPr.TransDate,AddDay(ARDr.TransDate,-1),AddDay(ARDr.TransDate,1))==false) then begin testf = false; end;
            if (testf) then begin
              ARDr.FileName = "IPVc";
              ARDr.TransNr = IPr.SerNr;
              ARDr.TransRow = i;
              ARDr.TransDate = IPr.TransDate;
              ARDr.IntYc = IPYc;
              i = rwcnt;
              res = true;
              found = false;
            end;
          end;
        end;
        if (res==false) then begin
          testf = true;
          if (IPr.CurPayVal!=ARDr.Sum) then begin testf = false; end;
          if (DateInRange(IPr.TransDate,AddDay(ARDr.TransDate,-1),AddDay(ARDr.TransDate,1))==false) then begin testf = false; end;
          if (testf) then begin
            ARDr.FileName = "IPVc";
            ARDr.TransNr = IPr.SerNr;
            ARDr.TransRow = -2;
            ARDr.TransDate = IPr.TransDate;
            ARDr.IntYc = IPYc;
            ARDr.CurncyCode = IPr.PayCurCode;
            res = true;
            found = false;
          end;
        end;
      end;
    end;
  end;

LFindMatchingReceipt:;
  ARDr.Sum = GetInvoiceBalance(IPrw.InvoiceNr,ARDr.TransRow,ARDr.Sum,curbalf);
  FindMatchingReceipt = res;
  return;
end;

function Boolean PaymentReconcilled(record OPVc OPr)
begin
  Boolean res;
  row OPVc OPrw;
  Integer i,rwcnt;
  
  res = true;
  rwcnt = MatRowCnt(OPr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(OPr,i,OPrw);
    if (OPrw.Reconsf!=0 or OPrw.ovst!=0) then begin
    end else begin
      res = false;
      i = rwcnt;
    end;
  end;
  PaymentReconcilled = res;
  return;
end;

function Boolean ReceiptReconcilled(record IPVc IPr)
begin
  Boolean res;
  row IPVc IPrw;
  Integer i,rwcnt;
  
  res = true;
  rwcnt = MatRowCnt(IPr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(IPr,i,IPrw);
    if (IPrw.Reconsf==0) then begin
      res = false;
      i = rwcnt;
    end;
  end;
  ReceiptReconcilled = res;
  return;
end;

updating function Boolean BankAccountReconWClass_ReconcileTransaction(LongInt nr,Integer intyc,Integer transrow,string paymodeacc)
begin
  Boolean res;
  record TRVc oldTRr,TRr;
  row TRVc TRrw;
  row TRVc TR2rw;
  Integer i,j,rwcnt;
  val v;
  Boolean updf;
  array Integer arownr;

  TRr.Number = nr;
  TRr.IntYc = intyc;

  if (ReadFirstMain(TRr,2,true)) then begin
    RecordCopy(oldTRr,TRr);
    rwcnt = MatRowCnt(TRr);
    for (i=0;i<rwcnt;i=i+1) begin
      MatRowGet(TRr,i,TRrw);
      v = 0;
      for (j=i+1;j<rwcnt;j=j+1) begin
        MatRowGet(TRr,j,TR2rw);
        if (TR2rw.AccNumber==paymodeacc and TR2rw.Reconsf==0 and TR2rw.ovst==0) then begin
          v = v + (TR2rw.DebVal - TR2rw.CredVal);
        end;
      end;
    end;
    for (i=0;i<rwcnt;i=i+1) begin
      MatRowGet(TRr,i,TRrw);
      if (TRrw.AccNumber==paymodeacc) then begin
        TRrw.Reconsf = 1;
        TRrw.ReconDate = CurrentDate;
        MatRowPut(TRr,i,TRrw);
        updf = true;
      end;
    end;
    if (updf) then begin
      res = RecordUpdate(oldTRr,TRr,true)==0;
    end;
  end else begin
    res = BankAccountReconWClass_ReconcileRecord(nr,intyc,transrow,paymodeacc);
  end;
  BankAccountReconWClass_ReconcileTransaction = res;
  return;
end;

updating function Boolean BankAccountReconWClass_ReconcileRecord(LongInt nr,Integer intyc,Integer transrow,string paymodeacc)
begin
  Boolean res;
  record OPVc OPr;
  record OPVc oldOPr;
  row OPVc OPrw;
  record IPVc IPr;
  record IPVc oldIPr;
  row IPVc IPrw;
  Integer i,rwcnt;
  Boolean updatef;

  switch (intyc) begin
    case OPYc:
      OPr.SerNr = nr;
      if (ReadFirstMain(OPr,1,true)) then begin
        if (OPr.OrderedFlag!=0 and OPr.DoneFlag==0) then begin
          if (transrow<MatRowCnt(OPr)) then begin
            RecordCopy(oldOPr,OPr);
            MatRowGet(OPr,transrow,OPrw);
            OPrw.Reconsf = 1;
            OPrw.ReconDate = CurrentDate;
            MatRowPut(OPr,transrow,OPrw);
            if (PaymentReconcilled(OPr)) then begin
              OPr.DoneFlag = 1;
            end;
            if (RecordUpdate(oldOPr,OPr,true)==0) then begin
              res = true;
              if (OPr.DoneFlag!=0) then begin
                res = BankAccountReconWClass_ReconcileTransaction(nr,intyc,transrow,paymodeacc);
              end;
            end;
          end;
        end;
      end;
    case IPYc:
      IPr.SerNr = nr;
      if (ReadFirstMain(IPr,1,true)) then begin
        if (IPr.OKFlag==0) then begin
          RecordCopy(oldIPr,IPr);
          if (transrow==-2) then begin
            rwcnt = MatRowCnt(IPr);
            for (i=0;i<rwcnt;i=i+1) begin
              MatRowGet(IPr,i,IPrw);
              IPrw.Reconsf = 1;
              IPrw.ReconDate = CurrentDate;
              MatRowPut(IPr,i,IPrw);
            end;
            if (ReceiptReconcilled(IPr)) then begin
              IPr.OKFlag = 1;
            end;
            updatef = true;
          end else begin
            if (transrow<MatRowCnt(IPr)) then begin
              MatRowGet(IPr,transrow,IPrw);
              IPrw.Reconsf = 1;
              IPrw.ReconDate = CurrentDate;
              MatRowPut(IPr,transrow,IPrw);
              if (ReceiptReconcilled(IPr)) then begin
                IPr.OKFlag = 1;
              end;
              updatef = true;
            end;
          end;
          if (updatef) then begin
            if (RecordUpdate(oldIPr,IPr,true)==0) then begin
              res = true;
              if (IPr.OKFlag!=0) then begin
                res = BankAccountReconWClass_ReconcileTransaction(nr,intyc,transrow,paymodeacc);
              end;
            end;
          end;
        end;
      end;
  end;
  BankAccountReconWClass_ReconcileRecord = res;
  return;
end;

global
updating procedure BankAccountReconWClass_ReconcileBankTransactionRemote(string arg)
begin
  record PPVc PPr;
  record OPVc OPr;
  record IPVc IPr;
  record TRVc TRr;
  string 255 filename,transnr,transrow,pmaccnr,transintyc,banktr;
  LongInt pos,trrow;
  record BankTRVc BankTRr;
  record BankTRVc oldBankTRr;
  Boolean recf;

  pos = 0;
  GetNextSubstring(arg,pos,",",filename);
  GetNextSubstring(arg,pos,",",transnr);
  GetNextSubstring(arg,pos,",",transintyc);
  GetNextSubstring(arg,pos,",",transrow);
  GetNextSubstring(arg,pos,",",pmaccnr);
  GetNextSubstring(arg,pos,",",banktr);
  trrow = StringToLongInt(transrow);
  switch (filename) begin
    case "IPVc":
      IPr.SerNr = StringToLongInt(transnr);
      if (ReadFirstMain(IPr,1,true)) then begin
        recf = BankAccountReconWClass_ReconcileTransaction(IPr.SerNr,IPYc,StringToInt(transrow),pmaccnr);
      end;
    case "OPVc":
      OPr.SerNr = StringToLongInt(transnr);
      if (ReadFirstMain(OPr,1,true)) then begin
        recf = BankAccountReconWClass_ReconcileTransaction(OPr.SerNr,OPYc,StringToInt(transrow),pmaccnr);
      end;
    case "PPVc":
      PPr.SerNr = StringToLongInt(transnr);
      if (ReadFirstMain(PPr,1,true)) then begin
        recf = BankAccountReconWClass_ReconcileTransaction(PPr.SerNr,PPYc,StringToInt(transrow),pmaccnr);
      end;
    case "TRVc":
      TRr.Number = StringToLongInt(transnr);
      TRr.IntYc = StringToLongInt(transintyc);
      if (ReadFirstMain(TRr,2,true)) then begin
        recf = BankAccountReconWClass_ReconcileTransaction(TRr.Number,TRr.IntYc,StringToInt(transrow),pmaccnr);
      end;
  end;
  if (nonblank(banktr) and recf) then begin
    BankTRr.SerNr = StringToLongInt(banktr);
    if (ReadFirstMain(BankTRr,1,true)) then begin
      RecordCopy(oldBankTRr,BankTRr);
      BankTRr.Reconsf = 1;
      BankTRr.FileName = StringFromStringSet(760,filename);
      BankTRr.RecNumber = StringToLongInt(transnr);
      RecordUpdate(oldBankTRr,BankTRr,false);
    end;
  end;
  return;
end;

global
updating procedure BankAccountReconWClass_InvalidateBankPaymentRemote(string arg)
begin
  record OPVc OPr;
  record OPVc oldOPr;
  row OPVc OPrw;
  string 255 filename,transnr,transrow,pmaccnr,transintyc,banktr;
  LongInt pos,trrow;

  pos = 0;
  GetNextSubstring(arg,pos,",",filename);
  GetNextSubstring(arg,pos,",",transnr);
  GetNextSubstring(arg,pos,",",transintyc);
  GetNextSubstring(arg,pos,",",transrow);
  GetNextSubstring(arg,pos,",",pmaccnr);
  GetNextSubstring(arg,pos,",",banktr);
  trrow = StringToLongInt(transrow);
  switch (filename) begin
    case "OPVc":
      OPr.SerNr = StringToLongInt(transnr);
      if (ReadFirstMain(OPr,1,true)) then begin
        if (OPr.OrderedFlag!=0 and OPr.DoneFlag==0) then begin
          if (trrow<MatRowCnt(OPr)) then begin
            RecordCopy(oldOPr,OPr);
            MatRowGet(OPr,trrow,OPrw);
            OPrw.ovst = 1;
            MatRowPut(OPr,trrow,OPrw);
            RecordUpdate(oldOPr,OPr,true);
          end;
        end;
      end;
  end;
  return;
end;

//------

function Boolean TransactionAlreadyDisplayed(record MainVc Mainr,array record AccountReconDataVc aARDr)
begin
  Boolean res;
  Integer i;
  record AccountReconDataVc ARDr;
  
  for (i=0;i<aARDr.length;i=i+1) begin
    ARDr = aARDr[i];
    if (ARDr.IntYc==Mainr.IntYc and ARDr.TransNr==Mainr.TransNr) then begin
      res = true;
      goto LTransactionAlreadyDisplayed;
    end;
  end;
LTransactionAlreadyDisplayed:;
  TransactionAlreadyDisplayed = res;
  return;
end;

function Boolean ExistsInAccountReconData(array record AccountReconDataVc aARDr,string filename,LongInt transnr,Integer transrow)
begin
  Boolean res;
  record AccountReconDataVc ARDr;
  Integer i;
  
  for (i=0;i<aARDr.length;i=i+1) begin
    ARDr = aARDr[i];
    if (ARDr.FileName==filename and ARDr.TransNr==transnr and (ARDr.TransRow==transrow or ARDr.TransRow==-2)) then begin
      res = true;
      goto LExistsInAccountReconData;
    end;
  end;
LExistsInAccountReconData:;
  ExistsInAccountReconData = res;
  return;
end;

procedure AddDataMissingInBankTransactions(string pmaccnr,string typeref,Date sd,Date ed,var string html,array record AccountReconDataVc aARDr)
begin
  Boolean found,testf;
  record MainVc Mainr;
  record OPVc OPr;
  row OPVc OPrw;
  record IPVc IPr;
  row IPVc IPrw;
  record TRVc TRr;
  row TRVc TRrw;
  record AccountReconDataVc ARDr;
  Integer i,rwcnt;
  string 255 paymode;
  transaction string 255 gAccRcn_vpmaccnr;
  LongInt l;
  record PMBlock PMb;
  row PMBlock PMbrw;
  
  BlockLoad(PMb);
  l = aARDr.length;
/*
  Mainr.AccNumber = gAccRcn_vpmaccnr;
  Mainr.TransDate = sd;
  found = true;
  while (LoopMain(Mainr,2,found)) begin
    if (Mainr.AccNumber!=gAccRcn_vpmaccnr) then begin found = false; end;
    if (DateInRange(Mainr.TransDate,sd,ed)==false) then begin found = false; end;
    if (found) then begin
      testf = true;
      if (Mainr.FileName!="TRVc") then begin testf = false; end;
      if (testf) then begin
        TRr.Number = Mainr.TransNr;
        TRr.IntYc = Mainr.IntYc;
        if (ReadFirstMain(TRr,2,true)==false) then begin
          testf = false;
        end;
      end;
      if (testf) then begin
        testf = TransactionAlreadyDisplayed(Mainr,aARDr)==false;//Row ?
      end;
      if (testf) then begin
        rwcnt = MatRowCnt(TRr);
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(TRr,i,TRrw);
          if (TRrw.Reconsf==0 and TRrw.ovst==0 and TRrw.AccNumber==gAccRcn_vpmaccnr) then begin
            html = html & "    <div id='AccRcn_Data" & l &  "' class='AccRcn_DataWithRecord' onclick=\"" & JSCallHal("BankAccountReconWClass_OpenRecordToReconcile",Mainr.FileName & "," & Mainr.TransNr & "," & Mainr.IntYc) & "\">" & chr(13);
            html = html & "      <div style='float: left; width: 70%; padding-left: 2%' align='left'>" & TRr.TransDate & "</div> " & chr(13);
            html = html & "      <div style='float: left; width: 26%; padding-right: 2%' align='right'>" & TRrw.DebVal-TRrw.CredVal & "</div>" & chr(13);
            html = html & "      <div style='float: left; width: 98%; padding-left: 2%' align='left'>" & TRrw.Comment & "</div> " & chr(13);
            html = html & "      <div style='float: left; width: 98%; padding-left: 2%' align='left'>" & USetStr(14161) & ": " & Mainr.TransNr & "</div> " & chr(13);
            html = html & "    </div>" & chr(13);
            l = l + 1;
          end;
        end;
      end;
    end;
  end;
*/

  OPr.OrderedFlag = 1;
  OPr.DoneFlag = 0;
  found = typeref=="D";
  while (LoopKey("OrderedFlag",OPr,2,found)) begin
    if (OPr.OrderedFlag!=1) then begin found = false; end;
    if (OPr.DoneFlag!=0) then begin found = false; end;
    if (found) then begin
      testf = true;
      if (DateInRange(OPr.TransDate,sd,ed)==false) then begin testf = false; end;
      if (testf) then begin
        rwcnt = MatRowCnt(OPr);
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(OPr,i,OPrw);
          if (OPrw.ovst==0 and OPrw.Reconsf==0) then begin
            if (ExistsInAccountReconData(aARDr,"OPVc",OPr.SerNr,i)==false) then begin
              paymode = OPrw.PayMode;
              if (blank(paymode)) then begin paymode = OPr.PayMode; end;
//              GetPMBlockRow(PMb,paymode,PMbrw);
              GetPMRow(paymode,PMbrw);
              if (PMbrw.AccNr==pmaccnr) then begin
                ARDr.BankTRNr = -1;
                ARDr.FileName = "OPVc";
                ARDr.TransNr = OPr.SerNr;
                ARDr.TransRow = i;
                ARDr.TransDate = OPr.TransDate;
                ARDr.IntYc = OPYc;
                ARDr.Sum = OPrw.BankVal;
                ARDr.CurncyCode = OPrw.BankCurncy;
                ARDr.ContactName = OPrw.Comment;
                aARDr[aARDr.length] = ARDr;
              end;
            end;
          end;
        end;
      end;
    end;
  end;

  found = typeref=="C";
  IPr.OKFlag = 0;
  IPr.TransDate = sd;
  while (LoopKey("OKFlagTransDate",IPr,2,found)) begin
    if (IPr.OKFlag!=0) then begin found = false; end;
    if (DateInRange(IPr.TransDate,sd,ed)==false) then begin found = false; end;
    if (found) then begin
      testf = true;
      if (DateInRange(IPr.TransDate,sd,ed)==false) then begin testf = false; end;
      if (testf) then begin
        rwcnt = MatRowCnt(IPr);
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(IPr,i,IPrw);
          if (IPrw.Reconsf==0) then begin
            if (ExistsInAccountReconData(aARDr,"IPVc",IPr.SerNr,i)==false) then begin
              paymode = IPrw.PayMode;
              if (blank(paymode)) then begin paymode = IPr.PayMode; end;
//              GetPMBlockRow(PMb,paymode,PMbrw);
              GetPMRow(paymode,PMbrw);
              if (PMbrw.AccNr==pmaccnr) then begin
                ARDr.BankTRNr = -1;
                ARDr.FileName = "IPVc";
                ARDr.TransNr = IPr.SerNr;
                ARDr.TransRow = i;
                ARDr.TransDate = IPr.TransDate;
                ARDr.IntYc = IPYc;
                ARDr.Sum = IPrw.BankVal;
                ARDr.CurncyCode = IPrw.BankCurncy;
                ARDr.ContactName = IPrw.CustName;
                aARDr[aARDr.length] = ARDr;
              end;
            end;
          end;
        end;
      end;
    end;
  end;

  return;
end;

