procedure SetupDataFolder()
begin
  record IVVc IVr;
  record CUVc CUr;

  Delete_File("graphs/customers.txt");
  CreateFile("graphs/customers.txt");
  CloseFile;
  OpenExportFile("graphs/customers.txt",true);

  ExportString("customer_code");
  ExportString("customer_name");
  ExportString("customer_category_code");
  NewLine;

  while (LoopMain(CUr,1,true)) begin
    if (CUr.CUType) then begin
      ExportString(CUr.Code);
      ExportString(CUr.Name);
      ExportString(CUr.CustCat);
      NewLine;
    end;
  end;

  CloseFile;

  Delete_File("graphs/invoices.txt");
  CreateFile("graphs/invoices.txt");
  CloseFile;
  OpenExportFile("graphs/invoices.txt",true);

  ExportString("invoice_number");
  ExportString("customer_code");
  ExportString("invoice_amount");
  ExportString("gross_profit_amount");
  ExportString("invoice_date");
  NewLine;

  while (LoopMain(IVr,1,true)) begin
    if (IVr.OKFlag==1 and
        IVr.Invalid==0 and
        IVr.InvType==kInvoiceTypeNormal) then begin

      ExportString(IVr.SerNr);
      ExportString(IVr.CustCode);
      ExportString(ValToString(IVr.Sum4,M4Val,"",".",0));
      ExportString(ValToString(IVr.TotGP,M4Val,"",".",0));
      ExportString(DateToString(IVr.InvDate,"YYYY-MM-DD"));
      NewLine;
    end;
  end;

  CloseFile;
end;

global
procedure AIDataChatWClass_Chat()
begin
  Integer wn,nwn;
  record AIChatVc AICr;
  string 255 request;
  json response;
  LongInt httpres,i;
  array string 255 roles,messages;
  string 255 resp_role,resp_message,model;
  string 255 systemprompt,dataprompt,pythoncode;
  LongInt pos;

  wn = CurWindow;
  DeselectWindow(wn,true);
  GetWindowRecord(wn,AICr);

  //AIChat_Load(wn,roles,messages);

  systemprompt = "You are a data analyst who are an expert at writing code to provide simple graphs in pyhthon" & NL;
  AIChat_AddMessage(roles,messages,"system",systemprompt);

  dataprompt =              "Given the following files in tab separated format where each filename is followed by the fields in the file" & NL;
  dataprompt = dataprompt & NL;
  dataprompt = dataprompt & "customers.txt with the fields customer_code, customer_name, customer_category_code" & NL;
  dataprompt = dataprompt & "invoices.txt with the fields invoice_number, customer_code, invoice_amount, gross_profit_amount, invoice_date" & NL;
  dataprompt = dataprompt & NL;
  dataprompt = dataprompt & "Please write python code according to the below specification to produce a graph" & NL;
  dataprompt = dataprompt & "Specity the data types when loading the data with panda" & NL;
  dataprompt = dataprompt & "The graph shall be saved as 'graph.png' in the current directory" & NL;
  dataprompt = dataprompt & NL;
  dataprompt = dataprompt & "SPECIFICATION" & NL;
  dataprompt = dataprompt & NL;
  dataprompt = dataprompt & GetTextField(AICr);

  AIChat_AddMessage(roles,messages,"user",dataprompt);

  AIChat_StoreWn(wn,roles,messages,true,true,true);

  model = OpenAI_Model(model,AICr);

  httpres = OpenAI_DoChat(model,roles,messages,response,AICr.DebugFlag);

  resp_role = JSONGet(response,"choices/[0]/message/role");
  resp_message = JSONGet(response,"choices/[0]/message/content");

  if (resp_role<>"") then begin
    AIChat_AddMessage(roles,messages,resp_role,resp_message);
    AIChat_StoreWn(wn,roles,messages,false,true,true);

    Delete_File("graphs/program.py");
    while (GetNextSubString(resp_message,pos,"```",pythoncode)) begin
      if (left(pythoncode,6)=="python") then begin
        CreateFolder("graphs");
        pythoncode = right(pythoncode,len(pythoncode) - 6);
        WriteStringToFile(pythoncode & NL,"graphs/program.py",1);
      end;
    end;

    if (FileExists("graphs/program.py")) then begin
      SetupDataFolder;
      RunShellScript("bash -l ""cd graphs ; /opt/homebrew/opt/python@3.11/libexec/bin/python program.py""");
      OpenFileWithDefaultProgram("graphs/graph.png");
    end;
  end;

  return;
end;

global
function Boolean AIDataChatWClassOnOKWindow(Integer wn)
begin
  AIDataChatWClass_Chat;
  AIDataChatWClassOnOKWindow = false;
end;
