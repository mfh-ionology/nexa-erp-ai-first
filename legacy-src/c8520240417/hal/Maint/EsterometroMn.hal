external procedure AddPlainXmlToArea(area,string,Integer);
external procedure AddXmlTagToArea(area,string,string,string,Integer);
external procedure M4PadString(string,Integer,string,Boolean,var string);
external function string 255 ConvertXml(string);
external procedure MulVATIV(string,val,var val,var val,Integer,Integer);
external procedure JSONStringStart(var string);
external procedure JSONStringAdd(var string,string,string);
external procedure JSONStringEnd(var string);
external procedure BitSafeBase64EncodeAnArea(var area); 

updating function Boolean DoRequestAruba(area req,string ip,LongInt port,string path,Integer typef,string error,string contenttype,string reqstr,string method,var area reply,var string errcode)
begin
  Boolean res;
  json js;
  string 255 tstr;
  record HTSTXBlock HTSTXb;

  BlockLoad(HTSTXb);
  res = false;

  SetAreaZeroSize(reply);
  tstr = path;
  res = SendWebRequest(ip,port,-1,true,method,tstr & reqstr,contenttype,"",false,req,reply,10);
  if (res) then begin
    js = ParseJsonArea(reply);
    errcode = JSONGet(js,error);
    if (blank(errcode)) begin
      if (typef==1) then begin
        tstr = JSONGet(js,"refresh_token");
        if (nonblank(tstr)) begin
          HTSTXb.RefreshToken = tstr;
          tstr = JSONGet(js,"access_token");
          HTSTXb.LoginToken = tstr;
          BlockStore(HTSTXb);
        end;
      end else begin
        tstr = JSONGet(js,"requestID");
      end;
      res = true;
    end else begin
      switch (typef) begin
        case 2:
          if (errcode!="0000") then begin
            res = false;
          end;
          tstr = JSONGet(js,"errorDescription");
          if (nonblank(tstr)) then begin
            errcode = tstr;
          end;
        otherwise
          res = false;
      end;
    end;
  end;
  
  DoRequestAruba = res;
  return;
end;

updating function Boolean AddDataToCallAruba(Boolean testf,area a_data)
begin
  Boolean res;
  string 255 path,tstr,tstr2,ip,contenttype,errortext,errcode;
  LongInt port;
  area req,rep;
  Integer status;
  record HTSTXBlock HTSTXb;
  
  BlockLoad(HTSTXb);
  res = false;
  if (testf) then begin
    ip = "demows.fatturazioneelettronica.aruba.it";
  end else begin
    ip = "ws.fatturazioneelettronica.aruba.it";
  end;
  port = 443;
  contenttype = "application/json;charset=UTF-8";

  JSONStringStart(tstr);
  tstr = tstr & chr(10);
  tstr = tstr & """userName"":" & """" & HTSTXb.Username & """,";
  tstr = tstr & chr(10);
  tstr = tstr & """password"":" & """" & HTSTXb.Password & """,";
  tstr = tstr & chr(10);
  tstr = tstr & """userID"":" & """" & HTSTXb.Username & """,";
  tstr = tstr & chr(10);
  tstr = tstr & """comunicationType"":" & """" & "DF" & """,";
  tstr = tstr & chr(10);
  tstr = tstr & """dataFile"":" & """";
  AddTextToArea(tstr,req);
  if (GetAreaLength(a_data)>0) then begin
    BitSafeBase64EncodeAnArea(a_data);
  end;
  AddAreaToArea(a_data,req);
  tstr = """";
  tstr = tstr & chr(10);
  JSONStringEnd(tstr);
  AddTextToArea(tstr,req);

  tstr = "Authorization: Bearer " & HTSTXb.LoginToken;
  SetWebHeaders(tstr);

  res = DoRequestAruba(req,ip,port,"/services/ClientRequest/CreateTransmissionRequest",2,"errorCode",contenttype,"","POST",rep,errcode);

  AddDataToCallAruba = res;
  return;
end;

updating function Boolean DoLoginAruba(Boolean testf)
begin
  Boolean res;
  string 255 path,tstr,ip,contenttype,errcode;
  LongInt port;
  area req,rep;
  record HTSTXBlock HTSTXb;
  
  BlockLoad(HTSTXb);
  res = false;
  if (testf) then begin
    ip = "demoauth.fatturazioneelettronica.aruba.it";
  end else begin
    ip = "auth.fatturazioneelettronica.aruba.it";
  end;
  port = 443;
  path = "/auth/signin";
  contenttype = "application/x-www-form-urlencoded; charset=utf-8";

  if (nonblank(HTSTXb.RefreshToken)) then begin
    tstr = "grant_type=refresh_token&refresh_token=" & HTSTXb.RefreshToken;
    AddTextToArea(tstr,req);
    res = DoRequestAruba(req,ip,port,path,1,"error",contenttype,"","POST",rep,errcode);
  end;
  if (!res) then begin
    tstr = "grant_type=password&username=" & HTSTXb.Username & "&password=" & HTSTXb.Password;
    SetAreaZeroSize(req);
    AddTextToArea(tstr,req);
    res = DoRequestAruba(req,ip,port,path,1,"error",contenttype,"","POST",rep,errcode);
  end;

  DoLoginAruba = res;
  return;
end;

global
procedure FillEsterometroArray(var Array string astr,record RcVc RepSpec,integer mode)
begin
  record IVVc IVr;
  record VIVc VIr;
  Boolean testf;
  vector Boolean v_addedf;
  string 255 tstr;
  
  switch (RepSpec.flags[0]) begin
    case 0:
      switch (mode) begin
        case 1:
          testf = true;
          IVr.TransDate = RepSpec.sStartDate;
          while (LoopKey("TransDate",IVr,1,testf)) begin
            if (IVr.TransDate>RepSpec.sEndDate) then begin
              testf = false;
            end else begin
              if (!v_addedf[IVr.XMLPosition] and IVr.XMLPosition>0) then begin
                if (blank(RepSpec.f1) or StringToLongInt(StripNonDigits(RepSpec.f1))==IVr.XMLNumber) then begin
                  astr[astr.length] = IVr.XMLPosition;
                  v_addedf[IVr.XMLPosition] = true;
                end;
              end;
            end;
          end;
        case 2:
          testf = true;
          IVr.TransDate = RepSpec.sStartDate;
          while (LoopKey("TransDate",IVr,1,testf)) begin
            if (IVr.TransDate>RepSpec.sEndDate) then begin
              testf = false;
            end else begin
              tstr = "SL" & IVr.XMLNumber & ".xml";
              if (!v_addedf[tstr] and IVr.XMLNumber>0) then begin
                astr[astr.length] = tstr;
                v_addedf[tstr] = true;
              end;
            end;
          end;
      end;
    case 1:
      switch (mode) begin
        case 1:
          testf = true;
          VIr.TransDate = RepSpec.sStartDate;
          while (LoopKey("TransDate",VIr,1,testf)) begin
            if (VIr.TransDate>RepSpec.sEndDate) then begin
              testf = false;
            end else begin
              if (!v_addedf[VIr.XMLPosition] and VIr.XMLPosition>0) then begin
                if (blank(RepSpec.f1) or StringToLongInt(StripNonDigits(RepSpec.f1))==VIr.XMLNumber) then begin
                  astr[astr.length] = VIr.XMLPosition;
                  v_addedf[VIr.XMLPosition] = true;
                end;
              end;
            end;
          end;
        case 2:
          testf = true;
          VIr.TransDate = RepSpec.sStartDate;
          while (LoopKey("TransDate",VIr,1,testf)) begin
            if (VIr.TransDate>RepSpec.sEndDate) then begin
              testf = false;
            end else begin
              tstr = "PL" & VIr.XMLNumber & ".xml";
              if (!v_addedf[tstr] and VIr.XMLNumber>0) then begin
                astr[astr.length] = tstr;
                v_addedf[tstr] = true;
              end;
            end;
          end;
      end;
  end;

  return;
end;

function val GetVATprc(string vatcode,var string entity)
begin
  record VATCodeBlock VATRec;
  row VATCodeBlock VATrw;
  Integer i,rwcnt;
  val res;
  
  BlockLoad(VATRec);
  rwcnt = MatRowCnt(VATRec);
  for (i=i;i<rwcnt;i=i+1) begin
    MatRowGet(VATRec,i,VATrw);
    if (vatcode==VATrw.VATCode) then begin
      res = VATrw.ExVatpr;
      if (blank(res))  then begin
        res = VATrw.IncVatpr;
      end;
      entity = VATrw.VATEntity;
      i = rwcnt;
    end;
  end;
  
  GetVATprc = res;
  return;
end;

procedure AddCustData(record IVVc IVr,var area a_req,var Integer level,string prevcust)
begin
  record CountryVc Countryr;

  if (nonblank(prevcust)) then begin
    level = level - 1;
    AddPlainXmlToArea(a_req,"</CessionarioCommittenteDTE>",level);
  end;
  AddPlainXmlToArea(a_req,"<CessionarioCommittenteDTE>",level);
  level = level + 1;
  AddPlainXmlToArea(a_req,"<IdentificativiFiscali>",level);
  level = level + 1;
  AddPlainXmlToArea(a_req,"<IdFiscaleIVA>",level);
  level = level + 1;
  Countryr.Code = IVr.InvCountry;
  ReadFirstMain(Countryr,1,true);
  AddXmlTagToArea(a_req,"IdPaese","",Countryr.ISOCode,level);
  AddXmlTagToArea(a_req,"IdCodice","",IVr.RegNr1,level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</IdFiscaleIVA>",level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</IdentificativiFiscali>",level);
  AddPlainXmlToArea(a_req,"<AltriDatiIdentificativi>",level);
  level = level + 1;
  AddXmlTagToArea(a_req,"Denominazione","",ConvertXml(IVr.Addr0),level);
  AddPlainXmlToArea(a_req,"<Sede>",level);
  level = level + 1;
  AddXmlTagToArea(a_req,"Indirizzo","",ConvertXml(IVr.Addr1),level);
  if (nonblank(IVr.Addr2)) then begin
    AddXmlTagToArea(a_req,"Comune","",ConvertXml(IVr.Addr2),level);
  end;
  if (nonblank(IVr.InvAddr4)) then begin
    AddXmlTagToArea(a_req,"Provincia","",ConvertXml(IVr.InvAddr4),level);
  end;
  AddXmlTagToArea(a_req,"Nazione","",Countryr.ISOCode,level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</Sede>",level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</AltriDatiIdentificativi>",level);

  return;
end;

