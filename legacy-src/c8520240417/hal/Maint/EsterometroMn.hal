procedure GetVATDataIV(record IVVc IVr,var vector val v_vatval,var array string a_vatcode)
begin
  row IVVc IVrw;
  Integer i,rwcnt;
  val vatsum,taxsum,rowsum;
  vector Boolean v_vatcodef;

  rwcnt = MatRowCnt(IVr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(IVr,i,IVrw);
    if (IVrw.ovst==0 and nonblank(IVrw.VATCode) and IVrw.Sum!=0) then begin
      MulVATIV(IVrw.VATCode,IVrw.Sum,vatsum,taxsum,IVr.InclVAT,IVr.NoTAXonVAT);
      if (IVr.InclVAT==0) then begin
        rowsum = IVrw.Sum;
      end else begin
        rowsum = IVrw.Sum - vatsum;
      end;
      v_vatval["excl|" & IVrw.VATCode] = v_vatval["excl|" & IVrw.VATCode] + rowsum;
      v_vatval["vat|" & IVrw.VATCode] = v_vatval["vat|" & IVrw.VATCode] + vatsum;
      if (!v_vatcodef[IVrw.VATCode]) then begin
        v_vatcodef[IVrw.VATCode] = true;
        a_vatcode[a_vatcode.length] = IVrw.VATCode;
      end;
    end;
  end;
  
  return;
end;

procedure GetVATDataVI(record VIVc VIr,var vector val v_vatval,var array string a_vatcode)
begin
  row VIVc VIrw;
  Integer i,rwcnt;
  val vatsum,taxsum,rowsum;
  vector Boolean v_vatcodef;

  rwcnt = MatRowCnt(VIr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(VIr,i,VIrw);
    if (VIrw.ovst==0 and nonblank(VIrw.VATCode) and VIrw.Sum!=0) then begin
      MulVATIV(VIrw.VATCode,VIrw.Sum,vatsum,taxsum,0,VIr.NoTAXonVAT);
      rowsum = VIrw.Sum - vatsum;
      v_vatval["excl|" & VIrw.VATCode] = v_vatval["excl|" & VIrw.VATCode] + rowsum;
      v_vatval["vat|" & VIrw.VATCode] = v_vatval["vat|" & VIrw.VATCode] + vatsum;
      if (!v_vatcodef[VIrw.VATCode]) then begin
        v_vatcodef[VIrw.VATCode] = true;
        a_vatcode[a_vatcode.length] = VIrw.VATCode;
      end;
    end;
  end;
  
  return;
end;

procedure AddIVData(record IVVc IVr,var area a_req,var Integer level)
begin
  string 255 tstr,entity;
  vector val v_vatval;
  array string 255 a_vatcode;
  Integer i;

  AddPlainXmlToArea(a_req,"<DatiFatturaBodyDTE>",level);
  level = level + 1;
  AddPlainXmlToArea(a_req,"<DatiGenerali>",level);
  level = level + 1;
  switch (IVr.InvType) begin
    case kInvoiceTypeDownpayment: tstr = "TD02";
    case kInvoiceTypeCredit: tstr = "TD04";
    case kInvoiceTypeDebit: tstr = "TD05";
    otherwise tstr = "TD01";
  end;
  AddXmlTagToArea(a_req,"TipoDocumento","",tstr,level);
  AddXmlTagToArea(a_req,"Data","",DateToString(IVr.InvDate,"YYYY-MM-DD"),level);
  AddXmlTagToArea(a_req,"Numero","",IVr.OfficialSerNr,level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</DatiGenerali>",level);
  ClearVector(v_vatval);
  ClearArray(a_vatcode);
  GetVATDataIV(IVr,v_vatval,a_vatcode);
  for (i=0;i<a_vatcode.length;i=i+1) begin
    AddPlainXmlToArea(a_req,"<DatiRiepilogo>",level);
    level = level + 1;
    AddXmlTagToArea(a_req,"ImponibileImporto","",ValToString(v_vatval["excl|" & a_vatcode[i]],M4Val,"",".",0),level);
    AddPlainXmlToArea(a_req,"<DatiIVA>",level);
    level = level + 1;
    AddXmlTagToArea(a_req,"Imposta","",ValToString(v_vatval["vat|" & a_vatcode[i]],M4Val,"",".",0),level);
    AddXmlTagToArea(a_req,"Aliquota","",ValToString(GetVATprc(a_vatcode[i],entity),M4Val,"",".",0),level);
    level = level - 1;
    AddPlainXmlToArea(a_req,"</DatiIVA>",level);
    if (nonblank(entity)) then begin
      AddXmlTagToArea(a_req,"Natura","",entity,level);
    end;
    level = level - 1;
    AddPlainXmlToArea(a_req,"</DatiRiepilogo>",level);
  end;
  level = level - 1;
  AddPlainXmlToArea(a_req,"</DatiFatturaBodyDTE>",level);
  
  return;
end;

procedure AddVIData(record VIVc VIr,var area a_req,var Integer level)
begin
  string 255 tstr,entity;
  vector val v_vatval;
  array string 255 a_vatcode;
  Integer i;

  AddPlainXmlToArea(a_req,"<DatiFatturaBodyDTR>",level);
  level = level + 1;
  AddPlainXmlToArea(a_req,"<DatiGenerali>",level);
  level = level + 1;
  switch (VIr.InvType) begin
    case kInvoiceTypeDownpayment: tstr = "TD02";
    case kInvoiceTypeCredit: tstr = "TD04";
    case kInvoiceTypeDebit: tstr = "TD05";
    otherwise tstr = "TD01";
  end;
  AddXmlTagToArea(a_req,"TipoDocumento","",tstr,level);
  AddXmlTagToArea(a_req,"Data","",DateToString(VIr.InvDate,"YYYY-MM-DD"),level);
  AddXmlTagToArea(a_req,"Numero","",VIr.InvoiceNr,level);
  AddXmlTagToArea(a_req,"DataRegistrazione","",DateToString(VIr.TransDate,"YYYY-MM-DD"),level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</DatiGenerali>",level);
  ClearVector(v_vatval);
  ClearArray(a_vatcode);
  GetVATDataVI(VIr,v_vatval,a_vatcode);
  for (i=0;i<a_vatcode.length;i=i+1) begin
    AddPlainXmlToArea(a_req,"<DatiRiepilogo>",level);
    level = level + 1;
    AddXmlTagToArea(a_req,"ImponibileImporto","",ValToString(v_vatval["excl|" & a_vatcode[i]],M4Val,"",".",0),level);
    AddPlainXmlToArea(a_req,"<DatiIVA>",level);
    level = level + 1;
    AddXmlTagToArea(a_req,"Imposta","",ValToString(v_vatval["vat|" & a_vatcode[i]],M4Val,"",".",0),level);
    AddXmlTagToArea(a_req,"Aliquota","",ValToString(GetVATprc(a_vatcode[i],entity),M4Val,"",".",0),level);
    level = level - 1;
    AddPlainXmlToArea(a_req,"</DatiIVA>",level);
    if (nonblank(entity)) then begin
      AddXmlTagToArea(a_req,"Natura","",entity,level);
    end;
    AddXmlTagToArea(a_req,"Deducibile","","SI",level);
    AddXmlTagToArea(a_req,"EsigibilitaIVA","","I",level);
    level = level - 1;
    AddPlainXmlToArea(a_req,"</DatiRiepilogo>",level);
  end;
  level = level - 1;
  AddPlainXmlToArea(a_req,"</DatiFatturaBodyDTR>",level);
  
  return;
end;

procedure AddSLHeader(var area a_req,var Integer level,Integer newnum)
begin
  record CYBlock CYb;
  string 255 tstr;

  BlockLoad(CYb);  
  AddPlainXmlToArea(a_req,"<?xml version=""1.0"" encoding=""UTF-8"" standalone=""yes""?><ns2:DatiFattura versione=""DAT20"" xmlns:ns2=""http://ivaservizi.agenziaentrate.gov.it/docs/xsd/fatture/v2.0"">",level);
  level = level + 1;
  AddPlainXmlToArea(a_req,"<DatiFatturaHeader>",level);
  level = level + 1;
  AddXmlTagToArea(a_req,"ProgressivoInvio","",newnum,level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</DatiFatturaHeader>",level);
  AddPlainXmlToArea(a_req,"<DTE>",level);
  level = level + 1;
  AddPlainXmlToArea(a_req,"<CedentePrestatoreDTE>",level);
  level = level + 1;
  AddPlainXmlToArea(a_req,"<IdentificativiFiscali>",level);
  level = level + 1;
  AddPlainXmlToArea(a_req,"<IdFiscaleIVA>",level);
  level = level + 1;
  tstr = "";
  if (HasLocalization("ITA")) then begin
    tstr = "IT";
  end;
  AddXmlTagToArea(a_req,"IdPaese","",tstr,level);
  AddXmlTagToArea(a_req,"IdCodice","",CYb.VATNr,level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</IdFiscaleIVA>",level);
  if (nonblank(CYb.OrgNr)) then begin
    AddXmlTagToArea(a_req,"CodiceFiscale","",CYb.OrgNr,level);
  end;
  level = level - 1;
  AddPlainXmlToArea(a_req,"</IdentificativiFiscali>",level);
  AddPlainXmlToArea(a_req,"<AltriDatiIdentificativi>",level);
  level = level + 1;
  AddXmlTagToArea(a_req,"Denominazione","",ConvertXml(CYb.CompName),level);
  AddPlainXmlToArea(a_req,"<Sede>",level);
  level = level + 1;
  AddXmlTagToArea(a_req,"Indirizzo","",ConvertXml(CYb.Addr0),level);
  M4PadString(CYb.Addr2,5,"0",true,tstr)
  AddXmlTagToArea(a_req,"CAP","",ConvertXml(tstr),level);
  AddXmlTagToArea(a_req,"Comune","",ConvertXml(CYb.Addr3),level);
  if (nonblank(CYb.Addr4)) then begin
    AddXmlTagToArea(a_req,"Provincia","",ConvertXml(CYb.Addr4),level);
  end;
  AddXmlTagToArea(a_req,"Nazione","","IT",level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</Sede>",level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</AltriDatiIdentificativi>",level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</CedentePrestatoreDTE>",level);

  return;
end;

