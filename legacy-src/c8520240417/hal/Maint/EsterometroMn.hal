  AddPlainXmlToArea(a_req,"<Sede>",level);
  level = level + 1;
  AddXmlTagToArea(a_req,"Indirizzo","",ConvertXml(CYb.Addr0),level);
  M4PadString(CYb.Addr2,5,"0",true,tstr)
  AddXmlTagToArea(a_req,"CAP","",ConvertXml(tstr),level);
  AddXmlTagToArea(a_req,"Comune","",ConvertXml(CYb.Addr3),level);
  if (nonblank(CYb.Addr4)) then begin
    AddXmlTagToArea(a_req,"Provincia","",ConvertXml(CYb.Addr4),level);
  end;
  AddXmlTagToArea(a_req,"Nazione","","IT",level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</Sede>",level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</AltriDatiIdentificativi>",level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</CessionarioCommittenteDTR>",level);

  return;
end;

procedure AddSLFooter(var area a_req,var Integer level)
begin

  level = level - 1;
  AddPlainXmlToArea(a_req,"</CessionarioCommittenteDTE>",level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</DTE>",level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</ns2:DatiFattura>",level);

  return;
end;

procedure AddPLFooter(var area a_req,var Integer level)
begin

  level = level - 1;
  AddPlainXmlToArea(a_req,"</CedentePrestatoreDTR>",level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</DTR>",level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</ns2:DatiFattura>",level);

  return;
end;

procedure InvalidatePos(record RcVc RepSpec,var area a_req,var Integer level)
begin

  AddPlainXmlToArea(a_req,"<?xml version=""1.0"" encoding=""UTF-8"" standalone=""yes""?><ns2:DatiFattura versione=""DAT20"" xmlns:ns2=""http://ivaservizi.agenziaentrate.gov.it/docs/xsd/fatture/v2.0"">",level);
  level = level + 1;
  AddPlainXmlToArea(a_req,"<ANN>",level);
  level = level + 1;
  AddXmlTagToArea(a_req,"IdFile","",RepSpec.f1,level);
  AddXmlTagToArea(a_req,"Posizione","",RepSpec.f2,level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</ANN>",level);
  level = level - 1;
  AddPlainXmlToArea(a_req,"</ns3:DatiFattura>",level);
  
  return;
end;

global updating
procedure EsterometroMn(record RcVc RepSpec)
begin
  record IVVc IVr,IV2r;
  record VIVc VIr,VI2r;
  Boolean TrHs,testf,firstf;
  string 255 prevcust,fname,path;
  LongInt cnt,newnum,tlong;
  area a_req,a_rep;
  Integer level;
  record HTSTestServerBlock HTSTSb;
  record HTSTXBlock HTSTXb;

  BlockLoad(HTSTXb);
  BlockLoad(HTSTSb);

  cnt = 1;
  switch (RepSpec.flags[2]) begin
    case 0:
      level = 0;
      firstf = true;
      switch (RepSpec.flags[0]) begin
        case 0:
          IVr.XMLNumber = 999999999999999;
          ReadLastKey("XMLNumber",IVr,1,false);
          newnum = 1;
          if (IVr.XMLNumber>0) then begin
            newnum = IVr.XMLNumber + 1;
          end;
          fname = "tmp/SL" & newnum & ".xml";
          ResetLoop(IVr);
          TrHs = true;
          IVr.CustCode = "";
          IVr.TransDate = RepSpec.sStartDate;
          while (LoopKey("TransDateCust",IVr,2,TrHs)) begin
            if (IVr.TransDate>RepSpec.sEndDate) then begin
              TrHs = false;
            end else begin
              testf = true;
              if (IVr.OKFlag==0) then begin
                testf = false;
              end;
              if (IVr.Invalid!=0) then begin
                testf = false;
              end;
              if (testf) then begin
                if (blank(prevcust) or prevcust!=IVr.CustCode) then begin
                  if (firstf) then begin
                    firstf = false;
                    AddSLHeader(a_req,level,newnum);
                  end;
                  AddCustData(IVr,a_req,level,prevcust);
                  prevcust = IVr.CustCode;
                end;
                AddIVData(IVr,a_req,level);
                RecordCopy(IV2r,IVr);
                IVr.XMLPosition = cnt;
                IVr.XMLNumber = newnum;
                RecordUpdate(IV2r,IVr,false);
                cnt = cnt + 1;
              end;
            end;
          end;
          if (cnt>1) then begin
            AddSLFooter(a_req,level);
          end;
        case 1:
          VIr.XMLNumber = 999999999999999;
          ReadLastKey("XMLNumber",VIr,1,false);
          newnum = 1;
          if (VIr.XMLNumber>0) then begin
            newnum = VIr.XMLNumber + 1;
          end;
          fname = "tmp/PL" & newnum & ".xml";
          ResetLoop(VIr);
          TrHs = true;
          VIr.VECode = "";
          VIr.TransDate = RepSpec.sStartDate;
          while (LoopKey("TransDateVECode",VIr,2,TrHs)) begin
            if (VIr.TransDate>RepSpec.sEndDate) then begin
              TrHs = false;
            end else begin
              testf = true;
              if (VIr.OKFlag==0) then begin
                testf = false;
              end;
              if (VIr.Invalid!=0) then begin
                testf = false;
              end;
              if (testf) then begin
                if (blank(prevcust) or prevcust!=VIr.VECode) then begin
                  if (firstf) then begin
                    firstf = false;
                    AddPLHeader(a_req,level,newnum);
                  end;
                  AddVendData(VIr,a_req,level,prevcust);
                  prevcust = VIr.VECode;
                end;
                AddVIData(VIr,a_req,level);
                RecordCopy(VI2r,VIr);
                VIr.XMLPosition = cnt;
                VIr.XMLNumber = newnum;
                RecordUpdate(VI2r,VIr,false);
                cnt = cnt + 1;
              end;
            end;
          end;
          if (cnt>1) then begin
            AddPLFooter(a_req,level);
          end;
      end;
    case 1:
      if (nonblank(RepSpec.f1) and nonblank(RepSpec.f2)) then begin
        tlong = StringToLongInt(StripNonDigits(RepSpec.f1));
        switch (RepSpec.flags[0]) begin
          case 0:
            IVr.XMLNumber = tlong;
            testf = true;
            while (LoopKey("XMLNumber",IVr,1,testf)) begin
              if (IVr.XMLNumber!=tlong) then begin
                testf = false;
              end else begin
                if (IVr.XMLPosition==StringToLongInt(RepSpec.f2)) then begin
                  fname = "tmp/SL" & IVr.XMLNumber & "-" & IVr.XMLPosition & "Invalidate.xml";
                  InvalidatePos(RepSpec,a_req,level);
                  cnt = cnt + 1;
                  testf = false;
                end;
              end;
            end;
          case 1:
            VIr.XMLNumber = tlong;
            testf = true;
            while (LoopKey("XMLNumber",VIr,1,testf)) begin
              if (VIr.XMLNumber!=tlong) then begin
                testf = false;
              end else begin
                if (VIr.XMLPosition==StringToLongInt(RepSpec.f2)) then begin
                  fname = "tmp/PL" & VIr.XMLNumber & "-" & VIr.XMLPosition & "Invalidate.xml";
                  InvalidatePos(RepSpec,a_req,level);
                  cnt = cnt + 1;
                  testf = false;
                end;
              end;
            end;
        end;
      end;
  end;

  if (cnt>1) then begin
    if (RepSpec.flags[1]==0) then begin
      WriteAreaToFile(a_req,fname,0);
    end else begin
      WriteAreaToFile(a_req,fname,0);
      if (HTSTXb.Partner==kInternalServerArubaInvoicing) then begin
        if (DoLoginAruba(HTSTSb.ThisIsTestTX!=0)) then begin
          AddDataToCallAruba(HTSTSb.ThisIsTestTX!=0,a_req);
        end;
      end;
    end;
  end;
  
  return;
end;