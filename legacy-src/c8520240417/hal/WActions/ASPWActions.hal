  end;

  res = AssignHostIP(CNr,RepSpec.f2,msg);
  if (res>0) begin
    MessageBox(0,msg);
    goto LASPAssignHostIPWClassChange;
  end;

  CloseWindow(wn);

LASPAssignHostIPWClassChange:;
end;

