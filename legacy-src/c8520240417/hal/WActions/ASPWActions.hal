global
function Boolean CheckCloudControllerVersion(string vercode,var string msg)
begin
  Boolean res;

  if (left(vercode,7)!="STDERP_") then begin
    msg = "Please select a version of Standard ERP and try again.";
    goto LCheckCloudControllerVersion;
  end;

  if (right(vercode,4)!="-ASP") then begin
    msg = "Please select an ASP version of Standard ERP and try again.";
    goto LCheckCloudControllerVersion;
  end;

  res = true;
LCheckCloudControllerVersion:;
  CheckCloudControllerVersion = res;
  return;
end;

global
updating procedure UpdateCloudToSelectedVersionLsm()
begin
  record HansaVersionVc HVr;
  Integer wn;
  string 255 msg;

  wn = CurWindow;
  if (!GetRecordFromBrowse(HVr,wn,1)) then begin
    MessageBox(0,"Please select the version that you want to update to and try again.");
    goto LUpdateCloudToSelectedVersionLsm;
  end;

  if (CheckCloudControllerVersion(HVr.Code,msg)==false) then begin
    MessageBox(0,msg);
    goto LUpdateCloudToSelectedVersionLsm;
  end;

  UpdateCloudToVersion(HVr);

LUpdateCloudToSelectedVersionLsm:;
end;

