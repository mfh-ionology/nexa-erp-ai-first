    RepSpec.repname = "InspectRemoteCloudServerLogRn";
    RepSpec.f1 = recarr[i];
    RepSpec.f2 = "hal.log";
    RepSpec.NoTimeoutLimit = 1;
    RunReport(RepSpec,0);
  end;
end;

