procedure GetRemoteSelectedServers(var array uuid recarr)
begin
  array record RemoteCloudServerVc RCSarr;
  record RemoteCloudServerVc RCSr;
  LongInt i;
  Integer wn;

  wn = CurWindow;
  ClearArray(recarr);
  GetAllRecordsFromBrowse(RCSarr,wn);

  for (i = 0; i<RCSarr.length; i = i + 1) begin
    RCSr = RCSarr[i];
    recarr[i] = RCSr.UUID;
  end;
end;

function Boolean GetRemoteSelectedServersWithStatus(var array uuid recarr,LongInt required_status)
begin
  array record RemoteCloudServerVc RCSarr;
  record RemoteCloudServerVc RCSr;
  LongInt i;
  Integer wn;
  Boolean statusokf;

  wn = CurWindow;
  ClearArray(recarr);
  GetAllRecordsFromBrowse(RCSarr,wn);

  for (i = 0; i<RCSarr.length; i = i + 1) begin
    RCSr = RCSarr[i];
    if (RCSr.CurrentStatus==required_status) then begin
      recarr[recarr.length] = RCSr.UUID;
    end else begin
      statusokf = false;
    end;
  end;

  GetRemoteSelectedServersWithStatus = statusokf;
  return;
end;

global
updating procedure DownloadClientForRemoteCloudServerLsm()
begin
  array uuid recarr;
  Integer mwn,i;
  string 255 addr;
  LongInt port;
  record RemoteCloudServerVc RCSr;
  string 255 name;

  mwn = CurWindow;
  i = 1;
  while (GetRecordFromBrowse(RCSr,mwn,i)) begin
    if ((RCSr.CurrentStatus!=kStatusRunning) and
        (RCSr.CurrentStatus!=kStatusMaintenance) and
        (RCSr.CurrentStatus!=kStatusRunningPendingStop) and
        (RCSr.CurrentStatus!=kStatusRunningTest)) then begin
      MessageBox(0,"Please start " & RCSr.Name & " before trying to launch a client for the server.");
    end else begin
      name = RCSr.Name;
      if (WindowsMode) then begin
        name = ReplaceStringWithString(name,"ò","o");
        name = ReplaceStringWithString(name,"ó","o");
        name = ReplaceStringWithString(name,"ô","o");
        name = ReplaceStringWithString(name,"œ","oe");
        name = ReplaceStringWithString(name,"ø","o");
        name = ReplaceStringWithString(name,"ō","o");
        name = ReplaceStringWithString(name,"õ","o");
        name = ReplaceStringWithString(name,"ö","o");
        name = ReplaceStringWithString(name,"Ô","o");
        name = ReplaceStringWithString(name,"Ò","O");
        name = ReplaceStringWithString(name,"Ó","O");
        name = ReplaceStringWithString(name,"Œ","OE");
        name = ReplaceStringWithString(name,"Ø","O");
        name = ReplaceStringWithString(name,"Ō","O");
        name = ReplaceStringWithString(name,"Õ","O");
        name = ReplaceStringWithString(name,"Ö","O");
        name = ReplaceStringWithString(name,"à","a");
        name = ReplaceStringWithString(name,"á","a");
        name = ReplaceStringWithString(name,"â","a");
        name = ReplaceStringWithString(name,"æ","ae");
        name = ReplaceStringWithString(name,"ã","a");
        name = ReplaceStringWithString(name,"å","a");
        name = ReplaceStringWithString(name,"ā","a");
        name = ReplaceStringWithString(name,"ä","a");
        name = ReplaceStringWithString(name,"À","A");
        name = ReplaceStringWithString(name,"Á","A");
        name = ReplaceStringWithString(name,"Â","a");
        name = ReplaceStringWithString(name,"Æ","AE");
        name = ReplaceStringWithString(name,"Ã","A");
        name = ReplaceStringWithString(name,"Å","A");
        name = ReplaceStringWithString(name,"Ā","A");
        name = ReplaceStringWithString(name,"Ä","A");
        name = ReplaceStringWithString(name,"ü","u");
        name = ReplaceStringWithString(name,"û","u");
        name = ReplaceStringWithString(name,"ù","u");
        name = ReplaceStringWithString(name,"ú","u");
        name = ReplaceStringWithString(name,"ū","u");
        name = ReplaceStringWithString(name,"Ü","U");
        name = ReplaceStringWithString(name,"Û","U");
        name = ReplaceStringWithString(name,"Ù","U");
        name = ReplaceStringWithString(name,"Ú","U");
        name = ReplaceStringWithString(name,"Ū","U");
        name = ReplaceStringWithString(name,"'","");
        name = ReplaceStringWithString(name,"*","");
        name = ReplaceStringWithString(name,".","");
        name = ReplaceStringWithString(name,":","");
        name = ReplaceStringWithString(name,",","");
        name = ReplaceStringWithString(name,";","");
        name = ReplaceStringWithString(name,"#","");
        name = ReplaceStringWithString(name,"€","");
        name = ReplaceStringWithString(name,"%","");
        name = ReplaceStringWithString(name,"&","");
        name = ReplaceStringWithString(name,"/","");
        name = ReplaceStringWithString(name,"\\","");
        name = ReplaceStringWithString(name,"(","");
        name = ReplaceStringWithString(name,")","");
        name = ReplaceStringWithString(name,"=","");
        name = ReplaceStringWithString(name,"<","");
        name = ReplaceStringWithString(name,">","");
        name = ReplaceStringWithString(name,"[","");
        name = ReplaceStringWithString(name,"]","");
        name = ReplaceStringWithString(name,"{","");
        name = ReplaceStringWithString(name,"}","");
        name = ReplaceStringWithString(name,"|","");
      end;

      if (LaunchClient(name)==false) then begin
        if (FindCloudServerAddr(RCSr,addr)) then begin
          InstallClientToServer(addr,RCSr.HTTPPort,RCSr.Port,name,RCSr.EncryptionKey);
        end;
      end;
    end;
    i = i + 1;
  end;
end;

