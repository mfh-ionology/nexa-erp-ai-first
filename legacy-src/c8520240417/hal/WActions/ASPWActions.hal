updating procedure ASPSendVersionToNodeWClassSend()
begin
  Integer wn;
  record RcVc RepSpec;
  Boolean res;

  wn = CurWindow;
  DeselectWindow(wn,true);
  GetWindowRecord(wn,RepSpec);

  res = SendVersionRecordToNode(RepSpec.f1,RepSpec.f2);
  if (res) then begin
