global procedure ASPRebuildNodeVClassWindowFieldGoto(Integer wn,record RcVc RepSpec,LongInt lp,string fld,Boolean self)
begin
  WindowFieldGoto(wn,RepSpec,lp,fld,self);
  return;
end;


function Boolean ASPRebuildNodeVClassTest(Integer wn,var record RcVc RepSpec,var string actfld,var string errmsg)
begin
  Boolean res;
  record HostingConfigurationVc HCr;
  record CloudNodeVc CNr;
  record EC2InstanceTypeVc EC2ITr;
  record EC2InstanceVc EC2Ir;
  val cost0,cost1;
  
  CNr.Code = RepSpec.f1;
  actfld = "f1";
  
  if (blank(CNr.Code)) then begin
    errmsg = "Cloud Node may not be blank";
    goto LASPRebuildNodeVClassTest;
  end;
  if (ReadFirstMain(CNr,1,true)==false) then begin
    errmsg = "Cloud Node " & RepSpec.f1 & " not found";
    goto LASPRebuildNodeVClassTest;
  end;
  HCr.SerNr = CNr.HostingConfig;
  if (ReadFirstMain(HCr,1,true)==false) then begin
    errmsg = "Hosting configuration with SerNr=" & HCr.SerNr & " " & CNr.HostingConfig & " (" & CNr.HostingConfigComment & ") not found";
    goto LASPRebuildNodeVClassTest;
  end;
  if (HCr.HostingType!=kHostingTypeAmazon) then begin
    errmsg = "Cloud Node " & RepSpec.f1 & " is not hosted on Amazon AWS";
    goto LASPRebuildNodeVClassTest;
  end;
  if (blank(HCr.AmazonRegion)) then begin
    errmsg = "Hosting configuration with SerNr=" & HCr.SerNr & " " & CNr.HostingConfig & " (" & CNr.HostingConfigComment & ") has no AWS region";
    goto LASPRebuildNodeVClassTest;
  end;
  if (blank(HCr.AmazonZone)) then begin
    errmsg = "Hosting configuration with SerNr=" & HCr.SerNr & " " & CNr.HostingConfig & " (" & CNr.HostingConfigComment & ") has no AWS availability zone";
    goto LASPRebuildNodeVClassTest;
  end;

  actfld = "";
  
  if (nonblank(RepSpec.f2)) then begin
    EC2ITr.InstanceType = RepSpec.f2;
    EC2ITr.Region = HCr.AmazonRegion;
    if (ReadFirstMain(EC2ITr,2,true)==false) then begin
      errmsg = "Invalid instance type: " & RepSpec.f2;
      actfld = "f2";
      goto LASPRebuildNodeVClassTest;
    end;

    EC2Ir.Type = EC2ITr.InstanceType;
    EC2Ir.AvailabilityZone = HCr.AmazonZone;
    CallCloud("ConsCC").EC2InstanceMonthlyCost2(EC2Ir,cost1);
  end;
  
  if (nonblank(CNr.AmazonInstanceType)) then begin
    EC2Ir.Type = CNr.AmazonInstanceType;
    EC2Ir.AvailabilityZone = HCr.AmazonZone;
    CallCloud("ConsCC").EC2InstanceMonthlyCost2(EC2Ir,cost0);
  end;

  res = true;
  RepSpec.SerNr = HCr.SerNr;
  RepSpec.f3 = HCr.Comment;
  RepSpec.f5 = CNr.Comment;
  RepSpec.f6 = CNr.Classification;
  RepSpec.f8 = HCr.AmazonRegion;
  RepSpec.f4 = CNr.AmazonInstanceType;
  RepSpec.vals0 = cost0;
  RepSpec.vals1 = cost1;

LASPRebuildNodeVClassTest:;
  ASPRebuildNodeVClassTest = res;
  return;
end;

global
function Boolean ASPRebuildNodeVClassAfterEditField(Integer wn,string fieldname,Integer fn,Integer rownr,Integer changed)
begin
  Boolean res;
  record RcVc RepSpec;
  string 255 actfld,errmsg;

  res = true;
  if (fieldname=="f1" or fieldname=="f2") then begin
    if (changed!=0) then begin
      GetWindowRecord(wn,RepSpec);
      if (ASPRebuildNodeVClassTest(wn,RepSpec,actfld,errmsg)==false) then begin
        MessageBox(0,errmsg);
        queued.ASPRebuildNodeVClassWindowFieldGoto(wn,RepSpec,-1,actfld,true);
        goto LASPRebuildNodeVClassAfterEditField;
      end;

      PutWindowRecord(wn,RepSpec);
      queued.ASPRebuildNodeVClassWindowFieldGoto(wn,RepSpec,-1,"f2",false);
    end;
  end;
  
LASPRebuildNodeVClassAfterEditField:;
  ASPRebuildNodeVClassAfterEditField = res;
  return;
end;
  
global
procedure ASPRebuildNodeVClassNodeStatus()
begin
  record RcVc RepSpec,RepSpec2;
  Integer wn;
  
  wn = CurWindow;
  DeselectWindow(wn,true);
  GetWindowRecord(wn,RepSpec);
  
  if (blank(RepSpec.f1)) then begin
    MessageBox(0,"Cloud Node may not be blank");
    goto LASPRebuildNodeVClassNodeStatus;
  end;

  RepSpec2.Media = mtScreen;
  RepSpec2.NoTimeoutLimit = 1;
  RepSpec2.f1 = RepSpec.f1;
  RepSpec2.flags[0] = 90;
  RepSpec2.repname = "NodeHostingStatsRn";
  RunReport(RepSpec2,0);
  
LASPRebuildNodeVClassNodeStatus:;
  return;
end;

global
function Boolean ASPRebuildNodeVClassOnOKWindow(Integer wn)
begin
  Boolean res;
  record RcVc RepSpec;
  record CloudNodeVc CNr;
  record HostingConfigurationVc HCr;
  string 255 actfld,errmsg;

  DeselectWindow(wn,true);
  GetWindowRecord(wn,RepSpec);
  res = ASPRebuildNodeVClassTest(wn,RepSpec,actfld,errmsg);
  if (res==false) then begin
    MessageBox(0,errmsg);
    queued.ASPRebuildNodeVClassWindowFieldGoto(wn,RepSpec,-1,actfld,true);
    goto LASPRebuildNodeVClassOnOKWindow;
  end;
  
  res = ASPRebuildNodeVClassCheckNode(RepSpec,errmsg);
  if (res==false) then begin
    MessageBox(0,errmsg);
    goto LASPRebuildNodeVClassOnOKWindow;
  end;

LASPRebuildNodeVClassOnOKWindow:;
  ASPRebuildNodeVClassOnOKWindow = res;
  return;
end;

global
updating procedure InstallFlexBILsm()
begin
  record RemoteCloudServerVc RCSr;
  Integer wn;
  string 255 msg;

  wn = CurWindow;
  if (GetRecordFromBrowse(RCSr,wn,1)) then begin
    if (IsAllowedHansaMailFunction(RCSr)==false) then begin
      goto LInstallFlexBILsm;
    end;
    InstallFlexBIOnRemoteCloudServer(RCSr,msg);
    if (nonblank(msg)) then begin MessageBox(0,msg); end;
  end else begin
    MessageBox(0,"Please select the server that you want to install FlexBI on and try again.");
  end;
  
LInstallFlexBILsm:;
  return;
end;
