updating procedure DevelopmentTestFuncLsm()
begin
  Integer wn;
  record HansaVersionVc HVr;
  string 255 str;

  HVr.Version = 80;
  HVr.SubVersion = 2;
  HVr.ProgramType = typStdAccountsServer;
  HVr.ProductCode = "StandardServer";

  if (ReadLastKey("DbVersion",HVr,2,true)==false) then begin
