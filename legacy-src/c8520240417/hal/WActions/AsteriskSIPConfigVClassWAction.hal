
global
procedure AsteriskSIPConfigVClassReportDefaults(Integer wn)
begin
  record RcVc RepSpec;
  record PBXConnectionVc PBXCr;

  DeSelectWindow(wn,true);
  GetWindowRecord(wn,RepSpec);
  ReportDefaults(RepSpec,"AsteriskSIPConfigVClass");
//  LoopMain(PBXCr,0,true);
//  RepSpec.f1 = PBXCr.Code; // Blank == update all open PBX connections
  PutWindowRecord(wn,RepSpec);
  SelectWindow(wn);
end;

