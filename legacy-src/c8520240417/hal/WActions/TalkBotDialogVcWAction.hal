remote updating procedure WatsonAssistantClear();
remote updating procedure WatsonAssistantExport(LongInt,var area);

global
function Boolean TalkBotDialogEntryDClassUpdateWindowSubset(Integer wn,var string subsetname)
begin
  record TalkBotDialogEntryVc TBDEr;
  
  GetWindowRecord(wn,TBDEr);
  if (nonblank(TBDEr.SerNr)) then begin
    subsetname = TBDEr.SerNr;
  end else begin
    subsetname = chr(0);
  end;
  
  TalkBotDialogEntryDClassUpdateWindowSubset = true;
  return;
end;

global
updating procedure TalkBotWatsonAssistantClearLsm()
begin
  WatsonAssistantClear;
  
  UpdateBrowses("TalkBotDialogVc");
  UpdateBrowses("TalkBotIntentVc");
  UpdateBrowses("TalkBotEntity");
  UpdateBrowses("TalkBotDialogEntryVc");
  return;
end;

global
updating procedure TalkBotWatsonAssistantExportLsm()
begin
  string 255 expfile;
  area a_json;
  record TalkBotDialogVc TBDr;
  LongInt wn;
  
  wn = CurWindow;
  if (GetRecordFromBrowse(TBDr,wn,1)==false) begin
    Beep;
    goto LTalkBotWatsonAssistantExportLsm;
  end;
  if (GetRecordFromBrowse(TBDr,wn,2)==true) begin
    Beep;
    goto LTalkBotWatsonAssistantExportLsm;
  end;

  expfile = SaveFileDialog(expfile,"","json");
  if (blank(expfile)) then begin goto LTalkBotWatsonAssistantExportLsm; end;
  
  Delete_file(expfile);
  WatsonAssistantExport(TBDr.SerNr,a_json);
  WriteAreaToFile(a_json,expfile,0);
  
LTalkBotWatsonAssistantExportLsm:;
  return;
end;

function Boolean GetActiveRow(Integer wn,var row TalkBotDialogEntryVc TBDErw)
begin
  record TalkBotDialogEntryVc TBDEr;
  Integer rownr;
  Boolean res;

  GetWindowRecord(wn,TBDEr);
  rownr = WindowActiveRow(wn);
  if (rownr>=0) then begin
    MatRowGet(TBDEr,rownr,TBDErw);
    res = true;
  end;

  GetActiveRow = res;
  return;
end;

