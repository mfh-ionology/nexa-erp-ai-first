function Boolean PrintConditionDClassCodeEFAfter(Integer wn,Boolean changedf)
begin
  Boolean res;
  record PrintConditionVc PrintConditionr;

  res = true;
  if (changedf) then begin
    GetWindowRecord(wn,PrintConditionr);
    PrintConditionr.ChangeDate = CurrentDate;
    PutWindowRecord(wn,PrintConditionr);
  end;
  PrintConditionDClassCodeEFAfter = res;
  return;
end;

