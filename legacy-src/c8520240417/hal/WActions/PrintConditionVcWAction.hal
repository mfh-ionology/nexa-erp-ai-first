global
function Boolean PrintConditionDClassAfterEditField(Integer wn,string fieldname,Integer fn, Integer rownr,Integer changed)
begin
  Boolean res;

  switch (fieldname) begin
    case "Code": res = PrintConditionDClassCodeEFAfter(wn,changed!=0);
    case "Comment": res = PrintConditionDClassCommentEFAfter(wn,changed!=0);
    case "Register": res = PrintConditionDClassRegisterEFAfter(wn,changed!=0);
    case "Field": res = PrintConditionDClassFieldEFAfter(wn,changed!=0);
    case "Operator": res = PrintConditionDClassOperatorEFAfter(wn,changed!=0);
    case "Parameter1": res = PrintConditionDClassParameter1EFAfter(wn,changed!=0);

  end;
  PrintConditionDClassAfterEditField = res;
  return;
end;


