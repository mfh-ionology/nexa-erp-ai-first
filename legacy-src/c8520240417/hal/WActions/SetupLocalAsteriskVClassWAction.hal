remote updating procedure SetupLocalAsteriskAtServer(boolean);

global
updating function Boolean SetupLocalAsteriskVClassOnOKWindow(Integer wn)
begin
  record RcVc RepSpec;
  Integer mwn;

  DeselectWindow(wn,false);
  mwn = MotherWindow(wn);
  GetWindowRecord(wn,RepSpec);
  OpenProgressWindow(41100,41101,2);
  SetupLocalAsteriskAtServer(false);
  CloseWindow(wn);
  SetupLocalAsteriskVClassOnOKWindow = false;
  return;
end;

