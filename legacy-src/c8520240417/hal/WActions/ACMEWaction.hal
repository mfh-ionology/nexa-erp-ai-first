procedure ACMEWorkspace_CheckValidationStatus()
begin
  LongInt wn;
  record ACMEWorkspaceVc AWr;

  wn = CurWindow;
  GetWindowRecord(wn,AWr);
  
  if (AWr.OrderURL=="") then begin
    Beep;
    StopAlert("Order not created");
    goto LACMECheckValidationStatus_out;
  end;
  
  ACMECheckValidationStatus(AWr);
  
LACMECheckValidationStatus_out:;
  SetWindowState(wn,Rs_update);
  PutWindowPrevRecord(wn,AWr);
  PutWindowRecord(wn,AWr);
  SetWindowState(wn,Rs_normal);
end;

