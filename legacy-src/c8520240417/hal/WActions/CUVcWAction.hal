procedure CUDClassOpenWeb()
BEGIN
  Integer wn,nwn;
  string 255 subset;
  record CUVc CUr;
  
  wn = CurWindow;
  GetWindowRecord(wn,CUr);
  nwn = OpenWindow("CUWebDClass",1,wn,subset,"",CUr);
