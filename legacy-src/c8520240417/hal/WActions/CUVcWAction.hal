    sufix_instruction = sufix_instruction & "Name and location of the company." & NL;
    sufix_instruction = sufix_instruction & "If you do not have information about the company, just say it, do not make it up." & NL;
    sufix_instruction = sufix_instruction & "" & NL;
    sufix_instruction = sufix_instruction & "Competitive Analysis:" & NL;
    sufix_instruction = sufix_instruction & "Compare key competitors offering similar solutions in the industry in the customer's country." & NL;
    sufix_instruction = sufix_instruction & "If you do not have information about the company, just say it, do not make it up." & NL;
  end;

  OpenAI_Do_Research(prompt,sufix_instruction);
end;
