function Boolean CUDClassVATNrCodeEFAfter(Integer wn,Boolean changedf)
begin
  Boolean res;
  record CUVc CUr;
  string 255 tstr,gotofield;
  LongInt errcode;
  
  if (changedf) then begin
    GetWindowRecord(wn,CUr);
    errcode = ValidCUDataForVATLaw(WindowState(wn),"VATNr",CUr,tstr,gotofield);
    if (errcode!=0) then begin
      MessageBox(errcode," " & tstr);
    end;
  end;
  CUDClassVATNrCodeEFAfter = res;
  return;
end;

