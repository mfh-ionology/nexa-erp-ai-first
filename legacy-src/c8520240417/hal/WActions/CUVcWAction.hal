global
function string 255 OpenAI_AnalyzeCustomerSm()
begin
  record CUVc CUr;
  Integer wn,nwn,dbgwn;
  record AIChatVc AICr;
  record AIChatVc AIC2r;
  array string 255 roles,messages;
  json response;
  LongInt httpres;
  string 255 resp_role,resp_message,model,request,disclaimer;
  record RcVc RepSpec;
  area reparea;
  string 255 questiontext;
  string 255 prompt;
  string 255 prefix_custat;
  string 255 sufix_instruction;
  record AILinkBlock AILb;

  wn = CurWindow;
  
  DeselectWindow(wn,true);
  GetWindowRecord(wn,CUr);
  
  SetupCustPS2Rn(CUr.Code,RepSpec);
  RepSpec.Media = mtHandle;
  RunReport(RepSpec,0);
  GetThreadScrTxtH(reparea);
  
  BlockLoad(AILb);
  AICr.DebugFlag = AILb.DebugFlag;
  
  prompt = ReadFileToString("OpenAI_AnalyzeCustomer_Prompt.txt");
  prefix_custat = ReadFileToString("OpenAI_AnalyzeCustomer_PrefixCUStat.txt");
  sufix_instruction = ReadFileToString("OpenAI_AnalyzeCustomer_SuffixInstruction.txt");
  model = Trim(ReadFileToString("OpenAI_AnalyzeCustomer_Model.txt"));
  disclaimer = ReadFileToString("OpenAI_AnalyzeCustomer_Disclaimer.txt");

  if (prompt=="") then begin
    prompt =          "You are a sales expert. You are clear and to the point type of person. You manage many customers worldwide. You are excellent summarizing a customer information." & NL;
    prompt = prompt & "I will give you """"""INFORMATION"""""" about a specific company and you will write a """"""SUMMARY"""""". Optimize the SUMMARY for executives to read it, while using a serious, short and professional tone." & NL;
    prompt = prompt & "" & NL;
    prompt = prompt & "Before providing the """"""SUMMARY"""""" make sure you think step by step:" & NL;
    prompt = prompt & "1. Think about what aspects are important to know about this company" & NL;
    prompt = prompt & "2. The SUMMARY should be short, simple, brief and it  should express the most relevant points" & NL;
    prompt = prompt & "3. Avoid providing information that is not relevant for managers" & NL;
    prompt = prompt & "4. Avoid listing values with cents, avoid making references to record numbers or VAT details." & NL;
    prompt = prompt & "5. Use values like ""500"" instead of ""500.00""" & NL;
    prompt = prompt & "6. Find information about them on their website";
  end;
  
  if (prefix_custat=="") then begin
    prefix_custat = """""""INFORMATION"""""" This is the customer status report: " & NL & NL;
  end;

  if (sufix_instruction=="") then begin
    sufix_instruction = "Provide a SUMMARY for this customer, list the most important and relevant points to remember about the customer and a suggested next step.";
  end;

  if (disclaimer=="") then begin
    disclaimer = "Disclaimer: The content of this report is limited to information available up to September 2021, and any subsequent data is not included.";
  end;

  AIChat_AddMessage(roles,messages,"system",prompt);
  
  questiontext = "The customer is called " & CUr.Name;
  
  if (CUr.Person<>"") then begin
    questiontext = questiontext & ", our primary contact is " & CUr.Person;
  end;
  
  if (CUr.wwwAddr<>"") then begin
    questiontext = questiontext & ", their website is " & CUr.wwwAddr;
  end;

  questiontext = questiontext & NL & NL;

  questiontext = questiontext & prefix_custat & NL & NL;
  questiontext = questiontext & AreaToString(reparea);
  questiontext = questiontext & NL & NL;
  
  questiontext = questiontext & sufix_instruction;

  AIChat_AddMessage(roles,messages,"user",questiontext);
  
  model = OpenAI_Model(model,AICr);
  
  request =           "{";
  request = request & """model"": """ & model & """,";
  AddAIChatToJSON(roles,messages,request);
  request = request & "}";
  
  httpres = OpenAI_POST_JSON("v1/chat/completions",request,response);
  
  if (AICr.DebugFlag<>0) then begin
    SetTextField(AIC2r,request & CR & LF  & CR & LF & httpres & CR & LF  & CR & LF & JSONGetAsJSONString(response,"/"));
    dbgwn = OpenWindow("AIChatReplyWClass",0,0,"","",AIC2r);
  end;
  
  resp_role = JSONGet(response,"choices/[0]/message/role");
  resp_message = JSONGet(response,"choices/[0]/message/content");
  
  if (resp_role<>"") then begin
    OpenAI_Message("analysis",disclaimer,CrlfStringToHtml(resp_message));
//    AIChat_AddMessage(roles,messages,resp_role,resp_message);
//    nwn = OpenWindow("AIChatWClass",0,0,"","",AICr);
//    AIChat_Store(nwn,roles,messages);
  end;
end;

procedure AddDatumLine(var string alltext,string label,string datum)
begin
  if (Trim(datum)<>"") then begin
    alltext = alltext & label & ": " & datum & NL;
  end;
end;

function string 255 CustomerCategoryName(string CustCat)
begin
  record CCatVc CCatr;
  
  if (nonblank(CustCat)) then begin
    CCatr.Code = CustCat;
    if (ReadFirstMain(CCatr,1,true)) then begin
      CustomerCategoryName = CCatr.Comment;
    end;
  end;
end;

function string 255 SupplierCategoryName(string VECat)
begin
  record VGVc VGr;
  
  if (nonblank(VECat)) then begin
    VGr.Code = VECat;
    if (ReadFirstMain(VGr,1,true)) then begin
      SupplierCategoryName = VGr.Comment;
    end;
  end;
end;

function string 255 CustomerClassificationName(string Classification)
begin
  record CClassVc CClassr;
  LongInt pos;
  string 255 res,class;
  
  while (GetNextSubstring(Classification,pos,",",class)) begin
    CClassr.Code = class;
    if (ReadFirstMain(CClassr,1,true)) then begin
      if (CClassr.Comment<>"") then begin
        if (res<>"") then begin res = res & ", "; end;
        res = res & CClassr.Comment;
      end;
    end;
  end;
  
  CustomerClassificationName = res;
end;

global
function string 255 OpenAI_Do_Research(string prompt,string sufix_instruction)
begin
  record CUVc CUr;
  Integer wn,nwn;
  record AIChatVc AICr;
  record AIChatVc AIC2r;
  array string 255 roles,messages;
  json response;
  LongInt httpres;
  string 255 resp_role,resp_message,model,request,disclaimer,questiontext;
  record RcVc RepSpec;
  record AILinkBlock AILb;

  wn = CurWindow;
  
  DeselectWindow(wn,true);
  GetWindowRecord(wn,CUr);
  
  BlockLoad(AILb);
  AICr.DebugFlag = AILb.DebugFlag;
  
  model = Trim(ReadFileToString("OpenAI_Research_Model.txt"));
  disclaimer = ReadFileToString("OpenAI_Research_Disclaimer.txt");
  
  if (disclaimer=="") then begin
    disclaimer = "<p>Disclaimer<p>The content of this report is limited to information available up to September 2021, and any subsequent data is not included.";
  end;
  
  AIChat_AddMessage(roles,messages,"system",prompt);
  
  AddDatumLine(questiontext,"The customer's name is",CUr.Name);
  AddDatumLine(questiontext,"The customer's address is",CUr.InvAddr0 & " " & CUr.InvAddr1 & " " & CUr.InvAddr2);
  AddDatumLine(questiontext,"The customer's VAT number is",CUr.VATNr);
  AddDatumLine(questiontext,"The customer's category is",CustomerCategoryName(CUr.CustCat));
  AddDatumLine(questiontext,"The customer's supplier category is",SupplierCategoryName(CUr.VECat));
  AddDatumLine(questiontext,"The customer's classifications are",CustomerClassificationName(CUr.Classification));
  AddDatumLine(questiontext,"Our primary contact at the customer is",CUr.Person);
  AddDatumLine(questiontext,"The customer's website is",CUr.wwwAddr);
  questiontext = questiontext & NL;
  questiontext = questiontext & sufix_instruction;

  AIChat_AddMessage(roles,messages,"user",questiontext);
  
  model = OpenAI_Model(model,AICr);

  OpenAI_DoChat(model,roles,messages,response,AICr.DebugFlag);

  resp_role = JSONGet(response,"choices/[0]/message/role");
  resp_message = JSONGet(response,"choices/[0]/message/content");

  if (resp_role<>"") then begin
    OpenAI_Message("research",disclaimer,CrlfStringToHtml(resp_message));
  end;
end;

global
function string 255 OpenAI_ResearchContactSm()
begin
  string 255 prompt,sufix_instruction;
  
  prompt = ReadFileToString("OpenAI_ResearchContact_Prompt.txt");
  sufix_instruction = ReadFileToString("OpenAI_ResearchContact_SuffixInstruction.txt");
  
  if (prompt=="") then begin
    prompt = prompt & "You are a market researcher. You are clear and to the point type of person. You manage many customers worldwide. You are excellent researching and summarizing a customer information." & NL;
    prompt = prompt & "" & NL;
    prompt = prompt & "Before providing the """"""RESEARCH"""""" make sure you think step by step:" & NL;
    prompt = prompt & "1. Think about what aspects are important to know about this company" & NL;
    prompt = prompt & "2. The """"""RESEARCH"""""" should be short, simple, brief and it  should express the most relevant points" & NL;
    prompt = prompt & "3. Avoid providing information that is not relevant for managers" & NL;
    prompt = prompt & "4. Avoid listing values with cents, use values like ""500"" instead of ""500.00""" & NL;
    prompt = prompt & "5. Find information about the customer on their website or any other source" & NL;
    prompt = prompt & "6. Find information about the customer's industry" & NL;
    prompt = prompt & "7. If you do not have information about the company, just say it, do not make it up." & NL;
  end;
  
  if (sufix_instruction=="") then begin
    sufix_instruction = sufix_instruction & "Provide the results of the """"""RESEARCH"""""" in this format:" & NL;
    sufix_instruction = sufix_instruction & "" & NL;
    sufix_instruction = sufix_instruction & "Company Profile:" & NL;
    sufix_instruction = sufix_instruction & "" & NL;
    sufix_instruction = sufix_instruction & "Name and location of the company." & NL;
    sufix_instruction = sufix_instruction & "Size of the organization (e.g., number of employees, annual revenue)." & NL;
    sufix_instruction = sufix_instruction & "Brief history and mission statement." & NL;
    sufix_instruction = sufix_instruction & "If you do not have information about the company, just say it, do not make it up." & NL;
    sufix_instruction = sufix_instruction & "" & NL;
    sufix_instruction = sufix_instruction & "Customer's financial situation online:" & NL;
    sufix_instruction = sufix_instruction & "Financial Statements: Look for recent balance sheets and income statements." & NL;
    sufix_instruction = sufix_instruction & "News and Reports: Check news, reports, and press releases about the company's financial performance. Do not specify where to find the data but specify what do you know about their financial situation." & NL;
    sufix_instruction = sufix_instruction & "If you do not have information about the company, just say it, do not make it up." & NL;
    sufix_instruction = sufix_instruction & "" & NL;
    sufix_instruction = sufix_instruction & "Investor Relations: Visit the company's investor relations page for financial reports and presentations." & NL;
    sufix_instruction = sufix_instruction & "If you do not have information about the company, just say it, do not make it up." & NL;
    sufix_instruction = sufix_instruction & "" & NL;
    sufix_instruction = sufix_instruction & "Key Decision-Makers:" & NL;
    sufix_instruction = sufix_instruction & "Identify specific individuals responsible as relevant decision-makers." & NL;
    sufix_instruction = sufix_instruction & "If you do not have information about the company, just say it, do not make it up." & NL;
    sufix_instruction = sufix_instruction & "" & NL;
    sufix_instruction = sufix_instruction & "Recommendations: Based on the gathered information, offer strategic recommendations on how your AI solutions can address the customer's specific needs within their industry." & NL;
    sufix_instruction = sufix_instruction & "Data Sources: Include references to the sources of your research data, ensuring credibility. If you do not have information about the company, just say it, do not make it up." & NL;
  end;
  
  OpenAI_Do_Research(prompt,sufix_instruction);
end;

