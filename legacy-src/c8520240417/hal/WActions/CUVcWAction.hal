global
procedure LaunchFlexBI()
begin
  OpenWebBrowser("https://flex.bi/bi/login");
  return;
end;

procedure AddLineToArea(string line,area req)
begin
  AddTextToArea(line,req);
  AddTextToArea(chr(10),req);
  return;
end;

global
procedure CheckEUVATNumberCUDsm()
begin
  record CUVc CUr;
  record CountryVc Cr;
  area a_req,a_rep;
  Integer wn;
  xml x;
  string 255 tstr,xkey,countryCode;  
  
  wn = CurWindow;
  DeselectWindow(wn,false);
  GetWindowRecord(wn,CUr);
  if (CUr.CustType!=0) then begin
    MessageBox(21462,"");
    goto LCheckEUVATNumberCUDsm;
  end;
  Cr.Code = CUr.CountryCode;
  ReadFirstMain(Cr,1,true);
  countryCode = Cr.ISOCode;
  if (blank(countryCode)) then begin
    countryCode = CUr.CountryCode;
  end;
  AddLineToArea("<soapenv:Envelope xmlns:soapenv=""http://schemas.xmlsoap.org/soap/envelope/"" xmlns:urn=""urn:ec.europa.eu:taxud:vies:services:checkVat:types"">",a_req);
  AddLineToArea("<soapenv:Header/>",a_req);
  AddLineToArea("<soapenv:Body>",a_req);
  AddLineToArea("<urn:checkVat>",a_req);
  AddLineToArea("<urn:countryCode>" & countryCode & "</urn:countryCode>",a_req);
  AddLineToArea("<urn:vatNumber>" & StripNonDigits(CUr.VATNr) & "</urn:vatNumber>",a_req);
  AddLineToArea("</urn:checkVat>",a_req);
  AddLineToArea("</soapenv:Body>",a_req);
  AddLineToArea("</soapenv:Envelope>",a_req);
  // LogAreaToFile("_req_CheckEUVATNumberCUDsm.txt",a_req);
  if (SendWebRequest("ec.europa.eu",80,-1,false,"POST","/taxation_customs/vies/services/checkVatService","text/xml; charset=utf-8","",false,a_req,a_rep,30)) then begin
    // LogAreaToFile("_rep_CheckEUVATNumberCUDsm.txt",a_rep);
    x = ParseXMLArea(a_rep);
    xkey = "env:Envelope/env:Body/ns2:checkVatResponse/";
    if (XmlGet(x,xkey & "ns2:valid")=="true") then begin
      MessageBox(21452,"");
    end else begin
      MessageBox(21453," " & countryCode & " " & CUr.VATNr);
    end;
  end else begin
    MessageBox(20235,"");
  end;
LCheckEUVATNumberCUDsm:;  
  return;  
end;

