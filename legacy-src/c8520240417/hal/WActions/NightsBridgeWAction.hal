remote procedure NBEnableRooms();

global
procedure SendNightsBridgeStatusMessage(longint result)
begin
  if (result!=0) then begin
    MessageBox(0,USetStr(result));
  end;
  return;
end;

global
procedure NBEnableRoomsDsm()
begin
  Integer wn;
  record NightsBrigdeBlock NBb;

  wn = CurWindow;
  GetWindowRecord(wn,NBb);
  NBEnableRooms;
  return;
end;
