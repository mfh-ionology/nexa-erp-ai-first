global
function Boolean TalkBotDialogEntryDClassAfterEditField(Integer wn,string fieldname,Integer fn,Integer rownr,Integer changed)
begin
  Boolean res;
  record TalkBotDialogVc TBDr;
  record TalkBotDialogEntryVc TBDEr,TBDE2r;
  row TalkBotDialogEntryVc TBDErw;

  res = true;
  switch (fieldname) begin
    case "DialogNr":
      if (changed!=0) then begin
        GetWindowRecord(wn,TBDEr);
        TBDr.SerNr = TBDEr.DialogNr;
        if (ReadFirstMain(TBDr,1,true)) then begin
          TBDEr.DialogComment = TBDr.Comment;
          PutWindowRecord(wn,TBDEr);
        end;
      end;
    case "NextDialogEntryNr":
      if (changed!=0) then begin
        GetWindowRecord(wn,TBDEr);
        TBDE2r.SerNr = TBDEr.NextDialogEntryNr;
        if (ReadFirstMain(TBDE2r,1,true)) then begin
          TBDEr.NextDialogEntryComment = TBDE2r.Comment;
          PutWindowRecord(wn,TBDEr);
        end;
      end;
    case "DialogEntryNr":
      if (changed!=0) then begin
        GetWindowRecord(wn,TBDEr);
        MatRowGet(TBDEr,rownr,TBDErw);
        TBDE2r.SerNr = TBDErw.DialogEntryNr;
        if (ReadFirstMain(TBDE2r,1,true)) then begin
          TBDErw.DialogEntryComment = TBDE2r.Comment;
          MatRowPut(TBDEr,rownr,TBDErw);
          PutWindowRecord(wn,TBDEr);
        end;
      end;
  end;

  TalkBotDialogEntryDClassAfterEditField = res;
  return;
end;

