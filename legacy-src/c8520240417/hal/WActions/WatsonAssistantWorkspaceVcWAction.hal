global
updating procedure TalkBotTTSCreatePronounciationModelWA()
begin
  LongInt i,wn;
  record TalkBotPronModelVc TBPMr,oldTBPMr;
  string 255 modelid;
  json js;
  area a_req,a_message;
  Integer httpstatus;
  Boolean res;
  vector string 255 params_vec;

  wn = CurWindow;
  GetWindowRecord(wn,TBPMr);
  if (WindowState(wn)!=Rs_normal) then begin
    StopAlert("Record must be saved first");
    goto LTalkBotTTSCreatePronounciationModelWA;
  end;
  if (blank(TBPMr.ModelName) or blank(TBPMr.ModelDesc) /*or blank(language)*/) then begin
    goto LTalkBotTTSCreatePronounciationModelWA;
  end;
  
  AddTextToArea("{",a_req);
  AddTextToArea("\"name\":\"" & TBPMr.ModelName & "\"",a_req);
  AddTextToArea(", \"language\":\"" & "en-US" & "\"",a_req);
  AddTextToArea(", \"description\":\"" & TBPMr.ModelDesc & "\"",a_req);
  AddTextToArea("}",a_req);
  res = IBMCloudSendRequestArea(kWatsonServiceTTSCreatePronModel,"/customizations/",a_req,"",params_vec,httpstatus,a_message);
  js = ParseJSONArea(a_message);
  modelid = JSONGet(js,"customization_id");
  
  if (nonblank(modelid)) then begin
    oldTBPMr = TBPMr;
    TBPMr.ModelID = modelid;
    PutWindowRecord(wn,TBPMr);
    if (Recordupdate(oldTBPMr,TBPMr,true)==0) then begin
      SetWindowState(wn,Rs_normal);
    end;
  end;

LTalkBotTTSCreatePronounciationModelWA:;
  return;
end;

//TODO this should have some kind of conformation window like you are about to delete the whole custom voice set words and all
//and probably also delete the words asociated with it
global
updating procedure TalkBotTTSDeleteCustomModelWA()
begin
  LongInt i,wn;
  record TalkBotPronModelVc TBPMr,oldTBPMr;
  string 255 modelid;
  json js;
  area a_req,a_message;
  Integer httpstatus;
  Boolean res;
  vector string 255 params_vec;

  wn = CurWindow;
  GetWindowRecord(wn,TBPMr);
  if (WindowState(wn)!=Rs_normal) then begin
    StopAlert("Record must be saved first");
    goto LTalkBotTTSDeleteCustomModelWA;
  end;
  if (blank(TBPMr.ModelID)) then begin
    StopAlert("Record does not have a set custom ID");
    goto LTalkBotTTSDeleteCustomModelWA;
  end;
  
  res = IBMCloudSendRequestArea(kWatsonServiceTTSRemovePronModel,"/customizations/" & TBPMr.ModelID,a_req,"",params_vec,httpstatus,a_message);
  js = ParseJSONArea(a_message);
  modelid = JSONGet(js,"customization_id");
  
  if (blank(modelid)) then begin
    oldTBPMr = TBPMr;
    TBPMr.ModelID = modelid;
    PutWindowRecord(wn,TBPMr);
    if (Recordupdate(oldTBPMr,TBPMr,true)==0) then begin
      SetWindowState(wn,Rs_normal);
    end;
  end;

LTalkBotTTSDeleteCustomModelWA:;
  return;
end;

global
updating procedure SetTalkBotTTSSetCustomWordWA()
begin
  LongInt wn;
  integer result;
  record TalkBotPronWordVc TBPWr,oldTBPWr;
  record TalkBotPronModelVc TBPMr;
  string 255 modelid,pronunciation;

  wn = CurWindow;
  GetWindowRecord(wn,TBPWr);
  if (WindowState(wn)!=Rs_normal) then begin StopAlert("Record must be saved first"); goto LSetTalkBotTTSSetCustomWordWA; end;
  if (blank(TBPWr.ModelID)) then begin StopAlert("Record does not have a set customization"); goto LSetTalkBotTTSSetCustomWordWA; end;
  TBPMr.SerNr = TBPWr.ModelID;
  ReadFirstMain(TBPMr,1,true);
  if (blank(TBPMr.ModelID)) then begin StopAlert("Custom ID record not found"); goto LSetTalkBotTTSSetCustomWordWA; end;
  TalkBotTTSCustomSetWord(TBPWr.CustomWord,TBPWr.CustomPron,TBPMr.ModelID,result);
  if (result==1) then begin
    oldTBPWr = TBPWr;
    if (blank(TBPWr.CustomIBMPron)) then begin
      pronunciation = TalkBotTTSGetIBMOriginal(TBPWr.CustomWord,result);
      if (result==1) then begin
        TBPWr.CustomIBMPron = pronunciation;
      end else begin
        StopAlert("Failed to get IBM original pronounciation");
      end;
    end;
    PutWindowRecord(wn,TBPWr);
    if (Recordupdate(oldTBPWr,TBPWr,true)==0) then begin
      SetWindowState(wn,Rs_normal);
    end;
  end;

LSetTalkBotTTSSetCustomWordWA:;
  return;
end;

global
updating procedure TalkBotTTSSynthesizeWordWA()
begin
  LongInt wn;
  integer result;
  record TalkBotPronWordVc TBPWr,oldTBPWr;
  record TalkBotPronModelVc TBPMr;
  string 255 modelid,pronunciation;

  wn = CurWindow;
  GetWindowRecord(wn,TBPWr);
  if (WindowState(wn)!=Rs_normal) then begin StopAlert("Record must be saved first"); goto LTalkBotTTSSynthesizeWordWA; end;
  if (blank(TBPWr.ModelID)) then begin StopAlert("Record does not have a set custom ID"); goto LTalkBotTTSSynthesizeWordWA; end;
  if (blank(TBPWr.CustomWord)) then begin StopAlert("No word to synthesize"); goto LTalkBotTTSSynthesizeWordWA; end;
  TBPMr.SerNr = TBPWr.ModelID;
  ReadFirstMain(TBPMr,1,true);
  if (blank(TBPMr.ModelID)) then begin StopAlert("Custom ID record not found"); goto LTalkBotTTSSynthesizeWordWA; end;
  if (blank(TBPWr.CustomIBMPron)) then begin
    pronunciation = TalkBotTTSGetIBMOriginal(TBPWr.CustomWord,result);
    if (result==1) then begin
      oldTBPWr = TBPWr;
      TBPWr.CustomIBMPron = pronunciation;
    end else begin
      StopAlert("Failed to get IBM original pronounciation");
    end;
    PutWindowRecord(wn,TBPWr);
    if (Recordupdate(oldTBPWr,TBPWr,true)==0) then begin
      SetWindowState(wn,Rs_normal);
    end;
  end;
  PutWindowString(wn,"pronounciationModel",TBPMr.ModelID);
  Speak("en",TBPWr.CustomWord);

LTalkBotTTSSynthesizeWordWA:;
  return;
end;

