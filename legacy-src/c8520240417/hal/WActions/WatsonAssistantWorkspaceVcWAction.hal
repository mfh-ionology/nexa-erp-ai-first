external function Boolean IBMCloudSendRequestArea(Integer,string,area,string,vector string,var Integer,var area);
external procedure TalkBotTTSCustomSetWord(string,string,string,var integer);
external function string 255 TalkBotTTSGetIBMOriginal(string,var integer);
remote procedure IBMCloudAssistantListWorkspaces(var array string);
remote procedure IBMCloudAssistantImportWorkspace(string);

global
procedure WatsonSkillsOClassReload()
begin
  string 255 tag,tstr;
  Integer wn;
  LongInt pos,idx;
  record RcVc RepSpec;
  array string 255 skill_arr;
  string 255 skill_id,skill_lang,skill_name,skill_desc;

  wn = FindWindow("WatsonSkillsOClass");
  if (wn<=0) then begin
    goto LWatsonSkillsOClassReload;
  end;

  DeSelectWindow(wn,true);
  GetWindowRecord(wn,RepSpec);

  ClearStringList(wn);
  tag = "tagLOADING%";
  AddListRow(wn,"skills",1,tag,0);
  AddListData(wn,"skills","description","Loading...");
  PutWindowRecord(wn,RepSpec);

  ThreadRemote.IBMCloudAssistantListWorkspaces(skill_arr);

  ClearStringList(wn);
  for (idx = 0; idx<skill_arr.length; idx = idx + 1) begin
    pos = -1;
    if (!GetNextSubString(skill_arr[idx],pos,chr(0),skill_id)) then begin goto LWatsonSkillsOClassReload_next; end;
    if (!GetNextSubString(skill_arr[idx],pos,chr(0),skill_lang)) then begin goto LWatsonSkillsOClassReload_next; end;
    if (!GetNextSubString(skill_arr[idx],pos,chr(0),skill_name)) then begin goto LWatsonSkillsOClassReload_next; end;
    GetNextSubString(skill_arr[idx],pos,chr(0),skill_desc);

    tag = skill_id;
    AddListRow(wn,"skills",1,tag,0);
    AddListData(wn,"skills","id",skill_id);
    AddListData(wn,"skills","language",skill_lang);
    AddListData(wn,"skills","name",skill_name);
    AddListData(wn,"skills","description",skill_desc);
    
LWatsonSkillsOClassReload_next:;
  end;
  PutWindowRecord(wn,RepSpec);

  SetSelectedListLine(wn,0);

LWatsonSkillsOClassReload:;
  return;
end;

global
function Boolean WatsonSkillsOClassOnOpenWindow(Integer wn)
begin
  WatsonSkillsOClassReload;
  WatsonSkillsOClassOnOpenWindow = false;
  return;
end;

global
procedure ImportWatsonAssistantLsm()
begin
  Integer nwn,mwn;
  record RcVc RepSpec;
  
  mwn = CurWindow;
  nwn = OpenWindow("WatsonSkillsOClass",1,mwn,"","",RepSpec);

  return;
end;

global
procedure WatsonSkillsOClassImport()
begin
  LongInt line;
  string 255 skill_id,msg;
//  area a_ws;
  Integer wn;
  Boolean res;
  
  wn = CurWindow;
  
  line = SelectedListLine(wn);
  if (line<0) then begin goto LWatsonSkillsOClassImport; end;
  
  skill_id = GetListTag(wn,line);
  if (blank(skill_id)) then begin goto LWatsonSkillsOClassImport; end;

  CloseWindow(wn);
  
  OpenProgressWindow(41150,41151,5);
  ThreadRemoteAsync.IBMCloudAssistantImportWorkspace(skill_id);

LWatsonSkillsOClassImport:;
  return;
end;

global
function Boolean WatsonSkillsOClassListDblClick(Integer wn)
begin
  WatsonSkillsOClassImport;
  WatsonSkillsOClassListDblClick = true;
  return;
end;

