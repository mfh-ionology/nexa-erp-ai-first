  AddTextToArea("{",a_req);
  AddTextToArea("\"name\":\"" & TBLMr.ModelName & "\"",a_req);
  AddTextToArea(", \"base_model_name\":\"" & "en-US_BroadbandModel" & "\"",a_req);
  AddTextToArea(", \"description\":\"" & TBLMr.ModelDesc & "\"",a_req);
