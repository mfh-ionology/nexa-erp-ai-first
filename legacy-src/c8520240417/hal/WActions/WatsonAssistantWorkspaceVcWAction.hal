global
function Boolean WatsonAssistantWorkspaceDClassAfterEditField(Integer wn,string fieldname,Integer fn,Integer rownr,Integer changed)
begin
  Boolean res;
  record TalkBotDialogVc TBDr;
  record WatsonAssistantWorkspaceVc WAWr;

  res = true;
  switch (fieldname) begin
    case "DialogNr":
      if (changed!=0) then begin
        GetWindowRecord(wn,WAWr);
        TBDr.SerNr = WAWr.DialogNr;
        if (ReadFirstMain(TBDr,1,true)) then begin
          WAWr.DialogComment = TBDr.Comment;
          PutWindowRecord(wn,WAWr);
        end;
      end;
  end;

  WatsonAssistantWorkspaceDClassAfterEditField = res;
  return;
end;

