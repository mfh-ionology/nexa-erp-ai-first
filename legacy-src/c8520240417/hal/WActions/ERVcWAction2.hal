              if (RecordStore(ERr,updratef)) then begin
              end;
            end;
          end;
        end else begin
//  StopAlert("xx.curncy " & curncy & " units " & units & " rate " & rate & " ratedate " & ratedate & " BCb.BaseCur1 " & BCb.BaseCur1 & " BCb.BaseCur2 " & BCb.BaseCur2);
