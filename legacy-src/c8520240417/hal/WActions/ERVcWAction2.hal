  //  StopAlert("curncy " & curncy & " units " & units & " rate " & rate & " ratedate " & ratedate & " BCb.BaseCur1 " & BCb.BaseCur1 & " BCb.BaseCur2 " & BCb.BaseCur2);
              ERr.ToRate1 = rate;
