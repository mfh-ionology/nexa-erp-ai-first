function Boolean COVIDClassVECodeEFAfter(Integer wn,Integer fn,Integer rownr,Integer changed)
begin  
  record COVIVc COVIr;

  if (changed) then begin
    GetWindowRecord(wn,COVIr);
    if ((changed!=0) or ((blank(COVIr.Addr0)) and (nonblank(COVIr.VECode)))) then begin
      if (COVIVc_PasteVECode(COVIr)) then begin
        PutWindowRecord(wn,COVIr);
      end else begin
        Beep;
      end;
    end;  
  end;  
  COVIDClassVECodeEFAfter = true;
  return;
end;

