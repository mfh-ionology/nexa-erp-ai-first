function Boolean COVIDClassAccNumberEFAfter(Integer wn,Integer fn,Integer rownr,Integer changedf)
begin
record COVIVc COVIr;
  row COVIVc COVIrw;
  Boolean res;

 if (changedf!=0) then begin 
    GetWindowRecord(wn,COVIr);
    res = COVIVc_PasteAccNumber(COVIr,WindowState(wn),changedf,rownr);
    MatRowGet(COVIr,rownr,COVIrw);
    if (res) then begin
      MatRowPut(COVIr,rownr,COVIrw);
      PutWindowRecord(wn,COVIr);
    end;
 end;  
  COVIDClassAccNumberEFAfter = true;
  return;
end;

