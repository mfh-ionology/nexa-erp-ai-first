global
function Boolean COVIDClassAfterEditField(Integer wn,string fieldname,Integer fn,Integer rownr,Integer changed)
begin
  Boolean res;

  switch (fieldname) begin 
    case "VECode":        res = COVIDClassVECodeEFAfter(wn,fn,rownr,changed);
    case "FrRate":        res = COVIDClassFrRateEFAfter(wn,fn,rownr,changed);
    case "ToRateB1":      res = COVIDClassToRateB1EFAfter(wn,fn,rownr,changed);
    case "ToRateB2":      res = COVIDClassToRateB2EFAfter(wn,fn,rownr,changed);
    case "BaseRate1":     res = COVIDClassBaseRate1EFAfter(wn,fn,rownr,changed);
    case "BaseRate2":     res = COVIDClassBaseRate2EFAfter(wn,fn,rownr,changed);
    case "CurncyCode":    res = COVIDClassCurncyCodeEFAfter(wn,fn,rownr,changed);
    case "AccNumber":     res = COVIDClassAccNumberEFAfter(wn,fn,rownr,changed);
    case "Sum":           res = COVIDClassSumEFAfter(wn,fn,rownr,changed);
    case "VATCode":       res = COVIDClassVATCodeEFAfter(wn,fn,rownr,changed);
    case "ContractClass": res = COVIDClassContractClassEFAfter(wn,fn,rownr,changed);
    case "ACShort":       res = COVIDClassACShortEFAfter(wn,fn,rownr,changed);
    case "Department":    res = COVIDClassDepartmentEFAfter(wn,fn,rownr,changed);
    case "PayVal":        res = COVIDClassPayValEFAfter(wn,fn,rownr,changed);
  end;
  COVIDClassAfterEditField = res;
  return;
end;

global 
function Boolean COVIDClassInsertRowTest(Integer wn, Integer rownr)
begin
  Boolean res;
  record COVIVc COVIr;

  res = true;
  switch (WindowState(wn)) begin
    case 0://Rs_normal
      GetWindowRecord(wn,COVIr);
      if (COVIr.OKFlag!=0) then begin res = false; end;
    case 1://Rs_insert
      res = true;
    case 2://Rs_update
      GetPrevWindowRecord(wn,COVIr);
      if (COVIr.OKFlag!=0) then begin res = false; end;
    otherwise
      res = false;
  end;
  COVIDClassInsertRowTest = res;
  return;
end;

global 
function Boolean COVIDClassDeleteRowTest(Integer wn,Integer rownr)
begin
  record COVIVc COVIr;
  Boolean res;

  res = true;
  if (WindowState(wn)==2) then begin//Rs_update
    GetPrevWindowRecord(wn,COVIr);    
    if (COVIr.OKFlag!=0) then begin res = false; end;
  end;
LCOVIDClassDeleteRowTest:;  
  COVIDClassDeleteRowTest = res;
  return;
 end;

global
function Boolean COVIDClassActiveEditField(Integer wn,string fieldname,Integer fn,Integer wnst,Integer rownr,Integer changed)
begin
  Boolean res;
  record COVIVc COVIr;

  switch (wnst) begin
    case Rs_update:
      GetPrevWindowRecord(wn,COVIr);
    otherwise  
      GetWindowRecord(wn,COVIr);
  end;
  if (COVIr.OKFlag==0) then begin
    res = true;
  end;
  COVIDClassActiveEditField = res;
  return;
end;
