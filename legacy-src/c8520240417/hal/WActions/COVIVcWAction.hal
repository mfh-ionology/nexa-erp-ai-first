//remote procedure COVIVc_PastePayDeal(var record COVc);
external procedure RemoveOldContractClassObjects(string,var string);
remote function Boolean COVIVc_PasteVECode(var record COVIVc);
remote procedure COVIVc_PasteCurncyCode(var record COVIVc);
remote function Boolean COVIVc_PasteAccNumber(var record COVIVc,string,Integer,Integer);
remote procedure COVISumup(var record COVIVc);
remote procedure COVIVc_PasteACShort(var record COVIVc,Integer,Integer);
remote function val CalculateCOVICalcVATVal(var record COVIVc);
remote function val CalculateCOVINettVal(var record COVIVc);
remote procedure COVIVc_PasteDepartment(var record COVIVc);
remote procedure CalcCOVIRow(var record COVIVc,Integer);

function Boolean COVIDClassVATCodeEFAfter(Integer wn,Integer fn,Integer rownr,Boolean changedf)
begin
  record COVIVc COVIr;

  if (changedf) then begin
    GetWindowRecord(wn,COVIr);
    COVIr.NettVal = CalculateCOVINettVal(COVIr);
    COVIr.CalcVATVal = CalculateCOVICalcVATVal(COVIr);
    PutWindowRecord(wn,COVIr);
  end;
  COVIDClassVATCodeEFAfter = true;
  return;
end;

function Boolean COVIDClassContractClassEFAfter(Integer wn,Integer fn,Integer rownr,Integer changedf)
begin
  record COVIVc COVIr;
  record ContractClassBlock CCb;
  row ContractClassBlock CCbw;
  string 255 tstr,t2;
  Integer rwcnt,i;
 
  if (changedf!=0) then begin
    GetWindowRecord(wn,COVIr);
    tstr = WindEFstr(wn);
    if ((tstr!=COVIr.ContractClass) and (nonblank(tstr))) then begin
      t2 = COVIr.Objects;
      RemoveOldContractClassObjects(tstr,t2);
      COVIr.Objects = t2;
    end;
    BlockLoad(CCb);
    rwcnt = MatRowCnt(CCb);
    for (i=0;i<rwcnt;i=i+1) begin
      MatRowGet(CCb,i,CCbw);
      if (CCbw.Code==COVIr.ContractClass) then begin
        if (nonblank(COVIr.Objects)) Then begin
          COVIr.Objects = COVIr.Objects & ",";
        end;
        COVIr.Objects = COVIr.Objects & CCbw.DefObject;
      end;
    end;
    PutWindowRecord(wn,COVIr);
  end;
  COVIDClassContractClassEFAfter = true;
  return;
end;

