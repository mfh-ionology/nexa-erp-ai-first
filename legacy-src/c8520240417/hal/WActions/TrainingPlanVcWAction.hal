function Boolean TrainingPlanDClassTrainingStartEFAfter(Integer wn,Boolean changedf)
begin
  Boolean res;
  record TrainingPlanVc TrainingPlanr;
  record HRMSkillVc HRMSkillr;
  res = true;

  if (changedf) then begin
    GetWindowRecord(wn,TrainingPlanr);
    HRMSkillr.Code = TrainingPlanr.Topic;
    if (ReadFirstMain(HRMSkillr,1,true)) then begin
      TrainingPlanr.TrainingEnd = AddTime_Minutes(TrainingPlanr.TrainingStart,HRMSkillr.PlannedDuration);
    end;
    PutWindowRecord(wn,TrainingPlanr);
  end;
  
  TrainingPlanDClassTrainingStartEFAfter = res;
  return;
end;

global
function Boolean TrainingPlanDClassAfterEditField(Integer wn,string fieldname,Integer fn, Integer rownr,Integer changed)
begin
  Boolean res;

  switch (fieldname) begin
    case "Employee": res = TrainingPlanDClassEmployeeEFAfter(wn,changed!=0);
    case "Topic": res = TrainingPlanDClassTopicEFAfter(wn,changed!=0);
    case "Trainer": res = TrainingPlanDClassTrainerEFAfter(wn,changed!=0);
    case "Shadower": res = TrainingPlanDClassShadowerEFAfter(wn,changed!=0);
    case "Shadower2": res = TrainingPlanDClassShadower2EFAfter(wn,changed!=0);
    case "Shadower3": res = TrainingPlanDClassShadower3EFAfter(wn,changed!=0);
    case "TrainingStart": res = TrainingPlanDClassTrainingStartEFAfter(wn,changed!=0);
  end;
  TrainingPlanDClassAfterEditField = res;
  return;
end;

global
procedure EmployeeTrainingDsm()
begin
  record AT2UnitVc ATUnitr;
  record TrainingPlanVc TrainingPlanr;
  record RcVc RepSpec;
  Integer wn;

  wn = CurWindow;
  GetWindowRecord(wn,TrainingPlanr);
  RecordNew(RepSpec);
  RepSpec.repname = "EmployeeTrainingRn";
  RepSpec.f2 = TrainingPlanr.Topic;
  RepSpec.f3 = TrainingPlanr.Status;
  RepSpec.Media = mtScreen; 
  RepSpec.sStartDate = "01-01-1980";
  RepSpec.sEndDate = CurrentDate;
  RunReport(RepSpec,0);
  return;
end;