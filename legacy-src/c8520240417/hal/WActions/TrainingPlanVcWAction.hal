external function Time AddTime_Minutes(Time,Time);

function Boolean TrainingPlanDClassTopicEFAfter(Integer wn,Boolean changedf)
begin
  Boolean res;
  record TrainingPlanVc TrainingPlanr;
  record HRMSkillVc HRMSkillr;
  res = true;

  if (changedf) then begin
    GetWindowRecord(wn,TrainingPlanr);
    HRMSkillr.Code = TrainingPlanr.Topic;
    if (ReadFirstMain(HRMSkillr,1,true)) then begin
      TrainingPlanr.Description = HRMSkillr.Name;
    end;
    PutWindowRecord(wn,TrainingPlanr);
  end;
  TrainingPlanDClassTopicEFAfter = res;
  return;
end;

