global
updating procedure NPTSPaymentOneMode()
begin
  Integer wn,mwn,vwn;
  record RcVc RepSpec;
  record RcVc vRepSpec;
  record IVCashVc prevIVCr;
  record IVCashVc IVCr;
  row IVCashVc IVCrw;
  string 255 crncy,invcrncy,action;
  val fr,to1,to2,br1,br2,sum4;
  val totpaymentv,totcashv,cashwithdrawal;
  Array string 255 acrncy,alabel,apaymentmode;
  Array Integer apaymenttype;
  Array val apaymentv;
  Array string 255 apaymentchecknr;
  Array string 255 apaymentauthcode;
  Integer i,acrncnt,rwcnt;
  record LocalMachineBlock LMb;
  record RahaxiBlock Rb;
  vector val vpaymodeamounts;
  Boolean testf,closef,cashf;
  string 255 paymode,tstr,tag,transactionid,authorisation;
  Integer stp,selpmrow;
  LongInt pos;
  val received,rowsum;
  LongInt orgnr;
  record IVCashVc orgIVCr;
  row IVCashVc orgIVCrw;
  record BaseCurBlock BCb;
  
  wn = CurWindow;
  DeselectWindow(wn,true);
  mwn = MotherWindow(wn);
  if (mwn!=0) then begin
    BlockLoad(LMb);
    BlockLoad(BCb);
    GetWindowRecord(wn,RepSpec);
    tstr = PushButtonTag;
    pos = 0;
    GetNextSubstring(tstr,pos,",",paymode);
    GetNextSubstring(tstr,pos,",",tstr);
    stp = StringToInt(tstr);
    
    switch (GetWindowFileName(mwn)) begin
      case "IVCashVc":
        sum4 = IVCr.Sum4;
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,IVCr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVCr);
            if (prevIVCr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSPaymentOneModeTClass;
            end;
            if (prevIVCr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSPaymentOneModeTClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVCr);
            if (prevIVCr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSPaymentOneModeTClass;
            end;
            if (prevIVCr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSPaymentOneModeTClass;
            end;
        end;
        if (RequireOpenSession(IVCr.LocalMachineCode)) then begin
          if (IsSessionOpen(IVCr.LocalMachineCode,IVCr.DrawerCode,IVCr.TransDate,IVCr.TransTime)==false) then begin
            MessageBox(2195,"");
            goto LProceedNPTSPaymentOneModeTClass;
          end;
        end;
        if (IVCr.OKFlag!=0) then begin//omg ? 
          IVCr.OKFlag = 0;
        end;
        CntNPTSPaymentCurrenciesRemote(LMb.LocalMachineCode,alabel,acrncy,apaymenttype,apaymentmode,acrncnt);
        for (i=0;i<acrncnt;i=i+1) begin
          if (apaymenttype[i]==stp and apaymentmode[i]==paymode) then begin
            selpmrow = i;
            i = acrncnt;
          end;
        end;

        received = StringToVal(GetWindowString(wn,"NPTSPaymentTClassAmount"),M4Val);
        if (RepSpec.vals1>=0) then begin
          if (received<0) then begin
            MessageBox(24191,"");
            goto LProceedNPTSPaymentOneModeTClass;
          end;
        end else begin
          if (received>0) then begin
            MessageBox(24191,"");
            goto LProceedNPTSPaymentOneModeTClass;
          end;
        end;

        crncy = acrncy[selpmrow];
        GetFullCurncyRate(crncy,IVCr.InvDate,fr,to1,to2,br1,br2);

        invcrncy = IVCr.CurncyCode;
        if (blank(IVCr.CurncyCode)) then begin 
          invcrncy = BCb.BaseCur1;            
        end;

        CurValToOtherCurWithRate(IVCr.InvDate,crncy,received,fr,to1,to2,br1,br2,
                                 invcrncy,totpaymentv,DefaultCurRoundOff);    

        if (stp==kInvoiceRowTypeCashPayment) then begin
          totcashv = totpaymentv;
        end;


        rwcnt = MatRowCnt(IVCr);
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(IVCr,i,IVCrw);
          rowsum = IVCrw.Sum;
          if (IVCr.CurncyCode==IVCrw.CurncyCode) and (IVCr.CurncyCode!=BCb.BaseCur1) and (nonblank(IVCr.CurncyCode)) then begin
            CurValToOtherCurWithRate(IVCr.InvDate,IVCrw.CurncyCode,IVCrw.Sum,IVCrw.FrRate,IVCrw.ToRateB1,IVCrw.ToRateB2,IVCrw.BaseRate1,IVCrw.BaseRate2,
                                     IVCr.CurncyCode,rowsum,DefaultCurRoundOff);    
          end else begin
            rowsum = MulRateToBase1(IVCrw.CurncyCode,IVCrw.Sum,IVCrw.FrRate,IVCrw.ToRateB1,IVCrw.ToRateB2,IVCrw.BaseRate1,IVCrw.BaseRate2,DefaultCurRoundOff);
          end;
          switch (IVCrw.stp) begin
            case kInvoiceRowTypeCashPayment:
              vpaymodeamounts[IVCrw.PayMode] = vpaymodeamounts[IVCrw.PayMode] + rowsum; 
              totcashv = totcashv + rowsum;
              totpaymentv = totpaymentv + rowsum;
            case kInvoiceRowTypeCreditCardPayment:
              vpaymodeamounts[IVCrw.PayMode] = vpaymodeamounts[IVCrw.PayMode] + rowsum; 
              totpaymentv = totpaymentv + rowsum;
            case kInvoiceRowTypeCashWithdrawal:
              vpaymodeamounts[IVCrw.PayMode] = vpaymodeamounts[IVCrw.PayMode] + rowsum; 
              totpaymentv = totpaymentv + rowsum;
              cashwithdrawal = cashwithdrawal + rowsum;
            case kInvoiceRowTypeSwishPayment:
              vpaymodeamounts[IVCrw.PayMode] = vpaymodeamounts[IVCrw.PayMode] + rowsum; 
              totpaymentv = totpaymentv + rowsum;
            case kInvoiceRowTypeMPesaPayment:
              vpaymodeamounts[IVCrw.PayMode] = vpaymodeamounts[IVCrw.PayMode] + rowsum; 
              totpaymentv = totpaymentv + rowsum;
            case kInvoiceRowTypeQRPayment:
              vpaymodeamounts[IVCrw.PayMode] = vpaymodeamounts[IVCrw.PayMode] + rowsum; 
              totpaymentv = totpaymentv + rowsum;
            case kInvoiceRowTypeChequePayment:
              vpaymodeamounts[IVCrw.PayMode] = vpaymodeamounts[IVCrw.PayMode] + rowsum; 
              totpaymentv = totpaymentv + rowsum;
            case kInvoiceRowTypeGiftVoucherPayment:
              vpaymodeamounts[IVCrw.PayMode] = vpaymodeamounts[IVCrw.PayMode] + rowsum; 
              totpaymentv = totpaymentv + rowsum;
            otherwise
              if (IVCrw.stp==kInvoiceRowTypeReturnIVNr) then begin 
                orgnr = IVCrw.OrgIVNr;
              end;      
          end;
        end;
        

        if ((totpaymentv-totcashv)>IVCr.Sum4) then begin
          if (totpaymentv>totcashv) then begin
            if (UserCanAction("AllowCashWithdrawal",true)==false) then begin
              MessageBox(20878,"");
              WindowFieldGoto(wn,RepSpec,-1,"NPTSPaymentBLayoutReceived",true);
              goto LProceedNPTSPaymentOneModeTClass;
            end;
          end;
        end;
        if (IVCr.Sum4>0) then begin
          cashwithdrawal = totpaymentv - totcashv - IVCr.Sum4;
        end;
              
        if (received==0) then begin
          received = RepSpec.vals1 - totpaymentv;
          totpaymentv = totpaymentv + received;
//          closef = true; //no closing to get same workflow

          CurValToOtherCurWithRate(IVCr.InvDate,invcrncy,received,fr,to1,to2,br1,br2,
                                   crncy,received,DefaultCurRoundOff);    
//we want remaining balance to be calculated in base cur                                   
        end;
        if (received==0) then begin
          goto LProceedNPTSPaymentOneModeTClass;
        end;
        if (received<0) then begin
          orgIVCr.SerNr = orgnr;
          if (ReadFirstMain(orgIVCr,1,true)) then begin
            rwcnt = MatRowCnt(orgIVCr);
            for (i=0;i<rwcnt;i=i+1) begin
              MatRowGet(orgIVCr,i,orgIVCrw);
              if (orgIVCrw.stp==kInvoiceRowTypeCreditCardPayment or orgIVCrw.stp==kInvoiceRowTypeSwishPayment or orgIVCrw.stp==kInvoiceRowTypeMPesaPayment or orgIVCrw.stp==kInvoiceRowTypeQRPayment) then begin 
                transactionid = orgIVCrw.CCTransID;
                authorisation = orgIVCrw.AuthorizationCode;
                i = rwcnt;
              end;
              if (orgIVCrw.stp==kInvoiceRowTypeCashPayment) then begin 
                cashf = true;
                i = rwcnt;
              end;
            end;
          end;
          if (blank(transactionid) and cashf==false) then begin
            goto LProceedNPTSPaymentOneModeTClass;
          end;
        end;

/*        
        crncy = acrncy[selpmrow];


        if (GetFullCurncyPurchaseRate(crncy,IVCr.TransDate,fr,to1,to2,br1,br2)==false) then begin
          GetFullCurncyRate(crncy,IVCr.TransDate,fr,to1,to2,br1,br2);
        end;
*/        
        if (stp==kInvoiceRowTypeGiftVoucherPayment) then begin
          OpenGiftVoucherTouchScreenDClass(mwn,-1,IVCr.SerNr,-received,IVCr.Sum4-IVCr.TendValue,IVCr.CurncyCode,paymode,USetStr(24608));
          CloseWindow(wn);
          goto LProceedNPTSPaymentOneModeTClass;
        end;
        if (stp==kInvoiceRowTypeCreditCardPayment or stp==kInvoiceRowTypeQRPayment) then begin
          BlockLoad(Rb);
          switch (Rb.TerminalType) begin
            case kLocalCCTerminalIngenicoiCT220:
              vRepSpec.UsedOnly = kLocalCCTerminalIngenicoiCT220;
              vRepSpec.ArtMode = 1;
              vRepSpec.long1 = IVCr.SerNr;
              vRepSpec.AccStr = paymode;
              vRepSpec.f5 = alabel[selpmrow];
              vRepSpec.CurncyCode = crncy;
              vwn = OpenWindow("CCPayVerifoneProcessingWClass",0,wn,"","",vRepSpec);
              DeselectWindow(vwn,false);
              if (received<0) then begin
                IngenicoiCT220CreditCard_Purchase(IVCr.SerNr,IVCr.InvType,received,vRepSpec.AccStr,vRepSpec.f5,vwn);
              end else begin
                IngenicoiCT220CreditCard_Purchase(IVCr.SerNr,IVCr.InvType,received,vRepSpec.AccStr,vRepSpec.f5,vwn);
              end;
              goto LProceedNPTSPaymentOneModeTClass;
            case kLocalCCTerminalVerifoneBanksys:
              vRepSpec.UsedOnly = kLocalCCTerminalVerifoneBanksys;
              vRepSpec.ArtMode = 1;
              vRepSpec.long1 = IVCr.SerNr;
              vRepSpec.AccStr = paymode;
              vRepSpec.f5 = alabel[selpmrow];
              vRepSpec.CurncyCode = crncy;
              vwn = OpenWindow("CCPayVerifoneProcessingWClass",0,wn,"","",vRepSpec);
              DeselectWindow(vwn,false);
              if (received<0) then begin
                VerifoneBanksys_Void(received,paymode,alabel[selpmrow],transactionid,"",vwn);
              end else begin
                VerifoneBanksys_Purchase(received,paymode,alabel[selpmrow],vwn);
              end;
              goto LProceedNPTSPaymentOneModeTClass;
            case kLocalCCTerminalWorldPay:
              vRepSpec.UsedOnly = kLocalCCTerminalWorldPay;
              vRepSpec.ArtMode = 1;
              vRepSpec.long1 = IVCr.SerNr;
              vRepSpec.AccStr = paymode;
              vRepSpec.f5 = alabel[selpmrow];
              vRepSpec.CurncyCode = crncy;
              vwn = OpenWindow("CCPayVerifoneProcessingWClass",0,wn,"","",vRepSpec);
              DeselectWindow(vwn,false);
              if (received<0) then begin
                WorldPayCreditCard_Purchase(IVCr.SerNr,IVCr.InvType,received,vRepSpec.AccStr,vRepSpec.f5,vwn);
              end else begin
                WorldPayCreditCard_Purchase(IVCr.SerNr,IVCr.InvType,received,vRepSpec.AccStr,vRepSpec.f5,vwn);
              end;
              goto LProceedNPTSPaymentOneModeTClass;
            case kLocalCCTerminalSmartPay:
              vRepSpec.UsedOnly = kLocalCCTerminalSmartPay;
              vRepSpec.ArtMode = 1;
              vRepSpec.long1 = IVCr.SerNr;
              vRepSpec.AccStr = paymode;
              vRepSpec.f5 = alabel[selpmrow];
              vRepSpec.CurncyCode = crncy;
              vRepSpec.OKmode = 0;
              if (received<0) then begin
                vRepSpec.OKmode = -1;
              end;
              vRepSpec.FirstVer = stp;
              vwn = OpenWindow("CCPayVerifoneProcessingWClass",0,wn,"","",vRepSpec);
              DeselectWindow(vwn,false);
              switch (stp) begin
                case kInvoiceRowTypeQRPayment:
                  action = "QRPayment";
                case kInvoiceRowTypeCreditCardPayment:
                  action = "CCPayment";
                otherwise
                  action = "CCPayment";
              end;

              if (received<0) then begin
                SmartPayCreditCard_Purchase(Rb.RahaxiServerIP,Rb.RahaxiServerPort,IVCr.SerNr,IVCr.InvType,received,0,vRepSpec.AccStr,vRepSpec.f5,action,authorisation,vwn);
              end else begin
                SmartPayCreditCard_Purchase(Rb.RahaxiServerIP,Rb.RahaxiServerPort,IVCr.SerNr,IVCr.InvType,received,cashwithdrawal,vRepSpec.AccStr,vRepSpec.f5,action,"",vwn);
              end;
              goto LProceedNPTSPaymentOneModeTClass;
            case kLocalCCTerminalWorldlineToM:
              vRepSpec.UsedOnly = kLocalCCTerminalWorldlineToM;
              vRepSpec.ArtMode = 1;
              vRepSpec.long1 = IVCr.SerNr;
              vRepSpec.AccStr = paymode;
              vRepSpec.f5 = alabel[selpmrow];
              vRepSpec.CurncyCode = crncy;
              vwn = OpenWindow("CCPayVerifoneProcessingWClass",0,wn,"","",vRepSpec);
              DeselectWindow(vwn,false);
              if (received<0) then begin
                // VerifoneBanksys_Void(received,paymode,alabel[selpmrow],transactionid,"",vwn);
              end else begin
                WorldlineToMCreditCard_Purchase(IVCr.SerNr,crncy,received,vwn);
              end;
              goto LProceedNPTSPaymentOneModeTClass;
          end;


        end;
        ClearRow(IVCr,IVCrw,stp);
        IVCrw.stp = stp;
        IVCrw.Spec = alabel[selpmrow];
        IVCrw.Sum = received;
        IVCrw.PayMode = paymode;
        IVCrw.CurncyCode = crncy;
        IVCrw.FrRate = fr;
        IVCrw.ToRateB1 = to1;
        IVCrw.ToRateB2 = to2;
        IVCrw.BaseRate1 = br1;
        IVCrw.BaseRate2 = br2;  
        IVCrw.AuthorizationCode = GetWindowString(wn,"NPTSPaymentBLayoutAuthorizationCode");
        MatRowPut(IVCr,MatRowCnt(IVCr),IVCrw);

        PutWindowRecord(mwn,IVCr);
   end;
    if (WindowDoOK(mwn,0)) then begin
      DeselectWindow(wn,false);
      GetWindowRecord(wn,RepSpec);
      switch (GetWindowFileName(mwn)) begin
        case "IVCashVc":
          GetWindowRecord(mwn,IVCr);
          SetPOSWindowDisplay_PaymentRow(IVCrw.Spec,IVCr.RetValue);
          IVCashDClass_RefreshStringList(mwn,IVCr);
//          OpenCashDrawer_IVCashVc(IVCr);//only when OKING 
          PutWindowString(wn,"NPTSPaymentTClassAmount","");
          RepSpec.vals1 = IVCr.Sum4;
          RepSpec.vals1 = RepSpec.vals1 - totpaymentv;
          if (RepSpec.vals1<0) then begin RepSpec.vals1 = 0; end;
          RepSpec.vals2 = RepSpec.vals1;
          PutWindowString(wn,"NPTSPaymentTClassTotalDue",RepSpec.vals2);
          RepSpec.vals0 = totpaymentv - IVCr.Sum4;

          if (RepSpec.vals0<0) then begin
            RepSpec.vals0 = 0;
          end;

          PutWindowString(wn,"NPTSPaymentTClassBase1ChangeAmount",RepSpec.vals0);
          OpenCashDrawer;
          WindowFieldGotoForTouchScreen(wn,-1,"NPTSPaymentTClassAmount",true);
          if (RepSpec.vals0<=0) then begin
            CloseWindow(wn);
            if (IVCashPOSButtonAutoFinish(mwn)==kPOSButtonAutoFinishYes) then begin
              IVCashDClassTouchScreenFinishButton;
            end;
          end;
      end;
    end else begin
      closef = true;
//?      SelectHWStoreWClass;
    end;
  end;
  if (closef) then begin
    CloseWindow(wn);
  end;
LProceedNPTSPaymentOneModeTClass:;  
  return;
end;

