global
procedure ProceedSVOPasteNPTSSClass()
begin
  Integer mwn,nwn,wn;
  record RcVc RepSpec;
  record IVCashVc IVCashr,prevIVCashr;
  record SVOVc SVOr;

  wn = CurWindow;
  DeselectWindow(wn,true);
  mwn = MotherWindow(wn);
  if (mwn!=0) then begin
    GetWindowRecord(wn,RepSpec);
    if (blank(RepSpec.f1)) then begin
      goto LProceedSVOPasteNPTSSClass;
    end;
    switch (GetWindowFileName(mwn)) begin
      case "IVCashVc":
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,IVCashr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedSVOPasteNPTSSClass;
            end;
            if (prevIVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedSVOPasteNPTSSClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedSVOPasteNPTSSClass;
            end;
            if (IVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedSVOPasteNPTSSClass;
            end;
        end;
        SVOPasteNPTSSClassRemote(RepSpec.f1,IVCashr);
        IVCashr.SubLedgerFlag = 1;
        PutWindowRecord(mwn,IVCashr);
        WindowFieldGotoForTouchScreen(mwn,-1,"ivcashcommand",true);
        CloseWindow(wn);
        IVCashDClass_RefreshStringList(mwn,IVCashr);
        ExsecutePOSAfterFunction(mwn,kPOSButtonTypePasteServiceOrder,GetWindowString(wn,"page"));
    end;
  end;
LProceedSVOPasteNPTSSClass:;  
  return;
end;

global
updating procedure ProceedSHPasteNPTSSClass()
begin
  Integer mwn,nwn,wn;
  record RcVc RepSpec;
  record IVCashVc IVCashr,prevIVCashr;
  record SHVc SHr;
  record ORVc ORr;

  wn = CurWindow;
  DeselectWindow(wn,true);
  mwn = MotherWindow(wn);
  if (mwn!=0) then begin
    GetWindowRecord(wn,RepSpec);
    if (blank(RepSpec.f1)) then begin
      goto LProceedSHPasteNPTSSClass;
    end;
    switch (GetWindowFileName(mwn)) begin
      case "IVCashVc":
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,IVCashr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedSHPasteNPTSSClass;
            end;
            if (prevIVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedSHPasteNPTSSClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedSHPasteNPTSSClass;
            end;
            if (IVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedSHPasteNPTSSClass;
            end;
        end;
        SHPasteNPTSSClassRemote(RepSpec.f1,IVCashr);
        IVCashr.SubLedgerFlag = 1;
        SHr.SerNr = IVCashr.OrderNr;
        if (ReadFirstMain(SHr,1,true)) then begin
          PutWindowRecord(mwn,IVCashr);
          IVCashDClass_RefreshStringList(mwn,IVCashr);
          WindowFieldGotoForTouchScreen(mwn,-1,"ivcashcommand",true);
          if (RecordInsert(IVCashr,false)) then begin
            ORr.SerNr = SHr.OrderNr;
            if (ReadFirstMain(ORr,1,true)) then begin
              CreateRecordLink(IVCashr,CurrentCompany,ORr,CurrentCompany);
              CreateRecordLink(ORr,CurrentCompany,IVCashr,CurrentCompany);
            end;
            CreateRecordLink(IVCashr,CurrentCompany,SHr,CurrentCompany);
            CreateRecordLink(SHr,CurrentCompany,IVCashr,CurrentCompany);
          end;
        end;
        CloseWindow(wn);
        SetWindowState(mwn,Rs_Normal)
        ExsecutePOSAfterFunction(mwn,kPOSButtonTypePasteSalesOrder,GetWindowString(wn,"page"));
    end;
  end;
LProceedSHPasteNPTSSClass:;  
  return;
end;

updating procedure ProceedHotelResPasteNPTSSClassExecute(Integer wn)
begin
  Integer mwn,nwn;
  record RcVc RepSpec;
  record IVCashVc IVCashr,prevIVCashr;
  record JobVc Jobr;

  DeselectWindow(wn,true);
  mwn = MotherWindow(wn);
  if (mwn!=0) then begin
    GetWindowRecord(wn,RepSpec);
    if (blank(RepSpec.f1)) then begin
      goto LProceedHotelResPasteNPTSSClassExecute;
    end;
    switch (GetWindowFileName(mwn)) begin
      case "IVCashVc":
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,IVCashr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedHotelResPasteNPTSSClassExecute;
            end;
            if (prevIVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedHotelResPasteNPTSSClassExecute;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedHotelResPasteNPTSSClassExecute;
            end;
            if (IVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedHotelResPasteNPTSSClassExecute;
            end;
        end;
        //Jobr.SerNr = IVCashr.OrderNr;
        PutWindowRecord(mwn,IVCashr);
        GetWindowRecord(mwn,IVCashr);
        ReRunWindowDef(mwn);
        IVCashDClass_RefreshStringList(mwn,IVCashr);
        WindowFieldGotoForTouchScreen(mwn,-1,"ivcashcommand",true);
        if (RecordStore(IVCashr,true) and ReadFirstMain(Jobr,1,true)) then begin
          CreateRecordLink(IVCashr,CurrentCompany,Jobr,CurrentCompany);
          CreateRecordLink(Jobr,CurrentCompany,IVCashr,CurrentCompany);
          UpdateBrowses("JobVc");
        end;
        CloseWindow(wn);
        // CloseWindow(mwn);
        // nwn = OpenWindow("NPTSIVCashDClass",1,0,"","",IVCashr);
        ExsecutePOSAfterFunction(mwn,kPOSButtonTypePasteHotelReservation,GetWindowString(wn,"page"));
    end;
  end;
LProceedHotelResPasteNPTSSClassExecute:;
  return;
end;

global
updating procedure ProceedHotelResPasteNPTSSClass()
begin
  ProceedHotelResPasteNPTSSClassExecute(CurWindow);
  return;
end;

global
procedure IVCashDClassTouchScreenPasteHotelRes()
begin
  Integer wn,mwn;
  record RcVc RepSpec;
  record IVCashVc IVCashr;
  string 255 tstr;
  Boolean testf;
  
  mwn = CurWindow;
  RecordClear(RepSpec);
  GetWindowRecord(mwn,IVCashr);
  if (UserCanAction("PasteHotelResPOS",true)) then begin
    testf = true;
    if (IVCashr.OKFlag!=0) then begin testf = false; end;
    if (IVCashr.Invalid!=0) then begin testf = false; end;
    if (testf) then begin
      wn = OpenWindow("HotelResPasteNPTSSClass",0,mwn,"","",RepSpec);
      PutWindowString(wn,"page",GetWindowString(mwn,"touchscreenwindowpage"));
      WindowFieldGoto(wn,RepSpec,-1,"f1",false);
    end;
  end else begin
    MessageBox(1274,StringFromStringSet(3,"PasteORPOS"));
  end;
  return;
end;

global
procedure IVCashLClassCounterSalesToggle()
begin
  Integer wn;
  
  wn = CurWindow;
  if (wn>0) then begin
    if (GetWindowSubset(wn)=="1") then begin
      SetWindowSubset(wn,"");
      PutWindowString(wn,"IVCashLClassAllPOSFlag","true");
    end else begin
      SetWindowSubset(wn,"1");
      PutWindowString(wn,"IVCashLClassAllPOSFlag","false");
    end;
  end;
  UpdateBrowses("IVCashLClass");
  ReRunWindowDef(wn);
  return;
end;

global
procedure ReverseMPesaPayTouchScreenOClass()
begin
  record CCMerchantIDVc CCMerchantIDr;
  record LocalMachineBlock LMb;
  record CCAccountIDVc CCAccountIDr;
  record RcVc RepSpec;
  Integer wn;

  wn = CurWindow;
  DeselectWindow(wn,true);
  BlockLoad(LMb);
  GetWindowRecord(wn,RepSpec);
  FindCCAccountID(RepSpec.CurncyCode,LMb.LocalMachineCode,kCCAccountTypePOS,CCAccountIDr,kCardHolderAny);
  CCMerchantIDr.Code = CCAccountIDr.MerchantID;
  ReadFirstMain(CCMerchantIDr,1,true);
  if (CCMerchantIDr.Partner==kCCPartnerMPesa) then begin
    Bambora_Cancel_Request(wn);
  end;
  CloseWindow(wn);
  return;
end;

global
updating procedure ProceedEnterSalesmanNPTSRowOClass()
begin
  Integer wn,mwn,nwn,rownr;
  record RcVc RepSpec;
  record IVCashVc IVCashr;
  row IVCashVc IVCashrw;
  record IVCashVc prevIVCashr;
  record RestAccVc RestAccr;
  record RestAccVc prevRestAccr;
  row RestAccVc RestAccrw;
  record IVVc IVr;
  row IVVc IVrw;
  record IVVc prevIVr;
  record UserVc Userr;
  string 255 tstr;
  record RestBlock Rb;

  if (UserCanAction("AllowSalesmanChangeOnPOS",false)==false) then begin
    MessageBox(1274,StringFromStringSet(3,"AllowSalesmanChangeOnPOS"));
    goto LProceedEnterSalesmanNPTSRowOClass;
  end;
  
  wn = CurWindow;
  DeselectWindow(wn,true);
  mwn = MotherWindow(wn);
  if (mwn!=0) then begin
    GetWindowRecord(wn,RepSpec);
    rownr = RepSpec.long1;
    if (rownr==-1) then begin 
      goto LProceedEnterSalesmanNPTSRowOClass;
    end;
    DeselectWindow(mwn,false);
    switch (GetWindowFileName(mwn)) begin
      case "IVCashVc":
        GetWindowRecord(mwn,IVCashr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedEnterSalesmanNPTSRowOClass;
            end;
            if (prevIVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedEnterSalesmanNPTSRowOClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedEnterSalesmanNPTSRowOClass;
            end;
            if (prevIVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedEnterSalesmanNPTSRowOClass;
            end;
        end;
        Userr.Code = RepSpec.f1;    
        if (ReadFirstMain(Userr,1,true)==false) then begin
          MessageBox(20170,": " & RepSpec.f1);
          goto LProceedEnterSalesmanNPTSRowOClass;
        end;
        MatRowGet(IVCashr,rownr,IVCashrw);
        IVCashrw.Salesmen = RepSpec.f1;
        MatRowPut(IVCashr,rownr,IVCashrw);
        PutWindowRecord(mwn,IVCashr);
      case "IVVc":
        GetWindowRecord(mwn,IVr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVr);
            if (prevIVr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedEnterSalesmanNPTSRowOClass;
            end;
            if (prevIVr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedEnterSalesmanNPTSRowOClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVr);
            if (prevIVr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedEnterSalesmanNPTSRowOClass;
            end;
            if (prevIVr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedEnterSalesmanNPTSRowOClass;
            end;
        end;
        Userr.Code = RepSpec.f1;    
        if (ReadFirstMain(Userr,1,true)==false) then begin
          MessageBox(20170,": " & RepSpec.f1);
          goto LProceedEnterSalesmanNPTSRowOClass;
        end;
        MatRowGet(IVr,rownr,IVrw);
        IVrw.Salesmen = RepSpec.f1;
        MatRowPut(IVr,rownr,IVrw);
        PutWindowRecord(mwn,IVr);
      case "RestAccVc":
        BlockLoad(Rb);
        GetWindowRecord(mwn,RestAccr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevRestAccr);
            if (prevRestAccr.Closed!=0) then begin
              CloseWindow(wn);
              goto LProceedEnterSalesmanNPTSRowOClass;
            end;
            if (prevRestAccr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedEnterSalesmanNPTSRowOClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevRestAccr);
            if (prevRestAccr.Closed!=0) then begin
              CloseWindow(wn);
              goto LProceedEnterSalesmanNPTSRowOClass;
            end;
            if (prevRestAccr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedEnterSalesmanNPTSRowOClass;
            end;
        end;
        Userr.Code = RepSpec.f1;    
        if (ReadFirstMain(Userr,1,true)==false) then begin
          MessageBox(20170,": " & RepSpec.f1);
          goto LProceedEnterSalesmanNPTSRowOClass;
        end;
        MatRowGet(RestAccr,rownr,RestAccrw);
        RestAccrw.SalesAssistant = RepSpec.f1;
        MatRowPut(RestAccr,rownr,RestAccrw);
        PutWindowRecord(mwn,RestAccr);
    end;
  end;
  if (WindowDoOK(mwn,0)) then begin
    DeselectWindow(wn,false);
    GetWindowRecord(wn,RepSpec);
    CloseWindow(wn);
    ReRunWindowDef(mwn);
    if (Rb.StepsSequence) then begin
      nwn = OpenWindow("SetTableTouchScreenOClass",0,mwn,"","",RepSpec);
    end;
  end else begin
    CloseWindow(wn);
  end;
LProceedEnterSalesmanNPTSRowOClass:;
  return;
end;

