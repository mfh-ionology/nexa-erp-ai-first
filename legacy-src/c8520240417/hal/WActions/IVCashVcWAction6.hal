global
updating procedure ConfirmedMPesaPayTouchScreenOClass()
begin
  Integer wn,mwn;
  record RcVc RepSpec;
  record IVCashVc prevIVCashr;
  record IVCashVc IVCashr;
  row IVCashVc IVCashrw;
  Array string 255 acrncy;
  Array Boolean achangecrncyf;
  Integer i,acrncnt;
  string 255 crncy;
  val fr,to1,to2,br1,br2,sum4;
  record RestAccVc prevRestAccr;
  record RestAccVc RestAccr;
  row RestAccVc RestAccrw;
  record IVVc prevIVr;
  record IVVc IVr;
  row IVVc IVrw;

  wn = CurWindow;
  DeselectWindow(wn,true);
  mwn = MotherWindow(wn);
  if (mwn!=0) then begin
    GetWindowRecord(wn,RepSpec);
    switch (GetWindowFileName(mwn)) begin
      case "IVCashVc":
        sum4 = IVCashr.Sum4;
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,IVCashr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LConfirmedMPesaPayTouchScreenOClass;
            end;
            if (prevIVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LConfirmedMPesaPayTouchScreenOClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LConfirmedMPesaPayTouchScreenOClass;
            end;
            if (prevIVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LConfirmedMPesaPayTouchScreenOClass;
            end;
        end;
        if (MpesaConfirmTransaction(RepSpec.f3,IVCashr.SerNr)==false) then begin
          goto LConfirmedMPesaPayTouchScreenOClass;
        end;
        if (IVCashr.OKFlag!=0) then begin
          IVCashr.OKFlag = 0;
        end;
        CntPOSCurrencies(acrncy,achangecrncyf,acrncnt);
        for (i=0;i<acrncnt;i=i+1) begin
        
          ClearRow(IVCashr,IVCashrw,kInvoiceRowTypeMPesaPayment);
          IVCashrw.Sum = RepSpec.vals0;
          if (IVCashrw.Sum!=0) then begin
            crncy = "";
            if (HasMultiCurrency) then begin
              crncy = RepSpec.CurncyCode;
            end;
            IVCashrw.PayMode = RepSpec.AccStr;
            IVCashrw.Spec = RepSpec.f6;
            if (HasMultiCurrency) then begin
              if (GetFullCurncyPurchaseRate(crncy,CurrentDate,fr,to1,to2,br1,br2)==false) then begin
                GetFullCurncyRate(crncy,CurrentDate,fr,to1,to2,br1,br2);
              end;
            end;
            IVCashrw.CurncyCode = crncy;
            IVCashrw.FrRate = fr;
            IVCashrw.ToRateB1 = to1;
            IVCashrw.ToRateB2 = to2;
            IVCashrw.BaseRate1 = br1;
            IVCashrw.BaseRate2 = br2;
            MatRowPut(IVCashr,MatRowCnt(IVCashr),IVCashrw);
            POSAudit_LogIVCashVcRow(IVCashr,IVCashrw,kPOSEventTypeAddRow);
          end;
        end;
        IVCashSumup(IVCashr,true);
        PutWindowRecord(mwn,IVCashr);
        WindowFieldGotoForTouchScreen(mwn,-1,"ivcashcommand",true);
      case "RestAccVc":
    end;
    if (WindowDoOK(mwn,0)) then begin
      DeselectWindow(wn,false);
      GetWindowRecord(wn,RepSpec);
      CloseWindow(wn);
      switch (GetWindowFileName(mwn)) begin
        case "IVCashVc":
          GetWindowRecord(mwn,IVCashr);
          IVCashDClass_RefreshStringList(mwn,IVCashr);
          SetPOSWindowDisplay_PaymentRow(IVCashrw.Spec,IVCashr.RetValue);
          OpenCashDrawer_IVCashVc(IVCashr);
          if (IVCashr.RetValue==0) then begin
            if (IVCashPOSButtonAutoFinish(mwn)==kPOSButtonAutoFinishYes) then begin
              IVCashDClassTouchScreenFinishButton;
            end;
          end;
        case "RestAccVc":     
      end;
    end else begin
      CloseWindow(wn);
      SelectHWStoreWClass;
    end;
  end;
LConfirmedMPesaPayTouchScreenOClass:;  
  WindowFieldGotoForTouchScreen(mwn,-1,"ivcashcommand",true); 
  return;
end;

global
updating procedure ProceedSwishPayTouchScreenOClass()
begin
  Integer wn,mwn,nwn;
  record RcVc RepSpec;
  record IVCashVc orgIVCr;
  record IVCashVc prevIVCr;
  record IVCashVc IVCr;
  row IVCashVc IVCrw;
  val from,to1,to2,base1,base2;
  string 255 crncy,transid,cardnumber;
  record RestAccVc prevRestAccr;
  record RestAccVc RestAccr;
  row RestAccVc RestAccrw;
  record LocalMachineBlock LMb;
  Integer wnst,txtype;
  record CCAccountIDVc CCAccountIDr;  
  record CCMerchantIDVc CCMerchantIDr;  
  Date blankd;
  integer i,rwcnt,cardholdertype;

  wn = CurWindow;
  DeselectWindow(wn,true);
  mwn = MotherWindow(wn);
  if (mwn!=0) then begin
    GetWindowRecord(wn,RepSpec);
    switch (GetWindowFileName(mwn)) begin
      case "IVCashVc":
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,IVCr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVCr);
            if (prevIVCr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedSwishPayTouchScreenOClass;
            end;
            if (prevIVCr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedSwishPayTouchScreenOClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVCr);
            if (prevIVCr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedSwishPayTouchScreenOClass;
            end;
            if (IVCr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedSwishPayTouchScreenOClass;
            end;
        end;
        BlockLoad(LMb);
        if (AbsoluteVal(IVCr.Sum4)<AbsoluteVal(RepSpec.vals0)) then begin
          CloseWindow(wn);
          MessageBox(20878,"");
          WindowFieldGoto(wn,IVCr,-1,"vals0",true);
          goto LProceedSwishPayTouchScreenOClass;
        end;
        if (blank(RepSpec.f1)) then begin
          MessageBox(1058,"");
          WindowFieldGoto(wn,RepSpec,-1,"f1",true);
          goto LProceedSwishPayTouchScreenOClass;
        end;
//        if (IVCr.OKFlag!=0) then begin
//          IVCr.OKFlag = 0;
//        end;
        txtype = kCardTransactionPay;
//        FindPaymentGateway("","",kCCAccountTypePOS,CCAccountIDr,kCardHolderAny,kCCPartnerSwish);
        FindPaymentGateway(RepSpec.CurncyCode,LMb.LocalMachineCode,kCCAccountTypePOS,CCAccountIDr,kCardHolderAny,kCCPartnerSwish);
        CCMerchantIDr.Code = CCAccountIDr.MerchantID;
        ReadFirstMain(CCMerchantIDr,1,true);
        if (CCMerchantIDr.Partner==kCCPartnerSwish) then begin
          if (blank(CCAccountIDr.URL)) then begin
            MessageBox(41800,"");
            WindowFieldGoto(wn,RepSpec,-1,"f1",true);
            goto LProceedSwishPayTouchScreenOClass;
          end;
          if (blank(CCAccountIDr.Certificate)) then begin
            MessageBox(41801,"");
            WindowFieldGoto(wn,RepSpec,-1,"f1",true);
            goto LProceedSwishPayTouchScreenOClass;
          end;
          if (blank(CCAccountIDr.PrivateKey)) then begin
            MessageBox(41802,"");
            WindowFieldGoto(wn,RepSpec,-1,"f1",true);
            goto LProceedSwishPayTouchScreenOClass;
          end;
          if (blank(CCAccountIDr.PrivateKeyPsswd)) then begin
            MessageBox(41803,"");
            WindowFieldGoto(wn,RepSpec,-1,"f1",true);
            goto LProceedSwishPayTouchScreenOClass;
          end;
          if (RepSpec.vals0<0) then begin
            txtype = kCardTransactionRefund;
            rwcnt = MatRowCnt(IVCr);
            for (i=0;i<rwcnt;i=i+1) begin
              MatRowGet(IVCr,i,IVCrw);
              if (IVCrw.stp==kInvoiceRowTypeReturnIVNr) then begin
                i = rwcnt;
              end;
            end;
            orgIVCr.SerNr = IVCrw.OrgIVNr;
            if (ReadFirstMain(orgIVCr,1,true)) then begin
              rwcnt = MatRowCnt(orgIVCr);
              for (i=0;i<rwcnt;i=i+1) begin
                MatRowGet(orgIVCr,i,IVCrw);
                if (IVCrw.stp==kInvoiceRowTypeCreditCardPayment) then begin
                  transid = IVCrw.CCTransID;
                  i = rwcnt;
                end;
              end;
            end;
          end;            
          ProceedSwishPayTouchScreenRemote(RepSpec,CCAccountIDr,IVCr,txtype,transid);
          
          goto LProceedSwishPayTouchScreenOClass;
        end;              
    /*
        ClearRow(IVCr,IVCrw,kInvoiceRowTypeCreditCardPayment);
        IVCrw.stp = kInvoiceRowTypeCreditCardPayment;
        IVCrw.Sum = RepSpec.vals0;
        IVCrw.PayMode = RepSpec.AccStr;
        IVCrw.Spec = RepSpec.f6;
        IVCrw.AuthorizationCode = RepSpec.f1;
        crncy = RepSpec.CurncyCode;
        GetFullCurncyRate(crncy,IVCr.TransDate,from,to1,to2,base1,base2);
        IVCrw.CurncyCode = crncy;
        IVCrw.FrRate = from;
        IVCrw.ToRateB1 = to1;
        IVCrw.ToRateB2 = to2;
        IVCrw.BaseRate1 = base1;
        IVCrw.BaseRate2 = base2;  
        MatRowPut(IVCr,MatRowCnt(IVCr),IVCrw);
        POSAudit_LogIVCashVcRow(IVCr,IVCrw,kPOSEventTypeAddRow);
        IVCashSumup(IVCr,true);
        PutWindowRecord(mwn,IVCr);
        WindowFieldGoto(mwn,IVCr,-1,"touchscreenitem",true);
        IVCashDClass_RefreshStringList(mwn,IVCr);
*/        
      case "RestAccVc":
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,RestAccr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevRestAccr);
            if (prevRestAccr.Closed!=0) then begin
              CloseWindow(wn);
              goto LProceedSwishPayTouchScreenOClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevRestAccr);
            if (prevRestAccr.Closed!=0) then begin
              CloseWindow(wn);
              goto LProceedSwishPayTouchScreenOClass;
            end;
        end;
        if (RestAccr.Sum4<RepSpec.vals0) then begin
          CloseWindow(wn);
          MessageBox(20878,"");
          WindowFieldGoto(wn,RestAccr,-1,"vals0",true);
          goto LProceedSwishPayTouchScreenOClass;
        end;
/*        
        ClearRow(RestAccr,RestAccrw,kInvoiceRowTypeCreditCardPayment);
        RestAccrw.stp = kInvoiceRowTypeCreditCardPayment;
        RestAccrw.Sum = RepSpec.vals0;
        RestAccrw.PayMode = RepSpec.AccStr;
        RestAccrw.Spec = RepSpec.f6;
        RestAccrw.AuthorizationCode = RepSpec.f1;
        crncy = RepSpec.CurncyCode;
        GetFullCurncyRate(crncy,RestAccr.TransDate,from,to1,to2,base1,base2);
        RestAccrw.CurncyCode = crncy;
        RestAccrw.FrRate = from;
        RestAccrw.ToRateB1 = to1;
        RestAccrw.ToRateB2 = to2;
        RestAccrw.BaseRate1 = base1;
        RestAccrw.BaseRate2 = base2;  
        MatRowPut(RestAccr,MatRowCnt(RestAccr),RestAccrw);
        RestAccSumup(RestAccr,"");
        PutWindowRecord(mwn,RestAccr);
        RestAccDClass_RefreshStringList(mwn,RestAccr);
*/        
    end;
/*    
    if (WindowDoOK(mwn,0)) then begin
      DeselectWindow(wn,false);
      GetWindowRecord(wn,RepSpec);
      CloseWindow(wn);
      switch (GetWindowFileName(mwn)) begin
        case "IVCashVc":
          GetWindowRecord(mwn,IVCr);
          IVCashDClass_RefreshStringList(mwn,IVCr);
          SetPOSWindowDisplay_PaymentRow(IVCrw.Spec,IVCr.RetValue);
          OpenCashDrawer_IVCashVc(IVCr);
        case "RestAccVc":
          GetWindowRecord(mwn,RestAccr);
          RestAccDClass_RefreshStringList(mwn,RestAccr);
          SetPOSWindowDisplayAmount(USetStr(27350),RestAccr.Sum4-RestAccr.TendValue);
          OpenCashDrawer;
      end;
    end else begin
      CloseWindow(wn);
      SelectHWStoreWClass;
    end;
*/    
  end;
LProceedSwishPayTouchScreenOClass:;  
  return;
end;

global
updating procedure ProceedMPesaPayTouchScreenOClass()
begin
  Integer wn,mwn,nwn;
  record RcVc RepSpec;
  record IVCashVc orgIVCr;
  record IVCashVc prevIVCr;
  record IVCashVc IVCr;
  row IVCashVc IVCrw;
  val from,to1,to2,base1,base2;
  string 255 crncy,transid,cardnumber,message;
  record RestAccVc prevRestAccr;
  record RestAccVc RestAccr;
  row RestAccVc RestAccrw;
  record LocalMachineBlock LMb;
  Integer wnst,txtype;
  record CCAccountIDVc CCAccountIDr;  
  record CCMerchantIDVc CCMerchantIDr;  
  Date blankd;
  integer i,rwcnt,cardholdertype;

  wn = CurWindow;
  DeselectWindow(wn,true);
  mwn = MotherWindow(wn);
  if (mwn!=0) then begin
    GetWindowRecord(wn,RepSpec);
    switch (GetWindowFileName(mwn)) begin
      case "IVCashVc":
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,IVCr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVCr);
            if (prevIVCr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedMPesaPayTouchScreenOClass;
            end;
            if (prevIVCr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedMPesaPayTouchScreenOClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVCr);
            if (prevIVCr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedMPesaPayTouchScreenOClass;
            end;
            if (IVCr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedMPesaPayTouchScreenOClass;
            end;
        end;
        BlockLoad(LMb);
        if (AbsoluteVal(IVCr.Sum4)<AbsoluteVal(RepSpec.vals0)) then begin
          CloseWindow(wn);
          MessageBox(20878,"");
          WindowFieldGoto(wn,IVCr,-1,"vals0",true);
          goto LProceedMPesaPayTouchScreenOClass;
        end;
        if (blank(RepSpec.f1)) then begin
          MessageBox(1058,"");
          WindowFieldGoto(wn,RepSpec,-1,"f1",true);
          goto LProceedMPesaPayTouchScreenOClass;
        end;
        if (blank(RepSpec.f2) and blank(RepSpec.f3)) then begin
          MessageBox(1058,"");
          WindowFieldGoto(wn,RepSpec,-1,"f2",true);
          goto LProceedMPesaPayTouchScreenOClass;
        end;
        txtype = kCardTransactionPay;
        FindPaymentGateway(RepSpec.CurncyCode,LMb.LocalMachineCode,kCCAccountTypePOS,CCAccountIDr,kCardHolderAny,kCCPartnerMPesa);
        CCMerchantIDr.Code = CCAccountIDr.MerchantID;
        ReadFirstMain(CCMerchantIDr,1,true);
        if (CCMerchantIDr.Partner==kCCPartnerMPesa) then begin
          if (blank(CCAccountIDr.URL)) then begin
            MessageBox(41800,"");
            WindowFieldGoto(wn,RepSpec,-1,"f1",true);
            goto LProceedMPesaPayTouchScreenOClass;
          end;
          if (blank(CCAccountIDr.MPesaPhone)) then begin
            MessageBox(41811,"");
            WindowFieldGoto(wn,RepSpec,-1,"f1",true);
            goto LProceedMPesaPayTouchScreenOClass;
          end;
          if (blank(CCAccountIDr.MPesaConsKey)) then begin
            MessageBox(41812,"");
            WindowFieldGoto(wn,RepSpec,-1,"f1",true);
            goto LProceedMPesaPayTouchScreenOClass;
          end;
          if (blank(CCAccountIDr.MPesaConsSecret)) then begin
            MessageBox(41813,"");
            WindowFieldGoto(wn,RepSpec,-1,"f1",true);
            goto LProceedMPesaPayTouchScreenOClass;
          end;
          if (blank(CCAccountIDr.MPesaUsername)) then begin
            MessageBox(41814,"");
            WindowFieldGoto(wn,RepSpec,-1,"f1",true);
            goto LProceedMPesaPayTouchScreenOClass;
          end;
          if (RepSpec.vals0<0) then begin
            txtype = kCardTransactionRefund;
            rwcnt = MatRowCnt(IVCr);
            for (i=0;i<rwcnt;i=i+1) begin
              MatRowGet(IVCr,i,IVCrw);
              if (IVCrw.stp==kInvoiceRowTypeReturnIVNr) then begin
                i = rwcnt;
              end;
            end;
            orgIVCr.SerNr = IVCrw.OrgIVNr;
            if (ReadFirstMain(orgIVCr,1,true)) then begin
              rwcnt = MatRowCnt(orgIVCr);
              for (i=0;i<rwcnt;i=i+1) begin
                MatRowGet(orgIVCr,i,IVCrw);
                if (IVCrw.stp==kInvoiceRowTypeCreditCardPayment) then begin
                  transid = IVCrw.CCTransID;
                  i = rwcnt;
                end;
              end;
            end;
          end;
          if (ProceedMPesaPayTouchScreenRemote(RepSpec,CCAccountIDr,IVCr,txtype,transid,message)==false) then begin
            MessageBox(0,message);
          end;
          goto LProceedMPesaPayTouchScreenOClass;
        end;
      case "RestAccVc":
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,RestAccr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevRestAccr);
            if (prevRestAccr.Closed!=0) then begin
              CloseWindow(wn);
              goto LProceedMPesaPayTouchScreenOClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevRestAccr);
            if (prevRestAccr.Closed!=0) then begin
              CloseWindow(wn);
              goto LProceedMPesaPayTouchScreenOClass;
            end;
        end;
        if (RestAccr.Sum4<RepSpec.vals0) then begin
          CloseWindow(wn);
          MessageBox(20878,"");
          WindowFieldGoto(wn,RestAccr,-1,"vals0",true);
          goto LProceedMPesaPayTouchScreenOClass;
        end;
    end;
  end;
LProceedMPesaPayTouchScreenOClass:;  
  return;
end;

global
updating function Boolean GiftVoucherSalesTouchScreenDClassOnOKWindow(Integer wn)
begin
  boolean res;

  ProceedGiftVoucherSalesTouchScreenDClass;
  GiftVoucherSalesTouchScreenDClassOnOKWindow = res;
  return;
end;

global
updating procedure MPesaRegisterURLDsm()
begin
  record CCAccountIDVc CCAccountIDr;
  integer wn;
  record IVCashVc IVCr;
  Integer txtype;
  string 255 transid,message,tstr;

  wn = CurWindow;
  DeselectWindow(wn,true);
  GetWindowRecord(wn,CCAccountIDr);

  if (WindowState(wn)!=Rs_normal) then begin
    MessageBox(42284,"." & "Save the record before registering");
    goto LMPesaRegisterURLDsm;
  end;
  if (blank(CCAccountIDr.MPesaTill)) then begin
   MessageBox(21675,"");
    goto LMPesaRegisterURLDsm;
  end;
  if (blank(CCAccountIDr.MPesaUsername)) then begin
    MessageBox(21676,"");
    goto LMPesaRegisterURLDsm;
  end;
  if (blank(CCAccountIDr.MPesaPassword)) then begin
    MessageBox(21677,"");
    goto LMPesaRegisterURLDsm;
  end;
  if (blank(CCAccountIDr.MPesaDomain)) then begin
    MessageBox(21685,"");
    goto LMPesaRegisterURLDsm;
  end;
  if (blank(CCAccountIDr.MPesaConsKey)) then begin
    MessageBox(21678,"");
    goto LMPesaRegisterURLDsm;
  end;
  if (blank(CCAccountIDr.MPesaConsSecret)) then begin
    MessageBox(21679,"");
    goto LMPesaRegisterURLDsm;
  end;
  if (blank(CCAccountIDr.MPesaInitiator)) then begin
    MessageBox(21680,"");
    goto LMPesaRegisterURLDsm;
  end;
  // if (blank(CCAccountIDr.MPesaSecCred)) then begin
  //   MessageBox(21681,"");
  //   goto LMPesaRegisterURLDsm;
  // end;
  tstr = GetTextField(CCAccountIDr);
  if (blank(tstr)) then begin
    MessageBox(21682,"");
    goto LMPesaRegisterURLDsm;
  end;
  MPesaRegisterURL(CCAccountIDr,IVCr,transid,message);
LMPesaRegisterURLDsm:;
  return;
end;

global
updating procedure ProceedCashPayTouchScreenDClass()
begin
  Integer wn,mwn;
  record RcVc RepSpec;
  record IVVc prevIVr;
  record IVVc IVr;
  row IVVc IVrw;
  record IVCashVc prevIVCashr;
  record IVCashVc IVCashr;
  row IVCashVc IVCashrw;
  val from,to1,to2,base1,base2;
  string 255 crncy;
  record RestAccVc prevRestAccr;
  record RestAccVc RestAccr;
  row RestAccVc RestAccrw;

  wn = CurWindow;
  DeselectWindow(wn,true);
  mwn = MotherWindow(wn);
  if (mwn!=0) then begin
    GetWindowRecord(wn,RepSpec);
    switch (GetWindowFileName(mwn)) begin
      case "IVVc":
      case "IVCashVc":
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,IVCashr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedCashPayTouchScreenDClass;
            end;
            if (prevIVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedCashPayTouchScreenDClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedCashPayTouchScreenDClass;
            end;
            if (prevIVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedCashPayTouchScreenDClass;
            end;
        end;
        if (IVCashr.OKFlag!=0) then begin
          IVCashr.OKFlag = 0;
        end;
        
        ClearRow(IVCashr,IVCashrw,kInvoiceRowTypeCashPayment);
        IVCashrw.stp = kInvoiceRowTypeCashPayment;
        IVCashrw.Sum = RepSpec.vals0;
        IVCashrw.PayMode = RepSpec.AccStr;
        IVCashrw.Spec = RepSpec.f6;
        crncy = RepSpec.CurncyCode;
        GetFullCurncyRate(crncy,IVCashr.TransDate,from,to1,to2,base1,base2);
        IVCashrw.CurncyCode = crncy;
        IVCashrw.FrRate = from;
        IVCashrw.ToRateB1 = to1;
        IVCashrw.ToRateB2 = to2;
        IVCashrw.BaseRate1 = base1;
        IVCashrw.BaseRate2 = base2;  
        MatRowPut(IVCashr,MatRowCnt(IVCashr),IVCashrw);
        PutWindowRecord(mwn,IVCashr);
        WindowFieldGoto(mwn,IVCashr,-1,"touchscreenitem",true);
        IVCashDClass_RefreshStringList(mwn,IVCashr);
        POSAudit_LogIVCashVcRow(IVCashr,IVCashrw,kPOSEventTypeAddRow);
      case "RestAccVc":
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,RestAccr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevRestAccr);
            if (prevRestAccr.Closed!=0) then begin
              CloseWindow(wn);
              goto LProceedCashPayTouchScreenDClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevRestAccr);
            if (prevRestAccr.Closed!=0) then begin
              CloseWindow(wn);
              goto LProceedCashPayTouchScreenDClass;
            end;
        end;
                
        ClearRow(RestAccr,RestAccrw,kInvoiceRowTypeCreditCardPayment);
        RestAccrw.stp = kInvoiceRowTypeCashPayment;
        RestAccrw.Sum = RepSpec.vals0;
        RestAccrw.PayMode = RepSpec.AccStr;
        RestAccrw.Spec = RepSpec.f6;
        crncy = RepSpec.CurncyCode;
        GetFullCurncyRate(crncy,RestAccr.TransDate,from,to1,to2,base1,base2);
        RestAccrw.CurncyCode = crncy;
        RestAccrw.FrRate = from;
        RestAccrw.ToRateB1 = to1;
        RestAccrw.ToRateB2 = to2;
        RestAccrw.BaseRate1 = base1;
        RestAccrw.BaseRate2 = base2;  
        MatRowPut(RestAccr,MatRowCnt(RestAccr),RestAccrw);
        RestAccSumup(RestAccr,"");
        PutWindowRecord(mwn,RestAccr);
        RestAccDClass_RefreshStringList(mwn,RestAccr);
    end;
    if (WindowDoOK(mwn,0)) then begin
      DeselectWindow(wn,false);
      GetWindowRecord(wn,RepSpec);
      CloseWindow(wn);
      switch (GetWindowFileName(mwn)) begin
        case "IVVc":
        case "IVCashVc":
          GetWindowRecord(mwn,IVCashr);
          SetPOSWindowDisplay_PaymentRow(IVCashrw.Spec,IVCashr.RetValue);
          IVCashDClass_RefreshStringList(mwn,IVCashr);
          OpenCashDrawer_IVCashVc(IVCashr);
        case "RestAccVc":
          GetWindowRecord(mwn,RestAccr);
          RestAccDClass_RefreshStringList(mwn,RestAccr);
          OpenCashDrawer;
      end;
    end else begin
      CloseWindow(wn);
      SelectHWStoreWClass;
    end;
  end;
LProceedCashPayTouchScreenDClass:;  
  return;
end;

global
procedure CancelCCPayTouchScreenDClass()
begin
  record CCMerchantIDVc CCMerchantIDr;  
  record LocalMachineBlock LMb;
  record CCAccountIDVc CCAccountIDr;  
  record RcVc RepSpec;
  Integer wn;

  wn = CurWindow;
  DeselectWindow(wn,true);
  BlockLoad(LMb);
  GetWindowRecord(wn,RepSpec);
  FindCCAccountID(RepSpec.CurncyCode,LMb.LocalMachineCode,kCCAccountTypePOS,CCAccountIDr,kCardHolderAny);
  CCMerchantIDr.Code = CCAccountIDr.MerchantID;
  ReadFirstMain(CCMerchantIDr,1,true);
  if (CCMerchantIDr.Partner==kCCPartnerBambora) then begin
    Bambora_Cancel_Request(wn);
  end;
  CloseWindow(wn);
  return;
end;

global
function string 255 LocalMachinePaymentMode2(string defaultpaymode,Integer rowtype,string crncy,string localmachine,string drawer,
                                             var string label)
begin
  string 255 res;
  record RestPMBlock RestPMb;
  row RestPMBlock RestPMbrw;
  Integer i,rwcnt;
  Boolean testf;
  record DefCashBlock DCb;
  row PMBlock PMrw;
  
  label = "";
  res = defaultpaymode;
  if (blank(res)) then begin
    BlockLoad(DCb);
    switch (rowtype) begin
      case kInvoiceRowTypeCashPayment:
        res = DCb.DefCashPayMode;
      case kInvoiceRowTypeCreditCardPayment:
        res = DCb.DefCCPayMode;
      case kInvoiceRowTypeSwishPayment:
        res = DCb.DefCCPayMode;
      case kInvoiceRowTypeMPesaPayment:
        res = DCb.DefCCPayMode;
      case kInvoiceRowTypeQRPayment:
        res = DCb.DefCCPayMode;
      case kInvoiceRowTypeCashWithdrawal:
        res = DCb.DefCWPayMode;
    end;
  end;
  
  BlockLoad(RestPMb);
  rwcnt = MatRowCnt(RestPMb);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(RestPMb,i,RestPMbrw);
    testf = true;
    if (rowtype!=RestPMbrw.rowstp) then begin testf = false; end;
    if (nonblank(crncy)) then begin
      if (crncy!=RestPMbrw.CurncyCode) then begin testf = false; end;
    end;
    if (nonblank(localmachine)) then begin
      if (SetInSet(localmachine,RestPMbrw.MachineName)==false) then begin testf = false; end;
    end;
    if (nonblank(drawer)) then begin
      if (SetInSet(drawer,RestPMbrw.Drawers)==false) then begin testf = false; end;
    end;
    if (testf) then begin
      res = RestPMbrw.PMCode;
      label = RestPMbrw.Label;
      goto LLocalMachinePaymentMode2;
    end;
  end;
LLocalMachinePaymentMode2:;  
  if (blank(label) and nonblank(res)) then begin
    GetPMRow(res,PMrw);
    label = PMrw.Comment;
  end;
  LocalMachinePaymentMode2 = res;  
  return;
end;

global
function string 255 LocalMachinePaymentMode(string defaultpaymode,Integer rowtype,string crncy,string localmachine,string drawer)
begin
  string 255 tstr;
  
  LocalMachinePaymentMode = LocalMachinePaymentMode2(defaultpaymode,rowtype,crncy,localmachine,drawer,tstr);
  return;
end;

global
updating procedure ProceedNPTSCashPaymentTClass()
begin
  Integer wn,mwn;
  record RcVc RepSpec;
  record IVCashVc prevIVCashr;
  record IVCashVc IVCashr;
  row IVCashVc IVCashrw;
  Array string 255 acrncy;
  Array Boolean achangecrncyf;
  Integer i,acrncnt;
  string 255 crncy;
  val fr,to1,to2,br1,br2,sum4;
  record RestAccVc prevRestAccr;
  record RestAccVc RestAccr;
  row RestAccVc RestAccrw;
  record IVVc prevIVr;
  record IVVc IVr;
  row IVVc IVrw;
  
  wn = CurWindow;
  DeselectWindow(wn,true);
  mwn = MotherWindow(wn);
  if (mwn!=0) then begin
    GetWindowRecord(wn,RepSpec);
    switch (GetWindowFileName(mwn)) begin
      case "IVCashVc":
        sum4 = IVCashr.Sum4;
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,IVCashr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSCashPaymentTClass;
            end;
            if (prevIVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSCashPaymentTClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSCashPaymentTClass;
            end;
            if (prevIVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSCashPaymentTClass;
            end;
        end;
        if (IVCashr.OKFlag!=0) then begin
          IVCashr.OKFlag = 0;
        end;
        CntPOSCurrencies(acrncy,achangecrncyf,acrncnt);
        for (i=0;i<acrncnt;i=i+1) begin
        
          ClearRow(IVCashr,IVCashrw,kInvoiceRowTypeCashPayment);
          IVCashrw.stp = kInvoiceRowTypeCashPayment;
          IVCashrw.Sum = StringToVal(GetWindowString(wn,"NPTSCashPaymentCashReceived" & i),M4Val);
          IVCashrw.BasePrice = StringToVal(GetWindowString(wn,"NPTSCashPaymentChangeGiven" & i),M4Val);
          if (IVCashrw.Sum!=0 or IVCashrw.BasePrice!=0) then begin
            crncy = "";
            if (HasMultiCurrency) then begin
              crncy = GetWindowString(wn,"NPTSCashPaymentCurrency" & i);
            end;
            IVCashrw.PayMode = LocalMachinePaymentMode(RepSpec.AccStr,kInvoiceRowTypeCashPayment,crncy,IVCashr.LocalMachineCode,IVCashr.DrawerCode);
            if (blank(IVCashrw.PayMode)) then begin
              IVCashrw.PayMode = RepSpec.AccStr;
            end;
            IVCashrw.Spec = RepSpec.f6;
            if (HasMultiCurrency) then begin
              if (GetFullCurncyPurchaseRate(crncy,CurrentDate,fr,to1,to2,br1,br2)==false) then begin
                GetFullCurncyRate(crncy,CurrentDate,fr,to1,to2,br1,br2);
              end;
            end;
            IVCashrw.CurncyCode = crncy;
            IVCashrw.FrRate = fr;
            IVCashrw.ToRateB1 = to1;
            IVCashrw.ToRateB2 = to2;
            IVCashrw.BaseRate1 = br1;
            IVCashrw.BaseRate2 = br2;  
            MatRowPut(IVCashr,MatRowCnt(IVCashr),IVCashrw);
            POSAudit_LogIVCashVcRow(IVCashr,IVCashrw,kPOSEventTypeAddRow);
          end;
        end;
        IVCashSumup(IVCashr,true);
        if (IVCashr.InvType==kPOSInvoiceTypeCredit) then begin
          if (IVCashr.RetValue!=0) then begin
            MessageBox(20878,"");
            WindowFieldGoto(wn,RepSpec,-1,"NPTSCashPaymentCashReceived0",true);
            goto LProceedNPTSCashPaymentTClass;
          end;
        end;
        PutWindowRecord(mwn,IVCashr);
        WindowFieldGotoForTouchScreen(mwn,-1,"ivcashcommand",true);
      case "IVVc":
        sum4 = IVr.Sum4;
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,IVr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVr);
            if (prevIVr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSCashPaymentTClass;
            end;
            if (prevIVr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSCashPaymentTClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVr);
            if (prevIVr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSCashPaymentTClass;
            end;
            if (prevIVr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSCashPaymentTClass;
            end;
        end;
        if (IVr.OKFlag!=0) then begin
          IVr.OKFlag = 0;
        end;
        CntPOSCurrencies(acrncy,achangecrncyf,acrncnt);
        for (i=0;i<acrncnt;i=i+1) begin
        
          ClearRow(IVr,IVrw,kInvoiceRowTypeCashPayment);
          IVrw.stp = kInvoiceRowTypeCashPayment;
          IVrw.Sum = StringToVal(GetWindowString(wn,"NPTSCashPaymentCashReceived" & i),M4Val);
          if (IVrw.Sum!=0) then begin
            IVrw.PayMode = RepSpec.AccStr;
            IVrw.Spec = RepSpec.f6;
            crncy = GetWindowString(wn,"NPTSCashPaymentCurrency" & i);
            if (GetFullCurncyPurchaseRate(crncy,CurrentDate,fr,to1,to2,br1,br2)==false) then begin
              GetFullCurncyRate(crncy,CurrentDate,fr,to1,to2,br1,br2);
            end;
            IVrw.CurncyCode = crncy;
            IVrw.FrRate = fr;
            IVrw.ToRateB1 = to1;
            IVrw.ToRateB2 = to2;
            IVrw.BaseRate1 = br1;
            IVrw.BaseRate2 = br2;  
            MatRowPut(IVr,MatRowCnt(IVr),IVrw);
          end;
        end;
        IVSumup(IVr,true);
        PutWindowRecord(mwn,IVr);
        WindowFieldGotoForTouchScreen(mwn,-1,"ivcashcommand",true);
        IVCashDClass_RefreshStringList(mwn,IVCashr);
      case "RestAccVc":
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,RestAccr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevRestAccr);
            if (prevRestAccr.Closed!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSCashPaymentTClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevRestAccr);
            if (prevRestAccr.Closed!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSCashPaymentTClass;
            end;
        end;

        CntPOSCurrencies(acrncy,achangecrncyf,acrncnt);
        for (i=0;i<acrncnt;i=i+1) begin
        
          ClearRow(RestAccr,RestAccrw,kInvoiceRowTypeCreditCardPayment);
          RestAccrw.stp = kInvoiceRowTypeCashPayment;
          RestAccrw.Sum = StringToVal(GetWindowString(wn,"NPTSCashPaymentCashReceived" & i),M4Val);
          if (RestAccrw.Sum>0) then begin
            RestAccrw.PayMode = RepSpec.AccStr;
            RestAccrw.Spec = RepSpec.f6;
            crncy = GetWindowString(wn,"NPTSCashPaymentCurrency" & i);
            if (GetFullCurncyPurchaseRate(crncy,CurrentDate,fr,to1,to2,br1,br2)==false) then begin
              GetFullCurncyRate(crncy,CurrentDate,fr,to1,to2,br1,br2);
            end;
            RestAccrw.CurncyCode = crncy;
            RestAccrw.FrRate = fr;
            RestAccrw.ToRateB1 = to1;
            RestAccrw.ToRateB2 = to2;
            RestAccrw.BaseRate1 = br1;
            RestAccrw.BaseRate2 = br2;  
            MatRowPut(RestAccr,MatRowCnt(RestAccr),RestAccrw);
          end;
        end;        
        RestAccSumup(RestAccr,"");
        PutWindowRecord(mwn,RestAccr);
        RestAccDClass_RefreshStringList(mwn,RestAccr);
    end;
    if (WindowDoOK(mwn,0)) then begin
      DeselectWindow(wn,false);
      GetWindowRecord(wn,RepSpec);
      CloseWindow(wn);
      switch (GetWindowFileName(mwn)) begin
        case "IVVc":
          GetWindowRecord(mwn,IVr);
          IVDClass_RefreshStringList(mwn,IVr);
          SetPOSWindowDisplay_PaymentRow(IVrw.Spec,IVr.RetnValue);
          OpenCashDrawer;
        case "IVCashVc":
          GetWindowRecord(mwn,IVCashr);
          IVCashDClass_RefreshStringList(mwn,IVCashr);
          SetPOSWindowDisplay_PaymentRow(IVCashrw.Spec,IVCashr.RetValue);
          OpenCashDrawer_IVCashVc(IVCashr);
          if (IVCashPOSButtonAutoFinish(mwn)==kPOSButtonAutoFinishYes) then begin
            IVCashDClassTouchScreenFinishButton;
          end;
        case "RestAccVc":
          GetWindowRecord(mwn,RestAccr);
          RestAccDClass_RefreshStringList(mwn,RestAccr);
          SetPOSWindowDisplayAmount(USetStr(27350),RestAccr.Sum4-RestAccr.TendValue);
          OpenCashDrawer;
          if (RestAccPOSButtonAutoFinish(mwn)==kPOSButtonAutoFinishYes) then begin
            RestAccDClassTouchScreenFinishButton;
          end;
      end;
    end else begin
      switch (GetWindowFileName(mwn)) begin
        case "IVCashVc":
          if (IVCashr.OKFlag!=0) then begin
            IVCashr.OKFlag = 0;
            PutWindowRecord(mwn,IVCashr);
          end;
      end;
      CloseWindow(wn);
      SelectHWStoreWClass;
    end;
  end;
LProceedNPTSCashPaymentTClass:;
  //WindowFieldGoto(mwn,RepSpec,-1,"ivcashcommand",true);
  WindowFieldGotoForTouchScreen(mwn,-1,"ivcashcommand",true); 
  return;
end;

global
procedure CancelNPTSCashPaymentTClass()
begin
  Integer mwn,wn;
  record RcVc RepSpec;

  if (FindWindow("CCPayVerifoneProcessingWClass")>0) then begin
  end else begin
    wn = CurWindow;
    mwn =  MotherWIndow(wn);
    DeselectWindow(wn,true);
    CloseWindow(wn);
  //WindowFieldGoto(mwn,RepSpec,-1,"ivcashcommand",true);
    WindowFieldGotoForTouchScreen(mwn,-1,"ivcashcommand",true); 
  end;
  return;
end;

global
updating procedure ProceedNPTSPaymentTClass()
begin
  Integer wn,mwn;
  record RcVc RepSpec;
  record IVCashVc prevIVCashr;
  record IVCashVc IVCashr;
  row IVCashVc IVCashrw;
  string 255 crncy;
  val fr,to1,to2,br1,br2,sum4;
  val totpaymentv,totcashv;
  Array string 255 acrncy,alabel,apaymentmode;
  Array Integer apaymenttype;
  Array val apaymentv;
  Array string 255 apaymentchecknr;
  Array string 255 apaymentauthcode;
  Integer i,acrncnt,rwcnt;
  record LocalMachineBlock LMb;
  record RestAccVc prevRestAccr;
  record RestAccVc RestAccr;
  row RestAccVc RestAccrw;
  vector val vpaymodeamounts;
  Boolean testf;
  record RestBlock Restb;
  record IVVc prevIVr;
  record IVVc IVr;
  row IVVc IVrw;
  transaction Integer gTransferRestAccToKitchenOrder;
  record RestSetupVc RSr;
  Integer ProceedPaymentPrintKitchenOrder,ProceedPaymentPrintReceipt,ProceedPaymentSaveTab;

  wn = CurWindow;
  DeselectWindow(wn,true);
  mwn = MotherWindow(wn);
  if (mwn!=0) then begin
    BlockLoad(LMb);
    GetWindowRecord(wn,RepSpec);
    switch (GetWindowFileName(mwn)) begin
      case "IVCashVc":
        sum4 = IVCashr.Sum4;
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,IVCashr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSPaymentTClass;
            end;
            if (prevIVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSPaymentTClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSPaymentTClass;
            end;
            if (prevIVCashr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSPaymentTClass;
            end;
        end;
        if (IVCashr.OKFlag!=0) then begin
          IVCashr.OKFlag = 0;
        end;
        rwcnt = MatRowCnt(IVCashr);
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(IVCashr,i,IVCashrw);
          switch (IVCashrw.stp) begin
/*          
            case kInvoiceRowTypeLoyaltyPointsPayment:
              MatRowDelete(IVCashr,i);
              rwcnt = MatRowCnt(IVCashr);
              i = 0;
*/              
            case kInvoiceRowTypeCashPayment:
              MatRowDelete(IVCashr,i);
              rwcnt = MatRowCnt(IVCashr);
              i = 0;
/*              
            case kInvoiceRowTypeCreditCardPayment:
              MatRowDelete(IVCashr,i);
              rwcnt = MatRowCnt(IVCashr);
              i = 0;
            case kInvoiceRowTypeChequePayment:
              MatRowDelete(IVCashr,i);
              rwcnt = MatRowCnt(IVCashr);
              i = 0;
            case kInvoiceRowTypeGiftVoucherPayment:
//              MatRowDelete(IVCashr,i);
//              rwcnt = MatRowCnt(IVCashr);
//              i = 0;
*/
          end;
        end;
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(IVCashr,i,IVCashrw);
          switch (IVCashrw.stp) begin
            case kInvoiceRowTypeCreditCardPayment:
              vpaymodeamounts[IVCashrw.PayMode] = vpaymodeamounts[IVCashrw.PayMode] + IVCashrw.Sum;
            case kInvoiceRowTypeSwishPayment:
              vpaymodeamounts[IVCashrw.PayMode] = vpaymodeamounts[IVCashrw.PayMode] + IVCashrw.Sum;
            case kInvoiceRowTypeMPesaPayment:
              vpaymodeamounts[IVCashrw.PayMode] = vpaymodeamounts[IVCashrw.PayMode] + IVCashrw.Sum;
            case kInvoiceRowTypeQRPayment:
              vpaymodeamounts[IVCashrw.PayMode] = vpaymodeamounts[IVCashrw.PayMode] + IVCashrw.Sum;
            case kInvoiceRowTypeCashWithdrawal:
              vpaymodeamounts[IVCashrw.PayMode] = vpaymodeamounts[IVCashrw.PayMode] + IVCashrw.Sum;
          end;
        end;
        CntNPTSPaymentCurrenciesRemote(LMb.LocalMachineCode,alabel,acrncy,apaymenttype,apaymentmode,acrncnt);
        for (i=0;i<acrncnt;i=i+1) begin
          switch (apaymenttype[i]) begin
            case kInvoiceRowTypeChequePayment:
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassChequeAmount" & apaymentmode[i]),M4Val);
              apaymentchecknr[i] = GetWindowString(wn,"NPTSPaymentTClassChequeNr" & apaymentmode[i]);
            case kInvoiceRowTypeCreditCardPayment:
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassAmount" & apaymentmode[i]),M4Val) - vpaymodeamounts[apaymentmode[i]];
              apaymentauthcode[i] = GetWindowString(wn,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i]);
              if (LMb.CCRequireAuthCode!=0) then begin
                if (blank(apaymentauthcode[i])) and (apaymentv[i]>0) then begin
                  MessageBox(1058,"");
                  WindowFieldGoto(wn,RepSpec,-1,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i],true);
                  goto LProceedNPTSPaymentTClass;
                end;
              end;
            case kInvoiceRowTypeSwishPayment:
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassAmount" & apaymentmode[i]),M4Val) - vpaymodeamounts[apaymentmode[i]];
              apaymentauthcode[i] = GetWindowString(wn,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i]);
              if (LMb.CCRequireAuthCode!=0) then begin
                if (blank(apaymentauthcode[i])) and (apaymentv[i]>0) then begin
                  MessageBox(1058,"");
                  WindowFieldGoto(wn,RepSpec,-1,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i],true);
                  goto LProceedNPTSPaymentTClass;
                end;
              end;
            case kInvoiceRowTypeMPesaPayment:
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassAmount" & apaymentmode[i]),M4Val) - vpaymodeamounts[apaymentmode[i]];
              apaymentauthcode[i] = GetWindowString(wn,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i]);
              if (LMb.CCRequireAuthCode!=0) then begin
                if (blank(apaymentauthcode[i])) and (apaymentv[i]>0) then begin
                  MessageBox(1058,"");
                  WindowFieldGoto(wn,RepSpec,-1,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i],true);
                  goto LProceedNPTSPaymentTClass;
                end;
              end;
            case kInvoiceRowTypeQRPayment:
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassAmount" & apaymentmode[i]),M4Val) - vpaymodeamounts[apaymentmode[i]];
              apaymentauthcode[i] = GetWindowString(wn,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i]);
              if (LMb.CCRequireAuthCode!=0) then begin
                if (blank(apaymentauthcode[i])) and (apaymentv[i]>0) then begin
                  MessageBox(1058,"");
                  WindowFieldGoto(wn,RepSpec,-1,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i],true);
                  goto LProceedNPTSPaymentTClass;
                end;
              end;
            case kInvoiceRowTypeCashWithdrawal:
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassAmount" & apaymentmode[i]),M4Val) - vpaymodeamounts[apaymentmode[i]];
              apaymentauthcode[i] = GetWindowString(wn,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i]);
              if (LMb.CCRequireAuthCode!=0) then begin
                if (blank(apaymentauthcode[i])) and (apaymentv[i]>0) then begin
                  MessageBox(1058,"");
                  WindowFieldGoto(wn,RepSpec,-1,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i],true);
                  goto LProceedNPTSPaymentTClass;
                end;
              end;
            case kInvoiceRowTypeGiftVoucherPayment:
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassGVPAmount" & apaymentmode[i]),M4Val);
            otherwise
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassAmount" & apaymentmode[i]),M4Val);
          end;
          switch (apaymenttype[i]) begin
            case kInvoiceRowTypeCashPayment:
              totcashv = totcashv + apaymentv[i];
            case kInvoiceRowTypeCreditCardPayment:
              totcashv = totcashv + apaymentv[i];
            case kInvoiceRowTypeSwishPayment:
              totcashv = totcashv + apaymentv[i];
            case kInvoiceRowTypeMPesaPayment:
              totcashv = totcashv + apaymentv[i];
            case kInvoiceRowTypeQRPayment:
              totcashv = totcashv + apaymentv[i];
            case kInvoiceRowTypeCashWithdrawal:
              totcashv = totcashv + apaymentv[i];
            case kInvoiceRowTypeChequePayment:
              totcashv = totcashv + apaymentv[i];
          end;
          totpaymentv = totpaymentv + apaymentv[i];
        end;
        if ((totpaymentv-totcashv)>=IVCashr.Sum4) then begin
          if (totpaymentv>totcashv) then begin
            MessageBox(20878,"");
            WindowFieldGoto(wn,RepSpec,-1,"NPTSPaymentTClassAmount" & apaymentmode[0],true);
            goto LProceedNPTSPaymentTClass;
          end;
        end;
        NPTSPaymentPasteAmounts(IVCashr,alabel,acrncy,apaymenttype,apaymentmode,apaymentv,apaymentchecknr,apaymentauthcode,acrncnt);
        PutWindowRecord(mwn,IVCashr);
        WindowFieldGotoForTouchScreen(mwn,-1,"ivcashcommand",true);
        IVCashDClass_RefreshStringList(mwn,IVCashr);
      case "IVVc":
        sum4 = IVr.Sum4;
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,IVr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVr);
            if (prevIVr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSPaymentTClass;
            end;
            if (prevIVr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSPaymentTClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVr);
            if (prevIVr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSPaymentTClass;
            end;
            if (prevIVr.Invalid!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSPaymentTClass;
            end;
        end;
        if (IVr.OKFlag!=0) then begin
          IVr.OKFlag = 0;
        end;
        rwcnt = MatRowCnt(IVr);
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(IVr,i,IVrw);
          switch (IVrw.stp) begin
/*          
            case kInvoiceRowTypeLoyaltyPointsPayment:
              MatRowDelete(IVr,i);
              rwcnt = MatRowCnt(IVr);
              i = 0;
*/              
            case kInvoiceRowTypeCashPayment:
              MatRowDelete(IVr,i);
              rwcnt = MatRowCnt(IVr);
              i = 0;
/*              
            case kInvoiceRowTypeCreditCardPayment:
              MatRowDelete(IVr,i);
              rwcnt = MatRowCnt(IVr);
              i = 0;
            case kInvoiceRowTypeChequePayment:
              MatRowDelete(IVr,i);
              rwcnt = MatRowCnt(IVr);
              i = 0;
            case kInvoiceRowTypeGiftVoucherPayment:
//              MatRowDelete(IVr,i);
//              rwcnt = MatRowCnt(IVr);
//              i = 0;
*/
          end;
        end;
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(IVr,i,IVrw);
          switch (IVrw.stp) begin
            case kInvoiceRowTypeCreditCardPayment:
              vpaymodeamounts[IVrw.PayMode] = vpaymodeamounts[IVrw.PayMode] + IVrw.Sum;
            case kInvoiceRowTypeSwishPayment:
              vpaymodeamounts[IVrw.PayMode] = vpaymodeamounts[IVrw.PayMode] + IVrw.Sum;
            case kInvoiceRowTypeMPesaPayment:
              vpaymodeamounts[IVrw.PayMode] = vpaymodeamounts[IVrw.PayMode] + IVrw.Sum; 
            case kInvoiceRowTypeQRPayment:
              vpaymodeamounts[IVrw.PayMode] = vpaymodeamounts[IVrw.PayMode] + IVrw.Sum;
            case kInvoiceRowTypeCashWithdrawal:
              vpaymodeamounts[IVrw.PayMode] = vpaymodeamounts[IVrw.PayMode] + IVrw.Sum;
          end;
        end;

        CntNPTSPaymentCurrenciesRemote(LMb.LocalMachineCode,alabel,acrncy,apaymenttype,apaymentmode,acrncnt);
        for (i=0;i<acrncnt;i=i+1) begin
          switch (apaymenttype[i]) begin
            case kInvoiceRowTypeChequePayment:
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassChequeAmount" & apaymentmode[i]),M4Val);
              apaymentchecknr[i] = GetWindowString(wn,"NPTSPaymentTClassChequeNr" & apaymentmode[i]);
            case kInvoiceRowTypeCreditCardPayment:
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassAmount" & apaymentmode[i]),M4Val) - vpaymodeamounts[apaymentmode[i]];
              apaymentauthcode[i] = GetWindowString(wn,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i]);
              if (LMb.CCRequireAuthCode!=0) then begin
                if (blank(apaymentauthcode[i])) and (apaymentv[i]>0) then begin
                  MessageBox(1058,"");
                  WindowFieldGoto(wn,RepSpec,-1,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i],true);
                  goto LProceedNPTSPaymentTClass;
                end;
              end;
            case kInvoiceRowTypeSwishPayment:
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassAmount" & apaymentmode[i]),M4Val) - vpaymodeamounts[apaymentmode[i]];
              apaymentauthcode[i] = GetWindowString(wn,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i]);
              if (LMb.CCRequireAuthCode!=0) then begin
                if (blank(apaymentauthcode[i])) and (apaymentv[i]>0) then begin
                  MessageBox(1058,"");
                  WindowFieldGoto(wn,RepSpec,-1,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i],true);
                  goto LProceedNPTSPaymentTClass;
                end;
              end;
            case kInvoiceRowTypeMPesaPayment:
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassAmount" & apaymentmode[i]),M4Val) - vpaymodeamounts[apaymentmode[i]];
              apaymentauthcode[i] = GetWindowString(wn,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i]);
              if (LMb.CCRequireAuthCode!=0) then begin
                if (blank(apaymentauthcode[i])) and (apaymentv[i]>0) then begin
                  MessageBox(1058,"");
                  WindowFieldGoto(wn,RepSpec,-1,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i],true);
                  goto LProceedNPTSPaymentTClass;
                end;
              end;
            case kInvoiceRowTypeQRPayment:
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassAmount" & apaymentmode[i]),M4Val) - vpaymodeamounts[apaymentmode[i]];
              apaymentauthcode[i] = GetWindowString(wn,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i]);
              if (LMb.CCRequireAuthCode!=0) then begin
                if (blank(apaymentauthcode[i])) and (apaymentv[i]>0) then begin
                  MessageBox(1058,"");
                  WindowFieldGoto(wn,RepSpec,-1,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i],true);
                  goto LProceedNPTSPaymentTClass;
                end;
              end;
            case kInvoiceRowTypeCashWithdrawal:
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassAmount" & apaymentmode[i]),M4Val) - vpaymodeamounts[apaymentmode[i]];
              apaymentauthcode[i] = GetWindowString(wn,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i]);
              if (LMb.CCRequireAuthCode!=0) then begin
                if (blank(apaymentauthcode[i])) and (apaymentv[i]>0) then begin
                  MessageBox(1058,"");
                  WindowFieldGoto(wn,RepSpec,-1,"NPTSPaymentTClassAuthorizationCode" & apaymentmode[i],true);
                  goto LProceedNPTSPaymentTClass;
                end;
              end;
            case kInvoiceRowTypeGiftVoucherPayment:
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassGVPAmount" & apaymentmode[i]),M4Val);
            otherwise
              apaymentv[i] = StringToVal(GetWindowString(wn,"NPTSPaymentTClassAmount" & apaymentmode[i]),M4Val);
          end;
          switch (apaymenttype[i]) begin
            case kInvoiceRowTypeCashPayment:
              totcashv = totcashv + apaymentv[i];
            case kInvoiceRowTypeCreditCardPayment:
              totcashv = totcashv + apaymentv[i];
            case kInvoiceRowTypeSwishPayment:
              totcashv = totcashv + apaymentv[i];
            case kInvoiceRowTypeMPesaPayment:
              totcashv = totcashv + apaymentv[i];
            case kInvoiceRowTypeQRPayment:
              totcashv = totcashv + apaymentv[i];
            case kInvoiceRowTypeCashWithdrawal:
              totcashv = totcashv + apaymentv[i];
          end;
          totpaymentv = totpaymentv + apaymentv[i];
        end;
        if ((totpaymentv-totcashv)>IVr.Sum4) then begin
          if (totpaymentv>totcashv) then begin
            MessageBox(20878,"");
            WindowFieldGoto(wn,RepSpec,-1,"NPTSPaymentTClassAmount" & apaymentmode[0],true);
            goto LProceedNPTSPaymentTClass;
          end;
        end;
        NPTSPaymentPasteAmounts_IVVc(IVr,alabel,acrncy,apaymenttype,apaymentmode,apaymentv,apaymentchecknr,apaymentauthcode,acrncnt);
//        IVr.OKFlag = 1;
        PutWindowRecord(mwn,IVr);
        WindowFieldGotoForTouchScreen(wn,-1,"ivcashcommand",true);
        OpenStdCCWindow(mwn);
      case "RestAccVc":
        BlockLoad(Restb);
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,RestAccr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevRestAccr);
            if (prevRestAccr.Closed!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSPaymentTClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevRestAccr);
            if (prevRestAccr.Closed!=0) then begin
              CloseWindow(wn);
              goto LProceedNPTSPaymentTClass;
            end;
        end;
        rwcnt = MatRowCnt(RestAccr);
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(RestAccr,i,RestAccrw);
          switch (RestAccrw.stp) begin
/*          
            case kInvoiceRowTypeLoyaltyPointsPayment:
              MatRowDelete(RestAccr,i);
              rwcnt = MatRowCnt(RestAccr);
              i = 0;
*/              
            case kInvoiceRowTypeCashPayment:
