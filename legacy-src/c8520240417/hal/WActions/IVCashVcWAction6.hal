global
updating procedure IVCashDClassTouchScreenDuplicateIVCash()
begin
  record IVCashVc IVCashr,newIVCashr;
  Integer wn,i,nwn,rwcnt;
  Longint newnr;
  record SRBlock SRb; 
  record CashierDefBlock CashDefRec;
  record AccBlock ARAccRec;
  record UserVc USr;
  record CUVc CUr;
  row IVCashVc newIVCashrw,IVCashrw;
  record LocalOffLineNrBlock LastRecNr;
  val frrate,to1,to2,br1,br2;
  Date curdate;
  string 255 tstr,curcode;
  Boolean gentrans;

  wn = CurWindow;
  GetWindowRecord(wn,IVCashr); 
  RecordNew(newIVCashr);
  CloseWindow(wn);

  BlockLoad(ARAccRec);  
  BlockLoad(CashDefRec);  
  curdate = CurrentDate;
  newIVCashr.SerNr = -1;
  newIVCashr.SDNr = -1;
  newIVCashr.PUNr = -1;
  newIVCashr.POSNr = CashDefRec.POSNr;
  newIVCashr.TransTime = CurrentTime;
  newIVCashr.StartTime = CurrentTime;
  newIVCashr.InvDate = curdate;
  newIVCashr.TransDate = curdate;
  if (ServingClient==false) then begin//offline
    BlockLoad(LastRecNr);
    newnr = LastRecNr.LastIVCashNr;
    newIVCashr.SerNr = NextSerNr("IVCashVc",newIVCashr.TransDate,newnr,false,newIVCashr.LangCode);
    if (newIVCashr.SerNr<=LastRecNr.LastIVCashNr) then begin
      newIVCashr.SerNr = LastRecNr.LastIVCashNr + 1;
    end;
    if (SerNrTestIVCashVc(newIVCashr.SerNr,newIVCashr.TransDate,gentrans)==false) then begin
      BlockLoad(SRb);  
      newnr = GetCurUserLastNr("IVCashVc");
      if (newnr==-1) then begin
        newnr = SRb.LastIVCashNr;
      end;
      newIVCashr.SerNr = NextSerNr("IVCashVc",newIVCashr.TransDate,newnr,false,newIVCashr.LangCode);
    end;
  end;
  newIVCashr.Prntdf = 0;
  newIVCashr.OKFlag = 0;
  newIVCashr.NLFlag = 0;
  newIVCashr.ExportedFlag = 0;
  newIVCashr.Suspended = 0;
  GetCurUser(USr);
  newIVCashr.OurContact = USr.CurOurContact;
  if (nonblank(USr.Location)) then begin
    newIVCashr.Location = USr.Location;
  end;
  newIVCashr.RefStr = "";
  newIVCashr.TagNumber = "";
  GetFullCurncyRate(curcode,curdate,frrate,to1,to2,br1,br2);
  newIVCashr.CurncyCode = curcode;
  newIVCashr.FrRate = frrate;
  newIVCashr.ToRateB1 = to1;
  newIVCashr.ToRateB2 = to2;
  newIVCashr.BaseRate1 = br1;
  newIVCashr.BaseRate2 = br2;
  if (IsDoingManagerOverride) then begin
    newIVCashr.SalesMan = OriginalLogin;
  end else begin
    newIVCashr.SalesMan = CurrentUser;
  end;
  newIVCashr.RetValue = blankval;  
  newIVCashr.TendValue = blankval;  
  newIVCashr.CashValue = blankval;
  if (ProgramType==typOffLine) then begin
    newIVCashr.UpdStockFlag = 0;
  end else begin
    newIVCashr.UpdStockFlag = 0;
  end;
  newIVCashr.RecValue = blankval;    
  newIVCashr.RecValue2 = blankval;    
  newIVCashr.CashValueB2 = blankval;    
  newIVCashr.RetValueB2 = blankval;    
  newIVCashr.CashValueCur = blankval;    
  newIVCashr.RetValueCur = blankval;
  GetBaseCurncy(2,curcode);
  newIVCashr.POSCurncyCode = curcode;    
  newIVCashr.AuthorizationCode = "";
  newIVCashr.Invalid = 0;
  newIVCashr.LocOKNr = blankval;
  newIVCashr.OrderNr = -1;
  newIVCashr.AuthorizationCode = "";
  newIVCashr.AuthorizationCode2 = "";
  newIVCashr.Invalid = 0;
  newIVCashr.InvalidDate = "";
  newIVCashr.InvalidTime = "";
  newIVCashr.InvalidBy = "";
  newIVCashr.TaxAdminServSeal = "";
  CUr.Code = newIVCashr.CustCode;
  if (ReadFirstMain(CUr,1,true)) then begin
  end;
  if (HasLocalization("LTU")) then begin
    newIVCashr.FiscalFlag = 1;
  end else begin
    newIVCashr.FiscalFlag = CUr.FiscalFlag;
  end;
  if (HasLocalization("SAU")) then begin
    newIVCashr.SauOfficialSerNr = "";
  end;
  if (HasLocalization("POL")) then begin
    switch (CUr.IPBookVAT) begin
      case 1:
        newIVCashr.IPBookVAT = CUr.IPBookVAT;
      case 2:
        newIVCashr.IPBookVAT = 0;
      otherwise
        newIVCashr.IPBookVAT = ARAccRec.IPBookVAT;
    end;
  end else begin
    newIVCashr.IPBookVAT = ARAccRec.IPBookVAT;  
  end;
  rwcnt = MatRowCnt(IVCashr);
  for (i=0;i<rwcnt;i=i+1) begin
    MatRowGet(IVCashr,i,IVCashrw);
    switch (IVCashrw.stp) begin
      case kInvoiceRowTypeVoid: goto Skiprow;
      case kInvoiceRowTypeOnAccountPayment: goto Skiprow;
      case kInvoiceRowTypeGiftVoucherPayment: goto Skiprow;    
      case kInvoiceRowTypeLoyaltyPointsPayment: goto Skiprow;
      case kInvoiceRowTypeCashPayment: goto Skiprow;
      case kInvoiceRowTypeCreditCardPayment: goto Skiprow;
      case kInvoiceRowTypeSwishPayment: goto Skiprow; 
      case kInvoiceRowTypeMPesaPayment: goto Skiprow;
      case kInvoiceRowTypeQRPayment: goto Skiprow;
      case kInvoiceRowTypeCashWithdrawal:goto Skiprow;
      otherwise
        newIVCashrw.FIFO = blankval;
        newIVCashrw.FIFORowVal = blankval;
        newIVCashrw.DownPaidSum = blankval;
        newIVCashrw.OrdQuant = blankval;
        newIVCashrw.OrdRow = -1;
        newIVCashrw.ArtCode =  IVCashrw.ArtCode;
        newIVCashrw.Quant = IVCashrw.Quant;
        newIVCashrw.Price = IVCashrw.Price;
        newIVCashrw.Sum = IVCashrw.Sum;
        newIVCashrw.vRebate = IVCashrw.vRebate;
        newIVCashrw.SalesAcc = IVCashrw.SalesAcc;
        newIVCashrw.Objects = IVCashrw.Objects;
        newIVCashrw.BasePrice = IVCashrw.BasePrice;
        newIVCashrw.rowGP = IVCashrw.rowGP;
        newIVCashrw.FIFO = IVCashrw.FIFO;
        newIVCashrw.Spec = IVCashrw.Spec;
        newIVCashrw.VATCode = IVCashrw.VATCode;
        newIVCashrw.Recepy = "";
        newIVCashrw.SerialNr = -1;
        newIVCashrw.PriceFactor = IVCashrw.PriceFactor; 
        newIVCashrw.FIFORowVal = IVCashrw.FIFORowVal;
        newIVCashrw.Coefficient = IVCashrw.Coefficient; 
        newIVCashrw.ExciseNr = IVCashrw.ExciseNr;
        newIVCashrw.UnitCode = IVCashrw.UnitCode;
        newIVCashrw.UnitFactQuant = IVCashrw.UnitFactQuant;
        newIVCashrw.UnitFactPrice = IVCashrw.UnitFactPrice;
        newIVCashrw.UnitXval = IVCashrw.UnitXval;
        newIVCashrw.UnitYval = IVCashrw.UnitYval;
        newIVCashrw.UnitZval = IVCashrw.UnitZval;
        newIVCashrw.OrdQuant = blankval;
        newIVCashrw.DownPaidSum = blankval;
        newIVCashrw.OrdRow = -1;
        newIVCashrw.PosCode = "";
        newIVCashrw.TAX2Code = IVCashrw.TAX2Code;
        newIVCashrw.TAX2Prc = IVCashrw.TAX2Prc;
        newIVCashrw.TAX2Reb = IVCashrw.TAX2Reb;
        newIVCashrw.TAX1Reb = IVCashrw.TAX1Reb;
        newIVCashrw.TAX2Acc = IVCashrw.TAX2Acc;
        newIVCashrw.GCNr = "";
        newIVCashrw.PayMode   = "";
        newIVCashrw.CreditCard = "";
        newIVCashrw.AuthorizationCode = "";
        newIVCashrw.CurncyCode = IVCashrw.CurncyCode;
        newIVCashrw.FrRate = IVCashrw.FrRate;
        newIVCashrw.ToRateB1 = IVCashrw.ToRateB1;
        newIVCashrw.ToRateB2 = IVCashrw.ToRateB2;
        newIVCashrw.BaseRate1 = IVCashrw.BaseRate1;
        newIVCashrw.BaseRate2 = IVCashrw.BaseRate2;  
        newIVCashrw.VoidedRowNr = -1;
        newIVCashrw.Sign = "";
        newIVCashrw.VoidedSign = "";
        newIVCashrw.DiscApprovedBy = "";
        newIVCashrw.ChequeNr = "";
        newIVCashrw.CheckNr = IVCashrw.CheckNr ;
        newIVCashrw.SplitArtCode = IVCashrw.SplitArtCode;
        newIVCashrw.SplitFactor = IVCashrw.SplitFactor;
        newIVCashrw.SplitArtName = IVCashrw.SplitArtName;
        newIVCashrw.SplitQuant = IVCashrw.SplitQuant;
        newIVCashrw.MBRCode = IVCashrw.MBRCode;
        newIVCashrw.OrgIVNr = IVCashrw.OrgIVNr;
        newIVCashrw.Points = IVCashrw.Points ;
        newIVCashrw.SalesAssistant = IVCashrw.SalesAssistant;
        newIVCashrw.TaxTemplateCode = IVCashrw.TaxTemplateCode;
        newIVCashrw.TaxMatrix = IVCashrw.TaxMatrix;
        newIVCashrw.CCTransID = "";
        newIVCashrw.CCTimestamp = "";
        newIVCashrw.MotherArtCode = "";
        newIVCashrw.RecipeQuant = -1;
        newIVCashrw.CustArtCode = IVCashrw.CustArtCode;
        newIVCashrw.StandProblemCode = IVCashrw.StandProblemCode;
        newIVCashrw.Salesmen = IVCashrw.Salesmen;
        newIVCashrw.MotherNr = IVCashrw.MotherNr;
        newIVCashrw.AEStatus = IVCashrw.AEStatus;
        newIVCashrw.Location = IVCashrw.Location;
        newIVCashrw.SecondarySerialNr = -1;
        newIVCashrw.AlternateDeviceID = -1;
        newIVCashrw.MotherSecondarySerialNr = -1;
        newIVCashrw.MotherAlternateDeviceID  = -1;
        newIVCashrw.CCReceiptNr = -1;
        newIVCashrw.RvrsVATCode = "";
        newIVCashrw.SHNr = -1;
        newIVCashrw.SHRow = -1;
        MatRowPut(newIVCashr,i,newIVCashrw);
    end;
    Skiprow:;
  end;  
  IVCashSumup(newIVCashr,true);
  newIVCashr.OfficialSerNr = "";
  newIVCashr.OfficialSerNr2 = "";
  newIVCashr.LocalMachineCode = CurMachineName;
  newIVCashr.DrawerCode = CurDrawerCode(newIVCashr.LocalMachineCode);
  newIVCashr.TerminalID = CurTerminalID;
  newIVCashr.BranchID = CurBranchID;
  newIVCashr.Objects = AddObjectToObjectList(newIVCashr.Objects,GetObjectFromRestIT(newIVCashr.LocalMachineCode));        
  newIVCashr.FiscalDeviceSeqNr = -1;
  newIVCashr.LoyaltyCardNr = "";
  newIVCashr.LCMLevel = IVCashr.LCMLevel;
  newIVCashr.Hash = "";
  newIVCashr.HashKeyVersion = 0;  
  POSAudit_LogIVCashVc(newIVCashr,newIVCashr,kPOSEventTypeNewRecord);
   
  nwn = OpenWindow("NPTSIVCashDClass",1,0,"","",newIVCashr);
  SetWindowState(nwn,Rs_insert);
  PutWindowRecord(nwn,newIVCashr);
LIVCashDClassTouchScreenDuplicateIVCash:;  
  return;
end;

global
procedure IVCashDClassTouchScreenResumeSales()
begin
  array record IVCashVc aIVCashr;
  record IVCashVc IVCashr;
  record RcVc RepSpec;
  Integer wn,i;
  
  wn = CurWindow;
  PausedPOInvoices(CurrentUser,aIVCashr);
  if (aIVCashr.length==0) then begin
    goto LIVCashDClassTouchScreenResumeSales;
  end;
  CloseWindow(wn);
  if (aIVCashr.length>1) then begin
    wn = OpenWindow("PausedIVCashLClass",0,0,"","",RepSpec);
    if (wn>0) then begin
      for (i=0;i<aIVCashr.length;i=i+1) begin
        RecordCopy(IVCashr,aIVCashr[i]);
        AddListRow(wn,"pausedsales",1,IVCashr.SerNr,0);
        AddListData(wn,"pausedsales","nr",IVCashr.SerNr);
        AddListData(wn,"pausedsales","custcode",IVCashr.CustCode);
        AddListData(wn,"pausedsales","date",IVCashr.InvDate);
      end;      
//      ReRunWindowDef(wn);
      StringListScrollBottom(wn);
      SetSelectedListLine(wn,0);
    end;
  end else begin
    RecordCopy(IVCashr,aIVCashr[0]);
    wn = OpenWindow("NPTSIVCashDClass",0,0,"","",IVCashr);
    WindowFieldGotoForTouchScreen(wn,-1,"ivcashcommand",false);
  end;
LIVCashDClassTouchScreenResumeSales:;  
  return;
end;

global
function Boolean PausedIVCashLClassOnOKWindow(Integer wn)
begin
  Integer nwn;
  record IVCashVc IVCashr;

  IVCashr.SerNr = StringToLongInt(GetListString(wn,SelectedListLine(wn)));
  if (ReadFirstMain(IVCashr,1,true)) then begin
    nwn = OpenWindow("NPTSIVCashDClass",0,0,"","",IVCashr);
    WindowFieldGotoForTouchScreen(nwn,-1,"ivcashcommand",false);
  end;
  CloseWindow(wn);
  PausedIVCashLClassOnOKWindow = false;
  return;
end;

global
updating procedure ProceedOfficialSerNrNPTSSClassExecute(Integer wn)
begin
  Integer mwn,nwn,rownr;
  record RcVc RepSpec;
  record RcVc newRepSpec;
  record IVCashVc IVCashr;
  record IVCashVc prevIVCashr;
  string 255 tstr,t2;
  record LegalInvNrBlock LINrb;
  row LegalInvNrBlock LINrbrw;
  Integer i,rwcnt;
  Boolean testf;
  
  DeselectWindow(wn,true);
  mwn = MotherWindow(wn);
  if (mwn!=0) then begin
    GetWindowRecord(wn,RepSpec);
    switch (GetWindowFileName(mwn)) begin
      case "IVCashVc":
        DeselectWindow(mwn,false);
        GetWindowRecord(mwn,IVCashr);
        switch (WindowState(mwn)) begin
          case Rs_update:
            GetPrevWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedOfficialSerNrNPTSSClass;
            end;
          case Rs_normal:
            GetWindowRecord(mwn,prevIVCashr);
            if (prevIVCashr.OKFlag!=0) then begin
              CloseWindow(wn);
              goto LProceedOfficialSerNrNPTSSClass;
            end;
        end;
        PrepareOfficialSerialNrBlock(kOfficialNumTypePOSIVVc,LINrb);
        PrepareOfficialSerialNrBlock(kOfficialNumTypeManualPOSIVVc,LINrb);
        PrepareOfficialSerialNrBlock(kOfficialNumTypeRecoverdPOSIVVc,LINrb);
        testf = false;
        rwcnt = MatRowCnt(LINrb);
        for (i=0;i<rwcnt;i=i+1) begin
          MatRowGet(LINrb,i,LINrbrw);
          IVCashr.OfficialSerNr = RepSpec.f1;
          testf = TestNextOfficialSerialNr_IVCashVc(LINrbrw,"",IVCashr,false);
          if (testf) then begin
            i = rwcnt;
          end;
        end;
        if (testf==false) then begin
          IVCashr.OfficialSerNr = "";
          MessageBox(39190,"");
          goto LProceedOfficialSerNrNPTSSClass;
        end;

        IVCashr.OfficialSerNr = RepSpec.f1;
        IVCashr.Status = kRecordStatusManual;
        PutWindowRecord(mwn,IVCashr);
        ReRunWindowDef(mwn);
        WindowDoOK(mwn,0);
        CloseWindow(wn);
    end;
  end;
LProceedOfficialSerNrNPTSSClass:;  
  WindowFieldGotoForTouchScreen(mwn,-1,"ivcashcommand",true); 
  return;
end;

