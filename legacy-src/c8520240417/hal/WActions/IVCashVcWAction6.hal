global
function Integer IVCashPOSButtonAutoFinish(Integer wn)
begin
  Integer res;
  record CashierDefBlock CDb;

  res = GetWindowInteger(wn,"POSAutoFinish");

  if (res==kPOSButtonAutoFinishDefault) then begin
    BlockLoad(CDb);
    if (CDb.IVCashAutoFinish) then begin
      res = kPOSButtonAutoFinishYes;
    end else begin
      res = kPOSButtonAutoFinishNo;
    end;
  end;

  IVCashPOSButtonAutoFinish = res;
  return;
end;

global
function Integer RestAccPOSButtonAutoFinish(Integer wn)
begin
  Integer res;
  record CashierDefBlock CDb;

  res = GetWindowInteger(wn,"POSAutoFinish");

  if (res==kPOSButtonAutoFinishDefault) then begin
    BlockLoad(CDb);
    if (CDb.RestAccAutoFinish) then begin
      res = kPOSButtonAutoFinishYes;
    end else begin
      res = kPOSButtonAutoFinishNo;
    end;
  end;

  RestAccPOSButtonAutoFinish = res;
  return;
end;

global 
procedure SelectHWStoreWClass()
begin
  Integer wn;
  
  if (IsStandardProduct) then begin
    wn = FindWindow("HWStoreWClass");
    if (wn>0) then begin
      SelectWindow(wn);
    end;
  end;
  return;
end;

global
procedure SetPOSWindowDisplay_PaymentRow(string spec,val v)
begin
  string 255 tstr;
  
  if (v<0) then begin
    tstr = USetStr(24193) & "   " & ValToString(-v,M4Val,ThousandSeparator,DecimalSeparator,0);
    SetPOSWindowDisplay(spec,tstr);
  end else begin
    tstr = USetStr(24193) & "   " & ValToString(0.00,M4Val,ThousandSeparator,DecimalSeparator,0);
    SetPOSWindowDisplay("",tstr);
  end;
  return;
end;

updating procedure OpenNewIVCash(Integer mwn)
begin
  record IVCashVc IVCr;
  val prevRetValue;
  string 255 tstr;

  GetWindowRecord(mwn,IVCr);
  IVCashDClass_RefreshStringList(mwn,IVCr);
  prevRetValue = IVCr.RetValue;
  WindowDoNew(mwn,0);
  GetWindowRecord(mwn,IVCr);
  IVCr.RetValue = prevRetValue;
  PutWindowString(mwn,"touchscreenwindowpage",1);
  PutWindowString(mwn,"touchscreenwindowpagestack","1");
  PutWindowString(mwn,"touchscreenwindowprinterstack","*");
  PutWindowString(mwn,"CustomerDisplayData_Line1","");
  PutWindowString(mwn,"CustomerDisplayData_Line2","");    
  PutWindowString(mwn,"touchscreenitemlastrownr",-1);
  PutWindowString(mwn,"ReturnMode","false");
  tstr = USetStr(24172) & "  ";
  tstr = tstr & ValToString(prevRetValue,M4Val,ThousandSeparator,DecimalSeparator,0);
  SetPOSWindowDisplay("",tstr);
  PutWindowRecord(mwn,IVCr);
  IVCashDClass_RefreshStringList(mwn,IVCr);
  return;
end;

