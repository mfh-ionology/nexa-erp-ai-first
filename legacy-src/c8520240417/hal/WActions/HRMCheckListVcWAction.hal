global
function Boolean HRMCheckListDClassAfterEditField(Integer wn,string fieldname,Integer fn, Integer rownr,Integer changed)
begin
  Boolean res;

  switch (fieldname) begin
    case "Employee":   res = HRMCheckListDClassEmployeeEFAfter(wn,changed!=0);
    case "Superior":   res = HRMCheckListDClassSuperiorEFAfter(wn,changed!=0);
    case "CheckPoint": res = HRMCheckListDClassCheckPointEFAfter(wn,rownr,changed!=0);
    case "CheckPointComment": res = HRMCheckListDClassCheckPointCommentEFAfter(wn,rownr,changed!=0);
    case "Status":     res = HRMCheckListDClassStatusEFAfter(wn,rownr,changed!=0);
    case "Responsible":res = HRMCheckListDClassResponsibleEFAfter(wn,rownr,changed!=0);
    case "JobTitle":   res = HRMCheckListDClassJobTitleEFAfter(wn,changed!=0);
  end;
  HRMCheckListDClassAfterEditField = res;
  return;
end;

