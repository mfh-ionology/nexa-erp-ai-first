global 
updating procedure CreateMailFromHRMCheckListDsm()
BEGIN
  Integer wn,nwn;
  record MailVc Mailr;
  record HRMCheckListVc HRMCheckListr;
  Integer err;

  wn = CurWindow;
  if (WindowState(wn)==0)then begin//Rs_normal
    GetWindowRecord(wn,HRMCheckListr);  
    err = CreateMailFromHRMCheckList(HRMCheckListr,Mailr);
    if (err!=0) then begin
      if (err>0) then begin
        MessageBox(err,"");
      end;
    end else begin
      nwn = OpenWindow("MailDClass",1,0,"","",Mailr);
    end;
  end;
  return;
end;
