global
function Boolean CCMerchantIDSClassCommandNew(Integer wn)
begin
  Integer mwn,wn2;
  record CCMerchantIDVc CCMerchantIDr;
  record CCMerchantIDVc oldCCMerchantIDr;
  mwn = MotherWindow(wn);
  CloseWindow(wn);
  RecordNew(CCMerchantIDr);
  oldCCMerchantIDr.Code = CCMerchantIDr.Code;
  if (ReadFirstMain(oldCCMerchantIDr,1,true)) then begin CCMerchantIDr.Code = ""; end;
  wn2 = OpenWindow("CCMerchantIDDClass",1,mwn,"","",CCMerchantIDr);  
  CUDClassBeforeEditField(wn2,"Code",1,-1);
  CCMerchantIDSClassCommandNew = true;
  return;
end;
