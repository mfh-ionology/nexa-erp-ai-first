global
function Boolean GenPerTRVClassOnOKWindow(Integer wn)
begin
  record RcVc RepSpec;
  Boolean res;

  res = true;
  
  DeselectWindow(wn,true);
  GetWindowRecord(wn,RepSpec);
  
  if (blank(RepSpec.d1)) then begin
    res = false;
    MessageBox(42500,"");
  end;

  GenPerTRVClassOnOKWindow = res;
  return;
end;


