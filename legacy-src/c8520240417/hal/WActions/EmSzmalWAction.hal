remote function boolean emSzmalDoSecondPhaseAuthenticationData(string,string,string,string,string);
remote procedure emSzmalGetAccountHistory(record RcVc,integer);
remote procedure emSzmalGetAccountsList(record BankVc);
remote procedure DoEmSzmalStartSessionRemote(Integer);
remote function LongInt DateDiff(Date,Date);

procedure emSzmalStartSession(Integer sessiontype)
begin
  record EmSzmalBlock EmSzmalBl;
  integer wn;

  BlockLoad(EmSzmalBl);
  wn = CurWindow;
  if (blank(EmSzmalBl.ApiId)) then begin
    MessageBox(0,USetStr(42960));
    goto LemSzmalStartSession;
  end;
  if (blank(EmSzmalBl.ApiKey)) then begin
    MessageBox(0,USetStr(42961));
    goto LemSzmalStartSession;
  end;

  DoEmSzmalStartSessionRemote(sessiontype);
LemSzmalStartSession:;
  return;
end;

global
procedure emSzmalSubmitAuthCode()
begin
  integer wn,nwn,wn2;
  record RcVc RepSpec;
  record BankVc Bankr;
  wn = FindWindow("EmSzmalAuthCodeOClass");
  DeselectWindow(wn,false);
  GetWindowRecord(wn,RepSpec);

  wn2 = FindWindow("BankDClass");
  DeselectWindow(wn2,false);
  GetWindowRecord(wn2,Bankr); 
  
  emSzmalDoSecondPhaseAuthenticationData(RepSpec.f1,Bankr.emSzmalBankLogin,Bankr.emSzmalBankPassword,Bankr.emSzmalBankProvider,Bankr.emSzmalBankUserContext);
  CloseWIndow(wn);
  return;
end;

global
procedure emSzmalSubmitAuthCode2()
begin
  integer wn,nwn,wn2;
  record RcVc RepSpec;
  record BankVc Bankr;
  record RcVc RepSpec2;
  string 255 accountnr,bankname,pmmode;
  record PMBlock PMBl;
  row PMBlock PMBlrw;
  Integer rwcnt,i;
  Boolean testf;

  testf = false;
  BlockLoad(PMBl);

  wn = CurWindow;
  DeselectWindow(wn,false);
  GetWindowRecord(wn,RepSpec);
  pmmode = GetWindowString(FindWindow("BankAccountReconWClass"),"gAccRcn_vpmaccnr");
  rwcnt = MatRowCnt(PMBl);
  for (i=0 ;i<rwcnt;i=i+1) begin
    MatRowGet(PMBl,i,PMBlrw);
    if (PMBlrw.AccNr==pmmode) then begin
      accountnr = PMBlrw.BankNr;
      bankname = PMBlrw.BankCode;
      goto LemSzmalSubmitAuthCode2;
    end;
  end;
  LemSzmalSubmitAuthCode2:;

  Bankr.Code = bankname;
  if (ReadFirstMain(Bankr,1,true)) begin 
    if (Bankr.Nr2 == accountnr) then begin
       testf = true;
    end;
  end;
  if (testf) then begin
    emSzmalDoSecondPhaseAuthenticationData(RepSpec.f1,Bankr.emSzmalBankLogin,Bankr.emSzmalBankPassword,Bankr.emSzmalBankProvider,Bankr.emSzmalBankUserContext);
  end;
  CloseWIndow(wn);
  return;
end;


global
procedure emSzmalGetAccountsListDsm()
begin
  record BankVc Bankr;
  integer wn,nwn;

  wn = CurWindow;
  DeselectWindow(wn,false);
  GetWindowRecord(wn,Bankr); 
  emSzmalGetAccountsList(Bankr);
  return;
end;

global
procedure EmSzmalAuthCodesm()
begin
  integer wn,nwn;
  record RcVc RepSpec;

  wn = CurWindow;
  nwn = OpenWindow("EmSzmalAuthCodeOClass",1,wn,"","",RepSpec);
  return;
end;

global
procedure EmSzmalAuthCode2sm()
begin
  integer wn,nwn;
  record RcVc RepSpec;

  wn = CurWindow;
  nwn = OpenWindow("EmSzmalAuthCode2OClass",1,wn,"","",RepSpec);
  return;
