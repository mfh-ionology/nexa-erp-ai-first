global
procedure EmSzmalBalancesm()
begin
  emSzmalStartSession(1);
  return;
end;

global
procedure EmSzmalHistorysm()
begin
  integer wn,nwn;
  record RcVc RepSpec;
  record BankVc Bankr;
  record EmSzmalBlock EmSzmalBl;

  emSzmalStartSession(0);
  BlockLoad(EmSzmalBl);
  if (nonblank(EmSzmalBl.SessionId)) then begin
    wn = CurWindow;
    GetWindowRecord(wn,Bankr);
    if (blank(Bankr.Nr2)) then begin
      MessageBox(0,USetStr(42966));
      goto LEmSzmalHistorysm;
    end;
    if (blank(Bankr.emSzmalBankLogin)) then begin
      MessageBox(0,USetStr(42965));
      goto LEmSzmalHistorysm;
    end;
    if (blank(Bankr.emSzmalBankPassword)) then begin
      MessageBox(0,USetStr(42964));
      goto LEmSzmalHistorysm;
    end;
    if (blank(Bankr.emSzmalBankProvider)) then begin
      MessageBox(0,USetStr(42963));
      goto LEmSzmalHistorysm;
    end;
    RepSpec.f1 = Bankr.Nr2;
    RepSpec.f2 = Bankr.emSzmalBankLogin;
    RepSpec.f3 = Bankr.emSzmalBankPassword;
    RepSpec.f4 = Bankr.emSzmalBankProvider;
    RepSpec.flags[0] = Bankr.SkipSms;
    RepSpec.f5 = Bankr.emSzmalBankUserContext;
    nwn = OpenWindow("EmSzmalAccountHistoryPeriodOClass",0,wn,"","",RepSpec);
  end;
LEmSzmalHistorysm:;
  return;
end;

global
procedure EmSzmalHistoryRequestDsm()
begin
  integer wn,oldwn;
  record RcVc RepSpec;
  record BankVc Bankr;

  wn = FindWindow("EmSzmalAccountHistoryPeriodOClass");
  DeselectWindow(wn,false);
  GetWindowRecord(wn,RepSpec);
  if (DateDiff(RepSpec.sEndDate,RepSpec.sStartDate)>7) then begin
    MessageBox(42972,"");
    goto LEmSzmalHistoryRequestDsm;
  end;
  if (DateDiff(RepSpec.sStartDate,CurrentDate)>30) then begin
    MessageBox(42976,"");
    goto LEmSzmalHistoryRequestDsm;
  end;
  CloseWindow(wn);
  emSzmalGetAccountHistory(RepSpec,0);
LEmSzmalHistoryRequestDsm:;
  return;
end;