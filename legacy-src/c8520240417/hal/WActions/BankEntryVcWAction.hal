global
updating procedure BudEntryDClassPost()
begin
  record BudEntryVc BEr;
  Integer wn;

  wn = CurWindow;
  GetWindowRecord(wn,BEr);
  if (blank(BEr.BFCode)) then begin
    MessageBox(1058,"");
    WindowFieldGoto(wn,BEr,-1,"BFCode",true);
    goto LBudEntryDClassPost;
  end; 
  BudEntryDClassPostRemote(BEr);
LBudEntryDClassPost:;  
  return;
end;