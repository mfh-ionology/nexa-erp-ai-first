remote procedure BudEntryDClass_OnOpenWindow(var record BudEntryVc);
remote updating function LongInt BudEntryDClassPostRemote(var record BudEntryVc);
remote procedure BudEntryDClass_AddVal(var record BudEntryVc,Integer);
remote procedure BudEntryDClass_PasteFormula(var record BudEntryVc,Integer);
remote procedure BudEntryDClass_Sumup(var record BudEntryVc,Boolean,Boolean);
remote procedure BudEntryDClass_PastePeriod2Str(var record BudEntryVc);
remote procedure BudEntryDClass_PasteAccNumber(var record BudEntryVc,Integer);

global 
function Boolean BudEntryDClassDeleteRowTest(Integer wn,Integer rownr)
begin
  Boolean res;

  res = false;
  BudEntryDClassDeleteRowTest = res;
  return;
end;

