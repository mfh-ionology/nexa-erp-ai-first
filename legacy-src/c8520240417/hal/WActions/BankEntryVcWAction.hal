  return;
end;

global
function Boolean BudEntryDClassActiveEditField(Integer wn,string fieldname,Integer fn,Integer wnst,Integer rownr,Integer changed)
begin
  Boolean res;
  
  res = true;
  if (rownr>=0) then begin  
    switch (fieldname) begin
      case "NewBudVal": res = false;
    end;
  end;
  BudEntryDClassActiveEditField = res;
  return;
end;

function Boolean BudEntryDClassAccNumberEFAfter(Integer wn,Integer rownr,Boolean changedf)
begin
  record BudEntryVc BEr;
  Boolean res;

  if (changedf) then begin
    GetWindowRecord(wn,BEr);
    BudEntryDClass_PasteAccNumber(BEr,rownr);
    PutWindowRecord(wn,BEr);
  end;  
  BudEntryDClassAccNumberEFAfter = res;
  return;
end;

