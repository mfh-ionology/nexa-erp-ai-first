global
function Boolean BudEntryDClassAfterEditField(Integer wn,string fieldname,Integer fn, Integer rownr,Integer changed)
begin
  Boolean res;

  switch (fieldname) begin
    case "Period2Str": res = BudEntryDClassPeriod2StrEFAfter(wn,changed!=0);
    case "AccNumber": res = BudEntryDClassAccNumberEFAfter(wn,rownr,changed!=0);
    case "Objects": res = BudEntryDClassObjectsEFAfter(wn,changed!=0);
    case "BudgetClass": res = BudEntryDClassBudgetClassEFAfter(wn,changed!=0);
    case "AddVal": res = BudEntryDClassAddValEFAfter(wn,rownr,changed!=0);
    case "Formula": res = BudEntryDClassFormulaEFAfter(wn,rownr,changed!=0);
  end;
  BudEntryDClassAfterEditField = res;
  return;
end;

