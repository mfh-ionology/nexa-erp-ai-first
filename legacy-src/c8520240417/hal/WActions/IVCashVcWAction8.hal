external procedure POSAudit_WindowOpen(Integer);
external procedure POSAudit_WindowClose(Integer);

global
function Boolean POSEventDClassOnOpenWindow(Integer wn)
begin
  Boolean res;

  POSAudit_WindowOpen(wn);
  POSEventDClassOnOpenWindow = res;
  return;
end;

global
function Boolean POSEventDClassOnCloseWindow(integer wn)
begin
  POSAudit_WindowClose(wn);
  POSEventDClassOnCloseWindow = true;
  return;
end;

