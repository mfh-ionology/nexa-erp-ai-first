global
function Boolean CCPayVerifoneProcessingWClassOnCloseWindow(integer wn)
begin
  POSAudit_WindowClose(wn);
  CCPayVerifoneProcessingWClassOnCloseWindow = true;
  return;
end;

global
function Boolean CCPayVerifoneProcessingWClassOnClose(Integer wn,Integer wn2)
begin
  Boolean noclosingf;
  record RcVc RepSpec;
  
  GetWindowRecord(wn,RepSpec);
  noclosingf = false;
  if (RepSpec.UsedOnly==kLocalCCTerminalWorldPay or RepSpec.UsedOnly==kLocalCCTerminalSmartPay or RepSpec.UsedOnly==kLocalCCTerminalVerifoneBanksys or RepSpec.UsedOnly==kLocalCCTerminalIngenicoiCT220) then begin
    noclosingf = GetWindowString(wn,"ProcessingFinished")=="false";
  end;
  CCPayVerifoneProcessingWClassOnClose = noclosingf;
  return;
end;

