external function Boolean CheckEmailStr(string);
external procedure ExtractObjWithSeparator(string,string,Boolean,var Integer,var string);
remote procedure CostPocketSubscribe(var record CostPocketBlock,var LongInt);
remote procedure DoCostPocketGetDataRequest(var LongInt,var string);
remote procedure DoCostPocketGetReportRequest(var LongInt,var string);
remote procedure CostPocketUnSubscribe(var record CostPocketBlock,var LongInt,var string);

function Boolean IsValidUserName(string userName)
begin
  boolean res;
  string 255 firstName,lastName;
  integer pos;
  
  res = false;
  pos = 0;
  ExtractObjWithSeparator(" ",userName,false,pos,firstName);
  ExtractObjWithSeparator(" ",userName,false,pos,lastName);
  if (nonblank(firstName) and nonblank(lastName)) then begin
    res = true;
  end;
  IsValidUserName = res;
  return;
end;

global 
procedure CostPocketGetDataDsm()
begin
  Integer wn;
  Longint err;
  record CostPocketBlock CPb;
  string 255 errmsg;

  BlockLoad(CPb);

  wn = CurWindow;
  if (blank(CPb.APIId)) or (blank(CPb.APIToken)) then begin
    MessageBox(43169,"");
    goto LCostPocketGetDataDsm;
  end;

  DoCostPocketGetDataRequest(err,errmsg);

  if (err!=-1) then begin
    if (nonblank(errmsg)) then begin
      MessageBox(err,errmsg);
    end else begin
      MessageBox(err,"");
    end;
  goto LCostPocketGetDataDsm;
  end;
  
  if (err==-1) then begin
    CheckmarkBox(43168,"");
  end;

LCostPocketGetDataDsm:;
  return;
end;

