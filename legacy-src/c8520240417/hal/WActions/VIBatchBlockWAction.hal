global
function Boolean VIBatchTClassAfterEditField(Integer wn,string fieldname,Integer fn,Integer rownr,Integer changed)
begin
  Boolean res;
  
  res = false;
  switch (fieldname) begin
    case "VECode": res = VIBatchTClassVECodeEFAfter(wn,fn,rownr,changed!=0);
    case "PayDeal": res = VIBatchTClassPayDealEFAfter(wn,fn,rownr,changed!=0);
    case "InvDate": res = VIBatchTClassInvDateEFAfter(wn,fn,rownr,changed!=0);
    case "AccNumber": res = VIBatchTClassAccNumberEFAfter(wn,fn,rownr,changed!=0);
  end;

  VIBatchTClassAfterEditField = res;
  return;
end;
