// caengdb.hal To build Standard Books

begin
  SetLangMode(LangEnglish,"ENG",2);

  SetBuildProductCode("StandardBooksExcellent"); // Do not translate
  SetBuildProgramType(typBooks);
  SetWhiteLabelProduct(true);
  
  CreateInitObj(typBooks,kProductStandardBooksExcellent,kLicenseModeClient);
  
  Exec_File("english/caengdb-stdcommon.hal");
  
  return;
end;
