// caengdb.hal To build Standard Accounts

begin
  SetLangMode(LangEnglish,"ENG",2);

  SetBuildProductCode("StandardHealthcare"); // Do not translate
  SetBuildProgramType(typBooks);
    
  CreateInitObj(typBooks,kProductStandardHealthcare,kLicenseModeClient);
  
  Exec_File("english/caengdb-stdcommon.hal");
  
  return;
end;
