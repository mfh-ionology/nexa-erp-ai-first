  RecordField(scope,M4Str,255,0);
  RecordField(acr_values,M4Str,255,0);
  RecordField(response_type,M4Str,255,0);
  RecordField(redirect_uri,M4Str,255,0);
  RecordField(code_verifier,M4Str,255,0);
  RecordField(code_challenge_method,M4Str,255,0);
  RecordField(code_challenge,M4Str,255,0);
  RecordField(token,M4MlStr,255,0);
  //RecordField(code_challenge_method,M4Str,255,0);
  //RecordField(code_verifier,M4Str,255,0);
  // nonce
  MainKeyBegin(state,0);
  KeySegment(state);
  EndRecord;

  RecordBegin(SavedLLMScoreVc,-,"");
  RecordField(Tag,M4Str,255,0);
  RecordField(TagCode,M4Str,255,0);
  RecordField(Example,M4Str,255,0);
  RecordField(Embedding,M4Str,255,0);
  MainKeyBegin(MainKey,0);
  KeySegment(Tag);
  KeySegment(TagCode);
  EndRecord;

  RecordBegin(X509AttributesVc,-,"");
  VirtualRegister;
  RecordField(CountryName,M4Str,255,0);
  RecordField(StateOrProvinceName,M4Str,255,0);
  RecordField(Locality,M4Str,255,0);
  RecordField(Organization,M4Str,255,0);
  RecordField(CommonName,M4Str,255,0);
  RecordField(OrganizationalUnit,M4Str,255,0);
  RecordField(CertificateSerialNumber,M4Str,255,0);
  RecordField(EmailAddress,M4Str,255,0);
  RecordField(Title,M4Str,255,0);
  RecordField(DomainComponent,M4Str,255,0);
  RecordField(Street,M4Str,255,0);
  RecordField(PostalCode,M4Str,255,0);
  RecordField(HostName,M4Str,255,0);
  RecordField(IpAddress,M4Str,255,0);
  RecordField(DistinguishedNameQualifier,M4Str,255,0);
  EndRecord;
    
  BlockBegin(EInvoiceSessionBlock,-,"");
  RecordField(SessionToken,M4Str,0,0);
  RecordField(CreatedTimestamp,M4Str,0,0);
  RecordField(LastUpdatedTimestamp,M4Str,0,0);
  RecordField(SessionRefNum,M4Str,0,0);
  EndBlock;

  BlockBegin(HRPortalBlock,-,"");
  BlockInServer;
  BlockForAllCompanies;
  RecordField(Active,M4Int,0,0);
  RecordField(PageLogin,M4Code,20,0);
  RecordField(PageApp,M4Code,20,0);
  EndBlock;

  return;
end;
