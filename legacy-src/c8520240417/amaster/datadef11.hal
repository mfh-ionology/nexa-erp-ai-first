/* datadef11.hal */

procedure DefineUniversityURLVcHeader()
begin
  NewAutosyncRegister(kSyncDirectionFull,false);
  RecordField(WindowName,M4Str,255,0);
  RecordField(URL,M4Str,255,0);
  RecordField(State,M4Set,407,0);
  RecordField(UDate,M4Date,0,0); // cache validated time on client, change time on server
  RecordField(UTime,M4Time,0,0);
  RecordField(Math,M4Matrix,0,0);  
end;

procedure DefineUniversityURLVcMath()
begin
  ArrayBegin(Math,-,1);
  ArrayField(Property,M4StrSet,408,0);
  ArrayField(Value,M4Str,255,0);
  ArrayField(ProductCode,M4StrSet,546,0); // SetBuildProductCode
  EndArray; 
end;

procedure DefineUniversityURLVcKeys()
begin
  MainKeyBegin(MainKey,0);
  KeySegment(UUID);
  KeyBegin(WindowName);
  KeySegment(WindowName);
  KeySegment(UUID);
  KeyBegin(State);
  KeySegment(State);
  KeySegment(UUID);
end;

procedure SerialPortDeviceDefinition()
begin
  RecordField(Code,M4Code,10,0);
  RecordField(DeviceType,M4Set,413,0);
  RecordField(LocalMachineCode,M4Code,20,0);
  RecordField(Printer,M4Set,415,0);
  RecordField(Port,M4Str,100,0);
  RecordField(BaudRate,M4Long,0,0);
  RecordField(ByteSize,M4Int,0,0);
  RecordField(Parity,M4Int,0,0);
  RecordField(StopBits,M4Int,0,0);
  RecordField(Codepage,M4StrSet,-1,0);
  RecordField(FlowControl,M4Set,414,0);
  RecordField(EscSeqBefore,M4Str,100,0);
  RecordField(EscSeqAfter,M4Str,100,0);
  RecordField(FailureCode,M4Code,10,SerialPortDeviceVc);
  RecordField(UseHttps,M4Int,0,0);
  RecordField(Password,M4Str,20,0);  
  RecordField(LogCommunication,M4Int,0,0);
  RecordField(DeviceID,M4Str,30,0);
  return;
end;

procedure DefineUnOkWarnFields()
begin
  RecordField(IVWarn,M4Int,0,0);
  RecordField(IPWarn,M4Int,0,0);
  RecordField(VIWarn,M4Int,0,0);
  RecordField(OPWarn,M4Int,0,0);
  RecordField(PUWarn,M4Int,0,0);
  RecordField(SHWarn,M4Int,0,0);
  RecordField(StockMovWarn,M4Int,0,0);
  RecordField(SDWarn,M4Int,0,0);
  RecordField(RetWarn,M4Int,0,0);
  RecordField(RetPUWarn,M4Int,0,0);
  RecordField(CLInWarn,M4Int,0,0);
  RecordField(CLOutWarn,M4Int,0,0);
  return;
end;

