# Auto-BMAD Secrets Configuration
# Copy this file to .bmad-secrets in your project root and fill in your values
# DO NOT commit .bmad-secrets to version control

# Slack Webhook URL for notifications
# Get this from: Slack App > Incoming Webhooks > Add New Webhook
BMAD_SLACK_WEBHOOK="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# Enable/disable Slack notifications (true/false)
BMAD_SLACK_ENABLED="true"

# Optional: Discord webhook (future support)
# BMAD_DISCORD_WEBHOOK=""

# Optional: Email configuration (future support)
# BMAD_EMAIL_SMTP=""
# BMAD_EMAIL_TO=""
