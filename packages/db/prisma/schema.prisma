generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Base Models — E1.1 Schema Foundation
// ---------------------------------------------------------------------------
// Conventions (Architecture §2.3):
//   - UUID PKs: id String @id @default(uuid())
//   - Natural keys where appropriate (Currency.code, Country.code)
//   - snake_case DB mapping: @@map("table_name"), @map("column_name")
//   - Timestamps: createdAt/updatedAt on every model
//   - Audit: createdBy/updatedBy on mutable models
//   - isActive on reference entities (soft-delete pattern §2.3.1)
//   - Monetary: Decimal @db.Decimal(19,4)
//   - Exchange rates: Decimal @db.Decimal(18,8)
//   - Quantities: Decimal @db.Decimal(10,4)
// ---------------------------------------------------------------------------

// Currency and Country are GLOBAL reference entities shared across all companies.
// They do NOT have a companyId field — this is an intentional exception to the
// "companyId on every table" rule (Architecture §2.3). Currencies and countries
// are ISO standards and are not tenant-scoped. Per-company FX rates are handled
// by ExchangeRate which IS tenant-scoped via companyId.
model Currency {
  code       String   @id @map("code") @db.VarChar(3)
  name       String   @map("name")
  symbol     String   @map("symbol")
  minorUnit  Int      @default(2) @map("minor_unit")
  roundTotal Int      @default(2) @map("round_total")
  roundVat   Int      @default(2) @map("round_vat")
  roundLine  Int      @default(2) @map("round_line")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  companyProfiles          CompanyProfile[]
  exchangeRates            ExchangeRate[]
  countriesWithThisDefault Country[]        @relation("CountryDefaultCurrency")

  @@map("currencies")
}

model Country {
  code                String   @id @map("code") @db.VarChar(2)
  iso3Code            String   @map("iso3_code") @db.VarChar(3)
  name                String   @map("name")
  defaultCurrencyCode String?  @map("default_currency_code") @db.VarChar(3)
  region              String?  @map("region")
  vatPrefix           String?  @map("vat_prefix")
  dateFormat          String?  @map("date_format")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  defaultCurrency Currency?        @relation("CountryDefaultCurrency", fields: [defaultCurrencyCode], references: [code])
  companyProfiles CompanyProfile[]
  bankHolidays    BankHoliday[]

  @@map("countries")
}

enum ExchangeRateSource {
  BOE
  ECB
  MANUAL

  @@map("exchange_rate_source")
}

model ExchangeRate {
  id           String             @id @default(uuid()) @map("id")
  companyId    String             @map("company_id")
  currencyCode String             @map("currency_code") @db.VarChar(3)
  rateDate     DateTime           @map("rate_date") @db.Date
  buyRate      Decimal            @map("buy_rate") @db.Decimal(18, 8)
  sellRate     Decimal            @map("sell_rate") @db.Decimal(18, 8)
  midRate      Decimal            @map("mid_rate") @db.Decimal(18, 8)
  source       ExchangeRateSource @map("source")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company  CompanyProfile @relation(fields: [companyId], references: [id])
  currency Currency       @relation(fields: [currencyCode], references: [code])

  @@unique([companyId, currencyCode, rateDate], map: "uq_exchange_rates_company_currency_date")
  @@index([companyId], map: "idx_exchange_rates_company_id")
  @@map("exchange_rates")
}

model Department {
  id         String  @id @default(uuid()) @map("id")
  companyId  String  @map("company_id")
  code       String  @map("code")
  name       String  @map("name")
  costCentre String? @map("cost_centre")
  managerId  String? @map("manager_id") // FK to User — added in E1-4
  isActive   Boolean @default(true) @map("is_active")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company CompanyProfile @relation(fields: [companyId], references: [id])
  manager User?          @relation("DepartmentManager", fields: [managerId], references: [id])

  @@unique([companyId, code], map: "uq_departments_company_code")
  @@index([companyId, isActive], map: "idx_departments_company_active")
  @@map("departments")
}

model PaymentTerms {
  id              String   @id @default(uuid()) @map("id")
  companyId       String   @map("company_id")
  code            String   @map("code")
  name            String   @map("name")
  dueDays         Int      @map("due_days")
  discountPercent Decimal? @map("discount_percent") @db.Decimal(5, 2)
  discountDays    Int?     @map("discount_days")
  isDefault       Boolean  @default(false) @map("is_default")
  isActive        Boolean  @default(true) @map("is_active")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company CompanyProfile @relation(fields: [companyId], references: [id])

  @@unique([companyId, code], map: "uq_payment_terms_company_code")
  @@index([companyId, isActive], map: "idx_payment_terms_company_active")
  @@map("payment_terms")
}

enum VatType {
  STANDARD
  REDUCED
  ZERO
  EXEMPT
  OUTSIDE_SCOPE
  REVERSE_CHARGE
  SECOND_HAND

  @@map("vat_type")
}

model VatCode {
  id                  String  @id @default(uuid()) @map("id")
  companyId           String  @map("company_id")
  code                String  @map("code")
  name                String  @map("name")
  rate                Decimal @map("rate") @db.Decimal(5, 2)
  type                VatType @map("type")
  salesAccountCode    String? @map("sales_account_code")
  purchaseAccountCode String? @map("purchase_account_code")
  isDefault           Boolean @default(false) @map("is_default")
  isActive            Boolean @default(true) @map("is_active")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company CompanyProfile @relation(fields: [companyId], references: [id])

  @@unique([companyId, code], map: "uq_vat_codes_company_code")
  @@index([companyId, isActive], map: "idx_vat_codes_company_active")
  @@map("vat_codes")
}

enum TagType {
  CUSTOMER
  ITEM
  ORDER
  GENERAL

  @@map("tag_type")
}

model Tag {
  id        String  @id @default(uuid()) @map("id")
  companyId String  @map("company_id")
  code      String  @map("code")
  name      String  @map("name")
  tagType   TagType @map("tag_type")
  color     String? @map("color") // hex colour
  isActive  Boolean @default(true) @map("is_active")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company CompanyProfile @relation(fields: [companyId], references: [id])

  @@unique([companyId, code, tagType], map: "uq_tags_company_code_type")
  @@index([companyId, isActive], map: "idx_tags_company_active")
  @@map("tags")
}

enum HolidayType {
  PUBLIC
  COMPANY
  SPECIAL

  @@map("holiday_type")
}

model BankHoliday {
  id          String      @id @default(uuid()) @map("id")
  companyId   String      @map("company_id")
  name        String      @map("name")
  date        DateTime    @map("date") @db.Date
  countryCode String      @map("country_code") @db.VarChar(2)
  holidayType HolidayType @map("holiday_type")
  isRecurring Boolean     @default(false) @map("is_recurring")
  isActive    Boolean     @default(true) @map("is_active")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company CompanyProfile @relation(fields: [companyId], references: [id])
  country Country        @relation(fields: [countryCode], references: [code])

  @@unique([companyId, date, countryCode], map: "uq_bank_holidays_company_date_country")
  @@index([companyId, isActive], map: "idx_bank_holidays_company_active")
  @@map("bank_holidays")
}

enum VatScheme {
  STANDARD
  FLAT_RATE
  CASH

  @@map("vat_scheme")
}

// CompanyProfile defines the company itself — its `id` IS the companyId that all
// other tenant-scoped tables reference. No self-referential companyId needed here.
model CompanyProfile {
  id                 String  @id @default(uuid()) @map("id")
  name               String  @map("name")
  legalName          String? @map("legal_name")
  registrationNumber String? @map("registration_number")
  vatNumber          String? @map("vat_number")
  utrNumber          String? @map("utr_number")
  natureOfBusiness   String? @map("nature_of_business")
  baseCurrencyCode   String  @default("GBP") @map("base_currency_code") @db.VarChar(3)
  isDefault          Boolean @default(false) @map("is_default")
  isActive           Boolean @default(true) @map("is_active")

  // Address
  addressLine1 String? @map("address_line_1")
  addressLine2 String? @map("address_line_2")
  city         String? @map("city")
  county       String? @map("county")
  postcode     String? @map("postcode")
  countryCode  String  @default("GB") @map("country_code") @db.VarChar(2)

  // Contact
  phone   String? @map("phone")
  email   String? @map("email")
  website String? @map("website")

  // Configuration
  timezone           String    @default("Europe/London") @map("timezone")
  weekStart          Int       @default(1) @map("week_start")
  dateFormat         String    @default("DD/MM/YYYY") @map("date_format")
  decimalSeparator   String    @default(".") @map("decimal_separator")
  thousandsSeparator String    @default(",") @map("thousands_separator")
  vatScheme          VatScheme @default(STANDARD) @map("vat_scheme")
  defaultLanguage    String    @default("en") @map("default_language")

  // Tax Agent
  taxAgentName  String? @map("tax_agent_name")
  taxAgentPhone String? @map("tax_agent_phone")
  taxAgentEmail String? @map("tax_agent_email")

  // Branding
  logoUrl String? @map("logo_url")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  // Relations
  baseCurrency         Currency              @relation(fields: [baseCurrencyCode], references: [code])
  country              Country               @relation(fields: [countryCode], references: [code])
  exchangeRates        ExchangeRate[]
  departments          Department[]
  paymentTerms         PaymentTerms[]
  vatCodes             VatCode[]
  tags                 Tag[]
  bankHolidays         BankHoliday[]
  systemSettings       SystemSetting[]
  sharingRulesAsSource RegisterSharingRule[] @relation("SharingSource")
  sharingRulesAsTarget RegisterSharingRule[] @relation("SharingTarget")
  userCompanyRoles     UserCompanyRole[]
  users                User[]
  numberSeries         NumberSeries[]
  accessGroups         AccessGroup[]
  userAccessGroups     UserAccessGroup[]
  auditLogs            AuditLog[]
  aiSkillOverrides       AiSkillOverride[]
  aiConversations        AiConversation[]
  aiMemories             AiMemory[]
  aiMemorySettings       AiMemorySettings[]
  aiConversationSummaries AiConversationSummary[]
  dataViews              DataView[]
  dateRangePresets       DateRangePreset[]
  savedViews             SavedView[]
  automations            AiAutomation[]

  @@index([baseCurrencyCode], map: "idx_company_profiles_base_currency_code")
  @@index([countryCode], map: "idx_company_profiles_country_code")
  @@index([isDefault], map: "idx_company_profiles_is_default")
  @@map("company_profiles")
}

enum SettingCategory {
  GENERAL
  FINANCE
  AR
  AP
  SALES
  PURCHASING
  INVENTORY
  CRM
  HR
  MANUFACTURING
  REPORTING

  @@map("setting_category")
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON

  @@map("setting_value_type")
}

model SystemSetting {
  id        String           @id @default(uuid()) @map("id")
  companyId String           @map("company_id")
  key       String           @map("key")
  value     String           @map("value") // JSON-serialised
  valueType SettingValueType @map("value_type")
  category  SettingCategory  @map("category")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company CompanyProfile @relation(fields: [companyId], references: [id])

  @@unique([companyId, key], map: "uq_system_settings_company_key")
  @@index([companyId, category], map: "idx_system_settings_company_category")
  @@map("system_settings")
}

// ---------------------------------------------------------------------------
// Multi-Company & RBAC Models — E1.3 Multi-Company Models
// ---------------------------------------------------------------------------

enum SharingMode {
  NONE
  ALL_COMPANIES
  SELECTED

  @@map("sharing_mode")
}

model RegisterSharingRule {
  id              String      @id @default(uuid()) @map("id")
  entityType      String      @map("entity_type")
  sharingMode     SharingMode @map("sharing_mode")
  sourceCompanyId String      @map("source_company_id")
  targetCompanyId String?     @map("target_company_id")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  sourceCompany CompanyProfile  @relation("SharingSource", fields: [sourceCompanyId], references: [id])
  targetCompany CompanyProfile? @relation("SharingTarget", fields: [targetCompanyId], references: [id])

  @@unique([entityType, sourceCompanyId, targetCompanyId], map: "uq_sharing_rule")
  // NOTE: Partial index for NULL targetCompanyId uniqueness added via raw SQL in migration:
  // CREATE UNIQUE INDEX "uq_sharing_rule_no_target" ON "register_sharing_rules" ("entity_type", "source_company_id") WHERE "target_company_id" IS NULL;
  // This prevents duplicate ALL_COMPANIES/NONE rules per entityType + sourceCompanyId (PostgreSQL treats NULLs as distinct in unique constraints).
  @@index([sourceCompanyId, entityType], map: "idx_sharing_rules_source_entity")
  @@index([targetCompanyId, entityType], map: "idx_sharing_rules_target_entity")
  @@map("register_sharing_rules")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
  VIEWER

  @@map("user_role")
}

enum ViewScope {
  PERSONAL
  ROLE
  GLOBAL

  @@map("view_scope")
}

enum FieldDataType {
  STRING
  NUMBER
  DATE
  BOOLEAN
  ENUM
  CURRENCY

  @@map("field_data_type")
}

enum LovType {
  NONE
  STATIC
  GLOBAL
  VIEW_SPECIFIC

  @@map("lov_type")
}

enum PinPosition {
  NONE
  LEFT
  RIGHT

  @@map("pin_position")
}

enum FilterOperator {
  EQUALS
  NOT_EQUALS
  CONTAINS
  STARTS_WITH
  ENDS_WITH
  GT
  GTE
  LT
  LTE
  BETWEEN
  IN
  NOT_IN
  IS_EMPTY
  IS_NOT_EMPTY

  @@map("filter_operator")
}

model UserCompanyRole {
  id        String   @id @default(uuid()) @map("id")
  userId    String   @map("user_id")
  companyId String?  @map("company_id")
  role      UserRole @map("role")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company CompanyProfile? @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId], map: "uq_user_company_role")
  // NOTE: Partial index for global role uniqueness added via raw SQL in migration:
  // CREATE UNIQUE INDEX "uq_user_company_role_global" ON "user_company_roles" ("user_id") WHERE "company_id" IS NULL;
  @@map("user_company_roles")
}

// ---------------------------------------------------------------------------
// User & Session Models — E1.4
// ---------------------------------------------------------------------------

model User {
  id             String    @id @default(uuid()) @map("id")
  email          String    @map("email")
  passwordHash   String    @map("password_hash")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  companyId      String    @map("company_id")
  mfaEnabled     Boolean   @default(false) @map("mfa_enabled")
  mfaSecret      String?   @map("mfa_secret")
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  enabledModules Json      @default("[]") @map("enabled_modules")
  locale         String    @default("en") @map("locale") @db.VarChar(10)

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  // Relations
  company            CompanyProfile    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyRoles       UserCompanyRole[]
  refreshTokens      RefreshToken[]
  managedDepartments Department[]            @relation("DepartmentManager")
  userAccessGroups   UserAccessGroup[]
  aiConversations        AiConversation[]
  aiMemories             AiMemory[]
  aiMemorySettings       AiMemorySettings[]
  aiConversationSummaries AiConversationSummary[]
  columnPreferences      UserColumnPreference[]
  savedViews             SavedView[]
  createdAutomations     AiAutomation[] @relation("UserCreatedAutomations")

  @@unique([email], map: "uq_users_email")
  @@index([companyId], map: "idx_users_company_id")
  @@index([isActive], map: "idx_users_is_active")
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @map("id")
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tokenHash], map: "uq_refresh_tokens_token_hash")
  @@index([userId, revokedAt], map: "idx_refresh_tokens_user_revoked")
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Number Series — E1.5
// ---------------------------------------------------------------------------

model NumberSeries {
  id         String  @id @default(uuid()) @map("id")
  companyId  String  @map("company_id")
  entityType String  @map("entity_type")
  prefix     String  @map("prefix")
  nextValue  Int     @default(1) @map("next_value")
  padding    Int     @default(5) @map("padding")
  suffix     String? @map("suffix")
  isActive   Boolean @default(true) @map("is_active")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company CompanyProfile @relation(fields: [companyId], references: [id])

  @@unique([companyId, entityType], map: "uq_number_series_company_entity")
  @@index([companyId], map: "idx_number_series_company_id")
  @@index([companyId, isActive], map: "idx_number_series_company_active")
  @@map("number_series")
}

// ---------------------------------------------------------------------------
// Granular RBAC — E2b.2
// ---------------------------------------------------------------------------

enum FieldVisibility {
  VISIBLE
  READ_ONLY
  HIDDEN

  @@map("field_visibility")
}

// ---------------------------------------------------------------------------
// Resource Registry — E2b.1
// ---------------------------------------------------------------------------
// Resource is a GLOBAL table (no companyId). It defines all controllable
// pages, reports, settings, and maintenances in the system. This is one of
// the few exceptions to the "companyId on every table" rule (Architecture §3b,
// Data Models §3.1).

enum ResourceType {
  PAGE
  REPORT
  SETTING
  MAINTENANCE

  @@map("resource_type")
}

model Resource {
  id          String       @id @default(uuid()) @map("id")
  code        String       @unique @map("code") @db.VarChar(100)
  name        String       @map("name") @db.VarChar(255)
  module      String       @map("module") @db.VarChar(50)
  type        ResourceType @map("type")
  parentCode  String?      @map("parent_code") @db.VarChar(100)
  sortOrder   Int          @default(0) @map("sort_order")
  icon        String?      @map("icon") @db.VarChar(100)
  description String?      @map("description") @db.Text
  isActive    Boolean      @default(true) @map("is_active")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Self-relation for hierarchy
  parent   Resource?  @relation("ResourceHierarchy", fields: [parentCode], references: [code])
  children Resource[] @relation("ResourceHierarchy")

  // Granular RBAC relations (E2b.2)
  permissions    AccessGroupPermission[]
  fieldOverrides AccessGroupFieldOverride[]

  @@index([module, sortOrder], map: "idx_resources_module_sort")
  @@index([type], map: "idx_resources_type")
  @@map("resources")
}

// ---------------------------------------------------------------------------
// Access Group Models — E2b.2
// ---------------------------------------------------------------------------

model AccessGroup {
  id          String  @id @default(uuid()) @map("id")
  companyId   String  @map("company_id")
  code        String  @map("code") @db.VarChar(50)
  name        String  @map("name") @db.VarChar(255)
  description String? @map("description") @db.Text
  isSystem    Boolean @default(false) @map("is_system")
  isActive    Boolean @default(true) @map("is_active")
  createdBy   String  @map("created_by")
  updatedBy   String  @map("updated_by")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company          CompanyProfile             @relation(fields: [companyId], references: [id])
  permissions      AccessGroupPermission[]
  fieldOverrides   AccessGroupFieldOverride[]
  userAccessGroups UserAccessGroup[]
  savedViews       SavedView[]

  @@unique([companyId, code], map: "uq_access_groups_company_code")
  @@index([companyId, isActive], map: "idx_access_groups_company_active")
  @@map("access_groups")
}

model AccessGroupPermission {
  id            String  @id @default(uuid()) @map("id")
  accessGroupId String  @map("access_group_id")
  resourceCode  String  @map("resource_code") @db.VarChar(100)
  canAccess     Boolean @default(false) @map("can_access")
  canNew        Boolean @default(false) @map("can_new")
  canView       Boolean @default(false) @map("can_view")
  canEdit       Boolean @default(false) @map("can_edit")
  canDelete     Boolean @default(false) @map("can_delete")

  // Relations
  accessGroup AccessGroup @relation(fields: [accessGroupId], references: [id], onDelete: Cascade)
  resource    Resource    @relation(fields: [resourceCode], references: [code])

  @@unique([accessGroupId, resourceCode], map: "uq_access_group_permissions_group_resource")
  @@map("access_group_permissions")
}

model AccessGroupFieldOverride {
  id            String          @id @default(uuid()) @map("id")
  accessGroupId String          @map("access_group_id")
  resourceCode  String          @map("resource_code") @db.VarChar(100)
  fieldPath     String          @map("field_path") @db.VarChar(255)
  visibility    FieldVisibility @map("visibility")

  // Relations
  accessGroup AccessGroup @relation(fields: [accessGroupId], references: [id], onDelete: Cascade)
  resource    Resource    @relation(fields: [resourceCode], references: [code])

  @@unique([accessGroupId, resourceCode, fieldPath], map: "uq_access_group_field_overrides_group_resource_field")
  @@map("access_group_field_overrides")
}

model UserAccessGroup {
  id            String   @id @default(uuid()) @map("id")
  userId        String   @map("user_id")
  accessGroupId String   @map("access_group_id")
  companyId     String   @map("company_id")
  assignedBy    String   @map("assigned_by")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations — Cascade on user/accessGroup matches UserCompanyRole.user pattern;
  // users are soft-deleted (isActive=false), so hard-delete cascade is a safety net only.
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessGroup AccessGroup    @relation(fields: [accessGroupId], references: [id], onDelete: Cascade)
  company     CompanyProfile @relation(fields: [companyId], references: [id])

  @@unique([userId, accessGroupId, companyId], map: "uq_user_access_groups_user_group_company")
  @@index([userId, companyId], map: "idx_user_access_groups_user_company")
  @@map("user_access_groups")
}

// ---------------------------------------------------------------------------
// Audit Trail — E3.2 (Architecture §2.6, IMP-003)
// ---------------------------------------------------------------------------
// Append-only audit log. NO updatedAt/updatedBy by design.
// PostgreSQL RULES enforce immutability at the database level (added in migration).

model AuditLog {
  id            String   @id @default(uuid()) @map("id")
  companyId     String   @map("company_id")
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id")
  action        String   @map("action")
  beforeData    Json?    @map("before_data")
  afterData     Json?    @map("after_data")
  userId        String   @map("user_id")
  isAiAction    Boolean  @default(false) @map("is_ai_action")
  aiConfidence  Decimal? @map("ai_confidence") @db.Decimal(5, 4)
  correlationId String?  @map("correlation_id")
  timestamp     DateTime @default(now()) @map("timestamp")

  // Relations
  company CompanyProfile @relation(fields: [companyId], references: [id])

  @@index([companyId, entityType, entityId], map: "idx_audit_logs_company_entity")
  @@index([companyId, userId, timestamp], map: "idx_audit_logs_company_user_time")
  @@index([companyId, timestamp], map: "idx_audit_logs_company_time")
  @@index([companyId, action], map: "idx_audit_logs_company_action")
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// AI Infrastructure Models — E5.1 AI Service Layer
// ---------------------------------------------------------------------------
// AI models are cross-cutting infrastructure, not a business module.
// AiMessage and AiFeedback are append-only (no updatedAt).
// AiPromptVersion is immutable version history (no updatedAt).
// All tenant-scoped entities use companyId FK.
// ---------------------------------------------------------------------------

model AiModel {
  id              String   @id @default(uuid()) @map("id")
  name            String   @unique(map: "uq_ai_models_name") @map("name")
  provider        String   @map("provider")
  modelId         String   @map("model_id")
  displayName     String   @map("display_name")
  maxInputTokens  Int      @map("max_input_tokens")
  maxOutputTokens Int      @map("max_output_tokens")
  costPerMInput   Decimal  @map("cost_per_m_input") @db.Decimal(10, 4)
  costPerMOutput  Decimal  @map("cost_per_m_output") @db.Decimal(10, 4)
  capabilities    Json     @map("capabilities")
  isActive        Boolean  @default(true) @map("is_active")
  isDefault       Boolean  @default(false) @map("is_default")
  config          Json?    @map("config")
  fallbackModelId String?  @map("fallback_model_id")
  routingTags     String[] @map("routing_tags")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Self-relation for fallback
  fallbackModel AiModel?  @relation("AiModelFallback", fields: [fallbackModelId], references: [id])
  fallbackOf    AiModel[] @relation("AiModelFallback")

  // Reverse relations
  agents   AiAgent[]
  messages AiMessage[]
  usage    AiUsage[]

  @@map("ai_models")
}

model AiPrompt {
  id            String  @id @default(uuid()) @map("id")
  name          String  @unique(map: "uq_ai_prompts_name") @map("name")
  description   String? @map("description")
  category      String  @map("category")
  systemPrompt  String  @map("system_prompt") @db.Text
  userTemplate  String  @map("user_template") @db.Text
  parameters    Json    @map("parameters")
  outputFormat  Json?   @map("output_format")
  activeVersion Int     @default(1) @map("active_version")
  isActive      Boolean @default(true) @map("is_active")
  createdBy     String  @map("created_by")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  versions  AiPromptVersion[]
  agents    AiAgent[]
  variables AiPromptVariable[]

  @@map("ai_prompts")
}

model AiPromptVersion {
  id           String  @id @default(uuid()) @map("id")
  promptId     String  @map("prompt_id")
  version      Int     @map("version")
  systemPrompt String  @map("system_prompt") @db.Text
  userTemplate String  @map("user_template") @db.Text
  parameters   Json    @map("parameters")
  changeReason String? @map("change_reason")
  createdBy    String  @map("created_by")

  // Append-only — version history, no updatedAt
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  prompt AiPrompt @relation(fields: [promptId], references: [id])

  @@unique([promptId, version], map: "uq_ai_prompt_versions_prompt_version")
  @@map("ai_prompt_versions")
}

model AiAgent {
  id            String   @id @default(uuid()) @map("id")
  name          String   @unique(map: "uq_ai_agents_name") @map("name")
  displayName   String   @map("display_name")
  description   String?  @map("description")
  modelId       String?  @map("model_id")
  routingTags   String[] @map("routing_tags")
  promptId      String   @map("prompt_id")
  tools         Json     @map("tools")
  guardrails    Json     @map("guardrails")
  triggerConfig Json     @map("trigger_config")
  maxTurns      Int      @default(10) @map("max_turns")
  isActive      Boolean  @default(true) @map("is_active")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  model  AiModel? @relation(fields: [modelId], references: [id])
  prompt AiPrompt @relation(fields: [promptId], references: [id])

  // Reverse relations
  conversations      AiConversation[]
  usage              AiUsage[]
  evals              AiEval[]
  automationSteps    AiAutomationStep[]
  automationStepRuns AiAutomationStepRun[]

  @@map("ai_agents")
}

model AiSkill {
  id            String   @id @default(uuid()) @map("id")
  name          String   @unique(map: "uq_ai_skills_name") @map("name")
  displayName   String   @map("display_name")
  description   String?  @map("description")
  category      String   @map("category")
  skillContent  String   @map("skill_content") @db.Text
  triggerPhrases String[] @map("trigger_phrases")
  inputSchema   Json     @map("input_schema")
  outputType    String   @map("output_type")
  requiredTools String[] @map("required_tools")
  isActive      Boolean  @default(true) @map("is_active")

  // E5b-2: Enhanced skill registry fields
  moduleKey            String?  @map("module_key")
  packKey              String?  @map("pack_key")
  negativeTriggers     String[] @map("negative_triggers")
  contextRequired      String[] @map("context_required")
  orchestrationPattern String?  @map("orchestration_pattern")
  parameters           Json?    @map("parameters")
  examples             Json?    @map("examples")
  priority             Int      @default(100) @map("priority")
  version              Int      @default(1) @map("version")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations (E5b-2)
  contexts  AiSkillContext[]
  overrides AiSkillOverride[]

  @@index([moduleKey, isActive], map: "idx_ai_skills_module")
  @@map("ai_skills")
}

model AiSkillContext {
  id              String   @id @default(uuid()) @map("id")
  skillId         String   @map("skill_id")
  contextKey      String   @map("context_key") @db.VarChar(255)
  contextQuery    String   @map("context_query") @db.Text
  tokenBudget     Int      @default(500) @map("token_budget")
  cacheTtlSeconds Int      @default(300) @map("cache_ttl_seconds")
  isRequired      Boolean  @default(false) @map("is_required")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  skill AiSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@map("ai_skill_contexts")
  @@index([skillId], map: "idx_skill_contexts_skill")
}

model AiModuleKnowledge {
  id            String   @id @default(uuid()) @map("id")
  moduleKey     String   @map("module_key")
  knowledgeType String   @map("knowledge_type")
  title         String   @db.VarChar(500)
  content       String   @db.Text
  priority      Int      @default(100) @map("priority")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("ai_module_knowledge")
  @@index([moduleKey, knowledgeType, isActive], map: "idx_module_knowledge")
}

model AiSkillOverride {
  id                     String   @id @default(uuid()) @map("id")
  skillId                String   @map("skill_id")
  companyId              String   @map("company_id")
  isActive               Boolean? @map("is_active")
  triggerPhrasesOverride String[] @map("trigger_phrases_override")
  priorityOverride       Int?     @map("priority_override")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  skill   AiSkill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("ai_skill_overrides")
  @@unique([skillId, companyId], map: "uq_skill_override")
}

model AiEntityTrigger {
  id             String   @id @default(uuid()) @map("id")
  moduleKey      String   @map("module_key")
  triggerWord    String   @map("trigger_word")
  entityType     String   @map("entity_type")
  searchEndpoint String   @map("search_endpoint")
  displayField   String   @map("display_field")
  subtitleField  String?  @map("subtitle_field")
  scopeBy        String?  @map("scope_by")
  icon           String?
  priority       Int      @default(100) @map("priority")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("ai_entity_triggers")
  @@unique([moduleKey, triggerWord], map: "uq_entity_trigger")
  @@index([isActive], map: "idx_entity_triggers_active")
}

model AiConversation {
  id        String    @id @default(uuid()) @map("id")
  userId    String    @map("user_id")
  agentId   String?   @map("agent_id")
  channel   String    @map("channel")
  title     String?   @map("title") @db.VarChar(255)
  status    String    @default("active") @map("status")
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  companyId String    @map("company_id")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user    User           @relation(fields: [userId], references: [id])
  agent   AiAgent?       @relation(fields: [agentId], references: [id])
  company CompanyProfile @relation(fields: [companyId], references: [id])

  // Reverse relations
  messages  AiMessage[]
  summaries AiConversationSummary[]

  @@index([userId, startedAt], map: "idx_ai_conversations_user_started")
  @@index([companyId], map: "idx_ai_conversations_company_id")
  @@map("ai_conversations")
}

model AiMessage {
  id              String   @id @default(uuid()) @map("id")
  conversationId  String   @map("conversation_id")
  role            String   @map("role")
  content         String   @map("content") @db.Text
  toolCalls       Json?    @map("tool_calls")
  toolResults     Json?    @map("tool_results")
  modelId         String?  @map("model_id")
  promptVersionId String?  @map("prompt_version_id")
  inputTokens     Int?     @map("input_tokens")
  outputTokens    Int?     @map("output_tokens")
  latencyMs       Int?     @map("latency_ms")
  confidence      Decimal? @map("confidence") @db.Decimal(3, 2)

  // Append-only — no updatedAt
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  conversation AiConversation @relation(fields: [conversationId], references: [id])
  model        AiModel?       @relation(fields: [modelId], references: [id])

  // Reverse relations
  feedback AiFeedback?

  @@index([conversationId, createdAt], map: "idx_ai_messages_conversation_created")
  @@map("ai_messages")
}

model AiFeedback {
  id           String  @id @default(uuid()) @map("id")
  messageId    String  @unique(map: "uq_ai_feedback_message_id") @map("message_id")
  userId       String  @map("user_id")
  rating       Int     @map("rating")
  editedFields Json?   @map("edited_fields")
  wasApproved  Boolean @map("was_approved")
  comment      String? @map("comment") @db.Text

  // Append-only — no updatedAt
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  message AiMessage @relation(fields: [messageId], references: [id])

  @@index([userId, createdAt], map: "idx_ai_feedback_user_created")
  @@map("ai_feedback")
}

model AiUsage {
  id           String   @id @default(uuid()) @map("id")
  tenantId     String   @map("tenant_id")
  modelId      String   @map("model_id")
  agentId      String?  @map("agent_id")
  date         DateTime @map("date") @db.Date
  requestCount Int      @map("request_count")
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  totalCost    Decimal  @map("total_cost") @db.Decimal(10, 4)

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  model AiModel  @relation(fields: [modelId], references: [id])
  agent AiAgent? @relation(fields: [agentId], references: [id])

  @@unique([tenantId, modelId, agentId, date], map: "uq_ai_usage_tenant_model_agent_date")
  // NOTE: Partial unique index for NULL agentId added via raw SQL in migration:
  // CREATE UNIQUE INDEX "uq_ai_usage_tenant_model_date_no_agent" ON "ai_usage" ("tenant_id", "model_id", "date") WHERE "agent_id" IS NULL;
  @@map("ai_usage")
}

model AiEval {
  id               String   @id @default(uuid()) @map("id")
  agentId          String   @map("agent_id")
  promptVersion    Int      @map("prompt_version")
  evalDate         DateTime @map("eval_date") @db.Date
  sampleSize       Int      @map("sample_size")
  accuracy         Decimal  @map("accuracy") @db.Decimal(5, 2)
  approvalRate     Decimal  @map("approval_rate") @db.Decimal(5, 2)
  avgLatencyMs     Int      @map("avg_latency_ms")
  avgCostPerAction Decimal  @map("avg_cost_per_action") @db.Decimal(10, 4)
  metrics          Json     @map("metrics")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agent AiAgent @relation(fields: [agentId], references: [id])

  @@index([agentId, evalDate], map: "idx_ai_evals_agent_eval_date")
  @@map("ai_evals")
}

// ---------------------------------------------------------------------------
// AI Memory Infrastructure — E5b.1
// ---------------------------------------------------------------------------

model AiMemory {
  id             String    @id @default(uuid()) @map("id")
  userId         String    @map("user_id")
  companyId      String    @map("company_id")
  category       String    @map("category") // PREFERENCE, WORKFLOW, ENTITY_CONTEXT, DECISION, INSTRUCTION
  content        String    @map("content") @db.Text
  source         String    @map("source") // EXPLICIT, IMPLICIT
  importance     Decimal   @default(1.0) @map("importance") @db.Decimal(5, 2)
  lastAccessedAt DateTime  @default(now()) @map("last_accessed_at")
  metadata       Json?     @map("metadata")

  // Vector search columns — managed via raw SQL in migration (Prisma doesn't support pgvector natively)
  embedding    Unsupported("vector(1536)")? @map("embedding")
  searchVector Unsupported("tsvector")?     @map("search_vector")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user    User           @relation(fields: [userId], references: [id])
  company CompanyProfile @relation(fields: [companyId], references: [id])

  @@index([userId, companyId, category], map: "idx_ai_memories_user_company_category")
  @@index([userId, companyId, importance(sort: Desc)], map: "idx_ai_memories_user_company_importance")
  @@index([userId, companyId, lastAccessedAt], map: "idx_ai_memories_user_company_accessed")
  @@map("ai_memories")
}

model AiConversationSummary {
  id              String   @id @default(uuid()) @map("id")
  userId          String   @map("user_id")
  companyId       String   @map("company_id")
  conversationId  String   @map("conversation_id")
  summary         String   @map("summary") @db.Text
  topics          String[] @map("topics")
  decisionsCount  Int      @default(0) @map("decisions_count")
  actionsCount    Int      @default(0) @map("actions_count")

  // Append-only — no updatedAt
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user         User           @relation(fields: [userId], references: [id])
  company      CompanyProfile @relation(fields: [companyId], references: [id])
  conversation AiConversation @relation(fields: [conversationId], references: [id])

  @@index([userId, companyId, createdAt(sort: Desc)], map: "idx_ai_conv_summaries_user_company_created")
  @@map("ai_conversation_summaries")
}

model AiMemorySettings {
  id                String   @id @default(uuid()) @map("id")
  userId            String   @map("user_id")
  companyId         String   @map("company_id")
  isEnabled         Boolean  @default(true) @map("is_enabled")
  enabledCategories String[] @default(["PREFERENCE", "WORKFLOW", "ENTITY_CONTEXT", "DECISION", "INSTRUCTION"]) @map("enabled_categories")
  retentionDays     Int      @default(365) @map("retention_days")
  maxMemories       Int      @default(500) @map("max_memories")
  decayHalfLifeDays Int      @default(30) @map("decay_half_life_days")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user    User           @relation(fields: [userId], references: [id])
  company CompanyProfile @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId], map: "uq_ai_memory_settings_user_company")
  @@map("ai_memory_settings")
}

// ---------------------------------------------------------------------------
// AI Automation Infrastructure — E5c.1
// ---------------------------------------------------------------------------
// Goal-oriented automation engine: scheduled, event-triggered, and chained
// workflows with sequential step execution and I/O piping.
// AiAutomationRun and AiAutomationStepRun are append-only (no updatedAt).
// ---------------------------------------------------------------------------

model AiAutomation {
  id                 String   @id @default(uuid()) @map("id")
  companyId          String   @map("company_id")
  name               String   @map("name") @db.VarChar(255)
  description        String?  @map("description") @db.Text
  triggerType        String   @map("trigger_type") // SCHEDULED, EVENT, CHAIN, MANUAL
  eventType          String?  @map("event_type") @db.VarChar(255)
  chainFromId        String?  @unique @map("chain_from_id")
  chainNextId        String?  @unique @map("chain_next_id")
  notificationConfig Json?    @map("notification_config")
  maxTokenBudget     Int      @default(50000) @map("max_token_budget")
  maxDurationMs      Int      @default(300000) @map("max_duration_ms")
  isActive           Boolean  @default(true) @map("is_active")
  createdById        String   @map("created_by_id")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company   CompanyProfile @relation(fields: [companyId], references: [id])
  createdBy User           @relation("UserCreatedAutomations", fields: [createdById], references: [id])

  // Self-referential chain relations
  chainFrom AiAutomation?  @relation("AutomationChainFrom", fields: [chainFromId], references: [id])
  chainedBy AiAutomation?  @relation("AutomationChainFrom")
  chainNext AiAutomation?  @relation("AutomationChainNext", fields: [chainNextId], references: [id])
  chainedTo AiAutomation?  @relation("AutomationChainNext")

  // Reverse relations
  schedule AiAutomationSchedule?
  steps    AiAutomationStep[]
  runs     AiAutomationRun[]

  @@index([companyId, isActive], map: "idx_ai_automations_company_active")
  @@index([triggerType], map: "idx_ai_automations_trigger_type")
  @@map("ai_automations")
}

model AiAutomationStep {
  id           String @id @default(uuid()) @map("id")
  automationId String @map("automation_id")
  stepOrder    Int    @map("step_order")
  agentId      String @map("agent_id")
  goal         String @map("goal") @db.Text
  inputConfig  Json   @map("input_config")
  outputConfig Json   @map("output_config")
  maxTurns     Int    @default(10) @map("max_turns")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  automation AiAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  agent      AiAgent      @relation(fields: [agentId], references: [id])

  // Reverse relations
  stepRuns AiAutomationStepRun[]

  @@unique([automationId, stepOrder], map: "uq_ai_automation_steps_automation_order")
  @@map("ai_automation_steps")
}

model AiAutomationSchedule {
  id             String    @id @default(uuid()) @map("id")
  automationId   String    @unique @map("automation_id")
  cronExpression String    @map("cron_expression") @db.VarChar(100)
  timezone       String    @default("Europe/London") @map("timezone") @db.VarChar(50)
  nextRunAt      DateTime? @map("next_run_at")
  lastRunAt      DateTime? @map("last_run_at")
  isPaused       Boolean   @default(false) @map("is_paused")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  automation AiAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([nextRunAt, isPaused], map: "idx_ai_automation_schedules_next_run_paused")
  @@map("ai_automation_schedules")
}

model AiAutomationRun {
  id           String    @id @default(uuid()) @map("id")
  automationId String    @map("automation_id")
  triggeredBy  String    @map("triggered_by") // 'scheduler', 'event', 'chain', 'manual:{userId}'
  status       String    @default("PENDING") @map("status") // PENDING, RUNNING, COMPLETED, FAILED, CANCELLED
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  totalTokens  Int       @default(0) @map("total_tokens")
  totalCost    Decimal   @default(0) @map("total_cost") @db.Decimal(10, 4)
  result       Json?     @map("result")
  error        String?   @map("error") @db.Text
  retryOfRunId String?   @map("retry_of_run_id")

  // Append-only — no updatedAt
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  automation AiAutomation @relation(fields: [automationId], references: [id])

  // Reverse relations
  stepRuns AiAutomationStepRun[]

  @@index([automationId, createdAt], map: "idx_ai_automation_runs_automation_created")
  @@index([status], map: "idx_ai_automation_runs_status")
  @@map("ai_automation_runs")
}

model AiAutomationStepRun {
  id          String    @id @default(uuid()) @map("id")
  runId       String    @map("run_id")
  stepId      String    @map("step_id")
  status      String    @default("PENDING") @map("status") // PENDING, RUNNING, COMPLETED, FAILED, SKIPPED
  agentId     String    @map("agent_id")
  modelId     String?   @map("model_id")
  input       Json?     @map("input")
  output      Json?     @map("output")
  error       String?   @map("error") @db.Text
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  latencyMs   Int?      @map("latency_ms")
  turns       Int       @default(0) @map("turns")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  // Append-only — no updatedAt
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  run   AiAutomationRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  step  AiAutomationStep @relation(fields: [stepId], references: [id])
  agent AiAgent           @relation(fields: [agentId], references: [id])

  @@index([runId, createdAt], map: "idx_ai_automation_step_runs_run_created")
  @@map("ai_automation_step_runs")
}

model AiPromptVariable {
  id           String  @id @default(uuid()) @map("id")
  promptId     String  @map("prompt_id")
  variableName String  @map("variable_name") @db.VarChar(100)
  displayName  String  @map("display_name") @db.VarChar(255)
  description  String? @map("description") @db.Text
  sourceType   String  @map("source_type") // DB_FIELD, DB_QUERY, PAGE_FIELD, SYSTEM, CONSTANT, EXPRESSION
  sourceConfig Json    @map("source_config")
  defaultValue String? @map("default_value") @db.Text
  isRequired   Boolean @default(false) @map("is_required")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  prompt AiPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, variableName], map: "uq_ai_prompt_variables_prompt_variable")
  @@map("ai_prompt_variables")
}

// ---------------------------------------------------------------------------
// Metadata-Driven DataTable Infrastructure — E7.1
// ---------------------------------------------------------------------------
// 3-tier architecture:
//   1. Metadata Layer: DataView + DataViewField + DateRangePreset
//   2. User Personalisation Layer: UserColumnPreference + SavedView
//   3. Filter Persistence Layer: SavedViewCondition
// ---------------------------------------------------------------------------

model DataView {
  id               String   @id @default(uuid())
  companyId        String   @map("company_id")
  viewKey          String   @map("view_key") @db.VarChar(50)
  viewName         String   @map("view_name") @db.VarChar(100)
  entityTable      String   @map("entity_table") @db.VarChar(100)
  idField          String   @map("id_field") @db.VarChar(50)
  defaultSortField String   @map("default_sort_field") @db.VarChar(50)
  defaultSortDir   String   @map("default_sort_dir") @db.VarChar(4) @default("DESC")
  isActive         Boolean  @default(true) @map("is_active")
  createdBy        String   @default("system") @map("created_by")
  updatedBy        String   @default("system") @map("updated_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  company    CompanyProfile  @relation(fields: [companyId], references: [id])
  fields     DataViewField[]
  savedViews SavedView[]

  @@unique([companyId, viewKey], map: "uq_data_views_company_view_key")
  @@map("data_views")
}

model DataViewField {
  id                 String        @id @default(uuid())
  dataViewId         String        @map("data_view_id")
  fieldKey           String        @map("field_key") @db.VarChar(100)
  fieldLabel         String        @map("field_label") @db.VarChar(100)
  fieldType          FieldDataType @map("field_type")
  defaultVisible     Boolean       @default(true) @map("default_visible")
  defaultOrder       Int           @map("default_order")
  defaultWidth       Int           @default(150) @map("default_width")
  sortable           Boolean       @default(true)
  filterable         Boolean       @default(true)
  advancedFilterOnly Boolean       @default(false) @map("advanced_filter_only")
  pinnable           Boolean       @default(true)
  lovType            LovType       @default(NONE) @map("lov_type")
  lovScope           String?       @map("lov_scope") @db.VarChar(50)
  lovStaticValues    Json?         @map("lov_static_values") @db.JsonB
  lovDependsOn       String?       @map("lov_depends_on") @db.VarChar(100)
  lovSearchMin       Int           @default(0) @map("lov_search_min")
  isActive           Boolean       @default(true) @map("is_active")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  dataView              DataView               @relation(fields: [dataViewId], references: [id], onDelete: Cascade)
  userColumnPreferences UserColumnPreference[]
  savedViewConditions   SavedViewCondition[]

  @@unique([dataViewId, fieldKey], map: "uq_data_view_fields_view_field_key")
  @@index([dataViewId, defaultOrder], map: "idx_data_view_fields_view_order")
  @@map("data_view_fields")
}

model DateRangePreset {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  presetKey   String   @map("preset_key") @db.VarChar(30)
  presetName  String   @map("preset_name") @db.VarChar(50)
  orderInList Int      @map("order_in_list")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company             CompanyProfile       @relation(fields: [companyId], references: [id])
  savedViewConditions SavedViewCondition[]

  @@unique([companyId, presetKey], map: "uq_date_range_presets_company_key")
  @@map("date_range_presets")
}

model UserColumnPreference {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  dataViewFieldId String      @map("data_view_field_id")
  visible         Boolean     @default(true)
  displayOrder    Int         @map("display_order")
  width           Int
  pinned          PinPosition @default(NONE)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataViewField DataViewField @relation(fields: [dataViewFieldId], references: [id], onDelete: Cascade)

  @@unique([userId, dataViewFieldId], map: "uq_user_column_prefs_user_field")
  @@map("user_column_preferences")
}

model SavedView {
  id             String    @id @default(uuid())
  companyId      String    @map("company_id")
  dataViewId     String    @map("data_view_id")
  name           String    @db.VarChar(100)
  groupName      String    @map("group_name") @db.VarChar(100)
  scope          ViewScope @default(PERSONAL)
  roleId         String?   @map("role_id")
  createdBy      String    @map("created_by")
  isFavourite    Boolean   @default(false) @map("is_favourite")
  favouriteOrder Int       @default(0) @map("favourite_order")
  isDefault      Boolean   @default(false) @map("is_default")
  filterLogic    String    @default("AND") @map("filter_logic") @db.VarChar(3)
  sortConfig     Json      @map("sort_config") @db.JsonB
  columnConfig   Json      @map("column_config") @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  company    CompanyProfile       @relation(fields: [companyId], references: [id])
  dataView   DataView             @relation(fields: [dataViewId], references: [id], onDelete: Cascade)
  creator    User                 @relation(fields: [createdBy], references: [id])
  role       AccessGroup?         @relation(fields: [roleId], references: [id])
  conditions SavedViewCondition[]

  @@unique([companyId, dataViewId, createdBy, name], map: "uq_saved_views_company_view_user_name")
  @@index([companyId, dataViewId, scope], map: "idx_saved_views_company_view_scope")
  @@map("saved_views")
}

model SavedViewCondition {
  id              String         @id @default(uuid())
  savedViewId     String         @map("saved_view_id")
  dataViewFieldId String         @map("data_view_field_id")
  operator        FilterOperator
  value           String?        @db.Text
  valueList       Json?          @map("value_list") @db.JsonB
  datePresetId    String?        @map("date_preset_id")
  groupId         Int            @default(0) @map("group_id")
  groupLogic      String         @default("AND") @map("group_logic") @db.VarChar(3)
  outerLogic      String         @default("AND") @map("outer_logic") @db.VarChar(3)
  conditionOrder  Int            @map("condition_order")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  savedView     SavedView        @relation(fields: [savedViewId], references: [id], onDelete: Cascade)
  dataViewField DataViewField    @relation(fields: [dataViewFieldId], references: [id])
  datePreset    DateRangePreset? @relation(fields: [datePresetId], references: [id])

  @@index([savedViewId, conditionOrder], map: "idx_saved_view_conditions_view_order")
  @@map("saved_view_conditions")
}

// ---------------------------------------------------------------------------
// Cross-Cutting Module — E8.1 Attachment (Architecture §2.20)
// ---------------------------------------------------------------------------
// Polymorphic file attachments. No companyId — company scope enforced through
// parent entity validation (entityType + entityId checked against caller's
// companyId on every operation). See Architecture §2.20.
// ---------------------------------------------------------------------------

model Attachment {
  id            String   @id @default(uuid())

  // ── Polymorphic Link ──
  entityType    String   @map("entity_type") @db.VarChar(100)
  entityId      String   @map("entity_id")

  // ── File Metadata ──
  fileName      String   @map("file_name") @db.VarChar(200)
  fileSize      Int      @map("file_size")
  mimeType      String   @map("mime_type") @db.VarChar(100)

  // ── Storage Location ──
  storageKey    String   @map("storage_key") @db.VarChar(500)
  storageBucket String   @map("storage_bucket") @db.VarChar(100)

  // ── Optional Description ──
  description   String?  @db.VarChar(500)

  // ── Upload Tracking ──
  uploadedBy    String   @map("uploaded_by")
  uploadedAt    DateTime @default(now()) @map("uploaded_at")

  // ── Standard Fields ──
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("attachments")
  @@index([entityType, entityId], map: "idx_attachments_entity")
  @@index([uploadedBy], map: "idx_attachments_uploaded_by")
}

// ---------------------------------------------------------------------------
// Note Type Enum — E8.2 Notes Service
// ---------------------------------------------------------------------------

enum NoteType {
  GENERAL
  INTERNAL
  CUSTOMER_VISIBLE
  SYSTEM

  @@map("note_type")
}

// ---------------------------------------------------------------------------
// Note Model — E8.2 Notes Service
// ---------------------------------------------------------------------------
// Polymorphic notes. No companyId — company scope enforced through parent
// entity validation (entityType + entityId checked against caller's companyId
// on every operation). See Architecture §2.20.
// ---------------------------------------------------------------------------

model Note {
  id             String    @id @default(uuid())

  // ── Polymorphic Link ──
  entityType     String    @map("entity_type") @db.VarChar(100)
  entityId       String    @map("entity_id")

  // ── Note Content ──
  noteType       NoteType  @default(GENERAL) @map("note_type")
  classification String?   @map("classification") @db.VarChar(60)
  title          String?   @map("title") @db.VarChar(200)
  content        String    @map("content") @db.Text

  // ── Flags ──
  isPinned       Boolean   @default(false) @map("is_pinned")

  // ── Soft Delete ──
  deletedAt      DateTime? @map("deleted_at")

  // ── Standard Fields ──
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      String    @map("created_by")
  updatedBy      String    @map("updated_by")

  @@map("notes")
  @@index([entityType, entityId, deletedAt], map: "idx_notes_entity_active")
  @@index([noteType], map: "idx_notes_type")
}

// ---------------------------------------------------------------------------
// Record Link Type Enum — E8.3 Record Links Service
// ---------------------------------------------------------------------------

enum RecordLinkType {
  CREATED_FROM
  FULFILLS
  PAYMENT_FOR
  CREDIT_FOR
  RELATES_TO
  PARENT_CHILD

  @@map("record_link_type")
}

// ---------------------------------------------------------------------------
// RecordLink Model — E8.3 Record Links Service (Architecture §2.20)
// ---------------------------------------------------------------------------
// Polymorphic record-to-record links. No companyId — company scope enforced
// through parent entity validation on BOTH source and target entities.
// See Architecture §2.20.
// ---------------------------------------------------------------------------

model RecordLink {
  id                String         @id @default(uuid())

  // ── Source Entity (Polymorphic) ──
  sourceEntityType  String         @map("source_entity_type") @db.VarChar(100)
  sourceEntityId    String         @map("source_entity_id")

  // ── Target Entity (Polymorphic) ──
  targetEntityType  String         @map("target_entity_type") @db.VarChar(100)
  targetEntityId    String         @map("target_entity_id")

  // ── Link Metadata ──
  linkType          RecordLinkType @map("link_type")
  isSystemGenerated Boolean        @default(false) @map("is_system_generated")
  description       String?        @db.VarChar(500)

  // ── Standard Fields ──
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  createdBy         String         @map("created_by")

  @@map("record_links")
  @@unique([sourceEntityType, sourceEntityId, targetEntityType, targetEntityId, linkType], map: "uq_record_links_source_target_type")
  @@index([sourceEntityType, sourceEntityId], map: "idx_record_links_source")
  @@index([targetEntityType, targetEntityId], map: "idx_record_links_target")
  @@index([linkType], map: "idx_record_links_link_type")
}
