# Platform Admin — Environment Variables
#
# VITE_PLATFORM_API_BASE_URL
#   Dev: Leave unset — Vite proxy rewrites /api/v1/* to http://localhost:5101/*
#   Production: Set to the Platform API origin (e.g., https://platform-api.nexa.example.com)
#   The API client prepends this to all request paths like /admin/intelligence/summary
#
# VITE_PLATFORM_API_BASE_URL=https://platform-api.nexa.example.com
